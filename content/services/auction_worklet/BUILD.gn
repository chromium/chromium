import("//v8/gni/v8.gni")

source_set("auction_worklet") {
  sources = [
    "auction_downloader.cc",
    "auction_downloader.h",
    "auction_v8_helper.cc",
    "auction_v8_helper.h",
    "bidder_worklet.cc",
    "bidder_worklet.h",
    "report_bindings.cc",
    "report_bindings.h",
    "seller_worklet.cc",
    "seller_worklet.h",
    "trusted_bidding_signals.cc",
    "trusted_bidding_signals.h",
    "worklet_loader.cc",
    "worklet_loader.h",
  ]

  configs += [
    "//build/config/compiler:wexit_time_destructors",
    "//v8:external_startup_data",
  ]

  deps = [
    "//base",
    "//content/public/common",
    "//gin",
    "//mojo/public/cpp/bindings",
    "//net",
    "//services/network/public/cpp",
    "//url",
    "//v8",
  ]
}

source_set("tests") {
  testonly = true

  sources = [
    "auction_downloader_unittest.cc",
    "bidder_worklet_unittest.cc",
    "seller_worklet_unittest.cc",
    "trusted_bidding_signals_unittest.cc",
    "worklet_loader_unittest.cc",
  ]

  deps = [
    ":auction_worklet",
    "//base",
    "//base/test:test_support",
    "//content/public/common",
    "//net",
    "//services/network:test_support",
    "//services/service_manager/public/cpp/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]

  if (v8_use_external_startup_data) {
    deps += [ "//gin" ]
  }

  if (is_android) {
    deps += [ "//v8:v8_external_startup_data_assets" ]
  }

  configs += [ "//v8:external_startup_data" ]
}
