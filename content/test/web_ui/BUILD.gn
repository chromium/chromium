import("//mojo/public/tools/bindings/mojom.gni")

mojom_with_js_interface_binder("test_js_interface_binder") {
  testonly = true
  source = "js_interface_binder_unittest.test-mojom"

  webui_controller = "content::TestJsInterfaceBinderUI"
  webui_controller_header =
      "//content/browser/webui/test_js_interface_binder_ui.h"
  webui_controller_deps = [ "//content/test:test_support" ]
}

mojom_with_js_interface_binder("test_js_interface_binder2") {
  testonly = true
  source = "js_interface_binder_unittest2.test-mojom"
  public_deps = [ ":test_secondary_interface" ]

  webui_controller = "content::TestJsInterfaceBinderUI"
  webui_controller_header =
      "//content/browser/webui/test_js_interface_binder_ui.h"
  webui_controller_deps = [ "//content/test:test_support" ]
}

mojom("test_secondary_interface") {
  testonly = true
  sources = [ "test_secondary_interface.test-mojom" ]
  public_deps = [ "//mojo/public/mojom/base" ]
}
