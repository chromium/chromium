# Basic test case: create a storage area and perform a Put operation

actions {
  new_storage_area {
    id: 0
    origin_id: ORIGIN_A
    renderer_id: RENDERER_A
  }
}
actions {
  storage_area_remote_action {
    id: 0
    m_put {
      m_key {
        values { value: 107 }
        values { value: 101 }
        values { value: 121 }
      }
      m_value {
        values { value: 118 }
        values { value: 97 }
        values { value: 108 }
      }
    }
  }
}

