<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1412240523210238692">бһҖбһ¶бһҡбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһўбһҸбҹ’бһҗбһ”бһ‘</translation>
<translation id="1542044944667958430">бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһӮбҹҒбһ бһ‘бҹҶбһ–бҹҗбһҡ</translation>
<translation id="1768717197362323622">бһҳбһёбһӣбһёбһңбһ·бһ“бһ¶бһ‘бһё</translation>
<translation id="1822429046913737220">бһ–бҹ’бһҡбһ№бһҖ/бһӣбҹ’бһ„бһ¶бһ…</translation>
<translation id="2094750046714988961">бһҳбһ·бһ“бһўбһ¶бһ…бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҳбҹ’бһ…бһ¶бһҹбҹӢбһ‘бһҳбҹ’бһҡбһ„бҹӢбһ‘бҹҒ бһ–бһёбһ–бҹ’бһҡбҹ„бҹҮбһ§бһ”бһҖбһҡбһҺбҹҚбһ•бҹ’бһ‘бһ»бһҖбһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ…бһ“бһ№бһ„бһ‘бһ¶бһ“бҹӢбһҡбһҪбһ…бһҡбһ¶бһӣбҹӢбһ‘бҹҒ</translation>
<translation id="2429669115401274487">бһӣбҹ’бһ„бһ¶бһ…</translation>
<translation id="2520230379124234395">бһҳбҹ’бһ…бһ¶бһҹбҹӢбһ‘бһҳбҹ’бһҡбһ„бҹӢбһ”бһ¶бһ“бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ</translation>
<translation id="2732718972699418926">бһ–бҹ’бһҡбһ№бһҖ</translation>
<translation id="2841013758207633010">бһ–бҹҒбһӣбһңбҹҒбһӣбһ¶</translation>
<translation id="3252174836838062892">бһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһ‘бһҹбҹ’бһҹбһ“бҹҚбһ‘бҹ’бһҡбһ“бһ·бһ…вҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ бһҹбһјбһҳбһ…бһ»бһ… ESC</translation>
<translation id="376869769528291915">:</translation>
<translation id="3845599764535987402">бһҳбҹүбҹ„бһ„</translation>
<translation id="4247305538398689241">бһҖбҹҶбһҺбһҸбҹӢбһҹбһ”бҹ’бһҸбһ¶бһ бҹҚ</translation>
<translation id="4768459022382175196">бһңбһ·бһ“бһ¶бһ‘бһё</translation>
<translation id="4859501799452851758">бһ‘бһҳбҹ’бһҡбһ„бҹӢбһ”бһ¶бһ“бһ”бһүбҹ’бһ…бһ”бҹӢбҹ” бһӣбһ‘бҹ’бһ’бһ•бһӣбһ“бҹ…бһҖбҹ’бһ“бһ»бһ„ <ph name="FILENAME" />бҹ”</translation>
<translation id="4932733599132424254">бһҖбһ¶бһӣбһ”бһҡбһ·бһ…бҹ’бһҶбҹҒбһ‘</translation>
<translation id="5659744962989939577">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ‘бҹ…вҖӢбһңбһ…бһ“бһ¶бһ“бһ»бһҖбҹ’бһҡбһҳ</translation>
<translation id="5789643057113097023">.</translation>
<translation id="5966707198760109579">бһҹбһ”бҹ’бһҸбһ¶бһ бҹҚ</translation>
<translation id="6015796118275082299">бһҶбҹ’бһ“бһ¶бҹҶ</translation>
<translation id="6444070574980481588">бһҖбҹҶбһҺбһҸбҹӢбһҖбһ¶бһӣбһ”бһҡбһ·бһ…бҹ’бһҶбҹҒбһ‘ бһ“бһ·бһ„бһ–бҹҒбһӣбһңбҹҒбһӣбһ¶</translation>
<translation id="6527303717912515753">бһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖ</translation>
<translation id="660254432468400466">бһҡбһҖбһҳбһ·бһ“бһғбһҫбһүвҖӢбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһ”бҹҶбһ”бҹ’бһӣбҹӮбһ„вҖӢбһўбһҸбҹ’бһҗбһ”бһ‘вҖӢвҖӢбһ‘бҹ…вҖӢбһҮбһ¶вҖӢбһҖбһ¶бһҡвҖӢбһ“бһ·бһҷбһ¶бһҷвҖӢбһҡбһ”бһҹбҹӢ Google вҖӢбһ‘бҹҒ</translation>
<translation id="6643016212128521049">бһҮбһҳбҹ’бһҡбҹҮ</translation>
<translation id="6727102863431372879">бһҖбҹҶбһҺбһҸбҹӢ</translation>
<translation id="6849295950938417341">бһ”бһ¶бһ“бһ”бһҡбһ¶бһҮбҹҗбһҷбһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҳбҹ’бһ…бһ¶бһҹбҹӢбһ‘бһҳбҹ’бһҡбһ„бҹӢ</translation>
<translation id="7102218676258945610">бһ“бһ¶бһ‘бһё</translation>
<translation id="7138678301420049075">бһ•бҹ’бһҹбҹҒбһ„бһ‘бҹҖбһҸ</translation>
<translation id="7575803462290353686">бһҖбҹҶбһҺбһҸбҹӢбһ–бҹҒбһӣбһңбҹҒбһӣбһ¶</translation>
<translation id="7648133459447652947">бһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһ‘бһҹбҹ’бһҹбһ“бҹҚбһ‘бҹ’бһҡбһ“бһ·бһ…вҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ бһҹбһјбһҳбһ”бҹ’бһҠбһјбһҡвҖӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһё бһ•бҹ’бһ‘бһ»бһҖвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢвҖӢбһЎбһҫбһ„бһңбһ·бһү бһ¬вҖӢбһҸбҹ’бһҡбһЎбһ”бҹӢбһҖбҹ’бһҡбҹ„бһҷ</translation>
<translation id="7781164152564914424">бһҖбҹҶбһҺбһҸбҹӢбһҒбҹӮ</translation>
<translation id="7821540960913969614">бһҖбҹҶбһҺбһҸбҹӢбһҖбһ¶бһӣбһ”бһҡбһ·бһ…бҹ’бһҶбҹҒбһ‘</translation>
<translation id="8261506727792406068">бһӣбһ»бһ”</translation>
<translation id="8880855155241626560">бһҳбһ·бһ“бһўбһ¶бһ…бһ”бһүбҹ’бһ…бһјбһӣбһҡбһјбһ”бһ—бһ¶бһ–бһ”бһ¶бһ“бһ‘бҹҒ</translation>
<translation id="8987927404178983737">бһҒбҹӮ</translation>
</translationbundle>