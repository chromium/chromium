	int animNum;
	int animDesc;
	
	public void doAnimLogo() {
		new Thread(new Runnable() {
            @Override
            public void run() {
				
				if (animNum == 1) {
					try {
						Thread.sleep(1500);
					} catch (Exception e) {}
				}
				else if (animNum == 4) {
					try {
						Thread.sleep(1500);
					} catch (Exception e) {}
				}
				else {
					try {
						Thread.sleep(100);
					} catch (Exception e) {}
				}
				
				runOnUiThread(new Runnable() {
					@Override
					public void run() {				
					
						synchronized(layoutLock) {
							if (exitLayoutLock) return;
			
							if (animDesc != 0) {
								animNum--;
								if (animNum < 1) {
									animNum = 2;
									animDesc = 0;
								}
							}
							else {
								animNum++;
								if (animNum > 4) {
									animNum = 3;
									animDesc = 1;
								}
							}
							
							//String imgname = "logo" + num;
							int res = 0;
							switch (animNum) {
								case 1:
									res = R.drawable.logo1;
									break;
								case 2:
									res = R.drawable.logo2;
									break;
								case 3:
									res = R.drawable.logo3;
									break;
								case 4:
									res = R.drawable.logo4;
									break;
							}
							
							ImageView imageView= (ImageView) findViewById(R.id.splashscreen);
							if (imageView != null && res != 0) {
								 imageView.setImageResource(res);
							}
						}
						
						doAnimLogo();
					}
				});
				
			}
		}).start();
	}

