    protected float dpadThreshold = 0.2f;
    protected float joystickDeadzone = 0.5f; // very high, since we don't know the device type
    private static final float MAX_MOTION_RANGE = 1.0f;

    // clean values
    // remove values larger than max
    // apply deadzone logic
    protected float cleanMotionValues(float number) {

        // apply deadzone
        if (number < joystickDeadzone && number > -joystickDeadzone)
            return 0.0f;

        // apply trim
        if (number > MAX_MOTION_RANGE)
            return MAX_MOTION_RANGE;
        if (number < -MAX_MOTION_RANGE)
            return -MAX_MOTION_RANGE;

        // scale values to be between deadzone and trim
        /*if (number < 0) {
            Range.scale(number, joystickDeadzone, MAX_MOTION_RANGE, 0, MAX_MOTION_RANGE);
        }
        if (number > 0) {
            Range.scale(number, -joystickDeadzone, -MAX_MOTION_RANGE, 0, -MAX_MOTION_RANGE);
        }*/


        return number;
    }

    @Override
    public boolean dispatchGenericMotionEvent(MotionEvent ev) {
        // if (event.getAction() == KeyEvent.ACTION_DOWN) {

        //callJS("printStr('" + ev.getAxisValue(MotionEvent.AXIS_X) +" | " + ev.getAxisValue(MotionEvent.AXIS_Y )+ "');");

        /* int actionCode = ev.getAction() & ev.ACTION_MASK;
            if (actionCode == MotionEvent.ACTION_UP || actionCode == MotionEvent.ACTION_CANCEL) {
                callJS("setNavKeyUp(40);");
                callJS("setNavKeyUp(38);");
                callJS("setNavKeyUp(37);");
                callJS("setNavKeyUp(39);");
            }
            else if (actionCode == MotionEvent.ACTION_DOWN || actionCode == MotionEvent.ACTION_MOVE) {
*/

        float left_stick_x = cleanMotionValues(ev.getAxisValue(MotionEvent.AXIS_X));
        float left_stick_y = cleanMotionValues(ev.getAxisValue(MotionEvent.AXIS_Y));
        float right_stick_x = cleanMotionValues(ev.getAxisValue(MotionEvent.AXIS_Z));
        float right_stick_y = cleanMotionValues(ev.getAxisValue(MotionEvent.AXIS_RZ));
        // float left_trigger = ev.getAxisValue(MotionEvent.AXIS_LTRIGGER);
        //float right_trigger = ev.getAxisValue(MotionEvent.AXIS_RTRIGGER);
        boolean dpad_down = ev.getAxisValue(MotionEvent.AXIS_HAT_Y) > dpadThreshold;
        boolean dpad_up = ev.getAxisValue(MotionEvent.AXIS_HAT_Y) < -dpadThreshold;
        boolean dpad_right = ev.getAxisValue(MotionEvent.AXIS_HAT_X) > dpadThreshold;
        boolean dpad_left = ev.getAxisValue(MotionEvent.AXIS_HAT_X) < -dpadThreshold;

        if (dpad_left || left_stick_x < 0 || right_stick_x < 0) {
            callJS("setNavKeyDown(37);");
        } else {
            callJS("setNavKeyUp(37);");
        }
        if (dpad_right || left_stick_x > 0 || right_stick_x > 0) {
            callJS("setNavKeyDown(39);");
        } else {
            callJS("setNavKeyUp(39);");

        }
        if (dpad_up || left_stick_y < 0 || right_stick_y < 0) {
            callJS("setNavKeyDown(38);");
        } else {
            callJS("setNavKeyUp(38);");
        }
        if (dpad_down || left_stick_y > 0 || right_stick_y > 0) {
            callJS("setNavKeyDown(40);");
        } else {
            callJS("setNavKeyUp(40);");
        }
        // }
        return super.dispatchGenericMotionEvent(ev);
    }


    @Override
    public boolean dispatchKeyEvent(KeyEvent event) {
        callJS("setNavKeyDown(" + event.getKeyCode() + ");");
        if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_DOWN) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(40);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(40);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_LEFT) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(37);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(37);");
            }
            // return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_RIGHT) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(39);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(39);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_DPAD_UP) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(38);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(38);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_BACK) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(-1000);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(-1000);");
            }
            return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_A) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(13);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(13);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_X) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(32);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(32);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_B) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(27);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(27);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_BUTTON_Y) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(46);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(46);");
            }
            //return true;
        }
        if (event.getKeyCode() == KeyEvent.KEYCODE_MENU) {
            if (event.getAction() == KeyEvent.ACTION_DOWN) {
                callJS("setNavKeyDown(-1001);");
            } else if (event.getAction() == KeyEvent.ACTION_UP) {
                callJS("setNavKeyUp(-1001);");
            }

            return true;
            //return super.dispatchKeyEvent(event);
        }
        return super.dispatchKeyEvent(event);
    }


