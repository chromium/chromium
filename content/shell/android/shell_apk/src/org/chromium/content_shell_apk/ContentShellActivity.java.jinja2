    @Override
    public void onActivityResult(int requestCode, int resultCode, Intent data) {
		
		switch (requestCode) {
			case DIR_SELECT_CODE:
			{
				ArrayList<String> ret = new ArrayList<String>();
				if (resultCode == RESULT_OK) {
					try {
						Uri uri = data.getData();
						Toast.makeText(ctx, uri.toString(),  Toast.LENGTH_SHORT).show();
						//Uri docUri = DocumentsContract.buildDocumentUriUsingTree(uri,  DocumentsContract.getTreeDocumentId(uri));
					//	String path = getPath(this, uri);
						
						String path = GetPathUtils.getDirectoryPathFromUri(this, uri); //getFullPathFromTreeUri(uri, this);
						if (path.trim().equals("/")) path = null;
						
						Toast.makeText(ctx, "Path: " + path,  Toast.LENGTH_SHORT).show();
						if (path != null) ret.add(path);
					} catch (Exception e) {}
				}
				
				String arr[] = new String[ret.size()];
				fileChooserResults(ret.toArray(arr));
				
				return;
				//break;
			}	
			case FILE_SELECT_CODE:
			{
				ArrayList<String> ret = new ArrayList<String>();
				
				if (resultCode == RESULT_OK) {
					// Get the Uri of the selected file 
					if(null != data) { // checking empty selection
					  if(null != data.getClipData()) { // checking multiple selection or not
						 for(int i = 0; i < data.getClipData().getItemCount(); i++) {
							try {
								Uri uri = data.getClipData().getItemAt(i).getUri();
								String path = null;
								//path = getPath(this, uri);
								path = GetPathUtils.getFilePathFromUri(this, uri);
								Toast.makeText(ctx, "Path: " + path,  Toast.LENGTH_SHORT).show();
								if (path != null) ret.add(path);
							} catch (Exception e){}
						 }
					  } else {
						  try {
							Uri uri = data.getData();
							String path = null;
							//path = getPath(this, uri);
							path = GetPathUtils.getFilePathFromUri(this, uri);
							Toast.makeText(ctx, "Path: " + path,  Toast.LENGTH_SHORT).show();
							if (path != null) ret.add(path);
						 } catch (Exception e){}
					  }
				   }
				}
				
				String arr[] = new String[ret.size()];
				fileChooserResults(ret.toArray(arr));
				
				return;
			}
		}
		
        super.onActivityResult(requestCode, resultCode, data);
        if (mWindowAndroid != null) mWindowAndroid.onActivityResult(requestCode, resultCode, data);
    }

