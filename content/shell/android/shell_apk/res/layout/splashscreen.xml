<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
          android:orientation="vertical" android:layout_width="fill_parent"
          android:layout_height="fill_parent" android:id="@+id/splash"
		  android:background="@android:color/black" android:gravity="center_vertical">

          <ImageView android:contentDescription="@string/cloudretro" android:id="@+id/splashscreen" android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:src="@drawable/logo1"
                  android:layout_gravity="center"/>
				  
			<EditText  android:id="@+id/ecurl"
		android:layout_width="fill_parent"
    android:layout_height="wrap_content"
	android:gravity="center"
        android:layout_gravity="center"
   android:hint="@string/url"
    android:text="@string/url" 
	android:inputType="textWebEmailAddress">
			</EditText>
			
			<Button
			 android:id="@+id/eclaunch"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
	android:gravity="center"
        android:layout_gravity="center"
    android:text="@string/launch" android:focusable="true"
				></Button>

</LinearLayout>
