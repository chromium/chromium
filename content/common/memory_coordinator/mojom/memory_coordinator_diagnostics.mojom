module content.mojom;

// The interface for receiving diagnostics-specific notifications from a child
// process. This handles Child -> Browser communication.
interface MemoryCoordinatorDiagnosticsHost {
  // Notifies the host when the aggregate memory limit for a consumer group
  // changes in the child process.
  OnMemoryLimitChanged(string consumer_id, int32 memory_limit);
};
