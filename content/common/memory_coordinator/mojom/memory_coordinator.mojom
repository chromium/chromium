module content.mojom;

[EnableIf=ENABLE_MEMORY_COORDINATOR_INTERNALS]
import "content/common/memory_coordinator/mojom/memory_coordinator_diagnostics.mojom";

// Represents a memory update for a consumer.
// TODO(pmonette): Hash the consumer ID to avoid serializing so many strings.
struct MemoryConsumerUpdate {
  string consumer_id;
  int32? percentage;
  bool release_memory;
};

// The interface for communicating with the MemoryCoordinator in a child
// process. This handles Browser -> Child communication.
interface ChildMemoryCoordinator {
  // Notifies of multiple changes at once.
  UpdateConsumers(array<MemoryConsumerUpdate> updates);

  // Enables diagnostics for this process. The child process should use the host
  // to report state changes.
  [EnableIf=ENABLE_MEMORY_COORDINATOR_INTERNALS]
  EnableDiagnosticsReporting(
      pending_remote<MemoryCoordinatorDiagnosticsHost> host);
};

// This struct directly corresponds to base::MemoryConsumerTraits, from which it
// is converted back and forth. See base/memory_coordinator/traits.h for a
// description of each trait.
struct MemoryConsumerTraits {
  uint8 supports_memory_limit;
  uint8 in_process;
  uint8 estimated_memory_usage;
  uint8 release_memory_cost;
  uint8 recreate_memory_cost;
  uint8 information_retention;
  uint8 memory_release_behavior;
  uint8 execution_type;
  uint8 release_gc_references;
  uint8 garbage_collects_v8_heap;
};

// The interface for communicating with the MemoryConsumerRegistry that lives in
// the browser process. This handles Child -> Browser communication.
interface ChildMemoryConsumerRegistryHost {
  // Binds the ChildMemoryCoordinator interface for the process associated with
  // this host.
  BindCoordinator(pending_remote<ChildMemoryCoordinator> coordinator);

  // Registers a MemoryConsumer with the browser-side registry.
  Register(string consumer_id, MemoryConsumerTraits? traits);

  // Unregisters a MemoryConsumer with the browser-side registry.
  Unregister(string consumer_id);
};
