module golden;

interface Page {
  OnSomethingHappened();
};

interface PageHandler {
  DoSomething();
};

interface WebUiPageHandlerFactory {
  CreatePageHandler(
      pending_remote<Page> page,
      pending_receiver<PageHandler> handler);
};
