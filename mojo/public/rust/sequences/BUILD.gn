import("//build/rust/rust_static_library.gni")

rust_static_library("sequences") {
  allow_unsafe = true

  crate_root = "lib.rs"
  sources = [
    "callback.rs",
    "cxx.rs",
    "lib.rs",
    "run_loop.rs",
    "scoped_refptr.rs",
    "sequenced_task_runner.rs",
  ]
  cxx_bindings = [ "cxx.rs" ]

  deps = [
    ":cxx_shim",
    "//base",
  ]

  allow_circular_includes_from = [ ":cxx_shim" ]

  visibility = [ "../*" ]
}

source_set("cxx_shim") {
  sources = [ "cxx_shim.h" ]
  deps = [ "//base" ]
}

# Testing targets

source_set("test_util") {
  testonly = true
  sources = [
    "test/test_util.cc",
    "test/test_util.h",
  ]
  deps = [
    "//base",
    "//base/test:test_support",
  ]
  visibility = [ ":*" ]
}

rust_static_library("test_cxx") {
  testonly = true
  allow_unsafe = true

  crate_root = "test/cxx.rs"
  sources = [ "test/cxx.rs" ]
  cxx_bindings = [ "test/cxx.rs" ]

  deps = [
    ":sequences",
    ":test_util",
    "//base",
  ]
  visibility = [ "../*" ]
}

rust_static_library("rust_sequences_unittests") {
  testonly = true
  is_gtest_unittests = true
  allow_unsafe = true

  crate_root = "test/lib.rs"
  sources = [ "test/lib.rs" ]

  deps = [
    ":sequences",
    ":test_cxx",
    ":test_util",
    "//testing/rust_gtest_interop",
  ]
  visibility = [ "../*" ]
}
