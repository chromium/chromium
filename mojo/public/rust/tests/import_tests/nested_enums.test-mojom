module nested_enums.mojom;

struct OuterStruct {
  enum InnerEnum {
    kValue1,
    kValue2,
  };
  InnerEnum inner_field;
};

interface TestNested {
  enum InterfaceEnum {
    kInterfaceValue1,
    kInterfaceValue2,
  };
  Test(OuterStruct s, InterfaceEnum e) => (OuterStruct s, InterfaceEnum e);
};
