import("//build/rust/rust_static_library.gni")
import("//mojo/public/tools/bindings/mojom.gni")

rust_static_library("bindings") {
  crate_root = "lib.rs"
  sources = [
    "interface.rs",
    "lib.rs",
    "message.rs",
    "message_header.rs",
    "message_pipe_watcher.rs",
    "receiver.rs",
    "remote.rs",
  ]

  deps = [
    ":helper_functions_cxx",
    "../mojom_value_parser",

    # "../mojom_value_parser:mojom_value_parser_core",
    "../sequences",
    "../system",
    "//third_party/rust/anyhow/v1:lib",
    "//third_party/rust/bitflags/v2:lib",
  ]
}

source_set("cxx_shim") {
  sources = [ "cxx_shim.h" ]
  deps = [ "//base" ]

  visibility = [ ":*" ]
}

rust_static_library("helper_functions_cxx") {
  crate_root = "cxx.rs"
  sources = [ "cxx.rs" ]
  cxx_bindings = [ "cxx.rs" ]

  deps = [
    ":cxx_shim",
    "//base",
  ]

  allow_unsafe = true
  visibility = [ ":*" ]
}

rust_static_library("bindings_unittests") {
  testonly = true
  is_gtest_unittests = true
  crate_root = "test/lib.rs"
  sources = [
    "test/lib.rs",
    "test/state_objects.rs",
    "test/tests.rs",
  ]

  deps = [
    ":bindings",
    ":bindings_unittests_mojom_rust",
    "../sequences",
    "../sequences:test_cxx",
    "../system",
    "../system/test_util",
    "//testing/rust_gtest_interop",
  ]
}

mojom("bindings_unittests_mojom") {
  testonly = true
  sources = [ "test_util/bindings_unittests.test-mojom" ]
  generate_rust = true
  visibility = [ ":*" ]
}
