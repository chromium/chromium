import("//build/rust/rust_static_library.gni")
import("//mojo/public/tools/bindings/mojom.gni")

rust_static_library("bindings_unittests") {
  testonly = true
  is_gtest_unittests = true
  allow_unsafe = true
  crate_root = "lib.rs"
  sources = [
    "cxx.rs",
    "lib.rs",
    "state_objects.rs",
    "tests.rs",
  ]
  cxx_bindings = [ "cxx.rs" ]

  deps = [
    ":bindings_unittests_mojom_rust",
    ":math_service_cpp",
    "..:bindings",
    "../../system",
    "../../system/test_util",
    "//base",
    "//base:base_rust",
    "//base:sequenced_task_runner_test_bridge",
    "//base/test:test_support_rust",
    "//testing/rust_gtest_interop",
  ]
}

source_set("math_service_cpp") {
  testonly = true
  sources = [
    "cpp/add_seven_service.cc",
    "cpp/add_seven_service.h",
    "cpp/cxx_shim.cc",
    "cpp/cxx_shim.h",
  ]
  deps = [
    ":bindings_unittests_mojom",
    "../../system",
    "//mojo/public/cpp/bindings",
    "//testing/gtest",
  ]
}

mojom("bindings_unittests_mojom") {
  testonly = true
  sources = [ "test_util/bindings_unittests.test-mojom" ]
  generate_rust = true
  rust_typemaps = [
    {
      types = [
        {
          mojom = "bindings_unittests.mojom.TypemappedStruct"
          rust = "MyCustomStruct"
        },
      ]
      traits_file = "test_traits.rs"
    },
  ]
  visibility = [ ":*" ]
}
