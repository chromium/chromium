{%- from "enum.tmpl" import declare_enum -%}
{%- from "union.tmpl" import declare_union -%}
{%- from "struct.tmpl" import declare_struct -%}
{%- from "interface.tmpl" import declare_interface -%}

// Generated by //mojo/public/tools/bindings/generators/mojom_rust_generator.py
// from {{module.path}}

#![allow(non_camel_case_types)]
#![allow(non_snake_case)]
{#- FOR_RELEASE: See if we can only add imports that are actually needed #}
#![allow(unused_imports)]

chromium::import! {
    "//mojo/public/rust/mojom_value_parser";
    "//mojo/public/rust/bindings";
    "//mojo/public/rust/system";
{% for imprt in imports %}
    "{{imprt}}";
{%- endfor %}
}

use std::collections::HashMap;
use ordered_float::OrderedFloat;

use mojom_value_parser::*;
{% for enum in module.enums %}
{{ declare_enum(enum.name, enum)}}
{% endfor -%}

{% for union in module.unions %}
{{ declare_union(union.name, union)}}
{% endfor -%}

{% for struct in module.structs %}
{{ declare_struct(struct.name, struct, true)}}
{% endfor -%}

{% for interface in module.interfaces %}
{{ declare_interface(interface)}}
{%- endfor -%}