import("//build/config/android/rules.gni")
import("//build/config/chrome_build.gni")

copy("personal_context_first_run_animation_resource") {
  if (is_internal_chrome_branded) {
    sources = [ "../core/resources/internal/assets/animations/personal_context_first_run_animation.json" ]
  } else {
    sources = [ "../core/resources/assets/animations/personal_context_first_run_animation.json" ]
  }
  outputs = [ "$target_gen_dir/animation_res/raw/personal_context_first_run_animation.json" ]
}

android_resources("personal_context_icon_resources") {
  if (is_internal_chrome_branded) {
    sources = [
      "../core/resources/internal/android/java/res/drawable/personal_context_first_run_card_1.xml",
      "../core/resources/internal/android/java/res/drawable/personal_context_first_run_card_2.xml",
    ]
  } else {
    sources = [
      "java/res/drawable/personal_context_first_run_card_1.xml",
      "java/res/drawable/personal_context_first_run_card_2.xml",
    ]
  }
}

android_resources("personal_context_java_resources") {
  sources = [ "$target_gen_dir/animation_res/raw/personal_context_first_run_animation.json" ]
  deps = [
    ":personal_context_first_run_animation_resource",
    ":personal_context_icon_resources",
  ]
}
