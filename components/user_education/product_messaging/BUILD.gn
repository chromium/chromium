import("//build/buildflag_header.gni")
import("//build/config/ui.gni")

source_set("product_messaging") {
  sources = [
    "product_messaging_controller.cc",
    "product_messaging_controller.h",
  ]

  public_deps = [ "//ui/base/interaction" ]

  deps = [
    "//base",
    "//components/user_education/common:session",
    "//components/user_education/common:storage",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "product_messaging_controller_unittest.cc" ]

  deps = [
    ":product_messaging",
    "//base",
    "//base/test:test_support",
    "//components/user_education/common:session",
    "//components/user_education/common:storage",
    "//components/user_education/test",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base/interaction:test_support",
  ]
}
