source_set("unit_tests") {
  testonly = true
  sources = [
    "origin_checker_unittest.cc",
    "safety_list_manager_unittest.cc",
    "shared_types_unittest.cc",
  ]
  deps = [
    ":core",
    "//base",
    "//base/test:test_support",
    "//testing/gtest",
    "//url",
  ]
}
