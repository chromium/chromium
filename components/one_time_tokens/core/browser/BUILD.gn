    "one_time_token_service_impl_unittest.cc",
    "one_time_token_unittest.cc",
    "util/expiring_subscription_manager_unittest.cc",
  ]
  deps = [
    ":browser",
    "//base/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}

static_library("test_support") {
  testonly = true
  sources = [
    "mock_one_time_token_service.cc",
    "mock_one_time_token_service.h",
  ]
  public_deps = [
    ":browser",
    "//base",
    "//testing/gmock",
  ]
}
