import("//build/config/features.gni")
import("//chromecast/chromecast.gni")
import("//media/media_options.gni")
import("//testing/test.gni")

source_set("message_port") {
  if (enable_cast_runtime_e2e_testing) {
    public_deps = [ ":message_port_mojo" ]
  } else if (is_fuchsia) {
    public_deps = [ ":message_port_fuchsia" ]
  } else {
    public_deps = [ ":message_port_cast" ]
  }
}

source_set("public") {
  sources = [
    "message_port.cc",
    "message_port.h",
  ]

  deps = [
    "//base",
    "//components/cast:export",
  ]

  defines = [ "CAST_COMPONENT_IMPLEMENTATION" ]

  visibility = [ ":*" ]
}

if (is_fuchsia) {
  source_set("message_port_fuchsia") {
    public = [ "message_port_fuchsia.h" ]

    sources = [ "message_port_fuchsia.cc" ]

    public_deps = [
      ":public",

      # TODO(crbug.com/1120731): Remove dependencies on //fuchsia.
      "//fuchsia/base",
      "//third_party/fuchsia-sdk/sdk/fidl/fuchsia.web",
    ]

    deps = [ "//base" ]
  }
}

source_set("message_port_cast") {
  public = [ "message_port_cast.h" ]

  sources = [ "message_port_cast.cc" ]

  public_deps = [ ":public" ]

  deps = [
    ":public",
    "//base",
    "//third_party/blink/public/common",
  ]
}

source_set("message_port_mojo") {
  public = [ "message_port_mojo.h" ]

  sources = [ "message_port_mojo.cc" ]

  public_deps = [
    ":public",
    "//components/cast/message_port/mojom",
  ]

  deps = [ ":public" ]
}

source_set("message_port_unittest") {
  testonly = true
  sources = [ "message_port_unittest.cc" ]
  deps = [
    ":message_port",
    ":test_message_port_receiver",
    "//base/test:test_support",
    "//build:buildflag_header_h",
    "//components/cast/message_port/mojom",
    "//media:media_buildflags",
    "//testing/gtest",
  ]
}

source_set("test_message_port_receiver") {
  testonly = true
  sources = [
    "test_message_port_receiver.cc",
    "test_message_port_receiver.h",
  ]
  deps = [
    ":public",
    "//base",
  ]
}
