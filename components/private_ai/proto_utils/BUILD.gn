  sources = [
    "attestation_evidence_utils_unittest.cc",
    "generate_content_response_utils_unittest.cc",
    "google_rpc_code_unittest.cc",
  ]
  deps = [
    ":proto_utils",
    "//base/test:test_support",
    "//components/private_ai:proto",
    "//components/private_ai/attestation",
    "//testing/gtest",
    "//third_party/oak:oak_proto",
  ]
}
