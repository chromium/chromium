source_set("proto_utils") {
  sources = [
    "attestation_evidence_utils.cc",
    "attestation_evidence_utils.h",
    "generate_content_response_utils.cc",
    "generate_content_response_utils.h",
    "google_rpc_code.cc",
    "google_rpc_code.h",
  ]
  deps = [
    "//base",
    "//components/private_ai:proto",
    "//components/private_ai/attestation",
    "//third_party/oak:oak_proto",
  ]
}

source_set("unit_tests") {
