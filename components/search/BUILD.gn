static_library("search") {
  sources = [
    "ntp_features.cc",
    "ntp_features.h",
    "search.cc",
    "search.h",
  ]

  deps = [
    "//base",
    "//components/search_engines",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "search_unittest.cc" ]
  if (is_android) {
    sources += [ "search_android_unittest.cc" ]
  }

  deps = [
    ":search",
    "//base",
    "//base/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
