<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="az">
<translation id="7649299977121480655">Reklam mövzuları saytın reklamları fərdiləşdirmək üçün istifadə edə biləcəyi vasitələrdən biridir. Reklam mövzuları olmasa da, saytlar maraq dairənizə uyğun olmayan reklamlar göstərə bilər. <ph name="BEGIN_LINK_1" />Reklam məxfiliyinin idarə edilməsi<ph name="END_LINK_1" /> haqqında ətraflı məlumat.</translation>
</translationbundle>