<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="be">
<translation id="7649299977121480655">Функцыя "Тэмы рэкламы" – адзін з інструментаў, якія могуць быць выкарыстаны сайтам для персаналізацыі рэкламы. Нават калі гэта функцыя адключана, сайты могуць і далей паказваць аб'явы, аднак яны могуць менш адпавядаць інтарэсам карыстальніка. <ph name="BEGIN_LINK_1" />Даведацца больш пра кіраванне прыватнасцю ў рэкламе.<ph name="END_LINK_1" /></translation>
</translationbundle>