<translation id="1884843295353628214">Оњ'ОљОќ</translation>
<translation id="1890171020361705182">РђЈОъОЕОЌОД Dino. ОЊОЎОаОЋОќОљОЋОе ОЉОфОдОЋОњОф ОцОЎОДОАОюОЎОЮ ОЌОЋОъОД ОъОДОўОўОЋОАОЎОЮ ОЋОъОцОўОеОЋОЊОДОўОЎОюОЎОЮ ОЉОбОЋОЊОЋ ОеОЦ ОбОю ОеОДОб ОаОЋОБ ОЕОЋОъОЮ. ОЏОЕОЕОЋОъОбОЎОЮ ОљОф ОћОљОЋОф ОЉОљОЋОЊОЎОЋ, ОдОеОЎОџ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОЊОюОњ ОъОбОю ОъОЏОЕОЋОюОЎОЮ.</translation>
<translation id="1898423065542865115">ОАОЎОаОЋОЪ</translation>
<translation id="1901443836186977402">{1,plural, =1{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />. ОћОфОЋОДОБ ОЕОю ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОцОњ ОЉОъОћОюОџ ОћОЎОъОъОћ ОћОљОЌОеОЋОаОћ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОћОњОЊОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ. ОбОю ОцОЎ ОћОЕОбОЋОЪ ОЉОъОЌОЕОЉ ОЕОюОџ, ОбОЏОЕОЎОЋ <ph name="CURRENT_DATE" />. ОћОљОЮ ОќОћ ОаОЏОЋОЪ? ОљОЮ ОюОљ, ОбОюОЎОџ ОюОЏОЋОЋОЪ ОљОф ОЕОбОЋОЪ ОћОъОбОеОЏОф ОЋОюОљОЌОе ОъОЏОЪ ОюОеОбОаОЪ ОљОф ОћОЊОБ ОћОќОћ.}one{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />. ОфОЋОДОБ ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОцОњ ОюОцОаОЎ # ОЎОъОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОфОдОЋОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ. ОбОю ОцОЎ ОћОЕОбОЋОЪ ОЉОъОЌОЕОЉ ОЕОюОџ, ОбОЏОЕОЎОЋ <ph name="CURRENT_DATE" />. ОћОљОЮ ОќОћ ОаОЏОЋОЪ? ОљОЮ ОюОљ, ОбОюОЎОџ ОюОЏОЋОЋОЪ ОљОф ОЕОбОЋОЪ ОћОъОбОеОЏОф ОЋОюОљОЌОе ОъОЏОЪ ОюОеОбОаОЪ ОљОф ОћОЊОБ ОћОќОћ.}two{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />. ОфОЋОДОБ ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОцОњ ОюОцОаОЎ ОЎОЋОъОЎОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОфОдОЋОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ. ОбОю ОцОЎ ОћОЕОбОЋОЪ ОЉОъОЌОЕОЉ ОЕОюОџ, ОбОЏОЕОЎОЋ <ph name="CURRENT_DATE" />. ОћОљОЮ ОќОћ ОаОЏОЋОЪ? ОљОЮ ОюОљ, ОбОюОЎОџ ОюОЏОЋОЋОЪ ОљОф ОЕОбОЋОЪ ОћОъОбОеОЏОф ОЋОюОљОЌОе ОъОЏОЪ ОюОеОбОаОЪ ОљОф ОћОЊОБ ОћОќОћ.}other{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />. ОфОЋОДОБ ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОцОњ ОюОцОаОЎ # ОЎОъОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОфОдОЋОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ. ОбОю ОцОЎ ОћОЕОбОЋОЪ ОЉОъОЌОЕОЉ ОЕОюОџ, ОбОЏОЕОЎОЋ <ph name="CURRENT_DATE" />. ОћОљОЮ ОќОћ ОаОЏОЋОЪ? ОљОЮ ОюОљ, ОбОюОЎОџ ОюОЏОЋОЋОЪ ОљОф ОЕОбОЋОЪ ОћОъОбОеОЏОф ОЋОюОљОЌОе ОъОЏОЪ ОюОеОбОаОЪ ОљОф ОћОЊОБ ОћОќОћ.}}</translation>
<translation id="1902576642799138955">ОфОДОЋОцОф ОфОЋОДОБ</translation>
<translation id="1908217026282415406">ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ ОЋОюОћОќОЎОќ ОљОЋОфОћ</translation>
