<translation id="166624440456221306">ОъОЌОЎОДОћ ОЕОю ОўОЉОюОф ОћОћОЕОЋОЋОљОћ</translation>
<translation id="1668071460721346172">ОДОЉОюОф ОљОЎОъОЎОЎОю</translation>
<translation id="1674504678466460478"><ph name="SOURCE_LANGUAGE" /> Ою<ph name="TARGET_LANGUAGE" /></translation>
<translation id="1682696192498422849">ОћОДОдОћ ОћОДОдОе ОеОљОЕОЋОЪ</translation>
<translation id="168693727862418163">ОљОЎОъОЋОф ОбОеОџ ОћОъОЊОЎОаОЎОЋОф ОћОќОћ ОаОЏОЕОю ОЉОЉОЊОЎОДОћ ОъОЋОю ОћОАОЏОЎОъОћ ОЋОћОъОбОеОЏОф ОфОфОбОюОЮ ОъОъОаОЋ.</translation>
<translation id="168841957122794586">ОљОЎОЕОЋОе ОћОЕОеОф ОъОЏОЎОю ОъОцОфОЌ ОћОдОцОаОћ ОЌОюОЕ.</translation>
<translation id="1689333818294560261">ОЏОЎОаОЋОЎ</translation>
<translation id="1692622044604477956">ОеОЕОЎОъОЋОф ОАОеОўОЎОЮ ОЉОДОЋОюОаОЋОб ОЋОќОъОаОЎ ОћОДОеОаОћ</translation>
<translation id="1697430960030447570">РђЈ<ph name="BEGIN_BOLD" />ОъОћ ОћОљОцОЕОеОЋОЎОЋОф ОЕОќОъОЎОаОЋОф ОюОџ ОюОаОЎОћОЋОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ:<ph name="END_BOLD" /> Chrome ОъОЋОЌОД ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОЋОЕОљОЎОЮ ОЕОаОЋОАОцОЋ ОюОцОаОЎ ОЎОЋОфОе Оъ-4 ОЕОЉОЋОбОЋОф. ОљОЮ ОћОъОЕОЏОф ОюОњОюОЋОЕ ОюОљОЋОфОЮ ОљОфОеОЎОЮ, ОљОЌОЊ ОћОаОЋОЕОљОЎОЮ ОбОЕОЋОЎ ОюОћОЋОцОЎОб ОЉОеОЕОЎОъОћ ОъОЌОЊОЕ. ОЉОЏОю ОЕОюОЉ ОаОЎОфОЪ ОњОЮ ОюОЌОАОЋОЮ ОаОЋОЕОљОЎОЮ ОЕОюОљ ОеОЋОдОЎОЮ ОЕ-Chrome ОЎОЕОфОБ ОбОЮ ОљОфОеОЎОЮ ОЋОюОћОЕОЉОЎОф ОљОф ОаОЋОЕОљОЎ ОћОъОЋОЊОбОЋОф ОЊОеОџ ОћОњОЊОеОЋОф Chrome.</translation>
