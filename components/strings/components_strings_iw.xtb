<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1003222766972176318">ОфОќОЏОЋОеОф: ОЎОЕ ОъОЉОдОб ОЕОъОЋОе</translation>
<translation id="1005146802850926840">ОАОеОўОЎ ОљОаОЎОъОдОЎОћ</translation>
<translation id="1008557486741366299">ОюОљ ОбОЏОЕОЎОЋ</translation>
<translation id="100957008357583611">ОюОћОЕОфОъОЕ ОЉОъОЎОДОЋОЮ ОЕОюОџ?</translation>
<translation id="1010200102790553230">ОюОўОбОЎОаОф ОћОЊОБ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="1010225406377140704">ОљОцОЕОе ОюОцОаОЋОф ОљОю ОћОЕОЋОюОЌ/Оф ОЋОюОЉОДОЕ ОДОЎОЕОЋОе ОЌОЊОЕ</translation>
<translation id="1011206368273183593">ОћОДОЉОдОЎОЮ ОЉОћОЏОаОћРђд</translation>
<translation id="1014509239502131234">ОъОфОЉОдОб ОЉОЎОўОЋОю ОЕОю ОћОфОЋОдОљОћ</translation>
<translation id="1015730422737071372">ОАОцОД ОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="1019413721762100891">ОЏОЉОЋОЎ</translation>
<translation id="1021753677514347426">РђЈОћОЉОбОЎОћ ОћОќОЋ ОъОфОеОЌОЕОф ОЉОњОюОю ОљОЎОЕОЋОе ОЕОћОЋОфОДОЪ ОЉОъОЏОЕОЎОе ОбОю ОЎОЊОџ ОљОЋ ОбОю ОЎОЊОЎ ОъОЎОЕОћОЋ ОљОЌОе. ОћОљОЎОЕОЋОе ОћОќОћ ОъОЋОЏОе ОЏОљОЎОЕОЋОе ОЕОъОЕОъОЕ ОюОдОЋОеОџ ОъОбОДОЉ ОљОЌОеОЎ ОеОЕОфОЋОф ОЋОЎОЎОеОЋОў ОаОфОЋОаОЎОЮ ОъОеОЕОфОЋОф, ОЋОћОЋОљ ОюОљ ОаОЌОЕОЉ ОЏОъОћОЎОъОЪ ОбОю ОЎОЊОЎ Chromium. ОЉОъОДОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОъОфОЉОдОб ОъОбОДОЉ ОъОАОЎОЉОЋОф ОюОњОЎОўОЎОъОЎОЋОф, ОЏОъОЋ ОЉОъОЋОАОЊОЋОф ОЌОЎОаОЋОџ ОљОЋ ОЉОеОЕОфОЋОф ОЕОю ОЌОЉОеОЋОф, ОљОџ Chromium ОеОЋОдОћ ОюОЋОЋОЊОљ ОЕОћОъОбОДОЉ ОъОфОЉОдОб ОЉОЎОЊОЎОбОфОџ ОњОЮ ОљОЮ ОљОЎОЪ ОюОџ ОљОцОЕОеОЋОф ОюОбОдОЋОе ОљОЋОфОЋ. ОћОъОбОДОЉ ОбОЕОЋОЎ ОюОћОфОЉОдОб ОЉОЏОю ОЊОцОЊОцОЪ ОљОЋ ОљОцОюОЎОДОдОЎОћ ОЕОаОЎОњОЕОЎОЮ ОюОљОЎОаОўОеОаОў.</translation>
<translation id="1024111578869940408">ОфОЋОДОцОЎОЮ ОЕОъОЌОДОЎОЮ ОљОфОеОЎОЮ ОюОцОбОъОЎОЮ ОъОЕОфОъОЕОЎОЮ ОЉОЏОфОЋОЉОф ОћОљОЎОаОўОеОаОў ОЕОю ОћОљОфОе ОћОъОДОЋОеОЎ, ОЋОбОЋОЕОЎОЮ ОЉОћ ОЕОЎОаОЋОЎОЎОЮ ОЕОДОЕОћ ОюОћОЉОЌОЎОЪ ОЉОћОЮ.</translation>
<translation id="1024913885641459127">ОЉОЎОДОЋОеОЋОф ОбОю ОъОЋОдОеОЎОЮ ОЋОћОЕОЋОЋОљОЋОф ОъОЌОЎОеОЎОЮ</translation>
<translation id="102916930470544692">ОъОцОфОЌ ОњОЎОЕОћ</translation>
<translation id="1030706264415084469"><ph name="URL" /> ОеОЋОдОћ ОюОљОЌОАОЪ ОЉОљОЋОцОЪ ОДОЉОЋОб ОЏОъОЋОф ОњОЊОЋОюОћ ОЕОю ОаОфОЋОаОЎОЮ ОЉОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="1030949145805074938">{COUNT,plural, =0{ОљОЎОЪ ОљОфОеОЎОЮ}=1{ОъОљОфОе ОљОЌОЊ. ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ. }one{Оъ-# ОљОфОеОЎОЮ. ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ. }two{Оъ-# ОљОфОеОЎОЮ. ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ. }other{Оъ-# ОљОфОеОЎОЮ. ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ. }}</translation>
<translation id="1035709686865413354">ОъОАОаОаОЎ ОъОЎОЮ ОЋОъОўОћОеОЎ ОъОЎОЮ</translation>
<translation id="1036348656032585052">ОЏОЎОЉОЋОЎ</translation>
<translation id="1036881361735705143">РђЈОъОбОўОцОћ РђЊ C4</translation>
<translation id="1038106730571050514">ОћОдОњОф ОћОдОбОЋОф</translation>
<translation id="1038842779957582377">ОЕОЮ ОюОљ ОЎОЊОЋОб</translation>
<translation id="1041998700806130099">ОћОЋОЊОбОћ ОюОњОЉОЎ ОњОЎОюОЎОЋОЪ ОбОЉОЋОЊОЋОф</translation>
<translation id="1044897699341250361">ОъОћ ОќОћ ОљОЋОъОе?</translation>
<translation id="1046350918013988591">ОЕОЋОЉОеОЎОЮ ОЋОћОаОЌОЋОф</translation>
<translation id="1048785276086539861">ОћОъОАОъОџ ОћОќОћ ОЎОЌОќОЋОе ОюОфОдОЋОњОф ОЊОБ ОЎОЌОЎОЊ ОЉОќОъОЪ ОбОеОЎОЏОф ОћОћОбОеОЋОф</translation>
<translation id="1050038467049342496">ОАОњОЎОеОф ОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф</translation>
<translation id="1053959602163383901">ОЉОЌОеОф ОюОЉОдОб ОљОЎОъОЋОф ОЉОљОъОдОбОЋОф ОъОЏОЕОЎОе ОљОЎОъОЋОф ОЉОљОфОеОЎОЮ ОЕОъОЕОфОъОЕОЎОЮ ОЉ-<ph name="PROVIDER_ORIGIN" />. ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОАОцОД ОћОќОћ ОљОЌОАОЪ ОъОЎОЊОб ОбОю ОљОъОдОбОЎ ОћОфОЕОюОЋОЮ ОЕОюОџ, ОЕОљОЋОфОЋ ОљОцОЕОе <ph name="LINK_TEXT" />.</translation>
<translation id="1055184225775184556">&amp;ОЉОЎОўОЋОю ОћОЋОАОцОћ</translation>
<translation id="1056898198331236512">ОљОќОћОеОћ</translation>
<translation id="1058344460600311577">РђЈ<ph name="PLAY_CHROME_DINO_GAME_FOCUSED_FRIENDLY_MATCH_TEXT" />, ОъОДОЎОЕОЎОЮ ОбОю Tab ОЋОљОќ ОбОю Enter ОЏОЊОЎ ОюОЕОЌОД ОЉОъОЕОЌОД Dino Run ОЉ-Chrome</translation>
<translation id="1058479211578257048">ОћОЏОеОўОЎОАОЎОЮ ОаОЕОъОеОЎОЮ...</translation>
<translation id="1060136083665017312">ОДОЋОаОАОЋОюОЋОф ОЋОъОбОеОЏОЋОф ОюОъОЕОЌОДОЎОЮ</translation>
<translation id="1060320201901229167">РђЈОъОбОўОцОћ РђЊ Kaku 5</translation>
<translation id="1062407476771304334">ОћОЌОюОцОћ</translation>
<translation id="1064054731605354900">A3x5</translation>
<translation id="1067029985695494416">ОћОцОеОўОЎОЮ ОЕОю ОъОаОЋОб ОћОЌОЎОцОЋОЕ</translation>
<translation id="1068672505746868501">ОљОБ ОцОбОЮ ОљОЎОЪ ОюОфОеОњОЮ ОЊОцОЎОЮ ОЉ<ph name="SOURCE_LANGUAGE" /></translation>
<translation id="1070333806075222467">Metal (Glossy)</translation>
<translation id="1070901266639972381">ОюОЎОюОћ</translation>
<translation id="1073690811593784042">Glass (Colored)</translation>
<translation id="1074497978438210769">ОюОљ ОъОљОЋОЉОўОЌ</translation>
<translation id="1074779248866616641">ОфОЋОдОљОћ</translation>
<translation id="1075364221219156102">ОЕОЎОъОЋОЕ ОЉОъОцОфОЌ ОњОЎОЕОћ</translation>
<translation id="1080116354587839789">ОћОфОљОъОћ ОюОеОЋОЌОЉ</translation>
<translation id="1081061862829655580">ОъОњОЕ 19</translation>
<translation id="1082026381988252344">ОњОюОЎОюОћ ОЉОфОЋОЏОЪ ОћОЏОеОўОЎОАОЎОЎОћ ОћОъОЕОЋОфОцОф ОЋОЕОЎОаОЋОЎ ОъОеОЌОД ОћОфОдОЋОњОћ ОЕОюОЋ</translation>
<translation id="1088664500620117635">ОћОъОЌОЎОе ОћОеОњОЎОю ОЕОю <ph name="PRODUCT_NAME" /> ОаОб ОЉОЎОЪ <ph name="LOW_PRICE" /> Ою-<ph name="HIGH_PRICE" />, ОљОЉОю ОћОъОЌОЎОе ОћОаОЋОЏОЌОЎ ОћОЋОљ <ph name="CURRENT_PRICE" /> ОЉОљОЎОаОўОеОаОў.</translation>
<translation id="1089439967362294234">ОЕОЎОаОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="1089599132348386324">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЕОаОЋОф ОљОф ОћОЉОЌОЎОеОћ ОЉОЏОю ОЕОюОЉ ОЉОћОњОЊОеОЋОф ОЕОю Chrome.</translation>
<translation id="1090629319939036170">РђЈОфОцОеОЎОў VR</translation>
<translation id="1091463901118115503">ОћОДОеОљОћ ОеОдОЋОцОћ</translation>
<translation id="1091779689406092804">ОдОЎОюОЋОъОЎ ОъОАОџ</translation>
<translation id="1094777233105318927">ОъОЎОЊОб ОбОю ОћОЊОцОЊОцОЪ, ОъОбОеОЏОф ОћОћОцОбОюОћ, ОћОъОЏОЕОЎОе, ОћОфОЋОЏОаОЋОф ОЕОћОЋОфОДОаОЋ ОЋОћОДОЉОдОЎОЮ</translation>
<translation id="1096545575934602868">ОћОЕОЊОћ ОћОќОћ ОЎОЏОЋОю ОюОЏОюОЋОю ОбОЊ <ph name="MAX_ITEMS_LIMIT" /> ОеОЕОЋОъОЋОф. ОЏОю ОћОеОЕОЋОъОЋОф ОћОаОЋОАОцОЋОф ОЎОЎОъОЌОДОЋ.</translation>
<translation id="1097803577928227769">ОцОљОеОДОЎОЮ ОЋОњОаОЎОЮ ОљОќОЋОеОЎОЎОЮ</translation>
<translation id="1099928364755383720">ОћОцОбОюОћ ОљОЋОўОЋОъОўОЎОф ОЕОю 'ОфОъОЋОаОћ ОЉОфОЋОџ ОфОъОЋОаОћ'</translation>
<translation id="1100782917270858593">РђЈОћОЏОцОфОЋОе ОюОћОъОЕОџ ОћОфОћОюОЎОџ, ОюОЋОЌОдОЎОЮ ОбОю Enter ОЏОЊОЎ ОюОћОъОЕОЎОџ ОЉОфОћОюОЎОџ ОЋОюОћОдОЎОњ ОљОф ОћОцОбОЎОюОЋОф ОћОеОюОЋОЋОаОўОЎОф ОЉОћОЎОАОўОЋОеОЎОћ ОЉ-Chrome</translation>
<translation id="1101672080107056897">ОцОбОЋОюОф ОЕОњОЎОљОћ</translation>
<translation id="1101902632743388185">ОўОЉОюОљОЋОф ОћОћОЕОЋОЋОљОћ ОЕОюОџ</translation>
<translation id="1104409666019087579">ОЎОЕ ОЏОъОћ ОЕОЊОЋОф ОЌОЋОЉОћ ОеОЎОДОЎОЮ. ОбОюОЎОџ ОюОъОюОљ ОљОЋОфОЮ ОюОцОаОЎ ОћОЕОъОЎОеОћ.</translation>
<translation id="1104860668737945357">РђЈОћОЏОцОфОЋОе ОюОаОЎОћОЋОю ОАОЎОАОъОљОЋОф, ОъОцОбОЎОюОЎОЮ ОљОЋОфОЋ ОЏОЊОЎ ОюОћОдОЎОњ ОЋОюОаОћОю ОљОф ОћОАОЎОАОъОљОЋОф ОЉОћОњОЊОеОЋОф Chrome</translation>
<translation id="1108464073729874771">A3x4</translation>
<translation id="1110809716549020493">ОћОљОЮ ОћОЏОеОўОЎОА ОћОЋОЋОЎОеОўОЋОљОюОЎ ОюОљ ОъОЋОюОљ? ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОцОеОўОЎ ОћОЏОеОўОЎОА ОћОЋОЋОЎОеОўОЋОљОюОЎ ОЏОЊОЎ ОюОћОбОфОЎОД ОљОЋОфОЮ ОюОюОЋОЌ. <ph name="IDS_AUTOFILL_FILLED_CARD_INFORMATION_BUBBLE_LEARN_MORE_LINK_LABEL_VIRTUAL_CARD" /></translation>
<translation id="1110994991967754504">ОдОеОЎОџ ОюОЉОЌОЋОе ОљОф ОћОћОеОЕОљОћ ОЕОю <ph name="PERMISSION_NAME" /></translation>
<translation id="1113000785583998331">РђЈОюОЕОъОЋОе ОљОф ОъОАОцОе Оћ-IBAN?</translation>
<translation id="1113869188872983271">&amp;ОЉОЎОўОЋОю ОЕОю ОЕОЎОаОЋОЎ ОАОЊОе</translation>
<translation id="1118429183611783760">ОЕОЋОљОЉОЎ ОљОЉОД ОЋОЌОЋОъОеОЎ ОаОЎОДОЎОЋОЪ ОюОеОдОцОЋОф</translation>
<translation id="1122714970786750095">ОљОюОДОўОеОЋОаОЎОДОћ ОЋОЌОЕОъОю</translation>
<translation id="1123753900084781868">ОћОЏОфОЋОЉОЎОЋОф ОћОъОЎОЎОЊОЎОЋОф ОюОљ ОќОъОЎОаОЋОф ОбОЏОЕОЎОЋ.</translation>
<translation id="1125453215844207206">РђЈОњОеОцОЎОДОћ ОюОюОљ ОфОЎОљОЋОе. ОъОфОЉОдОб ОЌОЎОюОЋОЦ ОўОДОАОў ОЕОъОЉОЋОАОА ОбОю AI ОъОЉОЎОф Google</translation>
<translation id="1125573121925420732">ОюОцОбОъОЎОЮ ОъОЋОцОЎОбОЋОф ОљОќОћОеОЋОф ОЉОќОъОЪ ОЕОљОфОеОЎОЮ ОъОбОЊОЏОаОЎОЮ ОљОф ОћОљОЉОўОЌОћ ОЕОюОћОЮ. ОќОћ ОљОъОЋОе ОюОћОЎОцОАОД ОЉОДОеОЋОЉ.</translation>
<translation id="112840717907525620">ОћОъОўОъОЋОЪ ОЕОю ОћОъОЊОЎОаОЎОЋОф ОфОДОЎОЪ</translation>
<translation id="1131264053432022307">ОфОъОЋОаОћ ОЕОћОбОфОДОф</translation>
<translation id="1138458427267715730">ОДОЉОюОф ОћОфОеОљОЋОф ОЏОЕОЎОЕ ОћОаОЌОЋОф ОЉОљОфОеОЎОЮ ОЉОљОЎОаОўОеОаОў</translation>
<translation id="1142713751288681188">ОАОЋОњ ОћОаОЎОЎОе</translation>
<translation id="1144136880160289237">ОбОЋОЊ ОљОЎОЪ ОаОЋОЕОљОЎОЮ ОцОбОЎОюОЎОЮ</translation>
<translation id="1149617035358809955">ОюОљОъОф ОљОф ОќОћОЋОфОџ ОюОдОЋОеОџ ОъОЎОюОЋОЎ ОцОеОўОЎ ОћОфОЕОюОЋОЮ ОЕОюОџ</translation>
<translation id="1150565364351027703">ОъОЕОДОцОЎ ОЕОъОЕ</translation>
<translation id="1150979032973867961">ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />. ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОюОљ ОаОЌОЕОЉ ОЏОъОћОЎОъОЪ ОбОю ОЎОЊОЎ ОъОбОеОЏОф ОћОћОцОбОюОћ ОЕОю ОћОъОЌОЕОЉ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОфОдОЋОеОћ ОЕОњОЋОЎОћ ОљОЋ ОфОЋОДОБ ОћОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ.</translation>
<translation id="1151972924205500581">ОаОЊОеОЕОф ОАОЎОАОъОћ</translation>
<translation id="1156303062776767266">ОъОЋОдОњ ОюОџ ОДОЋОЉОЦ ОъОДОЋОъОЎ ОљОЋ ОъОЕОЋОфОБ</translation>
<translation id="1158211211994409885"><ph name="HOST_NAME" /> ОАОњОе ОљОф ОћОЌОЎОЉОЋОе ОЉОљОЋОцОЪ ОЉОюОфОЎ ОдОцОЋОЎ.</translation>
<translation id="1160009341934077418">ОћОЎОАОўОЋОеОЎОЎОф ОћОъОЌОЎОеОЎОЮ ОЉОљОЎОаОўОеОаОў</translation>
<translation id="1161325031994447685">РђЈОюОћОфОЌОЉОе ОъОЌОЊОЕ ОљОю Оћ-Wi-Fi</translation>
<translation id="1161663161838091892">ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОдОеОЎОџ ОюОАОаОЏОеОЪ ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЋОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="1163507966173624031">ОъОЋОќОЎОДОф ОцОЋОюОД ОЋОъОЋОќОЎОДОћ ОъОАОЋОеОфОЎОф</translation>
<translation id="11635448457105324">РђЈОћОЏОцОфОЋОе ОюОаОЎОћОЋОю ОћОЏОфОЋОЉОЋОф, ОъОцОбОЎОюОЎОЮ ОљОЋОфОЋ ОЏОЊОЎ ОюОћОЋОАОЎОБ ОЋОюОаОћОю ОЏОфОЋОЉОЋОф ОЉОћОњОЊОеОЋОф Chrome</translation>
