<translation id="473775607612524610">ОбОЊОЏОЋОЪ</translation>
<translation id="4738601419177586157"><ph name="TEXT" /> РђЊ ОћОдОбОф ОЌОЎОцОЋОЕ</translation>
<translation id="4742407542027196863">ОаОЎОћОЋОю ОАОЎОАОъОљОЋОфРђд</translation>
<translation id="4743275772928623722">ОћОъОбОеОЏОф ОбОЋОЊОЏОаОћ ОљОЉОю ОЌОюОД ОъОћОљОцОюОЎОДОдОЎОЋОф ОЋОћОДОЉОдОЎОЮ ОЕОюОџ ОюОљ ОЕОЋОЌОќОеОЋ. ОћОљОцОюОЎОДОдОЎОЋОф ОЎОЋОеОЊОЋ ОъОЌОЊОЕ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ.</translation>
<translation id="4744514002166662487">ОЎОдОЎОеОф ОъОдОњОф</translation>
<translation id="4744603770635761495">ОаОфОЎОЉ ОюОћОцОбОюОћ</translation>
<translation id="4744816391336495134">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОўОЉОЎОбОф ОћОљОдОЉОб ОЏОЊОЎ ОюОљОъОф ОљОф ОќОћОЋОфОџ ОЉОЏОю ОЕОЎОъОЋОЕ ОЉОАОЎОАОъОћ ОЕОъОЋОеОћ</translation>
