<translation id="8012116502927253373">{NUM_CARDS,plural, =1{ОћОЏОеОўОЎОА ОћОќОћ ОЎОЎОЕОъОе ОЎОЌОЊ ОбОЮ ОћОЏОфОЋОЉОф ОЕОюОЋ ОюОЌОЎОЋОЉ. ОЎОфОљОцОЕОе ОюОџ ОюОћОЕОфОъОЕ ОЉОЋ ОюОљОЌОе ОћОфОЌОЉОеОЋОф ОљОю <ph name="USER_EMAIL" />.}one{ОћОЏОеОўОЎОАОЎОЮ ОћОљОюОћ ОЎОЎОЕОъОеОЋ ОЎОЌОЊ ОбОЮ ОћОЏОфОЋОЉОЋОф ОЕОюОћОЮ ОюОЌОЎОЋОЉ. ОЎОфОљОцОЕОе ОюОџ ОюОћОЕОфОъОЕ ОЉОћОЮ ОюОљОЌОе ОћОфОЌОЉОеОЋОф ОљОю <ph name="USER_EMAIL" />.}two{ОћОЏОеОўОЎОАОЎОЮ ОћОљОюОћ ОЎОЎОЕОъОеОЋ ОЎОЌОЊ ОбОЮ ОћОЏОфОЋОЉОЋОф ОЕОюОћОЮ ОюОЌОЎОЋОЉ. ОЎОфОљОцОЕОе ОюОџ ОюОћОЕОфОъОЕ ОЉОћОЮ ОюОљОЌОе ОћОфОЌОЉОеОЋОф ОљОю <ph name="USER_EMAIL" />.}other{ОћОЏОеОўОЎОАОЎОЮ ОћОљОюОћ ОЎОЎОЕОъОеОЋ ОЎОЌОЊ ОбОЮ ОћОЏОфОЋОЉОЋОф ОЕОюОћОЮ ОюОЌОЎОЋОЉ. ОЎОфОљОцОЕОе ОюОџ ОюОћОЕОфОъОЕ ОЉОћОЮ ОюОљОЌОе ОћОфОЌОЉОеОЋОф ОљОю <ph name="USER_EMAIL" />.}}</translation>
