<translation id="7669907849388166732">{COUNT,plural, =1{ОћОцОбОЋОюОЋОф ОЕОаОаОДОўОЋ ОбОЮ ОаОфОЋОаОЎОЮ ОЕОАОЋОъОаОЋ ОЏОАОЋОЊОЎОЎОЮ (ОцОбОЋОюОћ ОљОЌОф ОЊОЋОЋОЌОћ ОъОљОќ ОћОћОфОЌОЉОеОЋОф). <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" />}one{ОћОцОбОЋОюОЋОф ОЕОаОаОДОўОЋ ОбОЮ ОаОфОЋОаОЎОЮ ОЕОАОЋОъОаОЋ ОЏОАОЋОЊОЎОЎОЮ (# ОцОбОЋОюОЋОф ОЊОЋОЋОЌОЋ ОъОљОќ ОћОћОфОЌОЉОеОЋОф). <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" />}two{ОћОцОбОЋОюОЋОф ОЕОаОаОДОўОЋ ОбОЮ ОаОфОЋОаОЎОЮ ОЕОАОЋОъОаОЋ ОЏОАОЋОЊОЎОЎОЮ (# ОцОбОЋОюОЋОф ОЊОЋОЋОЌОЋ ОъОљОќ ОћОћОфОЌОЉОеОЋОф). <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" />}other{ОћОцОбОЋОюОЋОф ОЕОаОаОДОўОЋ ОбОЮ ОаОфОЋОаОЎОЮ ОЕОАОЋОъОаОЋ ОЏОАОЋОЊОЎОЎОЮ (# ОцОбОЋОюОЋОф ОЊОЋОЋОЌОЋ ОъОљОќ ОћОћОфОЌОЉОеОЋОф). <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" />}}</translation>
