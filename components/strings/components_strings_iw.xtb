<translation id="766014026101194726">{0,plural, =1{ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОћОљОЊОъОЎОЪ, ОћОбОюОљОф ОћОДОЋОЉОЦ ОћОќОћ ОаОЌОАОъОћ}one{ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОћОљОЊОъОЎОЪ, ОћОћОбОюОљОћ ОЕОю # ОДОЉОдОЎОЮ ОаОЌОАОъОћ}two{ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОћОљОЊОъОЎОЪ, ОћОћОбОюОљОћ ОЕОю # ОДОЉОдОЎОЮ ОаОЌОАОъОћ}other{ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОћОљОЊОъОЎОЪ, ОћОћОбОюОљОћ ОЕОю # ОДОЉОдОЎОЮ ОаОЌОАОъОћ}}</translation>
