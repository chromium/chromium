<translation id="1519264250979466059">РђЈОфОљОеОЎОџ Оћ-Build</translation>
<translation id="1521655867290435174">Google Sheets</translation>
<translation id="1524669537550112617">ОЎОЌОЎОЊОЋОф ОЊОЎОЋОе ОъОеОЋОћОўОЋОф ОюОћОЕОЏОеОћ</translation>
<translation id="1527263332363067270">ОфОЎОЏОБ ОаОфОЌОЉОеРђд</translation>
<translation id="1528311629279578926">ОћОЌОЎОЉОЋОе ОаОЌОАОЮ ОЏОЎ ОћОЋОљ ОћОЋОцОбОю ОбОю ОЎОЊОЎ ОЊОБ ОдОЎОЉОЋОеОЎ ОЏОЊОЎ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОеОЎОЮ ОљОЋ ОюОЕОеОфОЎОЮ ОЉОеОЕОф ОћОцОеОўОЎОф ОЕОюОџ. ОЏОЊОЎ ОюОљОЕОе ОљОф ОћОЌОЎОЉОЋОе, ОдОеОЎОџ ОюОўОбОЋОЪ ОъОЌОЊОЕ ОљОф ОћОЊОБ ОћОќОћ.</translation>
<translation id="1529789484829130889">ОъОњОЕ 8</translation>
<translation id="1530707389502320859">РђЈОћОљОфОе ОЕОаОЎОАОЎОф ОюОЉОДОе ОЉОЋ ОаОеОљОћ ОЏОъОЋ ОљОфОе ОъОќОЋОЎОБ. ОфОЋОДОцОЎОЮ ОЕОъОЌОДОЎОЮ ОљОфОеОЎОЮ ОюОцОбОъОЎОЮ ОъОЕОфОъОЕОЎОЮ ОЉОЏОфОЋОЉОф Оћ-URL ОЕОю ОћОљОфОе ОћОъОДОЋОеОЎ ОЋОбОЋОЕОЎОЮ ОЉОћ ОЕОЎОаОЋОЎОЎОЮ ОДОюОЎОЮ ОЉОЎОЋОфОе ОЏОЊОЎ ОЕОЎОћОЎОћ ОДОЕОћ ОюОћОЉОЌОЎОЪ ОЉОћОЉОЊОю.</translation>
<translation id="1532118530259321453">ОћОЊОБ ОћОќОћ ОљОЋОъОе</translation>
<translation id="1533966801397200693">ОћОцОеОЋОцОЎОю ОЕОљОюОЎОЋ ОаОЏОаОАОф ОћОЋОљ ОцОеОЋОцОЎОю ОъОаОЋОћОю. ОюОљОЊОъОЎОЪ ОЎОЕ ОљОцОЕОеОЋОф ОюОЕОаОЋОф ОъОеОЌОЋОД ОљОф ОћОњОЊОеОЋОф ОћОцОеОЋОцОЎОю, ОюОаОфОЌ ОъОЎОЊОб ОбОю ОћОЊОцОЊОцОЪ ОЉОљОъОдОбОЋОф ОЊОЋОЌОЋОф ОЋОюОЉОдОб ОъОЕОЎОъОЋОф ОЌОЕОЋОЉОЋОф ОљОЌОеОЋОф. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="1536390784834419204">ОфОеОњОЋОЮ ОћОЊОБ</translation>
<translation id="1538295100801850685">ОЕОЎОцОЋОеОЎОЮ ОЉОЌОЎОќОЋОЎ</translation>
<translation id="1539840569003678498">ОћОЊОЋОЌ ОаОЕОюОЌ:</translation>
<translation id="1542105669288201090">ОюОЎОъОЋОЊОЎ ОъОаОћОю ОбОАОДОЎОЮ</translation>
<translation id="1545757265410828525">ОћОЎОАОўОЋОеОЎОЎОф ОћОъОЌОЎОеОЎОЮ</translation>
<translation id="1549470594296187301">РђЈJavaScript ОдОеОЎОџ ОюОћОЎОЋОф ОъОЋОцОбОю ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОфОЏОЋОаОћ ОќОЋ.</translation>
<translation id="1553152622374372421">ОбОаОцОЎ ОАОцОЋОеОў ОЌОЋОеОБ</translation>
<translation id="1553358976309200471">РђЈОЏОЊОљОЎ ОюОбОЊОЏОЪ ОљОф Chrome</translation>
<translation id="1554485704925237240">ОЕОюОЎОўОћ ОЉОДОЋОеОљОЎОЮ ОЉОЕОЮ <ph name="READERNAME" /> ОЋОЉОЏОеОўОЎОАОЎОЮ ОћОЌОЏОъОЎОЮ ОЕОаОДОеОљОЎОЮ ОЉОљОъОдОбОЋОфОЮ</translation>
<translation id="1555130319947370107">ОЏОЌОЋОю</translation>
<translation id="1555191101192706055">ОфОЋОДОцОЎОЮ ОЉОљОфОе ОЕОЉОЋ ОаОЎОАОЎОф ОюОЉОДОе ОбОЕОЋОЎОЎОЮ ОюОњОеОЋОЮ ОюОџ ОЉОЊОеОЏОЎ ОъОеОъОћ ОюОћОфОДОЎОЪ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЕОъОЕОцОЎОбОЋОф ОбОю ОљОЋОцОЪ ОћОњОюОЎОЕОћ ОЕОюОџ. ОюОЊОЋОњОъОћ, ОбОю ОЎОЊОЎ ОЕОЎОаОЋОЎ ОЊОБ ОћОЉОЎОф ОљОЋ ОћОдОњОф ОъОЋОЊОбОЋОф ОаОЋОАОцОЋОф ОЉОљОфОеОЎОЮ ОЕОъОЉОДОеОЎОЮ ОЉОћОЮ.</translation>
<translation id="1559231233244409191">Cardboard (Triple Wall)</translation>
<translation id="1559447966090556585">ОюОљОцОЕОе ОДОЉОюОф ОћОфОеОљОЋОф?</translation>
<translation id="1559486004335285648">ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЕОю ОцОеОўОЎ ОћОфОЕОюОЋОЮ</translation>
<translation id="1559528461873125649">ОљОЎОЪ ОДОЋОЉОЦ ОљОЋ ОАОцОеОЎОЎОћ ОЉОЕОЮ ОќОћ</translation>
<translation id="1559572115229829303">РђЈ&lt;p&gt;ОюОљ ОаОЎОфОЪ ОюОЎОдОЋОе ОЌОЎОЉОЋОе ОцОеОўОЎ ОљОю <ph name="BEGIN_BOLD" /><ph name="DOMAIN" /><ph name="END_BOLD" /> ОъОЕОЋОЮ ОЕОћОфОљОеОЎОџ ОЋОћОЕОбОћ ОЉОъОЏОЕОЎОе ОЕОюОџ (<ph name="DATE_AND_TIME" />) ОЕОњОЋОЎОЎОЮ.&lt;/p&gt;

      &lt;p&gt;ОЎОЕ ОюОЕОаОЋОф ОљОф ОћОфОљОеОЎОџ ОЋОћОЕОбОћ ОЉОДОўОб &lt;strong&gt;ОЏОюОюОЎ&lt;/strong&gt; ОЉОљОцОюОЎОДОдОЎОћ &lt;strong&gt;ОћОњОЊОеОЋОф&lt;/strong&gt;РђЈ.&lt;/p&gt;</translation>
<translation id="1559839503761818503">ОћОъОЏОЕОЎОе ОЎОЋОцОбОю ОъОЌОЊОЕ ОбОю ОЎОЊОЎ ОћОљОЊОъОЎОЪ ОЉОЕОбОћ <ph name="TIME" /> ОЉОфОљОеОЎОџ <ph name="DATE" /></translation>
