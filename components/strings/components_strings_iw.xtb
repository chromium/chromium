<translation id="2268044343513325586">ОдОъОдОЋОЮ</translation>
<translation id="2268966938956566076">ОћОбОюОљОћ ОЉОбОЋОЊ <ph name="MINUTES" /> ОЊОД'</translation>
<translation id="2270484714375784793">ОъОАОцОе ОўОюОцОЋОЪ</translation>
<translation id="2276057643614339130">ОЉОАОЎОА ОћОЊОцОАОћ</translation>
<translation id="2277103315734023688">ОћОеОдОћ ОДОЊОЎОъОћ</translation>
<translation id="2277753418458118549">ОћОдОњОф ОцОеОўОЎ ОћОЌОЎОЉОЋОе</translation>
<translation id="2277949605527755300">РђФ<ph name="URL" /> ОеОЋОдОћ ОюОбОДОЋОЉ ОљОЌОе ОфОаОЋОбОЋОф ОћОЎОЊОЎОЎОЮ ОЕОюОџ</translation>
<translation id="22792995594807632">ОаОЊОеОЕОф ОЉОЊОЎОДОћ ОюОцОаОЎ ОћОћОЋОеОЊОћ</translation>
<translation id="2283340219607151381">ОЕОъОЎОеОћ ОЋОъОЎОюОЋОЎ ОЕОю ОЏОфОЋОЉОЋОф</translation>
<translation id="2283447177162560884">ОЉОЋОдОбОћ ОъОЌОЎОДОћ ОЕОю '<ph name="PAGE_TITLE" />'</translation>
<translation id="2286383991450886080">РђЈ34x44 ОљОЎОаОЦ'</translation>
<translation id="2288422996159078444">ОЏОю ОћОДОюОЊОф ОўОДОАОў, ОћОдОњОф ОЊОБ ОљОЋ ОцОбОЎОюОЋОф ОљОЌОеОф ОЉОљОЎОаОўОеОаОў ОаОъОдОљОф ОЉОъОбОДОЉ. ОЉОаОЋОАОБ, ОћОфОЋОЏОЪ ОЉОљОфОеОЎОЮ ОбОЕОЋОЎ ОюОћОЕОфОаОЋОф ОюОюОљ ОЎОЊОЎОбОфОџ.</translation>
<translation id="2289385804009217824">ОЌОЎОфОЋОџ</translation>
<translation id="2292556288342944218">ОћОњОЎОЕОћ ОюОљОЎОаОўОеОаОў ОЌОАОЋОъОћ</translation>
<translation id="2293443924986248631">РђЈОЏОЕОћОљОцОЕОеОЋОф ОъОЋОцОбОюОф, ОљОфОеОЎОЮ ОюОљ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОЏОЊОЎ ОюОбОДОЋОЉ ОљОЌОеОЎОџ ОЉОљОЎОаОўОеОаОў. ОЎОЎОфОЏОаОЋ ОЕОЎОЉОЋОЕОЎОЮ ОЉОцОбОЋОюОћ ОЕОю ОфОЏОЋОаОЋОф ОЉОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ.</translation>
<translation id="2295831393422400053">ОћОцОбОюОф ОћОћОњОЊОеОћ 'ОЕОЎОцОЋОе ОћОЌОЎОцОЋОЕОЎОЮ ОЋОћОњОюОЎОЕОћ' ОюОдОЋОеОџ ОЕОЎОъОЋОЕ ОЉОфОЏОЋОаОћ 'ОбОќОеОћ ОЉОЏОфОЎОЉОћ'</translation>
<translation id="2296244067976588032">РђЈОъОцОфОЌ ОњОЎОЕОћ Рђб iCloud Keychain</translation>
<translation id="2300306941146563769">ОюОљ ОћОЋОбОюОћ</translation>
<translation id="2301098101308036335">ОљОфОеОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОЋОќОъОаОЎ ОћОЉОЎОДОЋОеОЎОЮ.</translation>
<translation id="230286397113210245">ОћОЏОцОфОЋОе ОюОцОфОЎОЌОф ОЌОюОЋОЪ ОцОеОўОЎ, ОъОцОбОЎОюОЎОЮ ОљОЋОфОЋ ОЏОЊОЎ ОюОцОфОЋОЌ ОЌОюОЋОЪ ОцОеОўОЎ ОЌОЊОЕ ОЋОюОњОюОЋОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ</translation>
<translation id="2306124309679506798">ОеОЋОдОћ ОюОЎОћОаОЋОф ОъОЌОЋОЋОЎОћ ОАОЋОЌОцОф?</translation>
<translation id="2312234273148520048">ОфОЉОюОЎОаОЎОЮ ОЋОеОўОЉОЎОЮ</translation>
<translation id="2316087952091171402">ОцОЌОЋОф Оъ-<ph name="UPPER_ESTIMATE" />. ОЉОЉОЎОДОЋОе ОћОЉОљ ОЕОюОџ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЎОЎОўОбОаОЋ ОюОљОў ОЎОЋОфОе.</translation>
<translation id="2316159751672436664">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОЏОюОЎ ОћОаОњОЎОЕОЋОф ОЉОћОњОЊОеОЋОф ChromeOS</translation>
<translation id="2316887270356262533">РђЈОцОЎОаОЋОЎ ОЕОю ОцОЌОЋОф Оъ-Рђј1 MBРђј ОъОћОЕОўОЌ. ОЎОЎОфОЏОЪ ОЕОЌОюОД ОъОћОљОфОеОЎОЮ ОЎОЎОўОбОаОЋ ОюОљОў ОЎОЋОфОе ОЉОЉОЎОДОЋОе ОћОЉОљ ОЕОюОџ.</translation>
<translation id="2317259163369394535"><ph name="DOMAIN" /> ОЊОЋОеОЕ ОЕОЮ ОъОЕОфОъОЕ ОЋОАОЎОАОъОћ.</translation>
<translation id="2318594867107319532">ОЌОЋОфОъОф ОћОќОъОЪ ОћОљОЌОеОЋОаОћ ОЕОю ОћОъОЊОЎОаОЎОЋОф:</translation>
<translation id="2320564945062300737">ОъОЋОдОеОЎ ОўОЎОцОЋОЌ ОюОбОЋОе ОћОцОаОЎОЮ</translation>
<translation id="2322254345061973671">{COUNT,plural, =1{ОЌОюОЋОЪ ОљОЌОЊ}one{РђФ# ОЌОюОЋОаОЋОф}two{РђФ# ОЌОюОЋОаОЋОф}other{РђФ# ОЌОюОЋОаОЋОф}}</translation>
<translation id="2328651992442742497">ОЎОЕ ОћОеОЕОљОћ (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="2328955282645810595">ОЏОюОЎ ОЉОаОЎОЎОћ ОЋОЏОюОЎ ОбОЉОЋОЊОћ ОъОъОЋОаОбОЎОЮ</translation>
<translation id="2330137317877982892"><ph name="CREDIT_CARD" />, ОЉОфОЋОДОБ ОбОЊ <ph name="EXPIRATION_DATE_ABBR" /></translation>
<translation id="2337852623177822836">ОћОћОњОЊОеОћ ОаОЕОюОўОф ОбОю-ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="2340263603246777781"><ph name="ORIGIN" /> ОеОЋОдОћ ОюОЉОдОб ОћОфОљОъОћ ОбОЮ</translation>
<translation id="2344529975040861103">РђЈОљОцОЕОе ОюОъОюОљ ОљОф ОћОцОеОўОЎОЮ ОЕОю ОћОЏОеОўОЎОА ОћОќОћ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЏОЎ ОћОЌОЕОЉОЋОЪ ОъОДОЋОЕОе Ою-Google Pay</translation>
<translation id="2346319942568447007">ОфОъОЋОаОћ ОЕОћОбОфОДОф</translation>
<translation id="2348509731468399833">ОъОбОДОЉ ОћОъОЌОЎОеОЎОЮ ОћОЋОцОАОД</translation>
<translation id="2349957959687031096">ОћОЏОцОфОЋОе ОюОцОфОЎОЌОф ОЏОеОўОЎОАОЎОЎОћ ОцОеОўОЎОф, ОъОцОбОЎОюОЎОЮ ОљОЋОфОЋ ОЏОЊОЎ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЎОћ ОцОеОўОЎОф ОЌОЊОЕОћ ОЋОюОњОюОЋОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ</translation>
<translation id="2350796302381711542">ОћОљОЮ ОюОљОцОЕОе Ою-<ph name="HANDLER_HOSTNAME" /> ОюОцОфОЋОЌ ОљОф ОЏОю ОДОЎОЕОЋОеОЎ <ph name="PROTOCOL" /> ОЉОъОДОЋОЮ ОљОф <ph name="REPLACED_HANDLER_TITLE" />?</translation>
<translation id="2353297238722298836">ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОЊОБ ОќОћ ОЉОъОдОюОъОћ ОЋОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="2354001756790975382">ОАОЎОъОаОЎОЋОф ОљОЌОеОЋОф</translation>
<translation id="2355395290879513365">ОЎОЎОфОЏОЪ ОЕОфОЋОДОцОЎОЮ ОЎОЋОЏОюОЋ ОюОеОљОЋОф ОљОф ОћОфОъОЋОаОЋОф ОЕОЉОћОЪ ОдОцОЎОф ОЉОљОфОе ОќОћ, ОЋОюОљОЌОе ОъОЏОЪ ОћОЮ ОЎОаОАОЋ ОюОћОЋОаОЋОф ОљОЋОфОџ ОбОю ОЎОЊОЎ ОЕОЎОаОЋОЎ ОћОфОъОЋОаОЋОф.</translation>
<translation id="2356070529366658676">ОюОЕОљОЋОю</translation>
<translation id="2356926036049612643">РђЈОЏОюОЎ ОћОљОЋОцОўОЎОъОЎОќОдОЎОћ ОЕОю V8</translation>
<translation id="2356941001189392209">РђЈОеОЕОЎОъОћ ОЌОюОДОЎОф ОЕОю ОЏОфОЋОЉОЋОф URL ОЕОю ОЊОцОЎОЮ ОбОЮ ОљОЎОеОЋОбОЎ ОЕОЎОъОЋОЕ ОЉОўОЏОаОЋОюОЋОњОЎОћ ОъОЊОЋОе ОДОЋОЊОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ</translation>
<translation id="2357481397660644965">ОћОъОЏОЕОЎОе ОЕОюОџ ОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="DEVICE_MANAGER" /> ОЋОћОЌОЕОЉОЋОЪ ОЕОюОџ ОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="ACCOUNT_MANAGER" />.</translation>
<translation id="2359629602545592467">ОъОўОЉОбОЋОф ОъОеОЋОЉОЎОЮ</translation>
<translation id="2359808026110333948">ОћОъОЕОџ</translation>
<translation id="2361263712565360498">РђЈ275x395 Оъ"Оъ</translation>
<translation id="236340516568226369">ОфОцОеОЎОў ОъОфОњОЎОЮ ОюОЕОЎОаОЋОЎ ОњОЋОЊОю</translation>
<translation id="2365355378251437925">ОЎОЕ ОюОћОќОЎОЪ <ph name="FIELD" /></translation>
<translation id="2365382709349300355">ОДОЋОЉОЦ ОљОЌОЊ ОаОЌОАОЮ ОъОАОЎОЉОЋОф ОЕОДОЕОЋОеОЋОф ОюОъОЊОЎОаОЎОЋОф</translation>
<translation id="2365508935344991784">ОеОЎОћОЋОў ОюОњОЎОаОћ</translation>
<translation id="2366689192918515749">ОЉОЕОе ОЋОъОљОЏОюОЎ ОЎОЮ</translation>
<translation id="2367567093518048410">ОеОъОћ</translation>
<translation id="23703388716193220">ОдОЎОЋОЊ ОюОњОЋОюОБ</translation>
<translation id="2370368710215137370">ОћОбОюОљОф ОДОЉОдОЎОЮ</translation>
<translation id="2374629208601905275">РђЈОЉОћОфОљОЮ ОюОЌОЋОД ОЉОљОќОЋОе ОЕОюОџ, ОбОюОЎОџ ОюОЉОЌОЋОе ОљОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОЎОЋОњОЊОе ОЏОЉОеОЎОеОф ОћОъОЌОЊОю ОЉ-Chrome. ОъОаОЋОбОЎ ОћОЌОЎОцОЋОЕ ОћОљОюОћ ОцОЋОцОЋОюОеОЎОЎОЮ ОЉОљОќОЋОе ОЕОюОџ ОЋОъОЋОдОњОЎОЮ ОЉОАОЊОе ОљОДОеОљОЎ.</translation>
<translation id="2376455483361831781">ОўОЉОюОћ ОЌОЊОЕОћ</translation>
<translation id="2377241607395428273">ОфОЋОЏОаОЋОф ОњОеОцОЎОДОћ ОЋОљОаОЎОъОдОЎОћ</translation>
<translation id="2378084239755710604">ОњОЎОюОЎОЋОЪ ОЕОъОЎОеОф ОћОЏОеОўОЎОА ОаОАОњОе.</translation>
<translation id="237978325638124213">ОЉОЕОъОЎОЮ ОЋОаОЎОЌОЋОЌОЋОф</translation>
<translation id="2380886658946992094">Legal</translation>
<translation id="2383455408879745299">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОЏОюОЎ ОћОаОњОЎОЕОЋОф ОЉОћОњОЊОеОЋОф Chrome</translation>
<translation id="2384307209577226199">ОЉОеОЎОеОф ОъОЌОЊОю ОЕОю ОљОеОњОЋОЪ</translation>
<translation id="238459632961158867">ОљОфОе</translation>
<translation id="2385809941344967209">РђЈОбОЊОЏОЋОЪ Chrome ОЊОеОџ ОћОњОЊОеОЋОф Chrome</translation>
<translation id="2386255080630008482">ОљОЎОЕОЋОе ОћОЕОеОф ОаОЕОюОю.</translation>
<translation id="2388828676877700238">ОЎОЎОбОЋОЦ ОЋОфОЏОаОЋОЪ ОъОА</translation>
<translation id="239203817277685015">ОЎОЋОфОе ОъОцОЋОеОў</translation>
<translation id="239293030466334554">ОъОЏОЋОаОЎОЋОф ОбОЮ ОњОњ ОаОцОфОЌ</translation>
<translation id="2392959068659972793">ОћОдОњОф ОъОЊОЎОаОЎОЋОф ОюОюОљ ОбОеОџ ОъОЋОњОЊОе</translation>
<translation id="239429038616798445">ОЕОЎОўОф ОћОъОЕОюОЋОЌ ОћОќОЋ ОюОљ ОќОъОЎОаОћ. ОбОюОЎОџ ОюОЉОЌОЋОе ОЕОЎОўОћ ОљОЌОеОф.</translation>
<translation id="2395840535409704129">ОАОцОЋОеОў ОъОЎОЮ</translation>
<translation id="2396249848217231973">&amp;ОЉОЎОўОЋОю ОъОЌОЎОДОћ</translation>
<translation id="2399344929880464793">РђЈОћ-IBAN ОћОќОћ ОаОЕОъОе ОЉОЌОЕОЉОЋОЪ Google, ОЏОџ ОЕОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОЋ ОЉОЏОю ОЕОЎОеОЋОфОЎ Google.</translation>
<translation id="2399868464369312507">РђЈGoogle Chrome ОъОаОАОћ ОюОбОеОЋОџ ОљОф ОљОъОдОбОЎ ОћОфОЕОюОЋОЮ.</translation>
<translation id="2400600116338235695">ОћОљОфОе ОЎОЏОЋОю ОюОЉОДОЕ ОћОеОЕОљОћ ОюОћОфОЌОЉОе ОюОЎОдОЎОљОЋОф ОўОЋОеОЎОЋОф</translation>
<translation id="2404884497378469141">ОеОЋОдОћ ОюОаОАОЋОф ОЕОЋОЉ ОюОћОбОфОЎОД ОљОф ОћОДОЉОдОЎОЮ?</translation>
<translation id="2413155254802890957">ОЎОЕОаОћ</translation>
<translation id="2413528052993050574">ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />. ОЎОЎОфОЏОЪ ОЕОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОЉОЋОўОю. ОћОАОЎОЉОћ ОюОЏОџ ОбОЕОЋОЎОћ ОюОћОЎОЋОф ОћОњОЊОеОћ ОЕОњОЋОЎОћ ОљОЋ ОфОЋОДОБ ОћОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ.</translation>
<translation id="2414886740292270097">ОЏОћОћ</translation>
<translation id="2429716554270894715">Fabric (Waterproof)</translation>
<translation id="2436186046335138073">ОћОљОЮ ОюОљОцОЕОе Ою-<ph name="HANDLER_HOSTNAME" /> ОюОцОфОЋОЌ ОљОф ОЏОю ОДОЎОЕОЋОеОЎ <ph name="PROTOCOL" />?</translation>
<translation id="2436976580469434549">ОљОЋОъОаОЋОЎОЋОф ОўОДОАОўОЎОю ОЋОљОеОЎОњОЎОЮ</translation>
<translation id="243815215670139125">РђЈОюОљ ОаОЎОфОЪ ОюОЕОъОЋОе ОљОф ОћОЏОеОўОЎОА ОћОќОћ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google. ОЉОъОДОЋОЮ ОќОљОф, ОћОЋОљ ОаОЕОъОе ОЉ-Chrome ОЉОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="2438874542388153331">4 ОаОЎОДОЋОЉОЎОЮ ОЉОдОЊ ОЎОъОЎОЪ</translation>
<translation id="2441854154602066476">ОеОЕОЎОъОф ОљОъОдОбОЎ ОћОфОЕОюОЋОЮ ОћОќОъОЎОаОЎОЮ ОюОъОЎОюОЋОЎ ОЉОъОњОб. ОћОъОДОюОЊОф ОъОЋОАОфОеОф.</translation>
<translation id="2442865686365739754">РђЈ<ph name="BEGIN_EMPHASIS" />ОюОљ ОЎОЎОЕОъОеОЋ<ph name="END_EMPHASIS" /> ОЉ-Chrome ОћОаОфОЋОаОЎОЮ ОћОЉОљОЎОЮ:
          <ph name="BEGIN_LIST" />
            <ph name="LIST_ITEM" />ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЕОюОџ
            <ph name="LIST_ITEM" />ОДОЋОЉОдОЎ Cookie ОЋОаОфОЋОаОЎОЮ ОъОљОфОеОЎОЮ
            <ph name="LIST_ITEM" />ОъОЎОЊОб ОЕОћОЋОќОЪ ОЉОўОцОАОЎОЮ
          <ph name="END_LIST" /></translation>
<translation id="2448295565072560657">ОдОЎОЋОЊ ОћОЎОДОцОЎ ОЕОъОЌОЋОЉОе ОюОъОЏОЕОЎОе ОћОќОћ ОюОљОЌОе ОћОфОЌОЉОеОЋОф ОюОЌОЕОЉОЋОЪ ОЕОюОџ</translation>
<translation id="2451607499823206582">ОЉОъОбОДОЉ</translation>
<translation id="2452098632681057184">ОљОДОЋОюОЋОњОЎОћ ОЋОАОЉОЎОЉОћ</translation>
<translation id="2452837234288608067">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОбОќОЋОе ОЉОЉОДОЕОћ ОћОќОЋ. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="2456755709261364512">ОеОъОф ОћОўОбОЎОаОћ ОЕОю ОћОАОЋОюОюОћ ОдОеОЎОЏОћ ОюОћОЎОЋОф ОњОЉОЋОћОћ Оъ-<ph name="REQUIRED_BATTERY_PRECENT" />%</translation>
<translation id="2461385121573678775">РђЈРђФChrome Enterprise Core ОћОЋОљ ОЏОюОЎ ОъОеОЏОќОЎ ОюОћОњОЊОеОћ ОЕОю ОЏОюОюОЎ ОъОЊОЎОаОЎОЋОф ОюОЊОцОЊОцОЪ ОЊОеОџ ОћОбОаОЪ</translation>
<translation id="2461822463642141190">ОЏОеОњОб</translation>
<translation id="2462932596748424101">ОеОЕОфОЋОф ОЌОЉОеОфОЎОЋОф</translation>
<translation id="2465688316154986572">ОАОЎОЏОф ОћОЎОЊОЋОД</translation>
<translation id="2465914000209955735">РђЈОаОЎОћОЋОю ОћОДОЉОдОЎОЮ ОЕОћОЋОеОЊОф ОЉ-Chrome</translation>
<translation id="2466004615675155314">ОћОдОњОф ОъОЎОЊОб ОъОћОљОЎОаОўОеОаОў</translation>
<translation id="2466682894498377850">ОћОЏОеОўОЎОАОЎОЎОћ ОаОЕОюОЌОћ ОъОћОъОЏОЕОЎОе <ph name="DEVICE_NAME" /></translation>
<translation id="2467272921457885625">РђЈОъОцОеОўОЎОЮ ОЕОю ОЌОЋОъОеОф ОћОъОЏОЕОЎОе ОЋОаОфОЋОаОЎОЮ ОАОўОўОЎОАОўОЎОЎОЮ ОЏОъОЋ ОћОЎОАОўОЋОеОЎОЎОф ОћОаОЎОдОЋОю ОЕОю ОћОъОбОЉОЊ (CPU)/Оћ-RAM</translation>
<translation id="2467694685043708798"><ph name="BEGIN_LINK" />ОюОћОцОбОЎОю ОљОф ОљОЉОЌОЋОЪ ОћОеОЕОф<ph name="END_LINK" /></translation>
<translation id="2469153820345007638">РђЈОАОЊОе Оъ-1 ОбОЊ N</translation>
<translation id="24699311393038040">Paper (Coated)</translation>
<translation id="2470767536994572628">ОћОъОАОъОџ ОћОќОћ ОЎОЌОќОЋОе ОюОфОдОЋОњОф ОЊОБ ОЎОЌОЎОЊ ОЋОюОъОдОЉ ОћОАОЎОЉОЋОЉ ОћОъОДОЋОеОЎ ОЕОюОЋ ОЉОќОъОЪ ОбОеОЎОЏОф ОћОћОбОеОЋОф</translation>
<translation id="2471632709106952369">ОўОЉОюОљОЋОф ОћОЕОЋОЋОљОћ</translation>
<translation id="2473810985261856484">ОЕОЎОеОЋОфОЎОЮ ОъОЕОцОўОЎОЎОЮ</translation>
<translation id="2479148705183875116">ОюОъОбОЉОе ОљОю ОћОћОњОЊОеОЋОф</translation>
<translation id="2479410451996844060">РђЈОЏОфОЋОЉОф URL ОюОљ ОЌОЋОДОЎОф ОюОЌОЎОцОЋОЕ</translation>
<translation id="2480300195898055381">РђЈОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, <ph name="USER_EMAIL" /></translation>
<translation id="248064299258688299">ОћОфОЋОАОБ <ph name="EXTENSION_NAME" /> ОљОЋОъОе</translation>
<translation id="2482878487686419369">ОћОфОеОљОЋОф</translation>
<translation id="248348093745724435">ОъОЊОЎОаОЎОЋОф ОћОъОЌОЕОЉ</translation>
<translation id="2485243023686553468">ОъОЏОЕОЎОеОЎ ОАОъОљОеОўОцОЋОЪ</translation>
<translation id="2491120439723279231">ОљОЎОЕОЋОе ОћОЕОеОф ОъОЏОЎОю ОЕОњОЎОљОЋОф.</translation>
<translation id="2491414235131909199">ОћОЊОБ ОћОќОћ ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОфОЋОАОБ ОЏОюОЕОћОЋ</translation>
<translation id="2495083838625180221">РђЈОъОаОфОЌ JSON</translation>
<translation id="2496402116964818747">ОЉ<ph name="SETTINGS" /> ОЎОЕ ОљОцОЕОеОЋОф ОюОДОЉОЋОб ОљОЮ ОюОћОЕОфОъОЕ ОЉОўОЉОЎОбОф ОћОљОдОЉОб ОюОъОЎОюОЋОЎ ОАОЎОАОъОљОЋОф</translation>
<translation id="2498091847651709837">ОАОеОЎОДОф ОЏОеОўОЎОА ОЌОЊОЕ</translation>
<translation id="2501270939904835585">Labels (Satin)</translation>
<translation id="2501278716633472235">ОЌОќОеОћ</translation>
<translation id="250346157641628208">Paper (Inkjet)</translation>
<translation id="2505063700931618106">ОцОеОўОЎ ОћОЏОеОўОЎОА ОаОЕОъОеОЋ</translation>
<translation id="2505268675989099013">ОћОњОаОћ ОбОю ОћОЌОЕОЉОЋОЪ</translation>
<translation id="2508626115198287271"><ph name="BENEFIT_DESCRIPTION" /> (ОЉОЏОцОЋОБ ОюОфОаОљОЎОЮ)</translation>
<translation id="2512101340618156538">ОљОЎОЪ ОћОеОЕОљОћ (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="2512413427717747692">РђЈОЏОцОфОЋОе ОюОћОњОЊОеОф Chrome ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю, ОЎОЕ ОюОюОЌОЋОЦ ОбОю Enter ОЏОЊОЎ ОюОћОњОЊОЎОе ОљОф Chrome ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЕОю ОћОъОбОеОЏОф ОЉОћОњОЊОеОЋОф iOS</translation>
<translation id="2514548229949738417">ОЉОЎОф ОЋОњОЪ</translation>
<translation id="2515629240566999685">ОюОЉОЊОЋОД ОљОф ОћОљОЋОф ОЉОљОќОЋОе ОЕОюОџ</translation>
<translation id="2515761554693942801">РђЈОЉОЌОеОф ОюОЉОдОб ОљОЎОъОЋОф ОЉОљОъОдОбОЋОф Touch ID ОЉОљОфОеОЎОЮ ОЕОъОЕОфОъОЕОЎОЮ ОЉ-<ph name="PROVIDER_ORIGIN" />. ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОАОцОД ОћОќОћ ОљОЌОАОЪ ОъОЎОЊОб ОбОю ОљОъОдОбОЎ ОћОфОЕОюОЋОЮ ОЕОюОџ, ОЕОљОЋОфОЋ ОљОцОЕОе <ph name="LINK_TEXT" />.</translation>
<translation id="2518584823165598232">ОћОЏОеОўОЎОА ОћОќОћ ОюОљ ОќОъОЎОЪ. ОбОюОЎОџ ОюОцОаОЋОф ОюОАОцОД ОћОЏОеОўОЎОА ОЕОюОџ.</translation>
<translation id="2521385132275182522">ОАОЎОЏОф ОћОЎОЊОЋОД ОЉОцОЎОаОћ ОћОЎОъОаОЎОф ОћОфОЌОфОЋОаОћ</translation>
<translation id="2521736961081452453">ОЎОдОЎОеОф ОўОЋОцОА</translation>
<translation id="2523886232349826891">ОћОЏОеОўОЎОА ОЎОЎОЕОъОе ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="2524461107774643265">ОћОЋОАОцОф ОбОЋОЊ ОъОЎОЊОб</translation>
<translation id="2526062290525841862">РђЈОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОћОљОцОюОЎОДОдОЎОћ ОћОќОЋ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОъОдОЉ ОћОцОЎОфОЋОЌ ОЕОю ОљОцОюОЎОДОдОЎОЋОф ОљОЎОаОўОеОаОў ОъОЉОЋОЊОЊОЋОф (IWA)</translation>
<translation id="2526280916094749336">РђЈОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОЏОфОЋОЉОЋОф ОЕОъОЋОеОЋОф ОЉОъОЋОдОеОЎ Google. ОћОЏОфОЋОЉОф ОћОќОЋ ОфОЎОЕОъОе ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, <ph name="ACCOUNT" />.</translation>
<translation id="2527451058878391043">РђЈОДОЋОЊ ОћОљОЎОъОЋОф (CVC) ОъОЋОцОЎОб ОЉОдОЊ ОћОДОЊОъОЎ ОЕОю ОћОЏОеОўОЎОА. ОќОћОЋ ОћОДОЋОЊ ОЉОЪ 4 ОћОАОцОеОЋОф ОЕОъОЋОцОЎОб ОЉОдОЊ ОЎОъОЎОЪ ОъОбОю ОюОъОАОцОе ОћОЏОеОўОЎОА.</translation>
<translation id="2529899080962247600">ОћОЕОЊОћ ОћОќОћ ОЎОЏОЋОю ОюОЏОюОЋОю ОбОЊ <ph name="MAX_ITEMS_LIMIT" /> ОеОЕОЋОъОЋОф. ОћОъОбОеОЏОф ОфОфОбОюОЮ ОъОеОЕОЋОъОЋОф ОаОЋОАОцОЋОф.</translation>
<translation id="2530042584066815841">ОаОбОЎОюОф ОћОбОЏОЉОе ОЋОЕОЎОъОЋОЕ ОЉОЋ</translation>
<translation id="2533649878691950253">ОћОњОЎОЕОћ ОЕОю ОћОљОфОе ОћОќОћ ОюОъОЎОДОЋОЮ ОћОъОЊОЋОЎОД ОЕОюОџ ОЌОАОЋОъОћ ОЏОЎ ОЉОЌОеОф ОцОбОъОЎОЮ ОеОЉОЋОф ОюОљ ОюОљОЕОе ОљОЋОфОћ.</translation>
<translation id="253493526287553278">ОћОдОњОф ОћОцОеОўОЎОЮ ОЕОю ОДОЋОЊ ОћОћОўОЉОћ</translation>
<translation id="2535585790302968248">ОЏОЊОЎ ОюОњОюОЋОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ, ОЎОЕ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЎОћ ОцОеОўОЎОф ОЌОЊОЕОћ</translation>
<translation id="2535659140340599600">{COUNT,plural, =1{ОЋОЊОЋОъОЎОЎОЪ ОљОЌОЊ ОаОЋОАОБ}one{ОЋ-# ОЊОЋОъОЎОЎОаОЎОЮ ОаОЋОАОцОЎОЮ}two{ОЋ-# ОЊОЋОъОЎОЎОаОЎОЮ ОаОЋОАОцОЎОЮ}other{ОЋ-# ОЊОЋОъОЎОЎОаОЎОЮ ОаОЋОАОцОЎОЮ}}</translation>
<translation id="2536110899380797252">ОћОЋОАОцОф ОЏОфОЋОЉОф</translation>
<translation id="2537931901612099523">РђЈОъОЕОфОъОЕОЎОЮ ОљОЌОеОЎОЮ ОЉОъОЏОЕОЎОе ОћОќОћ ОюОљ ОЎОеОљОЋ ОљОф ОћОцОбОЎОюОЋОф ОЕОюОџ, ОюОЏОЪ ОаОЎОфОЪ ОюОњОюОЋОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ ОЎОЋОфОе. ОљОЎОЪ ОюОЏОџ ОћОЕОцОбОћ ОбОю ОЊОеОЏОЎ ОљОЎОАОЋОБ ОћОаОфОЋОаОЎОЮ ОЉОљОфОеОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф ОЋОћОЕОЎОеОЋОфОЎОЮ ОЕОцОЋОбОюОЎОЮ ОЉОћОЮ, ОЏОЋОюОю Google. ОбОЊОЎОЎОЪ ОфОфОЉОдОб ОЕОъОЎОеОћ ОЕОю ОћОЋОеОЊОЋОф ОЋОАОЎОъОаОЎОЋОф.</translation>
<translation id="2539524384386349900">ОќОћОћ</translation>
<translation id="2541219929084442027">РђЈОЊОцОЎОЮ ОЕОћОдОњОф ОЉОЏОеОўОЎОАОЎОЋОф ОћОъОдОЉ ОћОљОаОЋОаОЎОъОЎ ОюОљ ОЎОЎОЕОъОеОЋ ОЉОћОЎОАОўОЋОеОЎОЎОф ОћОЊОцОЊОцОЪ, ОЉОљОЌОАОЋОЪ ОДОЋОЉОдОЎ Оћ-cookie ОљОЋ ОЉОћОЎОАОўОЋОеОЎОЎОф ОћОЌОЎОцОЋОЕОЎОЮ ОюОљОЌОе ОЕОЏОю ОЏОеОўОЎОАОЎОЋОф ОћОъОдОЉ ОћОљОаОЋОаОЎОъОЎ ОЎОЎОАОњОеОЋ. ОДОЉОдОЎОЮ ОЕОћОЋОеОЊОф ОљОЋ ОАОЎОъОаОЎОЋОф ОЕОЎОдОеОф ОЎОЎОЕОъОеОЋ.</translation>
<translation id="2542106216580219892">ОњОюОЎОЕОф ОњОюОЎОЮ</translation>
<translation id="2544546346215446551">ОћОљОЊОъОЎОЪ ОћОцОбОЎОю ОљОф ОћОъОЏОЕОЎОе ОЕОюОџ ОъОЌОЊОЕ</translation>
<translation id="2544644783021658368">ОъОАОъОџ ОЎОЌОЎОЊ</translation>
<translation id="254524874071906077">РђЈОћОњОЊОе ОљОф Chrome ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="2545721997179863249">ОаОЉОЌОеОћ ОћОљОцОЕОеОЋОф 'ОъОЎОюОЋОЎ ОЏОю ОћОцОеОўОЎОЮ'</translation>
<translation id="2546283357679194313">РђЈОДОЋОЉОдОЎ Cookie ОЋОаОфОЋОаОЎОЮ ОъОљОфОеОЎОЮ</translation>
<translation id="254947805923345898">ОбОеОџ ОћОъОЊОЎОаОЎОЋОф ОюОљ ОЌОЋОДОЎ.</translation>
<translation id="2549836668759467704">ОЎОЎОбОЋОЦ ОЋОДОЉОюОаОЋОф ОЉОфОЌОЋОЮ ОћОЉОаОЎОЎОћ</translation>
<translation id="255002559098805027"><ph name="HOST_NAME" /> ОЕОюОЌ ОфОњОЋОЉОћ ОюОљ ОЌОЋОДОЎОф.</translation>
<translation id="2551608178605132291">ОЏОфОЋОЉОф: <ph name="ADDRESS" /></translation>
<translation id="2552246211866555379">Hagaki</translation>
<translation id="2552295903035773204">ОљОаОЎ ОеОЋОдОћ ОюОћОЕОфОъОЕ ОЉОаОбОЎОюОф ОъОАОџ ОЏОЊОЎ ОюОљОЕОе ОЏОеОўОЎОАОЎОЮ ОъОбОЏОЕОЎОЋ ОЋОљОЎОюОџ</translation>
<translation id="2552532158894206888">ОъОДОЕ ОЎОъОаОЎ</translation>
<translation id="2553853292994445426">РђЈОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОњОЊОеОЋОф Оћ-DNS ОћОъОљОЋОЉОўОЌ. ОЎОЎОфОЏОЪ ОЕОћОњОЊОеОф ОЕОеОф DNS ОъОљОЋОЉОўОЌ ОЕОћОћОфОЌОЉОеОЋОф ОљОюОЎОЋ ОаОЏОЕОюОф.</translation>
<translation id="255497580849974774">ОЌОЕОЋОЉ ОюОЋОЋОЊОљ ОЕОћОъОЏОЕОЎОе ОъОЌОЋОЉОе ОюОъОўОбОЪ ОЉОъОћОюОџ ОћОбОЊОЏОЋОЪ.</translation>
<translation id="2556876185419854533">&amp;ОЉОЎОўОЋОю ОбОеОЎОЏОћ</translation>
<translation id="2559566667529177711">Multi-Layer</translation>
<translation id="2570734079541893434">ОаОЎОћОЋОю ОћОћОњОЊОеОЋОф</translation>
<translation id="257136025287118539">ОћОљОЊОъОЎОЪ ОЕОюОџ ОъОбОЉОЎОе ОљОф ОћОДОЉОдОЎОЮ ОљОю <ph name="CLOUD_PROVIDER" />. ОљОцОЕОе ОЎОћОЎОћ ОюОЕОаОЋОф ОљОф ОћОДОЉОдОЎОЮ ОћОљОюОћ ОљОЌОеОЎ ОЕОћОћОбОюОљОћ ОфОАОфОЎОЎОЮ.</translation>
<translation id="2571488850200220306">ОЏОЊОЎ ОюОЕОъОЋОе ОбОю ОћОљОЉОўОЌОћ, ОЎОЕ ОюОљОЊОъОЎОЪ ОљОцОЕОеОЋОф ОюОеОљОЋОф ОњОЮ ОљОф ОъОбОеОЏОф ОћОћОцОбОюОћ ОЕОю ОћОъОЏОЕОЎОе, ОњОеОАОф ОћОЊОцОЊОцОЪ ОЋОћОфОЋОЏОаОћ ОЕОъОЋОфОДОаОф ОЉОЋ</translation>
<translation id="2573170131138724450">ОўОюОЋОЋОЎОќОЎОЋОф</translation>
<translation id="257674075312929031">ОДОЉОЋОдОћ</translation>
<translation id="258135245577667916">ОЏОеОўОЎОАОЎОЎОћ ОаОЋОАОцОћ ОбОю ОЎОЊОЎ <ph name="USER_DISPLAY_NAME" /></translation>
<translation id="2586657967955657006">ОюОЋОЌ</translation>
<translation id="2587841377698384444">РђЈОъОќОћОћ Directory API:</translation>
<translation id="2594318783181750337">ОфОдОЋОњОћ ОъОћОЎОеОћ ОЉОљОЎОаОўОеОаОў:</translation>
<translation id="2595719060046994702">ОћОъОЏОЕОЎОе ОЋОћОЌОЕОЉОЋОЪ ОюОљ ОъОаОЋОћОюОЎОЮ ОбОю-ОЎОЊОЎ ОЌОЉОеОћ ОљОЋ ОљОеОњОЋОЪ ОљОЌОе.</translation>
<translation id="2596415276201385844">РђЈОЏОЊОЎ ОюОЎОдОЋОе ОЌОЎОЉОЋОе ОъОљОЋОЉОўОЌ, ОћОЕОбОЋОЪ ОдОеОЎОџ ОюОћОЎОЋОф ОъОЋОњОЊОе ОЏОћОюОЏОћ. ОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОЕОћОљОЎОЕОЋОеОЎОЮ ОЕОЉОћОЮ ОљОфОеОЎОЮ ОъОЕОфОъОЕОЎОЮ ОЏОЊОЎ ОюОќОћОЋОф ОљОф ОбОдОъОЮ ОфОДОцОЎОЮ ОеОД ОюОъОЕОџ ОцОеОДОЎ ОќОъОЪ ОъОАОЋОЎОъОЎОЮ. ОъОљОЌОе ОЕОћОЕОбОЋОЪ ОЉОъОЏОЕОЎОе ОЕОюОџ ОЕОњОЋОЎ, Chrome ОюОљ ОЎОЏОЋОю ОюОљОъОф ОљОф ОћОљОЎОЕОЋОеОЎОЮ ОћОљОюОЋ.</translation>
<translation id="2597378329261239068">ОъОАОъОџ ОќОћ ОъОЋОњОЪ ОЉОљОъОдОбОЋОф ОАОЎОАОъОћ. ОЎОЕ ОюОћОќОЎОЪ ОАОЎОАОъОћ.</translation>
<translation id="2605979593348332811">ОЕОЮ ОцОЋОаОўОЎ</translation>
<translation id="2606760465469169465">ОљОЎОъОЋОф ОљОЋОўОЋОъОўОЎ</translation>
<translation id="2608019759319359258">ОЏОЕОЌОЋОАОъОЎОЮ ОаОЋОЕОљ ОъОАОЋОЎОЮ, ОћОЋОљ ОъОцОАОЎОД ОюОЕОъОЕ ОюОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОъОЋОЊОбОЋОф</translation>
<translation id="2610561535971892504">ОюОЌОЎОдОћ ОюОћОбОфОДОћ</translation>
