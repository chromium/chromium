<translation id="8389532092404711541">ОЉОЊОеОџ ОЏОюОю <ph name="LOW_PRICE" /></translation>
<translation id="8389940864052787379">ОЏОюОЎ ОеОЏОЉ ОъОЕОЋОцОеОЎОЮ ОЋОЉОћОфОљОъОћ ОљОЎОЕОЎОф</translation>
<translation id="8390725133630534698">ОћОЕОЎОфОЋОБ Оъ-<ph name="ORIGIN_NAME" /> ОљОю <ph name="VM_NAME" /> ОЌОАОЋОЮ ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОЕОю ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="8392783408127179588">ОЏОюОюОЎ ОћОъОЊОЎОаОЎОЋОф ОаОўОбОаОЎОЮ ОъОЌОЊОЕ</translation>
<translation id="8396522675989118466">ОќОћОЋ ОћОДОЋОЊ ОЉОЪ <ph name="NUMBER_OF_DIGITS" /> ОћОАОцОеОЋОф ОЕОъОЋОцОЎОб ОЉ<ph name="SIDE_OF_CARD" /></translation>
<translation id="8398335999901363925">ОеОЕОЎОъОф ОљОъОдОбОЎ ОћОфОЕОюОЋОЮ ОћОќОъОЎОаОЎОЮ ОюОъОЎОюОЋОЎ ОЉОъОњОб ОаОцОфОЌОћ ОЉОњОЋОЉОћ ОћОъОюОљ ОЕОю ОћОъОАОџ.</translation>
<translation id="8398446215576328011">ОЉОЎОўОЋОю ОЏОюОюОЎ ОћОъОЊОЎОаОЎОЋОф ОЕОћОЋОЌОюОЋ</translation>
<translation id="8398790343843005537">ОљОфОе ОљОф ОћОўОюОцОЋОЪ ОЕОюОџ</translation>
<translation id="8400929824946688748">ОфОбОАОЋОДОћ ОЋОЌОЎОаОЋОџ</translation>
<translation id="8402442052798347631">ОфОЋОДОцОЎОЮ ОЉОљОфОе ОЕОЉОЋ ОаОЎОАОЎОф ОюОЉОДОе ОбОЕОЋОЎОЎОЮ ОюОњОеОЋОЮ ОюОџ ОЉОЊОеОЏОЎ ОъОеОъОћ ОюОћОфОДОЎОЪ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЕОъОЕОцОЎОбОЋОф ОбОю ОљОЋОцОЪ ОћОњОюОЎОЕОћ ОЕОюОџ. ОюОЊОЋОњОъОћ, ОбОю ОЎОЊОЎ ОЕОЎОаОЋОЎ ОЊОБ ОћОЉОЎОф ОљОЋ ОћОдОњОф ОъОЋОЊОбОЋОф ОаОЋОАОцОЋОф ОЉОљОфОеОЎОЮ ОЕОъОЉОДОеОЎОЮ ОЉОћОЮ. ОъОЋОъОюОЦ ОъОљОЋОЊ ОюОЌОќОЋОе ОюОЊОБ ОћОЉОўОЋОЌ. <ph name="BEGIN_LEARN_MORE_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОљОќОћОеОћ ОћОќОЋ<ph name="END_LEARN_MORE_LINK" /></translation>
<translation id="8403506619177967839">ОАОцОеОЋОф ОЌОЋОЉОЉОЎОЮ</translation>
<translation id="8405579342203358118">РђЈОаОЎОфОЪ ОюОДОЉОЋОб ОљОЎОќОћ ОъОЎОЊОб ОЎОАОЋОаОЏОеОЪ ОЉОћОњОЊОеОЋОф Chrome</translation>
