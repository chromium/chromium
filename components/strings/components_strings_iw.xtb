<translation id="1706922226983368260">ОъОцОфОЌ ОњОЎОЕОћ Рђб '<ph name="PHONE_NAME" />'</translation>
<translation id="1706954506755087368">{1,plural, =1{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />; ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОљОъОЋОе ОюОћОЎОЏОаОА ОюОфОЋОДОБ ОеОД ОъОЌОе. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОћОњОЊОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ.}one{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />; ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОљОъОЋОе ОюОћОЎОЏОаОА ОюОфОЋОДОБ ОеОД ОЉОбОЋОЊ # ОЎОъОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОћОњОЊОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ.}two{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />; ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОљОъОЋОе ОюОћОЎОЏОаОА ОюОфОЋОДОБ ОеОД ОЉОбОЋОЊ ОЎОЋОъОЎОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОћОњОЊОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ.}other{ОћОЕОеОф ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОћОЋОЏОЎОЌ ОЕОћОЋОљ <ph name="DOMAIN" />; ОљОЎОЕОЋОе ОћОљОЉОўОЌОћ ОЕОюОЋ ОљОъОЋОе ОюОћОЎОЏОаОА ОюОфОЋОДОБ ОеОД ОЉОбОЋОЊ # ОЎОъОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОАОЎОЉОћ ОюОЏОџ ОћОЎОљ ОћОњОЊОеОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОфОЋОДОБ ОъОЎОЎОеОў ОљОф ОћОЌОЎОЉОЋОе ОЕОюОџ.}}</translation>
<translation id="1710259589646384581">ОъОбОеОЏОф ОћОцОбОюОћ</translation>
<translation id="1711234383449478798">ОљОЎОЪ ОћОфОЎОЎОЌОАОЋОф ОюОъОЊОЎОаОЎОЋОф ОЏОЎ ОюОљ ОћОЋОњОЊОе ОћОбОеОџ <ph name="VALUE" /> ОЉ-<ph name="POLICY_NAME" />.</translation>
