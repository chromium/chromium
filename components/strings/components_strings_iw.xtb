<translation id="5465724643247062031">Glass (Opaque)</translation>
<translation id="5466018172325111652">ОюОљ ОДОЎОЉОюОф ОљОф ОћОДОЋОЊ? <ph name="BEGIN_LINK" />ОљОаОЎ ОеОЋОдОћ ОюОДОЉОю ОДОЋОЊ ОЌОЊОЕ<ph name="END_LINK" /></translation>
<translation id="5470861586879999274">&amp;ОЉОЎОдОЋОб ОъОЌОЊОЕ ОЕОю ОбОеОЎОЏОћ</translation>
<translation id="5472588168895083535">ОћОъОбОДОЉ ОљОЌОе ОфОаОЋОбОЋОф ОћОЎОЊОЎОЎОЮ ОЌОАОЋОЮ</translation>
<translation id="547963486735802022">ОеОЋОдОћ ОюОаОАОЋОф ОЕОЋОЉ ОюОћОбОЉОЎОе ОљОф ОћОДОЉОдОЎОЮ?</translation>
<translation id="5481076368049295676">ОЎОЎОфОЏОЪ ОЕОћОфОЋОЏОЪ ОћОќОћ ОъОЏОЎОю ОљОъОдОбОЎОЮ ОЕОЎОаОАОЋ ОюОћОфОДОЎОЪ ОфОЋОЏОаОћ ОъОАОЋОЏОаОф, ОЕОњОЋОаОЉОф ОљОЋ ОъОЋОЌОДОф ОљОф ОћОъОЎОЊОб ОЕОюОџ. <ph name="BEGIN_LINK" />ОљОаОЎ ОеОЋОдОћ ОюОћОдОЎОњ ОЉОЏОю ОќОљОф<ph name="END_LINK" /></translation>
<translation id="5481682542063333508">ОћОдОбОћ ОюОбОќОеОћ ОЉОЏОфОЎОЉОћ</translation>
