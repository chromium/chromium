<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="mn">
<translation id="7649299977121480655">Зарын сэдвүүд нь сайтын зарыг хувийн болгоход ашиглаж болох олон зүйлийн ердөө нэг нь юм. Зарын сэдэвгүйгээр ч сайтууд танд зар харуулах боломжтой хэвээр хэдий ч тэдгээр нь сонирхол багатай байж магадгүй. <ph name="BEGIN_LINK_1" />Зарын нууцлалаа удирдах<ph name="END_LINK_1" /> талаар нэмэлт мэдээлэл авна уу.</translation>
</translationbundle>