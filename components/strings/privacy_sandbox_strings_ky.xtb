<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="ky">
<translation id="7649299977121480655">Жарнама темалары – сайттар жарнамаларды жекелештирүү үчүн колдоно турган нерселердин бири. Сайттар темаларсыз да сизге жарнамаларды көрсөтө берет, бирок алар кызыксыз болушу мүмкүн. <ph name="BEGIN_LINK_1" />Жарнаманын купуялыгын тескөө<ph name="END_LINK_1" /> тууралуу кеңири маалымат.</translation>
</translationbundle>