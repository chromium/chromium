<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="fr-CA">
<translation id="7649299977121480655">Les sujets d'annonces ne sont qu'un des nombreux moyens qu'un site peut utiliser pour personnaliser les annonces. Même sans sujets d'annonces, les sites peuvent toujours vous montrer des annonces. Celles-ci pourraient toutefois moins vous intéresser. Apprenez-en plus sur la <ph name="BEGIN_LINK_1" />gestion de la confidentialité des annonces<ph name="END_LINK_1" />.</translation>
</translationbundle>