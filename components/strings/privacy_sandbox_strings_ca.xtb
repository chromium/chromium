<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="ca">
<translation id="7649299977121480655">Els temes d'anunci només són un dels molts elements que un lloc web pot utilitzar per personalitzar anuncis. Encara que no hi hagi temes d'anunci, els llocs web poden continuar mostrant-te anuncis, però pot ser que siguin menys interessants. Obtén més informació sobre com pots <ph name="BEGIN_LINK_1" />gestionar la privadesa d'anuncis<ph name="END_LINK_1" />.</translation>
</translationbundle>