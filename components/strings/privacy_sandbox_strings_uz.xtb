<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="uz">
<translation id="7649299977121480655">Reklama mavzulari sayt reklamani moslashtirishda ishlatadigan maʼlumotlarning faqat bir qismi hisoblanadi. Mavzusiz reklamalar ham chiqishda davom etishi mumkin, lekin ular sizga qiziq boʻlmasligi mumkin. <ph name="BEGIN_LINK_1" />Reklamada maxfiylikni boshqarish<ph name="END_LINK_1" /> haqida batafsil.</translation>
</translationbundle>