<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="ka">
<translation id="7649299977121480655">სარეკლამო თემები არის ერთ-ერთი იმ მრავალი საშუალებიდან, რომლებითაც საიტს შეუძლია რეკლამების პერსონალიზება. საიტებს რეკლამის ჩვენება სარეკლამო თემების გარეშეც შეუძლია, თუმცა ის თქვენთვის ნაკლებად საინტერესო იქნება. შეიტყვეთ მეტი <ph name="BEGIN_LINK_1" />რეკლამასთან დაკავშირებული თქვენი კონფიდენციალურობის მართვის<ph name="END_LINK_1" /> შესახებ.</translation>
</translationbundle>