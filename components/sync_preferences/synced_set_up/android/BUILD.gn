import("//build/config/android/rules.gni")
import("//third_party/jni_zero/jni_zero.gni")

source_set("android") {
  sources = [
    "pref_to_value_map_bridge.cc",
    "pref_to_value_map_bridge.h",
  ]
  deps = [
    ":jni_headers",
    "//base",
    "//third_party/jni_zero",
  ]
}

generate_jni("jni_headers") {
  sources = [ "java/src/org/chromium/components/sync_preferences/synced_set_up/PrefToValueMapBridge.java" ]
}

android_library("java") {
  sources = [ "java/src/org/chromium/components/sync_preferences/synced_set_up/PrefToValueMapBridge.java" ]
  deps = [
    ":jni_headers_java",
    "//base:base_java",
    "//third_party/jni_zero:jni_zero_java",
  ]
}
