import("//testing/libfuzzer/fuzzer_test.gni")
import("//third_party/protobuf/proto_library.gni")

if (current_toolchain == host_toolchain) {
  executable("proto_extras_plugin") {
    sources = [ "proto_extras_plugin.cc" ]
    deps = [
      ":proto_extras_options_proto",
      "//base",
      "//third_party/protobuf:protoc_cpp",
      "//third_party/protobuf:protoc_lib",
    ]
  }

  executable("proto_test_extras_plugin") {
    sources = [ "proto_test_extras_plugin.cc" ]
    deps = [
      "//base",
      "//third_party/protobuf:protoc_cpp",
      "//third_party/protobuf:protoc_lib",
    ]
  }
}

proto_library("proto_extras_options_proto") {
  sources = [ "proto_extras_options.proto" ]

  # The use of full and lite runtime here is somewhat subtle. The plugin
  # uses the full runtime through its dependency on both
  # `//third_party/protobuf:protoc_cpp` and
  # `//third_party/protobuf:protoc_lib`. This means that this target
  # must not include the lite runtime, or certain component builds would
  # fail due to the plugin including both the full and lite runtime (see
  # https://crbug.com/40229487). The protos in this target are only
  # intended for use in the plugin at compile time, so it's safe to use
  # the full runtime here as long as this target does not get linked
  # into the Chrome binary. In order to correctly track build
  # dependencies without linking into Chrome, we restrict visibility and
  # define the `:proto_extras_options` group. Users of these options
  # should add `:proto_extras_options` to their `proto_deps` instead of
  # adding this target to their `deps`.
  use_protobuf_full = true
  visibility = [ ":*" ]
}

config("proto_extras_options_config") {
  inputs = [ "proto_extras_options.proto" ]
}

group("proto_extras_options") {
  public_configs = [ ":proto_extras_options_config" ]
}

source_set("proto_extras_lib") {
  public = [ "proto_extras_lib.h" ]
  sources = [ "proto_extras_lib.cc" ]
  public_deps = [
    "//base",
    "//third_party/protobuf:protobuf_lite",
  ]
}

source_set("proto_matchers") {
  testonly = true
  public = [ "proto_matchers.h" ]
  public_deps = [
    "//base",
    "//testing/gmock",
    "//third_party/protobuf:protobuf_lite",
  ]
}

if (use_fuzzing_engine_with_lpm) {
  # Component for protobuf_full support of our serialization, which is required
  # by proto fuzzers.
  source_set("protobuf_full_support") {
    public = [ "protobuf_full_support.h" ]
    sources = [ "protobuf_full_support.cc" ]
    public_deps = [
      ":proto_extras_lib",
      "//base",
      "//third_party/protobuf:protobuf_full",
    ]
  }
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "proto_extras_unittest.cc",
    "proto_test_extras_unittest.cc",
  ]

  deps = [
    "//base",
    "//base/test:test_support",
    "//components/proto_extras/test_proto",
    "//components/proto_extras/test_proto:test_proto_extras",
    "//components/proto_extras/test_proto:test_proto_test_extras",
    "//components/proto_extras/test_proto2",
    "//components/proto_extras/test_proto2:test_proto2_extras",
    "//components/proto_extras/test_proto2:test_proto2_test_extras",
    "//components/proto_extras/test_proto_edition",
    "//components/proto_extras/test_proto_edition:test_proto_edition_extras",
    "//components/proto_extras/test_proto_edition:test_proto_edition_test_extras",
    "//testing/gmock",
    "//testing/gtest",
    "//third_party/protobuf:protobuf_lite",
  ]
}
