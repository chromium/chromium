import("//tools/grit/grit_rule.gni")
import("//tools/grit/preprocess_if_expr.gni")
import("//tools/typescript/ts_library.gni")
import("//ui/webui/resources/tools/generate_grd.gni")

preprocess_if_expr("preprocess") {
  in_folder = "."
  out_folder = target_gen_dir
  in_files = [
    "flags.css",
    "flags.html",
    "flags.ts",
  ]
}

ts_library("build_ts") {
  root_dir = target_gen_dir
  out_dir = "$target_gen_dir/tsc"
  in_files = [ "flags.ts" ]
  definitions = [ "//tools/typescript/definitions/chrome_send.d.ts" ]
  deps = [ "//ui/webui/resources/js:build_ts" ]
  extra_deps = [ ":preprocess" ]
}

generate_grd("build_grd") {
  out_grd = "$target_gen_dir/resources.grd"
  grd_prefix = "flags_ui"
  input_files = [
    "flags.css",
    "flags.html",
  ]
  input_files_base_dir = rebase_path(target_gen_dir, root_build_dir)
  manifest_files =
      filter_include(get_target_outputs(":build_ts"), [ "*_manifest.json" ])
  deps = [ ":build_ts" ]
}

grit("resources") {
  grd_prefix = "flags_ui"

  # These arguments are needed since the grd is generated at build time.
  enable_input_discovery_for_gn_analyze = false
  source = "$target_gen_dir/resources.grd"
  deps = [ ":build_grd" ]

  outputs = [
    "grit/${grd_prefix}_resources.h",
    "grit/${grd_prefix}_resources_map.cc",
    "grit/${grd_prefix}_resources_map.h",
    "${grd_prefix}_resources.pak",
  ]

  output_dir = "$root_gen_dir/components"
}
