import("//build/config/features.gni")

source_set("reading") {
  sources = [ "reading/distillable_urls.h" ]

  if (is_chrome_branded) {
    sources += [ "internal/reading/distillable_urls.cc" ]
  } else {
    sources += [ "reading/distillable_urls.cc" ]
  }

  deps = [
    "//base",
    "//url",
  ]
}
