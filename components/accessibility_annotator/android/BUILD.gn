import("//build/config/android/rules.gni")
import("//build/config/chrome_build.gni")

copy("accessibility_annotator_first_run_animation_resource") {
  if (is_internal_chrome_branded) {
    sources = [ "../core/resources/internal/assets/animations/accessibility_annotator_first_run_animation.json" ]
  } else {
    sources = [ "../core/resources/assets/animations/accessibility_annotator_first_run_animation.json" ]
  }
  outputs = [
    "$target_gen_dir/res/raw/accessibility_annotator_first_run_animation.json",
  ]
}

android_resources("accessibility_annotator_icon_resources") {
  if (is_internal_chrome_branded) {
    sources = [
      "../core/resources/internal/android/java/res/drawable/accessibility_annotator_first_run_card_1.xml",
      "../core/resources/internal/android/java/res/drawable/accessibility_annotator_first_run_card_2.xml",
    ]
  } else {
    sources = [
      "java/res/drawable/accessibility_annotator_first_run_card_1.xml",
      "java/res/drawable/accessibility_annotator_first_run_card_2.xml",
    ]
  }
}

android_resources("accessibility_annotator_java_resources") {
  sources = [
    "$target_gen_dir/res/raw/accessibility_annotator_first_run_animation.json",
  ]
  deps = [
    ":accessibility_annotator_first_run_animation_resource",
    ":accessibility_annotator_icon_resources",
  ]
}
