source_set("data_models") {
  sources = [
    "entity.cc",
    "entity.h",
    "entity_converter.cc",
    "entity_converter.h",
    "entity_types.h",
    "intent.cc",
    "intent.h",
  ]

  public = [
    "entity.h",
    "entity_converter.h",
    "entity_types.h",
    "intent.h",
  ]

  public_deps = [ "//url" ]

  deps = [
    "//base",
    "//components/history/core/browser",
    "//components/sync/protocol",
    "//third_party/abseil-cpp:absl",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "entity_converter_unittest.cc" ]

  deps = [
    ":data_models",
    "//base/test:test_support",
    "//components/sync/protocol",
    "//testing/gtest",
  ]
}
