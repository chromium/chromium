source_set("core") {
  sources = [
    "accessibility_annotation_service.cc",
    "accessibility_annotation_service.h",
    "accessibility_query_service.cc",
    "accessibility_query_service.h",
    "direct_server_entity_provider.cc",
    "direct_server_entity_provider.h",
    "entity_data_provider.h",
  ]

  public_deps = [
    "//base",
    "//components/accessibility_annotator/core/annotation_reducer",
    "//components/accessibility_annotator/core/data_models",
    "//components/keyed_service/core",
    "//url",
  ]
}

source_set("features") {
  sources = [
    "accessibility_annotator_features.cc",
    "accessibility_annotator_features.h",
  ]
  deps = [ "//base" ]
}

source_set("unit_tests") {
  testonly = true

  sources = [
    "accessibility_query_service_unittest.cc",
    "direct_server_entity_provider_unittest.cc",
  ]

  deps = [
    ":core",
    "//base",
    "//base/test:test_support",
    "//components/accessibility_annotator/core/annotation_reducer:unit_tests",
    "//components/accessibility_annotator/core/data_models:unit_tests",
    "//components/accessibility_annotator/core/storage:unit_tests",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
