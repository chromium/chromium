import("//components/activity_reporter/buildflags.gni")

source_set("activity_reporter") {
  public = [ "activity_reporter.h" ]

  deps = [ "//base" ]

  sources = [ "activity_reporter_no_impl.cc" ]

  if (report_activity) {
    sources += [ "activity_reporter_impl.cc" ]
  } else {
    sources += [ "activity_reporter_disabled.cc" ]
  }
}
