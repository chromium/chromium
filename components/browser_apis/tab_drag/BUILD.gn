import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojom") {
  sources = [ "tab_drag_api.mojom" ]

  public_deps = [
    "//components/browser_apis/tab_strip:mojom",
    "//ui/gfx/geometry/mojom",
  ]

  webui_module_path = "/"
}

source_set("tab_drag") {
  sources = [
    "tab_drag_service_impl.cc",
    "tab_drag_service_impl.h",
  ]

  public_deps = [
    ":mojom",
    "//components/browser_apis/tab_strip:mojom",
    "//components/browser_apis/tab_strip/adapters",
  ]

  deps = [
    "//base",
    "//components/browser_apis/tab_drag/adapters",
    "//components/browser_apis/tab_drag/sessions",
    "//components/browser_apis/tab_drag/sessions:impl",
    "//components/browser_apis/tab_strip/types",
    "//mojo/public/cpp/bindings",
    "//ui/gfx",
    "//ui/gfx/geometry",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "sessions/tab_drag_session_unittest.cc" ]

  deps = [
    ":tab_drag",
    "//base",
    "//base/test:test_support",
    "//components/browser_apis/tab_drag/adapters",
    "//components/browser_apis/tab_drag/sessions",
    "//components/browser_apis/tab_drag/sessions:impl",
    "//components/browser_apis/tab_drag/testing",
    "//components/browser_apis/tab_strip/types",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
