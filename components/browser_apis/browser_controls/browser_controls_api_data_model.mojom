module browser_controls_api.mojom;

// The event flags for the click that might affect disposition of a
// button's behavior.
enum ClickDispositionFlag {
  kUnspecified = 0,
  kMiddleMouseButton = 1,
  kAltKeyDown = 2,
  kMetaKeyDown = 3,
};
