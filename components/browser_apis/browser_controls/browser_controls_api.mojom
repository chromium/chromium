module browser_controls_api.mojom;

import "components/browser_apis/browser_controls/browser_controls_api_data_model.mojom";
import "ui/base/mojom/menu_source_type.mojom";
import "ui/gfx/geometry/mojom/geometry.mojom";

// Called from C++ side of chrome://webui-toolbar.top-chrome
// (Browser -> Renderer)
interface BrowserControlsObserver {
  // Sets the dev tools state in the renderer, the renderer is expected to
  // make UI changes accordingly.
  OnDevToolsStatusChanged(DevToolsState state);

  // Sets the navigation loading state in the renderer, the renderer is
  // expected to make UI changes accordingly.
  OnNavigationStatusChanged(NavigationState state);

  // Indicates the context menu of type |menu_type| changed to |state| state.
  OnContextMenuStateChanged(ContextMenuType menu_type, ContextMenuState state);

  // Sets the split status of the active tab in the renderer, the renderer is
  // expected to make UI changes accordingly.
  OnTabSplitStatusChanged(bool is_split, SplitTabActiveLocation location);

  // Sets the pin state of the specified button in the renderer, the renderer
  // is expected to make UI changes accordingly.
  OnButtonPinStateChanged(ToolbarButtonType type, bool is_pinned);

  // Sets the layout constants in the renderer, the renderer is expected to make
  // UI changes accordingly.
  OnLayoutChanged(LayoutConstants layout_constants);
};

// BrowserControlsService defines methods to be called from the WebUI to the
// browser-side. This interface consolidates various browser control actions.
interface BrowserControlsService {
  // Registers an observer to receive status updates from the browser.
  AddObserver(
    pending_remote<BrowserControlsObserver> observer);

  // Stops the current page from loading. If the page is not in a loading
  // state, it is a no-op.
  StopLoad();

  // Displays the context menu with the provided menu type at the provided
  // offset in CSS pixels relative to the WebUIToolbarWebView's viewport origin.
  // The source indicates what triggered showing this menu (mouse, keyboard,
  // etc).
  ShowContextMenu(ContextMenuType menu_type,
                  gfx.mojom.Point viewport_coordinate_css_pixels,
                  ui.mojom.MenuSourceType source);

  // Called when the page finishes initialization.
  OnPageInitialized();

  // Reloads the current page. If the page is already in a loading state,
  // it will trigger another reload, and abort the previous one.
  // If `bypass_cache` is set to true, the page will be reloaded while
  // ignoring the HTTP cache.
  // `click_flags` contains the list of flag information about the click that
  // might affect the reload logic (e.g. whether it's clicked through the
  // middle mouse button, or whether the alt key is pressed).
  ReloadFromClick(bool bypass_cache, array<ClickDispositionFlag> click_flags);

  // Enters split view mode for the active tab. Only called when not in split.
  SplitActiveTab();

  // Gets the split status of the active tab.
  GetTabSplitState()
      => (bool is_split, SplitTabActiveLocation location);

  // Gets the pin state for the specified button.
  GetButtonPinState(ToolbarButtonType type) => (bool is_pinned);

  // Gets the current layout constants.
  GetLayoutConstants()
      => (LayoutConstants layout_constants);
};
