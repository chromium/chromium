import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojo_bindings") {
  sources = [ "composebox_query.mojom" ]
  public_deps = [ "//mojo/public/mojom/base" ]

  webui_module_path = "chrome://resources/mojo/components/omnibox/composebox"

  cpp_typemaps = [
    {
      types = [
        {
          mojom = "composebox_query.mojom.ToolMode"
          cpp = "::omnibox::ToolMode"
        },
        {
          mojom = "composebox_query.mojom.ModelMode"
          cpp = "::omnibox::ModelMode"
        },
        {
          mojom = "composebox_query.mojom.InputType"
          cpp = "::omnibox::InputType"
        },
        {
          mojom = "composebox_query.mojom.ToolConfig"
          cpp = "::omnibox::ToolConfig"
        },
        {
          mojom = "composebox_query.mojom.ModelConfig"
          cpp = "::omnibox::ModelConfig"
        },
        {
          mojom = "composebox_query.mojom.SectionConfig"
          cpp = "::omnibox::SectionConfig"
        },
        {
          mojom = "composebox_query.mojom.InputState"
          cpp = "::omnibox::InputState"
        },
        {
          mojom = "composebox_query.mojom.FileUploadStatus"
          cpp = "::contextual_search::FileUploadStatus"
        },
        {
          mojom = "composebox_query.mojom.FileUploadErrorType"
          cpp = "::contextual_search::FileUploadErrorType"
        },
      ]
      traits_headers = [ "contextual_search_mojom_traits.h" ]
      traits_sources = [ "contextual_search_mojom_traits.cc" ]
      traits_deps = [
        "//components/contextual_search:types",
        "//components/omnibox/common",
        "//third_party/omnibox_proto",
      ]
    },
  ]
}
