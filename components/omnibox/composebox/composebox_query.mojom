module composebox_query.mojom;

// A single URL parameter key-value pair.
// Named AimUrlParam instead of UrlParam to avoid collision with mojo::internal generated types.
struct AimUrlParam {
  string param_key;
  string param_value;
};

// Upload status of a file.
enum FileUploadStatus {
  // Not uploaded.
  kNotUploaded = 0,
  // File being processed.
  kProcessing = 1,
  // Failed validation - Terminal for this file attempt.
  kValidationFailed = 2,
  // Request sent to Lens server.
  kUploadStarted = 3,
  // Server confirmed successful receipt.
  kUploadSuccessful = 4,
  // Server or network error during upload - Terminal for this file attempt.
  kUploadFailed = 5,
  // File expired.
  kUploadExpired = 6,
  // File being processed, and suggest signals are ready.
  kProcessingSuggestSignalsReady = 7,
  // File is being replaced.
  kUploadReplaced = 8,
};

// For upload error notifications and metrics.
enum FileUploadErrorType {
  // Unknown.
  kUnknown = 0,
  // Browser error before/during request, not covered by validation.
  kBrowserProcessingError = 1,
  // Network-level issue (e.g., no connectivity, DNS failure).
  kNetworkError = 2,
  // Server returned an error (e.g., 5xx, specific API error).
  kServerError = 3,
  // Server rejected due to size after upload attempt - Considered terminal.
  kServerSizeLimitExceeded = 4,
  // Upload aborted by user deletion or session end.
  kAborted = 5,
  // Image processing error.
  kImageProcessingError = 6,
};

// The AIM model mode.
// LINT.IfChange(ModelMode)
enum ModelMode {
  // Model is unspecified.
  kUnspecified = 0,
  // Uses Regular Gemini Model.
  kGeminiRegular = 1,
  // Uses Gemini Pro Model.
  kGeminiPro = 2,
  // Uses Gemini Pro Model with automatic routing capabilities.
  kGeminiProAutoroute = 3,
  // Uses Gemini Pro Model without generative UI.
  kGeminiProNoGenUi = 4,
};
// LINT.ThenChange(//third_party/omnibox_proto/model_mode.proto:ModelMode)

// The AIM tool mode.
// LINT.IfChange(ToolMode)
enum ToolMode {
  // Tool is unspecified.
  kUnspecified = 0,
  // Enables Deep Search functionality.
  kDeepSearch = 1,
  // Enables Canvas Tool.
  kCanvas = 2,
  // Enables Gemini Pro mode.
  kGeminiPro = 3,
  // Enables Image generation functionality.
  kImageGen = 4,
  // Enables Deep Browse functionality.
  kDeepBrowse = 5,
  // Enables Image Generation for Selfie type images.
  kImageGenSelfie = 6,
  // Enables Image Generation for uploaded images.
  kImageGenUpload = 7,
  // Disables suggestions.
  kDisableSuggest = 8,
  // Enables AIM mode.
  kAim = 9,
  // Enables AIM Gen Prompt mode.
  kAimGenPrompt = 10,
};
// LINT.ThenChange(//third_party/omnibox_proto/tool_mode.proto:ToolMode)

// The AIM input type.
// LINT.IfChange(InputType)
enum InputType {
  // Input is unspecified.
  kUnspecified = 0,
  // Input is an image.
  kLensImage = 1,
  // Input is a file.
  kLensFile = 2,
  // Input is a browser tab.
  kBrowserTab = 3,
};
// LINT.ThenChange(//third_party/omnibox_proto/input_type.proto:InputType)

// Configuration for an input type.
// LINT.IfChange(InputTypeConfig)
struct InputTypeConfig {
  InputType input_type;
  string menu_label;
};
// LINT.ThenChange(//third_party/omnibox_proto/input_type_config.proto:InputTypeConfig)

// Configuration for a tool.
// LINT.IfChange(ToolConfig)
struct ToolConfig {
  ToolMode tool;
  bool disable_active_model_selection;
  string menu_label;
  string chip_label;
  string hint_text;
  array<AimUrlParam> aim_url_params;
};
// LINT.ThenChange(//third_party/omnibox_proto/tool_config.proto:ToolConfig)

// Configuration for a model.
// LINT.IfChange(ModelConfig)
struct ModelConfig {
  ModelMode model;
  string menu_label;
  string hint_text;
  array<AimUrlParam> aim_url_params;
};
// LINT.ThenChange(//third_party/omnibox_proto/model_config.proto:ModelConfig)

// Configuration for a section.
// LINT.IfChange(SectionConfig)
struct SectionConfig {
  string header;
};
// LINT.ThenChange(//third_party/omnibox_proto/section_config.proto:SectionConfig)

// Represents the current state of inputs, models, and tools within AIM.
// This struct is only ever sent from the browser to WebUI.
// LINT.IfChange(InputState)
struct InputState {
  // The set of allowed models.
  array<ModelMode> allowed_models;
  // The set of allowed tools.
  array<ToolMode> allowed_tools;
  // The set of allowed input types.
  array<InputType> allowed_input_types;
  // The currently active model.
  ModelMode active_model;
  // The currently active tool.
  ToolMode active_tool;
  // The set of currently disabled models.
  array<ModelMode> disabled_models;
  // The set of currently disabled tools.
  array<ToolMode> disabled_tools;
  // The set of currently disabled input types.
  array<InputType> disabled_input_types;
  // Configuration for available tools.
  array<ToolConfig> tool_configs;
  // Configuration for available models.
  array<ModelConfig> model_configs;
  // Configuration for available input types.
  array<InputTypeConfig> input_type_configs;
  // Configuration for the tools section.
  SectionConfig? tools_section_config;
  // Configuration for the model section.
  SectionConfig? model_section_config;
  // Hint text to display in the input.
  string hint_text;
  // The max number of inputs of a given type.
  map<InputType, int32> max_instances;
  // The max total number of inputs.
  int32 max_total_inputs;
};
// LINT.ThenChange(//components/omnibox/common/input_state.h:InputState)
