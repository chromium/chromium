module sqlite_vfs.mojom;

import "mojo/public/mojom/base/file.mojom";
import "mojo/public/mojom/base/shared_memory.mojom";

// The handles needed to open a SQLite DB for read-only access.
struct PendingReadOnlyFileSet {
  mojo_base.mojom.ReadOnlyFile db_file;
  mojo_base.mojom.ReadOnlyFile journal_file;

  // An optional write-ahead log file, specified only if this backend uses a
  // write-ahead log rather than a rollback journal.
  mojo_base.mojom.ReadOnlyFile? wal_file;

  // An optional write-ahead log index file, specified only if this backend uses
  // a write-ahead log rather than a rollback journal.
  mojo_base.mojom.ReadOnlyFile? wal_index_file;

  // Read-only views are only possible for backends supporting multiple
  // connections, so the shared lock is mandatory.
  mojo_base.mojom.UnsafeSharedMemoryRegion shared_lock;

  // True if this file set was created for a WAL-mode database. An instance may
  // have `wal_file` and `wal_index_file` handles even when false to migrate an
  // existing WAL-mode database back to using a rollback journal.
  bool wal_mode;
};

// The handles needed to open a SQLite DB for read-write access.
struct PendingReadWriteFileSet {
  mojo_base.mojom.File db_file;
  mojo_base.mojom.File journal_file;

  // An optional write-ahead log file, specified only if this backend uses a
  // write-ahead log rather than a rollback journal.
  mojo_base.mojom.File? wal_file;

  // An optional write-ahead log index file, specified only if this backend uses
  // a write-ahead log rather than a rollback journal and supports multiple
  // connections.
  mojo_base.mojom.File? wal_index_file;

  // Read-only handle to the optional WAL-index file (above) on POSIX systems if
  // the database supports multiple connections.
  [EnableIfNot=is_win]
  mojo_base.mojom.ReadOnlyFile? wal_index_file_read_only;

  // The shared lock is present if this backend supports multiple connections.
  mojo_base.mojom.UnsafeSharedMemoryRegion? shared_lock;

  // True if this file set was created for a WAL-mode database. An instance may
  // have a `wal_file` handle and optionally a `wal_index_file` handle even when
  // false to migrate an existing WAL-mode database back to using a rollback
  // journal.
  bool wal_mode;
};
