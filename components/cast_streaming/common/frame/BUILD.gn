visibility = [
  ":*",
  "//components/cast_streaming/browser/frame/*",
  "//components/cast_streaming/renderer/frame/*",

  # Shared between renderer/frame and renderer/web_ui
  "//components/cast_streaming/renderer/common/*",

  # Uses DecoderBufferReader for reading frames from the Renderer process
  "//components/mirroring/service/*",
  "//media/remoting:media_remoting_tests",
]

source_set("frame") {
  public = [
    "decoder_buffer_reader.h",
    "demuxer_stream_traits.h",
  ]
  sources = [ "decoder_buffer_reader.cc" ]
  public_deps = [
    "//base",
    "//media/mojo/mojom",
    "//mojo/public/cpp/system",
  ]
  deps = [
    "//media",
    "//media/mojo/common",
    "//mojo/public/cpp/system",
  ]
}

source_set("unit_tests") {
  testonly = true
  visibility += [ "//components/cast_streaming/common:unit_tests" ]
  public = []
  sources = [ "decoder_buffer_reader_unittest.cc" ]
  deps = [
    ":frame",
    "//base/test:test_support",
    "//media",
    "//media:test_support",
    "//media/mojo/common",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/gfx/geometry",
  ]
}
