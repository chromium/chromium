<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:key="test_preference_card"
        android:title="Test Preference"
        app:backgroundStyle="card" />

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:key="test_preference_color"
        android:title="Test Preference Color"
        app:backgroundStyle="card"
        app:backgroundColor="@android:color/holo_blue_light" />

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:key="test_preference_standard"
        android:title="Test Preference Standard"
        app:backgroundStyle="standard" />

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:key="test_preference_none"
        android:title="Test Preference None"
        app:backgroundStyle="none" />

</PreferenceScreen>
