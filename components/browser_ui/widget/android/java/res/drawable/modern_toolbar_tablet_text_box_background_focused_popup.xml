<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape
        android:shape="rectangle">
      <solid android:color="@color/omnibox_suggestion_dropdown_bg"/>
      <corners
          android:topLeftRadius="@dimen/omnibox_suggestion_dropdown_round_corner_radius"
          android:topRightRadius="@dimen/omnibox_suggestion_dropdown_round_corner_radius"
          android:bottomLeftRadius="0dp"
          android:bottomRightRadius="0dp" />
    </shape>
  </item>
  <item
      android:start="@dimen/location_bar_tablet_fusebox_popup_inset"
      android:end="@dimen/location_bar_tablet_fusebox_popup_inset"
      android:top="@dimen/location_bar_tablet_fusebox_popup_inset"
      android:bottom="0dp">
    <shape
        android:shape="rectangle">
      <solid android:color="@color/search_suggestion_bg_color"/>
      <corners
          android:topLeftRadius="@dimen/modern_toolbar_background_inner_corner_radius"
          android:topRightRadius="@dimen/modern_toolbar_background_inner_corner_radius"
          android:bottomLeftRadius="@dimen/modern_toolbar_background_inner_corner_radius"
          android:bottomRightRadius="@dimen/modern_toolbar_background_inner_corner_radius" />
    </shape>
  </item>
  <item
      android:id="@+id/glif_border_layer"
      android:start="@dimen/location_bar_tablet_fusebox_popup_inset"
      android:end="@dimen/location_bar_tablet_fusebox_popup_inset"
      android:top="@dimen/location_bar_tablet_fusebox_popup_inset"
      android:bottom="0dp">
    <shape android:shape="rectangle">
      <solid android:color="@android:color/transparent" />
    </shape>
  </item>
</layer-list>
