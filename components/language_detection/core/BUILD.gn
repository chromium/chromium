    "language_detection_model_unittest.cc",
    "ngram_hash_ops_utils_unittest.cc",
    "quantization_utils_unittest.cc",
  ]

  deps = [
    ":core",
    "//base",
    "//base/test:test_support",
    "//components/language_detection/testing",
    "//components/translate/core/common:common",
  ]
}
