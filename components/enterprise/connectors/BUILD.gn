import("//components/enterprise/buildflags/buildflags.gni")

source_set("connectors") {
  sources = [
    "common.cc",
    "common.h",
    "connectors_prefs.cc",
    "connectors_prefs.h",
    "device_trust/prefs.cc",
    "device_trust/prefs.h",
    "service_provider_config.cc",
    "service_provider_config.h",
  ]

  public_deps = [ "//components/enterprise/common/proto:connectors_proto" ]

  deps = [
    "//base",
    "//components/enterprise/buildflags",
    "//components/policy/core/browser",
    "//components/policy/core/common",
    "//components/prefs",
    "//components/strings:components_strings_grit",
    "//ui/gfx/range",
  ]

  if (!is_ios) {
    deps += [ "//components/download/public/common:public" ]
  }

  if (enterprise_client_certificates) {
    deps += [ "//components/enterprise/client_certificates/core" ]
  }
}

source_set("unit_tests") {
  testonly = true

  sources = [ "service_provider_config_unittest.cc" ]

  public_deps = [ ":connectors" ]

  deps = [
    "//base",
    "//components/policy/core/browser",
    "//components/policy/core/common",
    "//components/prefs",
    "//components/prefs:test_support",
    "//components/safe_browsing/core/common:safe_browsing_prefs",
    "//testing/gtest",
    "//url:url",
  ]
}
