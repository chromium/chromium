<?xml version="1.0" encoding="utf-8"?>
<grit-part>
  <!-- IPH prompting users on Smart Tab Sharing the first time they add context to a prompt -->
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_HEADER" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    Share relevant open tabs for better responses in this thread?
  </message>
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_HEADER_V2" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    Turn on tab sharing for this thread?
  </message>
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_MESSAGE_BODY" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    Get faster, more tailored responses by sharing your open tabs with this thread.
  </message>
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_MESSAGE_BODY_ALT" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    For the most personalized responses, allow this thread to reference your open tabs.
  </message>
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_MESSAGE_BODY_V2" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    When on, Chrome will automatically identify and use your relevant tabs for better responses.
  </message>
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_LEARN_MORE" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    Learn more
  </message>
  <message name="IDS_STS_IPH_PROMPT_FIRST_TIME_ADDING_CONTEXT_TURN_ON" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    Turn on
  </message>

  <!-- IPH prompting users to turn on Smart Tab Sharing for all threads (Global ON) -->
  <message name="IDS_STS_IPH_PROMPT_TURN_ON_FOR_ALL_THREADS_HEADER" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
    Share open tabs for every thread?
  </message>
  <message name="IDS_STS_IPH_PROMPT_TURN_ON_FOR_ALL_THREADS_HEADER_ALT" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
