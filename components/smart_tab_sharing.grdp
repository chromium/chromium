  <!-- Reminding users when Smart Tab Sharing is on for all threads and providing a pathway to manage the setting -->
  <message name="IDS_STS_CONTEXT_REMINDER_USED_FOLLOWING_TABS" desc="No implementation or screenshot yet. See http://crbug.com/490510281 for context.">
