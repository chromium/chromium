import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojo_bindings") {
  sources = [ "skill.mojom" ]
  webui_module_path = "/"
  cpp_typemaps = [
    {
      types = [
        {
          mojom = "skills.mojom.Skill"
          cpp = "::skills::Skill"
        },
      ]
      traits_headers = [ "skills_mojom_traits.h" ]
      traits_sources = [ "skills_mojom_traits.cc" ]
      traits_public_deps = [ ":public" ]
    },
  ]
  public_deps = [ "//mojo/public/mojom/base" ]
}

source_set("public") {
  sources = [
    "skill.cc",
    "skill.h",
    "skills_service.cc",
    "skills_service.h",
  ]

  public_deps = [
    ":metrics",
    "//base",
    "//components/keyed_service/core",
    "//components/skills/internal:downloader",
    "//components/skills/proto",
    "//components/sync/protocol",
  ]
}

source_set("metrics") {
  sources = [
    "skills_metrics.cc",
    "skills_metrics.h",
  ]

  public_deps = [ "//base" ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "skill_unittest.cc" ]

  deps = [
    ":public",
    "//base/test:test_support",
  ]

  visibility = [ "//components/skills:unit_tests" ]
}
