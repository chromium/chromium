source_set("internal") {
  visibility = [
    ":*",
    "//chrome/browser/skills",
    "//chrome/test:interactive_ui_tests",
    "//components/skills/content",
  ]

  sources = [
    "skills_service_impl.cc",
    "skills_service_impl.h",
    "skills_sync_bridge.cc",
    "skills_sync_bridge.h",
  ]

  public_deps = [
    "//base",
    "//components/skills/public",
  ]

  deps = [
    ":downloader",
    "//components/optimization_guide/core",
    "//components/skills:features",
    "//components/skills/proto",
    "//components/sync/model",
    "//components/sync/protocol",
    "//net",
    "//services/network/public/cpp",
  ]
}

source_set("downloader") {
  sources = [
    "skills_downloader.cc",
    "skills_downloader.h",
  ]

  deps = [
    "//base",
    "//components/skills/proto",
    "//components/skills/public:metrics",
    "//net",
    "//services/network/public/cpp",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [
    "skills_downloader_unittest.cc",
    "skills_service_impl_unittest.cc",
    "skills_sync_bridge_unittest.cc",
  ]

  deps = [
    ":downloader",
    ":internal",
    "//base",
    "//base/test:test_support",
    "//components/optimization_guide/core",
    "//components/optimization_guide/core:test_support",
    "//components/skills:features",
    "//components/skills/mocks",
    "//components/skills/proto",
    "//components/skills/public",
    "//components/sync:test_support",
    "//components/sync/base",
    "//components/sync/model",
    "//components/sync/protocol",
    "//testing/gtest",
  ]

  visibility = [ "//components/skills:unit_tests" ]
}
