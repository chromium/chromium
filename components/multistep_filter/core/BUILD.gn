source_set("features") {
  sources = [
    "features.cc",
    "features.h",
  ]
  deps = [ "//base" ]
}

source_set("switches") {
  sources = [
    "switches.cc",
    "switches.h",
  ]
  deps = [ "//base" ]
}

source_set("util") {
  sources = [
    "multistep_filter_util.cc",
    "multistep_filter_util.h",
  ]
  deps = [
    ":features",
    "//base",
    "//net",
    "//url",
  ]
}

source_set("core") {
  sources = [
    "multistep_filter_service.cc",
    "multistep_filter_service.h",
    "multistep_filter_ui_delegate.h",
  ]
  deps = [
    ":features",
    "//base",
    "//components/history/core/browser",
    "//components/keyed_service/core",
    "//components/multistep_filter/core/logging",
    "//components/signin/public/identity_manager",
    "//components/sync/base",
    "//components/sync/service",
    "//components/unified_consent",
    "//net",
    "//url",
  ]
  public_deps = [
    ":util",
    "//components/multistep_filter/core/annotation_index",
    "//components/multistep_filter/core/data_models",
    "//components/multistep_filter/core/extraction",
    "//components/multistep_filter/core/storage",
    "//components/multistep_filter/core/suggestion",
  ]
}

source_set("test_support") {
  testonly = true
  sources = [ "multistep_filter_service_test_api.h" ]
  public_deps =
      [ "//components/multistep_filter/core/annotation_index:test_support" ]
  deps = [
    ":core",
    "//base",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "multistep_filter_service_unittest.cc",
    "multistep_filter_util_unittest.cc",
  ]
  deps = [
    ":core",
    ":features",
    ":test_support",
    ":util",
    "//base",
    "//base/test:test_support",
    "//components/multistep_filter/core/annotation_index:test_support",
    "//components/multistep_filter/core/annotation_index:unit_tests",
    "//components/multistep_filter/core/data_models:unit_tests",
    "//components/multistep_filter/core/extraction",
    "//components/multistep_filter/core/extraction:unit_tests",
    "//components/multistep_filter/core/logging:unit_tests",
    "//components/multistep_filter/core/storage",
    "//components/multistep_filter/core/storage:unit_tests",
    "//components/multistep_filter/core/suggestion",
    "//components/multistep_filter/core/suggestion:unit_tests",
    "//components/prefs:test_support",
    "//components/signin/public/identity_manager:test_support",
    "//components/sync:test_support",
    "//components/unified_consent",
    "//testing/gmock",
    "//testing/gtest",
    "//url",
  ]
}
