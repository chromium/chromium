source_set("features") {
  sources = [
    "features.cc",
    "features.h",
  ]
  deps = [ "//base" ]
}

source_set("core") {
  sources = [
    "multistep_filter_service.cc",
    "multistep_filter_service.h",
  ]
  deps = [
    "//base",
    "//components/keyed_service/core",
    "//components/signin/public/identity_manager",
    "//url",
  ]
  public_deps = [
    "//components/multistep_filter/core/data_models",
    "//components/multistep_filter/core/suggestion",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "multistep_filter_service_unittest.cc" ]
  deps = [
    ":core",
    "//base",
    "//base/test:test_support",
    "//components/multistep_filter/core/data_models:unit_tests",
    "//components/multistep_filter/core/extraction:unit_tests",
    "//components/multistep_filter/core/suggestion",
    "//components/multistep_filter/core/suggestion:unit_tests",
    "//components/signin/public/identity_manager:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//url",
  ]
}
