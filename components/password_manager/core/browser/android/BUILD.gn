import("//build/config/android/config.gni")
import("//third_party/jni_zero/jni_zero.gni")

source_set("android") {
  sources = [
    "android_requirements.cc",
    "android_requirements.h",
  ]
  deps = [
    ":jni",
    "//base",
  ]
}

android_library("android_java") {
  sources =
      [ "org/chromium/components/password_manager/AndroidRequirements.java" ]
  deps = [
    "//base:base_java",
    "//build/android:build_java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//third_party/jni_zero:jni_zero_java",
  ]
  srcjar_deps = [ ":jni" ]
}

generate_jni("jni") {
  sources =
      [ "org/chromium/components/password_manager/AndroidRequirements.java" ]
  visibility = [ ":*" ]
}
