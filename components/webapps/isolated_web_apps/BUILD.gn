source_set("isolated_web_apps") {
  sources = [
    "client.cc",
    "client.h",
    "error/uma_logging.cc",
    "error/uma_logging.h",
    "error/unusable_swbn_file_error.cc",
    "error/unusable_swbn_file_error.h",
    "reading/response_reader.cc",
    "reading/response_reader.h",
    "reading/response_reader_factory.cc",
    "reading/response_reader_factory.h",
    "reading/response_reader_registry.cc",
    "reading/response_reader_registry.h",
    "reading/response_reader_registry_factory.cc",
    "reading/response_reader_registry_factory.h",
    "reading/signed_web_bundle_reader.cc",
    "reading/signed_web_bundle_reader.h",
    "reading/validator.cc",
    "reading/validator.h",

    # TODO(crbug.com/431980377): Move update_channel to types/.
    "update_channel.cc",
    "update_channel.h",
  ]

  public_deps = [
    ":features",
    ":key_distribution",
    "//base",
    "//components/keyed_service/content",
    "//components/keyed_service/core",
    "//components/web_package",
    "//components/webapps/isolated_web_apps/proto",
    "//components/webapps/isolated_web_apps/types",
    "//net",
    "//services/data_decoder/public/cpp",
    "//services/network/public/cpp",
    "//url",
  ]

  deps = [ "//content/public/browser" ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "error/uma_logging_unittest.cc",
    "error/unusable_swbn_file_error_unittest.cc",
  ]
  deps = [
    ":isolated_web_apps",
    "//base/test:test_support",
  ]
}

source_set("features") {
  sources = [
    "features.cc",
    "features.h",
  ]
  public_deps = [ "//base" ]
}

source_set("key_distribution") {
  sources = [
    "iwa_key_distribution_histograms.h",
    "iwa_key_distribution_info_provider.cc",
    "iwa_key_distribution_info_provider.h",
  ]
  deps = [
    ":features",
    "//components/webapps/isolated_web_apps/proto",
  ]
  public_deps = [ "//base" ]
}
