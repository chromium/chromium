<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1213425325105380833">бһҹбҹ’бһҠбһ¶бһҡбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһңбҹҒбһ”бһҠбҹӮбһӣбһўбҹ’бһ“бһҖбһ”бһ¶бһ“бһ”бҹ’бһҡбһҫбһҗбҹ’бһҳбһёбҹ—бһ“бҹҒбҹҮбһ“бҹ…бһӣбһҫбһ§бһ”бһҖбһҡбһҺбҹҚбһҠбҹӮбһӣбһ”бһ¶бһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢбһ‘бҹ…бһӮбһҺбһ“бһёбһ“бҹҒбҹҮ</translation>
<translation id="2065911435109240297">бһҹбҹ’бһҠбһ¶бһҡбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһңбҹҒбһ”бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ</translation>
<translation id="2111649875343992405">бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҳбһҫбһӣбһҗбһ¶бһҸбҹ’бһҡбһјбһңбһҹбҹ’бһҠбһ¶бһҡбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһңбҹҒбһ”бһҺбһ¶бһҒбҹ’бһӣбҹҮ</translation>
<translation id="2139186145475833000">бһ”бһ“бҹ’бһҗбҹӮбһҳбһ‘бҹ…бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһҠбһҫбһҳ</translation>
<translation id="2172982519592313442">бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҳбһҫбһӣбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһңбҹҒбһ”</translation>
<translation id="2478076885740497414">бһҸбҹҶбһЎбһҫбһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһё</translation>
<translation id="3789841737615482174">бһҸбҹҶбһЎбһҫбһ„</translation>
<translation id="3910402514791813257">бһҳбһ·бһ“бһўбһ¶бһ…вҖӢбһҠбҹҶбһЎбһҫбһ„бһ”бһ¶бһ“бһ‘бҹҒ</translation>
<translation id="4250229828105606438">бһҗбһҸбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ</translation>
<translation id="4665282149850138822"><ph name="NAME" /> бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһ“бҹ’бһҗбҹӮбһҳбһ‘бҹ…бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһҠбһҫбһҳбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ</translation>
<translation id="5250483651202458397">бһҡбһјбһ”бһҗбһҸвҖӢбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбҹ” бһ…бһ»бһ…бһҠбһҫбһҳбҹ’бһ”бһёбһ”бһ·бһ‘бҹ”</translation>
<translation id="5972844218283131174">бһҠбһҖбһҖбһ¶бһҡбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ</translation>
<translation id="6990079615885386641">бһ‘бһ‘бһҪбһӣбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһ“бҹҒбҹҮбһ–бһё Google Play Store: <ph name="APP_ACTION" /></translation>
<translation id="7333031090786104871">бһҖбҹҶбһ–бһ»бһ„вҖӢбһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ–бһёбһҳбһ»бһ“вҖӢбһ“бҹ…бһЎбһҫбһҷ</translation>
<translation id="7672888405515738928">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһңбҹҒбһ”бһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңбһҹбҹ’бһҠбһ¶бһҡбһӣбһҫбһ§бһ”бһҖбһҡбһҺбҹҚбһ“бҹҒбҹҮбҹ” бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҠбҹӮбһӣбһ”бһ„бҹ’бһ бһ¶бһүбһ“бҹ…бһ‘бһёбһ“бҹҒбҹҮбһӮбһәбһ•бҹ’бһўбҹӮбһҖбһӣбһҫбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ· Chrome бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</translation>
<translation id="8163051092261298861">бһҹбҹ’бһҠбһ¶бһҡбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһңбҹҒбһ”</translation>
<translation id="962979164594783469">бһҠбҹҶбһЎбһҫбһ„вҖӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһ“бҹҒбҹҮ</translation>
</translationbundle>