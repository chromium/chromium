# Configuration for an Android-12L (S_V2, API 32) AVD on google_apis on x86_64
# This should be kept in sync with foldable proto except the screen size

emulator_package {
  package_name: "chromium/third_party/android_sdk/public/emulator"
  version: "fS1J2VhqKvbfzOX-30B8DEbVTfSF-CR5G0epjSFDa_QC"  # 34.2.15 (Stable)
  dest_path: "android_32_google_apis_x64_foldable_landscape"
}

system_image_package {
  package_name: "chromium/third_party/android_sdk/public/system-images/android-32/google_apis/x86_64"
  version: "n4LhzpIajmPkxO_59_ggvj3Fc5oVmJGhtHVr3n3kT_kC"  # r8, SE1B.240122.005
  dest_path: "android_32_google_apis_x64_foldable_landscape"
}
system_image_name: "system-images;android-32;google_apis;x86_64"

avd_package {
  package_name: "chromium/third_party/android_sdk/public/avds/android-32/google_apis/x86_64"
  # Created in https://ci.chromium.org/ui/b/8742750746881767185
  # Patched gmscore version 24.33.35 in https://crrev.com/c/5669066
  version: "m3lmxut5F_NVYXertAZ23zlLGu9K8so9RDuYOsxoX0UC"
  dest_path: "android_32_google_apis_x64_foldable_landscape"
}
avd_name: "android_32_google_apis_x64_foldable_landscape"
