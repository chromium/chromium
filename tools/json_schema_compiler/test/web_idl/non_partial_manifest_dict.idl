// This will raise an error as the dict should be a partial dictionary.
dictionary ExtensionManifest {
  DOMString string_key;
};

// Example WebIDL schema which is invalid as it defines an ExtensionManifest
// dictionary for defining associated manifest keys, but doesn't make it
// partial.
interface TestWebIdl {
};

partial interface Browser {
  static attribute TestWebIdl testWebIdl;
};
