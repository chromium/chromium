<histogram-configuration>

<enums>

<!-- LINT.IfChange(IndigoTransformationResult) -->

<enum name="IndigoTransformationResult">
  <int value="0" label="Unknown"/>
  <int value="1" label="Success"/>
  <int value="2" label="Not signed in"/>
  <int value="3" label="Missing capabilities"/>
  <int value="4" label="Disabled by policy"/>
  <int value="5" label="Missing script"/>
  <int value="6" label="Remote status missing"/>
  <int value="7" label="Service not supported"/>
  <int value="8" label="Missing user image"/>
  <int value="9" label="Not onboarded"/>
  <int value="10" label="Generate image error"/>
</enum>

<!-- LINT.ThenChange(//chrome/browser/indigo/indigo_page_action_controller.h:IndigoTransformationResult) -->

</enums>

</histogram-configuration>
