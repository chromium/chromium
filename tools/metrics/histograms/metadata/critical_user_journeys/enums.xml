<!--
This file defines enums used in Critical User Journey histograms.
-->

<histogram-configuration>

<enums>

<!-- Define the steps for your journeys below! -->

<!-- LINT.IfChange(ClearBrowsingHistoryJourneySteps) -->

<enum name="ClearBrowsingHistoryJourneySteps">
  <int value="1" label="Open clear browsing data dialog via accelerator"/>
  <int value="2" label="Activate app menu toolbar button"/>
  <int value="3" label="Show clear browsing data settings dialog"/>
  <int value="4" label="Clear browsing data history event"/>
</enum>

<!-- LINT.ThenChange(//chrome/browser/metrics/critical_user_journeys/critical_user_journey_registry.h:ClearBrowsingHistoryJourneySteps) -->

<!-- LINT.IfChange(CriticalUserJourneyResult) -->

<enum name="CriticalUserJourneyResult">
  <int value="0" label="Completed"/>
  <int value="1" label="Aborted"/>
  <int value="2" label="Timed Out"/>
</enum>

<!-- LINT.ThenChange(//chrome/browser/metrics/critical_user_journeys/critical_user_journey_session.h:JourneyResult) -->

<!-- LINT.IfChange(PinExtensionJourneySteps) -->

<enum name="PinExtensionJourneySteps">
  <int value="1" label="Clicked the extensions toolbar button"/>
  <int value="2" label="Pin extension via menu item"/>
  <int value="3" label="Pin the extension via the side panel pin button"/>
</enum>

<!-- LINT.ThenChange(//chrome/browser/metrics/critical_user_journeys/critical_user_journey_registry.h:PinExtensionJourneySteps) -->

<!-- LINT.IfChange(ViewDownloadedFileFromAppMenuJourneySteps) -->

<enum name="ViewDownloadedFileFromAppMenuJourneySteps">
  <int value="1" label="Finish download"/>
  <int value="2" label="App menu button clicked"/>
  <int value="3" label="Downloads menu item clicked"/>
  <int value="4" label="Downloaded file clicked"/>
</enum>

<!-- LINT.ThenChange(//chrome/browser/metrics/critical_user_journeys/critical_user_journey_registry.h:ViewDownloadedFileFromAppMenuJourneySteps) -->

<!-- LINT.IfChange(ViewDownloadedFileJourneySteps) -->

<enum name="ViewDownloadedFileJourneySteps">
  <int value="1" label="Finish download"/>
  <int value="2" label="Download bubble appears"/>
  <int value="3" label="User clicked download bubble"/>
  <int value="4" label="Click downloaded file"/>
</enum>

<!-- LINT.ThenChange(//chrome/browser/metrics/critical_user_journeys/critical_user_journey_registry.h:ViewDownloadedFileJourneySteps) -->

</enums>

</histogram-configuration>
