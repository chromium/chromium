{%- set header_guard = "%s_"|format(
        out_file_path|upper|replace("/","_")|replace(".","_")|
            replace("-", "_")) %}

// This file is generated from:
{%- for path in in_files %}
//   {{path}}
{%-  endfor %}

#ifndef {{header_guard}}
#define {{header_guard}}

#include "third_party/skia/include/core/SkColor.h"

namespace {{namespace_name}} {

enum class ColorName {
{%- for obj in colors %}
  {{obj.name | to_const_name}},
{%-  endfor %}
};

{%- if opacities %}

enum class OpacityName {
{%-   for name in opacities.keys() %}
  {{name | to_const_name}},
{%-   endfor %}
};

SkAlpha GetOpacity(OpacityName opacity_name,
                   bool is_dark_mode);
{%- endif %}

SkColor ResolveColor(ColorName color_name,
                     bool is_dark_mode,
                     bool use_debug_colors);

extern char kDebugOverrideCssString[];

}  // namespace {{namespace_name}}
#endif  // {{header_guard}}
