import("//build/config/chrome_build.gni")
import("//build/config/dcheck_always_on.gni")

declare_args() {
  # This flag enables the graph dump feature for WebNN.
  webnn_enable_graph_dump =
      (is_win || is_linux || is_mac) && !is_official_build && dcheck_always_on
}
