import("//build/buildflag_header.gni")
import("//services/webnn/public/webnn_features.gni")

buildflag_header("buildflags") {
  header = "webnn_buildflags.h"
  flags = [ "WEBNN_ENABLE_GRAPH_DUMP=$webnn_enable_graph_dump" ]
}

component("cpp") {
  sources = [
    "compiler_disconnect_reason.h",
    "context_properties.cc",
    "context_properties.h",
    "data_type_limits.cc",
    "data_type_limits.h",
    "graph_validation_utils.cc",
    "graph_validation_utils.h",
    "ml_number.cc",
    "ml_number.h",
    "ml_tensor_usage.h",
    "operand_descriptor.cc",
    "operand_descriptor.h",
    "range.h",
    "supported_data_types.h",
    "supported_tensors.h",
    "webnn_errors.cc",
    "webnn_errors.h",
    "webnn_trace.cc",
    "webnn_trace.h",
    "webnn_types.h",
  ]

  public_deps = [
    ":buildflags",
    "//base",
  ]

  deps = [
    "//mojo/public/cpp/bindings",
    "//third_party/fp16",
  ]

  if (is_mac) {
    sources += [
      "coreml_initializer.cc",
      "coreml_initializer.h",
    ]
  }

  configs += [ "//build/config/compiler:prevent_unsafe_narrowing" ]

  defines = [ "IS_WEBNN_PUBLIC_CPP_IMPL" ]
}

# Provides a factory function for creating an in-process TFLite/LiteRT
# WebNNContextProvider.
source_set("in_process_context_provider") {
  sources = [
    "in_process_context_provider.cc",
    "in_process_context_provider.h",
  ]

  public_deps = [
    "//base",
    "//mojo/public/cpp/system",
  ]

  deps = [
    "//mojo/public/cpp/bindings",
    "//services/webnn:webnn_service",
    "//services/webnn/public/mojom",
  ]
}

if (is_win) {
  component("win") {
    sources = [
      "execution_providers_info.h",
      "platform_functions_win.cc",
      "platform_functions_win.h",
      "win_app_runtime_package_info.h",
    ]

    public_deps = [ "//base" ]

    deps = [ "//third_party/windows_app_sdk_headers:version_info" ]

    defines = [ "IS_WEBNN_PUBLIC_CPP_WIN_IMPL" ]
  }
}

source_set("tests") {
  testonly = true

  sources = [
    "ml_number_unittest.cc",
    "webnn_trace_unittest.cc",
  ]

  deps = [
    ":cpp",
    "//base/test:test_support",
    "//testing/gtest",
    "//third_party/fp16",
  ]
}
