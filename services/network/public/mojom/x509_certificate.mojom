module network.mojom;

// Typemapped to `scoped_refptr<net::X509Certificate>`.
struct X509Certificate {
  // The DER-encoded certificate.
  array<uint8> cert;
  // DER-encoded intermediates in the chain, if any.
  array<array<uint8>> intermediates;
};
