module network.mojom;

// Typemapped to `net::HttpResponseHeaders`.
struct HttpResponseHeaders {
  // Raw headers, starting with a normalized status line; the remainder are raw
  // header values, preserved as literally possible for fidelity. Lines are
  // delimited by NUL characters.
  array<uint8> headers;
};
