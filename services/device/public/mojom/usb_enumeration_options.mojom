module device.mojom;

import "mojo/public/mojom/base/string16.mojom";

struct UsbDeviceFilter {
  uint16? vendor_id;
  uint16? product_id;
  uint8? class_code;
  uint8? subclass_code;
  uint8? protocol_code;
  mojo_base.mojom.String16? serial_number;
};

struct UsbEnumerationOptions {
  array<UsbDeviceFilter> filters;
};
