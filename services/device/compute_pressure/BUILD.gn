import("//build/config/features.gni")

source_set("compute_pressure") {
  visibility = [ "//services/device:*" ]

  sources = [
    "compute_pressure_manager_impl.cc",
    "compute_pressure_manager_impl.h",
    "compute_pressure_sample.h",
    "compute_pressure_sampler.cc",
    "compute_pressure_sampler.h",
    "cpu_probe.cc",
    "cpu_probe.h",
  ]

  public_deps = [ "//services/device/public/mojom" ]

  deps = [
    "//base",
    "//mojo/public/cpp/bindings",
  ]

  if (is_linux || is_chromeos) {
    sources += [
      "cpu_probe_linux.cc",
      "cpu_probe_linux.h",
      "procfs_stat_cpu_parser.cc",
      "procfs_stat_cpu_parser.h",
    ]
  }
}
