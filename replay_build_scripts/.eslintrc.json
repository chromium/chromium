{
  "rules": {
    "quotes": "off",
    "prefer-const": "off",
    "comma-dangle": "off",
    "no-console": "off",
    "no-undef": ["error"],
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  }
}
