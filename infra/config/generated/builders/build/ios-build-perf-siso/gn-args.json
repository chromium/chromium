{
  "phases": {
    "builtin": {
      "gn_args": {
        "coverage_instrumentation_input_file": "//.code-coverage/files_to_instrument.txt",
        "enable_run_ios_unittests_with_xctest": true,
        "ios_chrome_enable_profile_altering_tests": true,
        "ios_enable_dangling_raw_ptr_checks": true,
        "is_component_build": false,
        "is_debug": true,
        "symbol_level": 1,
        "target_cpu": "arm64",
        "target_environment": "simulator",
        "target_os": "ios",
        "use_clang_coverage": true,
        "use_reclient": false,
        "use_remoteexec": true,
        "use_siso": true
      }
    },
    "no_clang_modules": {
      "gn_args": {
        "coverage_instrumentation_input_file": "//.code-coverage/files_to_instrument.txt",
        "enable_run_ios_unittests_with_xctest": true,
        "ios_chrome_enable_profile_altering_tests": true,
        "ios_enable_dangling_raw_ptr_checks": true,
        "is_component_build": false,
        "is_debug": true,
        "symbol_level": 1,
        "target_cpu": "arm64",
        "target_environment": "simulator",
        "target_os": "ios",
        "use_clang_coverage": true,
        "use_clang_modules": false,
        "use_reclient": false,
        "use_remoteexec": true,
        "use_siso": true
      }
    }
  }
