{
  "$build/siso": {
    "configs": [
      "builder",
      "remote-link",
      "default-remote"
    ],
    "enable_cloud_monitoring": true,
    "enable_cloud_trace": true,
    "experiments": [
      "no-fallback"
    ],
    "keep_going": 0,
    "profile_mode": "cloud",
    "project": "rbe-chromium-untrusted",
    "remote_jobs": 250
  }
}