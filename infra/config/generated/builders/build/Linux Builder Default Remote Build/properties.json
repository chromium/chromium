{
  "$build/chromium_tests_builder_config": {
    "builder_config": {
      "additional_exclusions": [
        "infra/config/generated/builders/build/Linux Builder Default Remote Build/gn-args.json"
      ],
      "builder_db": {
        "entries": [
          {
            "builder_id": {
              "bucket": "build",
              "builder": "Linux Builder Default Remote Build",
              "project": "chromium"
            },
            "builder_spec": {
              "builder_group": "chromium.build.fyi",
              "execution_mode": "COMPILE_AND_TEST",
              "legacy_chromium_config": {
                "apply_configs": [
                  "mb"
                ],
                "build_config": "Release",
                "config": "chromium",
                "target_bits": 64,
                "target_platform": "linux"
              },
              "legacy_gclient_config": {
                "apply_configs": [
                  "use_clang_coverage",
                  "chromium_with_telemetry_dependencies"
                ],
                "config": "chromium"
              }
            }
          }
        ]
      },
      "builder_ids": [
        {
          "bucket": "build",
          "builder": "Linux Builder Default Remote Build",
          "project": "chromium"
        }
      ],
      "targets_spec_directory": "infra/config/generated/builders/build/Linux Builder Default Remote Build/targets"
    }
  },
  "$build/siso": {
    "configs": [
      "builder",
      "remote-link",
      "default-remote"
    ],
    "enable_cloud_monitoring": true,
    "enable_cloud_trace": true,
    "experiments": [],
    "keep_going": 0,
    "profile_mode": "cloud",
    "project": "rbe-chromium-trusted",
    "remote_jobs": 250
  },
  "$recipe_engine/resultdb/test_presentation": {
    "column_keys": [],
    "grouping_keys": [
      "status",
      "v.test_suite"
    ]
  },
  "builder_group": "chromium.build.fyi",
  "recipe": "chromium"
}