{
  "gn_args": {
    "android_static_analysis": "on",
    "clang_use_default_sample_profile": false,
    "debuggable_apks": false,
    "default_min_sdk_version": 23,
    "enable_resource_allowlist_generation": false,
    "is_component_build": false,
    "is_cronet_build": true,
    "is_debug": true,
    "symbol_level": 1,
    "target_cpu": "arm64",
    "target_os": "android",
    "use_reclient": false,
    "use_remoteexec": true,
    "use_siso": true
  }
}