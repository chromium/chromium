{
  "Win x64 Builder": {
    "additional_compile_targets": [
      "base_nocompile_tests",
      "blink_platform_nocompile_tests",
      "blink_probes_nocompile_tests",
      "content_nocompile_tests",
      "pdf_fuzzers"
    ],
    "scripts": [
      {
        "module_name": "check_network_annotations",
        "module_scheme": "single",
        "name": "check_network_annotations",
        "script": "check_network_annotations.py"
      },
      {
        "module_name": "metrics_python_tests",
        "module_scheme": "pyunit",
        "name": "metrics_python_tests",
        "script": "metrics_python_tests.py"
      },
      {
        "module_name": "webkit_lint",
        "module_scheme": "single",
        "name": "webkit_lint",
        "script": "blink_lint_expectations.py"
      }
    ]
  },
  "win-webium-product-rel": {
    "gtest_tests": [
      {
        "args": [
          "--enable-features=InitialWebUI,WebUIReloadButton,WebUISplitTabsButton,SkipIPCChannelPausingForNonGuests,WebUIInProcessResourceLoadingV2,InitialWebUISyncNavStartToCommit"
        ],
        "isolate_profile_data": true,
        "merge": {
          "script": "//testing/merge_scripts/standard_gtest_merge.py"
        },
        "module_name": "//chrome/test:browser_tests",
        "module_scheme": "gtest",
        "name": "browser_tests",
        "retry_only_failed_tests": true,
        "swarming": {
          "dimensions": {
            "cpu": "x86-64",
            "os": "Windows-11"
          },
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com",
          "shards": 14
        },
        "test": "browser_tests",
        "test_id_prefix": "ninja://chrome/test:browser_tests/"
      },
      {
        "args": [
          "--enable-features=InitialWebUI,WebUIReloadButton,WebUISplitTabsButton,SkipIPCChannelPausingForNonGuests,WebUIInProcessResourceLoadingV2,InitialWebUISyncNavStartToCommit"
        ],
        "isolate_profile_data": true,
        "merge": {
          "script": "//testing/merge_scripts/standard_gtest_merge.py"
        },
        "module_name": "//chrome/test:interactive_ui_tests",
        "module_scheme": "gtest",
        "name": "interactive_ui_tests",
        "retry_only_failed_tests": true,
        "swarming": {
          "dimensions": {
            "cpu": "x86-64",
            "os": "Windows-11"
          },
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com",
          "shards": 3
        },
        "test": "interactive_ui_tests",
        "test_id_prefix": "ninja://chrome/test:interactive_ui_tests/"
      },
      {
        "args": [
          "--enable-features=InitialWebUI,WebUIReloadButton,WebUISplitTabsButton,SkipIPCChannelPausingForNonGuests,WebUIInProcessResourceLoadingV2,InitialWebUISyncNavStartToCommit"
        ],
        "isolate_profile_data": true,
        "merge": {
          "script": "//testing/merge_scripts/standard_gtest_merge.py"
        },
        "module_name": "//chrome/test:unit_tests",
        "module_scheme": "gtest",
        "name": "unit_tests",
        "retry_only_failed_tests": true,
        "swarming": {
          "dimensions": {
            "cpu": "x86-64",
            "os": "Windows-11"
          },
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com"
        },
        "test": "unit_tests",
        "test_id_prefix": "ninja://chrome/test:unit_tests/"
      }
    ]
  }
}