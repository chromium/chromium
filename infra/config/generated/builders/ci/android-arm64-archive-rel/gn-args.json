{
  "gn_args": {
    "android_static_analysis": "on",
    "dcheck_always_on": false,
    "debuggable_apks": false,
    "enable_android_secondary_abi": true,
    "is_component_build": false,
    "is_debug": false,
    "symbol_level": 0,
    "target_cpu": "arm64",
    "target_os": "android",
    "use_mold": false,
    "use_reclient": false,
    "use_remoteexec": true,
    "use_siso": true
  }
}