  "android-x64-treesinviz-enabled-rel": {
    "gtest_tests": [
      {
        "args": [
          "--enable-features=TreesInViz",
          "--avd-config=../../tools/android/avd/proto/android_35_google_apis_x64.textpb",
          "--gs-results-bucket=chromium-result-details",
          "--recover-devices"
        ],
        "description": "Run with android_35_google_apis_x64",
        "merge": {
          "args": [
            "--bucket",
            "chromium-result-details",
            "--test-name",
            "browser_tests"
          ],
          "script": "//build/android/pylib/results/presentation/test_results_presentation.py"
        },
        "module_name": "//chrome/test:browser_tests",
        "module_scheme": "gtest",
        "name": "browser_tests",
        "swarming": {
          "dimensions": {
            "cores": "8",
            "cpu": "x86-64",
            "device_os": null,
            "device_type": null,
            "os": "Ubuntu-22.04",
            "pool": "chromium.tests.avd"
          },
          "named_caches": [
            {
              "name": "android_35_google_apis_x64",
              "path": ".android_emulator/android_35_google_apis_x64"
            }
          ],
          "optional_dimensions": {
            "60": {
              "caches": "android_35_google_apis_x64"
            }
          },
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com"
        },
        "test": "browser_tests",
        "test_id_prefix": "ninja://chrome/test:browser_tests/"
      },
