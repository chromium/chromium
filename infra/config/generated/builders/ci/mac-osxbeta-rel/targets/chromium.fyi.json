          },
          "expiration": 21600,
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com"
        },
        "test": "telemetry_gpu_unittests",
        "test_id_prefix": "ninja://chrome/test:telemetry_gpu_unittests/"
