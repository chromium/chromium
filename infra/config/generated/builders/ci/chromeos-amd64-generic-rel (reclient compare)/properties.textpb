{
  "$build/reclient": {
    "ensure_verified": true,
    "instance": "rbe-chromium-trusted",
    "metrics_project": "chromium-reclient-metrics",
    "rewrapper_env": {
      "RBE_compare": "true"
    }
  },
  "$kitchen": {
    "devshell": true,
    "emulate_gce": true,
    "git_auth": true
  },
  "$recipe_engine/resultdb/test_presentation": {
    "column_keys": [],
    "grouping_keys": [
      "status",
      "v.test_suite"
    ]
  },
  "recipe": "chromium"
}