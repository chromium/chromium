{
  "linux-chromeos-treesinviz-enabled-rel": {
    "gtest_tests": [
      {
        "args": [
          "--enable-features=TreesInViz"
        ],
        "merge": {
          "script": "//testing/merge_scripts/standard_gtest_merge.py"
        },
        "module_name": "//chrome/test:browser_tests",
        "module_scheme": "gtest",
        "name": "browser_tests",
        "retry_only_failed_tests": true,
        "swarming": {
          "dimensions": {
            "cpu": "x86-64",
            "kvm": "1",
            "os": "Ubuntu-22.04"
          },
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com",
          "shards": 60
        },
        "test": "browser_tests",
        "test_id_prefix": "ninja://chrome/test:browser_tests/"
      },
      {
        "args": [
          "--enable-features=TreesInViz"
        ],
        "merge": {
          "script": "//testing/merge_scripts/standard_gtest_merge.py"
        },
        "module_name": "//cc:cc_unittests",
        "module_scheme": "gtest",
        "name": "cc_unittests",
        "retry_only_failed_tests": true,
        "swarming": {
          "dimensions": {
            "cpu": "x86-64",
            "os": "Ubuntu-22.04"
          },
          "service_account": "chromium-tester@chops-service-accounts.iam.gserviceaccount.com"
        },
        "test": "cc_unittests",
        "test_id_prefix": "ninja://cc:cc_unittests/"
      },
      {
        "args": [
          "--enable-features=TreesInViz"
        ],
        "merge": {
          "script": "//testing/merge_scripts/standard_gtest_merge.py"
        },
        "module_name": "//content/test:content_browsertests",
