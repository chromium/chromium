              "project": "chromium"
            },
            "builder_spec": {
              "build_gs_bucket": "chromium-fyi-archive",
              "builder_group": "chromium.fyi",
              "execution_mode": "COMPILE_AND_TEST",
              "legacy_chromium_config": {
                "apply_configs": [
                  "mb",
                  "mb_no_luci_auth"
                ],
                "config": "chromium",
