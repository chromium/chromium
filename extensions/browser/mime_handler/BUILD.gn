import("//extensions/buildflags/buildflags.gni")

assert(enable_extensions_core)

source_set("mime_handler_stream_delegate") {
  sources = [
    "mime_handler_stream_delegate.cc",
    "mime_handler_stream_delegate.h",
  ]
}

source_set("mime_handler_registry") {
  sources = [
    "mime_handler_registry.cc",
    "mime_handler_registry.h",
  ]
  public_deps = [
    "//base",
    "//components/keyed_service/core",
    "//extensions/browser:browser_sources",
    "//extensions/common",
  ]
  deps = [
    "//components/keyed_service/content",
    "//content/public/browser",
  ]
}

source_set("mime_handler_registry_unittest") {
  testonly = true
  sources = [ "mime_handler_registry_unittest.cc" ]
  deps = [
    ":mime_handler_registry",
    "//base/test:test_support",
    "//components/version_info",
    "//extensions:test_support",
    "//extensions/browser",
    "//extensions/common",
    "//testing/gtest",
  ]
}

source_set("stream_info") {
  sources = [
    "stream_info.cc",
    "stream_info.h",
  ]
  public_deps = [
    "//content/public/browser",
    "//extensions/common:mojom",
    "//mojo/public/cpp/bindings",
  ]
  deps = [
    ":mime_handler_stream_delegate",
    ":stream_container",
    "//base",
  ]
}
source_set("stream_container") {
  sources = [
    "stream_container.cc",
    "stream_container.h",
  ]
  public_deps = [
    "//base",
    "//extensions/common",
    "//extensions/common/api",
    "//third_party/blink/public/mojom:mojom_platform_headers",
    "//url",
  ]
  deps = [
    "//mojo/public/cpp/bindings",
    "//net",
  ]
}
