              'device_type': 'sailfish',
            },
          ],
          'shards': 3,
          'quickrun_shards': 6,
        },
      },
      'android-pie-x86-rel': {
        'args': [
          '--gtest_filter=-ImportantSitesUtilBrowserTest.DSENotConsideredImportantInRegularMode', # https://crbug.com/1034001
