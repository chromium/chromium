<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="fa">
<translation id="1026101648481255140">Ш§ШІШіШұ ЪҜШұЩҒШӘЩҶ ЩҶШөШЁ</translation>
<translation id="1029669172902658969">вҖҸШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ ШЁШұШ§ЫҢ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ChromiumOS</translation>
<translation id="1040916596585577953">вҖҸChromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ</translation>
<translation id="1042552502243217427">вҖҸЩҲЩӮШӘЫҢ ШіШ§ЫҢШӘЫҢ ШЁШұШ§ЫҢ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ Ш®ШөЩҲШөЫҢ ЩҫЫҢЩҲЩҶШҜЩҮШ§ ШҜШұ ШөЩҒШӯЩҮ Ш®ЩҲШҜ ШҜШұШ®ЩҲШ§ШіШӘ Щ…ЫҢвҖҢШҜЩҮШҜШҢ Chromium Ш§ШІ ШіШұЩҲШұЩҮШ§ЫҢ Google Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШ§ Ш§ЫҢЩҶ Ъ©Ш§Шұ ЩҮЩҲЫҢШӘШӘШ§ЩҶ Ш§ШІ ШҜЫҢШҜ ШіШ§ЫҢШӘ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢвҖҢШҙШҜЩҮ ЩҫЩҶЩҮШ§ЩҶ Щ…ЫҢвҖҢШҙЩҲШҜШҢ Ш§Щ…Ш§ Google Щ…ШӘЩҲШ¬ЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ Ъ©ЩҮ ЪҶЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ ШҙШҜЩҮвҖҢШ§ЩҶШҜ.</translation>
<translation id="1065672644894730302">Ш§ЩҲЩ„ЩҲЫҢШӘвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶ Ш®ЩҲШ§ЩҶШҜ. ШЁШ№Ш¶ЫҢ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШҜШұ ШҜШіШӘШұШі ЩҶШЁШ§ШҙЩҶШҜ ЩҲ ШӘШәЫҢЫҢШұШ§ШӘ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШЁШұЪҜШІЫҢШҜЩҮ Ш°Ш®ЫҢШұЩҮ ЩҶШ®ЩҲШ§ЩҮШҜ ШҙШҜ.</translation>
<translation id="1083934481477628225">вҖҸЩҲЩ„ЫҢвҖҢШӘШ§ЩҶ В«Ш§Ш¬Ш§ШІЩҮвҖҢЩҮШ§ЫҢ Щ…ШұШЁЩҲШ· ШЁЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ШҢ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ШҢ ЩҲ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§В» ШұШ§ ШЁШұШ§ЫҢ Chromium Ш®Ш§Щ…ЩҲШҙ Ъ©ШұШҜЩҮ Ш§ШіШӘ</translation>
<translation id="1104942323762546749">вҖҸChromium Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ ШөШ§ШҜШұ Ъ©ЩҶШҜ. ШЁШұШ§ЫҢ Ш§Ш¬Ш§ШІЩҮ ШЁЩҮ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Windows Ш®ЩҲШҜ ШұШ§ ШӘШ§ЫҢЩҫ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="112640046208448578">ЪҶЫҢШІЩҮШ§ ЫҢШ§ Щ…Ъ©Ш§ЩҶвҖҢЩҮШ§ ШұШ§ ШҙЩҶШ§ШіШ§ЫҢЫҢ Ъ©ЩҶЫҢШҜ ЩҲ ЩҶЩҲШҙШӘШ§Шұ ШұШ§ Ъ©ЩҫЫҢ ЫҢШ§ ШӘШұШ¬Щ…ЩҮ Ъ©ЩҶЫҢШҜ. ЩҲЩӮШӘЫҢ Ш§ШІ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ ЩҶЩ…Ш§ЪҜШұЩҒШӘЫҢ Ш§ШІ ШөЩҒШӯЩҮ ШЁЩҮ ШіШұЩҲШұ Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢШҙЩҲШҜ. <ph name="LEARN_MORE" /></translation>
<translation id="113122355610423240">вҖҸChromium Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ШӘШ§ЩҶ Ш§ШіШӘ</translation>
<translation id="1131805035311359397">вҖҸШЁШұШ§ЫҢ ШЁШұШұШіЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§ШІ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШҜШұШЁШұШ§ШЁШұ ЩҶЩӮШ¶ ШҜШ§ШҜЩҮ ЫҢШ§ ШҜЫҢЪҜШұ Щ…ШҙЪ©Щ„Ш§ШӘ Ш§Щ…ЩҶЫҢШӘЫҢ Щ…ШӯШ§ЩҒШёШӘ Щ…ЫҢвҖҢШҙЩҲШҜШҢ <ph name="BEGIN_LINK" />ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ<ph name="END_LINK" />.</translation>
<translation id="1153368717515616349">вҖҸШұЩҲЫҢ Щ…ЩҶЩҲЫҢ Chromium Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="1157985233335035034">ШІШЁШ§ЩҶвҖҢЩҮШ§ЫҢ Ш§Ш®ЫҢШұ</translation>
<translation id="1184145431117212167">вҖҸЩҶШөШЁ Ш§ЩҶШ¬Ш§Щ… ЩҶШҙШҜ ЪҶЩҲЩҶ Ш§ШІ ЩҶШіШ®ЩҮ Windows ШҙЩ…Ш§ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="1185134272377778587">вҖҸШҜШұШЁШ§ШұЩҮ Chromium</translation>
<translation id="1188705220418984327">вҖҸШЁШұШ§ЫҢ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ ЩҫЩҶШ¬ШұЩҮШҢ В«Ш¶ШЁШ·вҖҢЪ©ЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ЩҲЫҢЪҳЩҮ ChromiumВ» ШұШ§ ШҜШұ В«Ш§ЩҲЩ„ЩҲЫҢШӘвҖҢЩҮШ§ЫҢ ШіЫҢШіШӘЩ…В» Щ…Ш¬Ш§ШІ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="1203500561924088507">ШЁШ§ШЁШӘ ЩҶШөШЁ Ш§ШІ ШҙЩ…Ш§ ШіЩҫШ§ШівҖҢЪҜШІШ§ШұЫҢЩ…. ЩӮШЁЩ„вҖҢШ§ШІ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ <ph name="BUNDLE_NAME" />ШҢ ШЁШ§ЫҢШҜ Щ…ШұЩҲШұЪҜШұ ШұШ§ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="1262876892872089030">вҖҸЩҲЩӮШӘЫҢ Ш§ЫҢЩҶ ШЁШұЪҜЩҮ ШәЫҢШұЩҒШ№Ш§Щ„ ШЁЩҲШҜШҢ Щ…ЩӮШҜШ§ШұЫҢ Ш§ШІ ШӯШ§ЩҒШёЩҮ ШўШІШ§ШҜ ШҙШҜ ШӘШ§ ШіШұШ№ШӘ Chromium ШӯЩҒШё ШҙЩҲШҜ. Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ЩҮЩ…ЫҢШҙЩҮ Ш§ШІ ШәЫҢШұЩҒШ№Ш§Щ„ ШҙШҜЩҶ Щ…ШіШӘШ«ЩҶЫҢ ШҙЩҲШҜ.</translation>
<translation id="1265577313130862557">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҒШ§ЫҢЩ„ Ш®Ш·ШұЩҶШ§Ъ© Ш§ШіШӘ</translation>
<translation id="126567311906253476">вҖҸЩҲЩӮШӘЫҢ ШЁШ§ <ph name="USER_EMAIL" /> ШЁЩҮ ШіЫҢШіШӘЩ… ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ Google Щ…Ш«Щ„ Gmail ЫҢШ§ YouTube ЩҲШ§ШұШҜ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШЁШ§ ЩҮЩ…Ш§ЩҶ ШӯШіШ§ШЁ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="1290883685122687410">Ш®Ш·Ш§ЫҢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ: <ph name="METAINSTALLER_EXIT_CODE" />. <ph name="WINDOWS_ERROR" /></translation>
<translation id="1315551408014407711">вҖҸШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ЩҶЩ…Ш§ЫҢЩҮ Chromium Ш¬ШҜЫҢШҜ</translation>
<translation id="1324107359134968521">вҖҸвҖ«Chromium ШЁШұШ§ЫҢ Ъ©Ш§ЩҲШҙ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢ ШЁЩ„ЩҲШӘЩҲШ«
ШЁШ§ЫҢШҜ ШЁЩҮ ШЁЩ„ЩҲШӘЩҲШ« ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜ. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK" /></translation>
<translation id="1330562121671411446">ШӘШҙШ®ЫҢШө ШҜШ§ШҜЩҶ ШІШЁШ§ЩҶ</translation>
<translation id="1342274909142618978">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ Ш§ШІ Chromium ЩҮЩ… ШӯШ°ЩҒ ШҙЩҲШҜ (<ph name="URL" />)</translation>
<translation id="1345251407431278948">ШіЩҶШ¬Ш§ЩӮ ШҙШҜ! ШҜЩҒШ№ЩҮ ШЁШ№ШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ШұШ§ Ш§ШІШ·ШұЫҢЩӮ Ш§ЫҢЩҶ ШҜЪ©Щ…ЩҮ Ш¬ШҜЫҢШҜ ШҜШұ ЩҶЩҲШ§ШұШ§ШЁШІШ§Шұ ШЁШ§ШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="1356661055722410047">Ш¬ШҜЫҢШҜ! Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҮЩ… ЩҶЩҲШҙШӘШ§Шұ ЩҲ ЩҮЩ… ШӘШөШ§ЩҲЫҢШұ ШұЩҲЫҢ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ШұШ§ ШӘШұШ¬Щ…ЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="1414495520565016063">вҖҸШҙЩ…Ш§ ЩҲШ§ШұШҜ ШіЫҢШіШӘЩ… Chromium ШҙШҜЫҢШҜ!</translation>
<translation id="1478370723027452770">вҖҸШҜШұЫҢШ§ЩҒШӘ ШұШ§ЩҮЩҶЩ…Ш§ЫҢЫҢ ШҜШұШЁШ§ШұЩҮ Chrome for Testing</translation>
<translation id="1497802159252041924">Ш®Ш·Ш§ЫҢ ЩҶШөШЁ: <ph name="INSTALL_ERROR" /></translation>
<translation id="1524282610922162960">вҖҸЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ ШЁШұЪҜЩҮ Chromium</translation>
<translation id="1553461853655228091">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢШ¬Ш§ШҜ ЩҶЩӮШҙЩҮ ШіЩҮвҖҢШЁШ№ШҜЫҢ Щ…ШӯЫҢШ· ШҙЩ…Ш§ ШЁШ§ЫҢШҜ Ш§Ш¬Ш§ШІЩҮ ШҜШіШӘШұШіЫҢ ШЁЩҮ ШҜЩҲШұШЁЫҢЩҶ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜ</translation>
<translation id="1555494096857516577">{NUM_EXTENSIONS,plural, =1{вҖҸШҜЫҢЪҜШұ Ш§ШІ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ. вҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ.}one{вҖҸШҜЫҢЪҜШұ Ш§ШІ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ. вҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ.}other{вҖҸШҜЫҢЪҜШұ Ш§ШІ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ. вҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ.}}</translation>
<translation id="1574377791422810894">вҖҸШ§ШЁШІШ§ШұЩҮШ§ЫҢ Ш§ЫҢЩ…ЩҶЫҢ Chromium</translation>
<translation id="1591808205441691831">вҖҸЩӮШЁЩ„вҖҢШ§ШІ Ш§ЫҢЩҶЪ©ЩҮ ШЁШӘЩҲШ§ЩҶ ШЁШұШ®ЫҢвҖҢШ§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШұШ§ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» ШҙЩ…Ш§ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜ ЩҲ ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ШұШҜШҢ Chromium ШЁШ§ЫҢШҜ ЩҮЩҲЫҢШӘ ШҙЩ…Ш§ ШұШ§ ШӘШЈЫҢЫҢШҜ Ъ©ЩҶШҜ. Ш§ЪҜШұ Ш§ШІ ШіЫҢШіШӘЩ… Ш®Ш§ШұШ¬ ШҙЩҲЫҢШҜШҢ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШҜШұ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШЁШ§ЩӮЫҢ Ш®ЩҲШ§ЩҮШҜ Щ…Ш§ЩҶШҜ.</translation>
<translation id="1594928384848033697">вҖҸвҖ«Chromium Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ В«Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮВ» ШҙЩ…Ш§ ШұШ§ ШӯШ°ЩҒ Ъ©ЩҶШҜ. ШЁШұШ§ЫҢ Щ…Ш¬Ш§ШІ Ъ©ШұШҜЩҶ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Windows Ш®ЩҲШҜ ШұШ§ ШӘШ§ЫҢЩҫ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="1607715478322902680">{COUNT,plural, =0{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Щ„Ш§ШІЩ… Щ…ЫҢвҖҢШҜШ§ЩҶШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ}=1{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Щ„Ш§ШІЩ… Щ…ЫҢвҖҢШҜШ§ЩҶШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ. ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}one{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Щ„Ш§ШІЩ… Щ…ЫҢвҖҢШҜШ§ЩҶШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ. # ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}other{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Щ„Ш§ШІЩ… Щ…ЫҢвҖҢШҜШ§ЩҶШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ. # ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}}</translation>
<translation id="1625909126243026060">вҖҸЩ…ШұЩҲШұ Ъ©ЩҶШӘШұЩ„вҖҢЩҮШ§ЫҢ Ш§ШөЩ„ЫҢ Ш§Щ…ЩҶЫҢШӘ ЩҲ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢ ШҜШұ Chromium</translation>
<translation id="1632539827495546968">вҖҸШ§ЪҜШұ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ ЩҒЩӮШ· ЫҢЪ©вҖҢШЁШ§Шұ Ш§ШІ Ш§ЫҢЩҶ ШӯШіШ§ШЁ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ШІ <ph name="GUEST_LINK_BEGIN" />ШӯШ§Щ„ШӘ Щ…ЩҮЩ…Ш§ЩҶ<ph name="GUEST_LINK_END" /> ШҜШұ Щ…ШұЩҲШұЪҜШұ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ. Ш§ЪҜШұ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ ШЁШұШ§ЫҢ ШҙШ®Шө ШҜЫҢЪҜШұЫҢ ШӯШіШ§ШЁ Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶЫҢШҜШҢ ШЁЩҮ <ph name="DEVICE_TYPE" /> Ш®ЩҲШҜ <ph name="LINK_BEGIN" />ШҙШ®Шө Ш¬ШҜЫҢШҜЫҢ Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶЫҢШҜ<ph name="LINK_END" />.

Ш§Ш¬Ш§ШІЩҮвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ЩӮШЁЩ„Ш§ЩӢ ШЁЩҮ ЩҲШЁвҖҢШіШ§ЫҢШӘвҖҢЩҮШ§ ЩҲ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ ШҜШ§ШҜЩҮвҖҢШ§ЫҢШҜ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШҜШұ Ш§ЫҢЩҶ ШӯШіШ§ШЁ Ш§Ш№Щ…Ш§Щ„ ШҙЩҲШҜ. Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ В«ШӯШіШ§ШЁвҖҢЩҮШ§ЫҢ GoogleВ» Ш®ЩҲШҜ ШұШ§ ШҜШұ ШЁШ®Шҙ <ph name="SETTINGS_LINK_BEGIN" />ШӘЩҶШёЫҢЩ…Ш§ШӘ<ph name="SETTINGS_LINK_END" /> Щ…ШҜЫҢШұЫҢШӘ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="1640672724030957280">ШҜШұ ШӯШ§Щ„ ШЁШ§ШұЪҜЫҢШұЫҢвҖҰ</translation>
<translation id="1709772298389099340">Ш§Щ…ШӘЫҢШ§ШІЩҮШ§ЫҢ Ш№Ш§Щ„ЫҢ ШЁШұШ§ЫҢ <ph name="BROWSER_NAME" /> Ш§ШұШ§ШҰЩҮ Щ…ЫҢвҖҢШҜЩҮШҜ.</translation>
<translation id="1715127912119967311">вҖҸШЁШұШ§ЫҢ Ъ©Щ…Ъ© ШЁЩҮ ШЁЩҮШЁЩҲШҜ Ш§ЫҢЩҶ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ШҢ Chromium ШӘШ№Ш§Щ…Щ„Ш§ШӘ ШҙЩ…Ш§ ШЁШ§ Ш§ЫҢЩҶ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ ШұШ§ ШЁЩҮ Google Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш§ЩҒШұШ§ШҜ ШЁШ§ШІШЁЫҢЩҶ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШұШ§ ШЁШ®ЩҲШ§ЩҶЩҶШҜШҢ ЩҲ ЩҫШұШҜШ§ШІШҙ ЩҲ ШӯШ§ШҙЫҢЩҮвҖҢЩҶЩҲЫҢШіЫҢ Ъ©ЩҶЩҶШҜ.</translation>
<translation id="1722488837206509557">Ш§ЫҢЩҶ Ъ©Ш§Шұ ШЁЩҮ ШҙЩ…Ш§ Ш§Щ…Ъ©Ш§ЩҶ Щ…ЫҢвҖҢШҜЩҮШҜ Ш§ШІ ШЁЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢ ШҜШұШҜШіШӘШұШі Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ ЩҲ Щ…ШӯШӘЩҲШ§ ШұШ§ ШҜШұ ШўЩҶвҖҢЩҮШ§ ЩҶЩ…Ш§ЫҢШҙ ШҜЩҮЫҢШҜ.</translation>
<translation id="1733725117201708356">вҖҸChromium ШЁЩҮвҖҢШІЩҲШҜЫҢ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШұШ§ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="1736443181683099871">вҖҸChromium ШіШ№ЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ ЩҫЫҢЩ…Ш§ЫҢШҙвҖҢЩҮШ§ ШұШ§ ШЁЩҮ HTTPS Ш§ШұШӘЩӮШ§ ШҜЩҮШҜ</translation>
<translation id="1736662517232558588">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ЩҫШ§Ъ© ШҙШҜ</translation>
<translation id="1745121272106313518">вҖҸChromium ШӘШ§ <ph name="REMAINING_TIME" /> ШҜЫҢЪҜШұ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ</translation>
<translation id="1749104137266986751">вҖҸЩҲЩӮШӘЫҢ HTTPS ШҜШұШҜШіШӘШұШі ЩҶШЁШ§ШҙШҜШҢ Chromium ШЁШҜЩҲЩҶ ШҜШ§ШҜЩҶ ЩҮШҙШҜШ§Шұ ШЁЩҮ ШҙЩ…Ш§ Ш§ШІ Ш§ШӘШөШ§Щ„ ЩҶШ§Ш§Щ…ЩҶ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="1774152462503052664">вҖҸШ§Ш¬Ш§ШІЩҮ ШЁЩҮ Chromium ШЁШұШ§ЫҢ Ш§Ш¬ШұШ§ ШҜШұ ЩҫШівҖҢШІЩ…ЫҢЩҶЩҮ</translation>
<translation id="1779356040007214683">вҖҸШЁШұШ§ЫҢ Ш§ЫҢЩ…ЩҶвҖҢШӘШұ Ъ©ШұШҜЩҶ ChromiumШҢ ШЁШұШ®ЫҢ Ш§ШІ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ЫҢЫҢ ШұШ§ Ъ©ЩҮ ШҜШұВ <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ЩҒЩҮШұШіШӘ ШҙШҜЩҮвҖҢШ§ЩҶШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШЁШҜЩҲЩҶ Ш§Ш·Щ„Ш§Ш№ ШҙЩ…Ш§ Ш§Ш¶Ш§ЩҒЩҮ ШҙШҜЩҮ ШЁШ§ШҙЩҶШҜШҢ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ШұШҜЫҢЩ….</translation>
<translation id="1808667845054772817">вҖҸЩҶШөШЁ Щ…Ш¬ШҜШҜ Chromium</translation>
<translation id="1820835682567584003">вҖҸChromium ШҜШұ ШӘЩ„Ш§Шҙ Ш§ШіШӘ <ph name="AUTHENTICATION_PURPOSE" /></translation>
<translation id="1838374766361614909">ЩҫШ§Ъ© Ъ©ШұШҜЩҶ Ш¬ШіШӘШ¬ЩҲ</translation>
<translation id="18552579716432081">вҖҸШЁШұШ§ЫҢ ШӯШ°ЩҒ Ъ©ШұШҜЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ЩҒЩӮШ· Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ЩҲ ЩҶЪҜЩҮШҜШ§ШұЫҢ ШўЩҶ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ»ШҢ <ph name="BEGIN_LINK" />Ш§ШІ ШіЫҢШіШӘЩ… Chromium Ш®Ш§ШұШ¬ ШҙЩҲЫҢШҜ<ph name="END_LINK" />.</translation>
<translation id="185970820835152459">вҖҸЩ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ В«ШӯШіШ§ШЁвҖҢЩҮШ§ЫҢ GoogleВ» Ш®ЩҲШҜШӘШ§ЩҶ ШұШ§ Ъ©ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ШўЩҶвҖҢЩҮШ§ ЩҲШ§ШұШҜ ШҙШҜЩҮвҖҢШ§ЫҢШҜ Щ…ШҜЫҢШұЫҢШӘ Ъ©ЩҶЫҢШҜ. Ш§ШІ В«ШӯШіШ§ШЁвҖҢЩҮШ§ЫҢ GoogleВ» ШҙЩ…Ш§ ШҜШұ Щ…ШұЩҲШұЪҜШұ ChromiumШҢ В«ЩҒШұЩҲШҙЪҜШ§ЩҮ PlayВ»ШҢ вҖҸGmailШҢ ЩҲ Щ…ШӯШөЩҲЩ„Ш§ШӘ ШҜЫҢЪҜШұ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ. Ш§ЪҜШұ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ ШӯШіШ§ШЁ ЩҒШұШҜ ШҜЫҢЪҜШұЫҢ ШұШ§ Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶЫҢШҜ (Щ…Ш«Щ„Ш§ЩӢ ЫҢЪ©ЫҢ Ш§ШІ Ш§Ш№Ш¶Ш§ЫҢ Ш®Ш§ЩҶЩҲШ§ШҜЩҮ)ШҢ ШЁЩҮвҖҢШ¬Ш§ЫҢ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ШҙШ®Шө Ш¬ШҜЫҢШҜЫҢ ШұШ§ ШЁЩҮ <ph name="DEVICE_TYPE" /> Ш®ЩҲШҜ Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶЫҢШҜ. <ph name="LINK_BEGIN" />ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="LINK_END" /></translation>
<translation id="1862852878885210965">Ш¬ШіШӘШ¬ЩҲ Ъ©ШұШҜЩҶ ШЁШ§ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ»</translation>
<translation id="1863308913976887472">вҖҸШіШ§ЫҢШӘвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ ШЁШ§Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium Ш§Ш·Щ„Ш§Ш№Ш§ШӘЫҢ ШҜШұШЁШ§ШұЩҮ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ Ш°Ш®ЫҢШұЩҮ Ъ©ЩҶЩҶШҜ. ШЁШұШ§ЫҢ Щ…Ш«Ш§Щ„ШҢ Ш§ЪҜШұ ШЁШұШ§ЫҢ Ш®ШұЫҢШҜ Ъ©ЩҒШҙ Щ…Ш®ШөЩҲШө Щ…Ш§ШұШ§ШӘЩҲЩҶ Ш§ШІ ШіШ§ЫҢШӘЫҢ ШЁШ§ШІШҜЫҢШҜ Ъ©ЩҶЫҢШҜШҢ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШўЩҶ ШіШ§ЫҢШӘ Ш№Щ„Ш§ЩӮЩҮ ШҙЩ…Ш§ ШұШ§ ШЁЩҮвҖҢШөЩҲШұШӘ ШҜЩҲЩҶШҜЩҮ Щ…Ш§ШұШ§ШӘЩҲЩҶ Щ…ШҙШ®Шө Ъ©ЩҶШҜ. ШЁШ№ШҜШ§ЩӢШҢ Ш§ЪҜШұ ШЁШұШ§ЫҢ Ш«ШЁШӘвҖҢЩҶШ§Щ… ШҜШұ Щ…ШіШ§ШЁЩӮЩҮвҖҢШ§ЫҢ ШЁЩҮ ШіШ§ЫҢШӘЫҢ ШҜЫҢЪҜШұ Щ…ШұШ§Ш¬Ш№ЩҮ Ъ©ШұШҜЫҢШҜШҢ ШўЩҶ ШіШ§ЫҢШӘ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁШұШ§ШіШ§Ші Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ ШўЪҜЩҮЫҢвҖҢШ§ЫҢ ШЁШұШ§ЫҢ Ъ©ЩҒШҙ Щ…Ш®ШөЩҲШө ШҜЩҲЫҢШҜЩҶ ШЁЩҮ ШҙЩ…Ш§ ЩҶШҙШ§ЩҶ ШҜЩҮШҜ.</translation>
<translation id="1880677175115548835">Ш§ЩҶШӘШ®Ш§ШЁ ЩҶЩҲШҙШӘШ§Шұ</translation>
<translation id="1881322772814446296">вҖҸШҙЩ…Ш§ ШЁШ§ ШӯШіШ§ШЁ Щ…ШҜЫҢШұЫҢШӘвҖҢШҙШҜЩҮ ЩҲШ§ШұШҜ ШіЫҢШіШӘЩ… Щ…ЫҢвҖҢШҙЩҲЫҢШҜ ЩҲ ШЁЩҮ ШіШұЩҫШұШіШӘ ШўЩҶ Ш§Ш¬Ш§ШІЩҮ Ъ©ЩҶШӘШұЩ„ ШЁШұ ЩҶЩ…Ш§ЫҢЩҮ Chromium Ш®ЩҲШҜ ШұШ§ Щ…ЫҢвҖҢШҜЩҮЫҢШҜ. ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШҙЩ…Ш§ ШҙШ§Щ…Щ„ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ШҢ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШіШ§ШЁЩӮЩҮШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ЩҲ ШіШ§ЫҢШұ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШЁШұШ§ЫҢ ЩҮЩ…ЫҢШҙЩҮ ШЁЩҮ <ph name="USER_NAME" /> Щ…ШұШӘШЁШ· Ш®ЩҲШ§ЩҮШҜ ШҙШҜ. Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШұШ§ Ш§ШІ Ш·ШұЫҢЩӮ ШҜШ§ШҙШЁЩҲШұШҜ ШӯШіШ§ШЁвҖҢЩҮШ§ЫҢ Google ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ Ш§Щ…Ш§ ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШұШ§ ШЁЩҮ ШӯШіШ§ШЁ ШҜЫҢЪҜШұЫҢ Щ…ШұШӘШЁШ· ШіШ§ШІЫҢШҜ. ШҜШұ ШөЩҲШұШӘ ШӘЩ…Ш§ЫҢЩ„ ШЁШұШ§ЫҢ Ш°Ш®ЫҢШұЩҮ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium Щ…ЩҲШ¬ЩҲШҜ ШЁЩҮ ШөЩҲШұШӘ Ш¬ШҜШ§ЪҜШ§ЩҶЩҮ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҶЩ…Ш§ЫҢЩҮ Ш¬ШҜЫҢШҜЫҢ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶЫҢШҜ. <ph name="LEARN_MORE" /></translation>
<translation id="1896836275755235458">вҖҸвҖ«Chromium ШЁШ§ Щ…ШӯШҜЩҲШҜ Ъ©ШұШҜЩҶ ЩҒШ№Ш§Щ„ЫҢШӘ ЩҫШівҖҢШІЩ…ЫҢЩҶЩҮ ЩҲ Ш¬Щ„ЩҲЩҮвҖҢЩҮШ§ЫҢ ШҜЫҢШҜШ§ШұЫҢШҢ Щ…Ш«Щ„ ЩҫЫҢЩ…Ш§ЫҢШҙ ШұЩҲШ§ЩҶ ЩҲ ЩҶШұШ® ЩҒШұЫҢЩ… ЩҲЫҢШҜЫҢЩҲШҢ ШҜШұ Щ…ШөШұЩҒ ШЁШ§ШӘШұЫҢ ШөШұЩҒЩҮвҖҢШ¬ЩҲЫҢЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ В«ШЁЩҮЫҢЩҶЩҮвҖҢШіШ§ШІЫҢ Ш§ЩҶШұЪҳЫҢВ» ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" /></translation>
<translation id="1900969832270057921">вҖҸШіШұЩҲЫҢШі ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶ Chromium</translation>
<translation id="1911763535808217981">вҖҸШЁШ§ Ш®Ш§Щ…ЩҲШҙ Ъ©ШұШҜЩҶ Ш§ЫҢЩҶ ЪҜШІЫҢЩҶЩҮШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШЁШҜЩҲЩҶ ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ШЁЩҮ ШіЫҢШіШӘЩ… ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢ Google Щ…Ш§ЩҶЩҶШҜ Gmail ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="1916451563296275579">вҖҸШЁШұШҜШ§ШҙШӘЩҶ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШЁШұЩҶШ§Щ…ЩҮ Ш§ШІ Chromium</translation>
<translation id="1929939181775079593">вҖҸChromium ЩҫШ§ШіШ® ЩҶЩ…ЫҢвҖҢШҜЩҮШҜ. Щ…Ш¬ШҜШҜШ§ЩӢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ШҙЩҲШҜШҹ</translation>
<translation id="1933341829955786215">вҖҸШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ (<ph name="MANAGER" />) ШҙЩ…Ш§ ШұШ§ Щ…Щ„ШІЩ… Щ…ЫҢвҖҢЪ©ЩҶШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="193439633299369377">вҖҸШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ ChromiumOS ШЁШ§ЫҢШҜ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ШҙЩҲШҜ.</translation>
<translation id="1951406923938785464">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҶЩҲШ№ ЩҒШ§ЫҢЩ„ Щ…Ш№Щ…ЩҲЩ„Ш§ЩӢ ШЁШ§ШұЪҜЫҢШұЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш®Ш·ШұЩҶШ§Ъ© ШЁШ§ШҙШҜ</translation>
<translation id="1953553007165777902">ШҜШұШӯШ§Щ„ ШЁШ§ШұЪҜЫҢШұЫҢвҖҰ <ph name="MINUTE" /> ШҜЩӮЫҢЩӮЩҮ ШЁШ§ЩӮЫҢ Щ…Ш§ЩҶШҜЩҮ Ш§ШіШӘ</translation>
<translation id="1966382378801805537">вҖҸChromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШұШ§ ШӘШ№ЫҢЫҢЩҶ ЫҢШ§ ШӘЩҶШёЫҢЩ… Ъ©ЩҶШҜ</translation>
<translation id="1990262977744080398">вҖҸШЁШЁЫҢЩҶЫҢШҜ ЪҶШұШ§ Chromium ШЁШұШ®ЫҢвҖҢШ§ШІ ЩҒШ§ЫҢЩ„вҖҢЩҮШ§ ШұШ§ Щ…ШіШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜШҢ ШҜШұ ШЁШұЪҜЩҮ Ш¬ШҜЫҢШҜ ШЁШ§ШІ Щ…ЫҢвҖҢШҙЩҲШҜ</translation>
<translation id="1999715455684970349">вҖҸЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ Chromium ШұШ§ ШЁЩҮвҖҢШұЩҲШІ ЩҶЪҜЩҮ Щ…ЫҢвҖҢШҜШ§ШұШҜ. Ш§ЪҜШұ Ш§ЫҢЩҶ ШіШұЩҲЫҢШі ШәЫҢШұЩҒШ№Ш§Щ„ ЫҢШ§ Щ…ШӘЩҲЩӮЩҒ ШҙЩҲШҜШҢ ЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ Chromium ШЁЩҮвҖҢШұЩҲШІ ЩҶШ®ЩҲШ§ЩҮШҜ Щ…Ш§ЩҶШҜШҢ ШЁЩҮ Ш§ЫҢЩҶ Щ…Ш№ЩҶЫҢ Ъ©ЩҮ ШўШіЫҢШЁвҖҢЩҫШ°ЫҢШұЫҢвҖҢЩҮШ§ЫҢ Ш§Щ…ЩҶЫҢШӘЫҢ Ш§ШӯШӘЩ…Ш§Щ„ЫҢ ШЁШұШ·ШұЩҒ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ Ъ©Ш§Шұ ЩҶЪ©ЩҶЩҶШҜ. Ш§ЫҢЩҶ ШіШұЩҲЫҢШі ШІЩ…Ш§ЩҶЫҢвҖҢЪ©ЩҮ ЩҮЫҢЪҶ ЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ Chromium Ш§ШІ ШўЩҶ Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶЪ©ЩҶШҜШҢ Ш®ЩҲШҜ ШұШ§ ШӯШ°ЩҒ ЩҶШөШЁ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="2008474315282236005">вҖҸШ§ЫҢЩҶ Ъ©Ш§Шұ ЫҢЪ© Щ…ЩҲШұШҜ ШұШ§ Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШұШ§ЫҢ ШЁШ§ШІЫҢШ§ШЁЫҢ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШҜШұ ЩҒШұШөШӘЫҢ ШҜЫҢЪҜШұШҢ ШЁШ§ <ph name="USER_EMAIL" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="2018879682492276940">ЩҶШөШЁ ШӘЪ©Щ…ЫҢЩ„ ЩҶШҙШҜ. Щ„Ш·ЩҒШ§ЩӢ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2020032459870799438">вҖҸШЁШұШ§ЫҢ ШЁШұШұШіЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§ШІ ШҜЫҢЪҜШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШҜШұШЁШұШ§ШЁШұ ЩҶЩӮШ¶ ШҜШ§ШҜЩҮ ЫҢШ§ ШҜЫҢЪҜШұ Щ…ШҙЪ©Щ„Ш§ШӘ Ш§Щ…ЩҶЫҢШӘЫҢ Щ…ШӯШ§ЩҒШёШӘ Щ…ЫҢвҖҢШҙЩҲШҜШҢ <ph name="BEGIN_LINK" />ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ<ph name="END_LINK" />.</translation>
<translation id="2049376729098081731">вҖҸШ§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ Ъ©ЩҮ ШўЫҢШ§ ШіШ§ШЁЩӮЩҮ Chromium ШЁШұШ§ЫҢ ШӘШ¬ШұШЁЩҮвҖҢЩҮШ§ЫҢ ШҙШ®ШөЫҢвҖҢШҙШҜЩҮвҖҢШӘШұ ШҜШұ ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ Google Щ„ШӯШ§Шё ШҙЩҲШҜ ЫҢШ§ ЩҶЩҮ</translation>
<translation id="2086476982681781442">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҒШ§ЫҢЩ„ ЩҒШұЫҢШЁвҖҢШҜЩҮЩҶШҜЩҮ Ш§ШіШӘ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШӘШәЫҢЫҢШұШ§ШӘ ШәЫҢШұЩ…ЩҶШӘШёШұЩҮвҖҢШ§ЫҢ ШҜШұ ШҜШіШӘЪҜШ§ЩҮШӘШ§ЩҶ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶШҜ</translation>
<translation id="2088953378266246249">вҖҸШ§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…ШұШЁЩҲШ· ШЁЩҮ Ш§ЫҢЩҶЪ©ЩҮ Chromium ЪҶЪҜЩҲЩҶЩҮ ЪҜЩҲШ§ЩҮЫҢЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ ШұЫҢШҙЩҮвҖҢШ§Шҙ ШұШ§ Щ…ШҜЫҢШұЫҢШӘ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="2120965832000301375">{COUNT,plural, =1{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ ЫҢЪ© ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ. ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШЁШ§ШІ Ш®ЩҲШ§ЩҮШҜ Щ…Ш§ЩҶШҜ.}one{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ # ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ. ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШЁШ§ШІ Ш®ЩҲШ§ЩҮШҜ Щ…Ш§ЩҶШҜ.}other{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ # ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ. ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШЁШ§ШІ Ш®ЩҲШ§ЩҮШҜ Щ…Ш§ЩҶШҜ.}}</translation>
<translation id="2126108037660393668">ЩҒШ§ЫҢЩ„ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢШҙШҜЩҮ ШӘШЈЫҢЫҢШҜ ЩҶШҙШҜ.</translation>
<translation id="2137162749895930932">ШЁШіШӘЩҶ ШөЩҒШӯЩҮ ШӘШұШ¬Щ…ЩҮ</translation>
<translation id="215352261310130060">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ Ш§ШІ Ш§ШӘШөШ§Щ„ Ш§ЫҢЩ…ЩҶ Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶЩ…ЫҢвҖҢЪ©ЩҶШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҒШ§ЫҢЩ„ ШҜШіШӘЪ©Ш§ШұЫҢ ШҙШҜЩҮ ШЁШ§ШҙШҜ</translation>
<translation id="2157600032285353789">вҖҸЩ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШӯШ§Щ„ШӘ Щ…Ш·Ш§Щ„Ш№ЩҮШҢ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ ШұШ§ Ш§ШІ Щ…ЩҶЩҲЩҗ Chromium ШЁШ§ШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="2174178932569897599">вҖҸШіЩҒШ§ШұШҙЫҢ Ъ©ШұШҜЩҶ Chromium</translation>
<translation id="2174917724755363426">ЩҶШөШЁ Ъ©Ш§Щ…Щ„ ЩҶЫҢШіШӘ. Щ…Ш·Щ…ШҰЩҶЫҢШҜ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ ШўЩҶ ШұШ§ Щ„ШәЩҲ Ъ©ЩҶЫҢШҜШҹ</translation>
<translation id="2185166961232948079">вҖҸChromium - ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… ШҙШЁЪ©ЩҮ - <ph name="PAGE_TITLE" /></translation>
<translation id="2190166659037789668">Ш®Ш·Ш§ЫҢ ШЁШұШұШіЫҢ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ: <ph name="UPDATE_CHECK_ERROR" />.</translation>
<translation id="2199210295479376551">вҖҸШЁШұШҜШ§ШҙШӘЩҶ ШӯШіШ§ШЁ Ш§ШІ Chromium</translation>
<translation id="2210682093923538346">вҖҸШіШ§ЫҢШӘ Ш®Ш·ШұЩҶШ§Ъ©. вҖ«Chromium Ш§Ш№Щ„Ш§ЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШҜШ§ШҙШӘ.</translation>
<translation id="2236949375853147973">ЩҒШ№Ш§Щ„ЫҢШӘ Щ…ЩҶ</translation>
<translation id="2238130810669087193">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ. ШЁШ№ШҜШ§ШІ Ш§ЫҢЩҶЪ©ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЫҢШҜШҢ Ш§ЫҢЩҶ ЩҶШҙШ§ЩҶЫҢ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» ШҙЩ…Ш§ Ш°Ш®ЫҢШұЩҮ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ.</translation>
<translation id="2240214816234246077">вҖҸШ§Ш®ЫҢШұШ§ЩӢ ШЁШ§ШІШҜЫҢШҜЫҢ ЩҶШҜШ§ШҙШӘЩҮвҖҢШ§ЫҢШҜ. вҖ«Chromium вҖҸ<ph name="PERMISSION_1" /> ЩҲ <ph name="PERMISSION_2" /> ШұШ§ ШЁШұШҜШ§ШҙШӘ</translation>
<translation id="2241627712206172106">вҖҸШ§ЪҜШұ ШұШ§ЫҢШ§ЩҶЩҮвҖҢШ§ЫҢ ШұШ§ ШЁЩҮ ШөЩҲШұШӘ Щ…ШҙШӘШұЪ© Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ ШҜЩҲШіШӘШ§ЩҶ ЩҲ Ш®Ш§ЩҶЩҲШ§ШҜЩҮ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ ШЁЩҮ ШөЩҲШұШӘ Ш¬ШҜШ§ЪҜШ§ЩҶЩҮ Щ…ШұЩҲШұ Ъ©ЩҶЩҶШҜ ЩҲ Chromium ШұШ§ ШЁЩҮ ШөЩҲШұШӘЫҢ Ъ©ЩҮ Щ…Ш§ЫҢЩ„ЩҶШҜ ШӘЩҶШёЫҢЩ… Ъ©ЩҶЩҶШҜ.</translation>
<translation id="2313870531055795960">вҖҸЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ЩҲШЁ ШұШ§ ШЁШ§ ЩҒЩҮШұШіШӘ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢ ЩҶШ§Ш§Щ…ЩҶЫҢ Ъ©ЩҮ ШҜШұ Chromium Ш°Ш®ЫҢШұЩҮ ШҙШҜЩҮ Ш§ШіШӘ Щ…ЩӮШ§ЫҢШіЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Ш§ЪҜШұ ШіШ§ЫҢШӘЫҢ ШӘЩ„Ш§Шҙ Ъ©ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШҙЩ…Ш§ ШұШ§ ШЁЩҮвҖҢШіШұЩӮШӘ ШЁШЁШұШҜШҢ ЫҢШ§ ЩҲЩӮШӘЫҢ ЩҒШ§ЫҢЩ„ Щ…Ш®ШұШЁЫҢ ШЁШ§ШұЪҜЫҢШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ Chromium Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ЩҲШЁ ШұШ§ ЩҶЫҢШІ ШЁЩҮвҖҢЩҮЩ…ШұШ§ЩҮ ШЁШ®ШҙвҖҢЩҮШ§ЫҢ Ъ©ЩҲЪҶЪ©ЫҢ Ш§ШІ Щ…ШӯШӘЩҲШ§ЫҢ ШөЩҒШӯЩҮ ШЁЩҮ В«Щ…ШұЩҲШұ Ш§ЫҢЩ…ЩҶВ» Ш§ШұШіШ§Щ„ Ъ©ЩҶШҜ.</translation>
<translation id="2343156876103232566">вҖҸШЁШұШ§ЫҢ Ш§ШұШіШ§Щ„ ШҙЩ…Ш§ШұЩҮ Ш§ШІ Ш§ЫҢЩҶШ¬Ш§ ШЁЩҮ ШӘЩ„ЩҒЩҶ Android Ш®ЩҲШҜШҢ ШҜШұ ЩҮШұ ШҜЩҲ ШҜШіШӘЪҜШ§ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="2359808026110333948">Ш§ШҜШ§Щ…ЩҮ</translation>
<translation id="2361918034042471035">вҖҸШ§ЩҒШІЩҲЩҶЩҮ В«<ph name="EXTENSION_NAME" />В» Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="2374216753258219393">вҖҸШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШЁШ§ ШӯШіШ§ШЁ <ph name="USER_EMAIL_ADDRESS" />ШҢ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="2384373936468275798">вҖҸChromiumOS ЩҶШӘЩҲШ§ЩҶШіШӘ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ Ъ©ЩҶШҜ ШІЫҢШұШ§ Ш¬ШІШҰЫҢШ§ШӘ ЩҲШұЩҲШҜ ШЁЩҮ ШӯШіШ§ШЁ ШҙЩ…Ш§ ШЁЩҮвҖҢШұЩҲШІ ЩҶЫҢШіШӘ.</translation>
<translation id="2398377054246527950">{NUM_DEVICES,plural, =0{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ ЫҢЪ© В«ШҜШіШӘЪҜШ§ЩҮ Щ…ЫҢШ§ЩҶШ§ЫҢ Ш§ЩҶШіШ§ЩҶЫҢВ» (HID) ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҶШҜ}=1{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ ЫҢЪ© В«ШҜШіШӘЪҜШ§ЩҮ Щ…ЫҢШ§ЩҶШ§ЫҢ Ш§ЩҶШіШ§ЩҶЫҢВ» (HID) ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ}one{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ # В«ШҜШіШӘЪҜШ§ЩҮ Щ…ЫҢШ§ЩҶШ§ЫҢ Ш§ЩҶШіШ§ЩҶЫҢВ» (HID) ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ}other{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ # В«ШҜШіШӘЪҜШ§ЩҮ Щ…ЫҢШ§ЩҶШ§ЫҢ Ш§ЩҶШіШ§ЩҶЫҢВ» (HID) ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ}}</translation>
<translation id="2401032172288869980">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҲШұШЁЫҢЩҶ ЩҲ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="2403703063067034158">Ш®Ш·Ш§ЫҢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ: ЩҒШ№Щ„Ш§ЩӢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ШҜЫҢЪҜШұЫҢ ШҜШұШӯШ§Щ„ Ш§Ш¬ШұШ§ Ш§ШіШӘШҢ Щ„Ш·ЩҒШ§ЩӢ Ъ©Щ…ЫҢ ШЁШ№ШҜ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2440750600860946460">вҖҸШЁШ§ <ph name="BEGIN_LINK" />Ш§ШЁШІШ§ШұЩҮШ§ЫҢ Chromium<ph name="END_LINK" />ШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШЁЩҮвҖҢШ·ЩҲШұ Ш§ЫҢЩ…ЩҶ Щ…ШұЩҲШұ Ъ©ЩҶЫҢШҜ ЩҲ Ъ©ЩҶШӘШұЩ„ ШұШ§ ШҜШұШҜШіШӘ ШЁЪҜЫҢШұЫҢШҜ</translation>
<translation id="2451727308784734061">Ш§ШІ Щ…ЫҢШ§ЩҶвҖҢШЁШұ ШЁШұШ§ЫҢ ШҜШіШӘШұШіЫҢ ШіШұЫҢШ№ ШЁЩҮ В«Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮВ» Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ. Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Щ…ЫҢШ§ЩҶвҖҢШЁШұШӘШ§ЩҶ ШұШ§ ШЁЩҮ ШөЩҒШӯЩҮ Ш§ШөЩ„ЫҢ ШұШ§ЫҢШ§ЩҶЩҮ ЫҢШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІ ШЁШұЩҶШ§Щ…ЩҮ Щ…ЩҶШӘЩӮЩ„ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2478295928299953161">вҖҸChromium ШЁЩҮвҖҢШІЩҲШҜЫҢ ШЁШіШӘЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ</translation>
<translation id="2483889755041906834">вҖҸШҜШұ Chromium</translation>
<translation id="2485422356828889247">ШӯШ°ЩҒ ЩҶШөШЁ</translation>
<translation id="2513154137948333830">ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ„Ш§ШІЩ… Ш§ШіШӘ: <ph name="INSTALL_SUCCESS" /></translation>
<translation id="2522009821193247726">вҖҸШЁШұШ§ЫҢ Ш§ШҜШ§Щ…ЩҮ ШҜШ§ШҜЩҶШҢ ШЁШ§ЫҢШҜ ШЁШ§ <ph name="EMAIL" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ. ШЁШ§ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЩҫЫҢШұЩҲЫҢ Ш§ШІ Ш®Ш·вҖҢЩ…ШҙЫҢвҖҢЩҮШ§ЫҢ ШіШ§ШІЩ…Ш§ЩҶ ШӘШ¶Щ…ЫҢЩҶ Щ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="2542968102051442371">ЩҶЩҲШҙШӘШ§ШұЫҢ ШұШ§ ШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ</translation>
<translation id="2554739539410784893">вҖҸChromium Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ЪҜШ°ЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢ Щ…ЩҲШ¬ЩҲШҜ ШұШ§ Ш¬Ш§ЫҢЪҜШІЫҢЩҶ Ъ©ЩҶШҜ. ШЁШұШ§ЫҢ Щ…Ш¬Ш§ШІ Ъ©ШұШҜЩҶ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Windows Ш®ЩҲШҜ ШұШ§ ШӘШ§ЫҢЩҫ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2560420686485554789">вҖҸChromium ШЁШұШ§ЫҢ ШЁШ§ШұЪҜЫҢШұЫҢ ЩҒШ§ЫҢЩ„вҖҢЩҮШ§ ШЁШ§ЫҢШҜ ШЁЩҮ ШӯШ§ЩҒШёЩҮ ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜ</translation>
<translation id="2572494885440352020">Chromium Helper</translation>
<translation id="2575822587468774919">ЩҮШұЪҶЫҢШІЫҢ ШұШ§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ ШӘШ§ ШЁШ§ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» Ш¬ШіШӘШ¬ЩҲ ШҙЩҲШҜ</translation>
<translation id="2576118232315942160">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="2583187216237139145">вҖҸШіШұЩҫШұШіШӘ ЩҶЩ…Ш§ЫҢЩҮ Ъ©Ш§ШұЫҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШұШ§ Ъ©ЩҮ ШҜШұШ·ЩҲЩ„ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Ш§ЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮ Ш§ЫҢШ¬Ш§ШҜ ШҙШҜЩҮвҖҢШ§ЩҶШҜ (Щ…Ш«Щ„ Ш§ЫҢШ¬Ш§ШҜ ШіШ§ШЁЩӮЩҮ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ШҢ ЩҲ ШҜЫҢЪҜШұ ШӘЩҶШёЫҢЩ…Ш§ШӘ) ШЁШұШҜШ§ШұШҜ. <ph name="LEARN_MORE" /></translation>
<translation id="2592940277904433508">вҖҸШ§ШҜШ§Щ…ЩҮ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium</translation>
<translation id="259935314519650377">ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢШҙШҜЩҮ ШҜШұ ШӯШ§ЩҒШёЩҮ ЩҶЩҮШ§ЩҶ Ш°Ш®ЫҢШұЩҮ ЩҶШҙШҜ. Ш®Ш·Ш§: <ph name="UNPACK_CACHING_ERROR_CODE" />.</translation>
<translation id="2635452620547538388">вҖҸШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ЩҲ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШўЩҶвҖҢЩҮШ§ ШҜШұ ШӯШіШ§ШЁШӘШ§ЩҶ (<ph name="ACCOUNT_EMAIL" />)ШҢ ЩҮЩҲЫҢШӘ Ш®ЩҲШҜ ШұШ§ ШЁЩҮвҖҢШӘШЈЫҢЫҢШҜ ШЁШұШіШ§ЩҶЫҢШҜ</translation>
<translation id="264613044588233783">вҖҸChromium ШіШұЫҢШ№вҖҢШӘШұ Ш§Ш¬ШұШ§ Щ…ЫҢвҖҢШҙЩҲШҜ ЩҲ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ Ш§ШІ Ш¬Ш§ЩҲШ§ Ш§ШіЪ©ШұЫҢЩҫШӘ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЩҶШҜ ШЁШ§ЫҢШҜ Ш·ШЁЩӮ Ш·ШұШ§ШӯЫҢ Ъ©Ш§Шұ Ъ©ЩҶЩҶШҜ (ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ)</translation>
<translation id="2648074677641340862">вҖҸЫҢЪ© Ш®Ш·Ш§ЫҢ ШіЫҢШіШӘЩ…вҖҢШ№Ш§Щ…Щ„ ШҜШұ Ш·ЩҲЩ„ ЩҶШөШЁ ШұЩҲЫҢ ШҜШ§ШҜ. Щ„Ш·ЩҒШ§ЩӢ Chromium ШұШ§ ШҜЩҲШЁШ§ШұЩҮ ЩҶШөШЁ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2661879430930417727">вҖҸШ§ЪҜШұ Ш§ШІ ШҜШіШӘЪҜШ§ЩҮЫҢ ШЁЩҮвҖҢШөЩҲШұШӘ Щ…ШҙШӘШұЪ© Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ ШҜЩҲШіШӘШ§ЩҶ ЩҲ Ш§Ш№Ш¶Ш§ЫҢ Ш®Ш§ЩҶЩҲШ§ШҜЩҮ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ Ш¬ШҜШ§ЪҜШ§ЩҶЩҮ Щ…ШұЩҲШұ Ъ©ЩҶЩҶШҜ ЩҲ Chromium ШұШ§ ШЁЩҮвҖҢШҙЫҢЩҲЩҮ Ш®ЩҲШҜШҙШ§ЩҶ ШӘЩҶШёЫҢЩ… Ъ©ЩҶЩҶШҜ</translation>
<translation id="268602741124540128">вҖҸ<ph name="ACCOUNT_FIRST_NAME" /> ШЁЩҮ Chromium Ш®ЩҲШҙ ШўЩ…ШҜЫҢШҜ</translation>
<translation id="2711502716910134313">вҖҸШЁШұЪҜЩҮ Chromium</translation>
<translation id="2718390899429598676">вҖҸШЁШұШ§ЫҢ Ш§Щ…ЩҶЫҢШӘ ШЁЫҢШҙШӘШұШҢ Chromium ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ ШұЩ…ШІЪҜШ°Ш§ШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="2721354645805494590">вҖҸШЁШұШ§ЫҢ ШЁШұШҜШ§ШҙШӘЩҶ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ Ш§ШІ ChromiumШҢ Ш§ШІ ШіЫҢШіШӘЩ… Ш®Ш§ШұШ¬ ШҙЩҲЫҢШҜ</translation>
<translation id="2738871930057338499">вҖҸШ§ШӘШөШ§Щ„ ШЁЩҮ Ш§ЫҢЩҶШӘШұЩҶШӘ ШЁШұЩӮШұШ§Шұ ЩҶШҙШҜ. HTTP ЫҙЫ°Ыі Щ…Щ…ЩҶЩҲШ№ Ш§ШіШӘ. Щ„Ш·ЩҒШ§ЩӢ ЩҫЫҢЪ©ШұШЁЩҶШҜЫҢ ЩҫШұЩҲЪ©ШіЫҢвҖҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2753623023919742414">ШЁШұШ§ЫҢ Ш¬ШіШӘШ¬ЩҲШҢ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="2770231113462710648">ШӘШәЫҢЫҢШұ Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШЁЩҮ:</translation>
<translation id="277338894894732084">вҖҸШЁШ№ШҜШ§ЩӢ Chromium Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢЩҫШұШіШҜ Ъ©ЩҮ ШўЫҢШ§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ Ш§ШІ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Ш°Ш®ЫҢШұЩҮвҖҢШҙШҜЩҮ ШЁШұШ§ЫҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§Шұ ЩҒШұЩ…вҖҢЩҮШ§ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="2785438272836277133">вҖҸШ§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШӯШ§ЩҲЫҢ ШЁШҜШ§ЩҒШІШ§Шұ Ш§ШіШӘ ЩҲ ЩҶШ§Ш§Щ…ЩҶ Ш§ШіШӘ. ШўЩҶ ШұШ§ Ш§ШІ Chromium ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ ШӘШ§ ШҜЫҢЪҜШұ ЩҶШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ (Ш§ШІШ¬Щ…Щ„ЩҮ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ШҙШ®ШөЫҢ) ШұШ§ ШҜШұ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШЁШЁЫҢЩҶШҜ ЩҲ ШӘШәЫҢЫҢШұ ШҜЩҮШҜ.</translation>
<translation id="2799223571221894425">ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ</translation>
<translation id="2803971713792056305">вҖҸвҖ«Chromium ШҙЩ…Ш§</translation>
<translation id="2806241689335397269">вҖҸвҖ«Chromium Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢЩҫШұШіШҜ Ъ©ЩҮ ШўЫҢШ§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ЩҒШұЩ… Щ…Ш«Щ„ ШӘШ§ШұЫҢШ® ШӘЩҲЩ„ШҜШҢ ШіЩҶШҢ ЩҲ ШҙЩ…Ш§ШұЩҮ ЪҜШ°ШұЩҶШ§Щ…ЩҮвҖҢШӘШ§ЩҶ ШұШ§ Ш°Ш®ЫҢШұЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="2837693172913560447">вҖҸШЁШ§ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЩҶЩ…Ш§ЫҢЩҮ Chromium Ш¬ШҜЫҢШҜЫҢ ШЁШұШ§ЫҢ <ph name="USER_EMAIL_ADDRESS" /> Ш§ЫҢШ¬Ш§ШҜ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ</translation>
<translation id="2841525013647267359">ШӘШұШ¬Щ…ЩҮ Ъ©ШұШҜЩҶ Ш§ШІ</translation>
<translation id="2846251086934905009">Ш®Ш·Ш§ЫҢ ЩҶШөШЁ: ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ Ъ©Ш§Щ…Щ„ ЩҶШҙШҜ. ЩҶШөШЁ Щ„ШәЩҲ ШҙШҜ.</translation>
<translation id="2847479871509788944">вҖҸШӯШ°ЩҒ Ш§ШІ Chromium...</translation>
<translation id="2850691299438350830">вҖҸЩҲЩӮШӘЫҢ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮ ШЁШ§ШҙЫҢШҜШҢ Ш§Щ…ЩҶЫҢШӘ ШҙЩ…Ш§ ШұШ§ ШҜШұ Chromium ШӯЩҒШё Щ…ЫҢвҖҢЪ©ЩҶШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШЁШұШ§ЫҢ ШЁЩҮШЁЩҲШҜ Ш§Щ…ЩҶЫҢШӘ ШҙЩ…Ш§ ШҜШұ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ ШҜЫҢЪҜШұ Google Ш§ШіШӘЩҒШ§ШҜЩҮ ШҙЩҲШҜ</translation>
<translation id="2885378588091291677">Щ…ШҜЫҢШұ ЩҲШёШ§ЫҢЩҒ</translation>
<translation id="2910007522516064972">вҖҸШҜШұШЁШ§ШұЩҮ &amp;Chromium</translation>
<translation id="2915996080311180594">ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ШҜШұ ЩҒШұШөШӘЫҢ ШҜЫҢЪҜШұ</translation>
<translation id="2928420929544864228">ЩҶШөШЁ Ъ©Ш§Щ…Щ„ ШҙШҜ.</translation>
<translation id="2933336679234709858">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШЁШ§Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ЪҜШ°ШұШ№ШЁШ§ШұШӘ ШҙЩ…Ш§ ШұЩ…ШІЪҜШ°Ш§ШұЫҢ ШҙШҜЩҮ Ш§ШіШӘ. ШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ЩҲ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ»ШҢ Ш§ЫҢЩҶ ЪҜШ°ШұШ№ШЁШ§ШұШӘ ШұШ§ ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="2945997411976714835">Ш®Ш·Ш§ЫҢ ЩҶШөШЁ: ЩҒШұШ§ЫҢЩҶШҜ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ШҙШұЩҲШ№ ЩҶШҙШҜ.</translation>
<translation id="2970426615109535079">вҖҸШіШ§ШІЩ…Ш§ЩҶ ШҙЩ…Ш§ Chromium ШұШ§ Щ…ШҜЫҢШұЫҢШӘ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="2977470724722393594">вҖҸChromium ШЁЩҮвҖҢШұЩҲШІ Ш§ШіШӘ</translation>
<translation id="2977506796191543575">вҖҸШ§ЪҜШұ ШіШ§ЫҢШӘЫҢ ШӘЩ„Ш§Шҙ Ъ©ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШҙЩ…Ш§ ШұШ§ ШЁЩҮвҖҢШіШұЩӮШӘ ШЁШЁШұШҜШҢ ЫҢШ§ ЩҲЩӮШӘЫҢ ЩҒШ§ЫҢЩ„ Щ…Ш®ШұШЁЫҢ ШЁШ§ШұЪҜЫҢШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ Chromium Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ЩҲШЁ ШұШ§ ЩҶЫҢШІ ШЁЩҮвҖҢЩҮЩ…ШұШ§ЩҮ ШЁШ®ШҙвҖҢЩҮШ§ЫҢ Ъ©ЩҲЪҶЪ©ЫҢ Ш§ШІ Щ…ШӯШӘЩҲШ§ЫҢ ШөЩҒШӯЩҮ ШЁЩҮ В«Щ…ШұЩҲШұ Ш§ЫҢЩ…ЩҶВ» Ш§ШұШіШ§Щ„ Ъ©ЩҶШҜ</translation>
<translation id="2981563588585023386">вҖҸШЁШұШ§ЫҢ Ш§ЫҢЩ…ЩҶвҖҢШӘШұ Щ…Ш§ЩҶШҜЩҶ ШҜШұ ЩҒШ¶Ш§ЫҢ ШўЩҶЩ„Ш§ЫҢЩҶ ШЁШ§ Ъ©Щ…Ъ© Ш§ЩҶШӘШ®Ш§ШЁвҖҢЩҮШ§ЫҢ ЩҲЩ„ЫҢвҖҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="2987208172821108655">вҖҸвҖ«Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Ш§ЫҢЩҶ ШЁШұЪҜЩҮвҖҢЩҮШ§ ШұШ§ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ЩҶШҜ ШӘШ§ ШӘШ¬ШұШЁЩҮ Щ…ШұЩҲШұ ШҙЩ…Ш§ ШұШ§ ШЁЩҮШЁЩҲШҜ ШЁШ®ШҙШҜ ЩҲ Щ…ЩҶШ§ШЁШ№ ШұШ§ ШўШІШ§ШҜ Ъ©ЩҶШҜ.</translation>
<translation id="3013473503895162900">вҖҸвҖ«<ph name="URL" /> ШҜШұ ШЁШұЪҜЩҮ Ш¬ШҜЫҢШҜЫҢ ШҜШұ Chromium ШЁШ§ШІ Щ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="3032706164202344641">вҖҸChromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ. ШЁШ№ШҜШ§ЩӢ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3032787606318309379">вҖҸШ§ЩҒШІЩҲШҜЩҶ ШЁЩҮ ChromiumвҖҰ</translation>
<translation id="3038232873781883849">ШҜШұШ§ЩҶШӘШёШ§Шұ ЩҶШөШЁвҖҰ</translation>
<translation id="3045032126857188731">ШІШЁШ§ЩҶ ШӘШұШ¬Щ…ЩҮвҖҢШҙШҜЩҮ: <ph name="LANGUAGE" /></translation>
<translation id="3068187312562070417">вҖҸШҜЫҢЪҜШұ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium</translation>
<translation id="3068515742935458733">вҖҸШЁШ§ Ш§ШұШіШ§Щ„ ЪҜШІШ§ШұШҙвҖҢЩҮШ§ЫҢ Ш®ШұШ§ШЁЫҢ ЩҲ <ph name="UMA_LINK" /> ШЁЩҮ GoogleШҢ ШЁЩҮ ШЁЩҮШЁЩҲШҜ Google Ъ©Щ…Ъ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="3079753320517721795">{NUM_DEVICES,plural, =0{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ ЫҢЪ© ШҜШіШӘЪҜШ§ЩҮ USB ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҶШҜ}=1{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ ЫҢЪ© ШҜШіШӘЪҜШ§ЩҮ USB ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ}one{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ # ШҜШіШӘЪҜШ§ЩҮ USB ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ}other{вҖҸЫҢЪ© ЫҢШ§ ЪҶЩҶШҜ Ш§ЩҒШІЩҲЩҶЩҮ Chromium ШЁЩҮ # ШҜШіШӘЪҜШ§ЩҮ USB ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ}}</translation>
<translation id="3101560983689755071">вҖҸШіШ§ШЁЩӮЩҮ Щ…ШұЩҲШұ ШҙЩ…Ш§ ШЁШұ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ Щ…ЫҢвҖҢШЁЫҢЩҶЫҢШҜ ЩҲ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ Ъ©ЩҮ ШҜШұ ШІЫҢШұ ШЁШұШўЩҲШұШҜ ШҙШҜЩҮ Ш§ШіШӘ ШӘШЈШ«ЫҢШұ Щ…ЫҢвҖҢЪҜШ°Ш§ШұШҜ. ШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢ ШҙЩ…Ш§ШҢ Chromium Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ ШұШ§ ЩҮШұ Щ…Ш§ЩҮ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ЩҲ ЪҶШұШ®ШҙЫҢ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш№Щ„Ш§ЫҢЩӮ ШЁШ§ШІШўЩҲШұЫҢ ШҙЩҲШҜШҢ Щ…ЪҜШұ Ш§ЫҢЩҶЪ©ЩҮ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ.</translation>
<translation id="3103660991484857065">вҖҸЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ШҜШұ Ш®Ш§ШұШ¬ Ъ©ШұШҜЩҶ ШЁШ§ЫҢЪҜШ§ЩҶЫҢ Ш§ШІ ШӯШ§Щ„ШӘ ЩҒШҙШұШҜЩҮ ЩҶШ§Щ…ЩҲЩҒЩӮ ШЁЩҲШҜ. Щ„Ш·ЩҒШ§ЩӢ ШҜЩҲШЁШ§ШұЩҮ Chromium ШұШ§ ШЁШ§ШұЪҜЫҢШұЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3130323860337406239">вҖҸChromium ШҜШұШӯШ§Щ„ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶ ШҙЩ…Ш§ Ш§ШіШӘ.</translation>
<translation id="3137969841538672700">ШЁШұШ§ЫҢ Ш¬ШіШӘШ¬ЩҲШҢ ШЁШ®Шҙ Щ…ЩҲШұШҜЩҶШёШұ ШұШ§ ШЁЪ©ШҙЫҢШҜ</translation>
<translation id="3144188012276422546">вҖҸШ§ЫҢЩҶ ШЁШұЪҜЩҮ Ш§ШІ Щ…ЩҶШ§ШЁШ№ Ш§Ш¶Ш§ЩҒЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШұШ§ЫҢ ШЁЩҮШЁЩҲШҜ Ш№Щ…Щ„Ъ©ШұШҜШҢ Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ Chromium ШўЩҶ ШұШ§ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ЩҶШҜ.</translation>
<translation id="3155163173539279776">вҖҸШ§Ш¬ШұШ§ЫҢ Щ…Ш¬ШҜШҜ Chromium</translation>
<translation id="3161522574479303604">ЩҮЩ…ЩҮ ШІШЁШ§ЩҶвҖҢЩҮШ§</translation>
<translation id="3179665906251668410">вҖҸШЁШ§ШІ Ъ©ШұШҜЩҶ ЩҫЫҢЩҲЩҶШҜ ШҜШұ ЩҫЩҶШ¬ШұЩҮ &amp;ЩҶШ§ШҙЩҶШ§Ші Chromium</translation>
<translation id="3185330573522821672">вҖҸШіЩҒШ§ШұШҙЫҢ Ъ©ШұШҜЩҶ ЩҶЩ…Ш§ЫҢЩҮ Ш¬ШҜЫҢШҜ Chromium</translation>
<translation id="3224847870593914902">вҖҸШЁШұШ§ЫҢ ШЁШұШҜШ§ШҙШӘЩҶ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ Ш§ШІ ChromiumШҢ ШҜШұ ШөЩҒШӯЩҮ В«ШӘЩҶШёЫҢЩ…Ш§ШӘВ» Ш§ШІ ШіЫҢШіШӘЩ… Chromium Ш®Ш§ШұШ¬ ШҙЩҲЫҢШҜ</translation>
<translation id="3258596308407688501">вҖҸChromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…ШіЫҢШұ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Ш®ЩҲШҜ ШұШ§ ШЁШ®ЩҲШ§ЩҶШҜ ЫҢШ§ ШҜШұ ШўЩҶ ШЁЩҶЩҲЫҢШіШҜ:
<ph name="USER_DATA_DIRECTORY" /></translation>
<translation id="3268051428841342958">вҖҸV8 Щ…ЩҲШӘЩҲШұ WebAssembly ЩҲ Ш¬Ш§ЩҲШ§ Ш§ШіЪ©ШұЫҢЩҫШӘ Chromium Ш§ШіШӘ Ъ©ЩҮ Ш§ШІ ШўЩҶ ШЁШұШ§ЫҢ ШЁЩҮШЁЩҲШҜ Ш№Щ…Щ„Ъ©ШұШҜ ШіШ§ЫҢШӘ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ</translation>
<translation id="3286538390144397061">ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ш§Ъ©ЩҶЩҲЩҶ</translation>
<translation id="328888136576916638">вҖҸЪ©Щ„ЫҢШҜЩҮШ§ЫҢ Google API ЩҲШ¬ЩҲШҜ ЩҶШҜШ§ШұЩҶШҜ. ШЁШұШ®ЫҢ Ш§ШІ Ш№Щ…Щ„Ъ©ШұШҜЩҮШ§ЫҢ Chromium Ш§ШІ Ъ©Ш§Шұ Ш®ЩҲШ§ЩҮЩҶШҜ Ш§ЩҒШӘШ§ШҜ.</translation>
<translation id="3296368748942286671">вҖҸШ§ШҜШ§Щ…ЩҮ Ш§Ш¬ШұШ§ЫҢ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ ШҜШұ ЩҫШівҖҢШІЩ…ЫҢЩҶЩҮ ЩҮЩҶЪҜШ§Щ…ЫҢЪ©ЩҮ Chromium ШЁШіШӘЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ</translation>
<translation id="3313189106987092621">вҖҸChromium ЩӮШЁЩ„вҖҢШ§ШІ Ш§ЫҢЩҶЪ©ЩҮ ЩҮШұ ШіШ§ЫҢШӘЫҢ ШұШ§ Ш§ШІШ·ШұЫҢЩӮ Ш§ШӘШөШ§Щ„ ЩҶШ§Ш§Щ…ЩҶ ШЁШ§Шұ Ъ©ЩҶШҜ ШЁЩҮ ШҙЩ…Ш§ ЩҮШҙШҜШ§Шұ Щ…ЫҢвҖҢШҜЩҮШҜ</translation>
<translation id="3316771292331273802">вҖҸЩҲЩӮШӘЫҢ ЩҮЩ…ЩҮ ЩҫЩҶШ¬ШұЩҮвҖҢЩҮШ§ЫҢ Chromium ШұШ§ ШЁШЁЩҶШҜЫҢШҜ Ш§ШІ ШіЫҢШіШӘЩ… Ш§Ъ©Ш«Шұ ШіШ§ЫҢШӘвҖҢЩҮШ§ Ш®Ш§ШұШ¬ Ш®ЩҲШ§ЩҮЫҢШҜ ШҙШҜШҢ Ш§Щ…Ш§ Ш§ЪҜШұ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙШҜЩҮ ШЁШ§ШҙЫҢШҜ Ш§ШІ В«ШӯШіШ§ШЁ GoogleВ» Ш®Ш§ШұШ¬ ЩҶШ®ЩҲШ§ЩҮЫҢШҜ ШҙШҜ. ШЁШұШ§ЫҢ Ш§ЫҢЩҶЪ©ЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ ШҙЩ…Ш§ ШұШ§ ШЁЩҮвҖҢШ®Ш§Ш·Шұ ШЁШіЩҫШ§ШұЩҶШҜШҢ <ph name="SETTINGS_LINK" />.</translation>
<translation id="3350761136195634146">вҖҸШҜШұШӯШ§Щ„вҖҢШӯШ§Ш¶Шұ ЫҢЪ© ЩҶЩ…Ш§ЫҢЩҮ Chromium ШЁШ§ Ш§ЫҢЩҶ ШӯШіШ§ШЁ ЩҲШ¬ЩҲШҜ ШҜШ§ШұШҜ</translation>
<translation id="3387527074123400161">ChromiumOS</translation>
<translation id="3406848076815591792">вҖҸШЁЩҮ ЩҶЩ…Ш§ЫҢЩҮ Chromium Щ…ЩҲШ¬ЩҲШҜ Щ…ЫҢвҖҢШұЩҲЫҢШҜШҹ</translation>
<translation id="3412460710772753638">ШҜШұ В«Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮВ» ШҜШұ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ</translation>
<translation id="3430503420100763906">вҖҸШЁШ§ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҮЩ…ЩҮ ЪҶЫҢШІШӘШ§ЩҶ ШұШ§ ШҜШұ Chromium Ш¬ШҜШ§ Ъ©ЩҶЫҢШҜ. ШЁШұШ§ЫҢ ШҜЩҲШіШӘШ§ЩҶ ЩҲ Ш§Ш№Ш¶Ш§ЫҢ Ш®Ш§ЩҶЩҲШ§ШҜЩҮвҖҢШӘШ§ЩҶ ЩҶЩ…Ш§ЫҢЩҮ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶЫҢШҜШҢ ЫҢШ§ Ъ©Ш§Шұ ЩҲ ШіШұЪҜШұЩ…ЫҢ ШұШ§ Ш§ШІЩҮЩ… Ш¬ШҜШ§ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="347328004046849135">вҖҸЩҲЩӮШӘЫҢ ШЁШ§ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢШ§ЫҢ Щ„ЩҲШұЩҒШӘЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҢ Chromium ШҙЩ…Ш§ ШұШ§ Щ…Ш·Щ„Ш№ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="3474745554856756813">вҖҸШ§ЫҢЩҶ Ъ©Ш§Шұ <ph name="ITEMS_COUNT" /> Щ…ЩҲШұШҜ ШұШ§ Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШұШ§ЫҢ ШЁШ§ШІЫҢШ§ШЁЫҢ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШҜШұ ЩҒШұШөШӘЫҢ ШҜЫҢЪҜШұШҢ ШЁШ§ <ph name="USER_EMAIL" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="3497319089134299931">вҖҸШЁШ§ <ph name="SHORTCUT" /> Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШЁЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium Ш¬Ш§ШЁЩҮвҖҢШ¬Ш§ ШҙЩҲЫҢШҜ</translation>
<translation id="3509308970982693815">вҖҸЩ„Ш·ЩҒШ§ЩӢ ЩҮЩ…ЩҮ ЩҫЩҶШ¬ШұЩҮвҖҢЩҮШ§ЫҢ Chromium ШұШ§ ШЁШЁЩҶШҜЫҢШҜ ЩҲ ШҜЩҲШЁШ§ШұЩҮ ШіШ№ЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3530103706039034513">вҖҸвҖ«<ph name="EXISTING_USER" /> ШҜШұШӯШ§Щ„вҖҢШӯШ§Ш¶Шұ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮ Ш§ШіШӘ.  ШЁШұШ§ЫҢ Ш¬ШҜШ§ ЩҶЪҜЩҮ ШҜШ§ШҙШӘЩҶ Щ…ШұЩҲШұШӘШ§ЩҶШҢ ШҜШұ ЩҶЩ…Ш§ЫҢЩҮ Ш®ЩҲШҜШӘШ§ЩҶ ШЁШ§ ШӯШіШ§ШЁ <ph name="USER_EMAIL_ADDRESS" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="3533435340678213462">вҖҸШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢ ШҙЩ…Ш§ШҢ Ш№Щ„Ш§ЫҢЩӮЫҢ ШұШ§ Ъ©ЩҮ ЩӮШҜЫҢЩ…ЫҢвҖҢШӘШұ Ш§ШІ Ыҙ ЩҮЩҒШӘЩҮ ШЁШ§ШҙЩҶШҜ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶЫҢЩ…. ЩҲЩӮШӘЫҢ ШЁЩҮ Щ…ШұЩҲШұ Ъ©ШұШҜЩҶ Ш§ШҜШ§Щ…ЩҮ Щ…ЫҢвҖҢШҜЩҮЫҢШҜШҢ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш№Щ„Ш§ЩӮЩҮвҖҢШ§ЫҢ Щ…Ш¬ШҜШҜШ§ЩӢ ШЁЩҮ ЩҒЩҮШұШіШӘ Ш§Ш¶Ш§ЩҒЩҮ ШҙЩҲШҜ. ЫҢШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш№Щ„Ш§ЫҢЩӮЫҢ ШұШ§ Ъ©ЩҮ ЩҶЩ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ Chromium Щ…ШҜЩҶШёШұ ЩӮШұШ§Шұ ШҜЩҮШҜ ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3567254597502212821">вҖҸШіШ§ШЁЩӮЩҮ Щ…ШұЩҲШұ ШҙЩ…Ш§ШҢ ШіШ§ШЁЩӮЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium ШҜШұ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШЁШ§ШІШҜЫҢШҜ Ъ©ШұШҜЩҮвҖҢШ§ЫҢШҜ.</translation>
<translation id="3597003331831379823">ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ШЁШ§ Ш§Щ…ШӘЫҢШ§ШІЩҮШ§ЫҢ Ш№Ш§Щ„ЫҢ Ш§Ш¬ШұШ§ ЩҶШҙШҜ. <ph name="METAINSTALLER_ERROR" /></translation>
<translation id="3639635944603682591">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШӯШөЩҲЩ„ Щ…ШұЩҲШұ Ш§ЫҢЩҶ Ъ©Ш§ШұШЁШұ Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШӯШ°ЩҒ Щ…ЫҢвҖҢШҙЩҲШҜ. ШЁШұШ§ЫҢ ШЁШ§ШІЫҢШ§ШЁЫҢ ШҜШ§ШҜЩҮвҖҢЩҮШ§ШҢ ШЁШ§ ЩҶШ§Щ… <ph name="USER_EMAIL" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="364817392622123556">{COUNT,plural, =0{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш¬ШҜЫҢШҜЫҢ ШЁШұШ§ЫҢ Chromium ШҜШұ ШҜШіШӘШұШі Ш§ШіШӘ ЩҲ ШЁЩҮвҖҢЩ…ШӯШ¶ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ш§Ш№Щ…Ш§Щ„ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ.}=1{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш¬ШҜЫҢШҜЫҢ ШЁШұШ§ЫҢ Chromium ШҜШұ ШҜШіШӘШұШі Ш§ШіШӘ ЩҲ ШЁЩҮвҖҢЩ…ШӯШ¶ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ш§Ш№Щ…Ш§Щ„ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ. ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}one{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш¬ШҜЫҢШҜЫҢ ШЁШұШ§ЫҢ Chromium ШҜШұ ШҜШіШӘШұШі Ш§ШіШӘ ЩҲ ШЁЩҮвҖҢЩ…ШӯШ¶ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ш§Ш№Щ…Ш§Щ„ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ. # ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}other{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш¬ШҜЫҢШҜЫҢ ШЁШұШ§ЫҢ Chromium ШҜШұ ШҜШіШӘШұШі Ш§ШіШӘ ЩҲ ШЁЩҮвҖҢЩ…ШӯШ¶ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ш§Ш№Щ…Ш§Щ„ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ. # ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}}</translation>
<translation id="3651803019964686660">вҖҸШЁШұШ§ЫҢ Ш§ШұШіШ§Щ„ ШҙЩ…Ш§ШұЩҮ Ш§ШІ <ph name="ORIGIN" /> ШЁЩҮ ШӘЩ„ЩҒЩҶ Android Ш®ЩҲШҜШҢ ШҜШұ ЩҮШұ ШҜЩҲ ШҜШіШӘЪҜШ§ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="3667616615096815454">ЩҶШөШЁ ЩҶШҙШҜШҢ ШЁШұЩҶШ§Щ…ЩҮ ШЁШұШ§ЫҢ ШіШұЩҲШұ ЩҶШ§ШҙЩҶШ§Ші Ш§ШіШӘ.</translation>
<translation id="3669334504579945026">вҖҸШЁШұШ§ЫҢ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙШҢ В«Ш¶ШЁШ·вҖҢЪ©ЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ЩҲЫҢЪҳЩҮ ChromiumВ» ШұШ§ ШҜШұ В«Ш§ЩҲЩ„ЩҲЫҢШӘвҖҢЩҮШ§ЫҢ ШіЫҢШіШӘЩ…В» Щ…Ш¬Ш§ШІ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3685209450716071127">вҖҸChromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ. Ш§ШӘШөШ§Щ„ Ш§ЫҢЩҶШӘШұЩҶШӘ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="370962675267501463">{COUNT,plural, =0{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ Ш§ЫҢЩҶ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ}=1{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ Ш§ЫҢЩҶ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ. ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}one{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ Ш§ЫҢЩҶ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ. # ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}other{вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ Ш§ЫҢЩҶ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ. # ЩҫЩҶШ¬ШұЩҮ ЩҶШ§ШҙЩҶШ§Ші ШЁШ§ШІЪҜШҙШ§ЫҢЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.}}</translation>
<translation id="3713809861844741608">вҖҸШЁШ§ШІ Ъ©ШұШҜЩҶ ЩҫЫҢЩҲЩҶШҜ ШҜШұ &amp;ШЁШұЪҜЩҮ Ш¬ШҜЫҢШҜ Chromium</translation>
<translation id="3728124580182886854">вҖҸШЁШұШ§ЫҢ ШҙШ®ШөЫҢвҖҢШіШ§ШІЫҢ ЩҲ Ш§ЩҮШҜШ§ЩҒ ШЁЫҢШҙШӘШұШҢ Chromium ЩҲ ШҜЫҢЪҜШұ ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ Google ШұШ§ ШЁЩҮвҖҢЩҮЩ… ЩҫЫҢЩҲЩҶШҜ ШҜЩҮЫҢШҜ</translation>
<translation id="3788675262216168505">вҖҸЩ…ШҜЫҢШұЫҢШӘ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium</translation>
<translation id="3790262771324122253">вҖҸШЁШЁЫҢЩҶЫҢШҜ ЪҶШұШ§ Chromium ШЁШұШ®ЫҢвҖҢШ§ШІ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШұШ§ Щ…ШіШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="379589255253486813">вҖҸШ§ЪҜШұ Щ…ЩҲШұШҜЫҢ ЩҶЫҢШ§ШІ ШЁЩҮ ШЁШұШұШіЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜШҢ Chromium ШЁЩҮ ШҙЩ…Ш§ Ш§Ш·Щ„Ш§Ш№ Щ…ЫҢвҖҢШҜЩҮШҜ</translation>
<translation id="3802055581630249637">вҖҸвҖ«Chromium ШөЩҒШӯЩҮвҖҢЩҮШ§ЫҢЫҢ ШұШ§ Ъ©ЩҮ Ш§ШӯШӘЩ…Ш§Щ„Ш§ЩӢ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШЁШ§ШІШҜЫҢШҜ Ш®ЩҲШ§ЩҮЫҢШҜ Ъ©ШұШҜ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШӘШ§ ЩҲЩӮШӘЫҢ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШіШұЫҢШ№вҖҢШӘШұ ШЁШ§ШұЪҜЫҢШұЫҢ ШҙЩҲЩҶШҜ</translation>
<translation id="3830894615770080216">вҖҸШіЫҢШіШӘЩ… ChromiumOS</translation>
<translation id="3848258323044014972"><ph name="PAGE_TITLE" /> - Chromium</translation>
<translation id="3871664619793219264">вҖҸШ§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…ШұЩҲШұЪҜШұ Chromium Ш®ЩҲШҜ ШұШ§ Ъ©ЩҮ ШҜШұ <ph name="ACCOUNT_EMAIL" /> Ш°Ш®ЫҢШұЩҮ ШҙШҜЩҮ Ш§ШіШӘ ШҜШұЫҢШ§ЩҒШӘ Ъ©ЩҶЫҢШҜ</translation>
<translation id="3885770153807205175">Ш§ЩҶШӘШ®Ш§ШЁЪҜШұ ШІШЁШ§ЩҶ</translation>
<translation id="388648406173476553">вҖҸChromium ШұШ§ ШіЩҒШ§ШұШҙЫҢ ЩҲ Ъ©ЩҶШӘШұЩ„ Ъ©ЩҶЫҢШҜ. ЪҶЫҢШІЫҢ ЩҶЫҢШ§ШІ ШЁЩҮ ШұШіЫҢШҜЪҜЫҢ ШҜШ§ШұШҜШҢ ШЁШұШ§ЫҢ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ШЁЫҢШҙШӘШұ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3889543394854987837">вҖҸШЁШұШ§ЫҢ ШЁШ§ШІ Ъ©ШұШҜЩҶ Chromium ЩҲ ШҙШұЩҲШ№ ШЁЩҮ Щ…ШұЩҲШұШҢ ШұЩҲЫҢ ЩҶШ§Щ…ШӘШ§ЩҶ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3892148308691398805">Ъ©ЩҫЫҢ Ъ©ШұШҜЩҶ ЩҶЩҲШҙШӘШ§Шұ</translation>
<translation id="390528597099634151">вҖҸ<ph name="EXISTING_USER" /> ЩӮШЁЩ„Ш§ЩӢ ШЁЩҮ ШіЫҢШіШӘЩ… Ш§ЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮ Chromium ЩҲШ§ШұШҜ ШҙШҜЩҮ Ш§ШіШӘ. ШЁШұШ§ЫҢ Ш¬ШҜШ§ ЩҶЪҜЩҮ ШҜШ§ШҙШӘЩҶ Щ…ШұЩҲШұШҢ Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЩҶЩ…Ш§ЫҢЩҮ Щ…Ш®ШӘШө Ш®ЩҲШҜШӘШ§ЩҶ ШұШ§ ШЁШұШ§ЫҢШӘШ§ЩҶ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶШҜ.</translation>
<translation id="3909353120217047026">вҖҸШ§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ Ш®Ш·вҖҢЩ…ШҙЫҢ В«ЩҶШӘвҖҢШЁШ§ШІШ§Шұ ChromeВ» ШұШ§ ЩҶЩӮШ¶ Щ…ЫҢвҖҢЪ©ЩҶШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҶШ§Ш§Щ…ЩҶ ШЁШ§ШҙШҜ. ШўЩҶ ШұШ§ Ш§ШІ Chromium ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ ШӘШ§ ШҜЫҢЪҜШұ ЩҶШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ (Ш§ШІШ¬Щ…Щ„ЩҮ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ШҙШ®ШөЫҢ) ШұШ§ ШҜШұ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШЁШЁЫҢЩҶШҜ ЩҲ ШӘШәЫҢЫҢШұ ШҜЩҮШҜ.</translation>
<translation id="391789666908693569">вҖҸ<ph name="MANAGER_NAME" /> ШӯШіШ§ШЁ ШҙЩ…Ш§ ШұШ§ Щ…ШҜЫҢШұЫҢШӘ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШіШұЩҫШұШіШӘШӘШ§ЩҶ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Ш§ЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮ Щ…ШұЩҲШұЪҜШұ Chromium ЩҲ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШўЩҶ ШұШ§ (Щ…Ш«Щ„ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШіШ§ШЁЩӮЩҮШҢ ЩҲ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§) ШЁШЁЫҢЩҶШҜ ЩҲ ЩҲЫҢШұШ§ЫҢШҙ Ъ©ЩҶШҜ.</translation>
<translation id="3941890832296813527">Ш®Ш·Ш§ЫҢ ЩҶШөШЁ: ЩҶШ§Щ… ЩҒШ§ЫҢЩ„ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ ЫҢШ§ Ш§ШІ ШўЩҶ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="3945058413678539331">вҖҸChromium Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ШұШ§ Ъ©ЩҫЫҢ Ъ©ЩҶШҜ. ШЁШұШ§ЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ Ш§ЫҢЩҶ Ъ©Ш§Шұ Ш§ЩҶШ¬Ш§Щ… ШҙЩҲШҜШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Windows Ш®ЩҲШҜ ШұШ§ ШӘШ§ЫҢЩҫ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="3954172517175569325">вҖҸЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ШҢ ШұЩҲШҙвҖҢЩҮШ§ЫҢ ЩҫШұШҜШ§Ш®ШӘШҢ ЩҲ ЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҮвҖҢШ§ЫҢШҜ Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШЁШұШҜШ§ШҙШӘЩҮ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ. ШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…Ш¬ШҜШҜ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШҜШұ ChromiumШҢ ШҜЩҲШЁШ§ШұЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="3962647064319009959">вҖҸШЁШЁЫҢЩҶЫҢШҜ Chromium ЪҶЪҜЩҲЩҶЩҮ Ш§ЫҢЩ…ЩҶЫҢ ШҙЩ…Ш§ ШұШ§ ШӯЩҒШё Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="3975724895399328945">вҖҸШҜШұШЁШ§ШұЩҮ Google Chrome for Testing</translation>
<translation id="3997429360543082038">вҖҸШҜШұШЁШ§ШұЩҮ ChromiumOS</translation>
<translation id="4019629340646866719">вҖҸШ§ШұШ§ШҰЩҮ ChromiumOS ШЁЩҮвҖҢЪ©Щ…Ъ© <ph name="BEGIN_LINK_CROS_OSS" />ЩҶШұЩ…вҖҢШ§ЩҒШІШ§ШұЩҮШ§ЫҢ Щ…ШӘЩҶвҖҢШЁШ§ШІ<ph name="END_LINK_CROS_OSS" /> ШӘЪ©Щ…ЫҢЩ„ЫҢ Щ…Ш«Щ„ <ph name="BEGIN_LINK_LINUX_OSS" />Щ…ШӯЫҢШ· ШӘЩҲШіШ№ЩҮ ЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ Linux<ph name="END_LINK_LINUX_OSS" /> Щ…Щ…Ъ©ЩҶ ШҙШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="4022972681110646219">ШӘШұШ¬Щ…ЩҮ Ъ©ШұШҜЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ</translation>
<translation id="4023601594785368013">ШІШЁШ§ЩҶ Ш§ШөЩ„ЫҢ: <ph name="LANGUAGE" /></translation>
<translation id="4036079820698952681">вҖҸШЁШ§ ЪҜШІШ§ШұШҙ <ph name="BEGIN_LINK" />ШӘЩҶШёЫҢЩ…Ш§ШӘ Ъ©ЩҶЩҲЩҶЫҢ<ph name="END_LINK" />ШҢ ШЁЩҮ ШЁЩҮШӘШұ ШҙШҜЩҶ Chromium Ъ©Щ…Ъ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="4050175100176540509">ШЁЩҮШЁЩҲШҜЩҮШ§ЫҢ Ш§Щ…ЩҶЫҢШӘЫҢ Щ…ЩҮЩ… ЩҲ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ЫҢ Ш¬ШҜЫҢШҜ ШҜШұ Ш¬ШҜЫҢШҜШӘШұЫҢЩҶ ЩҶШіШ®ЩҮ ШҜШұ ШҜШіШӘШұШі Ш§ШіШӘ.</translation>
<translation id="4055805654398742145">Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮ</translation>
<translation id="4095980151185649725">{COUNT,plural, =1{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ ЫҢЪ© ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ Щ…ЫҢвҖҢШЁЩҶШҜШҜ. ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШӯШ°ЩҒ Щ…ЫҢвҖҢШҙЩҲШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ.}one{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ # ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ Щ…ЫҢвҖҢШЁЩҶШҜШҜ. ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШӯШ°ЩҒ Щ…ЫҢвҖҢШҙЩҲШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ.}other{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ # ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ Щ…ЫҢвҖҢШЁЩҶШҜШҜ. ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШӯШ°ЩҒ Щ…ЫҢвҖҢШҙЩҲШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ.}}</translation>
<translation id="4118474109249235144">вҖҸШӯШ§Щ„ШӘ ЩҶШ§ШҙЩҶШ§Ші Chromium</translation>
<translation id="4122186850977583290">вҖҸШұЩҒШӘЩҶ ШЁЩҮ ШөЩҒШӯЩҮ В«ШҜШұШЁШ§ШұЩҮ ChromiumВ»</translation>
<translation id="4148957013307229264">ШҜШұ ШӯШ§Щ„ ЩҶШөШЁ...</translation>
<translation id="419998258129752635">вҖҸ<ph name="PAGE_TITLE" /> - ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… ШҙШЁЪ©ЩҮ - Chromium</translation>
<translation id="421369550622382712">вҖҸШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ШҢ ШЁШ§ШІЫҢвҖҢЩҮШ§ШҢ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ ЩҲ Ш·ШұШӯвҖҢЩҮШ§ЫҢ ШІЩ…ЫҢЩҶЩҮ Chromium ШұШ§ Ъ©ШҙЩҒ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4217972271355023382">вҖҸШЁШұШ§ЫҢ Ш§ЫҢЩ…ЩҶвҖҢШӘШұ Щ…Ш§ЩҶШҜЩҶ ШҜШұ ЩҒШ¶Ш§ЫҢ ШўЩҶЩ„Ш§ЫҢЩҶ ШЁШ§ Ъ©Щ…Ъ© Ш§ЩҶШӘШ®Ш§ШЁвҖҢЩҮШ§ЫҢ ЩҲЩ„ЫҢвҖҢШӘШ§ЩҶШҢ ШЁЩҮ ЩҮЩ…Ш§ЩҶ ЩҶЩ…Ш§ЫҢЩҮ Chromium ШЁШұЩҲЫҢШҜ Ъ©ЩҮ ЩӮШЁЩ„Ш§ЩӢ ШЁШ§ <ph name="USER_EMAIL_ADDRESS" /> ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮвҖҢШ§ЫҢШҜ</translation>
<translation id="4222932583846282852">ШҜШұШӯШ§Щ„ Щ„ШәЩҲ Ъ©ШұШҜЩҶвҖҰ</translation>
<translation id="4224210481850767180">ЩҶШөШЁ Щ„ШәЩҲ ШҙШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="4230135487732243613">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШЁЩҮ Ш§ЫҢЩҶ ШӯШіШ§ШЁ Щ…ШұШӘШЁШ· ШҙЩҲШҜШҹ</translation>
<translation id="4251772536351901305">вҖҸШЁШ§ ШӘШ¬ШІЫҢЩҮвҖҢЩҲШӘШӯЩ„ЫҢЩ„ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШЁЫҢШҙШӘШұЫҢ Ш§ШІ ШіШ§ЫҢШӘвҖҢЩҮШ§ ШҜШұ Щ…ЩӮШ§ЫҢШіЩҮ ШЁШ§ Щ…ШӯШ§ЩҒШёШӘ Ш§ШіШӘШ§ЩҶШҜШ§ШұШҜШҢ ШҜШұШЁШ§ШұЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢ Ш®Ш·ШұЩҶШ§Ъ© ШЁЩҮ ШҙЩ…Ш§ ЩҮШҙШҜШ§Шұ Щ…ЫҢвҖҢШҜЩҮШҜШҢ ШӯШӘЫҢ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ Google ЩӮШЁЩ„Ш§ЩӢ Ш§ШІ ШўЩҶвҖҢЩҮШ§ Ш§Ш·Щ„Ш§Ш№ЫҢ ЩҶШҜШ§ШҙШӘЩҮ Ш§ШіШӘ. Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҮШҙШҜШ§ШұЩҮШ§ЫҢ Chromium ШұШ§ ШұШҜ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4269093074552541569">вҖҸШ®ШұЩҲШ¬ Ш§ШІ ШіЫҢШіШӘЩ… Chromium</translation>
<translation id="4271805377592243930">вҖҸШҜШұЫҢШ§ЩҒШӘ Ъ©Щ…Ъ© ШЁШұШ§ЫҢ Chromium</translation>
<translation id="4281844954008187215">ШҙШұШ§ЫҢШ· Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШіШұЩҲЫҢШі</translation>
<translation id="4285930937574705105">вҖҸШЁЩҮ ШҜЩ„ЫҢЩ„ Ш®Ш·Ш§ЫҢ ЩҶШ§Щ…ШҙШ®Шө ЩҶШөШЁ ЩҶШ§Щ…ЩҲЩҒЩӮ ШЁЩҲШҜ. Ш§ЪҜШұ Chromium ШҜШұ ШӯШ§Щ„ Ш§Ш¬ШұШ§ Ш§ШіШӘШҢ Щ„Ш·ЩҒШ§ЩӢ ШўЩҶ ШұШ§ ШЁШЁЩҶШҜЫҢШҜ ЩҲ ШҜЩҲШЁШ§ШұЩҮ ШіШ№ЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4304713468139749426">Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮ</translation>
<translation id="4334294535648607276">ШЁШ§ШұЪҜЫҢШұЫҢ Ъ©Ш§Щ…Щ„ ШҙШҜ.</translation>
<translation id="439358628917130594">вҖҸ<ph name="MANAGER" /> Щ„Ш§ШІЩ… Щ…ЫҢвҖҢШҜШ§ЩҶШҜ Ъ©ЩҮ ШҙЩ…Ш§ В«ШҙШұШ§ЫҢШ· Ш®ШҜЩ…Ш§ШӘВ» ШІЫҢШұ ШұШ§ ЩӮШЁЩ„вҖҢШ§ШІ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШЁШ®ЩҲШ§ЩҶЫҢШҜ ЩҲ ШЁЩҫШ°ЫҢШұЫҢШҜ. Ш§ЫҢЩҶ ШҙШұШ§ЫҢШ· ШЁШіШ· ШҜШ§ШҜЩҮ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜШҢ Ш§ШөЩ„Ш§Шӯ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜШҢ ЩҲ ШҙШұШ§ЫҢШ· Chromium OS ШұШ§ Щ…ШӯШҜЩҲШҜ ЩҶЩ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="4407044323746248786">вҖҸШҜШұЩҮШұШөЩҲШұШӘ Ш§ШІ Chromium Ш®Ш§ШұШ¬ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҹ</translation>
<translation id="4413205837991854510">Щ…ЫҢШ§ЩҶвҖҢШЁШұ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ЩҮЩ…ЫҢШҙЩҮ ЩҶШҙШ§ЩҶ ШҜШ§ШҜЩҮ ШҙЩҲШҜ</translation>
<translation id="4415566066719264597">вҖҸШ§Ш¬Ш§ШІЩҮ ШЁЩҮ Chromium ШЁШұШ§ЫҢ Ш§Ш¬ШұШ§ ШҜШұ ЩҫШівҖҢШІЩ…ЫҢЩҶЩҮ</translation>
<translation id="4419831163359812184">{NUM_EXTENSIONS,plural, =1{вҖҸвҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢвҖҢШҙШҜЩҮ ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" />}one{вҖҸвҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢвҖҢШҙШҜЩҮ ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" />}other{вҖҸвҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢвҖҢШҙШҜЩҮ ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" />}}</translation>
<translation id="4423735387467980091">вҖҸШіЩҒШ§ШұШҙЫҢ Ъ©ШұШҜЩҶ ЩҲ Ъ©ЩҶШӘШұЩ„ Chromium</translation>
<translation id="4427306783828095590">В«Щ…ШӯШ§ЩҒШёШӘ ШЁЩҮШЁЩҲШҜЫҢШ§ЩҒШӘЩҮВ» Ъ©Ш§ШұЩҮШ§ЫҢ ШЁЫҢШҙШӘШұЫҢ ШЁШұШ§ЫҢ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜЩҶ ШұЩ…ШІЪҜЫҢШұЫҢ ЩҲ ШЁШҜШ§ЩҒШІШ§Шұ Ш§ЩҶШ¬Ш§Щ… Щ…ЫҢвҖҢШҜЩҮШҜ</translation>
<translation id="4434353761996769206">Ш®Ш·Ш§ЫҢ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ: <ph name="INSTALLER_ERROR" /></translation>
<translation id="4438870983368648614">вҖҸвҖ«<ph name="MANAGER" /> вҖҸChromium ШұШ§ Щ…ШҜЫҢШұЫҢШӘ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="444069871276811466">вҖҸШ§ЩҒШІЩҲШҜЩҶ ЩҶЩ…Ш§ЫҢЩҮ Chromium</translation>
<translation id="4447409407328223819">вҖҸШҜШұШЁШ§ШұЩҮ Chrome for Testing</translation>
<translation id="4470974262661801543">вҖҸШЁШұШ§ЫҢ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ ЩҲ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШўЩҶвҖҢЩҮШ§ШҢ ЪҜШ°ШұШ№ШЁШ§ШұШӘШӘШ§ЩҶ ШұШ§ ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ</translation>
<translation id="4493028449971051158">Ш®Ш·Ш§ЫҢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ: Щ„Ш·ЩҒШ§ЩӢ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ШұШ§ ШЁШ§ ЩҶЩӮШҙ ШіШұЩҫШұШіШӘ Ш§Ш¬ШұШ§ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4501471624619070934">ЩҶШөШЁ Ш§ЩҶШ¬Ш§Щ… ЩҶШҙШҜ ШІЫҢШұШ§ ШҜШіШӘШұШіЫҢ ШҜШұ Ш§ЫҢЩҶ Ъ©ШҙЩҲШұ Щ…ШӯШҜЩҲШҜ Ш§ШіШӘ.</translation>
<translation id="4510853178268397146">вҖҸШ§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШұЩҲШҙвҖҢЩҮШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢШҢ Щ…Ш«Щ„ ЩҶШӯЩҲЩҮ Ш¬Щ…Ш№вҖҢШўЩҲШұЫҢ ЩҲ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШұШ§ Щ…ЩҶШӘШҙШұ ЩҶЪ©ШұШҜЩҮ Ш§ШіШӘ. вҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="452711251841752011">вҖҸШЁЩҮ Chromium Ш®ЩҲШҙвҖҢШўЩ…ШҜЫҢШҜШӣ ЩҫЩҶШ¬ШұЩҮ Щ…ШұЩҲШұЪҜШұ Ш¬ШҜЫҢШҜ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ШҙШҜ</translation>
<translation id="4531137820806573936">вҖҸвҖ«Chromium ШЁШұШ§ЫҢ ЩҶЩӮШҙЩҮвҖҢШЁШұШҜШ§ШұЫҢ Ш§ШІ Щ…ШӯЫҢШ· Ш§Ш·ШұШ§ЩҒ ЩҲ ШұШҜЫҢШ§ШЁЫҢ ШҜШіШӘШ§ЩҶ ШҙЩ…Ш§ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="4534145890176164066">вҖҸвҖ«Chromium ЩҒШұЩ…вҖҢЩҮШ§ ШұШ§ ШЁЩҮШӘШұ ШҜШұЪ© Щ…ЫҢвҖҢЪ©ЩҶШҜ ЩҲ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁШ§ ШіШұШ№ШӘ ШЁЫҢШҙШӘШұЫҢ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШ§ЫҢШӘШ§ЩҶ ЩҫШұ Ъ©ЩҶШҜ</translation>
<translation id="4536805923587466102">вҖҸЩӮШЁЩ„Ш§ЩӢ ШЁШ§ <ph name="USER_EMAIL_ADDRESS" /> ШҜШұ ЩҶЩ…Ш§ЫҢЩҮ Chromium ШҜЫҢЪҜШұЫҢ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮвҖҢШ§ЫҢШҜ</translation>
<translation id="4545268686623374213">вҖҸвҖ«Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Ш§ЫҢЩҶ ШЁШұЪҜЩҮ ШұШ§ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ЩҶШҜ ШӘШ§ ШӘШ¬ШұШЁЩҮ Щ…ШұЩҲШұ ШҙЩ…Ш§ ШұШ§ ШЁЩҮШЁЩҲШҜ ШЁШ®ШҙШҜ ЩҲ ШіШұШ№ШӘ ШЁШ§Щ„Ш§ ШұШ§ ШӯЩҒШё Ъ©ЩҶШҜ.</translation>
<translation id="454579500955453258">вҖҸШҜШұ ЩҶЩ…Ш§ЫҢЩҮ Ш¬ШҜЫҢШҜ Chromium Ш§ШҜШ§Щ…ЩҮ Щ…ЫҢвҖҢШҜЩҮЫҢШҜШҹ</translation>
<translation id="4548534452171747496">вҖҸвҖ«Chromium ШөЩҒШӯЩҮвҖҢЩҮШ§ ШұШ§ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШӘШ§ Щ…ШұЩҲШұ ЩҲ Ш¬ШіШӘШ¬ЩҲ Ъ©ШұШҜЩҶ ШіШұЫҢШ№вҖҢШӘШұ ШҙЩҲШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ ШөЩҒШӯЩҮвҖҢЩҮШ§ ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" /></translation>
<translation id="4567424176335768812">ШЁШ§ ШӯШіШ§ШЁ <ph name="USER_EMAIL_ADDRESS" /> ЩҲШ§ШұШҜ ШіЫҢШіШӘЩ… ШҙШҜЩҮвҖҢШ§ЫҢШҜ. Ш§Ъ©ЩҶЩҲЩҶ ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ ШўЩҶЩҮШ§ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮвҖҢШ§ЫҢШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШЁЩҮ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШіШ§ШЁЩӮЩҮ ЩҲ ШҜЫҢЪҜШұ ШӘЩҶШёЫҢЩ…Ш§ШӘШӘШ§ЩҶ ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЫҢШҜ.</translation>
<translation id="4570813286784708942">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ В«Щ…ШұЩҲШұ Ш§ЫҢЩ…ЩҶВ» Ш®Ш§Щ…ЩҲШҙ Ш§ШіШӘ ЩҲ ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶ ЩҒШ§ЫҢЩ„ ШұШ§ ШӘШЈЫҢЫҢШҜ Ъ©ШұШҜ</translation>
<translation id="4594305310729380060">ШҜШұ В«Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮВ» ШҜШұ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ</translation>
<translation id="459535195905078186">вҖҸШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ Chromium</translation>
<translation id="4613863813562375431">вҖҸЩҶШіШ®ЩҮ ChromiumOS</translation>
<translation id="4617285639650863674">вҖҸШЁШұШ§ЫҢ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙШҢ В«Ш¶ШЁШ·вҖҢЪ©ЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ЩҲЫҢЪҳЩҮ ChromiumВ» ШұШ§ ШҜШұ В«Ш§ЩҲЩ„ЩҲЫҢШӘвҖҢЩҮШ§ЫҢ ШіЫҢШіШӘЩ…В» Щ…Ш¬Ш§ШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="4621240073146040695">вҖҸШӘЩӮШұЫҢШЁШ§ЩӢ ШЁЩҮвҖҢШұЩҲШІ ШҙШҜЩҮ Ш§ШіШӘ! ШЁШұШ§ЫҢ ШӘЩ…Ш§Щ… Ъ©ШұШҜЩҶ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4665829708273112819">вҖҸЩҮШҙШҜШ§Шұ: Chromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…Ш§ЩҶШ№ Ш§ШІ Ш«ШЁШӘ ШіШ§ШЁЩӮЩҮ Щ…ШұЩҲШұШӘШ§ЩҶ ШӘЩҲШіШ· Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ ШҙЩҲШҜ. ШЁШұШ§ЫҢ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ШұШҜЩҶ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШҜШұ В«ШӯШ§Щ„ШӘ ЩҶШ§ШҙЩҶШ§ШіВ»ШҢ Ш§ЫҢЩҶ ЪҜШІЫҢЩҶЩҮ ШұШ§ Щ„ШәЩҲ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4673151026126227699">вҖҸШ§ЪҜШұ ЪҜШІШ§ШұШҙвҖҢЩҮШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium ШұШ§ ЩҶЫҢШІ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ Ъ©ЩҶЫҢШҜШҢ Ш§ЫҢЩҶ ЪҜШІШ§ШұШҙвҖҢЩҮШ§ ЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ЩҲШЁЫҢ ШұШ§ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШҜШұШЁШұЩ…ЫҢвҖҢЪҜЫҢШұШҜ</translation>
<translation id="4677944499843243528">вҖҸШёШ§ЩҮШұШ§ЩӢ ЩҶЩ…Ш§ЫҢЩҮ ШӘЩҲШіШ· ЩҒШұШўЫҢЩҶШҜ Chromium ШҜЫҢЪҜШұЫҢ (<ph name="PROCESS_ID" />) ШҜШұ ШұШ§ЫҢШ§ЩҶЩҮвҖҢШ§ЫҢ ШҜЫҢЪҜШұ (<ph name="HOST_NAME" />) ШҜШұ ШӯШ§Щ„ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШіШӘ. Chromium ЩҶЩ…Ш§ЫҢЩҮ ШұШ§ ЩӮЩҒЩ„ Ъ©ШұШҜЩҮ Ш§ШіШӘ ШӘШ§ Ш®ШұШ§ШЁ ЩҶШҙЩҲШҜ. Ш§ЪҜШұ Щ…Ш·Щ…ШҰЩҶЫҢШҜ ЩҒШұШўЫҢЩҶШҜЩҮШ§ЫҢ ШҜЫҢЪҜШұЫҢ Ш§ШІ Ш§ЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮ Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶЩ…ЫҢвҖҢЪ©ЩҶЩҶШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩӮЩҒЩ„ ЩҶЩ…Ш§ЫҢЩҮ ШұШ§ ШЁШ§ШІ Ъ©ЩҶЫҢШҜ ЩҲ Chromium ШұШ§ Щ…Ш¬ШҜШҜШ§ЩӢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ЩҶЩ…Ш§ЫҢЫҢШҜ.</translation>
<translation id="4680828127924988555">Щ„ШәЩҲ ЩҶШөШЁ</translation>
<translation id="469259825538636168">вҖҸШЁШұШ®ЫҢвҖҢШ§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ЩҮЩҶЩҲШІ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» ШҙЩ…Ш§ Ш°Ш®ЫҢШұЩҮ ЩҶШҙШҜЩҮ Ш§ШіШӘ. ЩҫЫҢШҙвҖҢШ§ШІ Ш®ШұЩҲШ¬ Ш§ШІ ШіЫҢШіШӘЩ…ШҢ ЪҶЩҶШҜ ШҜЩӮЫҢЩӮЩҮ ШөШЁШұ Ъ©ЩҶЫҢШҜ. Ш§ЪҜШұ Ш§Ъ©ЩҶЩҲЩҶ Ш§ШІ ШіЫҢШіШӘЩ… Ш®Ш§ШұШ¬ ШҙЩҲЫҢШҜШҢ Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШӯШ°ЩҒ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ.</translation>
<translation id="4708193446201257833">вҖҸШ§Ъ©ЩҶЩҲЩҶ Ъ©ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮвҖҢШ§ЫҢШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ШІ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ ШҜШұ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ. вҖ«<ph name="SHORTCUT" /> Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ Google ШұШ§ ШӘШәЫҢЫҢШұ ШҜЩҮШҜ.</translation>
<translation id="4708774505295300557">вҖҸШҙШ®ШөЫҢ ЩӮШЁЩ„Ш§ЩӢ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ <ph name="ACCOUNT_EMAIL_LAST" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ШҜШұ Ш§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ ЩҲШ§ШұШҜ ШҙШҜЩҮ Ш§ШіШӘ. ШЁШұШ§ЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§Ш·Щ„Ш§Ш№Ш§ШӘШӘШ§ЩҶ Ш¬ШҜШ§ ШӯЩҒШё ШҙЩҲШҜШҢ Щ„Ш·ЩҒШ§ЩӢ Ъ©Ш§ШұШЁШұ Chrome Ш¬ШҜЫҢШҜЫҢ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="4724676981607797757">ЩҶШөШЁ ШЁЩҮвҖҢШҜЩ„ЫҢЩ„ Ш®Ш·Ш§ЫҢ ЩҫШұЩҲШӘЪ©Щ„ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢвҖҢЩҶШҙШҜЩҮ Ш§ЩҶШ¬Ш§Щ… ЩҶШҙШҜ.</translation>
<translation id="4746050847053251315">вҖҸШҜШұЩҮШұШөЩҲШұШӘ Ш§ШІ Chromium Ш®Ш§ШұШ¬ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҹ</translation>
<translation id="4748217263233248895">вҖҸЩ„ШӯШёШ§ШӘЫҢ ЩҫЫҢШҙ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш§Щ…ЩҶЫҢШӘЫҢ ЩҲЫҢЪҳЩҮвҖҢШ§ЫҢ ШЁШұШ§ЫҢ Chromium Ш§Ш№Щ…Ш§Щ„ ШҙШҜ. ЩҮЩ…вҖҢШ§Ъ©ЩҶЩҲЩҶ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ъ©ЩҶЫҢШҜ ЩҲ Щ…Ш§ ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШ§ШІЫҢШ§ШЁЫҢ Ш®ЩҲШ§ЩҮЫҢЩ… Ъ©ШұШҜ.</translation>
<translation id="4788777615168560705">вҖҸChromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ. ШЁШ№ШҜ Ш§ШІ ЫІЫҙ ШіШ§Ш№ШӘ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ ЫҢШ§ <ph name="BEGIN_LINK" />ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ШұШ§ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ<ph name="END_LINK" />.</translation>
<translation id="479167709087336770">вҖҸШ§ШІ ЩҮЩ…Ш§ЩҶ ШәЩ„Ш·вҖҢЫҢШ§ШЁ Ш§Щ…Щ„Ш§ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ Ъ©ЩҮ ШҜШұ Ш¬ШіШӘШ¬ЩҲЫҢ Google Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ. ЩҶЩҲШҙШӘШ§ШұЫҢ Ъ©ЩҮ ШҜШұ Щ…ШұЩҲШұЪҜШұ ШӘШ§ЫҢЩҫ Ъ©ШұШҜЩҮвҖҢШ§ЫҢШҜ ШЁШұШ§ЫҢ Google Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢШҙЩҲШҜ. ЩҮШұЩҲЩӮШӘ ШЁШ®ЩҲШ§ЩҮЫҢШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ЫҢЩҶ ШұЩҒШӘШ§Шұ ШұШ§ ШҜШұ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШӘШәЫҢЫҢШұ ШҜЩҮЫҢШҜ.</translation>
<translation id="4814736265800133385">вҖҸШ§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium ШЁШҜЩҲЩҶ ШӯШіШ§ШЁ</translation>
<translation id="4888717733111232871">вҖҸЩӮШ§ЩҶЩҲЩҶ ШӘШұШ§ЩҒЫҢЪ© ЩҲШұЩҲШҜЫҢ ШЁШұШ§ЫҢ Chromium Ш¬ЩҮШӘ Ш§Ш¬Ш§ШІЩҮ ШЁЩҮ ШӘШұШ§ЩҒЫҢЪ© mDNS.</translation>
<translation id="4893347770495441059">вҖҸШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ ШЁШұШ§ЫҢ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium</translation>
<translation id="4918844574251943176">ШӘШөЩҲЫҢШұ Ъ©ЩҫЫҢ ШҙШҜ</translation>
<translation id="4942295735032723435">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ШЁШ№ШҜЫҢ ChromiumШҢ ШЁШ§ЫҢШҜ macOS ЩҶШіШ®ЩҮ ЫұЫұ ЫҢШ§ ШЁШ§Щ„Ш§ШӘШұ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЫҢШҜ. Ш§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ Ш§ШІ macOS ЩҶШіШ®ЩҮ ЫұЫ°.ЫұЫө Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="4943838377383847465">вҖҸChromium ШҜШұ ШӯШ§Щ„ШӘ ЩҫШівҖҢШІЩ…ЫҢЩҶЩҮ Ш§ШіШӘ.</translation>
<translation id="494490797786467921">вҖҸШЁШұШ§ЫҢ ШЁШіШӘЩҶ Ъ©Ш§ШҜШұ ЪҜЩҒШӘЪҜЩҲЫҢ ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… ChromiumШҢ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="4987820182225656817">вҖҸЩ…ЩҮЩ…Ш§ЩҶвҖҢЩҮШ§ Щ…ЫҢ ШӘЩҲШ§ЩҶЩҶШҜ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЩҶШҜ ШЁШҜЩҲЩҶ Ш§ЫҢЩҶвҖҢЪ©ЩҮ Ш§Ш«ШұЫҢ Ш§ШІ Ш®ЩҲШҜ ШЁЩҮ Ш¬Ш§ ШЁЪҜШ°Ш§ШұЩҶШҜ.</translation>
<translation id="4994636714258228724">вҖҸШ§ЩҒШұЩҲШҜЩҶ Ш®ЩҲШҜШӘШ§ЩҶ ШЁЩҮ Chromium</translation>
<translation id="5123973130450702873">вҖҸвҖ«Chromium ШЁШұШ§ЫҢ ШұШҜЫҢШ§ШЁЫҢ Ъ©ШұШҜЩҶ ШҜШіШӘвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="5174969993834422967">Щ…Ш№Щ…ЩҲЩ„Ш§ЩӢ Ш§Ш№Щ„Ш§ЩҶвҖҢЩҮШ§ ШұШ§ Щ…ШіШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ. ШЁШұШ§ЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ Ш§Ш№Щ„Ш§ЩҶ Ш§ШұШіШ§Щ„ Ъ©ЩҶШҜШҢ ШұЩҲЫҢ ЩҶЩ…Ш§ШҜ Ш§Ш№Щ„Ш§ЩҶ ШҜШұ ЪҜЩҲШҙЩҮ ЪҶЩҫ ЩҶЩҲШ§Шұ ЩҶШҙШ§ЩҶЫҢ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ.</translation>
<translation id="5187123684706427865">вҖҸШӯШіШ§ШЁ Chromium ШЁЩҮ Ш§ШөШ§Щ„ШӘвҖҢШіЩҶШ¬ЫҢ Щ…Ш¬ШҜШҜ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="5203572811198011329">вҖҸШЁШұШ§ЫҢ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШҜШұ В«ШӯШіШ§ШЁ GoogleвҖҸВ» Ш®ЩҲШҜ (<ph name="ACCOUNT_EMAIL" />) ЩҲ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ШұШҜЩҶ Ш§ШІ ШўЩҶвҖҢЩҮШ§ШҢ ЪҜШ°ШұШ№ШЁШ§ШұШӘШӘШ§ЩҶ ШұШ§ ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ</translation>
<translation id="5224391634244552924">вҖҸЪҜШ°ШұЩҲШ§ЪҳЩҮ Ш°Ш®ЫҢШұЩҮвҖҢШҙШҜЩҮвҖҢШ§ЫҢ ЩҲШ¬ЩҲШҜ ЩҶШҜШ§ШұШҜ. Chromium ШІЩ…Ш§ЩҶЫҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ Ъ©ЩҮ ШўЩҶвҖҢЩҮШ§ ШұШ§ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҮ ШЁШ§ШҙЫҢШҜ.</translation>
<translation id="5231355151045086930">вҖҸШ®ШұЩҲШ¬ Ш§ШІ ШіЫҢШіШӘЩ… Chromium</translation>
<translation id="5234764350956374838">ШұШҜ Ъ©ШұШҜЩҶ</translation>
<translation id="5252179775517634216">вҖҸ<ph name="EXISTING_USER" /> ЩӮШЁЩ„Ш§ЩӢ ШЁЩҮ ШіЫҢШіШӘЩ… Ш§ЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮ Chromium ЩҲШ§ШұШҜ ШҙШҜЩҮ Ш§ШіШӘ. ШЁШ§ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЩҶЩ…Ш§ЫҢЩҮ Chromium Ш¬ШҜЫҢШҜЫҢ ШЁШұШ§ЫҢ <ph name="USER_EMAIL_ADDRESS" /> Ш§ЫҢШ¬Ш§ШҜ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ</translation>
<translation id="5277894862589591112">вҖҸШЁШұШ§ЫҢ Ш§Ш№Щ…Ш§Щ„ ШӘШәЫҢЫҢШұШ§ШӘШӘШ§ЩҶШҢ Chromium ШұШ§ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ</translation>
<translation id="5286907366254680517">ШӘШҙШ®ЫҢШө ШҜШ§ШҜЩҮ ШҙШҜ</translation>
<translation id="5294316920224716406">вҖҸЩҮЩҶЪҜШ§Щ… Щ…ШұЩҲШұ В«ШҜШұШӯШ§Щ„ШӘ ЩҶШ§ШҙЩҶШ§ШіВ»ШҢ Chromium ЩӮШЁЩ„вҖҢШ§ШІ Ш§ЫҢЩҶЪ©ЩҮ ШіШ§ЫҢШӘ ШұШ§ Ш§ШІШ·ШұЫҢЩӮ Ш§ШӘШөШ§Щ„ ЩҶШ§Ш§Щ…ЩҶ ШЁШ§Шұ Ъ©ЩҶШҜ ШЁЩҮ ШҙЩ…Ш§ ЩҮШҙШҜШ§Шұ Щ…ЫҢвҖҢШҜЩҮШҜ</translation>
<translation id="5296845517486664001">вҖҸШ§ЪҜШұ ЩҶШіШ®ЩҮ ШўШІЩ…Ш§ЫҢШҙЫҢ ШұЩҲШҙЩҶ ШЁШ§ШҙШҜ ЩҲ Chromium ШЁЩҮвҖҢШ·ЩҲШұ ШӘШөШ§ШҜЩҒЫҢ ЩҶШіШ®ЩҮ ШўШІЩ…Ш§ЫҢШҙЫҢ ШұШ§ ШЁШұШ§ЫҢШӘШ§ЩҶ ЩҒШ№Ш§Щ„ Ъ©ШұШҜЩҮ ШЁШ§ШҙШҜШҢ ШіШ§ШЁЩӮЩҮ Щ…ШұЩҲШұШӘШ§ЩҶ ШЁШұ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ Щ…ЫҢвҖҢШЁЫҢЩҶЫҢШҜ ЩҲ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ Ъ©ЩҮ ШҜШұ ШІЫҢШұ ШЁШұШўЩҲШұШҜ ШҙШҜЩҮ Ш§ШіШӘ ШӘШЈШ«ЫҢШұ Щ…ЫҢвҖҢЪҜШ°Ш§ШұШҜ. ШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢ ШҙЩ…Ш§ШҢ Chromium Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ ШұШ§ ЩҮШұ Щ…Ш§ЩҮ ШЁЩҮвҖҢШ·ЩҲШұ ЪҶШұШ®ШҙЫҢ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="5310474266708705970">вҖҸЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ШЁШ§ <ph name="USER_EMAIL" /></translation>
