<translation id="5386450000063123300">вҖҸШҜШұШӯШ§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="538767207339317086">вҖҸЩ…Ш¬Ш§ШІ Ъ©ШұШҜЩҶ ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium</translation>
<translation id="5405650547142096840">вҖҸШӯШ°ЩҒ Ш§ШІ Chromium</translation>
