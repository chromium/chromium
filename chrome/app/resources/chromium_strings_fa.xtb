<translation id="5438241569118040789"><ph name="PAGE_TITLE" /> - Chromium Beta</translation>
<translation id="5473971139929175403">вҖҸChromium Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШҜШұШіШӘ Ъ©Ш§Шұ ЩҶЪ©ЩҶШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ШӘЩҲШІЫҢШ№ Linux ШҜЫҢЪҜШұ Ш§ШІ ШўЩҶ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="5475924890392386523">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҒШ§ЫҢЩ„ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁЩҮ ШӯШіШ§ШЁвҖҢЩҮШ§ЫҢ ШҙШ®ШөЫҢ ЩҲ ШҙШЁЪ©ЩҮвҖҢЩҮШ§ЫҢ Ш§Ш¬ШӘЩ…Ш§Ш№ЫҢ ШҙЩ…Ш§ ШўШіЫҢШЁ ШЁШұШіШ§ЩҶШҜ</translation>
<translation id="5480860683791598150">вҖҸChromium ШЁШұШ§ЫҢ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ Щ…Ъ©Ш§ЩҶШӘШ§ЩҶ ШЁШ§ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁШ§ЫҢШҜ ШЁЩҮ Щ…Ъ©Ш§ЩҶ ШҙЩ…Ш§ ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜ</translation>
<translation id="5487574057737591516">вҖҸШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢ ШҙЩ…Ш§ШҢ Ш№Щ„Ш§ЫҢЩӮЫҢ ШұШ§ Ъ©ЩҮ ЩӮШҜЫҢЩ…ЫҢвҖҢШӘШұ Ш§ШІ Ыҙ ЩҮЩҒШӘЩҮ ШЁШ§ШҙЩҶШҜ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶЫҢЩ…. ЩҲЩӮШӘЫҢ ШЁЩҮ Щ…ШұЩҲШұ Ъ©ШұШҜЩҶ Ш§ШҜШ§Щ…ЩҮ Щ…ЫҢвҖҢШҜЩҮЫҢШҜШҢ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш№Щ„Ш§ЩӮЩҮвҖҢШ§ЫҢ Щ…Ш¬ШҜШҜШ§ЩӢ ШЁЩҮ ЩҒЩҮШұШіШӘ Ш§Ш¶Ш§ЩҒЩҮ ШҙЩҲШҜ. ЩҲ Ш§ЪҜШұ Chromium ШЁЩҮвҖҢШ§ШҙШӘШЁШ§ЩҮ Ш№Щ„Ш§ЩӮЩҮвҖҢШ§ЫҢ ШұШ§ Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶШҜ ЫҢШ§ ШҙЩ…Ш§ ЩҶШ®ЩҲШ§ЩҮЫҢШҜ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢ Щ…ШҙШ®ШөЫҢ ШұШ§ ШЁШЁЫҢЩҶЫҢШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШўЩҶ Ш№Щ„Ш§ЩӮЩҮ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ.</translation>
<translation id="549669000822060376">вҖҸЩҲЩӮШӘЫҢ Chromium Ш¬ШҜЫҢШҜШӘШұЫҢЩҶ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ШіЫҢШіШӘЩ… ШұШ§ ЩҶШөШЁ Щ…ЫҢвҖҢЪ©ЩҶШҜШҢ Щ„Ш·ЩҒШ§ЩӢ ШөШЁШұ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="5496810170689441661">вҖҸChromium Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ШұШ§ ЩҲЫҢШұШ§ЫҢШҙ Ъ©ЩҶШҜ. ШЁШұШ§ЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ Ш§ЫҢЩҶ Ъ©Ш§Шұ Ш§ЩҶШ¬Ш§Щ… ШҙЩҲШҜШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Windows Ш®ЩҲШҜ ШұШ§ ШӘШ§ЫҢЩҫ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="5527463683072221100">вҖҸШЁШ§ШІ Ъ©ШұШҜЩҶ ЩҒШ§ЫҢЩ„вҖҢЩҮШ§ЫҢ PDF ШҜШұ Chromium</translation>
<translation id="5568136785038042132">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ ШҜШұ ЩҮЩ…ЩҮ ШұШ§ЫҢШ§ЩҶЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="5579324208890605088">Ш®Ш·Ш§ЫҢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ: Щ„Ш·ЩҒШ§ЩӢ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ШұШ§ ШЁШ§ ЩҶЩӮШҙ Ъ©Ш§ШұШЁШұ Щ…Ш№Щ…ЩҲЩ„ЫҢ Ш§Ш¬ШұШ§ Ъ©ЩҶЫҢШҜШҢ ЩҶЩҮ ШЁШ§ ЩҶЩӮШҙ ШіШұЩҫШұШіШӘ.</translation>
<translation id="5596627076506792578">ЪҜШІЫҢЩҶЩҮвҖҢЩҮШ§ЫҢ ШЁЫҢШҙШӘШұ</translation>
<translation id="5605834417512968703">ЩҮШұЪҶЫҢШІЫҢ ШұШ§ Ъ©ЩҮ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ ШЁШұШ§ЫҢ Ш¬ШіШӘШ¬ЩҲ Ъ©ШұШҜЩҶ ШЁШ§ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ ЫҢШ§ ШЁШұШ§ЫҢ Ш®Ш§ШұШ¬ ШҙШҜЩҶ Ш§ШІ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ»ШҢ Ъ©Щ„ЫҢШҜ В«ЪҜШұЫҢШІВ» ШұШ§ ЩҒШҙШ§Шұ ШҜЩҮЫҢШҜ</translation>
<translation id="5623402015214259806">{0,plural, =0{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium ШҜШұШҜШіШӘШұШі Ш§ШіШӘ}=1{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium ШҜШұШҜШіШӘШұШі Ш§ШіШӘ}one{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium Ш§ШІ # ШұЩҲШІ ЩҫЫҢШҙ ШҜШұШҜШіШӘШұШі Ш§ШіШӘ}other{вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium Ш§ШІ # ШұЩҲШІ ЩҫЫҢШҙ ШҜШұШҜШіШӘШұШі Ш§ШіШӘ}}</translation>
<translation id="5643865575100044307">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШіШ§ЫҢШӘ ЩҮЩ…ЩҲШ§ШұЩҮ ШЁШ№ШҜШ§ШІ ШЁШіШӘЩҶ Chromium Ш§ШІ ШҜШіШӘЪҜШ§ЩҮ ШӯШ°ЩҒ ШҙЩҲШҜ</translation>
<translation id="5653831366781983928">вҖҸЩ„Ш·ЩҒШ§ЩӢ Ш§Ъ©ЩҶЩҲЩҶ Chromium ШұШ§ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ъ©ЩҶЫҢШҜ</translation>
<translation id="5690427481109656848">Google LLC</translation>
<translation id="5698481217667032250">вҖҸЩҶЩ…Ш§ЫҢШҙ Chromium ШЁЩҮ Ш§ЫҢЩҶ ШІШЁШ§ЩҶ</translation>
<translation id="569897634095159764">Ш§ШӘШөШ§Щ„ ШЁЩҮ Ш§ЫҢЩҶШӘШұЩҶШӘ ШЁШұЩӮШұШ§Шұ ЩҶШҙШҜ. ШіШұЩҲШұ ЩҫШұЩҲЪ©ШіЫҢ ШЁЩҮ Ш§ШөШ§Щ„ШӘвҖҢШіЩҶШ¬ЫҢ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ.</translation>
<translation id="5761096224651992291">вҖҸШ§Ш®ЫҢШұШ§ЩӢ ШЁШ§ШІШҜЫҢШҜЫҢ ЩҶШҜШ§ШҙШӘЩҮвҖҢШ§ЫҢШҜ. вҖ«Chromium вҖҸ<ph name="PERMISSION_1" />ШҢвҖҸ <ph name="PERMISSION_2" />ШҢвҖҸ ЩҲ <ph name="PERMISSION_3" /> ШұШ§ ШЁШұШҜШ§ШҙШӘ</translation>
<translation id="5768371961535086509">вҖҸвҖ«Chromium ШӯШ§ЩҒШёЩҮ ШұШ§ Ш§ШІ ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢ ШәЫҢШұЩҒШ№Ш§Щ„ ШўШІШ§ШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШ§ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ Щ…ЩҶШ§ШЁШ№ ШЁЫҢШҙШӘШұЫҢ ШҜШұ ШұШ§ЫҢШ§ЩҶЩҮ ШЁЩҮ ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢ ЩҒШ№Ш§Щ„ ЩҲ ШіШ§ЫҢШұ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ Ш§Ш®ШӘШөШ§Шө ШҜШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ ЩҲ ШіШұШ№ШӘ ШЁШ§Щ„Ш§ЫҢ Chromium ШӯЩҒШё Щ…ЫҢвҖҢШҙЩҲШҜ. ЩҮШұШІЩ…Ш§ЩҶ ШЁЩҮ ШЁШұЪҜЩҮвҖҢЩҮШ§ЫҢ ШәЫҢШұЩҒШ№Ш§Щ„ ШЁШұЪҜШұШҜЫҢШҜШҢ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШҜЩҲШЁШ§ШұЩҮ ЩҒШ№Ш§Щ„ Щ…ЫҢвҖҢШҙЩҲЩҶШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ В«ШЁЩҮЫҢЩҶЩҮвҖҢШіШ§ШІЫҢ ШӯШ§ЩҒШёЩҮВ» ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" /></translation>
<translation id="5800158606660203929">вҖҸвҖ«Chromium ШұШ§ ШіЩҒШ§ШұШҙЫҢвҖҢШіШ§ШІЫҢ ЩҲ Ъ©ЩҶШӘШұЩ„ Ъ©ЩҶЫҢШҜ. вҖ«Chromium ШұШ§ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШӘЩҶШёЫҢЩ… Ъ©ЩҶЫҢШҜ.</translation>
<translation id="5809516625706423866">вҖҸШ§ШӘШөШ§Щ„ ШЁЩҮ Ш§ЫҢЩҶШӘШұЩҶШӘ ШЁШұЩӮШұШ§Шұ ЩҶШҙШҜ. HTTP ЫҙЫ°Ыұ Щ…Ш¬Ш§ШІ ЩҶЫҢШіШӘ. Щ„Ш·ЩҒШ§ЩӢ ЩҫЫҢЪ©ШұШЁЩҶШҜЫҢ ЩҫШұЩҲЪ©ШіЫҢвҖҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="5821520528363214608">вҖҸШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҲ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜШҢ Chromium ШұШ§ ШЁЩҮвҖҢШұЩҲШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="5862307444128926510">вҖҸШЁЩҮ Chromium Ш®ЩҲШҙ ШўЩ…ШҜЫҢШҜ</translation>
<translation id="5871205389137001634">ШЁШұШ§ЫҢ Ш®Ш§ШұШ¬ ШҙШҜЩҶ Ш§ШІ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ»ШҢ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="5883558403894052917">вҖҸChromium Щ…ШӘЩҲШ¬ЩҮ ШҙШҜЩҮ Ш§ШіШӘ Ъ©ЩҮ Ш§ЫҢЩҶ Щ…ЩҲШ§ШұШҜ ШӯШ§ЩҲЫҢ ШЁШҜШ§ЩҒШІШ§Шұ ЩҮШіШӘЩҶШҜ:</translation>
<translation id="5889361821821684993">вҖҸChromium ШЁЩҮвҖҢШ·ЩҲШұ Щ…ЩҶШёЩ… ШЁШұШұШіЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШӘШ§ Щ…Ш·Щ…ШҰЩҶ ШҙЩҲШҜ Щ…ШұЩҲШұЪҜШұШӘШ§ЩҶ Ш§ЫҢЩ…ЩҶвҖҢШӘШұЫҢЩҶ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШұШ§ ШҜШ§ШұШҜ. Ш§ЪҜШұ Щ…ЩҲШұШҜЫҢ ШЁЩҮ ШЁШ§ШІШЁЫҢЩҶЫҢ ШҙЩ…Ш§ ЩҶЫҢШ§ШІ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜШҢ ШЁЩҮ ШҙЩ…Ш§ Ш§Ш·Щ„Ш§Ш№ Ш®ЩҲШ§ЩҮЫҢЩ… ШҜШ§ШҜ.</translation>
<translation id="5895138241574237353">ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE" /> - ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… ШҙШЁЪ©ЩҮ</translation>
<translation id="5924017743176219022">ШҜШұШӯШ§Щ„ Ш§ШӘШөШ§Щ„ ШЁЩҮ Ш§ЫҢЩҶШӘШұЩҶШӘвҖҰ</translation>
<translation id="5929318705173562984">вҖҸвҖ«Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Ш§ЫҢЩҶ ШЁШұЪҜЩҮ ШұШ§ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ЩҶШҜ ШӘШ§ ШӘШ¬ШұШЁЩҮ Щ…ШұЩҲШұ ШҙЩ…Ш§ ШұШ§ ШЁЩҮШЁЩҲШҜ ШЁШ®ШҙШҜ ЩҲ Щ…ЩҶШ§ШЁШ№ ШұШ§ ШўШІШ§ШҜ Ъ©ЩҶШҜ.</translation>
<translation id="5941711191222866238">Ъ©ЩҲЪҶЪ© Ъ©ШұШҜЩҶ</translation>
<translation id="5972142260211327093">вҖҸШ§ЪҜШұ Chromium ШЁЩҮвҖҢШ·ЩҲШұ ШӘШөШ§ШҜЩҒЫҢ ЩҶШіШ®ЩҮ ШўШІЩ…Ш§ЫҢШҙЫҢ ШұШ§ ШЁШұШ§ЫҢШӘШ§ЩҶ ЩҒШ№Ш§Щ„ Ъ©ШұШҜЩҮ ШЁШ§ШҙШҜШҢ ШіШ§ШЁЩӮЩҮ Щ…ШұЩҲШұШӘШ§ЩҶ ШЁШұ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ Щ…ЫҢвҖҢШЁЫҢЩҶЫҢШҜ ЩҲ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ Ъ©ЩҮ ШҜШұ ШІЫҢШұ ШЁШұШўЩҲШұШҜ ШҙШҜЩҮ Ш§ШіШӘ ШӘШЈШ«ЫҢШұ Щ…ЫҢвҖҢЪҜШ°Ш§ШұШҜ. ШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШӯШұЫҢЩ… Ш®ШөЩҲШөЫҢ ШҙЩ…Ш§ШҢ Chromium Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ ШұШ§ ЩҮШұ Щ…Ш§ЩҮ ШЁЩҮвҖҢШ·ЩҲШұ ЪҶШұШ®ШҙЫҢ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш№Щ„Ш§ЫҢЩӮ ШЁШ§ШІШўЩҲШұЫҢ ШҙЩҲШҜШҢ Щ…ЪҜШұ Ш§ЫҢЩҶЪ©ЩҮ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ.</translation>
<translation id="5986585015444752010">{COUNT,plural, =1{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ ЫҢЪ© ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ Щ…ЫҢвҖҢШЁЩҶШҜШҜ.}one{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ # ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ Щ…ЫҢвҖҢШЁЩҶШҜШҜ.}other{вҖҸШ§ЪҜШұ ШЁЩҮвҖҢЩ…ШҜШӘ # ШҜЩӮЫҢЩӮЩҮ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ Щ…ЫҢвҖҢШЁЩҶШҜШҜ.}}</translation>
<translation id="5987687638152509985">вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium ШЁШұШ§ЫҢ ШҙШұЩҲШ№ ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ</translation>
<translation id="5988505247484123880">вҖҸШ§Щ…ШұЫҢ Ш№Ш§ШҜЫҢ Ш§ШіШӘ Ъ©ЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШЁШұШ§ЫҢ ШҙШ®ШөЫҢ Ъ©ШұШҜЩҶ ШӘШ¬ШұШЁЩҮвҖҢШӘШ§ЩҶШҢ Ш№Щ„Ш§ЫҢЩӮ ШҙЩ…Ш§ ШұШ§ ШЁЩҮвҖҢШ®Ш§Ш·Шұ ШўЩҲШұЩҶШҜ. ШЁЩҮвҖҢШ№Щ„Ш§ЩҲЩҮШҢ ШіШ§ЫҢШӘвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ ШЁШ§Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium Ш§Ш·Щ„Ш§Ш№Ш§ШӘЫҢ ШҜШұШЁШ§ШұЩҮ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ Ш°Ш®ЫҢШұЩҮ Ъ©ЩҶЩҶШҜ.</translation>
<translation id="6003112304606738118">ШҜШұШӯШ§Щ„ ШЁШ§ШұЪҜЫҢШұЫҢвҖҰ <ph name="HOURS" /> ШіШ§Ш№ШӘ ШЁШ§ЩӮЫҢ Щ…Ш§ЩҶШҜЩҮ Ш§ШіШӘ</translation>
<translation id="6019451407441383358">вҖҸЩ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШӯШ§Щ„ШӘ Щ…Ш·Ш§Щ„Ш№ЩҮШҢ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ ШұШ§ Ш§ШІ Щ…ЩҶЩҲЩҗ Chromium ШҜШұ ШЁШ§Щ„Ш§ ШіЩ…ШӘ ЪҶЩҫ ШЁШ§ШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="6040143037577758943">ШЁШіШӘЩҶ</translation>
<translation id="6058380562449900225">вҖҸШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ Chromium Ш§Ш¬Ш§ШІЩҮ ШҜШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ Ш§Ш¬Ш§ШІЩҮвҖҢЩҮШ§ЫҢ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ ШұШ§ Ъ©ЩҮ Ш§Ш®ЫҢШұШ§ЩӢ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШЁШ§ШІШҜЫҢШҜ ЩҶЪ©ШұШҜЩҮвҖҢШ§ЫҢШҜ ШӯШ°ЩҒ Ъ©ЩҶШҜ. Ш§Ш№Щ„Ш§ЩҶвҖҢЩҮШ§ Щ…ШӘЩҲЩӮЩҒ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="6063093106622310249">вҖҸ&amp;ШЁШ§ШІ Ъ©ШұШҜЩҶ ШҜШұ Chromium</translation>
<translation id="6069027071882229820">Ъ©ЩҫЫҢ Ъ©ШұШҜЩҶ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ШӘШөЩҲЫҢШұ</translation>
<translation id="6072279588547424923">вҖҸ<ph name="EXTENSION_NAME" /> ШЁЩҮ Chromium Ш§Ш¶Ш§ЩҒЩҮ ШҙШҜ</translation>
<translation id="6072463441809498330">вҖҸШіШұШ№ШӘ Chromium ШұШ§ Ш§ЩҒШІШ§ЫҢШҙ ШҜЩҮЫҢШҜ</translation>
<translation id="608006075545470555">Ш§ЩҒШІЩҲШҜЩҶ ЩҶЩ…Ш§ЫҢЩҮ Ъ©Ш§ШұЫҢ ШЁЩҮ Ш§ЫҢЩҶ Щ…ШұЩҲШұЪҜШұ</translation>
<translation id="6096348254544841612">вҖҸШіЩҒШ§ШұШҙЫҢ Ъ©ШұШҜЩҶ ЩҲ Ъ©ЩҶШӘШұЩ„ Chromium. ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢвҖҢ ШҜШұ ШҜШіШӘШұШі Ш§ШіШӘ.</translation>
<translation id="6107893135096467929">вҖҸШұЩҲШҙЩҶ вҖў Chromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…ЩҶШЁШ№ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШұШ§ ШӘШЈЫҢЫҢШҜ Ъ©ЩҶШҜ</translation>
<translation id="6119438414301547735">вҖҸЩ…Ш¬Ш§ШІ Ъ©ШұШҜЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШЁШұШ§ЫҢ ЩҶЩ…Ш§ЫҢШҙ ШҜШұШ®ЩҲШ§ШіШӘвҖҢЩҮШ§ЫҢ ШҜШіШӘШұШіЫҢ ШҜШұ ЩҶЩҲШ§ШұШ§ШЁШІШ§Шұ Chromium</translation>
<translation id="6120345080069858279">вҖҸChromium Ш§ЫҢЩҶ ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШұШ§ ШҜШұ ШӯШіШ§ШЁ Google ШҙЩ…Ш§ Ш°Ш®ЫҢШұЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Щ„Ш§ШІЩ… ЩҶЫҢШіШӘ ШўЩҶ ШұШ§ ШЁЩҮ Ш®Ш§Ш·Шұ ШЁШіЩҫШ§ШұЫҢШҜ.</translation>
<translation id="6129621093834146363">вҖҸ<ph name="FILE_NAME" /> Ш®Ш·ШұЩҶШ§Ъ© Ш§ШіШӘШҢ ШЁЩҶШ§ШЁШұШ§ЫҢЩҶ Chromium ШўЩҶ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="6132897690380286411">вҖҸChromium ШЁЩҮвҖҢШІЩҲШҜЫҢ ШЁШіШӘЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ ЩҲ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШұШ§ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="6145820983052037069">вҖҸЩ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШҜШұ Ш§ЫҢЩҶШ¬Ш§ ШЁЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium Ш¬Ш§ШЁЩҮвҖҢШ¬Ш§ ШҙЩҲЫҢШҜ</translation>
<translation id="615103374448673771">вҖҸШ§ЪҜШұ Ъ©ЩҲЪ©ЫҢвҖҢЩҮШ§ ШұШ§ Щ…Ш¬Ш§ШІ Ъ©ЩҶЫҢШҜШҢ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Chromium Ш§ШІ ШўЩҶвҖҢЩҮШ§ ЩҮЩҶЪҜШ§Щ… ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶШҜ</translation>
<translation id="6165508094623778733">ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ</translation>
<translation id="6174920971222007286">вҖҸШ§ЫҢЩҶ ЩҒШ§ЫҢЩ„ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш®Ш·ШұЩҶШ§Ъ© ШЁШ§ШҙШҜ<ph name="LINE_BREAK" />Ш§ЪҜШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШұШ§ Ш§ШұШ§ШҰЩҮ ШҜЩҮЫҢШҜШҢ Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ ШЁШұШ§ЫҢШӘШ§ЩҶ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ. Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ЩҒШ§ЫҢЩ„ ШЁЩҮ В«Щ…ШұЩҲШұ Ш§ЫҢЩ…ЩҶ GoogleВ» Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢШҙЩҲШҜШҢ Ш§Щ…Ш§ Щ…ШӯШӘЩҲШ§ЫҢ ЩҒШ§ЫҢЩ„ ЩҲ ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШҜШұ ШҜШіШӘЪҜШ§ЩҮШӘШ§ЩҶ ШЁШ§ЩӮЫҢ Щ…ЫҢвҖҢЩ…Ш§ЩҶШҜ.</translation>
<translation id="6182736845697986886">ЩҶШөШЁ ШЁЩҮвҖҢШҜЩ„ЫҢЩ„ ЩҲШ¬ЩҲШҜ Ш®Ш·Ш§ЫҢ ШҜШ§Ш®Щ„ЫҢ ШҜШұ ШіШұЩҲШұ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш§ЩҶШ¬Ш§Щ… ЩҶШҙШҜ.</translation>
<translation id="6183079672144801177">вҖҸЩ…Ш·Щ…ШҰЩҶ ШҙЩҲЫҢШҜ ШҜШұ <ph name="TARGET_DEVICE_NAME" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙШҜЩҮ ШЁШ§ШҙЫҢШҜ ЩҲ ШіЩҫШі ШҜЩҲШЁШ§ШұЩҮ Ш§ШұШіШ§Щ„ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="6212496753309875659">вҖҸШ§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ ШҜШұ ШӯШ§Щ„ ШӯШ§Ш¶Шұ ШҜШ§ШұШ§ЫҢ ЫҢЪ© ЩҶШіШ®ЩҮ Ш¬ШҜЫҢШҜШӘШұ Ш§ШІ Chromium Ш§ШіШӘ. ШҜШұШөЩҲШұШӘЫҢвҖҢЪ©ЩҮ ЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ Ъ©Ш§Шұ ЩҶЩ…ЫҢвҖҢЪ©ЩҶШҜШҢ Щ„Ш·ЩҒШ§ЩӢ Chromium ШұШ§ ШӯШ°ЩҒ ЩҶШөШЁ Ъ©ЩҶЫҢШҜ ЩҲ ШҜЩҲШЁШ§ШұЩҮ ШіШ№ЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="6219195342503754812">{0,plural, =0{вҖҸChromium ЩҮЩ…вҖҢШ§Ъ©ЩҶЩҲЩҶ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}=1{вҖҸChromium вҖҸЫұ Ш«Ш§ЩҶЫҢЩҮ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}one{вҖҸChromium вҖҸ# Ш«Ш§ЩҶЫҢЩҮ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}other{вҖҸChromium вҖҸ# Ш«Ш§ЩҶЫҢЩҮ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}}</translation>
<translation id="6241367896540709610">вҖҸChromium ШЁШұШ§ЫҢ ШЁШ§ШұЪҜЫҢШұЫҢ ЩҒШ§ЫҢЩ„вҖҢЩҮШ§ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜШіШӘШұШіЫҢ ШЁЩҮ ЩҒШ¶Ш§ЫҢ Ш°Ш®ЫҢШұЩҮвҖҢШіШ§ШІЫҢ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="6245734527075554892">вҖҸЩҶШҙШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ЩҲШЁ ШұШ§ ШЁШ§ ЩҒЩҮШұШіШӘ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢ ЩҶШ§Ш§Щ…ЩҶЫҢ Ъ©ЩҮ ШҜШұ Chromium Ш°Ш®ЫҢШұЩҮ ШҙШҜЩҮ Ш§ШіШӘ Щ…ЩӮШ§ЫҢШіЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="6248213926982192922">вҖҸChromium  Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШҙЩҲШҜ</translation>
<translation id="6268381023930128611">вҖҸШ§ШІ Chromium Ш®Ш§ШұШ¬ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҹ</translation>
<translation id="6270547683008298381">вҖҸШ§ЫҢЩҶ ШЁШұЪҜЩҮвҖҢЩҮШ§ Ш§ШІ Щ…ЩҶШ§ШЁШ№ ШЁЫҢШҙШӘШұЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЩҶШҜ. ШЁШұШ§ЫҢ ШЁЩҮШЁЩҲШҜ Ш№Щ…Щ„Ъ©ШұШҜШҢ Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ Chromium ШўЩҶвҖҢЩҮШ§ ШұШ§ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ЩҶШҜ.</translation>
<translation id="6281746429495226318">вҖҸШіЩҒШ§ШұШҙЫҢ Ъ©ШұШҜЩҶ ЩҶЩ…Ш§ЫҢЩҮ Chromium</translation>
<translation id="6290827346642914212">вҖҸЩҶШ§Щ…вҖҢЪҜШ°Ш§ШұЫҢ ЩҶЩ…Ш§ЫҢЩҮ Chromium</translation>
<translation id="6294831894865512704">вҖҸЫҢЪ©ЫҢ Ш§ШІ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ Ш§ШІ ШҙЩ…Ш§ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="6295779123002464101">вҖҸ<ph name="FILE_NAME" /> Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш®Ш·ШұЩҶШ§Ъ© ШЁШ§ШҙШҜШҢ ШЁЩҶШ§ШЁШұШ§ЫҢЩҶ Chromium ШўЩҶ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="6309712487085796862">вҖҸChromium ШҜШұШӯШ§Щ„ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜЩҲШұШЁЫҢЩҶ ШҙЩ…Ш§ Ш§ШіШӘ.</translation>
<translation id="6327105987658262776">ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ШҜШұШҜШіШӘШұШі ЩҶЫҢШіШӘ.</translation>
<translation id="6333502561965082103">вҖҸШ№Щ…Щ„ЫҢШ§ШӘ ШҜЫҢЪҜШұЫҢ ШҜШұ Chromium ШҜШұШӯШ§Щ„ Ш§ЩҶШ¬Ш§Щ… Ш§ШіШӘ. Щ„Ш·ЩҒШ§ЩӢ ШЁШ№ШҜШ§ЩӢ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="6334986366598267305">вҖҸШ§Ъ©ЩҶЩҲЩҶ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Chromium ШЁШ§ ШӯШіШ§ШЁ Google ШҙЩ…Ш§ ЩҲ ШҜШұ ШұШ§ЫҢШ§ЩҶЩҮвҖҢЩҮШ§ЫҢ Щ…ШҙШӘШұЪ© ШўШіШ§ЩҶвҖҢШӘШұ ШҙШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="633626832589656416">вҖҸвҖ«Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Ш§ЫҢЩҶ ШЁШұЪҜЩҮвҖҢЩҮШ§ ШұШ§ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ЩҶШҜ ШӘШ§ ШӘШ¬ШұШЁЩҮ Щ…ШұЩҲШұ ШҙЩ…Ш§ ШұШ§ ШЁЩҮШЁЩҲШҜ ШЁШ®ШҙШҜ ЩҲ ШіШұШ№ШӘ ШЁШ§Щ„Ш§ ШұШ§ ШӯЩҒШё Ъ©ЩҶШҜ.</translation>
<translation id="6347933965114150440">вҖҸЩ…ЫҢШ§ЩҶвҖҢШЁШұ Chromium</translation>
<translation id="6366160072964553914">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҒШ§ЫҢЩ„ Щ…Ш№Щ…ЩҲЩ„Ш§ЩӢ ШЁШ§ШұЪҜЫҢШұЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш®Ш·ШұЩҶШ§Ъ© ШЁШ§ШҙШҜ</translation>
<translation id="6373523479360886564">вҖҸШўЫҢШ§ Щ…Ш·Щ…ШҰЩҶ ЩҮШіШӘЫҢШҜ Ъ©ЩҮ Щ…ЫҢвҖҢШ®ЩҲШ§ЩҮЫҢШҜ Chromium ШұШ§ ШӯШ°ЩҒ ЩҶШөШЁ Ъ©ЩҶЫҢШҜШҹ</translation>
<translation id="6375219077595103062">Щ…ЫҢШ§ЩҶвҖҢШЁШұЫҢ ШЁЩҮ В«Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮВ» Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="6400112897226594999">вҖҸЩҶШҙШ§ЩҶвҖҢЩҲШ§ШұЩҮ Chromium ШҜШұЩҲЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ШұШ§ЫҢШ§ЩҶЩҮ.</translation>
<translation id="6403826409255603130">вҖҸвҖ«Chromium ЫҢЪ© Щ…ШұЩҲШұЪҜШұ ЩҲШЁ Ш§ШіШӘ Ъ©ЩҮ ШөЩҒШӯШ§ШӘ ЩҲШЁ ЩҲ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ ШұШ§ ШЁШ§ ШіШұШ№ШӘ ШЁШіЫҢШ§Шұ ШІЫҢШ§ШҜ Ш§Ш¬ШұШ§ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Ш§ЫҢЩҶ Щ…ШұЩҲШұЪҜШұ Ш®ЫҢЩ„ЫҢ ШіШұЫҢШ№ ЩҲ ЩҫШ§ЫҢШҜШ§Шұ Ш§ШіШӘ Ъ©Ш§Шұ Ъ©ШұШҜЩҶ ШЁШ§ ШўЩҶ ШўШіШ§ЩҶ Ш§ШіШӘ. ШЁШ§ Щ…ШӯШ§ЩҒШёШӘ ШҜШұШЁШұШ§ШЁШұ ШЁШҜШ§ЩҒШІШ§Шұ ЩҲ ШұЩ…ШІЪҜЫҢШұЫҢ ШӘШ№ШЁЫҢЩҮвҖҢШҙШҜЩҮ ШҜШұ ChromiumШҢ ШЁШ§ Ш§Щ…ЩҶЫҢШӘ ШЁЫҢШҙШӘШұЫҢ ЩҲШЁ ШұШ§ Щ…ШұЩҲШұ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="6436260184216827876">В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ШҜШұШҜШіШӘШұШі ЩҶЫҢШіШӘ. ШЁШ№ШҜШ§ЩӢ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="6442900851116057561">вҖҸШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ChromiumOS</translation>
<translation id="6443470774889161065">вҖҸвҖ«Chromium ШөЩҒШӯЩҮвҖҢЩҮШ§ЫҢ ШЁЫҢШҙШӘШұЫҢ ШұШ§ Ъ©ЩҮ Ш§ШӯШӘЩ…Ш§Щ„Ш§ЩӢ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШЁШ§ШІШҜЫҢШҜ Ш®ЩҲШ§ЩҮЫҢШҜ Ъ©ШұШҜ ЩҫЫҢШҙвҖҢШЁШ§ШұЪҜЫҢШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШӘШ§ ЩҲЩӮШӘЫҢ Ш§ШІ ШўЩҶвҖҢЩҮШ§ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШіШұЫҢШ№вҖҢШӘШұ ШЁШ§ШұЪҜЫҢШұЫҢ ШҙЩҲЩҶШҜ</translation>
<translation id="645458117210240797">вҖҸШ®Ш§Щ…ЩҲШҙ вҖў Chromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…ЩҶШЁШ№ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШұШ§ ШӘШЈЫҢЫҢШҜ Ъ©ЩҶШҜ</translation>
<translation id="6455857529632101747">вҖҸШЁЩҮ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium Ш®ЩҲШҙвҖҢШўЩ…ШҜЫҢШҜ</translation>
<translation id="6466344609055215035">вҖҸШЁШұШҜШ§ШҙШӘЩҶ ШӯШіШ§ШЁ Ш§ШІ Chromium</translation>
<translation id="6475912303565314141">вҖҸШ§ЫҢЩҶ ШЁШұЩҶШ§Щ…ЩҮ ЩҮЩ…ЪҶЩҶЫҢЩҶ ШөЩҒШӯЩҮвҖҢШ§ЫҢ ШұШ§ Ъ©ЩҮ ЩҮЩҶЪҜШ§Щ… ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Chromium ЩҶШҙШ§ЩҶ ШҜШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜШҢ Ъ©ЩҶШӘШұЩ„ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="648062525172759633">вҖҸШ§ЫҢЩҶ ШөЩҒШӯЩҮвҖҢЩҮШ§ ШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ ШӘЩҲШіШ№ЩҮвҖҢШҜЩҮЩҶШҜЪҜШ§ЩҶ Chromium ШҜШұЩҶШёШұ ЪҜШұЩҒШӘЩҮ ШҙШҜЩҮвҖҢШ§ЩҶШҜ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШЁЩҮвҖҢШ·ЩҲШұ ЩҒШ№Ш§Щ„ ЩҶЪҜЩҮШҜШ§ШұЫҢ ЫҢШ§ ШўШІЩ…Ш§ЫҢШҙ ЩҶШҙЩҲЩҶШҜ. ШЁШұШ§ЫҢ ЩҒШ№Ш§Щ„ Ъ©ШұШҜЩҶ ШўЩҶвҖҢЩҮШ§ШҢ ШЁЩҮ <ph name="BEGIN_LINK" />chrome://chrome-urls<ph name="LINK_END" /> ШЁШұЩҲЫҢШҜШҢ ШұЩҲЫҢ ШҜЪ©Щ…ЩҮ ЩҒШ№Ш§Щ„ Ъ©ШұШҜЩҶ ШөЩҒШӯЩҮвҖҢЩҮШ§ЫҢ Ш§ШҙЪ©Ш§Щ„вҖҢШІШҜШ§ЫҢЫҢ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ ЩҲ ШіЩҫШі ШҜЩҲШЁШ§ШұЩҮ ШЁЩҮ Ш§ЫҢЩҶ ШөЩҒШӯЩҮ ШЁШұЩҲЫҢШҜ.</translation>
<translation id="648319183876919572">В«Щ…ШұЩҲШұ Ш§ЫҢЩ…ЩҶ ЩҫЫҢШҙШұЩҒШӘЩҮВ» Ъ©Ш§ШұЩҮШ§ЫҢ ШЁЫҢШҙШӘШұЫҢ ШЁШұШ§ЫҢ Щ…ШӯШ§ЩҒШёШӘ Ш§ШІ ШҙЩ…Ш§ ШҜШұЩ…ЩӮШ§ШЁЩ„ ЩҲШЁвҖҢШіШ§ЫҢШӘвҖҢЩҮШ§ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ЫҢ Ш®Ш·ШұЩҶШ§Ъ© Ш§ЩҶШ¬Ш§Щ… Щ…ЫҢвҖҢШҜЩҮШҜ</translation>
<translation id="6510925080656968729">вҖҸШӯШ°ЩҒ ЩҶШөШЁ Chromium </translation>
<translation id="651535675648445253">вҖҸЩ…ЫҢШ§ЩҶвҖҢШЁШұЩҮШ§ ШҜШұ Chromium ШЁШ§ШІ Щ…ЫҢвҖҢШҙЩҲШҜ</translation>
<translation id="6524389414524528185">вҖҸШ§Ъ©ЩҶЩҲЩҶ Ъ©ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЩҮвҖҢШ§ЫҢШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ШІ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ ШҜШұ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ. ЩҮШұШІЩ…Ш§ЩҶ ШЁШ®ЩҲШ§ЩҮЫҢШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ЫҢЩҶ Щ…ЩҲШұШҜ ШұШ§ ШҜШұ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШӘШәЫҢЫҢШұ ШҜЩҮЫҢШҜ.</translation>
<translation id="6539122709674868420">вҖҸШ§ЪҜШұ <ph name="TIMEOUT_DURATION" /> Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ Щ…ЫҢвҖҢШЁЩҶШҜШҜ. ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШӯШ°ЩҒ ШҙШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ.</translation>
<translation id="6542839706527980775">вҖҸЩҮШұЪ©ШҜШ§Щ… Ш§ШІ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ ШҜШ§ШұШ§ЫҢ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Chromium Щ…Ш®ШӘШө Ш®ЩҲШҜШҙ Ш§ШіШӘ (Щ…Ш«Щ„Ш§ЩӢ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШіШ§ШЁЩӮЩҮШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ШҢ ЩҲ ШәЫҢШұЩҮ)</translation>
<translation id="6563921047760808519">вҖҸШҜШұШЁШ§ШұЩҮ Ш§ЫҢЩҶЪ©ЩҮ <ph name="BEGIN_LINK" />Chromium ЪҶЪҜЩҲЩҶЩҮ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ Ш®ШөЩҲШөЫҢ ЩҶЪҜЩҮ Щ…ЫҢвҖҢШҜШ§ШұШҜ<ph name="END_LINK" /> ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ</translation>
<translation id="656935081669708576">вҖҸШЁШұШ§ЫҢ ШҜЫҢШҜЩҶ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢ ЩҶЩ…Ш§ЫҢЩҮ Chromium ШҜЫҢЪҜШұШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ШЁЩҮ ШўЩҶ ЩҶЩ…Ш§ЫҢЩҮ ШЁШұЩҲЫҢШҜ</translation>
<translation id="6570579332384693436">вҖҸШЁШұШ§ЫҢ ШұЩҒШ№ Ш®Ш·Ш§ЩҮШ§ЫҢ Ш§Щ…Щ„Ш§ШҰЫҢШҢ Chromium ЩҶЩҲШҙШӘШ§ШұЫҢ ШұШ§ Ъ©ЩҮ ШҜШұ ЩҒЫҢЩ„ШҜ ЩҶЩҲШҙШӘШ§Шұ ШӘШ§ЫҢЩҫ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ ШЁШұШ§ЫҢ Google Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="6598877126913850652">вҖҸШұЩҒШӘЩҶ ШЁЩҮ ШӘЩҶШёЫҢЩ…Ш§ШӘ Ш§Ш№Щ„Ш§ЩҶ Chromium</translation>
<translation id="6600016381025017075">ЩҮШұЪҶЫҢШІЫҢ ШҜШұ Ш§ЫҢЩҶ ШөЩҒШӯЩҮ ШұШ§ Ш¬ШіШӘШ¬ЩҲ Ъ©ЩҶЫҢШҜ</translation>
<translation id="6613594504749178791">вҖҸШҜЩҒШ№ЩҮ ШЁШ№ШҜЫҢ Ъ©ЩҮ Chromium ШұШ§ Щ…Ш¬ШҜШҜШ§ЩӢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ Ш§ЫҢЩҶ ШӘШәЫҢЫҢШұШ§ШӘ Ш§Ш№Щ…Ш§Щ„ Щ…ЫҢвҖҢШҙЩҲЩҶШҜ.</translation>
<translation id="665732753414869868">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢШ¬Ш§ШҜ ЩҶЩӮШҙЩҮ ШіЩҮвҖҢШЁШ№ШҜЫҢ Ш§ШІ Щ…ШӯЫҢШ· Ш§Ш·ШұШ§ЩҒ ШҙЩ…Ш§ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҲШұШЁЫҢЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="6663852025006259149">вҖҸШіШ§ЫҢШӘвҖҢЩҮШ§ Ш§ШӯШӘЩ…Ш§Щ„Ш§ЩӢ Ш№Щ…Щ„Ъ©ШұШҜЫҢ Щ…Ш·Ш§ШЁЩӮ Ш§ЩҶШӘШёШ§Шұ ШҙЩ…Ш§ Ш®ЩҲШ§ЩҮЩҶШҜ ШҜШ§ШҙШӘ Ш§Щ…Ш§ ШЁШ№ШҜШ§ШІ ШЁШіШӘЩҮ ШҙШҜЩҶ ЩҮЩ…ЩҮ ЩҫЩҶШ¬ШұЩҮвҖҢЩҮШ§ЫҢ ChromiumШҢ ШҙЩ…Ш§ ШұШ§ ШЁЩҮвҖҢЫҢШ§ШҜ ЩҶШ®ЩҲШ§ЩҮЩҶШҜ ШҜШ§ШҙШӘ</translation>
<translation id="6669284030132180248">вҖҸШ§ЪҜШұ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ ШұШ§ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» ЩҮЩ… Ш°Ш®ЫҢШұЩҮ Ъ©ЩҶЫҢШҜШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩӮЫҢЩ…ШӘ Щ…ШӯШөЩҲЩ„Ш§ШӘ ШұШ§ ШҜШұ Chromium ЩҫЫҢЪҜЫҢШұЫҢ Ъ©ЩҶЫҢШҜ ЩҲ Ш§ШІ Ъ©Ш§ЩҮШҙ ЩӮЫҢЩ…ШӘвҖҢЩҮШ§ Щ…Ш·Щ„Ш№ ШҙЩҲЫҢШҜ</translation>
<translation id="6676384891291319759">ШҜШіШӘШұШіЫҢ ШЁЩҮ Ш§ЫҢЩҶШӘШұЩҶШӘ</translation>
<translation id="668175097507315160">вҖҸШЁЩҮвҖҢШҜЩ„ЫҢЩ„ ШЁШұЩҲШІ Ш®Ш·Ш§ ЩҮЩҶЪҜШ§Щ… ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ…ШҢ ChromiumOS ЩҶШӘЩҲШ§ЩҶШіШӘ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ Ъ©ЩҶШҜ.</translation>
<translation id="6692797197837897398">вҖҸвҖ«Chromium ШЁЩҮ ШҙЩ…Ш§ Ъ©Щ…Ъ© Щ…ЫҢвҖҢЪ©ЩҶШҜ ШЁШұ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ Щ…ЫҢвҖҢШЁЫҢЩҶЫҢШҜ ШӘШіЩ„Ш· ШЁЫҢШҙШӘШұЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЫҢШҜ ЩҲ ЩҮЩ…ЪҶЩҶЫҢЩҶ Щ…ЫҢШІШ§ЩҶ Ш§Ш·Щ„Ш§Ш№Ш§ШӘЫҢ ШұШ§ Ъ©ЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ ЩҮЩҶЪҜШ§Щ… ЩҶЩ…Ш§ЫҢШҙ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢ ШҙШ®ШөЫҢвҖҢШіШ§ШІЫҢвҖҢШҙШҜЩҮ ШЁЩҮ ШҙЩ…Ш§ ШҜШұШЁШ§ШұЩҮвҖҢШӘШ§ЩҶ Ш¬Щ…Ш№вҖҢШўЩҲШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶЩҶШҜ Щ…ШӯШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜ</translation>
<translation id="6709350901466051922">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="6712881677154121168">Ш®Ш·Ш§ЫҢ ШЁШ§ШұЪҜЫҢШұЫҢ: <ph name="DOWNLOAD_ERROR" />.</translation>
<translation id="6717134281241384636">вҖҸШ§ШІ ЩҶЩ…Ш§ЫҢЩҮЩ” ШҙЩ…Ш§ ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ШұШҜ ШІЫҢШұШ§ ШҜШ§ШұШ§ЫҢ ЩҶШіШ®ЩҮ Ш¬ШҜЫҢШҜШӘШұЫҢ Ш§ШІ Chromium Ш§ШіШӘ.

ШЁШұШ®ЫҢ Ш§ШІ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Щ…ЩҲШ¬ЩҲШҜ ЩҶШЁШ§ШҙЩҶШҜ. Щ„Ш·ЩҒШ§ЩӢ ЫҢЪ© ЩҒЩҮШұШіШӘ ШұШ§ЩҮЩҶЩ…Ш§ЫҢ ЩҶЩ…Ш§ЫҢЩҮ ШҜЫҢЪҜШұЫҢ ШұШ§ Щ…ШҙШ®Шө Ъ©ЩҶЫҢШҜ ЫҢШ§ Ш§ШІ ЩҶШіШ®ЩҮ Ш¬ШҜЫҢШҜШӘШұЫҢ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="6729124504294600478">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ШҙШ®ШөЫҢвҖҢШіШ§ШІЫҢ ЩҲ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ЫҢ ШҜЫҢЪҜШұШҢ Chromium ШұШ§ ШЁЩҮ В«ЩҒШ№Ш§Щ„ЫҢШӘвҖҢЩҮШ§ ШҜШұ ЩҲШЁ ЩҲ ШЁШұЩҶШ§Щ…ЩҮВ» ЩҲ ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ ЩҫЫҢЩҲЩҶШҜШҙШҜЩҮ Google Ш§Ш¶Ш§ЩҒЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="6734291798041940871">вҖҸChromium Ш§ШІ ЩӮШЁЩ„ ШЁШұШ§ЫҢ ЩҮЩ…ЩҮ Ъ©Ш§ШұШЁШұШ§ЩҶ Ш§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ ЩҶШөШЁ ШҙШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="673636774878526923">вҖҸШЁШұШ§ЫҢ ШҜШіШӘШұШіЫҢ ШЁЩҮ ЪҶЫҢШІЩҮШ§ЫҢ Chromium ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜШҢ ШіЩҫШі ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ ШұШ§ ШұЩҲШҙЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="674245979920622322">вҖҸШ§Ш®ЫҢШұШ§ЩӢ ШЁШ§ШІШҜЫҢШҜЫҢ ЩҶШҜШ§ШҙШӘЩҮвҖҢШ§ЫҢШҜ. вҖ«Chromium вҖҸ<ph name="PERMISSION_1" />ШҢвҖҸ <ph name="PERMISSION_2" />ШҢвҖҸ ЩҲ <ph name="COUNT" /> Щ…ЩҲШұШҜ ШҜЫҢЪҜШұ ШұШ§ ШЁШұШҜШ§ШҙШӘ</translation>
<translation id="67706546131546258">вҖҸChromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ Ш§ЫҢЩҶ ЩҒШ§ЫҢЩ„ ШұШ§ Ш§ШіЪ©ЩҶ Ъ©ЩҶЫҢШҜ ШІЫҢШұШ§ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ Ш®Ш·ШұЩҶШ§Ъ© ШЁШ§ШҙШҜ.</translation>
<translation id="6779406956731413166">вҖҸШ§ШұШ§ШҰЩҮ ChromiumOS ШЁЩҮвҖҢЪ©Щ…Ъ© <ph name="BEGIN_LINK_CROS_OSS" />ЩҶШұЩ…вҖҢШ§ЩҒШІШ§ШұЩҮШ§ЫҢ Щ…ШӘЩҶвҖҢШЁШ§ШІ<ph name="END_LINK_CROS_OSS" /> ШӘЪ©Щ…ЫҢЩ„ЫҢ Щ…Щ…Ъ©ЩҶ ШҙШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="6831043979455480757">ШӘШұШ¬Щ…ЩҮ</translation>
<translation id="6847869444787758381">вҖҸChromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜШҢ Ш§ЪҜШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШҜШұ Щ…Ш№ШұШ¶ Ш®Ш·Шұ ШЁШ§ШҙШҜШҢ Щ…Ш·Щ„Ш№ШӘШ§ЩҶ Ъ©ЩҶШҜ</translation>
<translation id="684888714667046800">ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶ ШЁЩҮ Ш§ЫҢЩҶШӘШұЩҶШӘ Щ…ШӘШөЩ„ ШҙШҜ. Ш§ЪҜШұ Ш§ШІ ШҜЫҢЩҲШ§Шұ ШўШӘШҙ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ Щ„Ш·ЩҒШ§ЩӢ Щ…Ш·Щ…ШҰЩҶ ШҙЩҲЫҢШҜ <ph name="PRODUCT_EXE_NAME" /> ШҜШұ ЩҒЩҮШұШіШӘ Щ…Ш¬Ш§ШІЩҮШ§ ШЁШ§ШҙШҜ.</translation>
<translation id="6857782730669500492">Chromium - <ph name="PAGE_TITLE" /></translation>
<translation id="6873893289264747459">вҖҸChromium Щ…ШӘЩҲШ¬ЩҮ ШҙШҜЩҮ Ш§ШіШӘ Ъ©ЩҮ В«<ph name="EXTENSION_NAME" />В» ШӯШ§ЩҲЫҢ ШЁШҜШ§ЩҒШІШ§Шұ Ш§ШіШӘ</translation>
<translation id="6896758677409633944">Ъ©ЩҫЫҢ</translation>
<translation id="6929417474050522668">вҖҸЩҲЩӮШӘЫҢ ЩҶШіШ®ЩҮ ШўШІЩ…Ш§ЫҢШҙЫҢ ШұЩҲШҙЩҶ ШЁШ§ШҙШҜШҢ В«ШіЩҶШ¬Шҙ ШўЪҜЩҮЫҢВ» ШЁЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ Ш§Ш¬Ш§ШІЩҮ Щ…ЫҢвҖҢШҜЩҮШҜ Ш§Ш·Щ„Ш§Ш№Ш§ШӘЫҢ ШұШ§ Ш§ШІ Chromium ШҜШұШ®ЩҲШ§ШіШӘ Ъ©ЩҶЩҶШҜ Ъ©ЩҮ ШЁЩҮ ШўЩҶвҖҢЩҮШ§ Ъ©Щ…Ъ© Щ…ЫҢвҖҢЪ©ЩҶШҜ Ш№Щ…Щ„Ъ©ШұШҜ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢШҙШ§ЩҶ ШұШ§ ШЁШіЩҶШ¬ЩҶШҜ. В«ШіЩҶШ¬Шҙ ШўЪҜЩҮЫҢВ» ШұШҜЫҢШ§ШЁЫҢ ШЁЫҢЩҶвҖҢШіШ§ЫҢШӘЫҢ ШұШ§ ШЁШ§ Ш§ЩҶШӘЩӮШ§Щ„ ШӯШҜШ§ЩӮЩ„ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…Щ…Ъ©ЩҶ ШЁЫҢЩҶ ШіШ§ЫҢШӘвҖҢЩҮШ§ Щ…ШӯШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="6940431691900807093">вҖҸШЁШ№ШҜШ§ЩӢШҢ ШіШ§ЫҢШӘЫҢ Ъ©ЩҮ Ш§ШІ ШўЩҶ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁШұШ§ЫҢ ШҙШ®ШөЫҢ Ъ©ШұШҜЩҶ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁЩҮ ШҙЩ…Ш§ ЩҶШҙШ§ЩҶ Щ…ЫҢвҖҢШҜЩҮШҜ Ш§ШІ Chromium ШЁШ®ЩҲШ§ЩҮШҜ Ш№Щ„Ш§ЫҢЩӮ ШҙЩ…Ш§ ШұШ§ ШЁШЁЫҢЩҶШҜ. Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШӯШҜШ§Ъ©Ш«Шұ Ыі Ш№Щ„Ш§ЩӮЩҮ ШұШ§ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ Ъ©ЩҶШҜ.</translation>
<translation id="6964305034639999644">вҖҸШЁШ§ШІ Ъ©ШұШҜЩҶ ЩҫЫҢЩҲЩҶШҜ ШҜШұ ЩҫЩҶШ¬ШұЩҮ &amp;ЩҶШ§ШҙЩҶШ§Ші Chromium</translation>
<translation id="6965382102122355670">ШӘШЈЫҢЫҢШҜ</translation>
<translation id="6978145336957848883">вҖҸЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢ Ш¶Ш№ЫҢЩҒ ШұШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶ ШЁЩҮвҖҢШұШ§ШӯШӘЫҢ ШӯШҜШі ШІШҜ. ШЁЩҮ Chromium Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ <ph name="BEGIN_LINK" />ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢЫҢ ЩӮЩҲЫҢ ШЁШұШ§ЫҢШӘШ§ЩҶ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶШҜ ЩҲ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁЩҮвҖҢШ®Ш§Ш·Шұ ШЁШіЩҫШ§ШұШҜ<ph name="END_LINK" />.</translation>
<translation id="6980074797973263542">вҖҸШіШ§ШІЩ…Ш§ЩҶ ШҙЩ…Ш§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ Щ…Ш«Щ„ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ШҢ ШіШ§ШЁЩӮЩҮШҢ ЩҲ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШЁЫҢЩҶШҜ ЩҲ Щ…ШҜЫҢШұЫҢШӘ Ъ©ЩҶШҜ. ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШұЩҲШұ ШҜШұ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ ШҙШ®ШөЫҢ Chromium ШұШ§ ШЁШЁЫҢЩҶШҜ.</translation>
<translation id="6985329841647292029">вҖҸШҙШұШ§ЫҢШ· ChromiumOS</translation>
<translation id="6990124437352146030">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁЩҮ Щ…Ш¬ЩҲШІ ШҜШіШӘШұШіЫҢ ШЁЩҮ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="7003299027384820442">вҖҸШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ЩҲ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШўЩҶвҖҢЩҮШ§ ШҜШұ ШӯШіШ§ШЁШӘШ§ЩҶ (<ph name="ACCOUNT_EMAIL" />)ШҢ ЪҜШ°ШұШ№ШЁШ§ШұШӘ Ш®ЩҲШҜ ШұШ§ ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ</translation>
<translation id="7011190694940573312">ЩҶШөШЁ Ш§ЩҶШ¬Ш§Щ… ЩҶШҙШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҶШіШ®ЩҮ Ш§ШІ ШіЫҢШіШӘЩ…вҖҢШ№Ш§Щ…Щ„ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="7024536598735240744">Ш®Ш·Ш§ЫҢ Щ„ШәЩҲ ЩҒШҙШұШҜЩҮвҖҢШіШ§ШІЫҢ: <ph name="UNPACK_ERROR" />.</translation>
<translation id="7025789849649390912">ЩҶШөШЁ Щ…ШӘЩҲЩӮЩҒ ШҙШҜ.</translation>
<translation id="7045244423563602563">вҖҸChromium ШұШ§ ШЁШұШ§ЫҢ Ш®ЩҲШҜ Ш§Ш®ШӘШөШ§ШөЫҢ Ъ©ЩҶЫҢШҜ</translation>
<translation id="705851970750939768">вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium</translation>
<translation id="7067091210845072982">вҖҸШ§ЪҜШұ ШӘШөЩҲЫҢШұЫҢ ШӘЩҲШ¶ЫҢШӯ Щ…ЩҒЫҢШҜЫҢ ЩҶШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜШҢ Chromium ШӘЩҲШ¶ЫҢШӯЫҢ ШЁШұШ§ЫҢ ШҙЩ…Ш§ Ш§ШұШ§ШҰЩҮ Ш®ЩҲШ§ЩҮШҜ Ъ©ШұШҜ. ШЁШұШ§ЫҢ Ш§ЫҢШ¬Ш§ШҜ ШӘЩҲШ¶ЫҢШӯШ§ШӘШҢ ШӘШөШ§ЩҲЫҢШұ ШЁЩҮ Google Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="7141270731789036260">вҖҸШіЩҒШ§ШұШҙЫҢвҖҢШіШ§ШІЫҢ Chrome for Testing</translation>
<translation id="7163519456498498587">вҖҸШӯШ°ЩҒ <ph name="EXTENSION_NAME" /> Ш§ШІ Chromium</translation>
<translation id="7173822816570314652">вҖҸШ§ЪҜШұ <ph name="TIMEOUT_DURATION" /> Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШўЩҶ ШұШ§ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. Ш§ЫҢЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШҙШ§Щ…Щ„ ШіШ§ШЁЩӮЩҮШҢ ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§ШұШҢ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ ШҙЩҲШҜ.</translation>
<translation id="718435575166326686">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҲШұШЁЫҢЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="7196312274710523067">вҖҸChromium ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ЩҶШҙШҜ. ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="7197677400338048821">вҖҸChromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ. ШЁШ№ШҜ Ш§ШІ ЫІЫҙ ШіШ§Ш№ШӘ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="7213407614656404070">вҖҸШ§ШІ Chromium ШЁШұШ§ЫҢ ШЁШ§ШІ Ъ©ШұШҜЩҶ ЩҫЫҢЩҲЩҶШҜЩҮШ§ЫҢ Щ…ЩҲШ¬ЩҲШҜ ШҜШұ ЩҫЫҢШ§Щ…вҖҢЩҮШ§ШҢ Ш§ШіЩҶШ§ШҜШҢ ЩҲ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ ШҜЫҢЪҜШұ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="7223968959479464213">вҖҸЩ…ШҜЫҢШұ ЩҲШёШ§ЫҢЩҒ - Chromium</translation>
<translation id="7246575524853130370">вҖҸШ№Щ„Ш§ЫҢЩӮ ШҙЩ…Ш§ ШЁЩҮвҖҢШ·ЩҲШұЫҢвҖҢЪ©ЩҮ Chromium ШЁШұШўЩҲШұШҜ Ъ©ШұШҜЩҮ Ш§ШіШӘ</translation>
<translation id="7274695763216404502">ШіЩҶШ¬Ш§ЩӮ ШҙШҜ! ШҜЩҒШ№ЩҮ ШЁШ№ШҜ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ШұШ§ Ш§ШІ ЩҶЩҲШ§ШұШ§ШЁШІШ§Шұ ШЁШ§ШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="7295544978856094497">{NUM_EXTENSIONS,plural, =1{вҖҸChromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ}one{вҖҸChromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ}other{вҖҸChromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ}}</translation>
<translation id="7309928523159922338">вҖҸШіЩҶШ¬Шҙ ШўЪҜЩҮЫҢ ШЁЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ Ш§Щ…Ъ©Ш§ЩҶ Щ…ЫҢвҖҢШҜЩҮШҜ Ш§Ш·Щ„Ш§Ш№Ш§ШӘЫҢ ШұШ§ Ш§ШІ Chromium ШҜШұШ®ЩҲШ§ШіШӘ Ъ©ЩҶЩҶШҜ Ъ©ЩҮ ШЁЩҮ ШўЩҶвҖҢЩҮШ§ Ъ©Щ…Ъ© Щ…ЫҢвҖҢЪ©ЩҶШҜ Ш№Щ…Щ„Ъ©ШұШҜ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢШҙШ§ЩҶ ШұШ§ ШЁШіЩҶШ¬ЩҶШҜ. В«ШіЩҶШ¬Шҙ ШўЪҜЩҮЫҢВ» ШұШҜЫҢШ§ШЁЫҢ ШЁЫҢЩҶвҖҢШіШ§ЫҢШӘЫҢ ШұШ§ ШЁШ§ Ш§ЩҶШӘЩӮШ§Щ„ ШӯШҜШ§ЩӮЩ„ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…Щ…Ъ©ЩҶ ШЁЫҢЩҶ ШіШ§ЫҢШӘвҖҢЩҮШ§ Щ…ШӯШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="731795002583552498">вҖҸШҜШұ ШӯШ§Щ„ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium</translation>
<translation id="7318036098707714271">вҖҸЩҒШ§ЫҢЩ„ Ш§ЩҲЩ„ЩҲЫҢШӘвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ Ш®ШұШ§ШЁ ЫҢШ§ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ. 
Chromium ЩӮШ§ШҜШұ ШЁЩҮ ШЁШ§ШІЫҢШ§ШЁЫҢ ШӘЩҶШёЫҢЩ…Ш§ШӘ ШҙЩ…Ш§ ЩҶЫҢШіШӘ.</translation>
<translation id="7339898014177206373">ЩҫЩҶШ¬ШұЩҮЩ” Ш¬ШҜЫҢШҜ</translation>
<translation id="734373864078049451">вҖҸЩҲШЁШҢ ЩҶШҙШ§ЩҶЪ©вҖҢЩҮШ§ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ Chromium ШҙЩ…Ш§ ШҜШұ Ш§ЫҢЩҶШ¬Ш§ ЩҮШіШӘЩҶШҜ.</translation>
<translation id="7349591376906416160">вҖҸШіШұЩҫШұШіШӘ ШіЫҢШіШӘЩ… ШЁШұШ§ЫҢ ШЁШ§ШІ ШҙШҜЩҶ <ph name="ALTERNATIVE_BROWSER_NAME" /> Ш¬ЩҮШӘ ШҜШіШӘШұШіЫҢ ШЁЩҮ <ph name="TARGET_URL_HOSTNAME" />ШҢ Chromium ШұШ§ ЩҫЫҢЪ©ШұШЁЩҶШҜЫҢ Ъ©ШұШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="7355355292030546812">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ Ш§ЫҢЩҶ ЩҒШ§ЫҢЩ„ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁЩҮ ШӯШіШ§ШЁвҖҢЩҮШ§ЫҢ ШҙШ®ШөЫҢ ЩҲ ШҙШЁЪ©ЩҮвҖҢЩҮШ§ЫҢ Ш§Ш¬ШӘЩ…Ш§Ш№ЫҢ ШҙЩ…Ш§ Ш§ШІШ¬Щ…Щ„ЩҮ <ph name="USER_EMAIL" /> ШўШіЫҢШЁ ШЁШұШіШ§ЩҶШҜ</translation>
<translation id="7384121030444253939">вҖҸШҜЫҢЪҜШұ Ш§ШІ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ. вҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="7389750180956889333">вҖҸвҖ«Chromium ЩҒШұЩ…вҖҢЩҮШ§ ШұШ§ ШЁЩҮШӘШұ ШҜШұЪ© Щ…ЫҢвҖҢЪ©ЩҶШҜ ЩҲ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁШ§ ШіШұШ№ШӘ ШЁЫҢШҙШӘШұЫҢ ШўЩҶвҖҢЩҮШ§ ШұШ§ ШЁШұШ§ЫҢШӘШ§ЩҶ ЩҫШұ Ъ©ЩҶШҜ. ШҜШұШЁШ§ШұЩҮ <ph name="BEGIN_LINK" />ШӘЪ©Щ…ЫҢЩ„ Ш®ЩҲШҜЪ©Ш§Шұ Chrome<ph name="END_LINK" /> ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ</translation>
<translation id="7449453770951226939"><ph name="PAGE_TITLE" /> - Chromium Dev</translation>
<translation id="7450541714075000668">ЩҶЩҲШҙШӘШ§Шұ Ъ©ЩҫЫҢ ШҙШҜ</translation>
<translation id="7451052299415159299">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁЩҮ Щ…Ш¬ЩҲШІ ШҜШіШӘШұШіЫҢ ШЁЩҮ ШҜЩҲШұШЁЫҢЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="7458892263350425044">вҖҸШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶШҢ ШҜШұ <ph name="BEGIN_LINK" />ШӘЩҶШёЫҢЩ…Ш§ШӘ ШіЫҢШіШӘЩ…<ph name="END_LINK" /> ШЁЩҮ Chromium ШҜШіШӘШұШіЫҢ ШҜЩҮЫҢШҜ</translation>
<translation id="7461356015007898716">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ШўШӘЫҢ ChromiumШҢ ШЁШ§ЫҢШҜ Windows 10 ЫҢШ§ ШЁШ§Щ„Ш§ШӘШұ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЫҢШҜ. Ш§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ Ш§ШІ Windows 7 Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="7467949745582939695">вҖҸChromium ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ ШҙЩҲШҜШҹ</translation>
<translation id="7483335560992089831">вҖҸЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Chromium ШҜШ§ШұШ§ЫҢ ЩҶШіШ®ЩҮ Щ…ШҙШ§ШЁЩҮ ШЁШ§ ЩҶШіШ®ЩҮ ШҜШұ ШӯШ§Щ„ Ш§Ш¬ШұШ§ ШұШ§ ЩҶШөШЁ Ъ©ЩҶЫҢШҜ. Щ„Ш·ЩҒШ§ЩӢ Chromium ШұШ§ ШЁШЁЩҶШҜЫҢШҜ ЩҲ ШҜЩҲШЁШ§ШұЩҮ ШіШ№ЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="751935028865900641">вҖҸШіШ§ЫҢШӘвҖҢЩҮШ§ Ш§ШӯШӘЩ…Ш§Щ„Ш§ЩӢ Ш№Щ…Щ„Ъ©ШұШҜ Щ…ЩҲШұШҜШ§ЩҶШӘШёШ§Шұ ШұШ§ Ш®ЩҲШ§ЩҮЩҶШҜ ШҜШ§ШҙШӘ. ЩҲЩӮШӘЫҢ ЩҮЩ…ЩҮ ЩҫЩҶШ¬ШұЩҮвҖҢЩҮШ§ЫҢ Chromium ШұШ§ ШЁШЁЩҶШҜЫҢШҜ Ш§ШІ ШіЫҢШіШӘЩ… Ш§Ъ©Ш«Шұ ШіШ§ЫҢШӘвҖҢЩҮШ§ Ш®Ш§ШұШ¬ Ш®ЩҲШ§ЩҮЫҢШҜ ШҙШҜШҢ Ш§Щ…Ш§ Ш§ЪҜШұ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙШҜЩҮ ШЁШ§ШҙЫҢШҜ Ш§ШІ В«ШӯШіШ§ШЁ GoogleВ» Ш®Ш§ШұШ¬ ЩҶШ®ЩҲШ§ЩҮЫҢШҜ ШҙШҜ.</translation>
<translation id="753534427205733210">{0,plural, =1{вҖҸChromium вҖҸЫұ ШҜЩӮЫҢЩӮЩҮ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}one{вҖҸChromium вҖҸ# ШҜЩӮЫҢЩӮЩҮ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}other{вҖҸChromium вҖҸ# ШҜЩӮЫҢЩӮЩҮ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}}</translation>
<translation id="7553334751796114046">вҖҸШЁШұШ§ЫҢ ЩҮЩ…вҖҢШұШіШ§ЩҶЫҢ ЩҫЩҶШ¬ШұЩҮШҢ В«Ш¶ШЁШ·вҖҢЪ©ЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ЩҲЫҢЪҳЩҮ ChromiumВ» ШұШ§ ШҜШұ В«Ш§ЩҲЩ„ЩҲЫҢШӘвҖҢЩҮШ§ЫҢ ШіЫҢШіШӘЩ…В» Щ…Ш¬Ш§ШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="7582945390259497898">вҖҸChromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ ШұШ§ ШЁШұШўЩҲШұШҜ Ъ©ЩҶШҜ. ШЁШ№ШҜШ§ЩӢШҢ ШіШ§ЫҢШӘЫҢ Ъ©ЩҮ Ш§ШІ ШўЩҶ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ШЁШұШ§ЫҢ ШҙШ®ШөЫҢ Ъ©ШұШҜЩҶ ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁЩҮ ШҙЩ…Ш§ ЩҶШҙШ§ЩҶ Щ…ЫҢвҖҢШҜЩҮШҜ Ш§ШІ Chromium ШЁШ®ЩҲШ§ЩҮШҜ Ш№Щ„Ш§ЫҢЩӮ ШҙЩ…Ш§ ШұШ§ ШЁШЁЫҢЩҶШҜ.</translation>
<translation id="7583399374488819119">ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ <ph name="COMPANY_NAME" /></translation>
<translation id="7585391435984513350">вҖҸШ§Ш®ЫҢШұШ§ЩӢ ШЁШ§ШІШҜЫҢШҜЫҢ ЩҶШҜШ§ШҙШӘЩҮвҖҢШ§ЫҢШҜ. вҖ«Chromium вҖҸ<ph name="PERMISSION" /> ШұШ§ ШЁШұШҜШ§ШҙШӘ</translation>
<translation id="761356813943268536">вҖҸChromium ШҜШұШӯШ§Щ„ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜЩҲШұШЁЫҢЩҶ ЩҲ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶ ШҙЩ…Ш§ Ш§ШіШӘ.</translation>
<translation id="7617377681829253106">вҖҸChromium Ш§Ъ©ЩҶЩҲЩҶ ШЁЩҮШӘШұ ШҙШҜЩҮ Ш§ШіШӘ</translation>
<translation id="7649070708921625228">ШұШ§ЩҮЩҶЩ…Ш§</translation>
<translation id="7658239707568436148">Щ„ШәЩҲ</translation>
<translation id="7686590090926151193">вҖҸChromium Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШҙЩ…Ш§ ЩҶЫҢШіШӘ</translation>
<translation id="7689606757190482937">вҖҸChromium ШұШ§ ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ ЩҲ ШҙШ®ШөЫҢвҖҢШіШ§ШІЫҢ Ъ©ЩҶЫҢШҜ</translation>
<translation id="7699779824407626136">вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium</translation>
<translation id="77283119132245232">ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ ШұШҜЫҢШ§ШЁЫҢ ШіЫҢШіШӘЩ… ШұШ§ ШЁШұШ§ЫҢ <ph name="BROWSER_NAME" /> Ш§ШұШ§ШҰЩҮ Щ…ЫҢвҖҢШҜЩҮШҜ. Ш§ЪҜШұ Ш§ЫҢЩҶ ШіШұЩҲЫҢШі ШәЫҢШұЩҒШ№Ш§Щ„ ШЁШ§ШҙШҜШҢ ШұШҜЫҢШ§ШЁЫҢвҖҢЩҮШ§ЫҢ Ш№Щ…Щ„Ъ©ШұШҜЫҢ Ъ©ЩҮ Щ…ШұЩҲШұЪҜШұ Ш§ЫҢШ¬Ш§ШҜ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШҙШ§Щ…Щ„ ШұЩҲЫҢШҜШ§ШҜЩҮШ§ЫҢ ШҜШұ ШіШ·Шӯ ШіЫҢШіШӘЩ… Щ…Ш§ЩҶЩҶШҜ ШұЩҲЫҢШҜШ§ШҜЩҮШ§ЫҢ ШӘШәЫҢЫҢШұ ШІЩ…ЫҢЩҶЩҮ ЩҲ ШўЩ…Ш§ШҜЩҮвҖҢШіШ§ШІЫҢ ШұШҙШӘЩҮ ЩҶШ®ЩҲШ§ЩҮШҜ ШЁЩҲШҜ.</translation>
<translation id="7745317241717453663">вҖҸШ§ЫҢЩҶ Ъ©Ш§Шұ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Щ…ШӯШөЩҲЩ„ Щ…ШұЩҲШұШӘШ§ЩҶ ШұШ§ Ш§ШІ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ШӯШ°ЩҒ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШұШ§ЫҢ ШЁШ§ШІЫҢШ§ШЁЫҢ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШҜШұ ЩҒШұШөШӘЫҢ ШҜЫҢЪҜШұШҢ ШЁШ§ <ph name="USER_EMAIL" /> ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ.</translation>
<translation id="7747138024166251722">ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ЩҶШӘЩҲШ§ЩҶШіШӘ ШҜШ§ЫҢШұЪ©ШӘЩҲШұЫҢ Щ…ЩҲЩӮШӘ Ш§ЫҢШ¬Ш§ШҜ Ъ©ЩҶШҜ. Щ„Ш·ЩҒШ§ЩӢ ЩҒШ¶Ш§ЫҢ Ш®Ш§Щ„ЫҢ ШҜЫҢШіЪ© ЩҲ Ш§Ш¬Ш§ШІЩҮ ЩҶШөШЁ ЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="7786760609782648049">вҖҸШіШұШ№ШӘ Chromium ШұШ§ Ш§ЩҒШІШ§ЫҢШҙ ШҜЩҮЫҢШҜ</translation>
<translation id="7790626492778995050"><ph name="PAGE_TITLE" /> - Chromium Canary</translation>
<translation id="7803986347287457849">вҖҸШҙШұШ§ЫҢШ· ШұШ§ ШіШ®ШӘвҖҢШӘШұ Ъ©ЩҶЫҢШҜ ШӘШ§ Ш§ЩҒШұШ§ШҜЫҢ Ъ©ЩҮ ШЁЩҮ ШӘШұШ§ЩҒЫҢЪ© Ш§ЫҢЩҶШӘШұЩҶШӘ ШҙЩ…Ш§ ШҜШіШӘШұШіЫҢ ШҜШ§ШұЩҶШҜ ЩҶШӘЩҲШ§ЩҶЩҶШҜ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ ШұШ§ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШЁШЁЫҢЩҶЩҶШҜ. вҖ«Chromium ШЁШұШ§ЫҢ Ш¬ШіШӘШ¬ЩҲЫҢ ЩҶШҙШ§ЩҶЫҢ IP ШіШ§ЫҢШӘ ШҜШұ ШіШ§ЩҶШ§ШҜ (ШіЫҢШіШӘЩ… ЩҶШ§Щ…ЪҜШ°Ш§ШұЫҢ ШҜШ§Щ…ЩҶЩҮ) Ш§ШІ Ш§ШӘШөШ§Щ„ Ш§ЫҢЩ…ЩҶЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="7810005234485217901">Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ШұШ§ ШЁШұШ§ЫҢ ШҜШіШӘШұШіЫҢ ШўШіШ§ЩҶ ШіЩҶШ¬Ш§ЩӮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="7828947555739565424">вҖҸШҜШұШӯШ§Щ„вҖҢШӯШ§Ш¶Шұ ЫҢЪ© ЩҶЩ…Ш§ЫҢЩҮ Chromium ШЁШ§ Ш§ЫҢЩҶ ШӯШіШ§ШЁ ШҜШұ Ш§ЫҢЩҶ ШҜШіШӘЪҜШ§ЩҮ ЩҲШ¬ЩҲШҜ ШҜШ§ШұШҜ</translation>
<translation id="7845233973568007926">ШЁШ§ШЁШӘ ЩҶШөШЁ Ш§ШІ ШҙЩ…Ш§ ШіЩҫШ§ШівҖҢЪҜШІШ§ШұЫҢЩ…. ЩӮШЁЩ„вҖҢШ§ШІ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ <ph name="BUNDLE_NAME" />ШҢ ШЁШ§ЫҢШҜ ШұШ§ЫҢШ§ЩҶЩҮ ШұШ§ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="7859018312476869945">вҖҸЩҲЩӮШӘЫҢ ШҜШұ ЩҶЩҲШ§Шұ ЩҶШҙШ§ЩҶЫҢ ЫҢШ§ ЪҶШ§ШұЪҜЩҲШҙ Ш¬ШіШӘШ¬ЩҲ ШӘШ§ЫҢЩҫ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ Chromium ШўЩҶЪҶЩҮ ШӘШ§ЫҢЩҫ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШұШ§ ШЁЩҮ Щ…ЩҲШӘЩҲШұ Ш¬ШіШӘШ¬ЩҲЫҢ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШҙЩ…Ш§ Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШӘШ§ ЩҫЫҢШҙЩҶЩҮШ§ШҜЩҮШ§ЫҢ ШЁЩҮШӘШұЫҢ ШҜШұЫҢШ§ЩҒШӘ Ъ©ЩҶШҜ. Ш§ЫҢЩҶ ЩҲЫҢЪҳЪҜЫҢ ШҜШұ В«ШӯШ§Щ„ШӘ ЩҶШ§ШҙЩҶШ§ШіВ» Ш®Ш§Щ…ЩҲШҙ Ш§ШіШӘ.</translation>
<translation id="7867198900892795913">вҖҸChromium ШЁЩҮ Ш¬ШҜЫҢШҜШӘШұЫҢЩҶ ЩҶШіШ®ЩҮ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ЩҶШҙШҜШҢ ШЁЩҶШ§ШЁШұШ§ЫҢЩҶ ЩӮШ§ШЁЩ„ЫҢШӘвҖҢЩҮШ§ЫҢ Ш¬ШҜЫҢШҜ ЩҲ ШұЩҒШ№ Ш§ШҙЪ©Ш§Щ„вҖҢЩҮШ§ЫҢ Ш§Щ…ЩҶЫҢШӘЫҢ ШұШ§ ЩҶШҜШ§ШұЫҢШҜ.</translation>
<translation id="7872446069773932638">ШҜШұШӯШ§Щ„ ШЁШ§ШұЪҜЫҢШұЫҢвҖҰ <ph name="SECONDS" /> Ш«Ш§ЩҶЫҢЩҮ ШЁШ§ЩӮЫҢ Щ…Ш§ЩҶШҜЩҮ Ш§ШіШӘ</translation>
<translation id="7888981273428720788">вҖҸШӘЩҶШёЫҢЩ… Chromium ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶</translation>
<translation id="7934340546140346950">вҖҸвҖ«Chromium Ш§ШӘШөШ§Щ„вҖҢЩҮШ§ЫҢ ЩҶШ§Ш§Щ…ЩҶ ШұШ§ ШҜШұШөЩҲШұШӘ Ш§Щ…Ъ©Ш§ЩҶ ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШЁЩҮ HTTPS Ш§ШұШӘЩӮШ§ Щ…ЫҢвҖҢШҜЩҮШҜ</translation>
<translation id="7935734571048689933">вҖҸвҖ«Chromium ШӘШӯШӘвҖҢЩ…ШҜЫҢШұЫҢШӘ Ш§ШіШӘ</translation>
<translation id="7937630085815544518">вҖҸШҙЩ…Ш§ ШЁШ№ЩҶЩҲШ§ЩҶ <ph name="USER_EMAIL_ADDRESS" /> ЩҲШ§ШұШҜ ШіЫҢШіШӘЩ… Chromium ШҙШҜЩҮвҖҢШ§ЫҢШҜ. Щ„Ш·ЩҒШ§ЩӢ ШЁШұШ§ЫҢ ЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Щ…Ш¬ШҜШҜ Ш§ШІ ЩҮЩ…Ш§ЩҶ ШӯШіШ§ШЁ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="7975919845073681630">вҖҸШ§ЫҢЩҶ ЩҶШөШЁ Ш«Ш§ЩҶЩҲЫҢЩҮ Chromium Ш§ШіШӘ ЩҲ ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ШӘШ§ЩҶ ШҙЩҲШҜ.</translation>
<translation id="7997934263947464652">вҖҸШ§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ШҢ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ШҢ ЩҲ ШІЩ…ЫҢЩҶЩҮвҖҢЩҮШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘЫҢ Ш§ШІ Щ…ЩҶШ§ШЁШ№ ЩҶШ§ШҙЩҶШ§Ш®ШӘЩҮ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ ШЁЩҮ ШҜШіШӘЪҜШ§ЩҮШӘШ§ЩҶ ШўШіЫҢШЁ ШЁШұШіШ§ЩҶЩҶШҜ. Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶвҖҢЩҮШ§ ШұШ§ ЩҒЩӮШ· Ш§ШІ <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ЩҶШөШЁ Ъ©ЩҶЫҢШҜ</translation>
<translation id="8010081455002666927">ШҙЩҶШ§ШіШ§ЫҢЫҢ Ш®ЩҲШҜЪ©Ш§Шұ</translation>
<translation id="8013436988911883588">вҖҸЩҲЩӮШӘЫҢ Chromium ШҜШіШӘШұШіЫҢ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜШҢ ЩҲШЁвҖҢШіШ§ЫҢШӘвҖҢЩҮШ§ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ Щ…Ш¬ЩҲШІ ШҜШіШӘШұШіЫҢ ШҜШұШ®ЩҲШ§ШіШӘ Ъ©ЩҶЩҶШҜ.</translation>
<translation id="80471789339884597">ШЁШ§ШЁШӘ ЩҶШөШЁ Ш§ШІ ШҙЩ…Ш§ ШіЩҫШ§ШівҖҢЪҜШІШ§ШұЫҢЩ…. ЩӮШЁЩ„вҖҢШ§ШІ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ <ph name="BUNDLE_NAME" />ШҢ ШЁШ§ЫҢШҜ ЩҮЩ…ЩҮ Щ…ШұЩҲШұЪҜШұЩҮШ§ ШұШ§ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8054112667659782652">Щ…ЫҢШ§ЩҶвҖҢШЁШұ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ЩҮЩ…ЫҢШҙЩҮ ЩҶШҙШ§ЩҶ ШҜШ§ШҜЩҮ ШҙЩҲШҜ</translation>
<translation id="80790299200510644">Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұ</translation>
<translation id="8086881907087796310">ЩҶШөШЁ Ш§ЩҶШ¬Ш§Щ… ЩҶШҙШҜ ШІЫҢШұШ§ ШұШ§ЫҢШ§ЩҶЩҮ ШҙЩ…Ш§ ШЁШ§ ШӯШҜШ§ЩӮЩ„ ШҙШұШ§ЫҢШ· ШіШ®ШӘвҖҢШ§ЩҒШІШ§ШұЫҢ Щ…Ш·Ш§ШЁЩӮШӘ ЩҶШҜШ§ШұШҜ.</translation>
<translation id="8096472344908884505"><ph name="PAGE_TITLE" /> - Google Chrome for Testing</translation>
<translation id="8105840573057009683">вҖҸChromium ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ШЁЩҮ Ш§Ш¬Ш§ШІЩҮ Щ…Ъ©Ш§ЩҶ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="8118331347066725040">ШҜШұШЁШ§ШұЩҮ Ш¬ШіШӘШ¬ЩҲ ШЁШ§ В«Щ„ЩҶШІВ»ШҢ ШЁШ§ШІШ®ЩҲШұШҜ Ш§ШұШіШ§Щ„ Ъ©ЩҶЫҢШҜ</translation>
<translation id="8133124826068723441">вҖҸChromiumOS ЩҶШӘЩҲШ§ЩҶШіШӘ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ Ъ©ЩҶШҜ ШІЫҢШұШ§ В«ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢВ» ШЁШұШ§ЫҢ ШҜШ§Щ…ЩҶЩҮ ШҙЩ…Ш§ ШҜШұШҜШіШӘШұШі ЩҶЫҢШіШӘ.</translation>
<translation id="813913629614996137">ШҜШұШӯШ§Щ„ Щ…ЩӮШҜШ§ШұШҜЩҮЫҢ Ш§ЩҲЩ„ЫҢЩҮвҖҰ</translation>
<translation id="8166782796394721554">вҖҸШұЩҲШҙЩҶ Ъ©ШұШҜЩҶ Щ…ШӯШ§ЩҒШёШӘ ШЁЫҢШҙШӘШұ ШҜШұ Щ…ЩҲШӘЩҲШұ WebAssembly ЩҲ Ш¬Ш§ЩҲШ§ Ш§ШіЪ©ШұЫҢЩҫШӘ Chromium</translation>
<translation id="81770708095080097">вҖҸШ§ЫҢЩҶ ЩҒШ§ЫҢЩ„ Ш®Ш·ШұЩҶШ§Ъ© Ш§ШіШӘШҢ ШЁЩҶШ§ШЁШұШ§ЫҢЩҶ Chromium ШўЩҶ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜЩҮ Ш§ШіШӘ.</translation>
<translation id="8221491193165283816">Щ…Ш№Щ…ЩҲЩ„Ш§ЩӢ Ш§Ш№Щ„Ш§ЩҶвҖҢЩҮШ§ ШұШ§ Щ…ШіШҜЩҲШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ. ШЁШұШ§ЫҢ Ш§ЫҢЩҶЪ©ЩҮ Ш§Ш¬Ш§ШІЩҮ ШҜЩҮЫҢШҜ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ Ш§Ш№Щ„Ш§ЩҶ ШЁЩҒШұШіШӘШҜШҢ Ш§ЫҢЩҶШ¬Ш§ ШұШ§ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8223363452568144035">вҖҸШЁШұШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜЩҲШұШЁЫҢЩҶШҢ ШҜШұ <ph name="BEGIN_LINK" />ШӘЩҶШёЫҢЩ…Ш§ШӘ ШіЫҢШіШӘЩ…<ph name="END_LINK" /> ШЁЩҮ Chromium ШҜШіШӘШұШіЫҢ ШҜЩҮЫҢШҜ</translation>
<translation id="8232193495299001329">вҖҸвҖ«Chromium ЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ Щ…ЩҶШЁШ№ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШұШ§ ШӘШЈЫҢЫҢШҜ Ъ©ЩҶШҜ ЩҲ Ш§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҶШ§Ш§Щ…ЩҶ ШЁШ§ШҙШҜ. ШўЩҶ ШұШ§ Ш§ШІ Chromium ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ ШӘШ§ ШҜЫҢЪҜШұ ЩҶШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ ШұШ§ (Ш§ШІШ¬Щ…Щ„ЩҮ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ШҙШ®ШөЫҢ) ШҜШұ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШЁШЁЫҢЩҶШҜ ЩҲ ШӘШәЫҢЫҢШұ ШҜЩҮШҜ.</translation>
<translation id="8248265253516264921">вҖҸШ§ЪҜШұ ШӘШөЩҲЫҢШұЫҢ ШӘЩҲШ¶ЫҢШӯ Щ…ЩҒЫҢШҜЫҢ ЩҶШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜШҢ Chromium ШӘЩҲШ¶ЫҢШӯЫҢ ШЁШұШ§ЫҢ ШҙЩ…Ш§ Ш§ШұШ§ШҰЩҮ Ш®ЩҲШ§ЩҮШҜ Ъ©ШұШҜ. ШЁШұШ§ЫҢ Ш§ЫҢШ¬Ш§ШҜ ШӘЩҲШ¶ЫҢШӯШ§ШӘШҢ ШӘШөШ§ЩҲЫҢШұ ШЁЩҮ Google Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢШҙЩҲШҜ. ЩҮШұЩҲЩӮШӘ Ш®ЩҲШ§ШіШӘЫҢШҜ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ Ш§ЫҢЩҶ ЪҜШІЫҢЩҶЩҮ ШұШ§ ШҜШұ ШӘЩҶШёЫҢЩ…Ш§ШӘ Ш®Ш§Щ…ЩҲШҙ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8254601181414348851">вҖҸШҜШұ ЩҶЩ…Ш§ЫҢЩҮ Ш¬ШҜЫҢШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҹ</translation>
<translation id="8286943863733751221">вҖҸвҖ«Chromium ШҜШұШЁШ§ШұЩҮ ШіШ§ЫҢШӘвҖҢЩҮШ§ ЩҲ ШЁШ§ШұЪҜЫҢШұЫҢвҖҢЩҮШ§ЫҢ ЩҶШ§Ш§Щ…ЩҶ <ph name="BEGIN_LINK" />ШЁЩҮ ШҙЩ…Ш§ ЩҮШҙШҜШ§Шұ Щ…ЫҢвҖҢШҜЩҮШҜ<ph name="END_LINK" /></translation>
<translation id="8313851650939857356">Ш®Ш·Ш§ЫҢ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ: <ph name="STARTUP_ERROR" />.</translation>
<translation id="8318772038038596122">вҖҸШ§ЪҜШұ <ph name="TIMEOUT_DURATION" /> Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҶШҙЩҲШҜШҢ ШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШўЩҶ ШұШ§ Щ…ЫҢвҖҢШЁЩҶШҜШҜ.</translation>
<translation id="8321888067342493336">Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ШӘШөЩҲЫҢШұ</translation>
<translation id="8326785589245660814">вҖҸШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium Ш°Ш®ЫҢШұЩҮвҖҢШҙШҜЩҮ ШҜШұ ШӯШіШ§ШЁШӘШ§ЩҶ ШұШ§ ЩҫШ§Ъ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="8330519371938183845">вҖҸШЁШұШ§ЫҢ ЩҮЩ…ЪҜШ§Щ…вҖҢШіШ§ШІЫҢ ЩҲ ШҙШ®ШөЫҢвҖҢШіШ§ШІЫҢ Chromium ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="8340674089072921962">вҖҸ<ph name="USER_EMAIL_ADDRESS" /> ЩӮШЁЩ„Ш§ЩӢ Ш§ШІ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ШұШҜ</translation>
<translation id="8359544530202147897">вҖҸШЁШұШ§ЫҢ Ш§ШҜШ§Щ…ЩҮ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium Ш°Ш®ЫҢШұЩҮвҖҢШҙШҜЩҮ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ (<ph name="ACCOUNT_EMAIL" />)ШҢвҖҸ Chromium ШұШ§ ШЁЩҮвҖҢШұЩҲШІ Ъ©ЩҶЫҢШҜ</translation>
<translation id="8360718212975266891">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ШўШӘЫҢ ChromiumШҢ ШЁШ§ЫҢШҜ Windows 10 ЫҢШ§ ШЁШ§Щ„Ш§ШӘШұ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЫҢШҜ. Ш§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ Ш§ШІ Windows 8 Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="8362914115861174987">ШӘШұШ¬Щ…ЩҮ ШЁЩҮ</translation>
<translation id="8370517070665726704">вҖҸШӯЩӮ ЩҶШҙШұ <ph name="YEAR" /> Google LLC.вҖҺ Ъ©Щ„ЫҢЩҮ ШӯЩӮЩҲЩӮ Щ…ШӯЩҒЩҲШё Ш§ШіШӘ.</translation>
<translation id="8372327902843331129">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ЩҲ Щ…ЩҲШ§ШұШҜ ШҜЫҢЪҜШұ ШҜШұ ЩҮЩ…ЩҮ ШҜШіШӘЪҜШ§ЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶШҢ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ. ШЁШ№ШҜШ§ШІ Ш§ЫҢЩҶЪ©ЩҮ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ ШҙШҜЫҢШҜШҢ Ш§ЫҢЩҶ ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» ШҙЩ…Ш§ Ш°Ш®ЫҢШұЩҮ Ш®ЩҲШ§ЩҮШҜ ШҙШҜ.</translation>
<translation id="837460953767177950">вҖҸШіЩҫШі ШЁШ§ЫҢШҜ Chromium ШұШ§ ШЁШ§ШІШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8397248745433792218">вҖҸвҖ«Chromium ШӘЩҲШөЫҢЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШўЩҶ ШұШ§ ШЁШұШҜШ§ШұЫҢШҜ. <ph name="BEGIN_LINK" />ШҜШұШЁШ§ШұЩҮ Ш§ЩҒШІЩҲЩҶЩҮвҖҢЩҮШ§ЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶЫҢвҖҢШҙШҜЩҮ ШЁЫҢШҙШӘШұ ШЁШҜШ§ЩҶЫҢШҜ<ph name="END_LINK" /></translation>
<translation id="8401454788024434101">вҖҸШ§ЫҢЩҶ Ш§ЩҒШІЩҲЩҶЩҮ ШӘЩҲШіШ· ШӘЩҲШіШ№ЩҮвҖҢШҜЩҮЩҶШҜЩҮ ШўЩҶ Щ„ШәЩҲ Ш§ЩҶШӘШҙШ§Шұ ШҙШҜЩҮ Ш§ШіШӘ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЩҶШ§Ш§Щ…ЩҶ ШЁШ§ШҙШҜ. ШўЩҶ ШұШ§ Ш§ШІ Chromium ШӯШ°ЩҒ Ъ©ЩҶЫҢШҜ ШӘШ§ ШҜЫҢЪҜШұ ЩҶШӘЩҲШ§ЩҶШҜ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ (Ш§ШІШ¬Щ…Щ„ЩҮ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ШҙШ®ШөЫҢ) ШұШ§ ШҜШұ ШіШ§ЫҢШӘвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ШІШҜЫҢШҜ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ШЁШЁЫҢЩҶШҜ ЩҲ ШӘШәЫҢЫҢШұ ШҜЩҮШҜ.</translation>
<translation id="8417404458978023919">{0,plural, =1{вҖҸChromium ШұШ§ ШёШұЩҒ ЫҢЪ© ШұЩҲШІ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ}one{вҖҸChromium ШұШ§ ШёШұЩҒ # ШұЩҲШІ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ}other{вҖҸChromium ШұШ§ ШёШұЩҒ # ШұЩҲШІ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Ъ©ЩҶЫҢШҜ}}</translation>
<translation id="8438543370129609977">вҖҸЩҲЩӮШӘЫҢ Ш§ШІ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜШҢ Ш№ЩҶЩҲШ§ЩҶШҢ ЩҶШҙШ§ЩҶЫҢ ЩҲШЁШҢ ЩҲ Щ…ШӯШӘЩҲШ§ЫҢ ШөЩҒШӯЩҮ (Ш§ШІШ¬Щ…Щ„ЩҮ ЩҒШ§ЫҢЩ„вҖҢЩҮШ§ЫҢ PDF) ШЁЩҮ ШіШұЩҲШұ Ш§ШұШіШ§Щ„ Щ…ЫҢвҖҢШҙЩҲШҜ. <ph name="LEARN_MORE" /></translation>
<translation id="8453117565092476964">вҖҸШЁШ§ЫҢЪҜШ§ЩҶЫҢ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ Ш®ШұШ§ШЁ ЫҢШ§ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ. Щ„Ш·ЩҒШ§ЩӢ Chromium ШұШ§ ШҜЩҲШЁШ§ШұЩҮ ШұШ§ ШЁШ§ШұЪҜЫҢШұЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8458614432758743027">вҖҸChromium ШЁЩҮ Windows 10 ЫҢШ§ ШЁШ§Щ„Ш§ШӘШұ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ.</translation>
<translation id="8463672209299734063">вҖҸШ§Ш®ШӘЫҢШ§ШұЫҢ: ШЁШ§ Ш§ШұШіШ§Щ„ Ш®ЩҲШҜЪ©Ш§Шұ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Ш§ШіШӘЩҒШ§ШҜЩҮ ЩҲ Ш№ЫҢШЁвҖҢЫҢШ§ШЁЫҢ ШЁЩҮ GoogleШҢ ШЁЩҮ ШЁЩҮШЁЩҲШҜ ЩҲЫҢЪҳЪҜЫҢвҖҢЩҮШ§ ЩҲ Ш№Щ…Щ„Ъ©ШұШҜ ChromiumOS Ъ©Щ…Ъ© Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8471947159125090285">вҖҸШЁШұШ§ЫҢ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҶ ШҜШ§ШҜЩҮвҖҢЩҮШ§ЫҢ Chromium ШҜШұ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ ЩҲ Ш§ШіШӘЩҒШ§ШҜЩҮ Ъ©ШұШҜЩҶ Ш§ШІ ШўЩҶвҖҢЩҮШ§ШҢ ЩҮЩҲЫҢШӘШӘШ§ЩҶ ШұШ§ ШЁЩҮвҖҢШӘШЈЫҢЫҢШҜ ШЁШұШіШ§ЩҶЫҢШҜ</translation>
<translation id="8493179195440786826">вҖҸЩҶШіШ®ЩҮ Chromium ЩӮШҜЫҢЩ…ЫҢ Ш§ШіШӘ</translation>
<translation id="8522801943730206384">вҖҸвҖ«Chromium ШІЩ…Ш§ЩҶЫҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ Ъ©ЩҮ ШўЩҶвҖҢЩҮШ§ ШұШ§ Ш°Ш®ЫҢШұЩҮ Ъ©ШұШҜЩҮ ШЁШ§ШҙЫҢШҜ</translation>
<translation id="8550334526674375523">Ш§ЫҢЩҶ ЩҶЩ…Ш§ЫҢЩҮ Ъ©Ш§ШұЫҢ Ъ©Ш§Щ…Щ„Ш§ЩӢ Щ…Ш¬ШІШ§ Ш§ШІ ЩҶЩ…Ш§ЫҢЩҮ ШҙШ®ШөЫҢвҖҢШӘШ§ЩҶ Ш§ШіШӘ.</translation>
<translation id="8555465886620020932">Ш®Ш·Ш§ЫҢ ШіШұЩҲЫҢШі: <ph name="SERVICE_ERROR" />.</translation>
<translation id="8556420416730706394">Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ В«Ш¬ШіШӘШ¬ЩҲЫҢ ШӘШөЩҲЫҢШұВ» ШұШ§ ШЁШұШ§ЫҢ ШҜШіШӘШұШіЫҢ ШўШіШ§ЩҶ ШіЩҶШ¬Ш§ЩӮ Ъ©ЩҶЫҢШҜШӣ ШұЩҲЫҢ ШҜЪ©Щ…ЩҮ В«ШіЩҶШ¬Ш§ЩӮ Ъ©ШұШҜЩҶВ» ШҜШұ ШЁШ§Щ„Ш§ЫҢ ЩҫШ§ЩҶЩ„ Ъ©ЩҶШ§ШұЫҢ Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="856656450041460113">Ш¬ШіШӘШ¬ЩҲЫҢ ЩҒЩҮШұШіШӘ ШІШЁШ§ЩҶвҖҢЩҮШ§</translation>
<translation id="8568283329061645092">вҖҸЩҲЩӮШӘЫҢ ШЁШ§ В«ШӯШіШ§ШЁ GoogleВ» Ш®ЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… ЩҲШ§ШұШҜ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҢ Chromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶШҜ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ЫҢШӘШ§ЩҶ ШұШ§ ШЁШұШұШіЫҢ Ъ©ЩҶШҜ</translation>
<translation id="8576826849825683917">вҖҸЪҶЩҶШҜЫҢЩҶ ШіШ§ШІЩ…Ш§ЩҶ Chromium ШұШ§ Щ…ШҜЫҢШұЫҢШӘ Щ…ЫҢвҖҢЪ©ЩҶЩҶШҜ</translation>
<translation id="8586442755830160949">вҖҸШӯЩӮ ЩҶШҙШұ <ph name="YEAR" /> ЩҶЩҲЫҢШіЩҶШҜЪҜШ§ЩҶ Chromium. Ъ©Щ„ЫҢЩҮ ШӯЩӮЩҲЩӮ Щ…ШӯЩҒЩҲШё Ш§ШіШӘ.</translation>
<translation id="8601359445272098721">Ш¬ШҜЫҢШҜ! ШЁШ§ Ш§ЩҶШӘШ®Ш§ШЁ ШҜЪ©Щ…ЩҮ В«ШӘШұШ¬Щ…ЩҮ Ъ©ШұШҜЩҶ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙВ»ШҢ Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЫҢШҜ ЩҮЩ… ЩҶЩҲШҙШӘШ§Шұ ЩҲ ЩҮЩ… ШӘШөШ§ЩҲЫҢШұ ШұЩҲЫҢ ШөЩҒШӯЩҮвҖҢЩҶЩ…Ш§ЫҢШҙ ШұШ§ ШӘШұШ¬Щ…ЩҮ Ъ©ЩҶЫҢШҜ</translation>
<translation id="8619360774459241877">вҖҸШҜШұШӯШ§Щ„ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ ChromiumвҖҰ</translation>
<translation id="8621669128220841554">вҖҸШЁЩҮ ШҜЩ„ЫҢЩ„ Ш®Ш·Ш§ЫҢ ЩҶШ§Щ…ШҙШ®ШөШҢ ЩҶШөШЁ ЩҶШ§Щ…ЩҲЩҒЩӮ ШЁЩҲШҜ. Щ„Ш·ЩҒШ§ЩӢ ШҜЩҲШЁШ§ШұЩҮ Chromium ШұШ§ ШЁШ§ШұЪҜЫҢШұЫҢ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8648201657708811153">вҖҸЩҶЩ…ЫҢвҖҢШӘЩҲШ§ЩҶ Google Chrome for Testing ШұШ§ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ Щ…ШұЩҲШұЪҜШұ ЩҫЫҢШҙвҖҢЩҒШұШ¶ ШӘЩҶШёЫҢЩ… Ъ©ШұШҜ.</translation>
<translation id="8697124171261953979">вҖҸШ§ЫҢЩҶ ШЁШұЩҶШ§Щ…ЩҮ ЩҮЩ…ЪҶЩҶЫҢЩҶ ШөЩҒШӯЩҮвҖҢШ§ЫҢ ШұШ§ Ъ©ЩҮ ЩҮЩҶЪҜШ§Щ… ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Chromium ЫҢШ§ Ш¬ШіШӘШ¬ЩҲ Ш§ШІ Omnibox ЩҶШҙШ§ЩҶ ШҜШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜШҢ Ъ©ЩҶШӘШұЩ„ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="8704119203788522458">вҖҸШ§ЫҢЩҶ Chromium ШҙЩ…Ш§ШіШӘ</translation>
<translation id="8719993436687031146">вҖҸШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҹ</translation>
<translation id="878572486461146056">Ш®Ш·Ш§ЫҢ ЩҶШөШЁ: ШіШұЩҫШұШіШӘ ШҙШЁЪ©ЩҮ ШҙЩ…Ш§ В«Ш®Ш·вҖҢЩ…ШҙЫҢ ЪҜШұЩҲЩҮЫҢВ» Ш§Ш№Щ…Ш§Щ„ Ъ©ШұШҜЩҮ Ш§ШіШӘ Ъ©ЩҮ Ш§ШІ ЩҶШөШЁ Ш¬Щ„ЩҲЪҜЫҢШұЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ: <ph name="INSTALL_ERROR" /></translation>
<translation id="8796602469536043152">вҖҸChromium ШЁЩҮ Щ…Ш¬ЩҲШІ ШҜШіШӘШұШіЫҢ ШЁЩҮ ШҜЩҲШұШЁЫҢЩҶ ЩҲ Щ…ЫҢЪ©ШұЩҲЩҒЩҲЩҶ ШЁШұШ§ЫҢ Ш§ЫҢЩҶ ШіШ§ЫҢШӘ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜ</translation>
<translation id="8818550178040858407">вҖҸШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ Щ…ЫҢвҖҢШҙЩҲЫҢШҜШҹ</translation>
<translation id="8826492472752484139">ШұЩҲЫҢ В«Щ…ШҜЫҢШұ ЪҜШ°ШұЩҲШ§ЪҳЩҮВ» Ъ©Щ„ЫҢЪ© Ъ©ЩҶЫҢШҜ</translation>
<translation id="8833697763442816810">вҖҸШіЫҢШіШӘЩ… ChromiumOS</translation>
<translation id="8852026904190808918">вҖҸШ§ЫҢЩҶ ШІШЁШ§ЩҶ ШЁШұШ§ЫҢ ЩҶЩ…Ш§ЫҢШҙ Щ…ЩҶЩҲЩҮШ§ШҢ ШӘЩҶШёЫҢЩ…Ш§ШӘШҢ ЩҮШҙШҜШ§ШұЩҮШ§ШҢ ЩҲ ЩҶЩҲШҙШӘШ§ШұЩҮШ§ЫҢ ШҜЫҢЪҜШұ ШҜШұ Chromium Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢШҙЩҲШҜ</translation>
<translation id="8862326446509486874">ШҙЩ…Ш§ ШӯЩӮЩҲЩӮ Щ„Ш§ШІЩ… ШЁШұШ§ЫҢ ЩҶШөШЁ ШҜШұ ШіШ·Шӯ ШіЫҢШіШӘЩ… ШұШ§ ЩҶШҜШ§ШұЫҢШҜ. ШҜЩҲШЁШ§ШұЩҮ ШЁЩҮвҖҢШ№ЩҶЩҲШ§ЩҶ ШіШұЩҫШұШіШӘ ЩҶШөШЁвҖҢЪ©ЩҶЩҶШҜЩҮ ШұШ§ Ш§Ш¬ШұШ§ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8876044221123442390">вҖҸШ§ЩҒШІЩҲШҜЩҶ ЩҶЩ…Ш§ЫҢЩҮ Chromium</translation>
<translation id="8880203542552872219">вҖҸШҜШұ Ш§ЫҢЩҶ ШөЩҲШұШӘШҢ Щ„Ш·ЩҒШ§ЩӢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Ш°Ш®ЫҢШұЩҮвҖҢШҙШҜЩҮ ШҜШұ Chromium ШұШ§ ЩҲЫҢШұШ§ЫҢШҙ Ъ©ЩҶЫҢШҜ ШӘШ§ ШЁШ§ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Ш¬ШҜЫҢШҜШӘШ§ЩҶ Щ…Ш·Ш§ШЁЩӮШӘ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙШҜ.</translation>
<translation id="8891709362986793894">вҖҸШіШ§ШІЩ…Ш§ЩҶШӘШ§ЩҶ ШҙЩ…Ш§ ШұШ§ Щ…Щ„ШІЩ… Щ…ЫҢвҖҢЪ©ЩҶШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҲШ§ШұШҜ ШҙЩҲЫҢШҜ</translation>
<translation id="8907580949721785412">вҖҸChromium ШҜШұ ШӯШ§Щ„ ШӘЩ„Ш§Шҙ ШЁШұШ§ЫҢ ЩҶШҙШ§ЩҶ ШҜШ§ШҜЩҶ ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ШіШӘ. ШЁШұШ§ЫҢ Ш§Ш¬Ш§ШІЩҮ ШЁЩҮ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЪҜШ°ШұЩҲШ§ЪҳЩҮ Windows Ш®ЩҲШҜ ШұШ§ ШӘШ§ЫҢЩҫ Ъ©ЩҶЫҢШҜ.</translation>
<translation id="8931379085695076764">вҖҸChromium Щ…ЫҢвҖҢШӘЩҲШ§ЩҶЩҶШҜ Ш№Щ„Ш§ЫҢЩӮШӘШ§ЩҶ ШұШ§ ШЁШұШ§ШіШ§Ші ШіШ§ШЁЩӮЩҮ Щ…ШұЩҲШұ ЪҶЩҶШҜ ЩҮЩҒШӘЩҮ ЪҜШ°ШҙШӘЩҮ ШЁШұШўЩҲШұШҜ Ъ©ЩҶШҜ. Ш§ЫҢЩҶ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Ш§ШІ ШҜШіШӘЪҜШ§ЩҮШӘШ§ЩҶ Ш®Ш§ШұШ¬ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ.</translation>
<translation id="8941642502866065432">вҖҸШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Chromium Ш§Щ…Ъ©Ш§ЩҶвҖҢЩҫШ°ЫҢШұ ЩҶЫҢШіШӘ</translation>
<translation id="897581876605952338">вҖҸЩҶШҙШ§ЩҶвҖҢЩҲШ§ШұЩҮ Chromium Enterprise</translation>
<translation id="8986207147630327271">ШЁШ§ Ш§ЫҢЩҶ Ъ©Ш§ШұШҢ ЩҶЩ…Ш§ЫҢЩҮ Ъ©Ш§ШұЫҢ ШұШ§ ШЁЩҮ Ш§ЫҢЩҶ Щ…ШұЩҲШұЪҜШұ Ш§Ш¶Ш§ЩҒЩҮ Щ…ЫҢвҖҢЪ©ЩҶЫҢШҜ ЩҲ ЩҒЩӮШ· Ъ©ЩҶШӘШұЩ„ ЩҶЩ…Ш§ЫҢЩҮ Ъ©Ш§ШұЫҢ ШұШ§ ШҜШұШ§Ш®ШӘЫҢШ§Шұ ШіШұЩҫШұШіШӘ ЩӮШұШ§Шұ Щ…ЫҢвҖҢШҜЩҮЫҢШҜ.</translation>
<translation id="8988036198400390003">вҖҸЩ…ШҜЫҢШұЫҢШӘ ЩҶЩ…Ш§ЫҢЩҮвҖҢЩҮШ§ЫҢ Chromium</translation>
<translation id="9019929317751753759">вҖҸШЁШұШ§ЫҢ Ш§ЫҢЩ…ЩҶвҖҢШӘШұ Ъ©ШұШҜЩҶ ChromiumШҢ Ш§ЩҒШІЩҲЩҶЩҮ ШІЫҢШұ ШұШ§ Ъ©ЩҮ ШҜШұ <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ЩҒЩҮШұШіШӘ ЩҶШҙШҜЩҮ Ш§ШіШӘ ЩҲ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШЁШҜЩҲЩҶ Ш§Ш·Щ„Ш§Ш№ ШҙЩ…Ш§ Ш§Ш¶Ш§ЩҒЩҮ ШҙШҜЩҮ ШЁШ§ШҙШҜШҢ ШәЫҢШұЩҒШ№Ш§Щ„ Ъ©ШұШҜЫҢЩ….</translation>
<translation id="9022552996538154597">вҖҸЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium</translation>
<translation id="904366664621834601">вҖҸвҖ«Chromium Ш§ЫҢЩҶ ШЁШ§ШұЪҜЫҢШұЫҢ ШұШ§ Щ…ШіШҜЩҲШҜ Ъ©ШұШҜ ШІЫҢШұШ§ ЩҒШ§ЫҢЩ„ ШЁШ§ЫҢЪҜШ§ЩҶЫҢ ШӯШ§ЩҲЫҢ ЩҒШ§ЫҢЩ„вҖҢЩҮШ§ЫҢ ШҜЫҢЪҜШұЫҢ Ш§ШіШӘ Ъ©ЩҮ Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ШЁШҜШ§ЩҒШІШ§Шұ ШЁШ§ШҙШҜ</translation>
<translation id="9062666675513499497">вҖҸЩҲШұЩҲШҜ ШЁЩҮ ШіЫҢШіШӘЩ… Chromium ЩҮЩҶЪҜШ§Щ… ЩҲШ§ШұШҜ ШҙШҜЩҶ ШЁЩҮ ШіЫҢШіШӘЩ… ШҜЫҢЪҜШұ ШіШұЩҲЫҢШівҖҢЩҮШ§ЫҢ Google</translation>
<translation id="9078733879136747090">вҖҸChromium ШЁЩҮвҖҢШ·ЩҲШұ Ш®ЩҲШҜЪ©Ш§Шұ ШЁШіШӘЩҮ ШҙШҜ</translation>
<translation id="9089354809943900324">вҖҸЩҶШіШ®ЩҮ Chromium ЩӮШҜЫҢЩ…ЫҢ Ш§ШіШӘ</translation>
<translation id="9093206154853821181">{0,plural, =1{вҖҸChromium ЫҢЪ© ШіШ§Ш№ШӘ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}one{вҖҸChromium # ШіШ§Ш№ШӘ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}other{вҖҸChromium # ШіШ§Ш№ШӘ ШҜЫҢЪҜШұ ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ Щ…ЫҢвҖҢШҙЩҲШҜ}}</translation>
<translation id="9106236359747881194">ЩҶЩҲШҙШӘШ§ШұЫҢ ШұШ§ ШЁШұШ§ЫҢ Ш¬ШіШӘШ¬ЩҲ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ</translation>
<translation id="9106612006984859720">вҖҸШЁШұШ§ЫҢ ШҜШұЫҢШ§ЩҒШӘ ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢвҖҢЩҮШ§ЫҢ ШўШӘЫҢ ChromiumШҢ ШЁШ§ЫҢШҜ Windows 10 ЫҢШ§ ШЁШ§Щ„Ш§ШӘШұ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЫҢШҜ. Ш§ЫҢЩҶ ШұШ§ЫҢШ§ЩҶЩҮ Ш§ШІ Windows 8.1 Ш§ШіШӘЩҒШ§ШҜЩҮ Щ…ЫҢвҖҢЪ©ЩҶШҜ.</translation>
<translation id="91086099826398415">вҖҸШЁШ§ШІ Ъ©ШұШҜЩҶ ЩҫЫҢЩҲЩҶШҜ ШҜШұ &amp;ШЁШұЪҜЩҮ Ш¬ШҜЫҢШҜ Chromium</translation>
