<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1026101648481255140">ОћОъОЕОџ ОЉОћОфОДОаОћ</translation>
<translation id="1029669172902658969">РђЈОћОцОбОюОћ ОъОЌОЊОЕ ОюОдОЋОеОџ ОбОЊОЏОЋОЪ Рђј&amp;ChromiumOS</translation>
<translation id="103359417695385097">РђЈРђФChromium ОъОЉОЎОЪ ОљОф ОћОўОцОАОЎОЮ ОўОЋОЉ ОЎОЋОфОе ОЋОЎОЏОЋОю ОюОъОюОљ ОљОЋОфОЮ ОљОЋОўОЋОъОўОЎОф ОъОћОе ОЎОЋОфОе. ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф.</translation>
<translation id="1040916596585577953">РђЈОюОцОЎ ОћОъОюОдОф Chromium, ОЏОЊОљОЎ ОюОЉОЊОЋОД ОљОф ОћОфОЋОАОБ ОћОќОћ</translation>
<translation id="1042552502243217427">РђЈОЏОЕОљОфОе ОъОЉОДОЕ ОюОўОбОЋОЪ ОъОеОљОЕ ОДОЎОЕОЋОеОЎОЮ ОЉОЊОБ ОЕОюОЋ ОЉОљОЋОцОЪ ОцОеОўОЎ, ОъОбОеОЏОф Chromium ОъОЕОфОъОЕОф ОЉОЕОеОфОЎ Google. ОЏОџ ОъОЋОАОфОеОф ОћОќОћОЋОф ОЕОюОџ ОъОћОљОфОе ОЕОаОўОбОЪ ОъОеОљОЕ, ОљОЉОю Google ОЎОЏОЋОюОћ ОюОЊОбОф ОљОЎОюОЋ ОљОфОеОЎОЮ ОаОўОбОаОЎОЮ ОъОеОљОЕ.</translation>
<translation id="1051793555070215510">ОъОЎОюОЋОЎ ОћОАОДОе ОћОќОћ ОЎОЎОДОЌ ОеОД ОЊОДОћ ОЋОЎОбОќОЋОе ОюОаОЋ ОюОЕОцОе ОљОф ОћОъОдОЉ ОћОцОеОўОЎ.</translation>
<translation id="1065672644894730302">ОюОљ ОћОЎОЎОфОћ ОљОцОЕОеОЋОф ОюОДОеОЋОљ ОљОф ОћОћОбОЊОцОЋОф ОЕОюОџ. ОЎОЎОфОЏОЪ ОЕОЌОюОД ОъОћОфОЏОЋОаОЋОф ОюОљ ОЎОћОЎОЋ ОќОъОЎОаОЋОф ОЋОЕОЎОаОЋОЎОЎОЮ ОЉОћОбОЊОцОЋОф ОюОљ ОЎОЎОЕОъОеОЋ.</translation>
<translation id="1083934481477628225">РђЈОћОћОЋОеОћ ОЕОюОџ ОћОЕОЉОЎОф ОЉ-Chromium ОљОф ОћОћОњОЊОеОћ 'ОћОеОЕОљОЋОф ОюОљОфОеОЎОЮ, ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОфОЋОАОцОЎОЮ'</translation>
<translation id="1104942323762546749">РђЈChromium ОеОЋОдОћ ОюОЎОЎОдОљ ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ. ОЎОЕ ОюОћОДОюОЎОЊ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ Ою-Windows ОЏОЊОЎ ОюОљОцОЕОе ОќОљОф.</translation>
<translation id="112640046208448578">ОљОцОЕОе ОюОаОАОЋОф ОюОќОћОЋОф ОЊОЉОеОЎОЮ ОљОЋ ОъОДОЋОъОЋОф ОЋОюОћОбОфОЎОД ОљОЋ ОюОфОеОњОЮ ОўОДОАОўОЎОЮ. ОЏОЕОъОЕОфОъОЕОЎОЮ ОЉОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф, ОдОЎОюОЋОЮ ОъОАОџ ОЕОю ОћОЊОБ ОаОЕОюОЌ ОюОЕОеОф. <ph name="LEARN_MORE" /></translation>
<translation id="113122355610423240">РђЈChromium ОъОЋОњОЊОе ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="1131805035311359397">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОЕОљОе ОћОАОЎОАОъОљОЋОф ОъОЋОњОаОЋОф ОъОцОаОЎ ОцОеОдОЋОф ОЉОљОЉОўОЌОф ОъОЎОЊОб ОЋОЉОбОЎОЋОф ОљОЉОўОЌОћ ОљОЌОеОЋОф, <ph name="BEGIN_LINK" />ОЎОЕ ОюОћОЎОЏОаОА Ою-Chromium<ph name="END_LINK" />.</translation>
<translation id="1153368717515616349">РђЈОюОЋОЌОдОЎОЮ ОбОю ОфОцОеОЎОў Chromium</translation>
<translation id="1157985233335035034">ОЕОцОЋОф ОљОЌОеОЋОаОЋОф</translation>
<translation id="1171831736360285680">РђЈОћОфОЋОАОБ ОћОфОЋОЋОАОБ ОбОю ОЎОЊОЎ <ph name="PARTNER_NAME" /> ОЋОЎОЏОЋОю ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chromium.

<ph name="EXTENSION_NAME" /></translation>
<translation id="1184145431117212167">РђЈОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЏОЎ ОћОњОеОАОћ ОЕОю Windows ОюОљ ОаОфОъОЏОф.</translation>
<translation id="1185134272377778587">РђЈОбОю Chromium</translation>
<translation id="1203500561924088507">ОфОЋОЊОћ ОЕОћОфОДОаОф. ОбОюОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОЊОцОЊОцОЪ ОюОцОаОЎ ОћОЕОЎОъОЋОЕ ОЉ-<ph name="BUNDLE_NAME" />.</translation>
<translation id="123265588161106468">РђЈОљОЌОеОЎ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОЋОЉОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ ОъОЌОЕОЉОЋОЪ Google ОЉ-Chromium. ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОљОцОЕОеОЋОф ОћОќОљОф, ОЏОЊОљОЎ ОюОбОЉОЋОе ОљОю "ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Chromium".</translation>
<translation id="1262876892872089030">РђЈОЉОќОъОЪ ОЕОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОюОљ ОћОЎОЎОфОћ ОцОбОЎОюОћ, ОћОфОцОаОћ ОќОЎОЏОеОЋОЪ ОЏОЊОЎ ОЕ-Chromium ОЎОъОЕОЎОџ ОюОцОбОЋОю ОЉОъОћОЎОеОЋОф. ОаОЎОфОЪ ОюОЉОЌОЋОе ОюОћОЌОеОЎОњ ОфОъОЎОЊ ОљОф ОћОљОфОе ОћОќОћ ОЏОЊОЎ ОЕОЎОЎОЕОљОе ОЉОъОдОЉ ОцОбОЎОю.</translation>
<translation id="1265577313130862557">РђЈChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОљОф ОЏОЎ ОћОДОЋОЉОЦ ОъОАОЋОЏОЪ</translation>
<translation id="126567311906253476">РђЈОЏОЕОаОЏОаОАОЎОЮ ОюОЕОЎОеОЋОфОЎ Google ОЏОъОЋ Gmail ОљОЋ YouTube ОбОЮ <ph name="USER_EMAIL" />, ОљОцОЕОе ОюОћОЎОЏОаОА ОљОЋОўОЋОъОўОЎОф Ою-Chromium ОбОЮ ОљОЋОфОЋ ОЌОЕОЉОЋОЪ</translation>
<translation id="1290883685122687410">ОЕОњОЎОљОћ ОЉОћОњОЊОеОћ: <ph name="METAINSTALLER_EXIT_CODE" />. <ph name="WINDOWS_ERROR" /></translation>
<translation id="1315551408014407711">РђЈОћОњОЊОеОф ОћОцОеОЋОцОЎОю ОћОЌОЊОЕ ОЕОюОџ ОЉ-Chromium</translation>
<translation id="1324107359134968521">РђЈОю-Chromium ОаОЊОеОЕОф ОњОЎОЕОћ Ою-Bluetooth ОЏОЊОЎ ОюОъОдОЋОљ 
 ОъОЏОЕОЎОеОЎ Bluetooth. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK" /></translation>
<translation id="1330562121671411446">ОќОЎОћОЋОЎ ОЕОцОћ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="1342274909142618978">РђЈОљОаОЎ ОеОЋОдОћ ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОњОЮ Оъ-Chromium (<ph name="URL" />)</translation>
<translation id="1345251407431278948">ОћОфОЏОЋОаОћ ОћОЋОдОъОЊОћ. ОъОбОЏОЕОЎОЋ ОљОцОЕОе ОюОњОЕОф ОюОЌОЎОцОЋОЕ ОћОфОъОЋОаОЋОф ОЊОеОџ ОћОЏОцОфОЋОе ОћОЌОЊОЕ ОЉОАОеОњОю ОћОЏОюОЎОЮ</translation>
<translation id="1356661055722410047">ОЌОЊОЕ! ОљОцОЕОе ОюОфОеОњОЮ ОўОДОАОў ОЋОфОъОЋОаОЋОф ОЉОъОАОџ</translation>
<translation id="1383876407941801731">ОЌОЎОцОЋОЕ</translation>
<translation id="1397530502368084401">РђЈ&amp;ОаОЎОћОЋОю ОћОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium</translation>
<translation id="1414495520565016063">РђЈОаОЏОаОАОф Ою-Chromium!</translation>
<translation id="141901961143729572">ОЏОљОЪ ОљОцОЕОе ОюОЕОфОБ ОљОф ОћОъОЌОЕОЉОЋОф ОЕОюОџ</translation>
<translation id="1465192221147974788">РђЈОЏОЊОЎ ОюОЕОфОБ ОљОф ОћОЌОюОЋОЪ, ОдОеОЎОџ ОюОљОцОЕОе ОћОДОюОўОф ОъОАОџ ОЉ-Chromium ОЉОДОўОб "ОћОњОЊОеОЋОф ОћОъОбОеОЏОф".</translation>
<translation id="1478370723027452770">РђЈОДОЉОюОф ОбОќОеОћ ОюОњОЉОЎ Chrome for Testing</translation>
<translation id="1496875977627931224">ОћОЎОЎ <ph name="USER_NAME" />,<ph name="LINE_BREAK" />ОљОЎОџ ОљОаОЎ ОЎОЏОЋОю ОюОбОќОЋОе ОюОџ?</translation>
<translation id="1497802159252041924">ОЕОњОЎОљОф ОћОфОДОаОћ: <ph name="INSTALL_ERROR" /></translation>
<translation id="1518627427551567882">ОћОЊОБ ОћОќОћ ОъОЋОњОЪ</translation>
<translation id="1524282610922162960">РђЈОЕОЎОфОЋОБ ОЏОеОўОЎОАОЎОЎОф Chromium</translation>
<translation id="154404805518949443">РђЈОЏОаОЎОАОћ Ою-Chromium</translation>
<translation id="1547469039832541117">ОАОЎОЋОЮ ОћОъОЕОЎОъОћ ОћОъОЋОЊОњОЕОф.</translation>
<translation id="1553461853655228091">РђЈChromium ОќОДОЋОД ОюОћОеОЕОљОф ОњОЎОЕОћ ОюОъОдОюОъОћ ОЏОЊОЎ ОюОЎОдОЋОе ОъОцОћ ОфОюОф-ОъОъОЊОЎОф ОЕОю ОћОАОЉОЎОЉОћ ОЕОюОџ</translation>
<translation id="1555494096857516577">{NUM_EXTENSIONS,plural, =1{РђЈОћОфОЋОАОБ ОћОќОћ ОЏОЉОе ОюОљ ОаОфОъОџ. ОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЋ Оъ-Chromium.}one{РђЈОћОфОЋОАОцОЎОЮ ОћОљОюОћ ОЏОЉОе ОюОљ ОаОфОъОЏОЎОЮ. ОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЮ Оъ-Chromium.}two{РђЈОћОфОЋОАОцОЎОЮ ОћОљОюОћ ОЏОЉОе ОюОљ ОаОфОъОЏОЎОЮ. ОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЮ Оъ-Chromium.}other{РђЈОћОфОЋОАОцОЎОЮ ОћОљОюОћ ОЏОЉОе ОюОљ ОаОфОъОЏОЎОЮ. ОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЮ Оъ-Chromium.}}</translation>
<translation id="1562320819937089394">РђЈОћОдОъОЊОф Chromium</translation>
<translation id="1574377791422810894">РђЈОћОЏОюОЎОЮ ОюОЉОўОЎОЌОЋОф ОЕОю Chromium</translation>
<translation id="1594928384848033697">РђЈРђФChromium ОеОЋОдОћ ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОќОљОф, ОдОеОЎОџ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ Ою-Windows.</translation>
<translation id="1607715478322902680">{COUNT,plural, =0{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОбОЊОЏОЋОЪ}=1{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОбОЊОЏОЋОЪ. ОћОЌОюОЋОЪ ОћОљОаОЋОаОЎОъОЎ ОюОљ ОЎОЎОцОфОЌ ОъОЌОЊОЕ.}one{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОбОЊОЏОЋОЪ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}two{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОбОЊОЏОЋОЪ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}other{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОбОЊОЏОЋОЪ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}}</translation>
<translation id="1625909126243026060">РђЈОЉОЊОЎОДОћ ОЕОю ОљОъОдОбОЎ ОћОЉОДОеОћ ОћОЌОЕОЋОЉОЎОЮ ОЉОЎОЋОфОе ОбОю ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ ОЉ-Chromium</translation>
<translation id="1640672724030957280">ОъОЋОеОЎОЊ...</translation>
<translation id="1680687534629375545">ОеОЋОдОћ ОюОЕОљОЋОю ОЕОљОюОћ ОбОю ОћОЊОБ ОћОќОћ ОЉ"ОЌОЎОцОЋОЕ ОћОфОъОЋОаОЋОф"?</translation>
<translation id="1709772298389099340">ОћОЕОЎОеОЋОф ОћОќОћ ОъОАОцОД ОћОеОЕОљОЋОф ОъОЋОеОЌОЉОЋОф Ою-<ph name="BROWSER_NAME" />.</translation>
<translation id="1715127912119967311">РђЈОЏОЊОЎ ОюОЕОцОе ОљОф ОћОфОЏОЋОаОЋОф ОћОљОюОЋ, Chromium ОЕОЋОюОЌ ОљОф ОћОљОЎОаОўОеОљОДОдОЎОЋОф ОЕОюОџ ОљОЎОфОЪ Ою-Google. ОЉОЋОЊОДОЎОЮ ОљОаОЋОЕОЎОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОДОеОЋОљ ОљОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ, ОюОбОЉОЊ ОљОЋОфОЮ ОЋОюОћОЋОАОЎОБ ОюОћОЮ ОћОбОеОЋОф.</translation>
<translation id="1722488837206509557">ОЏОџ ОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОЉОЌОЋОе ОъОЉОЎОЪ ОћОъОЏОЕОЎОеОЎОЮ ОћОќОъОЎОаОЎОЮ ОЋОюОћОдОЎОњ ОЉОћОЮ ОфОЋОЏОЪ.</translation>
<translation id="1733725117201708356">РђЈОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЉ-Chromium ОЎОЎОъОЌОДОЋ ОЉОДОеОЋОЉ</translation>
<translation id="1736443181683099871">РђЈChromium ОЎОаОАОћ ОюОЕОЊОеОњ ОљОф ОћОаОЎОЋОЋОўОЎОЮ Ою-HTTPS</translation>
<translation id="1736662517232558588">РђЈОаОфОЋОаОЎ Chromium ОаОъОЌОДОЋ</translation>
<translation id="1745121272106313518">РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ <ph name="REMAINING_TIME" /></translation>
<translation id="1749104137266986751">РђЈОЏОЕ-HTTPS ОюОљ ОЎОћОЎОћ ОќОъОЎОЪ, Chromium ОЎОЕОфОъОЕ ОЉОЌОЎОЉОЋОе ОюОљ ОъОљОЋОЉОўОЌ ОЉОюОЎ ОюОћОдОЎОњ ОљОќОћОеОћ</translation>
<translation id="1774152462503052664">РђЈОћОфОеОћ Ою-Chromium ОюОцОбОЋОю ОЉОеОДОб</translation>
<translation id="1779356040007214683">РђЈОЏОЊОЎ ОюОЕОцОе ОљОф ОћОљОЉОўОЌОћ ОЕОю Chromium, ОћОЕОЉОфОаОЋ ОЌОюОД ОъОћОфОЋОАОцОЎОЮ ОЕОюОљ ОеОЕОЋОъОЎОЮ ОЉ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ОЋОЎОЎОфОЏОЪ ОЕОаОЋОАОцОЋ ОюОюОљ ОЎОЊОЎОбОфОџ.</translation>
<translation id="1808667845054772817">РђЈОћОфОДОаОф Chromium ОъОЌОЊОЕ</translation>
<translation id="1820835682567584003">РђЈChromium ОъОаОАОћ <ph name="AUTHENTICATION_PURPOSE" /></translation>
<translation id="183031085822326697">РђЈОЉОцОбОЮ ОћОЉОљОћ ОЕ-Chromium ОЎОЎОцОфОЌ ОЉОъОЏОЕОЎОе <ph name="DEVICE_TYPE" />, ОфОЋОцОЎОб ОћОаОЌОЎОћ ОюОћОЕОфОъОЕ ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google.</translation>
<translation id="1838374766361614909">ОаОЎОДОЋОЎ ОЌОЎОцОЋОЕ</translation>
<translation id="18552579716432081">РђЈОЏОЊОЎ ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОъОћОъОЏОЕОЎОе ОћОќОћ ОЉОюОЉОЊ ОЋОбОЊОЎОЎОЪ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google, <ph name="BEGIN_LINK" />ОбОюОЎОџ ОюОдОљОф ОъОћОЌОЕОЉОЋОЪ ОЉ-Chromium<ph name="END_LINK" />.</translation>
<translation id="185970820835152459">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОаОћОю ОљОф ОЌОЕОЉОЋОаОЋОф Google ОЕОљОюОЎОћОЮ ОаОЏОаОАОф. ОЏОЊОЎ ОюОЎОћОаОЋОф ОъОЌОЎОЉОЋОе ОюОЌОЕОЉОЋОЪ ОЉОЊОцОЊОцОЪ Chromium, ОЉОЌОаОЋОф Play, ОЉ-РђЈGmail ОЋОЉОЕОЎОеОЋОфОЎОЮ ОаОЋОАОцОЎОЮ, ОбОюОЎОџ ОюОћОЎОЏОаОА ОбОЮ ОЌОЕОЉОЋОаОЋОф Google ОЕОюОџ. ОЏОЊОЎ ОюОћОЋОАОЎОБ ОЌОЕОЉОЋОЪ ОЕОю ОъОЎОЕОћОЋ ОљОЌОе, ОЏОъОЋ ОЌОЉОе/Оћ ОЉОДОЉОЋОдОћ ОћОъОЕОцОЌОфОЎОф, ОЎОЕ ОюОћОЋОАОЎОБ ОъОЕОфОъОЕ ОЌОЊОЕ Ою-<ph name="DEVICE_TYPE" />. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="1862852878885210965">ОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф'</translation>
<translation id="1880677175115548835">ОЉОЌОЎОеОф ОўОДОАОў</translation>
<translation id="1881322772814446296">РђЈОаОЏОаОАОф ОбОЮ ОЌОЕОЉОЋОЪ ОъОаОЋОћОю ОЕОаОЋОфОЪ ОюОъОаОћОю ОћОъОбОеОЏОф ОЕОюОЋ ОЕОюОЎОўОћ ОбОю ОћОцОеОЋОцОЎОю ОЕОюОџ ОЉ-Chromium. ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉ-Chromium, ОЏОњОЋОЪ ОљОцОюОЎОДОдОЎОЋОф, ОАОЎОъОаОЎОЋОф, ОћОЎОАОўОЋОеОЎОћ, ОАОЎОАОъОљОЋОф ОЋОћОњОЊОеОЋОф ОљОЌОеОЋОф ОЎОЎОДОЕОеОЋ ОЉОљОЋОцОЪ ОДОЉОЋОб Ою-<ph name="USER_NAME" />. ОаОЎОфОЪ ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЉОљОъОдОбОЋОф ОюОЋОЌ ОћОЉОДОеОћ ОЕОю ОЌОЕОЉОЋОаОЋОф Google, ОљОЉОю ОљОЎ ОљОцОЕОе ОюОЕОЎОЎОџ ОљОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОюОЌОЕОЉОЋОЪ ОљОЌОе. ОюОЌОюОЋОцОЎОЪ, ОЉОљОцОЕОеОЋОфОџ ОюОЎОдОЋОе ОцОеОЋОцОЎОю ОЌОЊОЕ ОЏОЊОЎ ОюОЕОъОЋОе ОљОф ОћОаОфОЋОаОЎОЮ ОћОДОЎОЎОъОЎОЮ ОЕОюОџ ОЉ-Chromium ОЉОаОцОеОЊ.<ph name="LEARN_MORE" /></translation>
<translation id="1896836275755235458">РђЈРђФChromium ОЌОЋОАОџ ОЉОЌОЎОЎ ОћОАОЋОюОюОћ ОбОю ОЎОЊОЎ ОћОњОЉОюОф ОћОцОбОЎОюОЋОф ОЉОеОДОб ОЋОћОљОцОДОўОЎОЮ ОћОЌОќОЋОфОЎОЎОЮ, ОЏОъОЋ ОњОюОЎОюОћ ОЌОюОДОћ ОЋОДОдОЉ ОцОеОЎОЎОъОЎОЮ ОЕОю ОАОеОўОЋОаОЎОЮ. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОъОдОЉ ОЌОЎОАОЏОЋОЪ ОЉОљОаОеОњОЎОћ<ph name="END_LINK" /></translation>
<translation id="1898804291554630487">ОЏОљОЪ ОЕОЋОљОюОЎОЮ ОЕОљОюОћ ОюОњОЉОЎ ОћОЊОБ ОћОќОћ</translation>
<translation id="1900969832270057921">РђЈОЕОЎОеОЋОф ОюОбОЊОЏОЋОЪ ОЕОю Chromium</translation>
<translation id="1911763535808217981">РђЈОЏОЎОЉОЋОЎ ОћОњОЊОеОћ ОќОЋ ОЎОљОцОЕОе ОюОџ ОюОћОЎОЏОаОА ОюОљОфОеОЎ Google, ОЏОъОЋ Gmail, ОЉОюОЎ ОюОћОЎОЏОаОА ОљОю Chromium</translation>
<translation id="1929939181775079593">РђЈChromium ОљОЎОаОЋ ОъОњОЎОЉ. ОюОћОцОбОЎОю ОъОЌОЊОЕ ОбОЏОЕОЎОЋ?</translation>
<translation id="1933341829955786215">РђЈОюОцОЎ ОЊОеОЎОЕОф ОћОљОеОњОЋОЪ ОЕОюОџ, <ph name="MANAGER" />, ОбОюОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЉ-Chromium</translation>
<translation id="193439633299369377">РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ChromiumOS ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ.</translation>
<translation id="1951406923938785464">РђЈChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОљОф ОЏОЎ ОюОеОЋОЉ ОюОљ ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОДОЉОдОЎОЮ ОъОћОАОЋОњ ОћОќОћ ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОДОЋОЉОЦ ОъОАОЋОЏОЪ</translation>
<translation id="1953553007165777902">ОъОфОЉОдОбОф ОћОЋОеОЊОћРђд ОЎОЕ ОбОЋОЊ <ph name="MINUTE" /> ОЊОД'</translation>
<translation id="1966382378801805537">РђЈОЉ-Chromium ОюОљ ОаОЎОфОЪ ОюОДОЉОЋОб ОљОЋ ОюОћОњОЊОЎОе ОљОф ОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="1990262977744080398">РђЈОъОЎОЊОб ОбОю ОЌОАОЎОъОћ ОЕОю ОДОЉОдОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЉ-Chromium, ОаОцОфОЌ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="1999715455684970349">РђЈОћОЕОЎОеОЋОф ОћОќОћ ОЕОЋОъОе ОбОю ОфОЋОЏОаОф Chromium ОбОЊОЏОаОЎОф. ОљОЮ ОћОЕОЎОеОЋОф ОћОќОћ ОъОЋОЕОЉОф ОљОЋ ОъОЋОцОАОД, ОфОЋОЏОаОф Chromium ОюОљ ОфОфОбОЊОЏОЪ ОЉОљОЋОцОЪ ОДОЉОЋОб. ОЏОфОЋОдОљОћ ОъОЏОџ, ОюОљ ОаОЎОфОЪ ОЎОћОЎОћ ОюОфОДОЪ ОцОеОдОЋОф ОљОЉОўОЌОћ ОЕОбОюОЋОюОЋОф ОюОћОЎОЋОЋОдОе, ОЋОЎОЎОфОЏОЪ ОЕОЌОюОД ОъОћОфОЏОЋОаОЋОф ОюОљ ОЎОцОбОюОЋ. ОћОЕОЎОеОЋОф ОћОќОћ ОЎОЋОАОе ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОљОЮ ОљОЎОЪ ОфОЋОЏОаОф Chromium ОЕОъОЕОфОъОЕОф ОЉОЋ.</translation>
<translation id="2008474315282236005">РђЈОћОцОбОЋОюОћ ОћОќОЋ ОфОъОЌОД ОцОеОЎОў ОљОЌОЊ ОъОћОъОЏОЕОЎОе. ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОаОфОЋОаОЎОЮ ОъОљОЋОЌОе ОЎОЋОфОе, ОћОЎОЏОаОА ОљОю Chromium ОбОЮ <ph name="USER_EMAIL" />.</translation>
<translation id="2018879682492276940">ОћОћОфОДОаОћ ОаОЏОЕОюОћ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="2020032459870799438">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОЕОљОе ОћОАОЎОАОъОљОЋОф ОъОЋОњОаОЋОф ОъОцОаОЎ ОцОеОдОЋОф ОЉОљОЉОўОЌОф ОъОЎОЊОб ОЋОЉОбОЎОЋОф ОљОЉОўОЌОћ ОљОЌОеОЋОф, <ph name="BEGIN_LINK" />ОЎОЕ ОюОћОЎОЏОаОА Ою-Chromium<ph name="END_LINK" />.</translation>
<translation id="2039417478970545937">ОћОњОЊОеОЋОф.</translation>
<translation id="2049376729098081731">РђЈОЉОЋОЌОеОЎОЮ ОљОЮ ОюОЏОюОЋОю ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОЉ-Chromium ОюОћОфОљОъОћ ОљОЎОЕОЎОф ОъОЊОЋОЎОДОф ОЎОЋОфОе ОЉОЕОЎОеОЋОфОЎ Google</translation>
<translation id="2054039611381840095">РђЈОЏОЊОЎ ОюОДОЉОю ОбОЊОЏОЋОаОЎОЮ ОЕОю Chromium ОЉОбОфОЎОЊ, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉ-macOS ОъОњОеОАОћ 12 ОЋОљОЎОюОџ. ОЉОъОЌОЕОЉ ОћОќОћ ОцОЋОбОюОф ОњОеОАОћ 11 ОЕОю macOS.</translation>
<translation id="2064856577282482477">РђЈОљОцОЕОе ОюОюОЌОЋОЦ ОбОю ОћОЏОцОфОЋОе "ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chromium" ОЉОЊОБ ОћОЏОеОўОЎОАОЎОЎОћ ОћОЌОЊОЕОћ ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОъОеОљОћ ОЕОюОЋ</translation>
<translation id="2086476982681781442">РђЈChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОљОф ОЏОЎ ОћОДОЋОЉОЦ ОъОўОбОћ ОЋОбОЕОЋОЎ ОюОЉОдОб ОЕОЎОаОЋОЎОЎОЮ ОюОљ ОдОцОЋОЎОЎОЮ ОЉОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="208726765006323911">РђЈОЉОцОбОЮ ОћОЉОљОћ ОЕ-Chromium ОЎОЎОцОфОЌ ОЉ-iOS, ОфОЋОцОЎОб ОћОаОЌОЎОћ ОюОаОАОЋОф ОљОф <ph name="FEATURE_NAME" />.</translation>
<translation id="2099452623287920103">РђЈОћОАОЎОАОъОљОЋОф ОЋОаОфОЋОаОЎОЮ ОљОЌОеОЎОЮ Оъ-Chromium ОЕОЕОъОеОф ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google ОЎОЋОАОеОЋ ОъОћОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЕОЋОЉ ОЉ-Chromium, ОдОеОЎОџ ОюОћОЎОЏОаОА ОЉОЌОќОеОћ ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="2120965832000301375">{COUNT,plural, =1{РђЈОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЏОЕОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉ-Chromium ОЉОъОЕОџ ОЊОДОћ. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф. ОћОЏОеОўОЎОАОЎОЋОф ОЎОЎОЕОљОеОЋ ОцОфОЋОЌОЋОф.}one{РђЈОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЏОЕОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉ-Chromium ОЉОъОЕОџ # ОЊОДОЋОф. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф. ОћОЏОеОўОЎОАОЎОЋОф ОЎОЎОЕОљОеОЋ ОцОфОЋОЌОЋОф.}two{РђЈОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЏОЕОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉ-Chromium ОЉОъОЕОџ # ОЊОДОЋОф. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф. ОћОЏОеОўОЎОАОЎОЋОф ОЎОЎОЕОљОеОЋ ОцОфОЋОЌОЋОф.}other{РђЈОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЏОЕОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉ-Chromium ОЉОъОЕОџ # ОЊОДОЋОф. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф. ОћОЏОеОўОЎОАОЎОЋОф ОЎОЎОЕОљОеОЋ ОцОфОЋОЌОЋОф.}}</translation>
<translation id="2126108037660393668">ОаОЏОЕОю ОћОљОЎОъОЋОф ОЕОю ОћОДОЋОЉОЦ ОЕОћОЋОеОЊ.</translation>
<translation id="2137162749895930932">ОАОњОЎОеОф ОћОъОАОџ ОюОфОеОњОЋОЮ</translation>
<translation id="215352261310130060">РђЈChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОљОф ОЏОЎ ОћОљОфОе ОюОљ ОъОЕОфОъОЕ ОЉОЌОЎОЉОЋОе ОъОљОЋОЉОўОЌ ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЉОЋОдОбОЋ ОЕОЎОаОЋОЎОЎОЮ ОюОљ ОъОЋОеОЕОЎОЮ ОЉОДОЋОЉОЦ</translation>
<translation id="2174178932569897599">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chromium</translation>
<translation id="2174917724755363426">ОћОћОфОДОаОћ ОюОљ ОћОЋОЕОюОъОћ. ОюОћОъОЕОЎОџ ОЉОЉОЎОўОЋОю?</translation>
<translation id="2185166961232948079">РђЈChromium РђЊ ОЏОаОЎОАОћ ОюОеОЕОф РђЊ <ph name="PAGE_TITLE" /></translation>
<translation id="2190166659037789668">ОћОЕОњОЎОљОћ ОЉОЉОЊОЎОДОф ОћОбОЊОЏОЋОЪ: <ph name="UPDATE_CHECK_ERROR" />.</translation>
<translation id="2199210295479376551">РђЈОћОАОеОф ОћОЌОЕОЉОЋОЪ Оъ-Chromium</translation>
<translation id="2210502920229141283">РђЈОљОцОЕОе ОюОЎОћОаОЋОф ОъОљОЎОаОўОеОаОў ОЉОўОЋОЌ ОЎОЋОфОе ОЉОЏОю ОъОДОЋОЮ ОбОЮ ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОњОюОЎОЕОћ ОЉОўОЋОЌОћ ОЉ-Chromium Ою-iOS</translation>
<translation id="2210682093923538346">РђЈОљОфОе ОъОАОЋОЏОЪ. РђФChromium ОћОАОЎОе ОљОф ОћОћОфОеОљОЋОф.</translation>
<translation id="2236949375853147973">ОћОцОбОЎОюОЋОф ОЕОюОЎ</translation>
<translation id="2238130810669087193">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОЏОфОЋОЉОЋОф ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОћОЎОЏОаОА Ою-Chromium. ОюОљОЌОе ОћОЏОаОЎОАОћ, ОћОЏОфОЋОЉОф ОћОќОЋ ОфОЎОЕОъОе ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google.</translation>
<translation id="2241627712206172106">РђЈОљОЮ ОъОЕОфОцОЎОЮ ОъОЌОЕОЉ, ОЌОЉОеОЎОЮ ОЋОЉОаОЎ ОъОЕОцОЌОћ ОЎОЏОЋОюОЎОЮ ОюОњОюОЋОЕ ОЉОаОцОеОЊ ОЋОюОћОњОЊОЎОе ОљОф Chromium ОЉОЊОЎОЋОД ОЏОцОЎ ОЕОћОЮ ОеОЋОдОЎОЮ.</translation>
<translation id="2283803047247799269">ОЌОЎОцОЋОЕ ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф"</translation>
<translation id="2287771843518581140">{NUM_TABS,plural, =1{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОЕОъОљОўОћ ОљОф ОћОЊОцОЊОцОЪ}one{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОъОљОўОЋОф ОљОф ОћОЊОцОЊОцОЪ}two{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОъОљОўОЋОф ОљОф ОћОЊОцОЊОцОЪ}other{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОъОљОўОЋОф ОљОф ОћОЊОцОЊОцОЪ}}</translation>
<translation id="2307973900865360088">РђЈОљОаОЎ ОеОЋОдОћ ОюОћОЕОљОЎОе ОљОф Chromium ОЉ-Dock</translation>
<translation id="2313870531055795960">РђЈОћОъОбОеОЏОф ОЉОЋОЊОДОф ОЏОфОЋОЉОЋОф URL ОЉОбОќОеОф ОеОЕОЎОъОћ ОЕОю ОљОфОеОЎОЮ ОюОљ ОЉОўОЋОЌОЎОЮ ОЕОЕОъОЋОеОћ ОЉ-Chromium. ОљОЮ ОЉОљОфОе ОЏОюОЕОћОЋ ОъОфОЉОдОб ОаОЎОАОЎОЋОЪ ОюОњОаОЋОЉ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ, ОљОЋ ОљОЮ ОћОъОбОеОЏОф ОъОќОћОћ ОћОЋОеОЊОћ ОЕОю ОДОЋОЉОЦ ОъОќОЎОД, Chromium ОбОЕОЋОЎ ОњОЮ ОюОЕОюОЋОЌ ОЏОфОЋОЉОЋОф URL ОюОЉОЊОЎОДОћ ОЉОљОъОдОбОЋОф 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ'. ОћОаОфОЋОаОЎОЮ ОЕОаОЕОюОЌОЎОЮ ОюОЉОЊОЎОДОћ ОЏОЋОюОюОЎОЮ ОЉОЎОўОЎОЮ ОъОфОЋОЏОЪ ОЕОю ОЊОцОЎОЮ.</translation>
<translation id="2332076562712130931">РђЈОЉОбОДОЉОЋОф ОћОљОЎОцОЋОА:
          <ph name="LINE_BREAKS" />
           Рђб ОЎОфОљОцОАОЋ ОЌОюОД ОъОћОћОњОЊОеОЋОф ОЋОъОДОЎОдОЋОеОЎ ОћОЊОеОџ ОЕОю Chromium
           <ph name="LINE_BREAK" />
           Рђб ОћОфОЋОАОцОЎОЮ ОЎОЋОЕОЉОфОЋ
           <ph name="LINE_BREAK" />
           Рђб ОЎОЎОъОЌОДОЋ ОДОЋОЉОдОЎ Cookie ОЋОаОфОЋОаОЎОЮ ОќОъОаОЎОЎОЮ ОљОЌОеОЎОЮ ОъОљОфОеОЎОЮ
            <ph name="LINE_BREAKS" />
           ОюОљ ОфОћОЎОћ ОћОЕОцОбОћ ОбОю ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОћОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф.</translation>
<translation id="2343156876103232566">РђЈОЏОЊОЎ ОюОЕОюОЋОЌ ОъОАОцОе ОъОЏОљОЪ ОюОўОюОцОЋОЪ Android, ОЎОЕ ОюОћОЎОЏОаОА Ою-Chromium ОЉОЕОаОЎ ОћОъОЏОЕОЎОеОЎОЮ.</translation>
<translation id="2356070529366658676">ОюОЕОљОЋОю</translation>
<translation id="2359808026110333948">ОћОъОЕОџ</translation>
<translation id="2361918034042471035">РђЈОћОфОЋОАОБ "<ph name="EXTENSION_NAME" />" ОъОЉОДОЕ ОъОъОџ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="236943522426971115">РђЈОћОЕОЉОфОф ОћОцОбОЎОюОЋОф ОЕОю Chromium ОЉОеОДОб ОюОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="2374216753258219393">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОћОќОћ ОЉОфОЋОе <ph name="USER_EMAIL_ADDRESS" />, ОбОюОЎОџ ОюОћОЎОЏОаОА Ою-Chromium.</translation>
<translation id="2384373936468275798">РђЈОюОљ ОЉОЋОдОб ОАОаОЏОеОЋОЪ ОЕОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉ-ChromiumOS ОЏОЎ ОцОеОўОЎ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ ОюОљ ОъОбОЋОЊОЏОаОЎОЮ.</translation>
<translation id="2398377054246527950">{NUM_DEVICES,plural, =0{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ ОюОъОЏОЕОЎОе ОъОъОЕОД ОљОаОЋОЕОЎ (HID) ОљОЌОЊ}=1{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ ОюОъОЏОЕОЎОе ОъОъОЕОД ОљОаОЋОЕОЎ (HID) ОљОЌОЊ}one{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ Ою-# ОъОЏОЕОЎОеОЎ ОъОъОЕОД ОљОаОЋОЕОЎ (HID)}two{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ Ою-# ОъОЏОЕОЎОеОЎ ОъОъОЕОД ОљОаОЋОЕОЎ (HID)}other{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ Ою-# ОъОЏОЕОЎОеОЎ ОъОъОЕОД ОљОаОЋОЕОЎ (HID)}}</translation>
<translation id="2401032172288869980">РђЈОаОЊОеОЕОЋОф ОћОеОЕОљОЋОф ОњОЎОЕОћ ОюОъОдОюОъОћ ОЋОюОъОЎОДОеОЋОцОЋОЪ ОЉ-Chromium ОбОЉОЋОе ОћОљОфОе ОћОќОћ</translation>
<translation id="2403703063067034158">ОЕОњОЎОљОћ ОЉОќОъОЪ ОћОћОцОбОюОћ: ОЎОЕ ОбОЋОЊ ОћОњОЊОеОћ ОЕОцОЋОбОюОф ОЏОеОњОб. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="2440750600860946460">РђЈОЉОбОќОеОф <ph name="BEGIN_LINK" />ОћОЏОюОЎОЮ ОЕОю Chromium<ph name="END_LINK" /> ОљОцОЕОе ОюОњОюОЋОЕ ОЉОЉОўОЌОћ ОЋОЉОЕОюОЎОўОћ</translation>
<translation id="2451727308784734061">ОЉОљОъОдОбОЋОф ОДОЎОдОЋОеОЎ ОћОЊОеОџ ОљОцОЕОе ОюОћОњОЎОб ОъОћОе ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф. ОаОЎОфОЪ ОюОћОбОЉОЎОе ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОюОъОеОЏОќ ОћОљОцОюОЎОДОдОЎОЋОф ОљОЋ ОюОъОАОџ ОћОЉОЎОф ОЕОю ОћОъОЌОЕОЉ.</translation>
<translation id="2478295928299953161">РђЈChromium ОЎОЎОАОњОе ОЉОДОеОЋОЉ</translation>
<translation id="2483889755041906834">РђЈОЉ-Chromium</translation>
<translation id="2485422356828889247">ОћОАОеОћ</translation>
<translation id="2513154137948333830">ОаОЊОеОЕОф ОћОцОбОюОћ ОъОЌОЊОЕ: <ph name="INSTALL_SUCCESS" /></translation>
<translation id="2542968102051442371">ОЉОЌОЎОеОћ ОЕОю ОўОДОАОў ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф'</translation>
<translation id="2554739539410784893">РђЈChromium ОъОаОАОћ ОюОћОЌОюОЎОБ ОљОф ОћОАОЎОАОъОљОЋОф ОћОДОЎОЎОъОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОќОљОф, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ Ою-Windows.</translation>
<translation id="2560420686485554789">РђЈChromium ОќОДОЋОД ОюОњОЎОЕОћ ОюОљОЌОАОЋОЪ ОЏОЊОЎ ОюОћОЋОеОЎОЊ ОДОЉОдОЎОЮ</translation>
<translation id="2572494885440352020">Chromium Helper</translation>
<translation id="2575822587468774919">ОљОцОЕОе ОюОЉОЌОЋОе ОъОЕОћОЋ ОюОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф'</translation>
<translation id="2576118232315942160">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОАОЎОАОъОљОЋОф ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="2592940277904433508">РђЈОћОъОЕОџ ОћОЕОЎОъОЋОЕ ОЉ-Chromium</translation>
<translation id="259935314519650377">ОЕОъОЎОеОф ОъОаОћОю ОћОћОфОДОаОћ ОЕОћОЋОеОЊ ОЉОъОўОъОЋОЪ ОаОЏОЕОюОћ. ОћОЕОњОЎОљОћ: <ph name="UNPACK_CACHING_ERROR_CODE" />.</translation>
<translation id="2620436844016719705">ОъОбОеОЏОф</translation>
<translation id="2629740064077610681">РђЈОћОљОЊОъОЎОЪ ОЉОљОеОњОЋОЪ ОЕОюОџ ОЎОЏОЋОю ОюОеОљОЋОф ОЋОюОаОћОю ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ, ОЏОъОЋ ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОћОАОЎОАОъОљОЋОф. ОљОЎОЪ ОюОљОЊОъОЎОЪ ОљОцОЕОеОЋОф ОюОеОљОЋОф ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЉОцОеОЋОцОЎОюОЎОЮ ОљОЌОеОЎОЮ ОЕОю Chromium</translation>
<translation id="2635452620547538388">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОЕОю Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ <ph name="ACCOUNT_EMAIL" />, ОбОюОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="2637732208198500597">{COUNT,plural, =0{РђЈОЏОЊОЎ ОЕОћОбОЊОЏОЋОЪ ОЎОЎОЏОаОА ОюОфОЋОДОБ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОъОАОњОеОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф}=1{РђЈОЏОЊОЎ ОЕОћОбОЊОЏОЋОаОЎОЮ ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОъОАОњОеОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф. ОћОЌОюОЋОЪ ОћОцОеОўОЎ ОюОљ ОЎОЎОцОфОЌ ОъОЌОЊОЕ.}one{РђЈОЏОЊОЎ ОЕОћОбОЊОЏОЋОаОЎОЮ ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОъОАОњОеОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф. # ОћОЌОюОЋОаОЋОф ОћОцОеОўОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}two{РђЈОЏОЊОЎ ОЕОћОбОЊОЏОЋОаОЎОЮ ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОъОАОњОеОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф. # ОћОЌОюОЋОаОЋОф ОћОцОеОўОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}other{РђЈОЏОЊОЎ ОЕОћОбОЊОЏОЋОаОЎОЮ ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОъОАОњОеОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф. # ОћОЌОюОЋОаОЋОф ОћОцОеОўОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}}</translation>
<translation id="2648074677641340862">РђЈОЉОъОћОюОџ ОћОћОфОДОаОћ ОљОеОбОћ ОЕОњОЎОљОћ ОЕОю ОъОбОеОЏОф ОћОћОцОбОюОћ. ОЎОЕ ОюОћОЋОеОЎОЊ ОЕОЋОЉ ОљОф Chromium.</translation>
<translation id="2661879430930417727">РђЈОљОЮ ОъОЕОфОцОЎОЮ ОъОЏОЕОЎОе, ОЌОЉОеОЎОЮ ОЋОЉОаОЎ ОъОЕОцОЌОћ ОЎОЏОЋОюОЎОЮ ОюОњОюОЋОЕ ОЉОаОцОеОЊ ОЋОюОћОњОЊОЎОе ОљОф Chromium ОЉОЊОЎОЋОД ОЏОцОЎ ОЕОћОЮ ОеОЋОдОЎОЮ</translation>
<translation id="2711502716910134313">РђЈОЏОеОўОЎОАОЎОЎОћ ОЕОю Chromium</translation>
<translation id="2718390899429598676">РђЈОюОЕОЎОцОЋОе ОћОљОЉОўОЌОћ, Chromium ОЎОдОцОЎОЪ ОљОф ОћОаОфОЋОаОЎОЮ.</translation>
<translation id="2721354645805494590">РђЈОЏОЊОЎ ОюОћОАОЎОе ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google Оъ-Chromium, ОдОеОЎОџ ОюОдОљОф ОъОћОЌОЕОЉОЋОЪ</translation>
<translation id="2722636413143664436">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОАОЎОАОъОљОЋОф, ОюОАОЎОъОаОЎОЋОф ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="2738871930057338499">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў. HTTP 403: ОДОЋОЊ ОљОЎОАОЋОе. ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОћОњОЊОеОћ ОЕОю ОЕОеОф Оћ-proxy.</translation>
<translation id="2753623023919742414">ОдОеОЎОџ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОЌОцОЕ</translation>
<translation id="2768103863314748511">РђЈОћОњОЊОеОф Chromium ОЏОЏОюОЎ ОЉОеОЎОеОф ОћОъОЌОЊОю ОюОдОцОЎОЎОћ ОЉОДОЋОЉОдОЎ PDF</translation>
<translation id="2785438272836277133">РђЈОћОфОЋОАОБ ОћОќОћ ОъОЏОЎОю ОфОЋОЏОаОћ ОќОЊОЋОаОЎОф ОЋОћОЋОљ ОюОљ ОЉОўОЋОЌ. ОдОеОЎОџ ОюОћОАОЎОе ОљОЋОфОЋ Оъ-Chromium ОЏОЊОЎ ОюОљ ОюОљОцОЕОе ОюОЋ ОЎОЋОфОе ОюОћОдОЎОњ ОЋОюОЕОаОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОфОфОЉОдОб ОЏОаОЎОАОћ, ОЏОЋОюОю ОћОцОеОўОЎОЮ ОћОљОЎОЕОЎОЎОЮ ОЕОюОџ.</translation>
<translation id="2799223571221894425">ОћОцОбОюОћ ОъОЌОЊОЕ</translation>
<translation id="2803971713792056305">РђЈОћ-Chromium ОЕОюОџ</translation>
<translation id="2816462166102338036">ОЌОЎОцОЋОЕ ОћОАОеОўОЋОЪ ОћОќОћ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф"</translation>
<translation id="2841525013647267359">ОфОеОњОЋОЮ Оъ:</translation>
<translation id="2846251086934905009">ОЕОњОЎОљОф ОћОфОДОаОћ: ОцОбОЋОюОф ОъОаОћОю ОћОћОфОДОаОћ ОюОљ ОћОЋОЕОюОъОћ. ОћОћОфОДОаОћ ОЉОЋОўОюОћ.</translation>
<translation id="2847479871509788944">РђЈОћОАОеОћ Оъ-Chromium...</translation>
<translation id="2850691299438350830">РђЈОъОњОЎОаОћ ОбОюОЎОџ ОЉ-Chromium ОЋОбОЕОЋОЎОћ ОюОЕОцОе ОљОф ОеОъОф ОћОљОЉОўОЌОћ ОЉОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф ОЕОю Google. ОћОћОњОаОћ ОћОќОЋ ОцОбОЎОюОћ ОеОД ОљОЮ ОаОЏОаОАОЎОЮ ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="2885378588091291677">ОъОаОћОю ОћОъОЕОЎОъОЋОф</translation>
<translation id="2910007522516064972">РђЈОъОЎОЊОб ОбОю &amp;ChromiumРђЈ</translation>
<translation id="2915996080311180594">ОћОцОбОюОћ ОъОЌОЊОЕ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="2928420929544864228">ОћОћОфОДОаОћ ОћОЋОЕОюОъОћ.</translation>
<translation id="2933336679234709858">РђЈОћОаОфОЋОаОЎОЮ ОЕОюОџ ОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google, ОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ.</translation>
<translation id="2945997411976714835">ОЕОњОЎОљОф ОћОфОДОаОћ: ОћОцОбОюОф ОћОфОћОюОЎОџ ОЕОю ОъОаОћОю ОћОћОфОДОаОћ ОаОЏОЕОюОћ.</translation>
<translation id="2948852018303413228">РђЈОеОЋОдОћ ОюОћОЎОЏОаОА ОъОћОе ОЎОЋОфОе ОюОљОфОеОЎОЮ? ОЏОЊОљОЎ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОЉ-Chromium ОЉ-iOS</translation>
<translation id="2966959524256557996">РђЈОљОцОЕОе ОюОћОЋОАОЎОБ ОцОеОЋОцОЎОю ОЌОЊОЕ ОЉ-Chromium ОЏОЊОЎ ОюОћОцОеОЎОЊ ОЉОЎОЪ ОћОАОЎОъОаОЎОЋОф, ОћОАОЎОАОъОљОЋОф ОЋОћОћОњОЊОеОЋОф.</translation>
<translation id="2970426615109535079">РђЈРђФChromium ОъОаОЋОћОю ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="2977470724722393594">РђЈChromiumРђЈ ОъОбОЋОЊОЏОЪ</translation>
<translation id="2977506796191543575">РђЈОљОЮ ОЉОљОфОе ОЏОюОЕОћОЋ ОъОфОЉОдОб ОаОЎОАОЎОЋОЪ ОюОњОаОЋОЉ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ, ОљОЋ ОљОЮ ОћОъОбОеОЏОф ОъОќОћОћ ОћОЋОеОЊОћ ОЕОю ОДОЋОЉОЦ ОъОќОЎОД, Chromium ОбОЕОЋОЎ ОњОЮ ОюОЕОюОЋОЌ ОЏОфОЋОЉОЋОф URL ОюОЉОЊОЎОДОћ ОЉОљОъОдОбОЋОф 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ'. ОћОаОфОЋОаОЎОЮ ОЕОаОЕОюОЌОЎОЮ ОюОЉОЊОЎОДОћ ОЏОЋОюОюОЎОЮ ОЉОЎОўОЎОЮ ОъОфОЋОЏОЪ ОЕОю ОЊОцОЎОЮ</translation>
<translation id="2981563588585023386">РђЈОЏОЊОЎ ОюОЕОъОЋОе ОбОю ОћОЉОўОЎОЌОЋОф ОљОЋОаОюОЎОЎОЪ ОЉОћОфОљОЮ ОюОљОцОЕОеОЋОЎОЋОф ОЕОаОЉОЌОеОЋ ОбОю ОЎОЊОЎ ОћОћОЋОеОћ ОЕОюОџ, ОбОюОЎОџ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="3003694935412297923">ОЏОю ОћОъОЕОЎОъОЋОф</translation>
<translation id="3012615494352020668">{count,plural, =1{РђЈРђФChromium ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ ОюОцОаОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОЕОъОЋОе ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ (ОцОеОЎОў ОљОЌОЊ).}one{РђЈРђФChromium ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ ОюОцОаОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОЕОъОЋОе ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ ({count} ОцОеОЎОўОЎОЮ).}two{РђЈРђФChromium ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ ОюОцОаОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОЕОъОЋОе ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ ({count} ОцОеОЎОўОЎОЮ).}other{РђЈРђФChromium ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ ОюОцОаОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОЕОъОЋОе ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ ({count} ОцОеОЎОўОЎОЮ).}}</translation>
<translation id="3013473503895162900">РђЈОцОфОЎОЌОћ ОЕОю <ph name="URL" /> ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЉ-Chromium.</translation>
<translation id="3032706164202344641">РђЈChromium ОюОљ ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ. ОЏОЊОљОЎ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="3032787606318309379">РђЈОъОфОЉОдОбОф ОћОЋОАОцОћ Ою-Chromium...</translation>
<translation id="3038232873781883849">ОЉОћОъОфОаОћ ОюОћОфОДОаОћРђд</translation>
<translation id="3045032126857188731">ОЕОцОф ОћОфОеОњОЋОЮ: <ph name="LANGUAGE" /></translation>
<translation id="3047590466164881923">ОАОњОЎОеОћ ОЕОю ОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОЕОю ОъОЕОЋОЉ</translation>
<translation id="3068187312562070417">РђЈОцОеОЋОцОЎОюОЎОЮ ОљОЌОеОЎОЮ ОЉ-Chromium</translation>
<translation id="3068515742935458733">РђЈОбОќОеОћ ОЉОЕОЎОцОЋОе Chromium ОбОю ОЎОЊОЎ ОЕОюОЎОЌОф <ph name="UMA_LINK" /> ОЋОЊОЋОЌОЋОф ОДОеОЎОАОћ ОљОю Google</translation>
<translation id="3079753320517721795">{NUM_DEVICES,plural, =0{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ ОюОћОфОДОЪ USB ОљОЌОЊ}=1{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ ОюОћОфОДОЪ USB ОљОЌОЊ}one{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ Ою-# ОћОфОДОаОЎ USB}two{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ Ою-# ОћОфОДОаОЎ USB}other{РђЈОфОЋОАОБ ОљОЌОЊ ОюОцОЌОЋОф Ою-Chromium ОаОЎОњОЕ Ою-# ОћОфОДОаОЎ USB}}</translation>
<translation id="3095811995836568724">РђЈОћОћОЎОАОўОЋОеОЎОћ ОЉ-Chromium</translation>
<translation id="3103660991484857065">РђЈОћОъОфОДОЎОЪ ОюОљ ОћОдОюОЎОЌ ОюОЉОўОю ОљОф ОЊОЌОЎОАОф ОћОљОеОЏОЎОЋОЪ. ОЎОЕ ОюОћОЋОеОЎОЊ ОЕОЋОЉ ОљОф Chromium.</translation>
<translation id="310459126943037700">ОАОЎОЋОЮ ОћОъОЕОЎОъОЋОф ОаОЏОЕОю.</translation>
<translation id="3130323860337406239">РђЈChromium ОъОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ ОЕОюОџ.</translation>
<translation id="3130333203120345554">ОЌОЎОцОЋОЕ ОЌОЊОЕ</translation>
<translation id="3137969841538672700">ОдОеОЎОџ ОюОњОеОЋОе ОЏОЊОЎ ОюОЌОцОЕ</translation>
<translation id="3144188012276422546">РђЈОЉОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОъОЕОљОЉОЎОЮ ОаОЋОАОцОЎОЮ. ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОЉОЎОдОЋОбОЎОЮ, ОЏОЊОљОЎ ОюОљОцОЕОе Ою-Chromium ОюОћОЕОЉОЎОф ОљОЋОфОћ.</translation>
<translation id="3149163023759831301">РђЈОЏОЊОЎ ОюОЕОфОБ ОљОф ОћОъОАОџ, ОдОеОЎОџ ОюОљОцОЕОе ОћОДОюОўОф ОъОАОџ ОЉ-Chromium ОЉОДОўОб "ОћОњОЊОеОЋОф ОћОъОбОеОЏОф"</translation>
<translation id="3155163173539279776">РђЈОћОцОбОюОћ ОъОЌОЊОЕ ОЕОю Chromium</translation>
<translation id="3161522574479303604">ОЏОю ОћОЕОцОЋОф</translation>
<translation id="3179665906251668410">РђЈОцОфОЎОЌОф ОћОДОЎОЕОЋОе ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ ОЕОю Chromium</translation>
<translation id="3183357154200327217">РђЈОфОЋОЏОаОћ ОљОЌОеОф ОЉОъОЌОЕОЉ ОЕОюОџ ОћОЋОАОЎОцОћ ОбОЎОдОЋОЉ ОЕОбОЕОЋОЎ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chromium.

<ph name="EXTENSION_NAME" /></translation>
<translation id="3185330573522821672">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОцОеОЋОцОЎОю Chromium ОћОЌОЊОЕ</translation>
<translation id="3224847870593914902">РђЈОЏОЊОЎ ОюОћОАОЎОе ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google Оъ-Chromium, ОдОеОЎОџ ОюОдОљОф Оъ-Chromium ОЉОЊОБ ОћОћОњОЊОеОЋОф</translation>
<translation id="3234316605225071811">РђЈОЉОћОъОЕОџ, ОфОЋОдОњ ОюОџ ОЕОљОюОћ ОЉ-Chromium ОљОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОЊОб ОћОЕОъОЋОе ОЏОЊОЎ ОюОъОюОљ ОЉОЕОЉОЎОюОџ ОўОцОАОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="3258596308407688501">РђЈChromium ОљОЎОаОЋ ОЎОЏОЋОю ОюОДОеОЋОљ ОЋОюОЏОфОЋОЉ ОЉОАОцОеОЎОЎОф ОћОаОфОЋОаОЎОЮ ОЕОюОЋ: <ph name="USER_DATA_DIRECTORY" /></translation>
<translation id="3286538390144397061">ОћОцОбОю ОъОЌОЊОЕ ОЏОбОф</translation>
<translation id="328888136576916638">РђЈОћОъОцОфОЌОЋОф ОЕОю Google API ОЌОАОеОЎОЮ. ОцОЋОаОДОдОЎОЋОаОюОЎОЋОф ОъОАОЋОЎОъОф ОЕОю Chromium ОфОћОЎОћ ОъОЋОЕОЉОфОф.</translation>
<translation id="3296368748942286671">РђЈОћОъОЕОџ ОћОцОбОюОф ОЎОЎОЕОЋОъОЎОЮ ОЉОеОДОб ОЏОљОЕОе Chromium ОАОњОЋОе</translation>
<translation id="3313189106987092621">РђЈChromium ОЎОдОЎОњ ОљОќОћОеОћ ОюОцОаОЎ ОўОбОЎОаОф ОљОфОе ОЏОюОЕОћОЋ ОЉОљОъОдОбОЋОф ОЌОЎОЉОЋОе ОюОљ ОъОљОЋОЉОўОЌ</translation>
<translation id="3316771292331273802">РђЈОљОЮ ОАОЋОњОеОЎОЮ ОљОф ОЏОю ОћОЌОюОЋОаОЋОф ОЕОю Chromium, ОъОфОЉОдОбОф ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ, ОљОЉОю ОюОљ ОъОЌОЕОЉОЋОЪ Google, ОљОЮ ОаОЏОаОАОф ОљОюОЎОЋ ОЉ-Chromium. ОЏОЊОЎ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОќОЏОЋОе ОљОЋОфОџ, <ph name="SETTINGS_LINK" />.</translation>
<translation id="3322413454779348750">РђЈОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОъОЋОњОЊОе ОЏОЉОеОЎОеОф ОъОЌОЊОю ОћОЕОфОаОћ ОъОЌОЋОЦ Ою-Chromium. ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ, Chromium ОљОЎОцОА ОљОф ОћОћОњОЊОеОћ.</translation>
<translation id="3352986031709923790">РђЈОћОцОЎОаОћ ОћОЎОъОаОЎОф ОћОбОюОЎОЋОаОћ ОЕОю ОљОќОЋОе ОћОЌОЎОцОЋОЕ: Рђј<ph name="RIGHT" />%Рђј ОъОЎОъОЎОЪ, Рђј<ph name="TOP" />%Рђј ОъОюОъОбОюОћ</translation>
<translation id="3366305173356742781">РђЈОаОфОЋОаОЎ Chromium ОЉОЌОЕОЉОЋОЪ ОЕОюОџ</translation>
<translation id="3369405342922656244">ОЌОЎОцОЋОЕ ОћОЊОБ ОћОќОћ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф"</translation>
<translation id="3387527074123400161">ChromiumOS</translation>
<translation id="3406848076815591792">РђЈОюОбОЉОЋОе ОюОцОеОЋОцОЎОю ОДОЎОЎОЮ ОЕОю Chromium?</translation>
<translation id="3412460710772753638">ОбОЊОЏОЋОЪ ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="3461644266919055473">РђЈРђФChromium ОъОЉОдОб ОћОфОљОъОћ ОљОЎОЕОЎОфРђд</translation>
<translation id="347328004046849135">РђЈОљОЮ ОъОбОеОЏОф Chromium ОфОќОћОћ ОЕОаОЏОаОАОф ОбОЮ ОАОЎОАОъОћ ОЕОаОЌОЕОцОћ, ОћОЎОљ ОфОфОеОЎОб ОюОџ ОбОю ОЏОџ</translation>
<translation id="3474745554856756813">РђЈОцОбОЋОюОћ ОќОЋ ОфОъОЌОД <ph name="ITEMS_COUNT" /> ОцОеОЎОўОЎОЮ ОъОћОъОЏОЕОЎОе. ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОаОфОЋОаОЎОЮ ОъОљОЋОЌОе ОЎОЋОфОе, ОЎОЕ ОюОћОЎОЏОаОА ОљОю Chromium ОбОЮ <ph name="USER_EMAIL" />.</translation>
<translation id="3497319089134299931">РђЈОаОЎОфОЪ ОюОбОЉОЋОе ОЉОЎОЪ ОцОеОЋОцОЎОюОЎОЮ ОЕОю Chromium ОЉОљОъОдОбОЋОф <ph name="SHORTCUT" /></translation>
<translation id="3509308970982693815">РђЈОЎОЕ ОюОАОњОЋОе ОљОф ОЏОю ОЌОюОЋОаОЋОф Chromium ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3522404737534491619">РђЈОЏОЊОЎ ОюОЕОфОБ ОљОф ОћОЌОюОЋОЪ, ОдОеОЎОџ ОюОљОцОЕОе ОћОДОюОўОф ОъОАОџ ОЉ-Chromium ОЉОДОўОб "ОћОњОЊОеОЋОф ОћОъОбОеОЏОф"</translation>
<translation id="3530103706039034513">РђЈОЏОЉОе ОЉОЋОдОбОћ ОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ ОбОю ОЎОЊОЎ <ph name="EXISTING_USER" />.  ОЏОЊОЎ ОюОћОцОеОЎОЊ ОЉОЎОЪ ОцОбОЎОюОЋОЎОЋОф ОћОњОюОЎОЕОћ, ОбОюОЎОџ ОюОћОЎОЏОаОА Ою-Chromium ОЉОцОеОЋОцОЎОю ОЕОюОџ ОбОЮ ОћОљОЎОъОЎОЎОю <ph name="USER_EMAIL_ADDRESS" />.</translation>
<translation id="3561853857681580870">РђЈОЏОЊОЎ ОюОЕОфОБ ОљОф ОћОъОАОџ, ОдОеОЎОџ ОюОљОцОЕОе ОћОДОюОўОф ОъОАОџ ОЉ-Chromium ОЉОДОўОб "ОћОњОЊОеОЋОф ОћОъОбОеОЏОф".</translation>
<translation id="3597003331831379823">ОћОцОбОюОф ОћОћОњОЊОеОћ ОаОЏОЕОюОћ ОбОЮ ОћОеОЕОљОЋОф ОъОЋОеОЌОЉОЋОф. <ph name="METAINSTALLER_ERROR" /></translation>
<translation id="3600428265489994557">РђЈОЏОаОЎОАОћ Ою-Chromium</translation>
<translation id="3639635944603682591">РђЈОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЕОю ОћОљОЊОЮ ОћОќОћ ОЎОЎОъОЌОДОЋ ОъОћОъОЏОЕОЎОе. ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОаОфОЋОаОЎОЮ, ОЎОЕ ОюОћОЎОЏОаОА Ою-Chromium ОЉОфОЋОе <ph name="USER_EMAIL" />.</translation>
<translation id="364817392622123556">{COUNT,plural, =0{РђЈОЎОЕ ОбОЊОЏОЋОЪ ОЌОЊОЕ ОЉОЕОЉОЎОю Chromium ОЋОћОъОбОеОЏОф ОфОЌОЎОю ОљОЋОфОЋ ОЉОеОњОб ОЕОфОЉОЋОдОб ОћОцОбОюОћ ОъОЌОЊОЕ.}=1{РђЈОЎОЕ ОбОЊОЏОЋОЪ ОЌОЊОЕ ОЉОЕОЉОЎОю Chromium ОЋОћОъОбОеОЏОф ОфОЌОЎОю ОљОЋОфОЋ ОЉОеОњОб ОЕОфОЉОЋОдОб ОћОцОбОюОћ ОъОЌОЊОЕ. ОћОЌОюОЋОЪ ОћОљОаОЋОаОЎОъОЎ ОюОљ ОЎОЎОцОфОЌ ОъОЌОЊОЕ.}one{РђЈОЎОЕ ОбОЊОЏОЋОЪ ОЌОЊОЕ ОЉОЕОЉОЎОю Chromium ОЋОћОъОбОеОЏОф ОфОЌОЎОю ОљОЋОфОЋ ОЉОеОњОб ОЕОфОЉОЋОдОб ОћОцОбОюОћ ОъОЌОЊОЕ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}two{РђЈОЎОЕ ОбОЊОЏОЋОЪ ОЌОЊОЕ ОЉОЕОЉОЎОю Chromium ОЋОћОъОбОеОЏОф ОфОЌОЎОю ОљОЋОфОЋ ОЉОеОњОб ОЕОфОЉОЋОдОб ОћОцОбОюОћ ОъОЌОЊОЕ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}other{РђЈОЎОЕ ОбОЊОЏОЋОЪ ОЌОЊОЕ ОЉОЕОЉОЎОю Chromium ОЋОћОъОбОеОЏОф ОфОЌОЎОю ОљОЋОфОЋ ОЉОеОњОб ОЕОфОЉОЋОдОб ОћОцОбОюОћ ОъОЌОЊОЕ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}}</translation>
<translation id="3651803019964686660">РђЈОЏОЊОЎ ОюОЕОюОЋОЌ ОъОАОцОе Оъ-<ph name="ORIGIN" /> ОюОўОюОцОЋОЪ Android ОЕОюОџ, ОдОеОЎОџ ОюОћОЎОЏОаОА ОљОю Chromium ОЉОЕОаОЎ ОћОъОЏОЕОЎОеОЎОЮ.</translation>
<translation id="3667616615096815454">ОљОЎОЪ ОљОцОЕОеОЋОф ОюОћОфОДОЎОЪ, ОћОљОцОюОЎОДОдОЎОћ ОюОљ ОъОЋОЏОеОф ОюОЕОеОф.</translation>
<translation id="3675854891107786059">РђЈОЕОЎОъОЋОЕ ОЉ<ph name="BEGIN_LINK" />ОЉОЎОўОЋОЎ ОАОЎОАОъОћ ОъОЕОюОџ<ph name="END_LINK" /> ОЏОЊОЎ ОюОћОдОцОЎОЪ ОљОф ОЏОю ОаОфОЋОаОЎ Chromium ОЉОЌОЕОЉОЋОЪ Google. ОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЋОЏОфОЋОЉОЋОф ОЕОаОЕОъОеОЋ ОЉ-Google Pay ОюОљ ОЎОЋОдОцОаОЋ. ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЉ-Chromium ОюОљ ОфОАОЋОаОЏОеОЪ.</translation>
<translation id="3685209450716071127">РђЈChromium ОюОљ ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў.</translation>
<translation id="370962675267501463">{COUNT,plural, =0{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ}=1{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ. ОћОЌОюОЋОЪ ОћОљОаОЋОаОЎОъОЎ ОюОљ ОЎОЎОцОфОЌ ОъОЌОЊОЕ.}one{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}two{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}other{РђЈОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ. # ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ.}}</translation>
<translation id="3713809861844741608">РђЈОцОфОЎОЌОф ОћОДОЎОЕОЋОе ОЉ&amp;ОЏОеОўОЎОАОЎОЎОф Chromium ОЌОЊОЕОћ</translation>
<translation id="3728124580182886854">РђЈОљОцОЕОе ОюОДОЕОе ОљОф Chromium ОюОЕОЎОеОЋОфОЎ Google ОљОЌОеОЎОЮ ОюОдОЋОеОџ ОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОюОъОўОеОЋОф ОљОЌОеОЋОф</translation>
<translation id="3729187154190517324">ОЏОЊОЎ ОюОћОбОъОЎОД ОљОф ОћОЌОЎОцОЋОЕ, ОљОцОЕОе ОюОћОЋОАОЎОБ ОЏОъОћ ОЏОеОўОЎОАОЎОЋОф, ОДОЉОдОЎОЮ ОЋОЏОюОЎОЮ ОЉОљОъОдОбОЋОф ОћОЏОцОфОЋОе "ОћОЋОАОцОф ОЏОеОўОЎОАОЎОЎОћ ОЋОбОЋОЊ".</translation>
<translation id="3788675262216168505">РђЈОаОЎОћОЋОю ОћОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium</translation>
<translation id="3790262771324122253">РђЈОюОъОћ ОћОЋОеОЊОЋОф ОъОАОЋОЎОъОЋОф ОаОЌОАОъОЋОф ОЉ-Chromium</translation>
<translation id="379589255253486813">РђЈChromium ОЎОбОЊОЏОЪ ОљОЋОфОџ ОљОЮ ОЎОЕ ОъОЕОћОЋ ОЕОдОеОЎОџ ОюОЉОЊОЋОД</translation>
<translation id="3798048725356732506">РђЈОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium ОбОЋОќОеОЎОЮ ОюОћОцОеОЎОЊ ОЉОЎОЪ ОЌОюОДОЎОЮ ОЕОЋОаОЎОЮ ОЉОЌОЎОЎОЮ. ОљОцОЕОе ОюОћОЋОАОЎОБ ОцОеОЋОцОЎОю ОЌОЊОЕ ОбОЏОЕОЎОЋ.</translation>
<translation id="3802055581630249637">РђЈОЏОЊОЎ ОЕОћОЊОцОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОЎОЎОўОбОаОЋ ОъОћОе ОЎОЋОфОе, ОъОбОеОЏОф Chromium ОўОЋОбОаОф ОъОеОљОЕ ОЊОцОЎОЮ ОЕОЎОЕ ОАОЎОЏОЋОЎ ОњОЉОЋОћ ОЕОЎОЎОцОфОЌОЋ.</translation>
<translation id="3810973564298564668">ОаОЎОћОЋОю</translation>
<translation id="3846683726093018685">**ОАОЎОЏОЋОЮ:** ОЉОъОЕОцОў ОљОЌОЊ ОЕОю ОцОЌОЋОф Оъ-30 ОъОЎОюОЎОЮ, ОдОеОЎОџ ОюОфОљОе ОљОф ОћОаОЋОЕОљ ОЋОћОъОўОеОћ ОћОбОЎОДОеОЎОЎОЮ ОЕОю ОћОфОЋОЏОЪ ОЉОдОЎОюОЋОЮ ОћОъОАОџ.

          **ОћОдОбОф ОЕОљОюОЋОф:** ОЎОдОЎОеОф ОеОЕОЎОъОћ ОЕОю 3-5 ОЕОљОюОЋОф ОъОбОЋОеОеОЋОф ОъОЌОЕОЉОћ ОЕОћОъОЕОфОъОЕ ОЎОЏОЋОю ОюОЕОљОЋОю ОЏОЊОЎ ОюОћОЉОЎОЪ ОўОЋОЉ ОЎОЋОфОе ОљОф ОдОЎОюОЋОЮ ОћОъОАОџ. ОюОцОЌОЋОф ОЕОљОюОћ ОљОЌОф ОдОеОЎОЏОћ ОюОћОфОЎОЎОЌОА ОЉОљОЋОцОЪ ОАОцОдОЎОцОЎ ОюОљОЋОЉОЎОЎОДОў ОЌОќОЋОфОЎ, ОюОбОЎОдОЋОЉ ОЕОюОЋ ОљОЋ ОюОъОЎОДОЋОЮ ОЕОюОЋ.</translation>
<translation id="3848258323044014972"><ph name="PAGE_TITLE" /> - Chromium</translation>
<translation id="3885770153807205175">ОћОЏОюОЎ ОюОЉОЌОЎОеОф ОЕОцОћ</translation>
<translation id="388648406173476553">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОаОЎОћОЋОю ОЕОю Chromium ОаОЌОЋОдОћ ОцОбОЋОюОћ ОЕОюОџ - ОЎОЕ ОюОюОЌОЋОЦ ОюОДОЉОюОф ОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ.</translation>
<translation id="3889543394854987837">РђЈОЎОЕ ОюОюОЌОЋОЦ ОбОю ОћОЕОЮ ОЕОюОџ ОЏОЊОЎ ОюОцОфОЋОЌ ОљОф Chromium ОЋОюОћОфОЌОЎОю ОюОњОюОЋОЕ.</translation>
<translation id="3892148308691398805">ОћОбОфОДОф ОћОўОДОАОў</translation>
<translation id="390528597099634151">РђЈОћОъОЕОфОъОЕ <ph name="EXISTING_USER" /> ОЏОЉОе ОъОЌОЋОЉОе ОюОцОеОЋОцОЎОю Chromium ОћОќОћ. ОЏОЊОЎ ОюОћОцОеОЎОЊ ОЉОЎОЪ ОцОбОЎОюОЋОЎОЋОф ОњОюОЎОЕОћ, Chromium ОЎОЏОЋОю ОюОЎОдОЋОе ОбОЉОЋОеОџ ОцОеОЋОцОЎОю ОъОЕОюОџ.</translation>
<translation id="3909353120217047026">РђЈОћОфОЋОАОБ ОћОќОћ ОъОцОе ОљОф ОћОъОЊОЎОаОЎОЋОф ОЕОю ОЌОаОЋОф ОћОљОЎОаОўОеОаОў ОЕОю Chrome, ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОЋОљ ОюОљ ОЉОўОЋОЌ. ОдОеОЎОџ ОюОћОАОЎОе ОљОЋОфОЋ Оъ-Chromium ОЏОЊОЎ ОюОљ ОюОљОцОЕОе ОюОЋ ОЎОЋОфОе ОюОћОдОЎОњ ОЋОюОЕОаОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОфОфОЉОдОб ОЏОаОЎОАОћ, ОЏОЋОюОю ОћОцОеОўОЎОЮ ОћОљОЎОЕОЎОЎОЮ ОЕОюОџ.</translation>
<translation id="3937491663738985329">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chromium</translation>
<translation id="3941890832296813527">ОЕОњОЎОљОф ОћОфОДОаОћ: ОЕОЮ ОћОДОЋОЉОЦ ОЕОю ОъОаОћОю ОћОћОфОДОаОћ ОюОљ ОфОДОЎОЪ ОљОЋ ОюОљ ОаОфОъОџ.</translation>
<translation id="3945058413678539331">РђЈChromium ОъОаОАОћ ОюОћОбОфОЎОД ОљОф ОћОАОЎОАОъОљОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОюОъОбОеОЏОф ОюОбОЕОЋОф ОќОљОф, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ Ою-Windows.</translation>
<translation id="3954172517175569325">РђЈОћОАОЎОАОъОљОЋОф, ОљОъОдОбОЎ ОћОфОЕОюОЋОЮ ОЋОћОЏОфОЋОЉОЋОф ОЕОЕОъОеОф ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google ОЎОЋОАОеОЋ ОъОћОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЕОЋОЉ ОЉ-Chromium, ОдОеОЎОџ ОюОћОЎОЏОаОА ОЕОЋОЉ ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="395904275706073188">ОюОљ ОаОЎОфОЪ ОюОДОеОЋОљ ОЊОцОЎОЮ ОъОЋОњОаОЎОЮ. ОЏОЊОљОЎ ОюОаОАОЋОф ОЊОБ ОљОЌОе.</translation>
<translation id="3962647064319009959">РђЈОљОЎОџ ОъОбОеОЏОф Chromium ОЕОЋОъОеОф ОбОю ОћОљОЉОўОЌОћ ОЕОюОџ</translation>
<translation id="3971865010372729242">РђЈОЏОЕОъОДОюОЎОЊОЎОЮ ОўОДОАОў ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОљОЋ ОЉОфОЎОЉОф ОћОЌОЎОцОЋОЕ, Chromium ОЕОЋОюОЌ ОљОф ОћОўОДОАОў ОћОќОћ ОюОЏОюОЎ ОћОЌОЎОцОЋОЕ, ОћОЉОЎОаОћ ОћОъОюОљОЏОЋОфОЎОф ОЋОћОАОЋОЏОаОЎОЮ ОЕОю ОћОљОеОњОЋОЪ ОЏОЊОЎ ОюОДОЉОю ОћОдОбОЋОф.</translation>
<translation id="3975724895399328945">РђЈОъОЎОЊОб ОбОю &amp;Google Chrome for Testing</translation>
<translation id="3997429360543082038">РђЈОъОЎОЊОб ОбОю ChromiumOS</translation>
<translation id="4019629340646866719">РђЈОћОЕОЎОъОЋОЕ ОЉ-ChromiumOS ОъОфОљОцОЕОе ОЉОќОЏОЋОф <ph name="BEGIN_LINK_CROS_OSS" />ОфОЋОЏОаОЋОф ОДОЋОЊ ОцОфОЋОЌ<ph name="END_LINK_CROS_OSS" /> ОаОЋОАОцОЋОф ОЏОъОЋ <ph name="BEGIN_LINK_LINUX_OSS" />ОАОЉОЎОЉОф ОћОцОЎОфОЋОЌ ОЕОю Linux<ph name="END_LINK_LINUX_OSS" />.</translation>
<translation id="4022972681110646219">ОфОеОњОЋОЮ ОћОъОАОџ</translation>
<translation id="4023601594785368013">ОЕОцОћ ОъОДОЋОеОЎОф: <ph name="LANGUAGE" /></translation>
<translation id="4023845192681161785">РђЈОљОцОЕОе ОюОцОфОЋОЌ ОДОЎОЕОЋОеОЎОЮ ОЉ-Chromium ОъОЏОю ОљОцОюОЎОДОдОЎОћ. ОЉОаОЋОАОБ Chromium ОъОЋОдОъОЊ ОюОЕОЋОеОф ОћОъОЕОЎОъОЋОф ОюОњОЎОЕОћ ОаОЋОЌОћ.</translation>
<translation id="4036079820698952681">РђЈОЊОЎОЋОЋОЌ ОбОю <ph name="BEGIN_LINK" />ОћОћОњОЊОеОЋОф ОћОаОЋОЏОЌОЎОЋОф<ph name="END_LINK" /> ОЎОбОќОЋОе ОюОЕОцОе ОљОф Chromium</translation>
<translation id="4039097928859803404">РђЈОфОъОЎОЊ ОюОћОдОЎОњ ОљОф ОДОЎОдОЋОеОЎ ОћОЊОеОџ ОюОъОдОЉ AI</translation>
<translation id="4050175100176540509">ОћОњОеОАОћ ОћОЌОЊОЕОћ ОЏОЋОюОюОф ОЕОЎОцОЋОеОЎ ОЉОўОЎОЌОЋОф ОЌОЕОЋОЉОЎОЮ ОЋОфОЏОЋОаОЋОф ОЌОЊОЕОЋОф.</translation>
<translation id="4055805654398742145">ОъОаОћОю ОћОА&amp;ОЎОАОъОљОЋОф</translation>
<translation id="4061696872429826774">РђЈОфОЋОЏОаОћ ОљОЌОеОф ОЉОъОЌОЕОЉ ОЕОюОџ ОћОЋОАОЎОцОћ ОфОЋОАОБ ОЕОбОюОЋОю ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chromium.

<ph name="EXTENSION_NAME" /></translation>
<translation id="4095980151185649725">{COUNT,plural, =1{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ ОЊОДОћ. ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф.}one{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ # ОЊОДОЋОф. ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф.}two{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ # ОЊОДОЋОф. ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф.}other{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ # ОЊОДОЋОф. ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОЎОЎОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф.}}</translation>
<translation id="4118474109249235144">РђЈОъОдОЉ ОцОеОўОЎ ОЉ-Chromium</translation>
<translation id="4122186850977583290">РђЈОъОбОЉОе ОюОЊОБ 'ОъОЎОЊОб ОбОю Chromium'</translation>
<translation id="4147856324248078748">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chromium</translation>
<translation id="4148957013307229264">ОъОфОДОЎОЪ...</translation>
<translation id="419998258129752635">РђЈ<ph name="PAGE_TITLE" /> РђЊ ОЏОаОЎОАОћ ОюОеОЕОф РђЊ Chromium</translation>
<translation id="421369550622382712">РђЈОљОцОюОЎОДОдОЎОЋОф, ОъОЕОЌОДОЎОЮ, ОфОЋОАОцОЎОЮ ОЋОбОЎОдОЋОЉОЎОЮ ОъОбОЋОюОЎОЮ ОЉОЕОЉОЎОю Chromium.</translation>
<translation id="4217080900579554343">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОфОЋОАОБ ОћОќОћ ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЌОЕОЉОЎОЮ, ОдОеОЎОџ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="4217972271355023382">РђЈОЏОЊОЎ ОюОЕОъОЋОе ОбОю ОћОЉОўОЎОЌОЋОф ОљОЋОаОюОЎОЎОЪ ОЉОћОфОљОЮ ОюОљОцОЕОеОЋОЎОЋОф ОЕОаОЉОЌОеОЋ ОбОю ОЎОЊОЎ ОћОћОЋОеОћ ОЕОюОџ, ОбОюОЎОџ ОюОбОЉОЋОе ОюОцОеОЋОцОЎОю Chromium ОЕОЉОЋ ОЏОЉОе ОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ ОбОЮ ОћОљОЎОъОЎОЎОю <ph name="USER_EMAIL_ADDRESS" /></translation>
<translation id="4222932583846282852">ОъОЉОўОюРђд</translation>
<translation id="4224210481850767180">ОћОћОфОДОаОћ ОЉОЋОўОюОћ.</translation>
<translation id="4230135487732243613">РђЈОћОљОЮ ОюОДОЕОе ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉ-Chromium ОюОЌОЕОЉОЋОЪ ОќОћ?</translation>
<translation id="4251772536351901305">РђЈОъОДОЉОюОЎОЮ ОљОќОћОеОЋОф ОюОњОЉОЎ ОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ, ОњОЮ ОЏОљОюОћ ОЕОюОљ ОћОЎОЋ ОЎОЊОЋОбОЎОЮ Ою-Google ОюОцОаОЎ ОЏОЪ, ОЉОбОќОеОф ОаОЎОфОЋОЌ ОЕОю ОЎОЋОфОе ОаОфОЋОаОЎОЮ ОъОљОфОеОЎОЮ ОЉОћОЕОЋОЋОљОћ ОюОћОњОаОћ ОћОеОњОЎОюОћ. ОљОцОЕОе ОюОЊОюОњ ОбОю ОћОљОќОћОеОЋОф Оъ-Chromium.</translation>
<translation id="4269093074552541569">РђЈОЎОдОЎОљОћ Оъ-Chromium</translation>
<translation id="4271805377592243930">РђЈОбОќОеОћ ОЉОаОЋОЕОљ Chromium</translation>
<translation id="4281844954008187215">ОфОаОљОЎ ОЕОЎОеОЋОф</translation>
<translation id="4285930937574705105">РђЈОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЉОЕОю ОЕОњОЎОљОћ ОюОљ ОдОцОЋОЎОћ. ОљОЮ Chromium ОцОЋОбОю ОЏОбОф, ОЎОЕ ОюОАОњОЋОе ОљОЋОфОЋ ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="4298125729853015961">РђЈОЎОЎОдОЋОљ ОАОЎОАОъОљОЋОф Оъ-Chromium</translation>
<translation id="4304713468139749426">ОъОаОћОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="4334241893986177674">ОЌОЎОцОЋОЕ ОдОЎОюОЋОЮ ОћОъОАОџ ОћОќОћ</translation>
<translation id="4334294535648607276">ОћОћОЋОеОЊОћ ОћОЋОЕОюОъОћ.</translation>
<translation id="439358628917130594">РђЈОюОцОЎ ОЊОеОЎОЕОф <ph name="MANAGER" />, ОЎОЕ ОюОДОеОЋОљ ОљОф ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОћОЉОљОЎОЮ ОЋОюОћОАОЏОЎОЮ ОюОћОЮ ОюОцОаОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОћОќОћ. ОфОаОљОЎОЮ ОљОюОћ ОюОљ ОъОеОЌОЎОЉОЎОЮ, ОъОЕОаОЎОЮ ОљОЋ ОъОњОЉОЎОюОЎОЮ ОљОф ОћОфОаОљОЎОЮ ОЕОю ChromiumOS.</translation>
<translation id="4407044323746248786">РђЈОюОАОњОЋОе ОљОф Chromium ОЉОЏОю ОќОљОф?</translation>
<translation id="4413205837991854510">ОфОъОЎОЊ ОюОћОдОЎОњ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОюОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф</translation>
<translation id="4415566066719264597">РђЈChromium ОЎОЏОЋОю ОюОцОбОЋОю ОЉОеОДОб</translation>
<translation id="4419831163359812184">{NUM_EXTENSIONS,plural, =1{РђЈОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЋ Оъ-Chromium. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОфОЋОАОцОЎОЮ ОаОфОъОЏОЎОЮ<ph name="END_LINK" />}one{РђЈОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЮ Оъ-Chromium. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОфОЋОАОцОЎОЮ ОаОфОъОЏОЎОЮ<ph name="END_LINK" />}two{РђЈОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЮ Оъ-Chromium. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОфОЋОАОцОЎОЮ ОаОфОъОЏОЎОЮ<ph name="END_LINK" />}other{РђЈОљОаОЌОаОЋ ОъОъОюОЎОдОЎОЮ ОюОћОАОЎОе ОљОЋОфОЮ Оъ-Chromium. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОфОЋОАОцОЎОЮ ОаОфОъОЏОЎОЮ<ph name="END_LINK" />}}</translation>
<translation id="4423735387467980091">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОЕОюОЎОўОћ ОЉ-Chromium</translation>
<translation id="4427306783828095590">ОбОЮ ОћОћОњОаОћ ОћОъОЕОЋОцОеОф, ОћОЌОАОЎОъОћ ОЕОю ОцОЎОЕОЎОаОњ ОЋОфОЋОЏОаОЋОф ОќОЊОЋОаОЎОЋОф ОъОДОЎОцОћ ОЎОЋОфОе</translation>
<translation id="4434353761996769206">ОЕОњОЎОљОф ОъОаОћОю ОћОфОДОаОћ: <ph name="INSTALLER_ERROR" /></translation>
<translation id="4438870983368648614">РђЈОћОљОеОњОЋОЪ '<ph name="MANAGER" />' ОъОаОћОю ОљОф Chromium</translation>
<translation id="444069871276811466">РђЈОћОЋОАОцОф ОцОеОЋОцОЎОю Chromium</translation>
<translation id="4447409407328223819">РђЈОъОЎОЊОб ОбОю Chrome for Testing</translation>
<translation id="4470974262661801543">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google, ОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЕОюОџ</translation>
<translation id="4493028449971051158">ОЕОњОЎОљОф ОћОцОбОюОћ: ОЎОЕ ОюОћОцОбОЎОю ОљОф ОъОаОћОю ОћОћОфОДОаОћ ОЏОљОЊОъОЎОЪ.</translation>
<translation id="4501471624619070934">ОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЏОЎ ОћОњОЎОЕОћ ОъОЋОњОЉОюОф ОЉОъОЊОЎОаОћ ОћОќОЋ.</translation>
<translation id="4510853178268397146">РђЈОюОфОЋОАОБ ОћОќОћ ОюОљ ОцОЋОеОАОъОЋ ОаОЋОћОюОЎ ОцОеОўОЎОЋОф, ОюОъОЕОю ОћОљОЋОцОЪ ОЕОЉОЋ ОћОЋОљ ОљОЋОАОБ ОаОфОЋОаОЎОЮ ОЋОъОЕОфОъОЕ ОЉОћОЮ. ОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЋ.</translation>
<translation id="452711251841752011">РђЈОЉОеОЋОџ ОЉОЋОљОџ ОљОю Chromium. ОаОцОфОЌ ОЌОюОЋОЪ ОЌОЊОЕ ОЉОЊОцОЊОцОЪ</translation>
<translation id="4531137820806573936">РђЈОю-Chromium ОаОЊОеОЕОф ОћОеОЕОљОћ ОЏОЊОЎ ОюОъОцОЋОф ОљОф ОћОАОЉОЎОЉОћ ОЕОюОџ ОЋОюОбОДОЋОЉ ОљОЌОеОЎ ОфОаОЋОбОЋОф ОћОЎОЊОЎОЎОЮ</translation>
<translation id="4534145890176164066">РђЈРђФChromium ОъОЉОЎОЪ ОљОф ОћОўОцОАОЎОЮ ОўОЋОЉ ОЎОЋОфОе ОЋОЎОЏОЋОю ОюОъОюОљ ОљОЋОфОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОъОћОе ОЎОЋОфОе</translation>
<translation id="4536805923587466102">РђЈОЏОЉОе ОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ ОЉОфОЋОе <ph name="USER_EMAIL_ADDRESS" /> ОЉОцОеОЋОцОЎОю Chromium ОљОЌОе</translation>
<translation id="4548534452171747496">РђЈРђФChromium ОўОЋОбОЪ ОъОеОљОЕ ОЊОцОЎОЮ ОЋОЏОџ ОаОЎОфОЪ ОюОњОюОЋОЕ ОЋОюОЌОцОЕ ОъОћОе ОЎОЋОфОе. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОЊОцОЎОЮ<ph name="END_LINK" /></translation>
<translation id="4567424176335768812">ОаОЏОаОАОф ОюОъОбОеОЏОф ОЉОфОЋОе <ph name="USER_EMAIL_ADDRESS" />. ОЏОбОф ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОњОЕОф ОљОю ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОћОњОЊОеОЋОф ОљОЌОеОЋОф ОЕОюОџ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОћОЮ ОћОфОЌОЉОеОф ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="4570813286784708942">РђЈChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОљОф ОЏОЎ ОћОЕОЉОфОф ОљОф ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОЋОљОЎ ОљОцОЕОе ОюОљОъОф ОљОф ОћОДОЋОЉОЦ</translation>
<translation id="4594305310729380060">ОЕОъОЎОеОћ ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="459535195905078186">РђЈОЎОЎОЕОЋОъОЎ Chromium</translation>
<translation id="4598116752460667024">ОъОЌОцОЕОЎОЮ ОфОћОюОЎОџ ОЏОюОЕОћОЋ ОъОћОеОЕОЎОъОћ.</translation>
<translation id="4613863813562375431">РђЈОњОеОАОф ChromiumOS</translation>
<translation id="4621240073146040695">РђЈОћОбОЊОЏОЋОЪ ОЏОъОбОў ОћОЋОЕОюОЮ! ОћОцОбОю ОъОЌОЊОЕ ОљОф ChromiumРђЈ ОЏОЊОЎ ОюОАОЎОЎОЮ ОљОф ОћОбОЊОЏОЋОЪ.</translation>
<translation id="4625064703209785397">РђЈОљОцОЕОе ОюОћОљОЎОЦ ОЉОЎОдОЋОбОЎОЮ ОЕОю ОљОфОеОЎОЮ ОЉОљОъОдОбОЋОф ОъОаОЋОб V8 ОЕОю Chromium, ОљОЉОю Chromium ОЎОћОЎОћ ОДОдОф ОцОЌОЋОф ОбОъОЎОЊ ОЉОцОаОЎ ОъОфОДОцОЋОф.</translation>
<translation id="4654936675281451226">РђЈРђФChromium ОъОЉОЎОЪ ОљОф ОћОўОцОАОЎОЮ ОўОЋОЉ ОЎОЋОфОе ОЋОЎОЏОЋОю ОюОъОюОљ ОљОЋОфОЮ ОљОЋОўОЋОъОўОЎОф ОъОћОе ОЎОЋОфОе. ОћОћОњОЊОеОћ ОћОќОЋ ОцОЋОбОюОф.</translation>
<translation id="4665829708273112819">РђЈОљОќОћОеОћ: Chromium ОюОљ ОЎОЏОЋОю ОюОъОаОЋОб ОъОфОЋОАОцОЎОЮ ОюОфОбОЊ ОљОф ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЕОюОџ. ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОћОфОЋОАОБ ОћОќОћ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ, ОдОеОЎОџ ОюОЉОўОю ОљОф ОћОЉОЌОЎОеОћ ОЕОю ОћОљОцОЕОеОЋОф ОћОќОЋ.</translation>
<translation id="4673151026126227699">РђЈОљОЮ ОЉОаОЋОАОБ ОЎОЕОЋОфОцОЋ ОЊОЋОЌОЋОф ОЕОЎОъОЋОЕ ОЉ-Chromium, ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОюОюОЋ ОљОф ОЏОфОЋОЉОЋОф Оћ-URL ОЕОЉОћОЪ ОЉОЎОДОеОф</translation>
<translation id="4677944499843243528">РђЈОаОеОљОћ ОЕОћОцОеОЋОцОЎОю ОаОъОдОљ ОЉОЕОЎОъОЋОЕ ОбОю ОЎОЊОЎ ОфОћОюОЎОџ Chromium ОљОЌОе (<ph name="PROCESS_ID" />) ОЉОъОЌОЕОЉ ОљОЌОе (<ph name="HOST_NAME" />)РђЈ. Chromium ОаОбОю ОљОф ОћОцОеОЋОцОЎОю ОЏОЊОЎ ОЕОюОљ ОЎОЎОцОњОЮ. ОљОЮ ОЋОЎОЊОљОф ОЕОљОБ ОфОћОюОЎОџ ОљОЌОе ОљОЎОаОЋ ОъОЕОфОъОЕ ОЉОцОеОЋОцОЎОю ОќОћ, ОљОцОЕОе ОљОф ОаОбОЎОюОф ОћОцОеОЋОцОЎОю ОЋОюОћОцОбОЎОю ОљОф Chromium ОъОЌОЊОЕ.</translation>
<translation id="4680828127924988555">ОЉОЎОўОЋОю ОћОћОфОДОаОћ</translation>
<translation id="469259825538636168">РђЈОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉ-Chromium ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google. ОЏОЊОљОЎ ОюОЌОЏОЋОф ОЏОъОћ ОЊОДОЋОф ОюОцОаОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ.</translation>
<translation id="4708193446201257833">РђЈОЏОЕОъОЌОЋОЉОеОЎОЮ ОюОЌОЕОЉОЋОЪ, ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОЋОЉОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ ОъОЌОЕОЉОЋОЪ Google ОЉ-Chromium. ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОЋОф ОЕОю ОЕОЎОеОЋОфОЎ Google ОЉОљОъОдОбОЋОф ОДОЎОдОЋОе ОћОЊОеОџ <ph name="SHORTCUT" />.</translation>
<translation id="4708774505295300557">РђЈОъОЎОЕОћОЋ ОаОЏОаОА ОЉОбОЉОе Ою-Chromium ОъОћОъОЌОЕОЉ ОћОќОћ ОЏ-<ph name="ACCOUNT_EMAIL_LAST" />. ОЎОЕ ОюОЎОдОЋОе ОъОЕОфОъОЕ ОЌОЊОЕ Ою-Chromium ОЏОЊОЎ ОюОЕОъОЋОе ОбОю ОцОеОўОЎОЋОф ОћОъОЎОЊОб ОЕОюОџ.</translation>
<translation id="4724676981607797757">ОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЉОњОюОю ОЕОњОЎОљОф ОцОеОЋОўОЋОДОЋОю ОЕОюОљ ОаОфОъОџ.</translation>
<translation id="4746050847053251315">РђЈОюОАОњОЋОе ОљОф Chromium ОЉОЏОю ОќОљОф?</translation>
<translation id="4748217263233248895">РђЈОЉОЋОдОб ОбОЊОЏОЋОЪ ОљОЉОўОЌОћ ОъОЎОЋОЌОЊ ОЕОю Chromium. ОбОЏОЕОЎОЋ ОбОюОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОЋОљОаОЌОаОЋ ОаОЕОЌОќОе ОљОф ОћОЏОеОўОЎОАОЎОЋОф.</translation>
<translation id="4759645701210484457">РђЈОЕОЋОљОюОЎОЮ ОљОф Chromium</translation>
<translation id="4771701986670315895">РђЈОюОљ ОаОЏОаОАОф ОюОљОфОе ОћОќОћ ОЉОќОъОЪ ОћОљОЌОеОЋОЪ. ОћОћОеОЕОљОЋОф "<ph name="PERMISSION_1" />", "<ph name="PERMISSION_2" />" ОЋОбОЋОЊ <ph name="COUNT" /> ОћОеОЕОљОЋОф ОћОЋОАОеОЋ ОбОю ОЎОЊОЎ Chromium.</translation>
<translation id="4788777615168560705">РђЈChromium ОюОљ ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОЉОбОЋОЊ 24 ОЕОбОЋОф ОљОЋ <ph name="BEGIN_LINK" />ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google<ph name="END_LINK" />.</translation>
<translation id="479167709087336770">РђЈОаОбОЕОћ ОЏОљОЪ ОЕОЎОъОЋОЕ ОЉОЉОЊОЎОДОф ОћОљОЎОЋОф ОЕОю ОЌОЎОцОЋОЕ Google. ОћОўОДОАОў ОћОъОЋОДОюОЊ ОЉОЊОцОЊОцОЪ ОаОЕОюОЌ ОљОю Google. ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОћОћОфОаОћОњОЋОф ОћОќОЋ ОЉОЏОю ОЕОюОЉ ОЊОеОџ ОћОћОњОЊОеОЋОф.</translation>
<translation id="4814736265800133385">РђЈОЕОЎОъОЋОЕ ОЉ-Chromium ОюОюОљ ОЌОЕОЉОЋОЪ</translation>
<translation id="4888717733111232871">РђЈОЏОюОю ОаОЏОаОА ОбОЉОЋОе Chromium ОбОю ОъОаОф ОюОљОцОЕОе ОфОаОЋОбОф mDNS.</translation>
<translation id="4893347770495441059">РђЈОћОцОбОюОћ ОъОЌОЊОЕ ОюОдОЋОеОџ ОбОЊОЏОЋОЪ &amp;Chromium</translation>
<translation id="4918844574251943176">ОћОфОъОЋОаОћ ОћОЋОбОфОДОћ</translation>
<translation id="4943838377383847465">РђЈChromium ОаОъОдОљ ОЉОъОдОЉ ОеОДОб.</translation>
<translation id="494490797786467921">РђЈОљОцОЕОе ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОАОњОЋОе ОљОф ОфОЎОЉОф ОћОЊОЋ-ОЕОЎОЌ ОЕОю ОћОЏОаОЎОАОћ Ою-Chromium</translation>
<translation id="4950660488495335294">РђЈОЉОљОъОдОбОЋОф ОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium, ОљОцОЕОе ОюОћОцОеОЎОЊ ОљОф ОЏОю ОћОцОеОЎОўОЎОЮ ОЉ-Chromium. ОљОцОЕОе ОюОЎОдОЋОе ОцОеОЋОцОЎОюОЎОЮ ОЕОъОЎОЋОбОЊОЎОЮ ОюОЌОЉОеОЎОЮ ОЋОюОЉОаОЎ ОъОЕОцОЌОћ ОљОЋ ОцОеОЋОцОЎОюОЎОЮ ОаОцОеОЊОЎОЮ ОюОбОЉОЋОЊОћ ОЋОюОЉОЎОюОЋОЎОЎОЮ ОЉОЕОбОЋОф ОћОцОаОљОЎ.</translation>
<translation id="4987820182225656817">РђЈОљОЋОеОЌОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉ-Chromium ОЉОюОЎ ОюОћОЕОљОЎОе ОЊОЉОе ОъОљОЌОЋОе.</translation>
<translation id="4992938037305302429">РђЈОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Chromium</translation>
<translation id="4994636714258228724">РђЈОћОЋОАОцОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ Ою-Chromium</translation>
<translation id="5123973130450702873">РђЈОдОеОЎОџ ОюОфОф Ою-Chromium ОћОеОЕОљОћ ОЏОЊОЎ ОюОбОДОЋОЉ ОљОЌОеОЎ ОфОаОЋОбОЋОф ОћОЎОЊОЎОЎОЮ</translation>
<translation id="5141988424377517949">РђЈОюОљ ОаОЏОаОАОф ОюОљОфОе ОћОќОћ ОЉОќОъОЪ ОћОљОЌОеОЋОЪ. ОћОћОеОЕОљОЋОф "<ph name="PERMISSION_1" />", "<ph name="PERMISSION_2" />" ОЋ"<ph name="PERMISSION_3" />" ОћОЋОАОеОЋ ОбОю ОЎОЊОЎ Chromium.</translation>
<translation id="5167819546851111585">ОљОЎОџ ОљОаОЎ ОЎОЏОЋОю ОюОбОќОЋОе ОюОџ?</translation>
<translation id="5174969993834422967">ОћОЉОЌОЎОеОћ ОЕОюОџ ОћОЎОљ ОЉОЊОеОџ ОЏОюОю ОюОЌОАОЋОЮ ОћОфОеОљОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОюОљОфОе ОћОќОћ ОюОћОдОЎОњ ОћОфОеОљОЋОф, ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОАОъОю ОћОћОфОеОљОћ ОЉОцОЎОаОћ ОћОЕОъОљОюОЎОф ОЕОю ОАОеОњОю ОћОъОЎОДОЋОЮ.</translation>
<translation id="5174983315706567306">ОљОЎОЪ ОъОАОцОЎОД ОъОДОЋОЮ ОЉОЏОЋОаОЪ.</translation>
<translation id="5187123684706427865">РђЈОаОЊОеОЕ ОљОЎОъОЋОф ОъОЌОЊОЕ ОюОЌОЕОЉОЋОЪ Chromium</translation>
<translation id="5224391634244552924">РђЈОљОЎОЪ ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф. Chromium ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОеОД ОљОЮ ОЕОъОеОф ОљОЋОфОЪ.</translation>
<translation id="5231355151045086930">РђЈОЎОдОЎОљОћ Оъ-Chromium</translation>
<translation id="5234764350956374838">ОАОњОЎОеОћ</translation>
<translation id="5254739261293693943">ОљОцОЕОе ОюОЕОљОЋОю ОЕОљОюОЋОф ОюОњОЉОЎ ОћОАОеОўОЋОЪ ОћОќОћ</translation>
<translation id="5277894862589591112">РђЈОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОЕОЎОаОЋОЎОЎОЮ ОЕОЉОЎОдОбОф, ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium</translation>
<translation id="5286907366254680517">ОќОЋОћОфОћ</translation>
<translation id="5294316920224716406">РђЈОЉОњОюОЎОЕОћ ОЉОъОдОЉ ОцОеОўОЎ, Chromium ОЎОдОЎОњ ОљОќОћОеОћ ОюОцОаОЎ ОўОбОЎОаОф ОљОфОе ОЉОљОъОдОбОЋОф ОЌОЎОЉОЋОе ОюОљ ОъОљОЋОЉОўОЌ</translation>
<translation id="5313228254328109263">РђЈОЕОЎОеОЋОф ОцОаОЎОъОЎ ОюОбОЊОЏОЋОЪ ОЕОю Chromium</translation>
<translation id="5346389065299425353">ОЏОЊОЎ ОюОћОбОъОЎОД ОљОф ОћОЌОЎОцОЋОЕ, ОљОцОЕОе ОюОћОЋОАОЎОБ ОЏОъОћ ОЏОеОўОЎОАОЎОЋОф, ОДОЉОдОЎОЮ ОЋОЏОюОЎОЮ</translation>
<translation id="5352264705793813212">РђЈОЎОЕ Ою-Chromium ОЏОъОћ ОћОъОюОдОЋОф ОюОњОЉОЎ ОЉОўОЎОЌОЋОф ОЕОЏОЊОљОЎ ОюОЉОЊОЋОД</translation>
<translation id="5352361688875342522">РђЈОцОеОЋОцОЎОюОЎОЮ ОљОЌОеОЎОЮ ОЉ-Chromium</translation>
<translation id="5358375970380395591">РђЈОћОЏОаОЎОАОћ ОЕОюОџ ОъОфОЉОдОбОф ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ ОъОаОЋОћОю ОЕОъОбОаОЎОД ОюОъОаОћОю ОћОъОбОеОЏОф ОЕОюОЋ ОЕОюОЎОўОћ ОбОю ОћОцОеОЋОцОЎОю ОЕОюОџ ОЉ-Chromium. ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉ-Chromium, ОЏОњОЋОЪ ОЎОЎОЕОЋОъОЎОЮ, ОАОЎОъОаОЎОЋОф, ОћОЎОАОўОЋОеОЎОћ, ОАОЎОАОъОљОЋОф ОЋОћОњОЊОеОЋОф ОљОЌОеОЋОф ОЎОЎОДОЕОеОЋ ОЉОљОЋОцОЪ ОДОЉОЋОб Ою-<ph name="USER_NAME" />. ОаОЎОфОЪ ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЉОљОъОдОбОЋОф ОюОЋОЌ ОћОЉОДОеОћ ОЕОю ОЌОЕОЉОЋОаОЋОф Google, ОљОЉОю ОюОљ ОаОЎОфОЪ ОюОЕОЎОЎОџ ОљОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОюОЌОЕОЉОЋОЪ ОљОЌОе. <ph name="LEARN_MORE" /></translation>
<translation id="5368118228313795342">ОДОЋОЊ ОаОЋОАОБ: <ph name="EXTRA_CODE" />.</translation>
<translation id="5377622451696208284">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОфОљОъОћ ОљОЎОЕОЎОф, ОдОеОЎОџ ОюОЏОюОЋОю ОљОф Chromium ОЉ'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф'</translation>
<translation id="5383439451358640070">РђЈОюОъОћ ОДОЉОдОЎОЮ ОъОАОЋОЎОъОЎОЮ ОаОЌОАОъОЎОЮ ОЉ-Chromium</translation>
<translation id="5386450000063123300">РђЈОъОфОЉОдОб ОбОЊОЏОЋОЪ ОЕОю ChromiumРђЈ (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="538767207339317086">РђЈОћОфОеОф ОЏОаОЎОАОћ ОљОю Chromium</translation>
<translation id="5405650547142096840">РђЈОюОћОАОЎОе Оъ-РђЈChromiumРђЈ</translation>
<translation id="5424544524441439284">РђЈОЎОеОЎОЊОћ ОЉОеОъОф ОћОЉОЎОдОЋОбОЎОЮ ОЉОфОъОЋОеОћ ОюОћОњОЉОеОф ОћОбОъОЎОЊОЋОф ОЕОю Chromium ОЉОцОаОЎ ОъОфОДОцОЋОф</translation>
<translation id="5427571867875391349">РђЈОћОњОЊОеОф Chromium ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЕОюОџ</translation>
<translation id="5438241569118040789">РђЈ<ph name="PAGE_TITLE" /> - Chromium ОЉОњОеОАОф ОЉОўОљ</translation>
<translation id="5460618461609401056">{NUM_TABS,plural, =1{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОЕОъОљОўОћ ОљОф ОћОЊОцОЊОцОЪ}one{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОъОљОўОЋОф ОљОф ОћОЊОцОЊОцОЪ}two{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОъОљОўОЋОф ОљОф ОћОЊОцОЊОцОЪ}other{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОЕОћОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОъОљОўОЋОф ОљОф ОћОЊОцОЊОцОЪ}}</translation>
<translation id="5473971139929175403">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕ-Chromium ОюОљ ОЎОцОбОю ОЏОеОљОЋОЎ ОЏОЎ ОћОЋОљ ОЏОЉОе ОюОљ ОаОфОъОџ ОЉОњОеОАОћ ОћОќОЋ ОЕОю Linux</translation>
<translation id="5475924890392386523">РђЈРђФChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОЋ ОЏОЎ ОћОДОЋОЉОЦ ОЎОЏОЋОю ОюОцОњОЋОб ОЉОЌОЕОЉОЋОаОЋОф ОћОљОЎОЕОЎОЎОЮ ОЋОЉОЌОЕОЉОЋОаОЋОф ОЕОюОџ ОЉОеОЕОфОЋОф ОћОЌОЉОеОфОЎОЋОф</translation>
<translation id="5480860683791598150">РђЈChromium ОќОДОЋОД ОюОњОЎОЕОћ ОюОъОЎОДОЋОЮ ОЕОюОџ ОЏОЊОЎ ОюОЕОфОБ ОљОЋОфОЋ ОбОЮ ОћОљОфОе ОћОќОћ</translation>
<translation id="549669000822060376">РђЈОЎОЕ ОюОћОъОфОЎОЪ ОЉОќОъОЪ ОЕ-Chromium ОъОфОДОЎОЪ ОљОф ОбОЊОЏОЋОаОЎ ОћОъОбОеОЏОф ОћОљОЌОеОЋОаОЎОЮ.</translation>
<translation id="5496810170689441661">РђЈChromium ОъОаОАОћ ОюОбОеОЋОџ ОљОф ОћОАОЎОАОъОљОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОќОљОф, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ Ою-Windows.</translation>
<translation id="5524890928877629608">РђЈОћОцОЎОаОћ ОћОЕОъОљОюОЎОф ОћОбОюОЎОЋОаОћ ОЕОю ОљОќОЋОе ОћОЌОЎОцОЋОЕ: Рђј<ph name="LEFT" />%Рђј ОъОЕОъОљОю, Рђј<ph name="TOP" />%Рђј ОъОюОъОбОюОћ</translation>
<translation id="5527463683072221100">РђЈОцОфОЎОЌОћ ОЕОю ОДОЋОЉОдОЎ PDF ОЉ-Chromium</translation>
<translation id="5536164441519929134">ОЎОЕ ОюОЎ ОЕОљОюОћ<ph name="LINE_BREAK" />ОюОњОЉОЎ ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ</translation>
<translation id="5579324208890605088">ОЕОњОЎОљОф ОћОцОбОюОћ: ОЎОЕ ОюОћОцОбОЎОю ОљОф ОъОаОћОю ОћОћОфОДОаОћ ОЏОъОЕОфОъОЕ ОеОњОЎОю ОЋОюОљ ОЏОљОЊОъОЎОЪ.</translation>
<translation id="5580770360767802657">РђЈОЕОЎОъОЋОЕ ОЉ-Chromium ОЏОЉОеОЎОеОф ОъОЌОЊОю ОЋОћОдОъОЊОћ ОЕОюОЋ</translation>
<translation id="5596627076506792578">ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="5605834417512968703">РђЈОљОцОЕОе ОюОЉОЌОЋОе ОъОЕОћОЋ ОюОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф' ОљОЋ ОюОюОЌОЋОЦ ОбОю Escape ОЏОЊОЎ ОюОдОљОф ОъОЌОЎОцОЋОЕ ОћОфОъОЋОаОЋОф</translation>
<translation id="5618818588972826921">РђЈОљОцОЕОе ОюОЉОЌОЋОе ОўОДОАОў ОљОЋ ОфОъОЋОаОћ ОюОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф" ОљОЋ ОюОюОЌОЋОЦ ОбОю Escape ОЏОЊОЎ ОюОдОљОф ОъОЌОЎОцОЋОЕ ОћОфОъОЋОаОЋОф</translation>
<translation id="5623402015214259806">{0,plural, =0{РђЈОЎОЕ ОбОЊОЏОЋОЪ Ою-Chromium}=1{РђЈОЎОЕ ОбОЊОЏОЋОЪ Ою-Chromium}one{РђЈОбОЊОЏОЋОЪ ОЕОю Chromium ОќОъОЎОЪ ОЏОЉОе # ОЎОъОЎОЮ}two{РђЈОбОЊОЏОЋОЪ ОЕОю Chromium ОќОъОЎОЪ ОЏОЉОе # ОЎОъОЎОЮ}other{РђЈОбОЊОЏОЋОЪ ОЕОю Chromium ОќОъОЎОЪ ОЏОЉОе # ОЎОъОЎОЮ}}</translation>
<translation id="5643865575100044307">РђЈОъОЌОЎОДОф ОаОфОЋОаОЎОЮ ОъОљОфОеОЎОЮ ОъОћОъОЏОЕОЎОе ОЉОЏОю ОцОбОЮ ОЕОАОЋОњОеОЎОЮ ОљОф Chromium</translation>
<translation id="5653831366781983928">РђЈОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium</translation>
<translation id="5690427481109656848">Google LLC</translation>
<translation id="5698481217667032250">РђЈОћОдОњОф Chromium ОЉОЕОцОћ ОќОЋ</translation>
<translation id="569897634095159764">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў. ОаОЊОеОЕ ОљОЎОъОЋОф ОЕОю ОЕОеОф Оћ-proxy.</translation>
<translation id="5713518899297503106">РђЈОЉОљОъОдОбОЋОф ОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium, ОљОцОЕОе ОюОћОцОеОЎОЊ ОЉОЎОЪ ОњОюОЎОЕОћ ОЉОЕОбОЋОф ОћОцОаОљОЎ ОюОњОюОЎОЕОћ ОЉОбОЉОЋОЊОћ. ОљОцОЕОе ОюОћОЋОАОЎОБ ОцОеОЋОцОЎОю ОЌОЊОЕ ОбОЏОЕОЎОЋ.</translation>
<translation id="5768371961535086509">РђЈРђФChromium ОъОцОаОћ ОъОДОЋОЮ ОЉОќОЎОЏОеОЋОЪ ОЕОъОЋОДОдОћ ОюОЏОеОўОЎОАОЎОЋОф ОюОљ ОцОбОЎОюОЋОф. ОЏОџ, ОюОЏОеОўОЎОАОЎОЋОф ОћОцОбОЎОюОЋОф ОЋОюОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф ОЎОЕ ОЎОЋОфОе ОъОЕОљОЉОЎОЮ ОъОћОъОЌОЕОЉ ОЋ-Chromium ОцОЋОбОю ОъОћОе. ОЏОЕОЌОЋОќОеОЎОЮ ОюОЏОеОўОЎОАОЎОЋОф ОћОюОљ ОцОбОЎОюОЋОф, ОћОЪ ОъОЋОцОбОюОЋОф ОъОЌОЊОЕ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОъОдОЉ ОЌОЎОАОЏОЋОЪ ОЉОќОЎОЏОеОЋОЪ<ph name="END_LINK" /></translation>
<translation id="5775198138441669627">РђЈОљОЮ ОЕОЏОЌОф ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОЕОЉОеОдОЋОаОџ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, ОбОюОЎОџ <ph name="SETTINGS_LINK" /> ОљОф ОаОфОЋОаОЎ Chromium ОЉОЌОЕОЉОЋОЪ</translation>
<translation id="5800158606660203929">РђЈОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chromium ОЋОюОаОћОю ОљОЋОфОЋ. ОћОњОЊОеОф Chromium ОЏОЉОеОЎОеОф ОћОъОЌОЊОю.</translation>
<translation id="5809516625706423866">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў. HTTP 401: ОљОЎОЪ ОћОеОЕОљОћ. ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОћОњОЊОеОћ ОЕОю ОЕОеОф Оћ-proxy.</translation>
<translation id="5817952762723416573">РђЈОљОцОЕОе ОюОћОљОЎОЦ ОЉОЎОдОЋОбОЎОЮ ОЕОю ОљОфОеОЎОЮ ОЉОљОъОдОбОЋОф ОъОаОЋОб V8 ОЕОю Chromium, ОљОЉОю Chromium ОЎОћОЎОћ ОДОдОф ОцОЌОЋОф ОбОъОЎОЊ ОЉОцОаОЎ ОъОфОДОцОЋОф. ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф.</translation>
<translation id="5821520528363214608">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google, ОбОюОЎОџ ОюОбОЊОЏОЪ ОљОф Chromium</translation>
<translation id="5824893331272123205">ОюОљ ОћОдОюОЌОаОЋ ОюОўОбОЋОЪ ОљОф ОћОЌОюОЋОаОЎОф, ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="5862307444128926510">РђЈОЉОеОЋОЏОЎОЮ ОћОЉОљОЎОЮ Ою-ChromiumРђЈ</translation>
<translation id="5871205389137001634">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОдОљОф ОъОЌОЎОцОЋОЕ ОћОфОъОЋОаОЋОф</translation>
<translation id="5883558403894052917">РђЈОъОбОеОЏОф Chromium ОњОЎОюОфОћ ОЕОћОцОеОЎОўОЎОЮ ОћОљОюОћ ОъОЏОЎОюОЎОЮ ОфОЋОЏОаОћ ОќОЊОЋОаОЎОф:</translation>
<translation id="5889361821821684993">РђЈChromium ОЉОЋОЊОД ОЉОДОЉОЎОбОЋОф ОЏОЊОЎ ОюОЋОЋОЊОљ ОЕОюОЊОцОЊОцОЪ ОЎОЕ ОљОф ОћОћОњОЊОеОЋОф ОћОЉОўОЋОЌОЋОф ОЉОЎОЋОфОе. ОаОЋОЊОЎОб ОюОџ ОљОЮ ОдОеОЎОџ ОюОЉОЊОЋОД ОъОЕОћОЋ.</translation>
<translation id="5895138241574237353">ОћОцОбОюОћ ОъОЌОЊОЕ</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE" /> РђЊ ОЏОаОЎОАОћ ОюОеОЕОф</translation>
<translation id="5924017743176219022">ОъОфОЉОдОбОф ОћОфОЌОЉОеОЋОф ОюОљОЎОаОўОеОаОўРђд</translation>
<translation id="5941711191222866238">ОъОќОбОЋОе</translation>
<translation id="5949225980829865667">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОАОЎОъОаОЎОћ ОћОќОЋ ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ, ОдОеОЎОџ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="5953657885167112863">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chromium</translation>
<translation id="5960071705175224773">ОћОћОњОЊОеОЋОф ОЕОюОџ ОЕОЋОаОЋ ОбОю ОЎОЊОЎ ОљОцОюОЎОДОдОЎОћ ОюОљ ОЎОЊОЋОбОћ</translation>
<translation id="5968400720580217226">РђЈОъОдОЉ AI</translation>
<translation id="5986585015444752010">{COUNT,plural, =1{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ ОЊОДОћ.}one{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ # ОЊОДОЋОф.}two{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ # ОЊОДОЋОф.}other{РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ # ОЊОДОЋОф.}}</translation>
<translation id="5987687638152509985">РђЈОЎОЕ ОюОбОЊОЏОЪ ОљОф Chromium ОЏОЊОЎ ОюОћОфОЌОЎОю ОљОф ОћОАОаОЏОеОЋОЪ</translation>
<translation id="6003112304606738118">ОъОфОЉОдОбОф ОћОЋОеОЊОћРђд ОЎОЕ ОбОЋОЊ <ph name="HOURS" /> ОЕОб'</translation>
<translation id="6009821354356307391">ОћОЋОАОцОћ ОЕОю ОЕОљОЎОюОфОф ОћОъОЕОџ</translation>
<translation id="6040143037577758943">ОАОњОЎОеОћ</translation>
<translation id="6058380562449900225">РђЈОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОљОцОЕОе Ою-Chromium ОюОћОАОЎОе ОћОеОЕОљОЋОф ОъОљОфОеОЎОЮ ОЕОюОљ ОаОЏОаОАОф ОљОюОЎОћОЮ ОюОљОЌОеОЋОаОћ. ОћОъОбОеОЏОф ОфОъОЕОЎОџ ОюОЕОюОЋОЌ ОћОфОеОљОЋОф.</translation>
<translation id="6063093106622310249">РђЈ&amp;ОцОфОЎОЌОћ ОЉ-Chromium</translation>
<translation id="6069027071882229820">ОћОбОфОДОћ ОЏОфОъОЋОаОћ</translation>
<translation id="6072279588547424923">РђЈ<ph name="EXTENSION_NAME" /> ОаОЋОАОБ Ою-РђЈChromiumРђЈ</translation>
<translation id="6072463441809498330">РђЈОЕОЎОцОЋОе ОћОъОћОЎОеОЋОф ОЉ-Chromium</translation>
<translation id="6096348254544841612">РђЈОЏОЊОЎ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Google Chrome ОЋОюОЕОюОЋОў ОЉОЋ ОўОЋОЉ ОЎОЋОфОе, ОЏОЊОљОЎ ОюОћОЋОеОЎОЊ ОљОф ОћОбОЊОЏОЋОЪ ОћОЌОЊОЕ.</translation>
<translation id="6107893135096467929">РђЈОъОЋОцОбОю Рђб Chromium ОюОљ ОЎОЏОЋОю ОюОљОъОф ОљОф ОъОДОЋОе ОћОфОЋОАОБ ОћОќОћ</translation>
<translation id="611228897408671387">РђЈОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Chromium</translation>
<translation id="6119438414301547735">РђЈОъОфОЪ ОћОеОЕОљОћ ОюОфОЋОАОБ ОюОћОдОЎОњ ОЉОДОЕОЋОф ОњОЎОЕОћ ОЉОАОеОњОю ОћОЏОюОЎОЮ ОЕОю Chromium</translation>
<translation id="6129621093834146363">РђЈ<ph name="FILE_NAME" /> ОъОАОЋОЏОЪ, ОЋОюОЏОЪ Chromium ОЌОАОЮ ОљОЋОфОЋ.</translation>
<translation id="6132897690380286411">РђЈChromium ОЎОЎОАОњОе ОЉОДОеОЋОЉ ОЋОћОаОфОЋОаОЎОЮ ОЕОЉОЋ ОЎОЎОъОЌОДОЋ</translation>
<translation id="6145820983052037069">РђЈОЏОљОЪ ОаОЎОфОЪ ОюОбОЉОЋОе ОЉОЎОЪ ОцОеОЋОцОЎОюОЎОЮ ОЕОю Chromium</translation>
<translation id="615103374448673771">РђЈОљОЮ ОъОљОцОЕОеОЎОЮ ОЕОЎОъОЋОЕ ОЉОДОЋОЉОдОЎ cookie, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОъОбОеОЏОф Chromium ОфОЕОфОъОЕ ОЉОћОЮ ОЉОъОћОюОџ ОўОбОЎОаОћ ОъОеОљОЕ.</translation>
<translation id="6165508094623778733">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="6173308241973263798">РђЈОдОеОЎОџ ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ Chromium ОЉОЌОЕОЉОЋОЪ</translation>
<translation id="6174920971222007286">РђЈОћОДОЋОЉОЦ ОћОќОћ ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ<ph name="LINE_BREAK" />ОЊОцОЊОцОЪ Chromium ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОћОЋОеОЊОћ ОћОќОЋ ОљОЮ ОъОќОЎОаОЎОЮ ОљОф ОћОАОЎОАОъОћ. ОъОЎОЊОб ОбОю ОћОДОЋОЉОЦ ОаОЕОюОЌ ОљОю ОћОфОЏОЋОаОћ 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ ОЕОю Google', ОљОЉОю ОћОАОЎОАОъОћ ОЋОћОфОЋОЏОЪ ОЕОю ОћОДОЋОЉОЦ ОаОЕОљОеОЎОЮ ОЉОъОЏОЕОЎОе.</translation>
<translation id="6182736845697986886">ОћОћОфОДОаОћ ОаОЏОЕОюОћ ОбОДОЉ ОЕОњОЎОљОћ ОцОаОЎОъОЎОф ОЉОЕОеОф ОћОбОЊОЏОЋОЪ.</translation>
<translation id="6183079672144801177">РђЈОЎОЕ ОюОЋОЋОЊОљ ОЕОаОЏОаОАОф Ою-Chromium ОЉ-<ph name="TARGET_DEVICE_NAME" /> ОЕОюОџ ОЋОюОЕОюОЋОЌ ОЕОЋОЉ.</translation>
<translation id="6204922163963157461">РђЈОфОЋОЏОаОћ ОљОЌОеОф ОЉОъОЌОЕОЉ ОЕОюОџ ОћОЋОАОЎОцОћ ОљОцОюОЎОДОдОЎОћ ОЕОбОЕОЋОЎОћ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chromium.

<ph name="EXTENSION_NAME" /></translation>
<translation id="6212496753309875659">РђЈОЉОъОЌОЕОЉ ОќОћ ОДОЎОЎОъОф ОЏОЉОе ОњОеОАОћ ОъОфОДОЊОъОф ОЎОЋОфОе ОЕОю Chromium. ОљОЮ ОћОфОЋОЏОаОћ ОљОЎОаОћ ОцОЋОбОюОф, ОЎОЕ ОюОћОАОЎОе ОљОф ОћОћОфОДОаОћ ОЕОю Chromium ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="6219195342503754812">{0,plural, =0{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОбОЏОЕОЎОЋ}=1{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ ОЕОаОЎОЎОћ ОљОЌОф}one{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЕОаОЎОЋОф}two{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЕОаОЎОЋОф}other{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЕОаОЎОЋОф}}</translation>
<translation id="6239161312595354541">ОеОЋОдОћ ОюОЕОљОЋОю ОъОЕОћОЋ ОюОњОЉОЎ ОћОАОеОўОЋОЪ ОћОќОћ ОЉОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф?</translation>
<translation id="6241367896540709610">РђЈОаОЊОеОЕОф ОћОеОЕОљОф ОњОЎОЕОћ ОюОљОЌОАОЋОЪ ОЉ-Chromium ОЏОЊОЎ ОюОћОЋОеОЎОЊ ОДОЉОдОЎОЮ</translation>
<translation id="6245734527075554892">РђЈОћОъОбОеОЏОф ОЉОЋОЊОДОф ОЏОфОЋОЉОЋОф URL ОЉОбОќОеОф ОеОЕОЎОъОћ ОЕОю ОљОфОеОЎОЮ ОюОљ ОЉОўОЋОЌОЎОЮ ОЕОЕОъОЋОеОћ ОЉ-Chromium</translation>
<translation id="6248213926982192922">РђЈОЎОЕ ОюОћОцОЋОџ ОљОф Chromium ОюОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="6268381023930128611">РђЈОћОљОЮ ОюОдОљОф Оъ-Chromium?</translation>
<translation id="6270547683008298381">РђЈОћОЏОеОўОЎОАОЎОЋОф ОћОљОюОћ ОъОЕОфОъОЕОЋОф ОЉОъОЕОљОЉОЎОЮ ОаОЋОАОцОЎОЮ. ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОЉОЎОдОЋОбОЎОЮ, ОЏОЊОљОЎ ОюОљОцОЕОе Ою-Chromium ОюОћОЕОЉОЎОф ОљОЋОфОЪ.</translation>
<translation id="6281746429495226318">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОцОеОЋОцОЎОю Chromium</translation>
<translation id="6290827346642914212">РђЈОЉОЌОЎОеОф ОЕОЮ ОюОцОеОЋОцОЎОю Chromium ОЕОюОџ</translation>
<translation id="6294831894865512704">РђЈОфОЋОАОБ ОъОЉОДОЕ ОъОъОџ ОюОћОЎОЏОаОА Ою-Chromium</translation>
<translation id="6295779123002464101">РђЈ<ph name="FILE_NAME" /> ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ, ОЋОюОЏОЪ Chromium ОЌОАОЮ ОљОЋОфОЋ.</translation>
<translation id="6309712487085796862">РђЈChromium ОъОЕОфОъОЕ ОЉОъОдОюОъОћ ОЕОюОџ.</translation>
<translation id="6327105987658262776">ОљОЎОЪ ОбОЊОЏОЋОаОЎОЮ ОќОъОЎОаОЎОЮ.</translation>
<translation id="6333502561965082103">РђЈОъОфОЉОдОбОф ОЏОеОњОб ОцОбОЋОюОћ ОљОЌОеОф ОЉ-Chromium. ОЏОЊОљОЎ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="6334986366598267305">РђЈОДОю ОЎОЋОфОе ОЏОбОф ОюОћОЕОфОъОЕ ОЉ-Chromium ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google ОЕОюОџ ОЋОЉОъОЌОЕОЉОЎОЮ ОъОЕОЋОфОцОЎОЮ.</translation>
<translation id="6347933965114150440">РђЈОДОЎОдОЋОе ОЊОеОџ ОЉ-Chromium</translation>
<translation id="6366160072964553914">РђЈChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОљОф ОЏОЎ ОюОеОЋОЉ ОюОљ ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОДОЉОдОЎОЮ ОЏОљОюОћ ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОДОЋОЉОЦ ОъОАОЋОЏОЪ</translation>
<translation id="6373523479360886564">РђЈОЉОеОдОЋОаОџ ОЉОљОъОф ОюОћОАОЎОе ОљОф ОћОфОДОаОф Chromium?</translation>
<translation id="6375219077595103062">ОаОЎОфОЪ ОюОћОЋОАОЎОБ ОДОЎОдОЋОе ОЊОеОџ ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="6388799252195623474">ОљОаОЎ ОеОЋОдОћ ОбОќОеОћ ОЉОаОЋОЕОљ ОћОќОћ</translation>
<translation id="6390800440335263989">РђЈОЏОЊОЎ ОюОћОъОЕОЎОџ, ОбОюОЎОџ ОюОћОЎОЏОаОА Ою-Chromium ОЉОљОъОдОбОЋОф ОћОЌОЕОЉОЋОЪ <ph name="EMAIL" />. ОЏОџ ОћОъОЊОЎОаОЎОЋОф ОЕОю ОћОљОеОњОЋОЪ ОфОЌОЋОю ОбОю ОћОъОЏОЕОЎОе ОЕОюОџ.</translation>
<translation id="6400112897226594999">РђЈОћОюОЋОњОЋ ОЕОю Chromium ОЉОфОЋОџ ОъОАОџ ОъОЌОЕОЉ.</translation>
<translation id="6403826409255603130">РђЈChromium ОћОЋОљ ОЊОцОЊОцОЪ ОљОЎОаОўОеОаОў ОћОъОцОбОЎОю ОЊОцОЎ ОљОЎОаОўОеОаОў ОЋОљОцОюОЎОДОдОЎОЋОф ОЉОъОћОЎОеОЋОф ОћОЉОќОД. ОќОћОЋ ОЊОцОЊОцОЪ ОъОћОЎОе, ОЎОдОЎОЉ ОЋОДОю ОюОЕОЎОъОЋОЕ ОЕОъОљОцОЕОе ОюОџ ОюОњОюОЋОЕ ОЉОљОЎОаОўОеОаОў ОЉОдОЋОеОћ ОъОљОЋОЉОўОЌОф ОЎОЋОфОе ОћОЋОЊОЋОф ОюОћОњОаОћ ОъОцОаОЎ ОфОЋОЏОаОЋОф ОќОЊОЋОаОЎОЋОф ОЋОцОЎОЕОЎОаОњ ОћОъОЋОЉОаОЎОф ОЉ-Chromium.</translation>
<translation id="642132557830635295">РђЈОЊОцОЊОцОЪ Chromium ОцОЋОбОю ОъОћОе ОЎОЋОфОе ОЋОфОЏОЋОаОЋОф ОЕОъОЕОфОъОЕОЋОф ОЉ-JavaScript ОљОъОЋОеОЋОф ОюОцОбОЋОю ОЏОъОЋ ОЕОдОеОЎОџ</translation>
<translation id="6436260184216827876">ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф' ОюОљ ОќОъОЎОаОћ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="6442900851116057561">РђЈОћОцОбОюОћ ОъОЌОЊОЕ ОЕОю ChromiumOS</translation>
<translation id="6443470774889161065">РђЈОЏОЊОЎ ОЕОћОЊОцОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОЎОЎОўОбОаОЋ ОъОћОе ОЎОЋОфОе, ОъОбОеОЏОф Chromium ОўОЋОбОаОф ОъОеОљОЕ ОбОЋОЊ ОЎОЋОфОе ОЊОцОЎОЮ ОЕОЎОЕ ОАОЎОЏОЋОЎ ОњОЉОЋОћ ОЕОЎОЎОцОфОЌОЋ.</translation>
<translation id="645458117210240797">РђЈОъОЋОЕОЉОф Рђб Chromium ОюОљ ОЎОЏОЋОю ОюОљОъОф ОљОф ОъОДОЋОе ОћОфОЋОАОБ ОћОќОћ</translation>
<translation id="6455857529632101747">РђЈОЉОеОЋОџ ОЉОЋОљОџ ОюОцОеОЋОцОЎОюОЎОЮ ОЕОю Chromium</translation>
<translation id="6466344609055215035">РђЈОћОАОеОф ОћОЌОЕОЉОЋОЪ Оъ-Chromium</translation>
<translation id="6475912303565314141">РђЈОћОњОЊОеОћ ОќОЋ ОњОЮ ОДОЋОЉОбОф ОљОЎОќОћ ОЊОБ ОъОЋОдОњ ОЏОЕОъОцОбОЎОюОЎОЮ ОљОф Chromium.</translation>
<translation id="648319183876919572">ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОъОњОаОћ ОбОюОЎОџ ОўОЋОЉ ОЎОЋОфОе ОъОцОаОЎ ОћОЋОеОЊОЋОф ОЋОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ</translation>
<translation id="6510925080656968729">РђЈОћОАОеОћ ОЕОю ОћОфОДОаОф Chromium</translation>
<translation id="651535675648445253">РђЈОДОЎОдОЋОеОЎ ОћОЊОеОџ ОаОцОфОЌОЎОЮ ОЉ-Chromium</translation>
<translation id="6539122709674868420">РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ <ph name="TIMEOUT_DURATION" />. ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЋ. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОаОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф.</translation>
<translation id="6542839706527980775">РђЈОЉОЏОю ОцОеОЋОцОЎОю ОъОљОЋОЌОАОаОЎОЮ ОаОфОЋОаОЎ Chromium ОъОЕОюОЋ ОЏОъОЋ ОАОЎОъОаОЎОЋОф, ОћОЎОАОўОЋОеОЎОћ, ОАОЎОАОъОљОЋОф ОЋОбОЋОЊ</translation>
<translation id="6563921047760808519">РђЈ<ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОюОњОЉОЎ ОћОЕОъОЎОеОћ ОбОю ОцОеОўОЎОЋОф ОћОаОфОЋОаОЎОЮ ОЉ-Chromium<ph name="END_LINK" /></translation>
<translation id="6564039629497156115">РђЈОћОЕОЎОаОЋОЎОЎОЮ ОЉОћОњОЊОеОћ ОћОќОЋ ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ ОюОљОЌОе ОћОцОбОюОћ ОъОЌОЊОЕ ОЕОю Chromium.</translation>
<translation id="656935081669708576">РђЈОљОцОЕОе ОюОбОЉОЋОе ОюОцОеОЋОцОЎОю Chromium ОљОЌОе ОЏОЊОЎ ОюОеОљОЋОф ОАОЎОАОъОљОЋОф</translation>
<translation id="6570579332384693436">РђЈChromium ОЕОЋОюОЌ ОљОф ОћОўОДОАОў ОЕОъОЋОДОюОЊ ОЉОЕОЊОЋОф ОўОДОАОў Ою-Google ОЏОЊОЎ ОюОфОДОЪ ОЕОњОЎОљОЋОф ОЏОфОЎОЉ</translation>
<translation id="6598877126913850652">РђЈОъОбОЉОе ОљОю ОћОњОЊОеОЋОф ОћОћОЋОЊОбОЋОф ОЕОю Chromium</translation>
<translation id="6600016381025017075">ОљОцОЕОе ОюОЌОцОЕ ОъОЕОћОЋ ОЉОЊОБ ОћОќОћ</translation>
<translation id="6613594504749178791">РђЈОћОЕОЎОаОЋОЎОЎОЮ ОЕОЉОЎОдОбОф ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ ОЉОцОбОЮ ОћОЉОљОћ ОЕОфОцОбОЎОю ОъОЌОЊОЕ ОљОф ChromiumРђЈ.</translation>
<translation id="6648212540664651655">РђЈОљОцОЕОе ОюОћОъОЕОЎОџ ОъОћОъОДОЋОЮ ОЕОЉОЋ ОћОцОАОДОф: Chromium ОЕОЌОќОе ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОъОћОАОЕОЪ ОћОљОЌОеОЋОЪ ОЕОюОџ. ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОћОљОцОЕОеОЋОф ОћОќОљОф, ОдОеОЎОџ ОюОбОЉОЋОе ОљОю</translation>
<translation id="665732753414869868">РђЈОаОЊОеОЕОф ОћОеОЕОљОф ОњОЎОЕОћ ОюОъОдОюОъОћ ОЉ-Chromium ОЏОЊОЎ ОюОЎОдОЋОе ОъОцОћ ОфОюОф-ОъОъОЊОЎОф ОЕОю ОћОАОЉОЎОЉОћ ОЕОюОџ</translation>
<translation id="6669284030132180248">РђЈОљОЮ ОћОАОЎОъОаОЎОЋОф ОЕОюОџ ОаОЕОъОеОЋОф ОњОЮ ОЉОЌОЕОЉОЋОЪ Google, ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОбОДОЋОЉ ОљОЌОеОЎ ОъОЌОЎОеОЎ ОъОЋОдОеОЎОЮ ОЉ-Chromium ОЋОюОДОЉОю ОћОЋОЊОбОЋОф ОЏОЕОћОъОЌОЎОеОЎОЮ ОЎОЋОеОЊОЎОЮ</translation>
<translation id="6676384891291319759">ОњОЎОЕОћ ОљОю ОћОљОЎОаОўОеОаОў</translation>
<translation id="668175097507315160">РђЈОюОљ ОЉОЋОдОб ОАОаОЏОеОЋОЪ ОЕОю ОћОаОфОЋОаОЎОЮ ОЉ-ChromiumOS ОЉОњОюОю ОЕОњОЎОљОћ ОЉОфОћОюОЎОџ ОћОЏОаОЎОАОћ.</translation>
<translation id="6691132793308828750">РђЈОюОћОАОЎОе ОљОф ОћОаОфОЋОаОЎОЮ ОЕОю ОћОљОцОюОЎОДОдОЎОћ ОћОќОљОф Оъ-Chromium?</translation>
<translation id="6692797197837897398">РђЈОЉ-Chromium ОЎОЕ ОюОџ ОЎОЋОфОе ОЕОюОЎОўОћ ОЉОъОЋОЊОбОЋОф ОЕОъОЋОдОњОЋОф ОюОџ, ОЋОЌОюОЋОф ОћОњОЉОюОЋОф ОбОю ОћОъОЎОЊОб ОбОюОЎОџ ОЕОћОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОДОЉОю ОЉОћОдОњОф ОъОЋОЊОбОЋОф ОЉОћОфОљОъОћ ОљОЎОЕОЎОф.</translation>
<translation id="6709350901466051922">РђЈОаОЊОеОЕОф ОћОеОЕОљОф ОњОЎОЕОћ ОюОъОЎОДОеОЋОцОЋОЪ ОЉ-Chromium ОбОЉОЋОе ОћОљОфОе ОћОќОћ</translation>
<translation id="6712881677154121168">ОЕОњОЎОљОћ ОЉОћОЋОеОЊОћ: <ph name="DOWNLOAD_ERROR" />.</translation>
<translation id="6717134281241384636">РђЈОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОцОеОЋОцОЎОю ОЕОюОџ ОъОЕОЋОЮ ОЕОћОЋОљ ОъОњОЎОб ОъОњОеОАОћ ОЌОЊОЕОћ ОЎОЋОфОе ОЕОю Chromium.

ОЎОЎОфОЏОЪ ОЕОЌОюОД ОъОћОфОЏОЋОаОЋОф ОюОљ ОЎОћОЎОЋ ОќОъОЎОаОЋОф. ОЎОЕ ОюОдОЎОЎОЪ ОАОцОеОЎОЎОф ОцОеОЋОцОЎОю ОљОЌОеОф ОљОЋ ОюОћОЕОфОъОЕ ОЉОњОеОАОћ ОЌОЊОЕОћ ОЎОЋОфОе ОЕОю Chromium.</translation>
<translation id="6729124504294600478">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОЉОфОЏОЋОаОЋОф ОљОЌОеОЋОф, ОдОеОЎОџ ОюОЏОюОЋОю ОљОф Chromium ОЉ'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОЋОЉОЕОЎОеОЋОфОЎ Google ОћОъОДОЋОЕОеОЎОЮ</translation>
<translation id="6734291798041940871">РђЈChromium ОЏОЉОе ОъОЋОфОДОЪ ОЉОъОЌОЕОЉ ОЋОаОњОЎОЕ ОюОЏОю ОћОъОЕОфОъОЕОЎОЮ.</translation>
<translation id="6742093177587589736">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОАОЎОъОаОЎОЋОф ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ, ОдОеОЎОџ ОюОћОЎОЏОаОА Ою-Chromium. ОюОљОЌОе ОћОЏОаОЎОАОћ, ОћОАОЎОъОаОЎОЎОћ ОћОќОЋ ОфОЎОЕОъОе ОЉОЌОЕОЉОЋОЪ Google.</translation>
<translation id="6751374565094704799">РђЈОљОцОЕОе ОюОћОљОЎОЦ ОЉОЎОдОЋОбОЎОЮ ОЕОю ОљОфОеОЎОЮ ОЉОљОъОдОбОЋОф ОъОаОЋОб V8 ОЕОю Chromium, ОљОЉОю Chromium ОЎОћОЎОћ ОДОдОф ОцОЌОЋОф ОбОъОЎОЊ ОЉОцОаОЎ ОъОфОДОцОЋОф. ОћОћОњОЊОеОћ ОћОќОЋ ОцОЋОбОюОф.</translation>
<translation id="6754665438209053659">{count,plural, =1{РђЈОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉ-Chromium ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google. ОЏОЊОљОЎ ОюОЌОЏОЋОф ОЏОъОћ ОЊОДОЋОф ОюОцОаОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ (ОцОеОЎОў ОљОЌОЊ).}one{РђЈОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉ-Chromium ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google. ОЏОЊОљОЎ ОюОЌОЏОЋОф ОЏОъОћ ОЊОДОЋОф ОюОцОаОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ ({count} ОцОеОЎОўОЎОЮ).}two{РђЈОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉ-Chromium ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google. ОЏОЊОљОЎ ОюОЌОЏОЋОф ОЏОъОћ ОЊОДОЋОф ОюОцОаОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ ({count} ОцОеОЎОўОЎОЮ).}other{РђЈОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉ-Chromium ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google. ОЏОЊОљОЎ ОюОЌОЏОЋОф ОЏОъОћ ОЊОДОЋОф ОюОцОаОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ ({count} ОцОеОЎОўОЎОЮ).}}</translation>
<translation id="67706546131546258">РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОАОеОЋОД ОљОф ОћОДОЋОЉОЦ ОћОќОћ ОЏОЎ ОћОЋОљ ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ.</translation>
<translation id="6779406956731413166">РђЈ<ph name="BEGIN_LINK_CROS_OSS" />ОфОЋОЏОаОф ОДОЋОЊ ОцОфОЋОЌ<ph name="END_LINK_CROS_OSS" /> ОаОЋОАОцОф ОъОљОцОЕОеОф ОљОф ОћОЕОЎОъОЋОЕ ОЉ-ChromiumOS.</translation>
<translation id="6831043979455480757">ОфОеОњОЋОЮ</translation>
<translation id="6847869444787758381">РђЈChromium ОъОЋОЊОЎОб ОюОџ ОљОЮ ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОаОъОдОљОЋОф ОЉОАОЎОЏОЋОЪ</translation>
<translation id="684888714667046800">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў. ОљОЮ ОъОЕОфОъОЕОЎОЮ ОЉОЌОЋОъОф ОљОЕ, ОдОеОЎОџ ОюОЋОЋОЊОљ ОЕ-<ph name="PRODUCT_EXE_NAME" /> ОЉОеОЕОЎОъОф ОћОћОЎОфОеОЎОЮ.</translation>
<translation id="6857782730669500492">РђЈChromiumРђЈ - <ph name="PAGE_TITLE" /></translation>
<translation id="6859580922007887573">ОдОеОЎОџ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОъОЕОЎОџ</translation>
<translation id="6862030660799253820">ОЌОЎОцОЋОЕ ОћОфОъОЋОаОћ ОћОќОЋ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф"</translation>
<translation id="6873893289264747459">РђЈОћОцОеОЎОў "<ph name="EXTENSION_NAME" />" ОЕОаОъОдОљ ОЉ-Chromium ОъОЏОЎОю ОфОЋОЏОаОћ ОќОЊОЋОаОЎОф</translation>
<translation id="6877155553248388166">РђЈОћОцОЎОаОћ ОћОЎОъОаОЎОф ОћОфОЌОфОЋОаОћ ОЕОю ОљОќОЋОе ОћОЌОЎОцОЋОЕ: Рђј<ph name="RIGHT" />%Рђј ОъОЎОъОЎОЪ, Рђј<ph name="BOTTOM" />%Рђј ОъОюОъОўОћ</translation>
<translation id="6896758677409633944">ОћОбОфОДОћ</translation>
<translation id="6901631050894301805">РђЈОћОњОЊОеОф Chromium ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЋОћОдОъОЊОћ ОЕОюОЋ ОюОАОеОњОю ОћОъОЕОЎОъОЋОф</translation>
<translation id="6909503629704372277">РђЈ&amp;ОаОЎОћОЋОю ОћОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium</translation>
<translation id="6934579572334859869">ОЕОюОЎОЌОф ОЕОљОюОћ ОљОю ОЌОЎОцОЋОЕ ОћОфОъОЋОаОЋОф ОюОњОЉОЎ ОћОфОъОЋОаОћ ОћОќОЋ</translation>
<translation id="6964305034639999644">РђЈОцОфОЎОЌОф ОћОДОЎОЕОЋОе ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ ОЕОю Chromium</translation>
<translation id="6965382102122355670">ОљОЎОЕОЋОе</translation>
<translation id="6978145336957848883">РђЈОДОю ОюОаОЌОЕ ОАОЎОАОъОљОЋОф ОЌОюОЕОЋОф. ОЉОљОъОдОбОЋОф Chromium ОљОцОЕОе <ph name="BEGIN_LINK" />ОюОЎОдОЋОе ОЋОюОќОЏОЋОе ОАОЎОАОъОљОЋОф ОЌОќОДОЋОф<ph name="END_LINK" />.</translation>
<translation id="6985329841647292029">РђЈОћОфОаОљОЎОЮ ОюОЕОЎОъОЋОЕ ОЉ-ChromiumOS</translation>
<translation id="6990124437352146030">РђЈChromium ОќОДОЋОД ОюОћОеОЕОљОф ОњОЎОЕОћ ОюОъОЎОДОеОЋОцОЋОЪ ОЉОЕОЉОЎОю ОћОљОфОе ОћОќОћ</translation>
<translation id="7003299027384820442">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОЕОю Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ <ph name="ACCOUNT_EMAIL" />, ОдОеОЎОџ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ</translation>
<translation id="7011190694940573312">ОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЏОЎ ОћОњОеОАОћ ОћОќОЋ ОЕОю ОъОбОеОЏОф ОћОћОцОбОюОћ ОюОљ ОаОфОъОЏОф.</translation>
<translation id="7024536598735240744">ОЕОњОЎОљОћ ОЉОцОфОЎОЌОћ: <ph name="UNPACK_ERROR" />.</translation>
<translation id="7025789849649390912">ОћОћОфОДОаОћ ОаОбОдОеОћ.</translation>
<translation id="7045244423563602563">РђЈОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chromium ОЉОЊОеОџ ОЕОаОЋОЌОћ ОюОџ</translation>
<translation id="7047386856539490735">ОћОфОЋОдОљОЋОф ОћОљОюОћ ОъОЋОбОЎОюОЋОф?</translation>
<translation id="705851970750939768">РђЈОЎОЕ ОюОбОЊОЏОЪ ОљОф ChromiumРђЈ</translation>
<translation id="7067091210845072982">РђЈОљОЮ ОљОЎОЪ ОюОфОъОЋОаОћ ОфОЎОљОЋОе ОъОЋОбОЎОю, Chromium ОЎОаОАОћ ОюОАОцОД ОюОџ ОфОЎОљОЋОе. ОЏОЊОЎ ОюОЎОдОЋОе ОфОЎОљОЋОеОЎОЮ, ОћОфОъОЋОаОЋОф ОаОЕОюОЌОЋОф ОљОю Google.</translation>
<translation id="7141270731789036260">РђЈОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chrome for Testing</translation>
<translation id="7147227333672430807">РђЈОљОцОЕОе ОюОћОЕОфОъОЕ ОЉ-Chromium ОЉОЏОю ОцОбОЮ ОЕОюОЋОЌОдОЎОЮ ОбОю ОДОЎОЕОЋОеОЎОЮ ОЉОћОЋОЊОбОЋОф, ОЉОъОАОъОЏОЎОЮ ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф</translation>
<translation id="7163519456498498587">РђЈОћОАОеОћ ОЕОю <ph name="EXTENSION_NAME" /> Оъ-Chromium</translation>
<translation id="7173822816570314652">РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, ОаОфОЋОаОЎ Chromium ОаОъОЌОДОЎОЮ ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОћОЮ ОЉОъОЕОџ <ph name="TIMEOUT_DURATION" />. ОЉОЎОЪ ОћОаОфОЋОаОЎОЮ ОЕОаОъОЌОДОЋ: ОћОЎОАОўОЋОеОЎОћ, ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЋОћОЋОеОЊОЋОф.</translation>
<translation id="718435575166326686">РђЈОаОЊОеОЕОф ОћОеОЕОљОф ОњОЎОЕОћ ОюОъОдОюОъОћ ОЉ-Chromium ОбОЉОЋОе ОћОљОфОе ОћОќОћ</translation>
<translation id="7196312274710523067">РђЈОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОцОбОЎОю ОљОф Chromium. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7197677400338048821">РђЈChromium ОюОљ ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОЉОбОЋОЊ 24 ОЕОбОЋОф.</translation>
<translation id="7213008767289637091">РђЈОЏОЊОљОЎ ОюОћОЕОљОЎОе ОљОф Chromium ОЉ-Dock ОЏОЊОЎ ОюОњОЕОф ОљОюОЎОЋ ОЉОъОћОЎОеОЋОф ОъОфОЎ ОЕОеОЋОдОЎОЮ</translation>
<translation id="7213407614656404070">РђЈОЕОЎОъОЋОЕ ОЉ-Chromium ОЉОЏОю ОцОбОЮ ОЕОюОЋОЌОдОЎОЮ ОбОю ОДОЎОЕОЋОеОЎОЮ ОЉОћОЋОЊОбОЋОф, ОЉОъОАОъОЏОЎОЮ ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф.</translation>
<translation id="7223968959479464213">РђЈОъОаОћОю ОћОъОЕОЎОъОЋОф - Chromium</translation>
<translation id="7246575524853130370">РђЈОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ ОЉОћОфОљОЮ ОюОћОбОеОЏОћ ОЕОю Chromium</translation>
<translation id="7274695763216404502">ОћОфОЏОЋОаОћ ОћОЋОдОъОЊОћ. ОъОбОЏОЕОЎОЋ ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф' ОЊОеОџ ОАОеОњОю ОћОЏОюОЎОЮ</translation>
<translation id="7288567540154601580">ОЏОеОўОЎОАОЎОЋОф ОЋОфОЋОАОцОЎОЮ</translation>
<translation id="7295544978856094497">{NUM_EXTENSIONS,plural, =1{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЋ}one{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЮ}two{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЮ}other{РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЮ}}</translation>
<translation id="7296334833518879294">РђЈОЏОЊОЎ ОюОЕОфОБ ОљОЋОЊОЎОЋ ОъОћОъОбОеОЏОф, ОдОеОЎОџ ОюОцОфОЋОЌ ОљОф ОћОњОЊОеОЋОф ОћОъОбОеОЏОф ОЋОюОЉОЌОЋОе ОЉОљОцОЕОеОЋОф "ОћОДОюОўОф ОљОЋОЊОЎОЋ ОЕОю ОћОъОбОеОЏОф ОЉОюОЉОЊ" Ою-Chromium. ОюОљОЌОе ОъОЏОЪ ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium.</translation>
<translation id="7309928523159922338">РђЈОъОЊОЎОЊОф ОћОъОЋОЊОбОЋОф ОъОљОцОЕОеОф ОюОљОфОеОЎОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ ОюОЉОДОЕ Оъ-Chromium ОъОЎОЊОб ОЕОЎОбОќОЋОе ОюОЉОбОюОЎ ОћОљОфОеОЎОЮ ОюОъОЊОЋОЊ ОљОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОћОъОЋОЊОбОЋОф ОЕОюОћОЮ. ОъОЊОЎОЊОф ОћОъОЋОЊОбОЋОф ОъОњОЉОЎОюОћ ОљОф ОћОъОбОДОЉ ОЉОљОфОеОЎОЮ ОЕОЋОаОЎОЮ ОбОю ОЎОЊОЎ ОћОбОЉОеОф ОЏОъОЋОф ОДОўОаОћ ОЏОЏОю ОћОљОцОЕОе ОЕОю ОъОЎОЊОб ОЉОЎОЪ ОљОфОеОЎОЮ.</translation>
<translation id="731795002583552498">РђЈОћОбОЊОЏОЋОЪ ОЕОю ChromiumРђЈ ОъОфОЉОдОб</translation>
<translation id="7318036098707714271">РђЈОДОЋОЉОЦ ОћОћОбОЊОцОЋОф ОЕОюОџ ОцОњОЋОЮ ОљОЋ ОюОљ ОЌОЋОДОЎ. 

Chromium ОюОљ ОЎОЏОЋОю ОюОЕОЌОќОе ОљОф ОћОћОњОЊОеОЋОф ОЕОюОџ.</translation>
<translation id="7339898014177206373">ОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="734373864078049451">РђЈОћОЎОАОўОЋОеОЎОЎОф ОћОљОфОеОЎОЮ, ОћОАОЎОъОаОЎОЋОф ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ Оъ-Chromium ОаОъОдОљОЎОЮ ОЏОљОЪ.</translation>
<translation id="7347827960336370838">РђЈОеОД ОъОЎ ОЕОЎОЋОЊОб ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЎОЏОЋОю ОюОДОеОЋОљ ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОЋОдОцОаОЎОЮ. ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОюОљ ОаОЕОюОЌ ОљОю Google ОЋОюОљ ОъОљОЋОЌОАОЪ ОљОдОюОћ. ОљОЮ ОЕОЏОЌОф ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОЕОЉОеОдОЋОаОџ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, ОбОюОЎОџ <ph name="BEGIN_LINK" />ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ Chromium ОЉОЌОЕОЉОЋОЪ<ph name="END_LINK" />.</translation>
<translation id="7349591376906416160">РђЈОюОцОЎ ОћОњОЊОеОф ОъОаОћОю ОћОъОбОеОЏОф, Chromium ОЎОцОфОЌ ОљОф<ph name="ALTERNATIVE_BROWSER_NAME" /> ОЏОЊОЎ ОюОњОЕОф ОљОю <ph name="TARGET_URL_HOSTNAME" />.</translation>
<translation id="7352651011704765696">ОъОЕОћОЋ ОћОЕОфОЉОЕ</translation>
<translation id="7376384068949534168">РђЈОюОљ ОаОЏОаОАОф ОюОљОфОе ОћОќОћ ОЉОќОъОЪ ОћОљОЌОеОЋОЪ. ОћОћОеОЕОљОЋОф "<ph name="PERMISSION_1" />" ОЋ"<ph name="PERMISSION_2" />" ОћОЋОАОеОЋ ОбОю ОЎОЊОЎ Chromium.</translation>
<translation id="7384121030444253939">РђЈОћОфОЋОАОБ ОћОќОћ ОЏОЉОе ОюОљ ОаОфОъОџ. ОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЋ.</translation>
<translation id="7413153308467572558">РђЈОљОцОЕОе ОюОћОъОЕОЎОџ ОъОћОъОДОЋОЮ ОЕОЉОЋ ОћОцОАОДОф: Chromium ОъОЕОЌОќОе ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОюОџ ОЉОЏОю ОћОцОбОюОћ ОъОЌОЊОЕ. ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОћОљОцОЕОеОЋОф ОћОќОЋ, ОдОеОЎОџ ОюОбОЉОЋОе ОљОю</translation>
<translation id="7427879960656355200">РђЈОЎОЎОЉОЋОљ ОАОЎОАОъОљОЋОф ОљОю Chromium</translation>
<translation id="7449453770951226939">РђЈ<ph name="PAGE_TITLE" /> - Chromium ОЉОњОеОАОф ОцОЎОфОЋОЌ</translation>
<translation id="7450541714075000668">ОћОўОДОАОў ОћОЋОбОфОД</translation>
<translation id="7451052299415159299">РђЈChromium ОќОДОЋОД ОюОћОеОЕОљОф ОњОЎОЕОћ ОюОъОдОюОъОћ ОЉОЕОЉОЎОю ОћОљОфОе ОћОќОћ</translation>
<translation id="7458892263350425044">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ, ОдОеОЎОџ ОюОћОЎОЏОаОА ОљОю <ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф ОћОъОбОеОЏОф<ph name="END_LINK" /> ОЋОюОфОф Ою-Chromium ОњОЎОЕОћ</translation>
<translation id="7461356015007898716">РђЈОЏОЊОЎ ОюОДОЉОю ОбОЊОЏОЋОаОЎОЮ ОЕОю Chromium ОЉОбОфОЎОЊ, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉ-Windows ОъОњОеОАОћ 10 ОЋОљОЎОюОџ. ОЉОъОЌОЕОЉ ОћОќОћ ОцОЋОбОюОф ОъОбОеОЏОф Windows 7.</translation>
<translation id="7467949745582939695">РђЈОюОћОцОбОЎОю ОљОф Chromium ОъОЌОЊОЕ?</translation>
<translation id="7483335560992089831">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОДОЎОЪ ОљОф ОљОЋОфОћ ОњОеОАОф Chromium ОЕОцОЋОбОюОф ОЏОеОњОб. ОЎОЕ ОюОАОњОЋОе ОљОф Chromium ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7517403744065880907">РђЈОљОцОЕОе ОюОЕОъОЋОе ОАОЎОАОъОљОЋОф ОЋОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЏОЕОъОЌОЋОЉОеОЎОЮ ОюОЌОЕОЉОЋОЪ ОЉ-Chromium. РђЈ<ph name="LEARN_MORE" /></translation>
<translation id="751935028865900641">РђЈОАОЉОЎОе ОюОћОаОЎОЌ ОЕОљОфОеОЎОЮ ОЎОцОбОюОЋ ОЏОдОцОЋОЎ. ОљОЮ ОАОЋОњОеОЎОЮ ОљОф ОЏОю ОћОЌОюОЋОаОЋОф ОЕОю Chromium, ОъОфОЉОдОбОф ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ, ОЌОЋОЦ ОъОЌОЕОЉОЋОЪ Google ОљОЮ ОћОЋОљ ОъОЌОЋОЉОе Ою-Chromium.</translation>
<translation id="753534427205733210">{0,plural, =1{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ ОЊОДОћ}one{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЊОДОЋОф}two{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЊОДОЋОф}other{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЊОДОЋОф}}</translation>
<translation id="7565444033145385702">РђЈОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОљОцОЕОе Ою-Chromium ОюОћОАОЎОе ОћОеОЕОљОЋОф ОъОљОфОеОЎОЮ ОЕОюОљ ОаОЏОаОАОф ОљОюОЎОћОЮ ОюОљОЌОеОЋОаОћ.</translation>
<translation id="7583399374488819119">ОъОаОћОю ОћОћОфОДОаОћ ОЕОю <ph name="COMPANY_NAME" /></translation>
<translation id="761356813943268536">РђЈChromium ОъОЕОфОъОЕ ОЉОъОдОюОъОћ ОЋОЉОъОЎОДОеОЋОцОЋОЪ ОЕОюОџ.</translation>
<translation id="7617377681829253106">РђЈChromium ОћОЕОфОцОе</translation>
<translation id="7622753900276619808">РђЈОбОЏОЕОЎОЋ ОЎОЕ ОюОџ ОЎОЋОфОе ОфОЏОЋОаОЋОф ОќОъОЎОаОЋОф ОЉ-Chromium</translation>
<translation id="7649070708921625228">ОбОќОеОћ</translation>
<translation id="7658239707568436148">ОЉОЎОўОЋОю</translation>
<translation id="7686590090926151193">РђЈChromium ОљОЎОаОЋ ОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЕОюОџ</translation>
<translation id="7689606757190482937">РђЈОАОаОЏОеОЋОЪ ОЋОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chromium ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОеОЕОЋОфОџ</translation>
<translation id="7699779824407626136">РђЈОбОЊОЏОЋОЪ Ою-Chromium</translation>
<translation id="7716950018788545737">ОћОъОЕОЎОъОЋОф ОћОАОфОЎОЎОъОЋ.</translation>
<translation id="77283119132245232">ОћОЕОЎОеОЋОф ОћОќОћ ОъОАОцОД ОфОЎОбОЋОЊ ОЕОю ОбОДОЉОЋОф ОћОъОбОеОЏОф Ою-<ph name="BROWSER_NAME" />. ОљОЮ ОћОЕОЎОеОЋОф ОћОќОћ ОъОЋОЕОЉОф, ОаОфОЋОаОЎ ОћОъОбОДОЉ ОљОЌОе ОћОЉОЎОдОЋОбОЎОЮ ОЕОаОЋОдОеОЎОЮ ОбОю ОЎОЊОЎ ОћОЊОцОЊОцОЪ ОюОљ ОЎОЏОюОюОЋ ОљОЎОеОЋОбОЎОЮ ОЏОюОю-ОъОбОеОЏОфОЎОЎОЮ, ОЏОъОЋ ОљОЎОеОЋОбОЎ ОћОЌОюОцОф ОћОДОЕОе ОЋОљОЎОеОЋОбОЎ ОЕОеОЕОЋОе ОъОЋОЏОаОЎОЮ.</translation>
<translation id="7745317241717453663">РђЈОцОбОЋОюОћ ОќОЋ ОфОъОЌОД ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОъОћОъОЏОЕОЎОе. ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОаОфОЋОаОЎОЮ ОъОљОЋОЌОе ОЎОЋОфОе, ОЎОЕ ОюОћОЎОЏОаОА ОљОю Chromium ОбОЮ <ph name="USER_EMAIL" />.</translation>
<translation id="7747138024166251722">ОћОъОфОДОЎОЪ ОюОљ ОћОдОюОЎОЌ ОюОЎОдОЋОе ОАОцОеОЎОЎОћ ОќОъОаОЎОф. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОъОДОЋОЮ ОћОцОаОЋОЎ ОЉОЊОЎОАОД ОЋОљОф ОћОљОЎОЕОЋОе ОюОћОфОДОаОф ОфОЋОЏОаОћ.</translation>
<translation id="7786760609782648049">РђЈОЕОЎОцОЋОе ОћОъОћОЎОеОЋОф ОЉ-Chromium</translation>
<translation id="7790626492778995050">РђЈ<ph name="PAGE_TITLE" /> РђЊ Chromium ОЉОњОеОАОф Canary</translation>
<translation id="7803986347287457849">РђЈОюОљОаОЕОЎОЮ ОЕОЎОЕ ОюОћОЮ ОњОЎОЕОћ ОюОфОбОЉОЋОеОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЎОћОЎОћ ОДОЕОћ ОЎОЋОфОе ОюОеОљОЋОф ОљОф ОћОљОфОеОЎОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ. РђФChromium ОъОЕОфОъОЕ ОЉОЌОЎОЉОЋОе ОъОљОЋОЉОўОЌ ОюОЌОЎОцОЋОЕ ОЏОфОЋОЉОЋОф IP ОЕОю ОљОфОеОЎОЮ ОЉ-DNS.</translation>
<translation id="7810005234485217901">ОљОцОЕОе ОюОћОдОъОЎОЊ ОљОф ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф' ОЏОЊОЎ ОюОљОцОЕОе ОњОЎОЕОћ ОаОЋОЌОћ</translation>
<translation id="7828947555739565424">РђЈОЏОЉОе ОДОЎОЎОЮ ОЉОъОЏОЕОЎОе ОцОеОЋОцОЎОю Chromium ОбОЮ ОћОЌОЕОЉОЋОЪ ОћОќОћ.</translation>
<translation id="7845233973568007926">ОфОЋОЊОћ ОЕОћОфОДОаОф. ОбОюОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЌОЕОЉ ОюОцОаОЎ ОћОЕОЎОъОЋОЕ ОЉ-<ph name="BUNDLE_NAME" />.</translation>
<translation id="7853661403199074278">РђЈОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chromium ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОъОеОљОћ ОЕОюОЋ.</translation>
<translation id="7859018312476869945">РђЈОЏОЕОъОДОюОЎОЊОЎОЮ ОўОДОАОў ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОљОЋ ОЉОфОЎОЉОф ОћОЌОЎОцОЋОЕ, Chromium ОЕОЋОюОЌ ОљОф ОћОўОДОАОў ОћОќОћ ОюОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОъОЋОњОЊОе ОЏОЉОеОЎОеОф ОъОЌОЊОю ОЏОЊОЎ ОюОДОЉОю ОћОдОбОЋОф ОўОЋОЉОЋОф ОЎОЋОфОе. ОћОљОцОЕОеОЋОф ОћОќОЋ ОъОЋОЕОЉОфОф ОЉОъОдОЉ ОћОцОеОўОЎ.</translation>
<translation id="7867198900892795913">РђЈОбОЊОЏОЋОЪ Chromium ОюОњОеОАОћ ОћОљОЌОеОЋОаОћ ОюОљ ОћОдОюОЎОЌ, ОЋОюОЏОЪ ОљОЎОЪ ОюОџ ОњОЎОЕОћ ОљОю ОфОЏОЋОаОЋОф ОЌОЊОЕОЋОф ОЋОфОЎОДОЋОаОЎ ОљОЉОўОЌОћ.</translation>
<translation id="7872446069773932638">ОъОфОЉОдОбОф ОћОЋОеОЊОћРђд ОЎОЕ ОбОЋОЊ <ph name="SECONDS" /> ОЕОа'</translation>
<translation id="7873537467422636035">РђЈОљОЮ ОЕОЏОЌОф ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОЕОЉОеОдОЋОаОџ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, <ph name="BEGIN_LINK" />ОбОюОЎОџ ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ Chromium ОЉОЌОЕОЉОЋОЪ<ph name="END_LINK" /></translation>
<translation id="7877212753140190672">ОЕОљОюОЋОф ОюОњОЉОЎ ОћОфОъОЋОаОћ ОћОќОЋ</translation>
<translation id="7887929410013642057">РђЈОфОъОЎОЊ ОюОћОдОЎОњ ОљОф ОДОЎОдОЋОеОЎ ОћОЊОеОџ ОюОъОдОЉ AI</translation>
<translation id="7888981273428720788">РђЈОћОњОЊОеОф Chromium ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="7934340546140346950">РђЈРђФChromium ОъОЕОЊОеОњ ОЌОЎОЉОЋОеОЎОЮ ОюОљ ОъОљОЋОЉОўОЌОЎОЮ Ою-HTTPS ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЏОЕОљОцОЕОе</translation>
<translation id="7937630085815544518">РђЈОаОЏОаОАОф Ою-Chromium ОЏ-<ph name="USER_EMAIL_ADDRESS" />. ОЎОЕ ОюОћОЕОфОъОЕ ОЉОљОЋОфОЋ ОЌОЕОЉОЋОЪ ОЏОЊОЎ ОюОћОЎОЏОаОА ОЕОЋОЉ.</translation>
<translation id="7953047982688951904">РђЈОЏОЊОљОЎ ОюОћОЋОеОЎОЊ ОљОф Chromium ОюОўОюОцОЋОЪ ОЋОюОЎОћОаОЋОф ОъОЕОЏОЉОф ОћОњОаОћ ОаОЋОАОцОф ОЉОЏОю ОъОДОЋОЮ</translation>
<translation id="7975919845073681630">РђЈОќОЋОћОЎ ОћОфОДОаОћ ОъОЕОаОЎОф ОЕОю Chromium, ОЋОюОљ ОаОЎОфОЪ ОюОћОцОЋОџ ОљОЋОфОЋ ОюОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЕОюОџ.</translation>
<translation id="7997934263947464652">РђЈОфОЋОАОцОЎОЮ, ОљОцОюОЎОДОдОЎОЋОф ОЋОбОЎОдОЋОЉОЎОЮ ОъОъОДОЋОеОЋОф ОюОљ ОъОЋОЏОеОЎОЮ ОбОюОЋОюОЎОЮ ОюОћОќОЎОД ОюОъОЏОЕОЎОе. ОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОфОДОЎОЪ ОљОЋОфОЮ ОеОД Оъ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /></translation>
<translation id="8004582292198964060">ОЊОцОЊОцОЪ</translation>
<translation id="8010081455002666927">ОќОЎОћОЋОЎ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="8013436988911883588">РђЈОљОЌОеОЎ ОъОфОЪ ОњОЎОЕОћ Ою-Chromium, ОљОфОеОЎОЮ ОЎОЋОЏОюОЋ ОюОЉОДОЕ ОъОъОџ ОњОЎОЕОћ.</translation>
<translation id="8031714377769448844">РђЈОљОцОЕОе ОюОћОдОъОЎОЊ ОљОф Chromium ОюОАОеОњОю ОћОљОцОюОЎОДОдОЎОЋОф ОЏОЊОЎ ОюОњОЕОф ОљОюОЎОЋ ОЉОъОћОЎОеОЋОф ОъОфОЎ ОЕОеОЋОдОЎОЮ</translation>
<translation id="80471789339884597">ОфОЋОЊОћ ОЕОћОфОДОаОф. ОбОюОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОЏОю ОћОЊОцОЊОцОаОЎОЮ ОюОцОаОЎ ОћОЕОЎОъОЋОЕ ОЉ-<ph name="BUNDLE_NAME" />.</translation>
<translation id="8054112667659782652">ОфОъОЎОЊ ОюОћОдОЎОњ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОюОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф</translation>
<translation id="8077498902115777962">РђЈОћОЕОЉОфОф ОћОцОбОЎОюОЋОф ОЕОю Chromium ОЉОеОДОб ОюОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="80790299200510644">ОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОфОъОЋОаОЋОф</translation>
<translation id="8086881907087796310">ОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЏОЎ ОћОъОЌОЕОЉ ОюОљ ОбОЋОъОЊ ОЉОЊОеОЎОЕОЋОф ОћОЌОЋОъОеОћ ОћОъОЎОаОЎОъОюОЎОЋОф.</translation>
<translation id="8096472344908884505">РђЈ<ph name="PAGE_TITLE" /> РђЊРђЈ Google Chrome for Testing</translation>
<translation id="8105840573057009683">РђЈОаОЊОеОЕОф ОћОеОЕОљОф ОъОЎОДОЋОЮ ОЉ-Chromium ОбОЉОЋОе ОћОљОфОе ОћОќОћ</translation>
<translation id="8118331347066725040">РђЈОЕОюОЎОЌОф ОъОЕОЋОЉ ОбОю ОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф Lens</translation>
<translation id="8133124826068723441">РђЈОюОљ ОЉОЋОдОб ОАОаОЏОеОЋОЪ ОЕОю ОћОаОфОЋОаОЎОЮ ОЉ-ChromiumOS ОЏОЎ ОљОцОЕОеОЋОф ОћОАОаОЏОеОЋОЪ ОюОљ ОќОъОЎОаОћ ОбОЉОЋОе ОћОЊОЋОъОЎОЎОЪ ОЕОюОџ.</translation>
<translation id="813913629614996137">ОъОфОЉОдОб ОљОфОЌОЋОю...</translation>
<translation id="81770708095080097">РђЈChromiumРђЈ ОЌОАОЮ ОљОф ОћОДОЋОЉОЦ ОћОќОћ ОЏОЎ ОћОЋОљ ОъОАОЋОЏОЪ.</translation>
<translation id="8177472873527554730">ОюОљ ОаОъОдОљ ОфОЋОЏОЪ ОЉОЊОБ</translation>
<translation id="8200109504272824693">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОЕОю Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ <ph name="USER_EMAIL" />, ОдОеОЎОџ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ</translation>
<translation id="8221491193165283816">ОћОЉОЌОЎОеОћ ОЕОюОџ ОћОЎОљ ОЉОЊОеОџ ОЏОюОю ОюОЌОАОЋОЮ ОћОфОеОљОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОюОљОфОе ОћОќОћ ОюОћОдОЎОњ ОћОфОеОљОЋОф ОЎОЕ ОюОюОЌОЋОЦ ОЏОљОЪ.</translation>
<translation id="8223363452568144035">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ, ОдОеОЎОџ ОюОћОЎОЏОаОА ОљОю <ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф ОћОъОбОеОЏОф<ph name="END_LINK" /> ОЋОюОфОф Ою-Chromium ОњОЎОЕОћ</translation>
<translation id="8232193495299001329">РђЈРђФChromium ОюОљ ОЎОЏОЋОю ОюОљОъОф ОљОф ОъОДОЋОе ОћОфОЋОАОБ ОћОќОћ ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОЋОљ ОюОљ ОЉОўОЋОЌ. ОдОеОЎОџ ОюОћОАОЎОе ОљОЋОфОЋ Оъ-Chromium ОЏОЊОЎ ОюОљ ОюОљОцОЕОе ОюОЋ ОЎОЋОфОе ОюОеОљОЋОф ОЋОюОЕОаОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОфОфОЉОдОб ОЏОаОЎОАОћ, ОЏОЋОюОю ОћОцОеОўОЎОЮ ОћОљОЎОЕОЎОЎОЮ ОЕОюОџ.</translation>
<translation id="8248265253516264921">РђЈОљОЮ ОљОЎОЪ ОюОфОъОЋОаОћ ОфОЎОљОЋОе ОъОЋОбОЎОю, Chromium ОЎОаОАОћ ОюОАОцОД ОюОџ ОфОЎОљОЋОе. ОЏОЊОЎ ОюОЎОдОЋОе ОфОЎОљОЋОеОЎОЮ, ОћОфОъОЋОаОЋОф ОаОЕОюОЌОЋОф ОљОю Google. ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф ОћОљОцОЕОеОЋОф ОћОќОЋ ОЉОЏОю ОќОъОЪ ОЊОеОџ ОћОћОњОЊОеОЋОф.</translation>
<translation id="8254601181414348851">РђЈОюОћОЎОЏОаОА Ою-Chromium ОбОЮ ОцОеОЋОцОЎОю ОЌОЊОЕ?</translation>
<translation id="8286943863733751221">РђЈ<ph name="BEGIN_LINK" />ОЉ-Chromium ОъОЋОдОњОЋОф ОљОќОћОеОЋОф<ph name="END_LINK" /> ОъОцОаОЎ ОћОЋОеОЊОЋОф ОЋОљОфОеОЎОЮ ОюОљ ОЉОўОЋОЌОЎОЮ</translation>
<translation id="8295827201165805317">РђЈОюОљ ОаОЏОаОАОф ОюОљОфОе ОћОќОћ ОЉОќОъОЪ ОћОљОЌОеОЋОЪ. ОћОћОеОЕОљОћ "<ph name="PERMISSION" />" ОћОЋОАОеОћ ОбОю ОЎОЊОЎ Chromium.</translation>
<translation id="8313851650939857356">ОЕОњОЎОљОф ОћОцОбОюОћ: <ph name="STARTUP_ERROR" />.</translation>
<translation id="8318772038038596122">РђЈОюОцОЎ ОћОњОЊОеОф ОћОљОеОњОЋОЪ, Chromium ОаОАОњОе ОљОЋОўОЋОъОўОЎОф ОЏОЕОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОъОЕОџ <ph name="TIMEOUT_DURATION" />.</translation>
<translation id="8321888067342493336">ОЕОъОЎОеОћ ОЏОфОъОЋОаОћ</translation>
<translation id="8330519371938183845">РђЈОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ ОфОАОаОЏОеОЪ ОЋОфОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chromium ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОеОЕОЋОфОџ</translation>
<translation id="8340674089072921962">РђЈОЉОЏОфОЋОЉОф <ph name="USER_EMAIL_ADDRESS" /> ОћОЕОфОъОЕОЋ ОЉОбОЉОе ОЉ-Chromium</translation>
<translation id="8359544530202147897">РђЈОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОЕОю Chromium ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google (<ph name="ACCOUNT_EMAIL" />), ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Chromium</translation>
<translation id="8360718212975266891">РђЈОЏОЊОЎ ОюОДОЉОю ОбОЊОЏОЋОаОЎОЮ ОЕОю Chromium ОЉОбОфОЎОЊ, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉ-Windows ОъОњОеОАОћ 10 ОЋОљОЎОюОџ. ОЉОъОЌОЕОЉ ОћОќОћ ОцОЋОбОюОф ОъОбОеОЏОф Windows 8.</translation>
<translation id="8362914115861174987">ОфОеОњОЋОЮ Ою</translation>
<translation id="8367705492654390392">ОљОцОЕОе ОюОЕОљОЋОю ОћОЏОю</translation>
<translation id="8370517070665726704">РђЈCopyright <ph name="YEAR" /> Google LLC.Рђј ОЏОю ОћОќОЏОЋОЎОЋОф ОЕОъОЋОеОЋОф.</translation>
<translation id="8372327902843331129">РђЈОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОюОАОЎОАОъОљОЋОф ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОћОЎОЏОаОА Ою-Chromium. ОюОљОЌОе ОћОЏОаОЎОАОћ, ОћОАОЎОАОъОћ ОћОќОЋ ОфОЎОЕОъОе ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google.</translation>
<translation id="837460953767177950">РђЈОюОљОЌОе ОъОЏОЪ ОЎОћОЎОћ ОбОюОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium.</translation>
<translation id="8397248745433792218">РђЈОћОћОъОюОдОћ ОЕОю Chromium ОћОЎОљ ОюОћОАОЎОе ОљОЋОфОЋ. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОфОЋОАОцОЎОЮ ОаОфОъОЏОЎОЮ<ph name="END_LINK" /></translation>
<translation id="8401454788024434101">РђЈОћОцОеОАОЋОЮ ОЕОю ОћОфОЋОАОБ ОћОќОћ ОЉОЋОўОю ОбОю ОЎОЊОЎ ОћОъОцОфОЌ ОЕОюОЋ, ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОфОЋОАОБ ОюОљ ОЉОўОЋОЌ. ОдОеОЎОџ ОюОћОАОЎОе ОљОЋОфОЋ Оъ-Chromium ОЏОЊОЎ ОюОљ ОюОљОцОЕОе ОюОЋ ОЎОЋОфОе ОюОћОдОЎОњ ОЋОюОЕОаОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОфОфОЉОдОб ОЏОаОЎОАОћ, ОЏОЋОюОю ОћОцОеОўОЎОЮ ОћОљОЎОЕОЎОЎОЮ ОЕОюОџ.</translation>
<translation id="8416884904046428725">РђЈРђФChromium ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ ОюОцОаОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОЕОъОЋОе ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ.</translation>
<translation id="8417404458978023919">{0,plural, =1{РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОфОЋОџ ОЎОЋОЮ ОљОЌОЊ}one{РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОфОЋОџ # ОЎОъОЎОЮ}two{РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОфОЋОџ # ОЎОъОЎОЮ}other{РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromium ОЉОфОЋОџ # ОЎОъОЎОЮ}}</translation>
<translation id="8438543370129609977">РђЈОЏОЕОъОЕОфОъОЕОЎОЮ ОЉОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф', ОЏОЋОфОеОф ОћОЊОБ, ОЏОфОЋОЉОф Оћ-URL ОЋОћОфОЋОЏОЪ ОЕОюОЋ, ОЏОЋОюОю ОДОЋОЉОдОЎ PDF, ОаОЕОюОЌОЎОЮ ОюОЕОеОф. <ph name="LEARN_MORE" /></translation>
<translation id="8447525028100794994">РђЈОъОЎОЊОб ОаОЋОАОБ ОбОю ОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф" ОЉ-Chromium</translation>
<translation id="8453117565092476964">РђЈОћОљОеОЏОЎОЋОЪ ОЕОю ОћОъОфОДОЎОЪ ОцОњОЋОЮ ОљОЋ ОЕОљОЎОаОЋ ОЌОЋОДОЎ. ОЎОЕ ОюОћОЋОеОЎОЊ ОЕОЋОЉ ОљОф Chromium.</translation>
<translation id="8458614432758743027">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-Chromium ОаОЊОеОЕ Windows ОъОњОеОАОћ 10 ОЋОљОЎОюОџ.</translation>
<translation id="8463672209299734063">РђЈОљОЋОцОдОЎОЋОаОюОЎ: ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОљОю Google ОфОбОќОЋОе ОюОЕОцОе ОљОф ОћОфОЏОЋОаОЋОф ОЋОљОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ChromiumOS.</translation>
<translation id="8471947159125090285">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chromium ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google, ОбОюОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="8482493977473846331">РђЈОћОдОњОф ОћОаОЌОЎОЋОф ОюОдОЋОеОџ ОЏОаОЎОАОћ ОљОю Chromium</translation>
<translation id="8493179195440786826">РђЈChromium ОљОЎОаОЋ ОъОбОЋОЊОЏОЪ</translation>
<translation id="850264194101621529">РђЈОфОЋОЊОћ ОЕОЉОЌОеОф ОЉ-Chromium ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЕОюОџ!</translation>
<translation id="8522801943730206384">РђЈОю-Chromium ОЎОЕ ОљОцОЕОеОЋОф ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОеОД ОљОЮ ОЕОъОеОф ОљОЋОфОЪ</translation>
<translation id="8548787790260785208">РђЈОљОцОЕОе ОюОДОЉОю ОљОќОћОеОћ ОљОЮ Chromium ОЎОъОдОљ ОЕОљОЌОф ОъОћОАОЎОАОъОљОЋОф ОЕОюОџ ОЊОюОцОћ ОЉОњОюОю ОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб</translation>
<translation id="8555465886620020932">ОЕОњОЎОљОћ ОЉОЕОЎОеОЋОф: <ph name="SERVICE_ERROR" />.</translation>
<translation id="8556420416730706394">ОљОцОЕОе ОюОћОдОъОЎОЊ ОљОф ОћОфОЏОЋОаОћ 'ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф' ОЏОЊОЎ ОюОљОцОЕОе ОњОЎОЕОћ ОаОЋОЌОћ: ОцОЕОЋОў ОюОЋОЌОдОЎОЮ ОбОю ОћОЏОцОфОЋОе 'ОћОдОъОЊОћ' ОЉОЌОюОД ОћОбОюОЎОЋОЪ ОЕОю ОћОЌОюОЋОаОЎОф ОћОдОЊОЊОЎОф</translation>
<translation id="856656450041460113">ОеОЕОЎОъОф ОЕОцОЋОф ОюОЌОЎОцОЋОЕ</translation>
<translation id="8568283329061645092">РђЈChromium ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЏОЕОаОЏОаОАОЎОЮ ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google</translation>
<translation id="8576826849825683917">РђЈОъОАОцОе ОљОеОњОЋОаОЎОЮ ОъОаОћОюОЎОЮ ОљОф Chromium</translation>
<translation id="8586442755830160949">РђЈCopyright <ph name="YEAR" /> The Chromium Authors. ОЏОю ОћОќОЏОЋОЎОЋОф ОЕОъОЋОеОЋОф.</translation>
<translation id="8601359445272098721">ОЌОЊОЕ! ОљОцОЕОе ОюОфОеОњОЮ ОўОДОАОў ОЋОфОъОЋОаОЋОф ОЉОъОАОџ ОЉОљОъОдОбОЋОф ОюОЌОЎОдОћ ОбОю ОћОЏОцОфОЋОе "ОфОеОњОЋОЮ ОћОъОАОџ"</translation>
<translation id="8619360774459241877">РђЈОћОцОбОюОф Chromium ОъОфОЉОдОбОф...</translation>
<translation id="8624541899164515475">ОћОњОЊОеОЋОф, ОЎОЎОцОфОЌОЋ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ.</translation>
<translation id="8648201657708811153">РђЈОюОљ ОаОЎОфОЪ ОюОћОњОЊОЎОе ОљОф Google Chrome for Testing ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю.</translation>
<translation id="8697124171261953979">РђЈОћОњОЊОеОћ ОќОЋ ОњОЮ ОДОЋОЉОбОф ОљОЎОќОћ ОЊОБ ОъОЋОдОњ ОЏОЕОъОцОбОЎОюОЎОЮ ОљОф Chromium ОљОЋ ОъОЉОдОбОЎОЮ ОЌОЎОцОЋОЕ ОъОАОеОњОю ОћОЏОфОЋОЉОЋОф.</translation>
<translation id="8704119203788522458">РђЈОќОћОЋ Оћ-Chromium ОЕОюОџ</translation>
<translation id="8712637175834984815">ОћОЉОаОфОЎ</translation>
<translation id="8719993436687031146">РђЈОюОћОЎОЏОаОА ОљОю Chromium?</translation>
<translation id="8745263398357414606">РђЈОЉ-Chromium ОљОцОЕОе ОюОбОЕОЋОф ОћОЏОю</translation>
<translation id="8747073452963259673">РђЈОћОцОЎОаОћ ОћОЕОъОљОюОЎОф ОћОфОЌОфОЋОаОћ ОЕОю ОљОќОЋОе ОћОЌОЎОцОЋОЕ: Рђј<ph name="LEFT" />%Рђј ОъОЕОъОљОю, Рђј<ph name="BOTTOM" />%Рђј ОъОюОъОўОћ</translation>
<translation id="878572486461146056">ОЕОњОЎОљОф ОћОфОДОаОћ: ОъОаОћОю ОћОеОЕОф ОћОЌОЎОю ОъОЊОЎОаОЎОЋОф ОДОЉОЋОдОфОЎОф ОЕОъОЋОаОбОф ОљОф ОћОћОфОДОаОћ: <ph name="INSTALL_ERROR" /></translation>
<translation id="8796602469536043152">РђЈChromium ОќОДОЋОД ОюОћОеОЕОљОф ОњОЎОЕОћ ОљОю ОћОъОдОюОъОћ ОЋОћОъОЎОДОеОЋОцОЋОЪ ОЉОЕОЉОЎОю ОћОљОфОе ОћОќОћ</translation>
<translation id="8818550178040858407">РђЈОюОћОЎОЏОаОА ОљОю Chromium?</translation>
<translation id="8823401858233292222">РђЈОћОњОЊОеОф Chromium ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЋОћОдОъОЊОћ ОЕОюОЋ ОюОАОеОњОю ОћОъОЕОЎОъОЋОф</translation>
<translation id="8826492472752484139">ОюОЋОЌОдОЎОЮ ОбОю 'ОъОаОћОю ОћОАОЎОАОъОљОЋОф'</translation>
<translation id="8833697763442816810">РђЈОъОбОеОЏОф ChromiumOS</translation>
<translation id="8852026904190808918">РђЈОќОЋ ОћОЕОцОћ ОЕОЉОћ ОъОЋОдОњОЎОЮ ОфОцОеОЎОўОЎОЮ, ОћОњОЊОеОЋОф, ОћОфОеОљОЋОф ОЋОўОДОАОўОЎОЮ ОљОЌОеОЎОЮ ОЉ-Chromium</translation>
<translation id="8862326446509486874">ОљОЎОЪ ОюОџ ОќОЏОЋОЎОЋОф ОЕОъОфОљОЎОъОЋОф ОюОћОфОДОаОћ ОЉОеОъОф ОћОъОбОеОЏОф. ОЎОЕ ОюОаОАОЋОф ОюОћОцОбОЎОю ОЕОЋОЉ ОљОф ОћОъОфОДОЎОЪ ОЏОъОаОћОю ОъОбОеОЏОф.</translation>
<translation id="8876044221123442390">РђЈОћОЋОАОцОф ОцОеОЋОцОЎОю Chromium</translation>
<translation id="8880203542552872219">РђЈОљОЮ ОЕОЎОаОЎОф ОљОф ОћОАОЎОАОъОћ ОћОќОЋ, ОЎОЕ ОюОбОеОЋОџ ОљОф ОћОАОЎОАОъОћ ОћОЕОъОЋОеОћ ОЉ-Chromium ОЏОџ ОЕОћОЎОљ ОфОфОљОЎОЮ ОюОАОЎОАОъОћ ОћОЌОЊОЕОћ ОЕОюОџ.</translation>
<translation id="8891709362986793894">РђЈОюОцОЎ ОЊОеОЎОЕОф ОћОљОеОњОЋОЪ ОЕОюОџ, ОбОюОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЉ-Chromium</translation>
<translation id="8907580949721785412">РђЈChromium ОъОаОАОћ ОюОћОдОЎОњ ОАОЎОАОъОљОЋОф. ОЎОЕ ОюОћОДОюОЎОЊ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ Ою-Windows ОЏОЊОЎ ОюОљОцОЕОе ОќОљОф.</translation>
<translation id="8941642502866065432">РђЈОюОљ ОаОЎОфОЪ ОюОбОЊОЏОЪ ОљОф Chromium</translation>
<translation id="897581876605952338">РђЈОћОюОЋОњОЋ ОЕОю Chromium Enterprise</translation>
<translation id="8988036198400390003">РђЈОаОЎОћОЋОю ОћОцОеОЋОцОЎОюОЎОЮ ОЉ-Chromium</translation>
<translation id="9019929317751753759">РђЈОЏОЊОЎ ОюОЕОцОе ОљОф ОћОљОЉОўОЌОћ ОЕОю Chromium, ОћОЕОЉОфОаОЋ ОљОф ОћОфОЋОАОБ ОћОЉОљ ОЕОљОЎОаОЋ ОеОЕОЋОЮ ОЉ-<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ОЋОЎОЎОфОЏОЪ ОЕОаОЋОАОБ ОюОюОљ ОЎОЊОЎОбОфОџ.</translation>
<translation id="904366664621834601">РђЈРђФChromium ОЌОАОЮ ОљОф ОћОћОЋОеОЊОћ ОћОќОЋ ОЏОЎ ОДОЋОЉОЦ ОћОљОеОЏОЎОЋОЪ ОЏОЋОюОю ОДОЉОдОЎОЮ ОљОЌОеОЎОЮ ОЕОбОюОЋОюОЎОЮ ОюОћОАОфОЎОе ОфОЋОЏОаОЋОф ОќОЊОЋОаОЎОЋОф</translation>
<translation id="9062666675513499497">РђЈОЏОаОЎОАОћ ОљОю Chromium ОЏОЕОаОЏОаОАОЎОЮ ОюОЕОЎОеОЋОфОЎ Google ОљОЌОеОЎОЮ</translation>
<translation id="9078733879136747090">РђЈChromium ОаОАОњОе ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="9089354809943900324">РђЈChromium ОљОЎОаОЋ ОъОбОЋОЊОЏОЪ</translation>
<translation id="9093206154853821181">{0,plural, =1{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ ОЕОбОћ}one{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЕОбОЋОф}two{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЕОбОЋОф}other{РђЈChromium ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОбОЋОЊ # ОЕОбОЋОф}}</translation>
<translation id="9106236359747881194">ОљОцОЕОе ОюОЉОЌОЋОе ОўОДОАОў ОюОЌОЎОцОЋОЕ</translation>
<translation id="9106612006984859720">РђЈОЏОЊОЎ ОюОДОЉОю ОбОЊОЏОЋОаОЎОЮ ОЕОю Chromium ОЉОбОфОЎОЊ, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉ-Windows ОъОњОеОАОћ 10 ОЋОљОЎОюОџ. ОЉОъОЌОЕОЉ ОћОќОћ ОцОЋОбОюОф ОъОбОеОЏОф Windows 8.1.</translation>
<translation id="91086099826398415">РђЈОцОфОЎОЌОф ОћОДОЎОЕОЋОе &amp;ОЉОЏОеОўОЎОАОЎОЎОф Chromium ОЌОЊОЕОћ</translation>
<translation id="911206726377975832">ОюОъОЌОЋОД ОњОЮ ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЕОюОџ?</translation>
<translation id="9134482777260927479">ОбОќОеОћ ОЉОЕОЎОбОЋОеОЎ ОћОЉОЎОф</translation>
<translation id="9148058034647219655">ОЎОдОЎОљОћ</translation>
<translation id="9155105544013854680">РђЈОеОЋОдОћ ОюОћОъОЕОЎОџ ОъОћОъОДОЋОЮ ОЕОЉОЋ ОћОцОАОДОф? Chromium ОЎОЏОЋОю ОюОЕОЌОќОе ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОюОџ ОЉОЏОю ОћОцОбОюОћ ОъОЌОЊОЕ. ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОћОљОцОЕОеОЋОф ОћОќОЋ, ОдОеОЎОџ ОюОбОЉОЋОе ОљОю</translation>
<translation id="9158494823179993217">РђЈОюОцОЎ ОћОњОЊОеОф ОъОаОћОю ОћОъОбОеОЏОф, Chromium ОЎОцОфОЌ ОЊОцОЊОцОЪ ОЌОюОЋОцОЎ ОЏОЊОЎ ОюОњОЕОф ОљОю <ph name="TARGET_URL_HOSTNAME" />.</translation>
<translation id="9185526690718004400">РђЈОћОцОбОюОћ ОъОЌОЊОЕ ОюОдОЋОеОџ ОбОЊОЏОЋОЪ &amp;Chromium</translation>
<translation id="9190841055450128916">РђЈChromium РђЈ(mDNS-In)</translation>
<translation id="9206863043651638213">РђЈОеОЋОдОћ ОюОЎОћОаОЋОф ОъОћОЎОфОеОЋОаОЋОф ОЕОю ОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ ОЉ-Chromium?</translation>
<translation id="924957577793602335">РђЈОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chromium ОЉОЊОеОџ ОЕОаОЋОЌОћ ОюОџ</translation>
<translation id="93478295209880648">РђЈОЎОЎОфОЏОЪ ОЕ-Chromium ОюОљ ОЎОцОбОю ОЏОеОљОЋОЎ ОЏОЎ ОћОЋОљ ОЏОЉОе ОюОљ ОаОфОъОџ ОЉ-Windows XP ОЋОЉ-Windows Vista</translation>
<translation id="945522503751344254"> ОЕОюОЎОЌОф ОъОЕОЋОЉ</translation>
<translation id="965162752251293939">РђЈОъОЎ ОъОЕОфОъОЕ/Оф ОЉ-Chromium?</translation>
<translation id="967427899662692980">РђЈОеОЋОдОћ ОюОћОЕОЎОњ ОљОф ОеОъОф ОћОљОЉОўОЌОћ ОћОњОЉОЋОћОћ ОЉОЎОЋОфОе ОЕОю Chromium?</translation>
<translation id="983803489796659991">РђЈОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЏОЎ ОЕОеОф ОћОбОЊОЏОЋОЪ ОюОљ ОъОЏОЎОю ОаОфОЋОаОЎ ОњОЎОЉОЋОЉ (hash) ОЕОю ОћОљОцОюОЎОДОдОЎОћ.</translation>
<translation id="985498048907240953">РђЈОЕОЎОъОЋОЕ ОЉ-Chromium ОюОюОљ ОЌОЕОЉОЋОЪ</translation>
<translation id="985602178874221306">РђЈОъОЌОЉОеОЎ Chromium</translation>
<translation id="989970834842471429">ОљОцОЕОе ОюОЉОЌОЋОе ОўОДОАОў ОљОЋ ОфОъОЋОаОћ ОюОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф ОћОфОЏОЋОаОћ "ОЌОЎОцОЋОЕ ОфОъОЋОаОЋОф"</translation>
<translation id="992780518932311116">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОЕОЎОеОЋОфОЎ ОћОъОЎОДОЋОЮ, ОдОеОЎОџ ОюОћОЎОЏОаОА ОљОю <ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф ОћОъОбОеОЏОф<ph name="END_LINK" /> ОЋОюОфОф Ою-Chromium ОњОЎОЕОћ</translation>
</translationbundle>