<translation id="8868626022555786497">ОЉОЕОЎОъОЋОЕ</translation>
<translation id="8868838761037459823">ОцОеОўОЎ ОћОеОЕОф ОћОАОюОЋОюОеОЎОф</translation>
<translation id="8868964574897075186">РђЈОћОАОЎОАОъОљОЋОф ОћОЋОбОЉОеОЋ ОюОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="8870413625673593573">ОаОАОњОеОЋ ОюОљОЌОеОЋОаОћ</translation>
<translation id="8871551568777368300">ОћОЋОдОъОЊ ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="8871696467337989339">ОћОЕОфОъОЕОф ОЉОАОЎОъОЋОЪ ОЕОЋОеОф ОцОДОЋОЊОћ ОЕОљОЎОаОЋ ОаОфОъОџ: <ph name="BAD_FLAG" />. ОћОЎОдОЎОЉОЋОф ОЋОћОљОЉОўОЌОћ ОЎОЎОцОњОбОЋ.</translation>
<translation id="8871974300055371298">ОћОњОЊОеОЋОф ОфОЋОЏОЪ</translation>
<translation id="8872155268274985541">ОаОъОдОљ ОДОЋОЉОЦ ОъОаОЎОцОАОў ОюОљ ОЌОЋОДОЎ ОюОбОЊОЏОЋОЪ ОЌОЎОдОЋОаОЎ ОЕОю ОДОЎОЋОАОД. ОћОбОЊОЏОЋОЪ ОЕОю ОљОцОюОЎОДОдОЎОЎОф ОћОДОЎОЋОАОД ОаОЏОЕОю. ОЎОЕ ОюОћОАОЎОе ОљОф ОћОЊОЎОАОД ОљОЋОЪ ОДОЎ.</translation>
<translation id="8872506776304248286">ОцОфОЌ ОЉОЎОЎОЕОЋОЮ</translation>
<translation id="8872777911145321141">ОфОЋОдОњ ОЕОљОюОћ ОЏОЕОљОфОе ОЎОеОдОћ ОюОћОЕОфОъОЕ ОЉОъОЏОЕОЎОеОЎ ОћОъОдОЎОљОЋОф ОћОъОЊОЋОъОћ ОЋОЉОаОфОЋОаОЎ ОћОъОдОЎОљОЋОф ОћОъОЊОЋОъОћ ОЕОюОџ (ОъОЋОъОюОЦ)</translation>
<translation id="8874184842967597500">ОюОљ ОъОЌОЋОЉОе</translation>
<translation id="8874341931345877644">РђЈОћОбОЉОеОћ (cast) ОюОъОЏОЕОЎОе:</translation>
<translation id="8875520811099717934">РђЈОЕОЊОеОЋОњ ОЕОю Linux</translation>
<translation id="8875736897340638404">ОЉОЌОЎОеОф ОћОеОЕОљОЋОф ОћОњОЎОЕОћ ОЕОюОџ</translation>
<translation id="8876307312329369159">ОюОљ ОаОЎОфОЪ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОАОЕОЪ ОюОћОЊОњОъОћ.</translation>
<translation id="8877448029301136595">[ОАОцОеОЎОЎОф ОљОЉ]</translation>
<translation id="8879284080359814990">ОћОд&amp;ОњОћ ОЏОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="8879921471468674457">ОЕОъОЎОеОф ОцОеОўОЎ ОћОЏОаОЎОАОћ</translation>
<translation id="8880054210564666174">ОюОљ ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОф ОеОЕОЎОъОф ОљОаОЕОЎ ОћОДОЕОе. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОеОЕОф, ОљОЋ <ph name="LINK_BEGIN" />ОюОаОАОЋОф ОЕОЋОЉ<ph name="LINK_END" />.</translation>
<translation id="8881020143150461183">ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ. ОюОфОъОЎОЏОћ ОўОЏОаОЎОф ОЎОЕ ОюОцОаОЋОф ОљОю <ph name="CARRIER_NAME" />.</translation>
<translation id="8883273463630735858">ОћОцОбОюОф ОћОљОдОћ ОЕОю ОюОЋОЌ ОъОњОб</translation>
<translation id="8884023684057697730"><ph name="BEGIN_BOLD" />ОљОЎОџ ОюОаОћОю ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ:<ph name="END_BOLD" /> ОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОцОеОўОЎОЋОф ОЕОюОџ, ОћОљОфОеОЎОЮ ОЕОаОЋОАОцОЋ ОюОеОЕОЎОъОћ ОюОцОаОЎ ОЎОЋОфОе Оъ-4 ОЕОЉОЋОбОЋОф ОаОъОЌОДОЎОЮ ОъОъОаОћ ОљОЋОўОЋОъОўОЎОф. ОљОфОе ОЕОЉОЎОДОеОф ОЉОЋ ОЕОЋОЉ ОбОЕОЋОЎ ОюОЌОќОЋОе ОЋОюОћОЋОцОЎОб ОЉОеОЕОЎОъОћ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОфОе ОљОЮ ОюОљ ОеОЋОдОЎОЮ ОЕОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЎОЋОњОЊОеОЋ ОюОцОЎ ОћОЉОЎОДОЋОе ОЉОЋ.</translation>
<translation id="8884570509232205463">ОћОъОЏОЕОЎОе ОЕОюОџ ОЎОЎОаОбОю ОеОД ОЉ-<ph name="UNLOCK_TIME" />.</translation>
<translation id="8888253246822647887">ОћОљОцОюОЎОДОдОЎОћ ОфОЎОцОфОЌ ОЉОАОЎОЋОЮ ОћОЕОЊОеОЋОњ. ОцОбОЋОюОф ОћОЕОЊОеОЋОњ ОЎОЏОЋОюОћ ОюОћОЎОъОЕОџ ОЏОъОћ ОЊОДОЋОф.</translation>
<translation id="8888432776533519951">ОдОЉОб:</translation>
<translation id="8889651696183044030">Ою-<ph name="ORIGIN" /> ОЎОЕ ОћОеОЕОљОћ ОюОбОеОЋОџ ОљОф ОћОДОЉОдОЎОЮ ОЋОћОфОЎОДОЎОЋОф ОћОЉОљОЎОЮ</translation>
<translation id="8890170499370378450">ОЎОЎОфОЏОаОЋ ОЌОЎОЋОЉОЎОЮ ОЉОњОЎОЪ ОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОАОюОЋОюОеОЎОЎОЮ</translation>
<translation id="8890516388109605451">ОъОДОЋОеОЋОф</translation>
<translation id="8890529496706615641">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОаОЋОф ОљОф ОЕОЮ ОћОцОеОЋОцОЎОю. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ, ОљОЋ ОюОцОаОЋОф ОюОАОцОД ОюОДОЉОюОф ОфОъОЎОЏОћ ОўОЏОаОЎОф.</translation>
<translation id="8892168913673237979">ОћОЏОЋОю ОъОЋОЏОЪ!</translation>
<translation id="8893801527741465188">ОћОАОеОф ОћОћОфОДОаОћ ОћОЋОЕОюОъОћ</translation>
<translation id="8893928184421379330">ОъОдОўОбОеОЎОЮ, ОюОљ ОаОЎОфОЪ ОюОќОћОЋОф ОљОф ОћОъОЏОЕОЎОе <ph name="DEVICE_LABEL" />.</translation>
<translation id="8894761918470382415">ОћОњОаОф ОњОЎОЕОћ ОюОаОфОЋОаОЎОЮ ОбОЉОЋОе ОдОЎОЋОЊ ОћОЎОДОцОЎ</translation>
<translation id="8895454554629927345">ОеОЕОЎОъОф ОАОЎОъОаОЎОЋОф</translation>
<translation id="8898786835233784856">ОЉОЌОе ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОЉОљОћ</translation>
<translation id="8898822736010347272">РђЈОЕОЋОюОЌ Ою-Google ОЏОфОЋОЉОЋОф URL ОЕОю ОЌОюОД ОъОћОЊОцОЎОЮ ОЕОљОюОЎОћОЮ ОаОЏОаОАОф, ОцОеОўОЎОЮ ОъОЋОњОЉОюОЎОЮ ОюОњОЉОЎ ОћОъОбОеОЏОф ОЋОЌОюОД ОъОфОЋОЏОЪ ОћОЊОцОЎОЮ. ОцОбОЋОюОћ ОќОЋ ОбОЋОќОеОф ОюОќОћОЋОф ОљОЎОЋОъОЎОЮ ОЌОЊОЕОЎОЮ ОЋОюОћОњОЪ ОбОю ОЏОю ОћОъОЕОфОъОЕОЎОЮ ОЉОљОЎОаОўОеОаОў.</translation>
<translation id="8899851313684471736">ОцОфОЎОЌОф ОДОЎОЕОЋОе &amp;ОЉОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="8900413463156971200">ОћОцОбОюОф ОеОЕОф ОАОюОЋОюОеОЎОф</translation>
<translation id="8902059453911237649">{NUM_DAYS,plural, =1{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОњОЉОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЋОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОћОЎОЋОЮ.}two{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОњОЉОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЋОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОюОцОаОЎ ОћОъОЋОбОЊ ОћОљОЌОеОЋОЪ.}many{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОњОЉОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЋОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОюОцОаОЎ ОћОъОЋОбОЊ ОћОљОЌОеОЋОЪ.}other{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОњОЉОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЋОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОюОцОаОЎ ОћОъОЋОбОЊ ОћОљОЌОеОЋОЪ.}}</translation>
<translation id="8902667442496790482">ОцОфОЎОЌОћ ОЕОю ОћОњОЊОеОЋОф ОћОћОДОеОљОћ</translation>
<translation id="8903263458134414071">ОЎОЕ ОюОЉОЌОЋОе ОЌОЕОЉОЋОЪ ОюОдОЋОеОџ ОЏОаОЎОАОћ</translation>
<translation id="890616557918890486">ОЕОЎОаОЋОЎ ОћОъОДОЋОе</translation>
<translation id="8907701755790961703">ОЉОЌОе ОљОеОЦ</translation>
<translation id="8907906903932240086">РђЈChrome ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ</translation>
<translation id="8909298138148012791">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОћОЋОАОеОћ.</translation>
<translation id="8909833622202089127">ОћОљОфОе ОбОЋОДОЉ ОљОЌОеОЎ ОћОъОЎОДОЋОЮ ОЕОюОџ</translation>
<translation id="8910222113987937043">РђЈОЕОЎОаОЋОЎОЎОЮ ОЉОАОЎОъОаОЎОЋОф, ОЉОћОЎОАОўОЋОеОЎОћ, ОЉОАОЎОАОъОљОЋОф ОЋОЉОћОњОЊОеОЋОф ОљОЌОеОЋОф ОюОљ ОЎОАОЋОаОЏОеОаОЋ ОбОЋОЊ ОбОЮ ОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОбОЮ ОќОљОф, ОћОаОфОЋОаОЎОЮ ОћОДОЎОЎОъОЎОЮ ОбОЊОЎОЎОЪ ОЎОЎОЕОљОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЋОаОЎОфОЪ ОюОаОћОю ОљОЋОфОЮ ОЉ<ph name="BEGIN_LINK" />ОъОеОЏОќ ОћОЕОюОЎОўОћ ОЕОю Google<ph name="END_LINK" />.</translation>
<translation id="8910987510378294980">ОћОАОфОеОф ОеОЕОЎОъОф ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="8912362522468806198">РђЈОЌОЕОЉОЋОЪ Google</translation>
<translation id="8912793549644936705">ОъОфОЌ</translation>
<translation id="8912810933860534797">ОћОцОбОюОф ОАОеОЎОДОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="8915370057835397490">ОўОбОЎОаОф ОћОћОдОбОћ ОъОфОЉОдОбОф...</translation>
<translation id="8916476537757519021">ОфОф-ОъОАОњОеОф ОюОъОдОЉ ОљОаОЋОаОЎОъОЎ: <ph name="SUBFRAME_SITE" /></translation>
<translation id="8918637186205009138">Оћ-<ph name="DEVICE_TYPE" /> ОЕОю <ph name="GIVEN_NAME" /></translation>
<translation id="8922624386829239660">ОћОќОќОф ОћОъОАОџ ОЏОЕОћОбОЏОЉОе ОаОЋОњОб ОЉОДОдОЋОф ОћОъОАОџ</translation>
<translation id="8923880975836399332">ОЏОЌОЋОю-ОЎОеОДОеОД ОЏОћОћ</translation>
<translation id="8925124370124776087">ОбОЏОЕОЎОЋ ОАОеОњОю ОћОЏОЋОфОеОф ОъОЋОАОфОе</translation>
<translation id="8925458182817574960">&amp;ОћОњОЊОеОЋОф</translation>
<translation id="8926389886865778422">ОљОЎОЪ ОюОЕОљОЋОю ОЕОЋОЉ</translation>
<translation id="892706138619340876">ОЉОЋОдОб ОљОЎОцОЋОА ОЕОю ОЌОюОД ОъОћОћОњОЊОеОЋОф</translation>
<translation id="8929696694736010839">ОЉОАОЕОЪ ОћОљОаОЋОаОЎОъОЎ ОћОаОЋОЏОЌОЎ ОЉОюОЉОЊ</translation>
<translation id="8930351635855238750">РђЈОћОњОЊОеОЋОф ОЌОЊОЕОЋОф ОЕОю ОДОЋОЉОдОЎ Cookie ОЎОЎОЏОаОАОЋ ОюОфОЋОДОБ ОюОљОЌОе ОћОўОбОЎОаОћ ОъОЌОЊОЕ ОЕОю ОћОЊОБ</translation>
<translation id="8930622219860340959">ОљОюОЌОЋОўОЎ</translation>
<translation id="8931076093143205651">РђЈОЕОюОЎОЌОф ОъОЎОЊОб ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ. ОЏОЊОЎ ОюОфОеОЋОЮ ОюОЕОЎОцОЋОе ОЌОЋОЋОЎОЎОф ОћОъОЕОфОъОЕ ОЉ-Android, ОљОцОЕОе ОюОЕОюОЋОЌ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ, ОаОфОЋОаОЎ ОъОЏОЕОЎОе ОЋОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОЋОф. ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОћОЎОдОЎОЉОЋОф ОЕОю ОћОъОбОеОЏОф ОЋОЕОю ОћОљОцОюОЎОДОдОЎОЋОф ОЋОюОЉОдОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android. ОћОћОњОЊОеОћ ОћОќОЋ ОаОљОЏОцОф ОбОю-ОЎОЊОЎ ОћОЉОбОюОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОЉОбОюОЎОЮ ОЎОЉОЌОеОЋ ОюОЕОюОЋОЌ ОљОю Google ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЕОю ОћОъОЏОЕОЎОе. ОљОЮ ОћОЋОцОбОюОћ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="8931475688782629595">ОаОЎОћОЋОю ОћОАОаОЏОеОЋОЪ</translation>
<translation id="8932654652795262306">ОћОцОеОўОЎОЮ ОЕОю ОЕОЎОфОЋОБ ОћОљОЎОаОўОеОаОў ОћОъОЎОЎОЊОЎ ОЉОЎОЪ ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="8932894639908691771">ОљОцОЕОеОЋОЎОЋОф ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ</translation>
<translation id="893298445929867520">ОбОњОюОЋОф ОћОДОаОЎОЋОф ОћОЋОАОфОеОЋ. ОћОЪ ОЎОЋОцОЎОбОЋ ОъОЌОЊОЕ ОюОљОЌОе ОЉОЎОдОЋОб ОЕОЎОаОЋОЎОЎОЮ.</translation>
<translation id="8933960630081805351">РђЈОћ&amp;ОдОњОћ ОЉ-Finder</translation>
<translation id="8934732568177537184">ОћОъОЕОџ</translation>
<translation id="8938800817013097409">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЎОъОаОЎОф ОъОљОЌОЋОе)</translation>
<translation id="8940081510938872932">ОћОъОЌОЕОЉ ОъОЉОдОб ОЎОЋОфОе ОъОЊОЎ ОцОбОЋОюОЋОф ОЏОеОњОб. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="8940381019874223173">РђЈОъОфОЋОџ Google Photos ОЕОюОџ</translation>
<translation id="8941173171815156065">ОЉОЎОўОЋОю ОћОћОеОЕОљОћ '<ph name="PERMISSION" />'</translation>
<translation id="894360074127026135">РђЈОћОњОЉОеОћ ОЉОЎОаОюОљОЋОъОЎОф ОЕОю Netscape</translation>
<translation id="8944099748578356325">ОљОцОЕОеОЋОф ОќОЋ ОњОЋОеОъОф ОюОцОеОЎОДОћ ОъОћОЎОеОћ ОЎОЋОфОе ОЕОю ОћОАОЋОюОюОћ (ОЏОеОњОб %<ph name="BATTERY_PERCENTAGE" />)</translation>
<translation id="8945274638472141382">ОњОЋОЊОю ОАОъОюОЎОЮ</translation>
<translation id="8946359700442089734">ОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОюОљ ОћОЋОцОбОюОЋ ОЉОљОЋОцОЪ ОъОюОљ ОЉОъОЏОЕОЎОе <ph name="IDS_SHORT_PRODUCT_NAME" /> ОќОћ.</translation>
<translation id="894763922177556086">ОљОЎОЏОЋОф ОўОЋОЉОћ</translation>
<translation id="8948939328578167195">ОћОљОфОе <ph name="WEBSITE" /> ОъОЉОДОЕ ОюОДОЉОю ОљОф ОцОеОўОЎ ОћОЎОдОеОЪ ОЋОћОЊОњОЮ ОЕОю ОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ</translation>
<translation id="895054485242522631">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОЌОЎОЎОЕОаОЎ ОфОаОЋОбОћ</translation>
<translation id="8951256747718668828">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЋОюОљ ОаОЎОфОЪ ОюОћОЕОюОЎОЮ ОљОф ОћОЕОЌОќОЋОе</translation>
<translation id="8951465597020890363">ОюОдОљОф ОЉОЏОю ОќОљОф ОъОъОдОЉ ОљОЋОеОЌ?</translation>
<translation id="8952831374766033534">ОљОцОЕОеОЋОф ОћОћОњОЊОеОћ ОюОљ ОаОфОъОЏОф: <ph name="ERROR_LINE" /></translation>
<translation id="8953476467359856141">ОЉОќОъОЪ ОўОбОЎОаОћ</translation>
<translation id="895347679606913382">ОћОцОбОЋОюОћ ОъОфОЌОЎОюОћ...</translation>
<translation id="8953654039337655940">РђЈОаОЕОюОЌОћ ОЉОДОЕОф ОљОЎОЕОЋОе ОюОћОЋОеОћ ОЕОюОџ ОЊОеОџ ОћОљОцОюОЎОДОдОЎОћ Google Family Link ОЋОЉОЏОфОЋОЉОф families.google.com. ОљОЮ ОћОЉОДОЕОћ ОфОљОЋОЕОе ОбОю ОЎОЊОЎ ОћОћОЋОеОћ, ОфОЎОЕОюОЌ ОљОюОЎОџ ОћОфОеОљОћ.</translation>
<translation id="8956230710625245889">ОцОфОЎОЌОћ ОЉОДОЋОеОљ</translation>
<translation id="8957757410289731985">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОцОеОЋОцОЎОю</translation>
<translation id="895944840846194039">РђЈОќОЎОЏОеОЋОЪ JavaScript</translation>
<translation id="8960208913905765425">ОћОъОеОф ОЎОЌОЎОЊОЋОф ОЕОю ОфОЕОЋОЉОЋОф ОъОћОЎОеОЋОф</translation>
<translation id="8962051932294470566">ОљОцОЕОе ОюОЕОфОБ ОеОД ОДОЋОЉОЦ ОљОЌОЊ ОЉОЏОю ОцОбОЮ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОЏОљОЕОе ОћОћОбОЉОеОћ ОћОаОЋОЏОЌОЎОф ОфОАОфОЎОЎОЮ.</translation>
<translation id="8962083179518285172">ОћОАОфОеОф ОцОеОўОЎОЮ</translation>
<translation id="8962918469425892674">ОћОљОфОе ОћОќОћ ОъОЕОфОъОЕ ОЉОЌОЎОЎОЕОаОЎ ОфОаОЋОбОћ ОљОЋ ОфОљОЋОеОћ.</translation>
<translation id="8965037249707889821">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОћОЎОЕОаОћ</translation>
<translation id="89667524227025535">РђЈОдОеОЎОџ ОюОАОеОЋОД ОљОф ОДОЋОЊ Оћ-QR ОЉОљОъОдОбОЋОф ОъОдОюОъОф ОћОъОЏОЕОЎОе ОљОЋ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОћОцОбОюОћ ОЕОДОЎОЉОюОф ОъОћОАОцОД</translation>
<translation id="8966809848145604011">ОцОеОЋОцОЎОюОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="8966870118594285808">ОаОЎОфОЪ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЎОћ ОъОЌОЊОЕ ОљОЮ ОАОњОеОф ОљОЋОфОћ ОЉОўОбОЋОф</translation>
<translation id="8967427617812342790">ОћОЋОАОБ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ</translation>
<translation id="8968527460726243404">РђЈОЏОЋОфОЉ ОфОъОЋОаОф ОћОъОбОеОЏОф ОЕОю ОъОбОеОЏОф ОћОћОцОбОюОћ ОЕОю Chrome</translation>
<translation id="8968766641738584599">ОЕОъОЎОеОф ОћОЏОеОўОЎОА</translation>
<translation id="89720367119469899">Esc</translation>
<translation id="8972513834460200407">РђЈОЎОЕ ОюОцОаОЋОф ОљОю ОъОаОћОю ОћОъОбОеОЏОф ОЕОю ОћОеОЕОф ОЕОюОџ ОЏОЊОЎ ОюОЋОЋОЊОљ ОЕОЌОЋОъОф ОћОљОЕ ОљОЎОаОћ ОЌОЋОАОъОф ОћОЋОеОЊОЋОф ОъОЕОеОфОЎ Google.</translation>
<translation id="8973557916016709913">ОћОАОеОф ОеОъОф ОћОъОеОЌОД ОъОћОфОдОЋОњОћ</translation>
<translation id="8973596347849323817">ОаОЎОфОЪ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОъОЏОЕОЎОе ОћОќОћ ОЏОЊОЎ ОЕОЎОфОљОЎОЮ ОюОдОеОЏОЎОџ. ОаОЎОфОЪ ОюОЕОаОЋОф ОљОф ОфОЏОЋОаОЋОф ОћОаОњОЎОЕОЋОф ОъОљОЋОЌОе ОЎОЋОфОе ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="897414447285476047">ОДОЋОЉОЦ ОћОЎОбОЊ ОюОљ ОћОЋОЕОюОЮ ОЉОњОюОю ОЉОбОЎОЎОф ОЌОЎОЉОЋОе.</translation>
<translation id="897525204902889653">ОЕОЎОеОЋОф ОћОАОњОе</translation>
<translation id="8975396729541388937">ОаОЎОфОЪ ОюОЉОўОю ОљОф ОћОћОеОЕОъОћ ОЉОЏОю ОЕОюОЉ ОЉОюОЌОЎОдОћ ОбОю ОћОДОЎОЕОЋОе ОЉОћОЋОЊОбОЋОф ОћОљОЎОъОЎОЎОю ОЕОъОДОЉОюОЎОЮ.</translation>
<translation id="8975562453115131273">{NUM_OTHER_TABS,plural, =0{"<ph name="TAB_TITLE" />"}=1{"<ph name="TAB_TITLE" />" ОЋОбОЋОЊ ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}two{"<ph name="TAB_TITLE" />" ОЋОбОЋОЊ # ОЏОеОўОЎОАОЎОЋОф}many{"<ph name="TAB_TITLE" />" ОЋОбОЋОЊ # ОЏОеОўОЎОАОЎОЋОф}other{"<ph name="TAB_TITLE" />" ОЋОбОЋОЊ # ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="8977811652087512276">ОћОАОЎОАОъОћ ОЕОњОЋОЎОћ ОљОЋ ОЕОћОДОЋОЉОЦ ОцОњОЋОЮ</translation>
<translation id="8978154919215542464">ОцОЋОбОю - ОАОаОЏОеОЋОЪ ОћОЏОЋОю</translation>
<translation id="897939795688207351">ОЉ-<ph name="ORIGIN" /></translation>
<translation id="8980345560318123814">ОЊОЋОЌОЋОф ОъОЕОЋОЉ</translation>
<translation id="8980951173413349704"><ph name="WINDOW_TITLE" /> РђЊ ОДОеОА</translation>
<translation id="8981825781894055334">ОћОаОЎОЎОе ОљОЋОќОю</translation>
<translation id="8983632908660087688">Ою-<ph name="ORIGIN" /> ОЎОЕ ОћОеОЕОљОћ ОюОбОеОЋОџ ОљОф <ph name="FILENAME" /></translation>
<translation id="8984694057134206124">ОћОъОЏОЕОЎОе ОЎОћОЎОћ ОњОюОЋОЎ ОюОЏОЋОюОЮ ОюОъОЕОџ <ph name="MINUTES" /> ОЊОДОЋОф. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="8985191021574400965">РђЈОЉОеОЋОџ ОЉОЋОљОџ Ою-Steam Ою-Chromebook</translation>
<translation id="8985264973231822211">ОЕОЎОъОЋОЕ ОљОЌОеОЋОЪ: ОюОцОаОЎ ОЎОЋОЮ ОљОЌОЊ (<ph name="DEVICE_LAST_ACTIVATED_TIME" />)</translation>
<translation id="8985661493893822002">ОдОеОЎОџ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў ОЏОЊОЎ ОюОћОЎОЏОаОА ОљОю <ph name="DEVICE_TYPE" />.</translation>
<translation id="8986362086234534611">ОюОЕОЏОЋОЌ</translation>
<translation id="8986494364107987395">РђЈОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОДОеОЎОАОћ ОЋОАОўОўОЎОАОўОЎОДОЋОф ОЕОЎОъОЋОЕ Ою-Google</translation>
<translation id="8987927404178983737">ОЌОЋОЊОЕ</translation>
<translation id="8991520179165052608">ОћОљОфОе ОеОЕОљОЎ ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="899384117894244799">ОћОАОеОћ ОЕОю ОъОЕОфОъОЕ ОъОЋОњОЉОю</translation>
<translation id="899403249577094719">РђЈОЏОфОЋОЉОф ОљОфОе ОЉОАОЎОАОЎОф ОЕОю ОљОЎОЕОЋОе Netscape</translation>
<translation id="899657321862108550">РђЈОћ-Chrome ОЕОюОџ, ОЉОЏОю ОъОДОЋОЮ</translation>
<translation id="899676909165543803">ОЌОЎОЎОЕОЪ ОўОЉОЎОбОЋОф ОћОљОдОЉОб ОћОЋОљ ОћОъОДОЕ ОћОЎОъОаОЎ ОЉОЕОЋОеОћ ОћОфОЌОфОЋОаОћ ОЉОъОДОюОЊОф. ОЎОЕ ОюОњОбОф ОЉОЋ ОЉОбОЊОЎОаОЋОф ОЉОљОЌОф ОћОљОдОЉОбОЋОф.</translation>
<translation id="8999560016882908256">ОЕОњОЎОљОћ ОЉОфОЌОЉОЎОе ОЕОю ОДОўОб: <ph name="ERROR_LINE" /></translation>
<translation id="9003647077635673607">ОћОфОеОћ ОЉОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="9003677638446136377">ОЉОЊОЎОДОћ ОаОЋОАОцОф</translation>
<translation id="9004754973617721124">ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОљОф ОћОћОеОЕОљОЋОф ОюОљОфОе <ph name="SITE_NAME" />, ОюОЏОю ОћОљОфОеОЎОЮ ОЕОфОЌОфОЎОЋ ОЋОюОљОцОюОЎОДОдОЎОЋОф ОћОъОЋОфОДОаОЋОф ОЉОћОЮ?</translation>
<translation id="9008201768610948239">ОАОњОЎОеОћ</translation>
<translation id="9008201858626224558">ОюОЌОдОЪ 'ОћОДОЋОЊОЮ' ОюОЊОБ ОћОцОеОўОЎОЮ ОЕОю <ph name="SUBPAGE_TITLE" /></translation>
<translation id="9008828754342192581">ОЉОЌОеОф ОЉОбОЉОе ОюОфОф ОћОеОЕОљОћ ОюОЏОю ОћОфОЋОАОцОЎОЮ ОЉРђЉ<ph name="ORIGIN" /></translation>
<translation id="9009369504041480176">ОЉОўОбОЎОаОћ (%<ph name="PROGRESS_PERCENT" />)...</translation>
<translation id="9009708085379296446">ОћОљОЮ ОћОфОЏОЋОЋОаОф ОюОЕОаОЋОф ОљОф ОћОЊОБ ОћОќОћ?</translation>
<translation id="9011163749350026987">ОћОдОњОћ ОфОъОЎОЊ ОЕОю ОћОАОъОю</translation>
<translation id="9011393886518328654">ОаОфОЋОаОЎ ОњОеОАОћ</translation>
<translation id="9012122671773859802">ОћОќОќОф ОћОъОАОџ ОЉОеОдОБ ОЏОЕОћОбОЏОЉОе ОќОќ</translation>
<translation id="9013037634206938463">РђЈОаОЊОеОЕ ОЕОўОЌ ОљОЌОАОЋОЪ ОцОаОЋОЎ ОЕОю <ph name="INSTALL_SIZE" /> ОЏОЊОЎ ОюОћОфОДОЎОЪ ОљОф Linux. ОЏОЊОЎ ОюОцОаОЋОф ОЕОўОЌ ОљОЌОАОЋОЪ, ОЎОЕ ОюОъОЌОЋОД ОДОЉОдОЎОЮ ОъОћОъОЏОЕОЎОе.</translation>
<translation id="901668144954885282">РђЈОњОЎОЉОЋОЎ ОЉ-Google Drive</translation>
<translation id="9018218886431812662">ОћОћОфОДОаОћ ОћОЋОЕОюОъОћ</translation>
<translation id="9019062154811256702">ОДОеОЎОљОћ ОЋОЕОЎОаОЋОЎ ОЕОю ОћОњОЊОеОЋОф ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="9019894137004772119">РђЈОЕОЎОъОЋОЕ ОЉОъОЎОДОЋОЮ. ОљОцОюОЎОДОдОЎОЋОф ОЋОЕОЎОеОЋОфОЎОЮ ОбОЮ ОћОеОЕОљОф ОъОЎОДОЋОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОДОЋОЮ ОЕОю ОћОъОЏОЕОЎОе ОЕОюОџ. Google ОбОЕОЋОЎОћ ОюОљОАОЋОБ ОаОфОЋОаОЎ ОъОЎОДОЋОЮ ОъОЊОЎ ОцОбОЮ, ОЋОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОћОљОюОћ ОЉОдОЋОеОћ ОљОаОЋОаОЎОъОЎОф ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОЊОЎОЋОД ОЕОю ОћОъОЎОДОЋОЮ ОЋОљОф ОћОљОЎОЏОЋОф ОЕОю ОЕОЎОеОЋОфОЎОЮ ОъОЉОЋОАОАОЎ-ОъОЎОДОЋОЮ.</translation>
<translation id="9019956081903586892">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОЋОеОЎОЊ ОъОЎОюОЋОЪ ОюОЉОЊОЎОДОф ОљОЎОЋОф</translation>
<translation id="9020300839812600209">РђЈОљОцОЕОе ОюОћОќОЎОЪ ОЏОфОЋОЉОф URL ОЏОЊОЎ ОюОеОљОЋОф ОљОЎОџ Оћ-LBS ОЎОЕОцОЎОб ОбОюОЎОћ.</translation>
<translation id="9020362265352758658">4x</translation>
<translation id="9021662811137657072">ОќОЋОћОћ ОЋОЎОеОЋОА</translation>
<translation id="902236149563113779">РђЈОљОфОеОЎОЮ ОбОЋОДОЉОЎОЮ ОЉОЊОеОџ ОЏОюОю ОљОЌОе ОъОЎОДОЋОЮ ОћОъОдОюОъОћ ОЏОЊОЎ ОюОфОъОЋОџ ОЉОфОЏОЋОаОЋОф AR ОЏОъОЋ ОъОЕОЌОДОЎОЮ ОљОЋ ОћОаОЌОЎОЋОф ОЉОфОдОЋОњОћ ОбОЎОюОЎОф</translation>
<translation id="9022847679183471841"><ph name="AVATAR_NAME" /> ОЏОЉОе ОъОЕОфОъОЕ/Оф ОЉОЌОЕОЉОЋОЪ ОћОќОћ ОЉОъОЌОЕОЉ ОћОаОЋОЏОЌОЎ.</translation>
<translation id="9023015617655685412">ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОюОАОЎОъОаОЎОЋОф...</translation>
<translation id="9023909777842748145">ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОбОЉОЋОе ОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.</translation>
<translation id="9024127637873500333">&amp;ОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="9024158959543687197">ОДОеОфОћ ОЕОњОЎОљОћ ОЉОўОбОЎОаОф ОћОфОДОЪ ОћОеОЕОф ОюОЕОЎОфОЋОБ ОДОЉОдОЎОЮ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОЏОфОЋОЉОф ОћОљОфОе ОЕОю ОћОћОфОДОЪ ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="9024692527554990034">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОДОЎОдОЋОеОЎ ОћОЊОеОџ ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОЏОЊОЎ ОюОЌОцОЕ ОЉОъОћОЎОеОЋОф ОЉОљОфОе ОАОцОдОЎОцОЎ, ОљОЋ ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОъОаОЋОб ОЌОЎОцОЋОЕ ОљОЌОе.</translation>
<translation id="9026731007018893674">ОћОЋОеОЊОћ</translation>
<translation id="9026852570893462412">ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф. ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф.</translation>
<translation id="9027459031423301635">ОцОфОЎОЌОф ОДОЎОЕОЋОе ОЉОЏОеОўОЎОАОЎОЎОћ &amp;ОЌОЊОЕОћ</translation>
<translation id="9029667986262585240">ОћОЕОЉОфОф ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОљОф ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ.</translation>
<translation id="9030515284705930323">РђЈОћОљОеОњОЋОЪ ОЕОюОџ ОюОљ ОћОцОбОЎОю ОљОф ОЌОаОЋОф Google Play ОЉОЌОЕОЉОЋОЪ ОЕОюОџ. ОюОъОЎОЊОб ОаОЋОАОБ, ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф.</translation>
<translation id="9030754204056345429">ОъОћОЎОе ОЎОЋОфОе</translation>
<translation id="9030785788945687215">Gmail</translation>
<translation id="9030855135435061269">ОљОЎОЪ ОЎОЋОфОе ОфОъОЎОЏОћ ОЉОцОюОљОњОЎОЪ <ph name="PLUGIN_NAME" /></translation>
<translation id="9031549947500880805">РђЈОњОЎОЉОЋОЎ ОЉ-Google Drive. ОћОћОњОЊОеОћ ОћОќОЋ ОъОљОцОЕОеОф ОюОљОЌОќОе ОаОфОЋОаОЎОЮ ОЉОДОюОЋОф ОљОЋ ОюОбОЉОЋОе ОюОъОЏОЕОЎОе ОљОЌОе ОЉОЏОю ОЕОюОЉ. ОћОњОЎОЉОЋОЎ ОЏОЋОюОю ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф.</translation>
<translation id="9031811691986152304">ОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="9032097289595078011">ОћОЕОЉОфОф ОћОћОфОљОъОћ ОћОъОћОЎОеОћ</translation>
<translation id="9033765790910064284">ОљОаОЎ ОеОЋОдОћ ОюОћОъОЕОЎОџ ОЉОЏОю ОќОљОф</translation>
<translation id="9033857511263905942">&amp;ОћОЊОЉОДОћ</translation>
<translation id="903480517321259405">ОЎОЕ ОюОћОДОюОЎОЊ ОЕОЋОЉ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф</translation>
<translation id="9037054491984310631">РђЈОЎОЕ ОЌОЎОЉОЋОе ОљОю ОъОЏОЕОЎОе Bluetooth ОЉОЕОЮ <ph name="DEVICE" /></translation>
<translation id="9037640663275993951">ОћОъОЏОЕОЎОе ОюОљ ОъОЋОеОЕОћ</translation>
<translation id="9037818663270399707">ОћОЌОЎОЉОЋОе ОЕОюОџ ОљОЎОаОЋ ОцОеОўОЎ ОЉОЏОю ОћОфОаОЋОбОћ ОЉОеОЕОф</translation>
<translation id="9037965129289936994">ОћОдОњОф ОъОДОЋОе</translation>
<translation id="9039014462651733343">{NUM_ATTEMPTS,plural, =1{ОаОЕОљОе ОюОџ ОаОЎОАОЎОЋОЪ ОљОЌОЊ.}two{ОаОЕОљОеОЋ ОюОџ # ОаОЎОАОЎОЋОаОЋОф.}many{ОаОЕОљОеОЋ ОюОџ # ОаОЎОАОЎОЋОаОЋОф.}other{ОаОЕОљОеОЋ ОюОџ # ОаОЎОАОЎОЋОаОЋОф.}}</translation>
<translation id="9040473193163777637">РђЈОеОЋОдОћ ОюОћОцОбОЎОю ОљОф ChromeVox, ОДОЋОеОљ ОћОъОАОџ ОћОъОЋОЉОаОћ ОЕОю ChromeOS? ОљОЮ ОЏОЪ, ОЎОЕ ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю 2 ОћОюОЌОдОаОЎОЮ ОЕОю ОбОЋОдОъОф ОћОДОЋОю ОюОъОЕОџ 5 ОЕОаОЎОЋОф.</translation>
<translation id="9040661932550800571">ОћОљОЮ ОюОбОЊОЏОЪ ОљОф ОћОАОЎОАОъОћ ОЕОю <ph name="ORIGIN" />?</translation>
<translation id="9041692268811217999">ОћОњОЎОЕОћ ОюОДОЉОдОЎОЮ ОъОДОЋОъОЎОЎОЮ ОЉОъОЌОЕОЉ ОЕОюОџ ОъОЋОЕОЉОфОф ОбОю-ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="904224458472510106">ОюОљ ОаОЎОфОЪ ОюОЉОўОю ОљОф ОћОцОбОЋОюОћ ОћОќОЋ</translation>
<translation id="9042893549633094279">ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ</translation>
<translation id="904451693890288097">ОћОќОаОф ОАОЎОАОъОћ ОбОЉОЋОе "<ph name="DEVICE_NAME" />":</translation>
<translation id="9044646465488564462">ОћОћОфОЌОЉОеОЋОф ОюОеОЕОф ОаОЏОЕОюОћ: <ph name="DETAILS" /></translation>
<translation id="9045160989383249058">ОеОЕОЎОъОф ОћОДОеОЎОљОћ ОЕОюОџ ОбОЉОеОћ ОюОЌОюОЋОаОЎОф ОћОдОЊОЊОЎОф ОћОЌОЊОЕОћ. ОЏОљОЪ ОюОЋОЌОдОЎОЮ ОЏОЊОЎ ОюОцОфОЋОЌ ОљОЋОфОћ.</translation>
<translation id="9045430190527754450">РђЈОЕОюОЎОЌОф ОЏОфОЋОЉОф ОћОљОЎОаОўОеОаОў ОЕОю ОћОЊОБ ОЕОљОюОЎОЋ ОаОЎОАОЎОф ОюОћОњОЎОб ОљОю Google</translation>
<translation id="9048745018038487540">ОЉОЌОЎОеОф ОЏОю ОћОњОЋОцОаОЎОЮ</translation>
<translation id="9050666287014529139">ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="9052404922357793350">ОћОъОЕОџ ОЌОАОЎОъОћ</translation>
<translation id="9053563360605707198">ОћОЊОцОАОћ ОбОю ОЕОаОЎ ОћОдОЊОЊОЎОЮ</translation>
<translation id="9053893665344928494">ОюОќОЏОЋОе ОљОф ОћОЉОЌОЎОеОћ ОћОќОЋ</translation>
<translation id="9055636786322918818">РђЈОљОЏОЎОцОћ ОЕОю ОћОдОцОаОф RC4. ОЕОЎОъОЋОЕ ОЉОљОцОЕОеОЋОф ОћОќОЋ ОъОњОЊОЎОюОћ ОљОф ОћОАОЎОЏОЋОЪ, ОЏОЎ ОћОдОцОаОЋОф RC4 ОљОЎОаОЪ ОъОљОЋОЉОўОЌОЋОф.</translation>
<translation id="9056810968620647706">ОюОљ ОаОъОдОљОЋ ОћОфОљОъОЋОф.</translation>
<translation id="9057007989365783744"><ph name="SUPERVISED_USER_NAME" /> ОеОЋОдОћ ОюОДОЉОю ОњОЎОЕОћ ОюОфОЋОЏОЪ ОћОЉОљ:</translation>
<translation id="9057354806206861646">ОюОЋОЌ ОќОъОаОЎОЮ ОЕОю ОбОЊОЏОЋОаОЎОЮ</translation>
<translation id="9062468308252555888">14x</translation>
<translation id="9063208415146866933">ОЕОњОЎОљОћ ОъОЕОЋОеОћ <ph name="ERROR_LINE_START" /> ОбОЊ <ph name="ERROR_LINE_END" /></translation>
<translation id="9064275926664971810">ОћОцОбОюОф ОћОљОцОЕОеОЋОф ОЕОю 'ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ' ОюОъОюОљ ОўОцОАОЎОЮ ОЉОюОЌОЎОдОћ ОљОЌОф</translation>
<translation id="9065203028668620118">ОбОеОЎОЏОћ</translation>
<translation id="9066394310994446814">РђЈОћОцОеОЎОў ОћОќОћ ОъОЋОдОњ ОюОџ ОбОю ОАОъОџ ОћОцОбОЎОюОЋОф ОћОДОЋОЊОъОф ОЕОюОџ ОЉОЕОЎОеОЋОфОЎ Google. ОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK1" />myactivity.google.com<ph name="END_LINK1" /> ОъОЋОдОњОЎОЮ ОћОаОфОЋОаОЎОЮ ОЕОюОџ, ОЋОљОцОЕОе ОюОъОЌОЋОД ОљОЋОфОЮ ОљОЋ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОЋОф.
        <ph name="BREAK" />
        <ph name="BREAK" />
        ОаОЎОфОЪ ОюОъОдОЋОљ ОъОЎОЊОб ОбОю ОћОаОфОЋОаОЎОЮ ОЕОаОљОАОцОЎОЮ ОбОю ОЎОЊОЎ Google ОЋОћОАОЎОЉОЋОф ОюОЏОџ ОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK2" />policies.google.com<ph name="END_LINK2" />.</translation>
<translation id="9066777626153702300">ОљОфОеОЎОЮ ОюОљ ОцОбОЎОюОЎОЮ</translation>
<translation id="9066782832737749352">ОўОДОАОў ОюОЊОЎОЉОЋОе</translation>
<translation id="9068298336633421551">РђЈОъОЋОъОюОЦ ОюОљОцОЕОе ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЎОеОЋОфОЎОЮ ОЕОю Android ОбОЮ ОћОеОЕОљОф ОъОЎОДОЋОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОДОЋОЮ ОЕОю ОћОъОЏОЕОЎОе ОЕОюОџ. Google ОбОЕОЋОЎОћ ОюОљОАОЋОБ ОаОфОЋОаОЎ ОъОЎОДОЋОЮ ОъОЊОЎ ОцОбОЮ ОЋОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОћОљОюОћ ОЉОдОЋОеОћ ОљОаОЋОаОЎОъОЎОф ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОЊОЎОЋОД ОЕОю ОћОъОЎОДОЋОЮ ОЋОљОф ОћОљОЎОЏОЋОф ОЕОю ОћОЕОЎОеОЋОфОЎОЮ ОъОЉОЋОАОАОЎ-ОћОъОЎОДОЋОЮ</translation>
<translation id="9068878141610261315">ОАОЋОњ ОћОДОЋОЉОЦ ОюОљ ОаОфОъОџ</translation>
<translation id="9070342919388027491">ОћОЏОеОўОЎОАОЎОЎОћ ОћОЋОбОЉОеОћ ОЎОъОЎОаОћ</translation>
<translation id="9074739597929991885">Bluetooth</translation>
<translation id="9074836595010225693">РђЈОбОЏОЉОе USB ОъОЌОЋОЉОе</translation>
<translation id="9075413375877487220">ОюОцОЎ ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОњОюОЎОЕОћ ОЉОўОЋОЌОћ, ОћОфОЋОАОБ ОћОќОћ ОюОљ ОъОћОЎОъОЪ.</translation>
<translation id="9076283476770535406">ОЎОЎОфОЏОЪ ОЕОћОљОфОе ОъОЏОЎОю ОфОЋОЏОЪ ОюОъОЉОЋОњОеОЎОЮ ОЉОюОЉОЊ</translation>
<translation id="9076523132036239772">ОъОдОўОбОеОЎОЮ, ОюОљ ОаОЎОфОЪ ОюОљОъОф ОљОф ОћОљОЎОъОЎОЎОю ОљОЋ ОћОАОЎОАОъОћ ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОфОЌОЎОюОћ ОюОћОфОЌОЉОе ОюОеОЕОф.</translation>
<translation id="9076977315710973122">РђЈОЕОЎОфОЋОБ ОЉОљОъОдОбОЋОф SMB</translation>
<translation id="9078193189520575214">ОћОЕОЎОаОЋОЎОЎОЮ ОъОфОЉОдОбОЎОЮРђд</translation>
<translation id="9078316009970372699">ОћОЕОЉОфОћ ОЕОю ОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎ ОЉОЎОЪ ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="9078842827190780028">ОфОЋОдОљОф ОЌОЎОцОЋОЕ ОаОЋОАОцОЋОф ОъОЋОдОњОЋОф ОЉОЌОюОЋОаОЎОф ОћОдОЊОЊОЎОф</translation>
<translation id="9079267182985899251">ОЉОДОеОЋОЉ ОюОљ ОфОћОЎОћ ОЎОЋОфОе ОфОъОЎОЏОћ ОЉОљОцОЕОеОЋОф ОќОЋ. ОЏОЊОЎ ОюОћОдОЎОњ ОЏОеОўОЎОАОЎОЎОћ ОЎОЕ ОюОћОЕОфОъОЕ ОЉ-<ph name="GOOGLE_MEET" />.</translation>
<translation id="9081543426177426948">ОљОфОеОЎОЮ ОЕОаОЏОаОАОЎОЮ ОљОюОЎОћОЮ ОюОљ ОаОЕОъОеОЎОЮ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="9084064520949870008">ОцОфОЎОЌОћ ОЏОЌОюОЋОЪ</translation>
<translation id="9085256200913095638">ОЕОЏОцОЋОю ОћОЏОеОўОЎОАОЎОЎОћ ОЕОаОЉОЌОеОћ</translation>
<translation id="9085776959277692427"><ph name="LANGUAGE" /> ОюОљ ОаОЉОЌОеОћ. ОЏОЊОЎ ОюОЉОЌОЋОе, ОЎОЕ ОюОюОЌОЋОЦ ОбОю 'ОЌОЎОцОЋОЕ' ОЋОбОю ОъОДОЕ ОћОеОЋОЋОЌ.</translation>
<translation id="9087949559523851360">ОћОЋОАОцОф ОъОЕОфОъОЕ ОЉОбОю ОћОеОЕОљОЋОф ОъОЋОњОЉОюОЋОф</translation>
<translation id="9088234649737575428"><ph name="PLUGIN_NAME" /> ОЌОАОЋОЮ ОюОцОЎ ОъОЊОЎОаОЎОЋОф ОћОљОеОњОЋОЪ</translation>
<translation id="9088446193279799727">РђЈОюОљ ОаОЎОфОЪ ОюОћОњОЊОЎОе ОљОф Linux. ОЎОЕ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="9088917181875854783">ОЎОЕ ОюОљОЕОе ОЕОАОЎОАОъОћ ОќОЋ ОъОЋОдОњОф ОЉ-"<ph name="DEVICE_NAME" />":</translation>
<translation id="9089416786594320554">ОЕОЎОўОЋОф ОДОюОў</translation>
<translation id="9090044809052745245">ОЏОџ ОљОЌОеОЎОЮ ОЎОеОљОЋ ОљОф ОћОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="9094033019050270033">ОбОЊОЏОЋОЪ ОАОЎОАОъОћ</translation>
<translation id="9094038138851891550">ОЕОЮ ОъОЕОфОъОЕ ОюОљ ОЌОЋОДОЎ</translation>
<translation id="9094859731829297286">РђЈОћОљОЮ ОюОћОДОдОЋОф ОЕОўОЌ ОЊОЎОАОД ОДОЉОЋОб ОЉОЕОЉОЎОю Linux?</translation>
<translation id="9094982973264386462">ОћОАОеОћ</translation>
<translation id="9095253524804455615">ОћОАОеОћ</translation>
<translation id="909554839118732438">ОАОњОЎОеОф ОЌОюОЋОаОЋОф ОљОаОЋОаОЎОъОЎОЎОЮ</translation>
<translation id="9100416672768993722">РђЈОЏОЊОЎ ОюОбОЉОЋОе ОюОЕОЎОўОф ОћОДОюОў ОЕОЉОћ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОюОљОЌОеОЋОаОћ, ОЎОЕ ОюОћОДОЎОЕ ОбОю <ph name="BEGIN_SHORTCUT" /><ph name="BEGIN_CTRL" />Ctrl<ph name="END_CTRL" /><ph name="SEPARATOR" /><ph name="BEGIN_SPACE" />ОеОЋОЋОЌ<ph name="END_SPACE" /><ph name="END_SHORTCUT" /></translation>
<translation id="9100765901046053179">ОћОњОЊОеОЋОф ОъОфОДОЊОъОЋОф</translation>
<translation id="9101691533782776290">ОћОцОбОюОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="9102610709270966160">ОћОцОбОюОф ОћОфОЋОАОБ</translation>
<translation id="9103479157856427471">ОћОњОЊОюОф ОћОфОдОЋОњОћ ОЉОъОАОџ ОбОЋОДОЉОф ОљОЌОеОЎ ОъОЎОДОЋОЊ ОћОъОДОюОЊОф</translation>
<translation id="9103868373786083162">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОЌОќОЋОе ОљОЌОЋОеОћ, ОфОцОеОЎОў ОћОДОЕОе ОюОћОдОњОф ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="9108035152087032312">ОъОфОЪ &amp;ОЕОЮ ОюОЌОюОЋОЪРђд</translation>
<translation id="9108072915170399168">ОћОћОњОЊОеОћ ОћОаОЋОЏОЌОЎОф ОЕОю ОћОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ ОћОЎОљ 'ОюОюОљ ОљОЎОаОўОеОаОў'</translation>
<translation id="9108674852930645435">ОъОћ ОЌОЊОЕ ОЉ-<ph name="DEVICE_TYPE" /></translation>
<translation id="9108808586816295166">РђЈОћ-DNS ОћОъОљОЋОЉОўОЌ ОюОљ ОЎОћОЎОћ ОЉОћОЏОеОЌ ОќОъОЎОЪ ОфОъОЎОЊ</translation>
<translation id="9109122242323516435">ОЏОЊОЎ ОюОцОаОЋОф ОаОцОЌ ОљОЌОАОЋОЪ, ОЎОЕ ОюОъОЌОЋОД ОДОЉОдОЎОЮ ОъОљОЌОАОЋОЪ ОћОъОЏОЕОЎОе.</translation>
<translation id="9109283579179481106">ОЌОЎОЉОЋОе ОюОеОЕОф ОАОюОЋОюОеОЎОф</translation>
<translation id="9111102763498581341">ОЉОЎОўОЋОю ОаОбОЎОюОћ</translation>
<translation id="9111305600911828693">ОюОљ ОћОЋОњОЊОе ОеОЎОЕОЎОЋОЪ</translation>
<translation id="9111395131601239814"><ph name="NETWORKDEVICE" />: <ph name="STATUS" /></translation>
<translation id="9111668656364922873">ОЉОеОЋОџ ОЉОЋОљОџ ОюОцОеОЋОцОЎОю ОћОЌОЊОЕ ОЕОюОџ</translation>
<translation id="9112517757103905964">ОћОДОЋОЉОЦ ОћОќОћ ОЏОЋОюОю ОфОЋОЏОЪ ОеОњОЎОЕ ОЋОюОЏОЪ ОћОћОъОюОдОћ ОЕОю ОћОљОеОњОЋОЪ ОћОЎОљ ОюОъОЌОЋОД ОљОЋОфОЋ</translation>
<translation id="9112748030372401671">ОћОЌОюОцОф ОћОўОцОў</translation>
<translation id="9112786533191410418">РђЈОћОДОЋОЉОЦ <ph name="FILE_NAME" /> ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ. ОюОЕОюОЋОЌ ОљОю Google ОюОдОЋОеОџ ОАОеОЎОДОћ?</translation>
<translation id="9112987648460918699">ОЌОЎОцОЋОЕ...</translation>
<translation id="9113240369465613386">ОеОД ОЊОцОЎОЮ ОбОЮ ОъОАОцОеОЎОЮ ОљОЎ-ОќОЋОњОЎОЎОЮ</translation>
<translation id="9113469270512809735">ОћОЌОюОцОф ОъОдОЉ ОЕОю ОћОдОњОф ОцОеОЎОўОЎОЮ ОЕОаОАОњОеОЋ ОюОљОЌОеОЋОаОћ</translation>
<translation id="9114663181201435112">ОЏОаОЎОАОћ ОЉОДОюОЋОф</translation>
<translation id="9115675100829699941">&amp;ОАОЎОъОаОЎОЋОф</translation>
<translation id="9116465289595958864">ОЕОЎОаОЋОЎ ОљОЌОеОЋОЪ</translation>
<translation id="9116799625073598554">ОљОцОюОЎОДОдОЎОћ ОюОеОЎОЕОЋОЮ ОћОбОеОЋОф</translation>
<translation id="9117030152748022724">ОаОЎОћОЋОю ОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ</translation>
<translation id="9120693811286642342">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЏОЊОЎ ОюОЎОћОаОЋОф ОъОћОЌОЋОЋОЎОћ ОћОЏОЎ ОўОЋОЉОћ, ОдОеОЎОџ ОюОћОфОДОЎОЪ ОљОф <ph name="DEVICE_OS" /> ОЉОЊОЎОАОД ОћОцОаОЎОъОЎ. ОЎОЕ ОюОџ ОњОЮ ОљОцОЕОеОЋОф ОюОћОфОДОЎОЪ ОЉОЕОюОЉ ОъОљОЋОЌОе ОЎОЋОфОе ОъОъОАОџ ОћОћОфОЌОЉОеОЋОф.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОљОЮ ОбОЊОЎОЎОЪ ОюОљ ОъОфОљОЎОЮ ОюОџ ОюОћОфОДОЎОЪ, ОљОцОЕОе ОюОћОеОЎОЦ ОљОф ОћОъОбОеОЏОф Оъ-USB ОЋОюОаОАОЋОф ОљОЋОфОћ. ОъОбОеОЏОф ОћОћОцОбОюОћ ОЋОћОаОфОЋОаОЎОЮ ОћОаОЋОЏОЌОЎОЎОЮ ОЕОюОџ ОЎОъОЕОЎОЏОЋ ОюОцОбОЋОю, ОљОЉОю ОЎОЎОфОЏОЪ ОЕОЎОћОЎОЋ ОъОњОЉОюОЋОф ОбОю ОаОцОЌ ОљОЌОАОЋОЪ ОЋОЉОЎОдОЋОбОЎОЮ.<ph name="END_PARAGRAPH2" /></translation>
<translation id="9121814364785106365">ОцОфОЎОЌОћ ОЏОЏОеОўОЎОАОЎОЎОћ ОъОЋОдОъОЊОф</translation>
<translation id="9122176249172999202"><ph name="IDS_SHORT_PRODUCT_NAME" /> ОћОЋОЕОћОћ</translation>
<translation id="9124003689441359348">ОЏОљОЪ ОЎОЋОцОЎОбОЋ ОћОАОЎОАОъОљОЋОф ОЕОЕОъОеОф</translation>
<translation id="9126149354162942022">ОдОЉОб ОћОАОъОЪ</translation>
<translation id="9128317794749765148">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОЕОюОЎОЮ ОљОф ОћОћОњОЊОеОћ</translation>
<translation id="9128335130883257666">ОцОфОЎОЌОф ОЊОБ ОћОћОњОЊОеОЋОф ОЕОю <ph name="INPUT_METHOD_NAME" /></translation>
<translation id="9128870381267983090">ОћОфОЌОЉОеОЋОф ОюОеОЕОф</translation>
<translation id="9130015405878219958">ОћОЋОќОЪ ОъОдОЉ ОюОљ ОЌОЋОДОЎ.</translation>
<translation id="9131487537093447019">РђЈОЕОюОЎОЌОф ОћОЋОЊОбОЋОф ОюОъОЏОЕОЎОеОЎ Bluetooth ОЋОДОЉОюОф ОћОЋОЊОбОЋОф ОъОћОЮ.</translation>
<translation id="9134066738478820307">ОљОфОеОЎОЮ ОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉОъОќОћОЎОЮ ОЏОЊОЎ ОюОћОцОбОЎОю ОфОЋОЏОЪ ОъОЋОњОЪ</translation>
<translation id="913411432238655354">ОЕОЌОќОЋОе ОћОљОцОюОЎОДОдОЎОЋОф ОЉОъОћОюОџ ОћОћОцОбОюОћ</translation>
<translation id="9137013805542155359">ОћОдОњОф ОъОДОЋОе</translation>
<translation id="9137157311132182254">ОъОаОЋОб ОЌОЎОцОЋОЕ ОъОЋОбОЊОБ</translation>
<translation id="9137248913990643158">РђЈОЎОЕ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЉ-Chrome ОюОцОаОЎ ОЕОћОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОћ ОћОќОЋ.</translation>
<translation id="9137916601698928395">ОцОфОЎОЌОф ОДОЎОЕОЋОе ОЉОфОЋОе <ph name="USER" /></translation>
<translation id="9138978632494473300">ОћОЋОАОцОф ОДОЎОдОЋОеОЎ ОЊОеОџ ОЉОъОДОЋОъОЋОф ОћОЉОљОЎОЮ:</translation>
<translation id="9139258866388561662">ОдОеОЎОџ ОюОћОЎОЏОаОА ОљОю <ph name="WEB_DRIVE" /> ОЏОЊОЎ ОюОћОЕОюОЎОЮ ОљОф ОћОћОЋОеОЊОћ</translation>
<translation id="9139988741193276691">РђЈОћОъОбОеОЏОф ОъОњОЊОЎОеОћ ОљОф Linux</translation>
<translation id="9140067245205650184">ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОфОЏОЋОаОћ ОаОЎОАОЎОЋОаОЎОф ОЕОљОЎОаОћ ОаОфОъОЏОф: <ph name="BAD_FLAG" />. ОћОЎОдОЎОЉОЋОф ОЋОћОљОЉОўОЌОћ ОЎОЎОцОњОбОЋ.</translation>
<translation id="9142637293078737510">ОћОЏОЎОаОЋОЎ ОЕОю ОДОЋОЉОЦ ОћОљОЎОъОњ'</translation>
<translation id="9143298529634201539">ОћОљОЮ ОюОћОАОЎОе ОљОф ОћОћОдОбОћ?</translation>
<translation id="9147392381910171771">&amp;ОљОцОЕОеОЋОЎОЋОф</translation>
<translation id="9148058034647219655">ОЎОдОЎОљОћ</translation>
<translation id="9148126808321036104">ОЏОаОЎОАОћ ОЌОЋОќОеОф</translation>
<translation id="9148963623915467028">ОћОљОфОе ОћОќОћ ОДОЎОЉОю ОњОЎОЕОћ ОюОъОЎОДОЋОЮ ОЕОюОџ.</translation>
<translation id="9149866541089851383">ОбОеОЎОЏОћРђд</translation>
<translation id="9150045010208374699">ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ</translation>
<translation id="9150079578948279438">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОАОЎОе ОљОф ОћОцОеОЋОцОЎОю. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ, ОљОЋ ОюОцОаОЋОф ОюОАОцОД ОюОДОЉОюОф ОфОъОЎОЏОћ ОўОЏОаОЎОф.</translation>
<translation id="9150860646299915960">РђЈОЕОЊОеОЋОњ ОћОДОЋОаОўОЎОЎОаОе ОЕОю Linux</translation>
<translation id="9154194610265714752">ОбОЋОЊОЏОЪ</translation>
<translation id="91568222606626347">ОЎОдОЎОеОф ОъОДОЕ ОДОЎОдОЋОе...</translation>
<translation id="9157096865782046368">0.8 ОЕОаОЎОЋОф</translation>
<translation id="9157697743260533322">ОћОњОЊОеОф ОбОЊОЏОЋОаОЎОЮ ОљОЋОўОЋОъОўОЎОЎОЮ ОюОЏОю ОћОъОЕОфОъОЕОЎОЮ ОаОЏОЕОюОћ (ОЕОњОЎОљОф ОДОЊОЮ-ОћОцОбОюОћ: <ph name="ERROR_NUMBER" />)</translation>
<translation id="9157915340203975005">ОћОЊОюОф ОЕОю ОћОъОЊОцОАОф ОцОфОЋОЌОћ</translation>
<translation id="9158715103698450907">ОљОЋОцОА! ОљОЎОеОбОћ ОЉОбОЎОћ ОЕОю ОфОДОЕОЋОеОф ОеОЕОф ОЉОъОћОюОџ ОћОљОЎОъОЋОф. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОЌОЎОЉОЋОе ОћОеОЕОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="9159643062839240276">РђЈОЏОЊОљОЎ ОюОаОАОЋОф:
    <ph name="BEGIN_LIST" />
      <ph name="LIST_ITEM" />ОюОЉОЊОЋОД ОљОф ОћОЏОЉОюОЎОЮ, ОћОъОЋОЊОЮ ОЋОћОаОфОЉ ОЕОЊОеОЏОЮ ОъОфОЉОдОб ОћОЌОЎОЉОЋОе ОюОеОЕОф
      <ph name="LIST_ITEM" />ОюОћОфОЌОЉОе ОъОЌОЊОЕ ОюОеОЕОф Оћ-Wi-Fi
      <ph name="LIST_ITEM" />ОюОћОцОбОЎОю ОљОф Chrome Connectivity Diagnostics
    <ph name="END_LIST" /></translation>
<translation id="916607977885256133">ОфОъОЋОаОћ ОЉОфОЋОџ ОфОъОЋОаОћ</translation>
<translation id="9167063903968449027">ОћОдОњОф ОеОЕОЎОъОф ОћОДОеОЎОљОћ</translation>
<translation id="9167450455589251456">ОћОцОеОЋОцОЎОю ОљОЎОаОЋ ОаОфОъОџ</translation>
<translation id="9168436347345867845">ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="9169496697824289689">ОћОдОњОф ОъОДОЕОЎ ОДОЎОдОЋОе</translation>
<translation id="916964310188958970">ОюОъОћ ОћОћОдОбОћ ОћОќОљОф ОћОЋОцОЎОбОћ?</translation>
<translation id="9170048603158555829">Thunderbolt</translation>
<translation id="9170061643796692986">ОћОњОЊОеОф ОћОеОЕОљОЋОф ОћОњОЎОЕОћ ОћОаОЋОЏОЌОЎОф ОћОЎОљ 'ОЏОю ОљОаОЕОЎ ОћОДОЕОе'</translation>
<translation id="9170848237812810038">&amp;ОЉОЎОўОЋОю</translation>
<translation id="9170884462774788842">РђЈОфОЋОЏОаОЎОф ОљОЌОеОф ОЉОъОЌОЕОЉ ОЕОюОџ ОћОЋОАОЎОцОћ ОбОЎОдОЋОЉ ОЕОбОЕОЋОЎ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chrome.</translation>
<translation id="917350715406657904">ОћОњОбОф ОюОъОњОЉОюОф ОћОќОъОЪ ОЕОаОДОЉОбОћ ОбОю ОЎОЊОЎ ОћОћОЋОеОћ ОЕОюОџ ОюОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" />. ОъОЌОе ОљОцОЕОе ОЎОћОЎОћ ОюОћОЕОфОъОЕ ОЉОћ ОюОъОЕОџ <ph name="TIME_LIMIT" />.</translation>
<translation id="9174401638287877180">РђЈОЕОюОЎОЌОф ОъОЎОЊОб ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ. ОЏОЊОЎ ОюОфОеОЋОЮ ОюОЕОЎОцОЋОе ОЌОЋОЋОЎОЎОф ОћОъОЕОфОъОЕ ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЉ-Android, ОљОцОЕОе ОюОЕОюОЋОЌ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ, ОаОфОЋОаОЎ ОъОЏОЕОЎОе ОЋОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОЋОф. ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОюОљ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОќОћОЋОф ОљОф ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ, ОЋОћОЮ ОЎОбОќОеОЋ ОюОаОЋ ОюОЕОъОЋОе ОбОю ОћОЎОдОЎОЉОЋОф ОЕОю ОћОъОбОеОЏОф ОЋОЕОю ОћОљОцОюОЎОДОдОЎОЋОф ОЋОюОЉОдОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android. ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОаОЋОАОцОЎОЮ' ОћОЋОцОбОюОћ ОбОЉОЋОе ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ, ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОћОЮ.</translation>
<translation id="9176476835295860688">РђЈОЕОюОЎОЌОћ ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОбОю ОћОЕОЎОъОЋОЕ. ОћОъОЏОЕОЎОе ОћОќОћ ОЕОЋОюОЌ ОбОЏОЕОЎОЋ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОЋОЉОљОцОюОЎОДОдОЎОЋОф. ОаОфОЋОаОЎОЮ ОљОюОћ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОЎОдОЎОЉОЋОф ОћОъОбОеОЏОф ОЋОћОљОцОюОЎОДОдОЎОЋОф, ОЏОъОЋ ОњОЮ ОюОЉОЎОдОЋОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎ Android. Оћ<ph name="BEGIN_LINK1" />ОћОњОЊОеОћ<ph name="END_LINK1" /> ОћОќОЋ ОаОљОЏОцОф ОбОю-ОЎОЊОЎ ОћОЉОбОюОЎОЮ. ОљОЮ ОћОЋОцОбОюОћ ОћОљОцОЕОеОЋОф 'ОцОбОЎОюОЋОф ОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. <ph name="BEGIN_LINK2" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK2" /></translation>
<translation id="9176611096776448349">РђЈ<ph name="WINDOW_TITLE" /> - ОъОЏОЕОЎОе Bluetooth ОъОЌОЋОЉОе</translation>
<translation id="9177949831069307748">РђЈОДОеОЎОљОф ОаОфОЋОаОЎ ОћОъОЏОЕОЎОе ОЋОъОЎОЊОб ОъОћОъОЏОЕОЎОе ОЕОюОџ Оъ-ChromeOS Flex.</translation>
<translation id="9178061802301856367">ОъОЌОЎОДОф ОцОеОўОЎ ОћОЏОаОЎОАОћ</translation>
<translation id="9179524979050048593">ОћОдОњОф ОЕОЮ ОћОъОЕОфОъОЕ ОЉОъОАОџ ОћОЏОаОЎОАОћ</translation>
<translation id="9180281769944411366">РђЈОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф. ОъОфОЉОдОбОф ОћОцОбОюОћ ОЕОю ОћОДОЋОаОўОЎОЎОаОе ОЕОю Linux.</translation>
<translation id="9180380851667544951">ОћОљОфОе ОеОЕОљОЎ ОюОЕОфОБ ОљОф ОћОъОАОџ</translation>
<translation id="9182556968660520230">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОцОбОЎОю ОфОЋОЏОЪ ОъОЋОњОЪ</translation>
<translation id="918352324374649435">{COUNT,plural, =1{ОљОцОюОЎОДОдОЎОћ}two{# ОљОцОюОЎОДОдОЎОЋОф}many{# ОљОцОюОЎОДОдОЎОЋОф}other{# ОљОцОюОЎОДОдОЎОЋОф}}</translation>
<translation id="9186963452600581158">РђЈОЏОаОЎОАОћ ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google ОЕОю ОЎОюОЊ ОљОЋ ОЎОюОЊОћ</translation>
<translation id="9187967020623675250">ОћОъОДОЕОЎОЮ ОюОљ ОфОЋОљОъОЎОЮ. ОдОеОЎОџ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОЏОюОЕОћОЋ ОЏОЊОЎ <ph name="RESPONSE" />.</translation>
<translation id="9188732951356337132">РђЈОЕОюОЎОЌОћ ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОбОю ОћОЕОЎОъОЋОЕ. ОћОъОЏОЕОЎОе ОћОќОћ ОЕОЋОюОЌ ОбОЏОЕОЎОЋ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОЋОЉОљОцОюОЎОДОдОЎОЋОф. ОаОфОЋОаОЎОЮ ОљОюОћ ОюОљ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОќОћОЋОф ОљОф ОћОЎОюОЊ/Оћ ОЕОюОџ, ОЋОћОЮ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОЎОдОЎОЉОЋОф ОћОъОбОеОЏОф ОЋОћОљОцОюОЎОДОдОЎОЋОф, ОЏОъОЋ ОњОЮ ОюОЉОЎОдОЋОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎ Android. ОљОЮ ОћОЋОцОбОюОћ ОЉОЕОЉОЎОю ОћОЎОюОЊ/Оћ ОЕОюОџ ОћОљОцОЕОеОЋОф 'ОцОбОЎОюОЋОф ОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОЋ/Оћ. <ph name="BEGIN_LINK2" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK2" /></translation>
<translation id="919686179725692564">ОъОЎОЊОб ОаОЋОАОБ ОбОю ОњОЎОЉОЋОЎ ОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ</translation>
<translation id="9198090666959937775">РђЈОЕОЎОъОЋОЕ ОЉОўОюОцОЋОЪ Android ОЏОъОцОфОЌ ОљОЉОўОЌОћ</translation>
<translation id="9199503643457729322">ОљОцОЕОе ОюОюОЌОЋОЦ ОбОю ОћОюОЌОдОЪ ОћОќОћ ОЏОЊОЎ ОюОдОљОф ОъОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф.</translation>
<translation id="9200339982498053969">Ою-<ph name="ORIGIN" /> ОфОћОЎОћ ОћОеОЕОљОћ ОюОбОеОЋОџ ОљОф ОћОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDERNAME" /></translation>
<translation id="920045321358709304">ОЌОЎОцОЋОЕ ОЉ-<ph name="SEARCH_ENGINE" /></translation>
<translation id="9201023452444595544">ОћОъОбОеОЏОф ОфОъОЌОД ОљОф ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОаОЕОъОеОЋ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="9201117361710210082">ОаОдОцОћ ОЉОбОЉОе</translation>
<translation id="9201220332032049474">ОљОцОЕОеОЋОЎОЋОф ОаОбОЎОюОф ОъОАОџ</translation>
<translation id="9201842707396338580">ОъОЕОћОЋ ОћОЕОфОЉОЕ. ОЎОЕ ОюОцОаОЋОф ОюОЉОбОюОЎОЮ ОљОЋ ОюОъОаОћОю ОЕОю ОћОъОЏОЕОЎОе. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="9203398526606335860">&amp;ОЎОдОЎОеОф ОцОеОЋОцОЎОюОЎОЮ ОъОЋОцОбОюОф</translation>
<translation id="9203904171912129171">ОЉОЌОЎОеОф ОъОЏОЕОЎОе</translation>
<translation id="9206889157914079472">ОЏОфОЎОЉОф ОћОбОеОЋОф ОЉОљОъОдОбОЋОф ОАОўОЎОЎОюОЋОА ОЉОъОАОџ ОћОаОбОЎОюОћ</translation>
<translation id="9209563766569767417">РђЈОћОъОбОеОЏОф ОЉОЋОЊОДОф ОљОф ОћОњОЊОеОЋОф ОћОДОЋОаОўОЎОЎОаОе ОЕОю Linux</translation>
<translation id="9209689095351280025">РђЈОљОфОеОЎОЮ ОюОљ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОЕОбОЋОДОЉОЎОЮ ОљОЌОеОЎОџ ОЉОљОЎОаОўОеОаОў</translation>
<translation id="9211177926627870898">ОаОЊОеОЕ ОбОЊОЏОЋОЪ</translation>
<translation id="9214520840402538427">ОљОЋОцОА! ОфОЮ ОћОќОъОЪ ОћОДОдОЋОЉ ОюОљОфОЌОЋОю ОЕОю ОъОљОцОЎОЎОаОЎ ОќОъОЪ ОћОћОфОДОаОћ. ОЎОЕ ОюОцОаОЋОф ОљОю ОаОдОЎОњ ОћОфОъОЎОЏОћ ОЕОюОџ.</translation>
<translation id="9214695392875603905">ОДОљОцОДОЎОЎОД</translation>
<translation id="9215293857209265904">"<ph name="EXTENSION_NAME" />" ОаОЋОАОБ</translation>
<translation id="9215742531438648683">РђЈОћОАОеОћ ОЕОю 'ОЌОаОЋОф Google Play'</translation>
<translation id="9218430445555521422">ОћОњОЊОеОћ ОЏОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="9218842937876577955"><ph name="APP_NAME" /> (ОћОљОцОюОЎОДОдОЎОћ ОюОљ ОаОфОъОЏОф)</translation>
<translation id="9220525904950070496">ОћОАОеОф ОЌОЕОЉОЋОЪ</translation>
<translation id="9220820413868316583">ОдОеОЎОџ ОюОћОеОЎОЮ ОљОф ОћОљОдОЉОб ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="923467487918828349">ОћОдОњОф ОћОЏОЋОю</translation>
<translation id="924818813611903184">РђЈОаОЎОћОЋОю ОЕОцОЋОф ОЉОћОњОЊОеОЋОф ChromeOS</translation>
<translation id="929117907539171075">ОћОъОбОеОЏОф ОфОъОЌОД ОњОЮ ОаОфОЋОаОЎОЮ ОЕОаОЕОъОеОЋ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ ОЉОљОцОюОЎОДОдОЎОћ ОъОЋОфОДОаОф</translation>
<translation id="930268624053534560">ОЌОЋОфОъОЋОф ОќОъОЪ ОъОцОЋОеОўОЋОф</translation>
<translation id="930893132043726269">ОћОаОЊОЎОЊОћ ОцОЋОбОюОф</translation>
<translation id="932327136139879170">ОЉОЎОф</translation>
<translation id="932508678520956232">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЎОю ОћОЊОцОАОћ.</translation>
<translation id="933427034780221291">{NUM_FILES,plural, =1{РђЈОћОДОЋОЉОЦ ОћОќОћ ОњОЊОЋОю ОъОЊОЎ ОЉОЕОЉОЎОю ОЉОЊОЎОДОф ОљОЉОўОЌОћ. ОљОцОЕОе ОюОћОбОюОЋОф ОДОЉОдОЎОЮ ОЉОњОЋОЊОю ОЕОю ОбОЊ 50 MB.}two{РђЈОЌОюОД ОъОћОДОЉОдОЎОЮ ОћОљОюОћ ОњОЊОЋОюОЎОЮ ОъОЊОЎ ОЉОЕОЉОЎОю ОЉОЊОЎОДОф ОљОЉОўОЌОћ. ОљОцОЕОе ОюОћОбОюОЋОф ОДОЉОдОЎОЮ ОЉОњОЋОЊОю ОЕОю ОбОЊ 50 MB.}many{РђЈОЌОюОД ОъОћОДОЉОдОЎОЮ ОћОљОюОћ ОњОЊОЋОюОЎОЮ ОъОЊОЎ ОЉОЕОЉОЎОю ОЉОЊОЎОДОф ОљОЉОўОЌОћ. ОљОцОЕОе ОюОћОбОюОЋОф ОДОЉОдОЎОЮ ОЉОњОЋОЊОю ОЕОю ОбОЊ 50 MB.}other{РђЈОЌОюОД ОъОћОДОЉОдОЎОЮ ОћОљОюОћ ОњОЊОЋОюОЎОЮ ОъОЊОЎ ОЉОЕОЉОЎОю ОЉОЊОЎОДОф ОљОЉОўОЌОћ. ОљОцОЕОе ОюОћОбОюОЋОф ОДОЉОдОЎОЮ ОЉОњОЋОЊОю ОЕОю ОбОЊ 50 MB.}}</translation>
<translation id="93343527085570547">РђЈОЏОЊОЎ ОюОЉОДОЕ ОЕОЎОаОЋОЎОЎ ОфОЋОЏОЪ ОъОАОЎОЉОЋОф ОъОЕОцОўОЎОЋОф, ОдОеОЎОџ ОюОбОЉОЋОе Ою<ph name="BEGIN_LINK1" />ОЊОБ ОћОбОќОеОћ ОћОъОЕОцОўОЎОф<ph name="END_LINK1" />. ОЌОюОД ОъОцОеОўОЎ ОћОъОбОеОЏОф ОЋОцОеОўОЎОЮ ОъОАОЋОЎОъОЎОЮ ОюОњОЉОЎ ОћОЌОЕОЉОЋОЪ ОбОЕОЋОЎОЎОЮ ОюОћОЎОЕОюОЌ ОљОю Google. ОљОаОЌОаОЋ ОаОЕОфОъОЕ ОЉОъОЎОЊОб ОЕОъОфОДОЉОю ОъОъОџ ОЏОЊОЎ ОюОўОцОю ОЉОЉОбОЎОЋОф ОўОЏОаОЎОЋОф ОЋОюОЕОцОе ОљОф ОћОЕОЎОеОЋОфОЎОЮ ОЕОюОаОЋ, ОЉОЏОцОЋОБ Ою<ph name="BEGIN_LINK2" />ОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф<ph name="END_LINK2" /> ОЋОю<ph name="BEGIN_LINK3" />ОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф<ph name="END_LINK3" />.</translation>
<translation id="93393615658292258">ОАОЎОАОъОћ ОЉОюОЉОЊ</translation>
<translation id="934244546219308557">ОЏОљОЪ ОаОЋОфОаОЎОЮ ОЕОЮ ОюОДОЉОЋОдОћ</translation>
<translation id="934503638756687833">РђЈОЉОъОДОеОћ ОћОдОЋОеОџ ОЎОЎОфОЏОЪ ОЕОЎОЋОАОеОЋ ОњОЮ ОцОеОЎОўОЎОЮ ОЕОюОљ ОъОЋОцОЎОбОЎОЮ ОЏОљОЪ. ОъОЎОЊОб ОаОЋОАОБ ОбОю &lt;a href="<ph name="URL" />"&gt;ОћОњОаОћ ОъОцОаОЎ ОфОЋОЏОаОЋОф ОюОљ ОеОдОЋОЎОЋОф&lt;/a&gt; ОќОъОЎОЪ ОЉОАОДОЎОеОћ ОћОўОЏОаОЎОф ОюОњОЉОЎ ОцОеОўОЎОЋОф ОЉ-Chrome.</translation>
<translation id="93480724622239549">ОЉОљОњ ОљОЋ ОЕОњОЎОљОћ</translation>
<translation id="935854577147268200">РђЈОћОўОюОцОЋОЪ ОЕОћОЋОњОЊОе ОЉ-Smart Lock ОћОЕОфОаОћ. ОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЏОЊОЎ ОюОбОЊОЏОЪ ОљОф Smart Lock. ОЉОцОбОЮ ОћОЉОљОћ, ОћОўОюОцОЋОЪ ОЎОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю <ph name="DEVICE_TYPE" />. ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф Smart Lock ОЉОћОњОЊОеОЋОф.</translation>
<translation id="93610034168535821">ОаОцОЌ ОћОљОЌОАОЋОЪ ОћОЏОЋОюОю ОЕОъОаОЋОдОю ОбОю ОЎОЊОЎ ОљОфОеОЎОЮ:</translation>
<translation id="936646668635477464">ОъОдОюОъОћ ОЋОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="936801553271523408">ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЕОю ОъОбОеОЏОф</translation>
<translation id="93766956588638423">ОфОЎОДОЋОЪ ОћОфОЋОАОБ</translation>
<translation id="938568644810664664">РђЈОљОцОЕОе ОюОаОАОЋОф ОюОЋОъОе "Hey Google, what song is this?Рђј" ОљОЋ "Hey Google, what's on my screen?Рђј"</translation>
<translation id="938623846785894166">ОДОЋОЉОЦ ОюОљ ОаОцОЋОЦ</translation>
<translation id="939401694733344652">РђЈОЉОЌОЕОЉОЋОаОЋОф ОћОљОюОћ ОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЉОЕОюОЉ ОћОќОћ. ОљОЮ ОаОЉОЌОе ОЌОЕОЉОЋОЪ ОюОЕОЎОъОЋОЕ ОбОЮ ОћОљОцОюОЎОДОдОЎОћ ОћОќОљОф Ою-Android, ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОЌОЕОЉОЋОЪ ОњОЮ ОбОЮ ОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф Ою-Android. ОаОЎОфОЪ ОюОЕОаОЋОф ОљОф ОљОцОЕОеОЋОф ОћОњОЎОЕОћ ОюОљОцОюОЎОДОдОЎОћ Ою-Android ОЉ<ph name="LINK_BEGIN" />ОћОњОЊОеОЋОф &gt; ОЌОЕОЉОЋОаОЋОф<ph name="LINK_END" />.</translation>
<translation id="939598580284253335">ОћОќОаОф ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="939736085109172342">ОфОЎОДОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="942532530371314860">РђЈ<ph name="APP_NAME" /> ОъОЕОфОБ ОЏОеОўОЎОАОЎОЎОћ ОЋОљОЋОЊОЎОЋ ОЕОю Chrome.</translation>
<translation id="945522503751344254"> ОЕОюОЎОЌОф ОъОЕОЋОЉ</translation>
<translation id="947329552760389097">&amp;ОЉОЊОЎОДОф ОеОЏОЎОЉОЎОЮ</translation>
<translation id="947526284350604411">ОћОфОЕОЋОЉОћ ОЕОюОџ</translation>
<translation id="947667444780368238">Ою-<ph name="ORIGIN" /> ОљОЎОЪ ОћОеОЕОљОћ ОюОцОфОЋОЌ ОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЎОћ ОћОќОЋ ОЏОЎ ОћОЎОљ ОъОЏОЎОюОћ ОДОЋОЉОдОЎ ОъОбОеОЏОф</translation>
<translation id="950307215746360464">ОъОЊОеОЎОџ ОћОћОњОЊОеОћ</translation>
<translation id="951991426597076286">ОЊОЌОЎОЎОћ</translation>
<translation id="952471655966876828">ОЏОЕОћОъОЏОЕОЎОе ОъОЋОцОбОю ОЋОЉОЕОЎОъОЋОЕ, ОћОЋОљ ОЎОЌОЋОЉОе ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="953434574221655299">ОЎОЕ ОћОеОЕОљОћ ОюОЊОбОф ОъОфОЎ ОћОъОЏОЕОЎОе ОћОќОћ ОъОЕОъОЕ ОљОЋОфОџ ОЉОљОЋОцОЪ ОцОбОЎОю</translation>
<translation id="956500788634395331">ОћОъОбОеОЏОф ОъОњОЎОаОћ ОбОюОЎОџ ОъОцОаОЎ ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ</translation>
<translation id="957960681186851048">ОћОљОфОе ОћОќОћ ОаОЎОАОћ ОюОћОЋОеОЎОЊ ОДОЉОдОЎОЮ ОъОеОЋОЉОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="960987915827980018">ОаОЋОфОеОћ ОЉОбОеОџ ОЕОбОћ ОљОЌОф</translation>
<translation id="962802172452141067">ОбОЦ ОфОЎОДОЎОЋОф ОЕОю ОАОЎОъОаОЎОЋОф</translation>
<translation id="964286338916298286">РђЈОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ ОћОЕОЉОЎОф ОљОф ОћОћОўОЉОЋОф ОЕОю Chrome ОЉОЕОЉОЎОю ОћОъОЏОЕОЎОе ОЕОюОџ.</translation>
<translation id="964439421054175458">{NUM_APLLICATIONS,plural, =1{ОљОцОюОЎОДОдОЎОћ}two{ОљОцОюОЎОДОдОЎОЋОф}many{ОљОцОюОЎОДОдОЎОЋОф}other{ОљОцОюОЎОДОдОЎОЋОф}}</translation>
<translation id="964790508619473209">ОцОеОЎОАОф ОъОАОЏОЎОЮ</translation>
<translation id="965211523698323809">ОљОцОЕОе ОюОЕОюОЋОЌ ОЋОюОДОЉОю ОћОЋОЊОбОЋОф ОўОДОАОў ОЊОеОџ Оћ-<ph name="DEVICE_TYPE" />. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="96535553604365597">РђЈОЊОЎОЋОЋОЌ ОбОю ОЉОбОЎОћ ОЉ-Google Cast</translation>
<translation id="967398046773905967">РђЈОюОљОБ ОљОфОе ОљОЎОЪ ОњОЎОЕОћ ОюОћОфОДОаОЎ HID</translation>
<translation id="967624055006145463">ОаОцОЌ ОћОаОфОЋОаОЎОЮ</translation>
<translation id="96774243435178359">ОъОЊОцОАОЋОф ОъОаОЋОћОюОЋОф</translation>
<translation id="968000525894980488">РђЈОъОцОбОЎОюОЎОЮ ОљОф ОЕОЎОеОЋОфОЎ Google Play.</translation>
<translation id="968037381421390582">ОћОЊ&amp;ОЉОДОћ ОЋОЌОЎОцОЋОЕ ОЕОю "<ph name="SEARCH_TERMS" />"</translation>
<translation id="969096075394517431">ОћОЌОюОцОф ОЕОцОЋОф</translation>
<translation id="970047733946999531">{NUM_TABS,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}two{# ОЏОеОўОЎОАОЎОЋОф}many{# ОЏОеОўОЎОАОЎОЋОф}other{# ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="971510864672937292">ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОљОф ОћОћОеОЕОљОЋОф ОюОљОфОе <ph name="SITE_NAME" /> ОЋОюОЏОю ОћОљОфОеОЎОЮ ОЕОфОЌОфОЎОЋ?</translation>
<translation id="971774202801778802">ОЏОфОЋОЉОф ОљОфОе ОЕОю ОАОЎОъОаОЎОЎОћ</translation>
<translation id="972996901592717370">ОЎОЕ ОюОњОбОф ОЉОюОЌОдОЪ ОћОћОцОбОюОћ ОбОЮ ОћОљОдОЉОб. ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОъОљОЋОЌОАОаОЎОЮ ОЉОљОЋОцОЪ ОъОљОЋОЉОўОЌ ОЋОљОБ ОцОбОЮ ОюОљ ОаОЕОюОЌОЎОЮ ОъОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" />.</translation>
<translation id="973473557718930265">ОЎОдОЎОљОћ</translation>
<translation id="975893173032473675">ОЕОцОф ОћОЎОбОЊ ОЕОю ОћОфОеОњОЋОЮ</translation>
<translation id="976499800099896273">ОфОЎОЉОф ОћОЊОЋ-ОЕОЎОЌ ОЕОю ОћОфОЎОДОЋОЪ ОћОљОЋОўОЋОъОўОЎ ОбОЮ ОћОцОбОЋОюОћ 'ОЉОЎОўОЋОю' ОъОЋОдОњОф ОбОЉОЋОе ОћОъОЎОюОћ <ph name="TYPED_WORD" /> ОЕОфОЋОДОаОћ ОюОъОЎОюОћ <ph name="CORRECTED_WORD" />.  ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОћОЌОдОЎОЮ ОюОъОбОюОћ ОЏОЊОЎ ОюОњОЕОф, ОюОдОљОф ОљОЋ ОюОћОфОбОюОЮ.</translation>
<translation id="978146274692397928">ОеОЋОЌОЉ ОАОЎОъОЪ ОћОцОЎОАОЋОД ОћОеОљОЕОЋОаОЎ ОћОЋОљ ОъОюОљ</translation>
<translation id="97905529126098460">ОћОЌОюОЋОЪ ОћОќОћ ОЎОЎОАОњОе ОюОљОЌОе ОћОЕОюОъОф ОћОЉОЎОўОЋОю.</translation>
<translation id="980731642137034229">ОюОЌОдОЪ ОфОцОеОЎОў ОцОбОЋОюОЋОф</translation>
<translation id="981121421437150478">ОюОљ ОъОДОЋОЋОЪ</translation>
<translation id="982684081337630214">РђЈОаОЕОюОЌОћ ОЉОДОЕОф ОљОЎОЕОЋОе ОюОћОЋОеОЎОЮ ОЕОюОџ ОЊОеОџ ОћОљОцОюОЎОДОдОЎОћ Google Family Link ОЋОЉОЏОфОЋОЉОф families.google.com. ОљОЮ ОљОЌОЊ ОъОћОћОЋОеОЎОЮ ОЎОљОЕОе ОљОф ОћОЉОДОЕОћ, ОфОЎОЕОюОЌ ОљОюОЎОџ ОћОфОеОљОћ.</translation>
<translation id="983511809958454316">РђЈОћОфОЏОЋОаОћ ОюОљ ОаОфОъОЏОф ОЉ-VR</translation>
<translation id="984275831282074731">ОљОъОдОбОЎ ОфОЕОюОЋОЮ</translation>
<translation id="984705303330760860">ОћОЋОАОцОф ОЕОцОЋОф ОюОЉОЊОЎОДОф ОћОљОЎОЋОф</translation>
<translation id="98515147261107953">ОюОеОЋОЌОЉ</translation>
<translation id="987068745968718743">Parallels Desktop: <ph name="PLUGIN_VM_NAME" /></translation>
<translation id="987264212798334818">ОЏОюОюОЎ</translation>
<translation id="987897973846887088">ОљОЎОЪ ОфОъОЋОаОЋОф ОќОъОЎОаОЋОф</translation>
<translation id="988320949174893488">ОюОљ ОЎОдОЎОЉ</translation>
<translation id="988978206646512040">ОћОЕОЊОћ ОЕОю ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОюОљ ОЎОЏОЋОю ОюОћОЎОЕОљОе ОеОЎОД</translation>
<translation id="992032470292211616">ОфОЋОАОцОЎОЮ, ОљОцОюОЎОДОдОЎОЋОф ОЋОбОЎОдОЋОЉОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОцОњОЋОб ОЉОъОЏОЕОЎОе ОЕОюОџ. ОЉОеОдОЋОаОџ ОюОћОъОЕОЎОџ?</translation>
