<translation id="6019851026059441029">РђЈОъОбОЋОюОћ РђЊ HD</translation>
<translation id="6020431688553761150">ОћОЕОеОф ОюОљ ОљОЎОЕОе ОбОЉОЋОеОџ ОњОЎОЕОћ ОљОю ОћОъОЕОљОЉ ОћОќОћ.</translation>
<translation id="6022526133015258832">ОцОфОЎОЌОћ ОЉОъОАОџ ОъОюОљ</translation>
<translation id="6022659036123304283">РђЈОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chrome ОЉОЊОеОџ ОЕОаОЋОЌОћ ОюОџ</translation>
<translation id="6023643151125006053">ОъОЏОЕОЎОе ОќОћ (ОъОАОцОе ОАОЎОЊОЋОеОЎ: <ph name="SERIAL_NUMBER" />) ОаОаОбОю ОбОю-ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОю <ph name="SAML_DOMAIN" />.</translation>
<translation id="6025215716629925253">ОћОфОЌОДОЋОф ОљОЌОе ОбОеОЎОъОћ</translation>
<translation id="6026819612896463875">РђЈ<ph name="WINDOW_TITLE" /> - USB ОъОЌОЋОЉОе</translation>
<translation id="6027945736510816438">ОћОљОЮ ОћОфОЏОЋОЋОаОф ОюОљОфОе <ph name="WEBSITE" />?</translation>
<translation id="6028117231645531007">ОћОЋОАОцОф ОўОЉОЎОбОф ОљОдОЉОб</translation>
<translation id="6031600495088157824">ОљОцОЕОеОЋОЎОЋОф ОДОюОў ОЉОАОеОњОю ОћОЏОюОЎОЮ</translation>
<translation id="6032091552407840792">ОфОДОЋОцОф ОћОаОЎОАОЎОЋОЪ ОћОќОЋ ОцОбОЎОюОћ ОеОД ОЉ<ph name="BEGIN_LINK" />ОљОќОЋОеОЎОЮ ОъОАОЋОЎОъОЎОЮ<ph name="END_LINK" />.</translation>
<translation id="6032715498678347852">ОЏОЊОЎ ОюОћОбОаОЎОД ОюОфОЋОАОБ ОњОЎОЕОћ ОюОљОфОе ОћОќОћ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОћОфОЋОАОБ.</translation>
<translation id="6032912588568283682">ОъОбОеОЏОф ОДОЉОдОЎОЮ</translation>
<translation id="603539183851330738">РђЈОЏОцОфОЋОе ОЉОЎОўОЋОю ОЉОфОЎОДОЋОЪ ОћОљОЋОўОЋОъОўОЎ. ОЌОќОеОћ ОюОњОеОАОћ ОћОДОЋОЊОъОф ОЕОю <ph name="TYPED_WORD" />.  ОЎОЕ ОюОћОДОЎОЕ ОбОю Enter ОЏОЊОЎ ОюОћОцОбОЎОю, ОљОЋ ОбОю Escape ОЏОЊОЎ ОюОЉОўОю.</translation>
<translation id="6038929619733116134">ОЌОАОЎОъОћ ОљОЮ ОЉОљОфОе ОъОЋОдОњОЋОф ОъОЋОЊОбОЋОф ОъОцОеОЎОбОЋОф ОљОЋ ОъОўОбОЋОф</translation>
<translation id="6039651071822577588">ОъОЎОюОЋОЪ ОъОљОцОЎОЎОаОЎ ОћОеОЕОф ОцОњОЋОЮ</translation>
<translation id="6040143037577758943">ОАОњОЎОеОћ</translation>
<translation id="6041046205544295907">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОЎОеОЋОф ОћОъОЎОДОЋОЮ ОЕОю Google ОаОбОќОе ОЉОъОДОЋОеОЋОф ОЏОњОЋОЪ WiРђЉFi, ОеОЕОфОЋОф ОАОюОЋОюОеОЎОЋОф ОЋОЌОЎОЎОЕОаОЎОЮ ОЏОЊОЎ ОюОћОбОеОЎОџ ОљОф ОъОЎОДОЋОЮ ОћОъОЏОЕОЎОе.<ph name="END_PARAGRAPH1" />
<ph name="BEGIN_PARAGRAPH2" />ОаОЎОфОЪ ОюОћОЕОЉОЎОф ОљОф ОћОћОбОЉОеОћ ОЕОю ОаОфОЋОаОЎ ОъОЎОДОЋОЮ ОбОю-ОЎОЊОЎ ОЏОЎОЉОЋОЎ ОЕОю ОћОњОЊОеОф ОћОъОЎОДОЋОЮ ОћОеОљОЕОЎОф ОЉОъОЏОЕОЎОе. ОљОцОЕОе ОњОЮ ОюОћОЕОЉОЎОф ОљОф ОћОЕОЎОъОЋОЕ ОЉ-Wi-Fi, ОЉОеОЕОфОЋОф ОАОюОЋОюОеОЎОЋОф ОЋОЉОЌОЎОЎОЕОаОЎОЮ ОюОљОЎОфОЋОе ОћОъОЎОДОЋОЮ ОЉОћОњОЊОеОЋОф ОћОъОЎОДОЋОЮ.<ph name="END_PARAGRAPH2" /></translation>
<translation id="6041155700700864984">ОЎОдОЎОљОћ ОъОъОАОџ ОъОюОљ</translation>
<translation id="6042308850641462728">ОбОЋОЊ</translation>
<translation id="604388835206766544">ОаОЎОфОЋОЌ ОћОћОњОЊОеОћ ОаОЏОЕОю</translation>
<translation id="6043994281159824495">ОЎОдОЎОљОћ ОбОЏОЕОЎОЋ</translation>
<translation id="6045114302329202345">РђЈОюОЌОдОЪ TrackPoint ОеОљОЕОЎ</translation>
<translation id="6047632800149092791">ОћОАОаОЏОеОЋОЪ ОюОљ ОцОЋОбОю. ОЎОЕ ОюОаОАОЋОф ОюОдОљОф ОЋОюОћОЎОЏОаОА ОЕОЋОЉ.</translation>
<translation id="6049797270917061226">ОћОДОЋОЉОЦ ОћОќОћ ОбОюОЋОю ОюОљОцОЕОе ОюОфОЋОДОцОЎОЮ ОюОњОаОЋОЉ ОљОф ОћОъОЎОЊОб ОћОљОЎОЕОЎ ОЕОюОџ.</translation>
<translation id="6051354611314852653">РђЈОљОЋОцОА!  ОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОљОъОф ОљОф ОћОњОЎОЕОћ ОЕОю ОъОЏОЕОЎОе ОќОћ ОюОъОъОЕОД Оћ-API.</translation>
<translation id="6051638103735819069">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОЏОюОЋОю ОъОЎОЊОб ОЏОъОЋ ОъОЋОбОЊ ОћОДОеОЎОАОћ ОЕОю ChromeOS, ОћОфОЏОЋОаОЋОф ОЕОЉОћОЪ ОаОбОЕОћ ОЕОЎОъОЋОЕ, ОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЋ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю ОЋОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОЕОЎОъОЋОЕ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Ою-Android. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОъОЏОЕОЎОе ChromeOS ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОюОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.<ph name="END_PARAGRAPH3" />
    <ph name="BEGIN_PARAGRAPH4" />ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОћОЋОцОбОюОћ ОЉОЌОЕОЉОЋОЪ Google ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОаОфОЋОаОЎОЮ ОЕОюОћОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОћОЮ. ОЏОЊОЎ ОюОДОеОЋОљ ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОћОњОЊОеОЋОф ОћОљОюОћ ОЋОюОњОюОЋОф ОљОЎОџ ОюОЕОаОЋОф ОљОЋОфОЪ, ОљОцОЕОе ОюОбОЉОЋОе ОюОЏОфОЋОЉОф families.google.com.<ph name="END_PARAGRAPH4" /></translation>
<translation id="6051811090255711417">ОћОДОЋОЉОЦ ОћОќОћ ОюОљ ОбОъОЊ ОЉОфОаОљОЎОЮ ОЕОю ОъОЊОЎОаОЎОЋОф ОћОљОЉОўОЌОћ ОЋОюОЏОЪ ОћОЋОљ ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="6052284303005792909">Рђб</translation>
<translation id="6052488962264772833">РђЈОдОеОЎОџ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОњОЎОЕОћ ОЏОЊОЎ ОюОћОфОЌОЎОю ОЉОћОбОЉОеОћ (cast)</translation>
<translation id="6052976518993719690">РђЈОеОЕОЋОф ОљОЎОЕОЋОеОЎ SSL </translation>
<translation id="6053401458108962351">&amp;ОаОЎОДОЋОЎ ОаОфОЋОаОЎ ОњОюОЎОЕОћ...</translation>
<translation id="6054284857788651331">ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЕОаОАОњОеОћ ОюОљОЌОеОЋОаОћ</translation>
<translation id="6054961935262556546">ОЕОЎОаОЋОЎ ОћОеОЕОљОЋОф ОћОњОЎОЕОћ</translation>
<translation id="6055171183283175969">ОћОќОаОф ОАОЎОАОъОћ ОЕОњОЋОЎОћ.</translation>
<translation id="6055392876709372977">РђЈPKCS #1 SHA-256 ОбОЮ ОћОдОцОаОф RSA</translation>
<translation id="6056710589053485679">ОўОбОЎОаОћ ОъОЌОЊОЕ ОеОњОЎОюОћ</translation>
<translation id="6057312498756061228">РђЈОћОДОЋОЉОЦ ОћОќОћ ОњОЊОЋОю ОъОЊОЎ ОЉОЕОЉОЎОю ОЉОЊОЎОДОф ОљОЉОўОЌОћ. ОљОцОЕОе ОюОцОфОЋОЌ ОДОЉОдОЎОЮ ОЉОњОЋОЊОю ОЕОю ОбОЊ 50 MB.</translation>
<translation id="6057381398996433816">ОаОЌОАОъОћ ОћОЎОЏОЋОюОф ОЕОю ОћОљОфОе ОћОќОћ ОюОћОЕОфОъОЕ ОЉОЌОЎОЎОЕОаОЎ ОћОфОаОЋОбОћ ОЋОћОфОљОЋОеОћ.</translation>
<translation id="6059276912018042191">РђЈОЏОеОўОЎОАОЎОЋОф Chrome ОљОЌОеОЋОаОЋОф</translation>
<translation id="6059652578941944813">ОћОЎОеОеОЏОЎОЎОф ОљОЎОЕОЋОеОЎОЮ</translation>
<translation id="6063284707309177505">РђЈОЎОдОЎОеОф ОДОЋОЊ QR</translation>
<translation id="6063847492705284550">РђЈ<ph name="BEGIN_BOLD" />ОћОбОеОћ:<ph name="END_BOLD" /> ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОъОЎОЕОћОЋ ОЎОдОюОЎОЌ ОюОњОЕОф ОљОю ОћОфОЋОдОљОЋОф ОћОљОЎОЕОЎОЋОф ОЕОю <ph name="SUPERVISED_USER_NAME" /> ОњОЮ ОЉОљОъОдОбОЋОф ОДОЋОю ОЊОЋОъОћ ОљОЋ ОћОДОюОўОћ. ОЏОЊОЎ ОюОЌОАОЋОџ ОЉОдОеОЎОЏОф ОћОАОЋОюОюОћ, ОљОцОЕОе ОюОЉОЌОЋОе ОЉОћОњОЊОеОЋОф Assistant ОЕОю <ph name="SUPERVISED_USER_NAME" /> ОЕОћОцОДОЋОЊОћ РђюHey GoogleРђЮ ОфОцОбОю ОеОД ОЏОЕОћОъОЏОЕОЎОе ОъОЌОЋОЉОе ОюОЌОЕОъОю ОљОЋ ОаОъОдОљ ОЉОўОбОЎОаОћ.</translation>
<translation id="6064217302520318294">ОаОбОЎОюОф ОъОАОџ</translation>
<translation id="6065289257230303064">ОфОЏОЋОаОЋОф ОАОцОеОЎОЎОћ ОЕОю ОаОЋОЕОљ ОљОЎОЕОЋОе</translation>
<translation id="6066794465984119824">РђЈОюОљ ОћОЋОњОЊОе ОњОЎОЉОЋОЉ (hash) ОЕОю ОфОъОЋОаОћ</translation>
<translation id="6069464830445383022">РђЈОћОЏОаОЎОАОћ Ою-Chromebook ОфОфОЉОдОб ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google</translation>
<translation id="6069671174561668781">ОћОњОЊОеОф ОўОцОў</translation>
<translation id="6071181508177083058">ОљОЎОЕОЋОе ОАОЎОАОъОћ</translation>
<translation id="6071576563962215370">ОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОЎОдОЋОе ОљОф ОаОбОЎОюОф ОћОъОљОцОЎОЎОаОЎОЮ ОЕОю ОћОъОЏОЕОЎОе ОЉОќОъОЪ ОћОћОфОДОаОћ.</translation>
<translation id="6072442788591997866">ОљОАОЋОе ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОЉОъОЏОЕОЎОе ОћОќОћ. ОЎОЕ ОюОцОаОЋОф ОљОю ОъОаОћОю ОћОъОбОеОЏОф. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="6073451960410192870">ОћОцОАОДОф ОдОЎОюОЋОЮ ОћОАОеОўОЋОЪ</translation>
<translation id="6073903501322152803">ОћОЋОАОцОф ОфОЏОЋОаОЋОф ОаОњОЎОЕОЋОф</translation>
<translation id="6075731018162044558">РђЈОљОЋОцОА!  ОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОДОЉОю ОљОАОЎОъОЋОЪ ОњОЎОЕОћ ОюОъОъОЕОД Оћ-API ОюОўОЋОЋОЌ ОљОеОЋОџ ОбОЉОЋОе ОъОЏОЕОЎОе ОќОћ.</translation>
<translation id="6075907793831890935">ОћОЌОюОцОф ОаОфОЋОаОЎОЮ ОбОЮ ОћОъОЏОЕОЎОе ОЉОЕОЮ <ph name="HOSTNAME" /></translation>
<translation id="6076175485108489240">РђЈОЕОЎОъОЋОЕ ОЉОъОЎОДОЋОЮ. ОъОфОЪ ОеОЕОЋОф ОюОЕОЎОеОЋОфОЎОЮ ОбОЮ ОћОеОЕОљОЋОф ОъОЎОДОЋОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОДОЋОЮ ОћОъОЏОЕОЎОе ОћОќОћ. Google ОбОЕОЋОЎОћ ОюОљОАОЋОБ ОъОЊОЎ ОцОбОЮ ОаОфОЋОаОЎ ОъОЎОДОЋОЮ ОЋОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОљОЋОцОЪ ОљОаОЋОаОЎОъОЎ ОЏОЊОЎ ОюОЕОцОе ОљОф ОЊОЎОЋОД ОћОъОЎОДОЋОЮ ОЋОЕОЎОеОЋОфОЎОЮ ОъОЉОЋОАОАОЎ-ОъОЎОДОЋОЮ. <ph name="BEGIN_LINK1" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK1" /></translation>
<translation id="6076491747490570887">ОљОцОЋОе ОДОеОЎОе</translation>
<translation id="6077131872140550515">ОћОАОеОћ ОъОеОЕОЎОъОф ОћОеОЕОфОЋОф ОћОъОЋОбОЊОцОЋОф</translation>
<translation id="6077189836672154517">ОўОЎОцОЎОЮ ОЋОбОЊОЏОЋОаОЎОЮ ОЉОаОЋОЕОљ <ph name="DEVICE_TYPE" /></translation>
<translation id="6077476112742402730">ОЊОЎОЉОЋОе ОюОћОДОюОЊОћ</translation>
<translation id="6078121669093215958">{0,plural, =1{ОъОдОЉ ОљОЋОеОЌ}two{# ОЌОюОЋОаОЋОф ОљОЋОеОЌОЎОЮ ОцОфОЋОЌОЎОЮ}many{# ОЌОюОЋОаОЋОф ОљОЋОеОЌОЎОЮ ОцОфОЋОЌОЎОЮ}other{# ОЌОюОЋОаОЋОф ОљОЋОеОЌОЎОЮ ОцОфОЋОЌОЎОЮ}}</translation>
<translation id="6078323886959318429">ОћОЋОАОцОф ОДОЎОдОЋОе ОЊОеОџ</translation>
<translation id="6078752646384677957">ОЎОЕ ОюОЉОЊОЋОД ОљОф ОбОЋОдОъОф ОћОДОЋОю ОюОъОЎОДОеОЋОцОЋОЪ ОЋОюОљОЋОЊОЎОЋ.</translation>
<translation id="6078769373519310690">РђЈ"<ph name="CHROME_EXTENSION_NAME" />" ОеОЋОдОћ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОе HID</translation>
<translation id="608029822688206592">РђЈОюОљ ОаОъОдОљОћ ОеОЕОф. ОЎОЕ ОюОћОЏОаОЎОА ОљОф ОЏОеОўОЎОА Оћ-SIM ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="6080689532560039067">ОЎОЕ ОюОЉОЊОЋОД ОљОф ОЕОбОф ОћОъОбОеОЏОф</translation>
<translation id="6082877069782862752">ОъОЎОцОЋОЎ ОъОцОфОЌОЋОф</translation>
<translation id="608531959444400877"><ph name="WINDOW_TITLE" /> РђЊ ОЌОюОД ОъОДОЉОЋОдОћ ОюОюОљ ОЕОЮ</translation>
<translation id="6085886413119427067">ОДОЉОЎОбОф ОљОЋОцОЪ ОћОћОфОЌОЉОеОЋОф ОюОљОфОеОЎОЮ ОЉОљОъОдОбОЋОф ОДОЎОЕОЋОе ОъОљОЋОЉОўОЌ</translation>
<translation id="6086004606538989567">ОюОЌОЕОЉОЋОЪ ОћОъОљОЋОъОф ОљОЎОЪ ОћОеОЕОљОф ОњОЎОЕОћ ОюОъОЏОЕОЎОе.</translation>
<translation id="6086846494333236931">ОћОЋОфОДОЪ ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ</translation>
<translation id="6087746524533454243">ОеОЋОдОћ ОюОљОфОе ОљОф ОЊОБ ОћОъОЎОЊОб ОбОю ОћОЊОцОЊОцОЪ? ОЎОЕ ОюОбОЉОЋОе ОюОЏОфОЋОЉОф</translation>
<translation id="6087960857463881712">ОцОеОдОЋОБ "ОљОЊОЎОе!"</translation>
<translation id="608912389580139775">ОЏОЊОЎ ОюОћОЋОАОЎОБ ОљОф ОћОЊОБ ОћОќОћ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОАОъОю ОћОАОЎОъОаОЎОЎОћ</translation>
<translation id="6091761513005122595">ОћОфОДОЪ ОћОеОЕОф ОюОЕОЎОфОЋОБ ОДОЉОдОЎОЮ ОаОўОбОЪ ОЉОћОдОюОЌОћ.</translation>
<translation id="6093888419484831006">ОћОъОбОеОЏОф ОъОЉОўОюОф ОљОф ОћОбОЊОЏОЋОЪ...</translation>
<translation id="6095541101974653012">ОаОЋОфОДОф ОъОћОЌОЕОЉОЋОЪ.</translation>
<translation id="6095984072944024315">Рѕњ</translation>
<translation id="6096047740730590436">ОцОфОЎОЌОћ ОЉОњОЋОЊОю ОъОеОЉОЎ</translation>
<translation id="6096326118418049043">РђЈОЕОЮ X.500</translation>
<translation id="609662062217584106">РђЈОъОќОћОћ UPI</translation>
<translation id="6097480669505687979">ОљОЮ ОюОљ ОЎОфОцОаОћ ОЕОўОЌ, ОЎОЎОфОЏОЪ ОЕОъОЕОфОъОЕОЎОЮ ОЋОаОфОЋОаОЎОЮ ОЎОЋОАОеОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ.</translation>
