<translation id="2175927920773552910">РђЈОДОЋОЊ QR</translation>
<translation id="2177950615300672361">ОЏОеОўОЎОАОЎОЎОћ ОљОаОЋОаОЎОъОЎОф: <ph name="TAB_NAME" /></translation>
<translation id="2178585470774851578">РђЈОцОбОЋОюОћ ОќОЋ ОъОљОцОЕОеОф ОцОбОЎОюОЋОф ОЕОю ОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОъОбОеОЏОф ОћОћОцОбОюОћ ОЕОю ChromeOS Flex ОЕОЎОњОЊОЎОеОЋ sshd daemon ОЋОЎОљОцОЕОеОЋ ОљОфОЌОЋОю ОъОЏОЋОаОаОЎ USB.</translation>
<translation id="2178614541317717477">РђЈОеОЕОЋОф ОћОљОЎОЕОЋОеОЎОЮ (CA) ОЉОАОЏОаОћ</translation>
<translation id="2179416702468739594">ОъОфОЉОдОб ОЌОЎОцОЋОЕ ОЕОю ОцОеОЋОцОЎОюОЎОЮ ОќОъОЎОаОЎОЮ. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОњОеОЋОЮ ОюОаОЎОфОЋОД ОћОеОЕОф ОћОАОюОЋОюОеОЎОф ОюОъОЕОџ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="2180620921879609685">ОюОЌОАОЋОЮ ОфОЋОЏОЪ ОЉОЏОю ОЊОБ</translation>
<translation id="2182058453334755893">ОћОЋОбОфОД ОљОю ОћОюОЋОЌ</translation>
<translation id="2184515124301515068">РђЈChrome ОЎОДОЉОб ОъОфОЎ ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОцОбОЎОю ОдОюОЎОюОЎОЮ (ОъОЋОъОюОЦ)</translation>
<translation id="2186711480981247270">ОћОЊОБ ОЕОЋОфОБ ОъОъОЏОЕОЎОе ОљОЌОе</translation>
<translation id="2187675480456493911">ОЉОЋОдОб ОАОаОЏОеОЋОЪ ОбОЮ ОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ. ОћОњОЊОеОЋОф ОЕОЕОЋОаОЋ ОбОю-ОЎОЊОЎ ОъОЕОфОъОЕОЎОЮ ОљОЌОеОЎОЮ ОюОљ ОЎОАОЋОаОЏОеОаОЋ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="2187895286714876935">ОЕОњОЎОљОф ОЎОЎОЉОЋОљ ОЕОю ОљОЎОЕОЋОе ОЕОеОф</translation>
<translation id="2187906491731510095">ОћОфОЋОАОцОЎОЮ ОбОЋОЊОЏОаОЋ</translation>
<translation id="2188881192257509750">ОцОфОЎОЌОф <ph name="APPLICATION" /></translation>
<translation id="2189787291884708275">ОЕОЎОфОЋОБ ОћОљОЋОЊОЎОЋ ОъОћОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="2190069059097339078">РђЈОъОљОЌОќОе ОцОеОўОЎ ОЏОаОЎОАОћ Ою-Wi-Fi</translation>
<translation id="219008588003277019">РђЈNative Client ОъОЋОЊОЋОю: <ph name="NEXE_NAME" /></translation>
<translation id="2190355936436201913">(ОеОЎОД)</translation>
<translation id="2191754378957563929">ОъОЋОцОбОюОф</translation>
<translation id="2192505247865591433">Оъ:</translation>
<translation id="2193365732679659387">ОћОњОЊОеОЋОф ОљОъОЋОЪ</translation>
<translation id="2194856509914051091">ОъОћ ОЏОЊОљОЎ ОюОДОЌОф ОЉОЌОЕОЉОЋОЪ</translation>
<translation id="2195331105963583686">ОљОцОЕОе ОЎОћОЎОћ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОћОќОћ ОњОЮ ОљОЌОе ОЏОџ, ОљОЉОю ОћОЋОљ ОюОљ ОЎОДОЉОю ОЎОЋОфОе ОбОЊОЏОЋОаОЎ ОфОЋОЏОаОћ ОЋОљОЉОўОЌОћ ОљОЋОўОЋОъОўОЎОЎОЮ</translation>
<translation id="2195729137168608510">ОћОњОаОф ОљОЎОъОЎОЎОю </translation>
<translation id="2198625180564913276">ОћОЋОАОцОф ОћОцОеОЋОцОЎОю ОъОфОЉОдОбОф. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="2199298570273670671">ОЕОњОЎОљОћ</translation>
<translation id="2200094388063410062">ОљОЎОъОЎОЎОю</translation>
<translation id="2200356397587687044">РђЈChrome ОдОеОЎОџ ОћОеОЕОљОћ ОЏОЊОЎ ОюОћОъОЕОЎОџ</translation>
<translation id="2203088913459920044">ОЕОЮ ОЎОЏОЋОю ОюОЏОюОЋОю ОљОЋОфОЎОЋОф, ОАОцОеОЋОф ОЋОфОЋОЋОЎОЮ ОъОЎОЋОЌОЊОЎОЮ</translation>
<translation id="220321590587754225">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОЌОЉОе. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="2204034823255629767">ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОЏОю ОъОћ ОЕОћОДОюОЊОф</translation>
<translation id="220858061631308971">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОќОћ ОЉ-"<ph name="DEVICE_NAME" />":</translation>
<translation id="2210462644007531147">ОљОЎ ОљОцОЕОе ОюОћОЕОюОЎОЮ ОљОф ОћОћОфОДОаОћ</translation>
<translation id="2212565012507486665">РђЈОљОЎОЕОЋОе ОДОЋОЉОдОЎ cookie</translation>
<translation id="2214018885812055163">ОфОЎОДОЎОЋОф ОъОЕОЋОфОцОЋОф</translation>
<translation id="2214884991347062907">ОАОЎОАОъОћ ОюОљ ОаОЏОЋОаОћ, ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="2214893006758804920">{LINE_COUNT,plural, =1{&lt;ОЕОЋОеОћ ОљОЌОф ОюОљ ОъОЋОдОњОф&gt;}two{&lt;<ph name="NUMBER_OF_LINES" /> ОЕОЋОеОЋОф ОюОљ ОъОЋОдОњОЋОф&gt;}many{&lt;<ph name="NUMBER_OF_LINES" /> ОЕОЋОеОЋОф ОюОљ ОъОЋОдОњОЋОф&gt;}other{&lt;<ph name="NUMBER_OF_LINES" /> ОЕОЋОеОЋОф ОюОљ ОъОЋОдОњОЋОф&gt;}}</translation>
<translation id="2218019600945559112">ОбОЏОЉОе ОЋОюОЋОЌ ОъОњОб</translation>
<translation id="2218320521449013367">РђЈОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОќОъОЪ ОЕ-Chrome ОћОАОЎОе ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф</translation>
<translation id="2218515861914035131">ОћОЊОЉОДОћ ОЏОўОДОАОў ОеОњОЎОю</translation>
<translation id="2219658597883514593">ОЌОќОеОћ ОбОю ОћОъОЊОеОЎОџ</translation>
<translation id="2220409419896228519">РђЈОћОЋОАОцОф ОАОЎОъОаОЎОЋОф ОюОљОцОюОЎОДОдОЎОЋОф ОћОъОЋОбОЊОцОЋОф ОЕОюОџ ОЉ-Google Apps</translation>
<translation id="2220529011494928058">ОЊОЎОЋОЋОЌ ОбОю ОЉОбОЎОћ</translation>
<translation id="2220572644011485463">ОДОЋОЊ ОљОЎОъОЋОф ОљОЋ ОАОЎОАОъОћ</translation>
<translation id="2221261048068091179"><ph name="FIRST_SWITCH" />, <ph name="SECOND_SWITCH" /></translation>
<translation id="222201875806112242">ОъОДОЋОе ОъОЊОЎОћ ОюОюОљ ОЕОЮ</translation>
<translation id="2224444042887712269">ОћОћОњОЊОеОћ ОћОќОЋ ОЕОЎОЎОЏОф Ою-<ph name="OWNER_EMAIL" />.</translation>
<translation id="222447520299472966">ОЎОЕ ОюОЉОЌОЋОе ОюОцОЌОЋОф ОљОюОЉОЋОЮ ОЕОю ОњОюОеОЎОЎОф ОљОЋОъОаОЋОф ОљОЌОЊ</translation>
<translation id="2224551243087462610">ОбОеОЎОЏОф ОЕОЮ ОћОфОЎОДОЎОЎОћ</translation>
<translation id="2225864335125757863">ОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОЌОЕОЉОЋОЪ, ОЎОЕ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОљОЋОф ОћОЉОљОЋОф ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ:</translation>
<translation id="2226449515541314767">РђЈОћОљОцОЕОеОЋОф ОюОЕОюОЋОў ОЕОюОЎОўОћ ОъОюОљОћ ОбОю ОъОЏОЕОЎОеОЎ MIDI ОаОЌОАОъОћ ОбОЉОЋОе ОљОфОе ОќОћ.</translation>
<translation id="2226826835915474236">ОДОЎОдОЋОеОЎ ОЊОеОџ ОюОљ ОцОбОЎОюОЎОЮ</translation>
<translation id="2226907662744526012">ОЉОЎОўОЋОю ОаОбОЎОюОћ ОљОЋОўОЋОъОўОЎ ОюОљОЌОе ОћОќОаОф ОДОЋОЊ ОћОљОЎОъОЋОф</translation>
<translation id="2227179592712503583">ОћОАОеОф ОћОћОдОбОћ</translation>
<translation id="2229161054156947610">ОаОЋОфОеОћ ОЎОЋОфОе ОъОЕОбОћ ОљОЌОф</translation>
<translation id="222931766245975952">ОћОДОЋОЉОЦ ОаОДОўОб</translation>
<translation id="2230005943220647148">ОдОюОќОЎОЋОА</translation>
<translation id="2231160360698766265">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОцОбОЎОю ОфОЋОЏОЪ ОъОЋОњОЪ</translation>
<translation id="2231238007119540260">ОљОЮ ОъОЋОЌОДОЎОЮ ОљОЎОЕОЋОе ОЕОеОф, ОъОЕОЌОќОеОЎОЮ ОљОф ОЉОЊОЎОДОЋОф ОћОљОЉОўОЌОћ ОћОеОњОЎОюОЋОф ОюОЕОеОф ОќОћ ОЋОЊОЋОеОЕОЎОЮ ОЕОћОЋОљ ОЎОЕОфОъОЕ ОЉОљОЎОЕОЋОе ОЌОЋОДОЎ.</translation>
<translation id="2232751457155581899">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОбОДОЋОЉ ОљОЌОе ОъОЎОДОЋОЮ ОћОъОдОюОъОћ</translation>
<translation id="2232876851878324699">ОћОДОЋОЉОЦ ОћОЏОЎОю ОљОЎОЕОЋОе ОљОЌОЊ, ОЕОюОљ ОЎОЋОЉОљ:</translation>
<translation id="2233502537820838181">&amp;ОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="223356358902285214">ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="2234827758954819389">ОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф</translation>
<translation id="2234876718134438132">РђЈОАОаОЏОеОЋОЪ ОЋОЕОЎОеОЋОфОЎ Google</translation>
<translation id="2235344399760031203">РђЈОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОЌОАОЋОъОЎОЮ</translation>
<translation id="2238379619048995541">ОаОфОЋОаОЎ ОъОдОЉ ОфОЊОЎОеОЋОф</translation>
<translation id="2241053333139545397">ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОъОАОцОе ОљОфОеОЎОЮ</translation>
<translation id="2241634353105152135">ОцОбОЮ ОљОЌОф ОЉОюОЉОЊ</translation>
<translation id="2242687258748107519">ОцОеОўОЎ ОДОЋОЉОЦ</translation>
<translation id="2246129643805925002">ОћОбОЊОЏОЋОаОЎОЮ ОЕОю <ph name="DEVICE_TYPE" /> ОЎОфОЉОдОбОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОеОДОб, ОЏОЊОЎ ОЕОаОЎОфОЪ ОЎОћОЎОћ ОюОЎОћОаОЋОф ОъОћОфОЏОЋОаОЋОф ОЋОъОЕОЎОцОЋОеОЎ ОћОљОЉОўОЌОћ ОћОљОЌОеОЋОаОЎОЮ. ОљОцОЕОе ОюОаОћОю ОљОф ОћОћОбОЊОцОЋОф ОюОњОЉОЎ ОбОЊОЏОЋОаОЎОЮ ОЉОћОњОЊОеОЋОф.</translation>
<translation id="2246549592927364792">РђЈОеОЋОдОћ ОюОДОЉОю ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф Оъ-Google?</translation>
<translation id="2247738527273549923">ОћОъОЏОЕОЎОе ОъОаОЋОћОю ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="2249111429176737533">ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ ОъОеОЋОЉОћ ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="2249605167705922988">ОюОъОЕОю 1-5, 8, 11-13</translation>
<translation id="2251218783371366160">ОцОфОЎОЌОћ ОЉОљОъОдОбОЋОф ОъОдОЎОњ ОћОъОбОеОЏОф</translation>
<translation id="225163402930830576">ОеОбОаОЋОЪ ОеОЕОфОЋОф</translation>
<translation id="2251809247798634662">ОЌОюОЋОЪ ОЌОЊОЕ ОюОњОюОЎОЕОћ ОЉОАОфОе</translation>
<translation id="225240747099314620">ОюОљОцОЕОе ОъОќОћОЎОЮ ОбОЉОЋОе ОфОЋОЏОЪ ОъОЋОњОЪ (ОЎОЎОфОЏОЪ ОЕОЎОћОЎОћ ОдОЋОеОџ ОюОљОфОЌОю ОљОф ОћОъОЌОЕОЉ)</translation>
<translation id="2255077166240162850">ОћОъОЏОЕОЎОе ОћОќОћ ОаОаОбОю ОюОдОЋОеОџ ОЕОЎОъОЋОЕ ОЉОЊОЋОъОЎОЎОЪ ОљОЋ ОЉОъОдОЉ ОЕОЋОаОћ.</translation>
<translation id="2255317897038918278">РђЈОћОўОЉОбОф ОЌОЋОфОъОф ОќОъОЪ ОЕОю Microsoft</translation>
<translation id="2256115617011615191">ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОЏОбОф</translation>
<translation id="2257053455312861282">ОћОЋОАОцОф ОЌОЕОЉОЋОЪ ОЉОЎОф ОАОцОеОЎ ОъОљОцОЕОеОф ОюОфОюОъОЎОЊ ОљОЋ ОюОфОюОъОЎОЊОћ ОюОћОЎОЏОаОА ОЉОаОЋОЌОЋОф ОюОљОфОеОЎОЮ, ОюОфОЋОАОцОЎОЮ ОЋОюОљОцОюОЎОДОдОЎОЋОф, ОЋОбОЊОЎОЎОЪ ОюОцОбОЋОю ОЉОъОАОњОеОф ОћОъОњОЉОюОЋОф ОЕОю ОЉОДОеОф ОћОћОЋОеОЎОЮ.</translation>
<translation id="2261323523305321874">ОъОаОћОю ОћОъОбОеОЏОф ОЉОЎОдОб ОЕОЎОаОЋОЎ ОЏОюОюОЎ ОЉОъОбОеОЏОф ОЕОъОЕОЉОЎОф ОЌОюОД ОъОћОцОеОЋОцОЎОюОЎОЮ ОћОЎОЕОаОЎОЮ.</translation>
<translation id="2262477216570151239">ОћОЕОћОЎОћ ОюОцОаОЎ ОЌОќОеОћ</translation>
<translation id="2263189956353037928">ОбОюОЎОџ ОюОдОљОф ОЋОюОћОЎОЏОаОА ОЕОЋОЉ</translation>
<translation id="2263371730707937087">ОДОдОЉ ОћОеОбОаОЋОЪ ОЕОю ОћОъОАОџ</translation>
<translation id="2263679799334060788">РђЈОфОЋОЊОћ ОбОю ОћОъОЕОЋОЉ ОЕОюОџ, ОЕОбОЋОќОе ОюОаОЋ ОюОЕОцОе ОљОф Google Cast.
    ОюОДОЉОюОф ОбОќОеОћ ОЉОцОфОеОЋОЪ ОЕОю ОЉОбОЎОЋОф ОћОбОЉОеОћ, ОаОЎОфОЪ ОюОбОЎОЎОЪ
    <ph name="BEGIN_LINK" />
    ОЉОъОеОЏОќ ОћОбОќОеОћ<ph name="END_LINK" />.</translation>
<translation id="22665427234727190">РђЈОдОеОЎОџ ОюОЉОДОЕ ОъОъОаОЎ ОљОЎОЕОЋОе ОЏОЕОљОфОе ОеОЋОдОћ ОюОњОЕОф ОюОъОЏОЕОЎОеОЎ Bluetooth (ОъОЋОъОюОЦ)</translation>
<translation id="2266957463645820432">РђЈIPP ОЉОЌОЎОЉОЋОе USB РђЈ(IPPUSB)</translation>
<translation id="2268130516524549846">РђЈBluetooth ОъОЋОЕОЉОф</translation>
<translation id="2270450558902169558">ОћОЌОюОцОф ОаОфОЋОаОЎОЮ ОбОЮ ОЏОю ОъОЏОЕОЎОе ОЉОЊОЋОъОЎОЎОЪ <ph name="DOMAIN" /></translation>
<translation id="2270612886833477697"><ph name="BEGIN_PARAGRAPH1" />ОћОћОфОДОаОћ <ph name="BEGIN_BOLD" />ОфОЋОЉОЎОю ОюОъОЌОЎОДОћ ОЕОю ОЏОю ОћОЏОЋОаОЪ ОћОДОЕОЎОЌ<ph name="END_BOLD" />. ОЌОЕОЋОЉ ОюОћОДОцОЎОЊ ОбОю ОњОЎОЉОЋОЎ ОћОаОфОЋОаОЎОЮ ОЕОюОџ.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОљОЎОЪ ОљОцОЕОеОЋОф ОюОЉОўОю ОљОф ОћОћОфОДОаОћ ОюОљОЌОе ОЕОћОЌОюОћ.<ph name="END_PARAGRAPH2" /></translation>
