<translation id="1143816224540441191">{NUM_MINS,plural, =1{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ ОЊОДОћ ОљОЌОф}two{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ {NUM_MINS} ОЊОДОЋОф}many{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ {NUM_MINS} ОЊОДОЋОф}other{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ {NUM_MINS} ОЊОДОЋОф}}</translation>
<translation id="1145593918056169051">ОћОъОЊОцОАОф ОћОцОАОЎОДОћ ОюОцОбОЋОю</translation>
