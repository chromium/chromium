<translation id="7668002322287525834">{NUM_WEEKS,plural, =1{ОЎОЕ ОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЉОфОЋОџ ОЕОЉОЋОб ({NUM_WEEKS})}two{ОЎОЕ ОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЉОфОЋОџ ОЕОЉОЋОбОЎОЎОЮ ({NUM_WEEKS})}many{ОЎОЕ ОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_WEEKS} ОЕОЉОЋОбОЋОф}other{ОЎОЕ ОюОћОЌОќОЎОе ОљОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_WEEKS} ОЕОЉОЋОбОЋОф}}</translation>
<translation id="7668423670802040666">РђЈОЕОъОЋОеОћ ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОЉОЌОЕОЉОЋОЪ <ph name="ACCOUNT" /></translation>
<translation id="7669825497510425694">{NUM_ATTEMPTS,plural, =1{ОДОЋОЊ ОљОЎОъОЋОф ОЕОњОЋОЎ. ОаОЕОљОе ОюОџ ОаОЎОАОЎОЋОЪ ОљОЌОЊ.}two{ОДОЋОЊ ОљОЎОъОЋОф ОЕОњОЋОЎ. ОаОЕОљОеОЋ ОюОџ # ОаОЎОАОЎОЋОаОЋОф.}many{ОДОЋОЊ ОљОЎОъОЋОф ОЕОњОЋОЎ. ОаОЕОљОеОЋ ОюОџ # ОаОЎОАОЎОЋОаОЋОф.}other{ОДОЋОЊ ОљОЎОъОЋОф ОЕОњОЋОЎ. ОаОЕОљОеОЋ ОюОџ # ОаОЎОАОЎОЋОаОЋОф.}}</translation>
<translation id="7670434942695515800">РђЈОюОДОЉОюОф ОћОЉОЎОдОЋОбОЎОЮ ОћОъОЎОўОЉОЎОЎОЮ ОЏОЊОљОЎ ОюОЕОЊОеОњ ОюОњОеОАОћ ОћОљОЌОеОЋОаОћ. ОъОЋОъОюОЦ ОюОњОЉОЋОф ОљОф ОћОДОЉОдОЎОЮ ОюОъОДОеОћ ОЕОюОљ ОфОћОЎОћ ОљОцОЕОеОЋОф ОюОћОЕОюОЎОЮ ОљОф ОћОЕОЊОеОЋОњ. ОљОЌОеОЎ ОЕОћОЕОЊОеОЋОњ ОЎОфОЌОЎОю, ОЎОфОЉОдОб ОЏОЎОЉОЋОЎ ОЕОю Linux. ОЌОЕОЋОЉ ОюОЕОъОЋОе ОљОф ОћОДОЉОдОЎОЮ ОћОцОфОЋОЌОЎОЮ ОюОцОаОЎ ОЕОъОъОЕОЎОЏОЎОЮ. <ph name="LINK_START" />ОюОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="7671130400130574146">ОЕОЎОъОЋОЕ ОЉОњОЉОЋОюОЋОф ОЋОЉОЕОЋОеОф ОћОЏОЋОфОеОф ОЕОю ОћОъОбОеОЏОф</translation>
<translation id="767127784612208024">ОаОњОЎОбОћ ОюОдОЋОеОџ ОљОЎОЕОЋОе ОћОљОфОЌОЋОю</translation>
<translation id="7672520070349703697"><ph name="HUNG_IFRAME_URL" />, ОЉ-<ph name="PAGE_TITLE" />.</translation>
<translation id="7674416868315480713">РђЈОћОЕОЉОфОћ ОЕОю ОЏОю ОћОЎОдОЎОљОЋОф ОЕОъОЋОњОЊОеОф ОюОњОЉОЎОћОЪ ОћОбОЉОеОћ ОЉ-Linux</translation>
<translation id="7674537509496907005"><ph name="APP_COUNT" /> ОљОцОюОЎОДОдОЎОЋОф</translation>
