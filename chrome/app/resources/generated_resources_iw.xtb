<translation id="3449839693241009168">ОЎОЕ ОюОюОЌОЋОЦ ОбОю <ph name="SEARCH_KEY" /> ОЏОЊОЎ ОюОЕОюОЋОЌ ОцОДОЋОЊОЋОф ОљОю <ph name="EXTENSION_NAME" /></translation>
<translation id="3450157232394774192">ОљОЌОЋОќ ОфОцОЋОАОћ ОЉОъОдОЉ ОюОљ ОцОбОЎОю</translation>
<translation id="3450180775417907283">РђЈОЏОЊОЎ ОюОћОЎОЏОаОА ОљОю <ph name="MANAGER" />, ОъОфОЌОЉОеОЎОЮ ОбОЏОЕОЎОЋ ОюОеОЕОф Wi-Fi ОЋОъОЋОеОЎОЊОЎОЮ ОбОЊОЏОЋОЪ.</translation>
<translation id="3452999110156026232">ОњОЎОЕОћ ОЕОю ОћОЋОеОћ</translation>
<translation id="3453612417627951340">ОЎОЕ ОдОЋОеОџ ОЉОљОЎОЕОЋОе</translation>
<translation id="3454213325559396544">ОќОћОЋ ОћОбОЊОЏОЋОЪ ОћОљОЋОўОЋОъОўОЎ ОћОљОЌОеОЋОЪ ОЕОю ОћОфОЋОЏОаОћ ОЋОћОљОЉОўОЌОћ ОбОЉОЋОе ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОћОќОћ. ОЏОЊОЎ ОюОДОЉОю ОбОЊОЏОЋОаОЎОЮ ОбОфОЎОЊОЎОЎОЮ, ОЎОЕ ОюОЕОЊОеОњ ОюОЊОњОЮ ОЌОЊОЕ ОЎОЋОфОе.</translation>
<translation id="3455436146814891176">ОАОаОЏОеОЋОЪ ОАОЎОАОъОф ОћОдОцОаОћ</translation>
<translation id="345693547134384690">ОцОфОЎОЌОф &amp;ОфОъОЋОаОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="3458451003193188688">ОбОДОЉ ОЕОњОЎОљОф ОеОЕОф, ОюОљ ОаОЎОфОЪ ОюОћОфОДОЎОЪ ОљОф ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ ОљОЋ ОюОЎОдОЋОе ОДОЕОе ОбОЮ ОъОаОћОю ОћОъОбОеОЏОф. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="3458794975359644386">ОЉОЎОўОЋОю ОћОЕОЎОфОЋОБ ОаОЏОЕОю</translation>
<translation id="3459509316159669723">ОћОЊОцОАОћ</translation>
<translation id="3459697287128633276">РђЈОЏОЊОЎ ОюОљОцОЕОе ОюОЌОЕОЉОЋОаОџ ОюОњОЕОф ОљОю ОЌОаОЋОф Google Play, ОбОюОЎОџ ОюОЉОдОб ОљОЎОъОЋОф ОљОдОю ОАОцОД ОћОќОћОЋОф ОЕОюОџ.</translation>
<translation id="3461766685318630278">ОЏОљОЪ ОЎОЕ ОљОцОЕОеОЋОф ОюОЎОдОЋОе ОЋОюОъОЌОЋОД ОДОЋОаОўОЎОЎОаОеОЎОЮ ОаОЋОАОцОЎОЮ.</translation>
<translation id="3462311546193741693">РђЈОћОцОбОЋОюОћ ОћОќОЋ ОфОЋОдОЎОљ ОљОЋОфОџ ОъОеОЋОЉ ОћОљОфОеОЎОЮ ОљОџ ОюОљ ОъОЌОЕОЉОЋОЪ Google, ОЏОЊОЎ ОЕОаОЎОфОЪ ОЎОћОЎОћ ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ.</translation>
<translation id="3462413494201477527">ОћОљОЮ ОюОЉОўОю ОљОф ОћОњОЊОеОф ОћОЌОЕОЉОЋОЪ?</translation>
<translation id="346298925039590474">ОћОеОЕОф ОћОАОюОЋОюОеОЎОф ОћОќОЋ ОфОћОЎОћ ОќОъОЎОаОћ ОюОЏОю ОћОъОЕОфОъОЕОЎОЮ ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="3463015289462934089">ОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОћОъОЏОЕОЎОе ОЕОюОџ ОъОЌОЋОЉОе ОюОљОЎОаОўОеОаОў.</translation>
<translation id="3464145797867108663">ОћОЋОАОцОф ОцОеОЋОцОЎОю ОбОЉОЋОЊОћ</translation>
<translation id="346431825526753">ОќОћОЋ ОЌОЕОЉОЋОЪ ОюОЎОюОЊОЎОЮ, ОћОъОаОЋОћОю ОбОю-ОЎОЊОЎ <ph name="CUSTODIAN_EMAIL" />.</translation>
<translation id="346546413339447252">ОДОЉОюОф ОћОаОЌОЋОф ОбОю ОћОъОЋОдОеОЎОЮ ОЕОю <ph name="MERCHANT_NAME_1" />, РђЈ<ph name="MERCHANT_NAME_2" /> ОЋОбОЋОЊ</translation>
<translation id="3468298837301810372">ОфОЋОЋОЎОф</translation>
<translation id="3468999815377931311">РђЈОўОюОцОЋОЪ Android</translation>
<translation id="3469583217479686109">ОЏОюОЎ ОћОЉОЌОЎОеОћ</translation>
<translation id="3470392222765168737">ОъОбОДОЉ ОљОЌОе ОћОљОфОе</translation>
<translation id="3471876058939596279">РђЈОљОЎ ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОЋ-ОќОъОаОЎОф ОЉОЎОдОЎОљОЋОф HDMI ОЋ-USB C ОюОЋОЋОЎОЊОљОЋ. ОбОюОЎОџ ОюОЉОЌОЋОе ОЎОдОЎОљОф ОЋОЎОЊОљОЋ ОљОЌОеОф.</translation>
<translation id="3473241910002674503">ОЉОъОдОЉ ОўОљОЉОюОў ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОюОЌОдОаОЎОЮ ОЏОЊОЎ ОюОбОЉОЋОе ОљОю ОЊОБ ОћОЉОЎОф, ОюОЌОќОЋОе ОюОЊОБ ОћОДОЋОЊОЮ ОЋОюОбОЉОЋОе ОЉОЎОЪ ОљОцОюОЎОДОдОЎОЋОф.</translation>
<translation id="3473479545200714844">ОъОњОЊОЎОю ОћОфОдОЋОњОћ</translation>
<translation id="3474218480460386727">ОЎОЕ ОюОЏОфОЋОЉ ОъОЎОюОЎОЮ ОЌОЊОЕОЋОф ОбОЮ 99 ОљОЋОфОЎОЋОф ОљОЋ ОцОЌОЋОф</translation>
<translation id="3474624961160222204">ОћОъОЕОџ ОЏ-<ph name="NAME" /></translation>
<translation id="3475843873335999118">ОћОъОбОеОЏОф ОбОЊОЎОЎОЪ ОюОљ ОъОќОћОћ ОљОф ОўОЉОЎОбОф ОћОљОдОЉОб. ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ.</translation>
<translation id="3476303763173086583">РђЈОЕОюОЎОЌОћ ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОбОю ОћОЕОЎОъОЋОЕ. ОљОцОЕОе ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОћОЌОЋОЋОЎОћ ОЕОю ОћОЎОюОЊ/Оћ ОЕОюОџ ОЉ-Android. ОюОЕОЮ ОЏОџ ОЎОЕ ОюОЕОюОЋОЌ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОЋОЉОљОцОюОЎОДОдОЎОЋОф. ОаОфОЋОаОЎОЮ ОљОюОћ ОюОљ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОќОћОЋОф ОљОф ОћОЎОюОЊ/Оћ ОЕОюОџ, ОЋОћОЮ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОЎОдОЎОЉОЋОф ОћОъОбОеОЏОф ОЋОћОљОцОюОЎОДОдОЎОЋОф, ОЏОъОЋ ОњОЮ ОюОЉОЎОдОЋОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎ Android. Оћ<ph name="BEGIN_LINK1" />ОћОњОЊОеОћ<ph name="END_LINK1" /> ОћОќОЋ ОаОљОЏОцОф ОбОю-ОЎОЊОЎ ОћОЉОбОюОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОЉОбОюОЎОЮ ОЎОЉОЌОеОЋ ОюОЕОюОЋОЌ ОљОю Google ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОћОќОћ. ОљОЮ ОћОЋОцОбОюОћ ОЉОЕОЉОЎОю ОћОЎОюОЊ/Оћ ОЕОюОџ ОћОљОцОЕОеОЋОф 'ОцОбОЎОюОЋОф ОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОЋ/Оћ. <ph name="BEGIN_LINK2" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK2" /></translation>
<translation id="347670947055184738">ОљОЋОцОА! ОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОЕОюОЋОБ ОъОЊОЎОаОЎОЋОф ОюОъОЏОЕОЎОе ОЕОюОџ.</translation>
<translation id="347785443197175480">ОљОаОЎ ОеОЋОдОћ ОюОћОъОЕОЎОџ ОюОљОцОЕОе Ою-<ph name="HOST" /> ОюОњОЕОф ОюОъОдОюОъОћ ОЋОюОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="3479552764303398839">ОюОљ ОбОЏОЕОЎОЋ</translation>
<translation id="3479685872808224578">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОЌОЉОе ОљОю ОЕОеОф ОћОћОЊОцОАОћ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЏОфОЋОЉОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3480612136143976912">ОаОЎОфОЪ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОњОЋОЊОю ОЋОћОАОњОаОЋОЪ ОЕОю ОћОЏОфОЋОЉОЎОЋОф ОћОъОЎОЎОЊОЎОЋОф. ОћОћОњОЊОеОћ ОћОќОЋ ОфОЌОЋОю ОњОЮ ОбОю ОљОцОюОЎОДОдОЎОЋОф ОЋОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ.</translation>
<translation id="3480827850068960424">ОаОъОдОљОЋ <ph name="NUM" /> ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="3481268647794498892">ОЎОЎОцОфОЌ ОЉ-<ph name="ALTERNATIVE_BROWSER_NAME" /> ОЉОбОЋОЊ <ph name="COUNTDOWN_SECONDS" /> ОЕОаОЎОЋОф</translation>
<translation id="3482719661246593752">Ою-<ph name="ORIGIN" /> ОЎОЕ ОљОцОЕОеОЋОф ОюОеОљОЋОф ОљОф ОћОДОЉОдОЎОЮ ОћОЉОљОЎОЮ</translation>
<translation id="3484273680291419129">ОћОАОеОф ОфОЋОЏОаОћ ОъОќОЎОДОћ ОъОфОЉОдОбОф...</translation>
<translation id="3484869148456018791">ОДОЉОюОф ОљОЎОЕОЋОе ОЌОЊОЕ</translation>
<translation id="3487007233252413104">ОцОЋОаОДОдОЎОћ ОљОаОЋОаОЎОъОЎОф</translation>
<translation id="3490695139702884919">РђЈОъОфОЉОдОбОф ОћОЋОеОЊОћРђд Рђј<ph name="PERCENT" />%Рђј</translation>
<translation id="3491669675709357988">РђЈОЉОЌОЕОЉОЋОЪ ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ ОюОљ ОъОЋОњОЊОеОф ОЉОДОеОф ОћОЋОеОЎОЮ ОЕОю Family Link. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЋОАОЎОБ ОЉОДОеОф ОћОЋОеОЎОЮ ОюОљОЌОе ОАОЎОЋОЮ ОћОћОњОЊОеОћ. ОЉОљОцОюОЎОДОдОЎОћ 'ОъОћ ОЌОЊОЕ ОЉ-Chromebook' ОъОцОЋОеОў ОъОЎОЊОб ОаОЋОАОБ ОбОю ОЉОДОеОф ОћОЋОеОЎОЮ.</translation>
<translation id="3491678231052507920">РђЈОљОфОеОЎОЮ ОъОЕОфОъОЕОЎОЮ ОЉОЊОеОџ ОЏОюОю ОЉОаОфОЋОаОЎОЮ ОЋОЉОъОЏОЕОЎОеОЎОЮ ОЕОю ОъОдОЎОљОЋОф ОъОЊОЋОъОћ ОЏОЊОЎ ОюОљОцОЕОе ОЏОаОЎОАОћ ОюОцОбОЎОюОЋОЎОЋОф VR</translation>
<translation id="3493486281776271508">ОЊОеОЋОЕ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="3493881266323043047">ОфОЋОДОБ</translation>
<translation id="3494769164076977169">ОЎОЕ ОюОЕОљОЋОю ОЏОЕОљОфОе ОъОаОАОћ ОюОћОЋОеОЎОЊ ОДОЉОдОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОюОљОЌОе ОћОДОЋОЉОЦ ОћОеОљОЕОЋОЪ (ОъОЋОъОюОЦ)</translation>
<translation id="3495496470825196617">ОъОбОЉОе ОюОъОдОЉ ОЕОЎОаОћ ОЉОќОъОЪ ОўОбОЎОаОћ</translation>
<translation id="3495660573538963482">РђЈОћОћОњОЊОеОЋОф ОЕОю Google Assistant</translation>
<translation id="3496213124478423963">ОћОфОеОЌОДОЋОф ОъОфОдОЋОњОћ</translation>
<translation id="3496238553815913323"><ph name="LANGUAGE" /> (ОюОљ ОаОЉОЌОеОћ)</translation>
<translation id="3496689104192986836">ОеОъОф ОћОўОбОЎОаОћ ОЕОю ОћОАОЋОюОюОћ: <ph name="PERCENTAGE" />%</translation>
<translation id="3497501929010263034">РђЈОћОфОДОЪ USB Оъ-<ph name="VENDOR_NAME" /> (ОъОЋОдОе <ph name="PRODUCT_ID" />)</translation>
<translation id="3497560059572256875">ОЕОЎОфОЋОБ ОћОЊОЋОЊОю</translation>
<translation id="3498215018399854026">ОюОљ ОћОдОюОЌОаОЋ ОюОЎОдОЋОе ОДОЕОе ОбОЮ ОћОћОЋОеОћ ОЕОюОџ. ОаОАОћ ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="3500417806337761827">РђЈОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОўОбОЎОаОф ОћОЕОЎОфОЋОБ. ОЏОЉОе ОаОўОбОаОЋ ОЎОЋОфОе ОъОЊОЎ ОЕОЎОфОЋОцОЎ SMB.</translation>
<translation id="3503995387997205657">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЕОЌОќОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОћОДОЋОЊОъОЋОф ОЕОЉОћОЪ ОћОЕОфОъОЕОф</translation>
<translation id="3505030558724226696">ОЉОЎОўОЋОю ОњОЎОЕОћ ОюОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="3505100368357440862">ОћОдОбОЋОф ОюОДОаОЎОЋОф</translation>
<translation id="3507132249039706973">ОъОЋОцОбОюОф ОћОњОаОћ ОеОњОЎОюОћ</translation>
<translation id="3507421388498836150">ОћОеОЕОљОЋОф ОаОЋОЏОЌОЎОЋОф ОЕОю "<ph name="EXTENSION_NAME" />"</translation>
<translation id="3507888235492474624">РђЈОАОеОЎОДОћ ОЌОЋОќОеОф ОюОљОЎОфОЋОе ОъОЏОЕОЎОеОЎ Bluetooth</translation>
<translation id="3508492320654304609">ОюОљ ОаОЎОфОЪ ОюОъОЌОЋОД ОљОф ОцОеОўОЎ ОћОЏОаОЎОАОћ ОЕОюОџ</translation>
<translation id="3508920295779105875">ОЎОЕ ОюОЉОЌОЋОе ОфОЎОДОЎОЎОћ ОљОЌОеОф...</translation>
<translation id="3509379002674019679">ОаОЎОфОЪ ОюОЎОдОЋОе, ОюОаОћОю ОЋОюОЕОъОЋОе ОАОЎОАОъОљОЋОф ОЏОЊОЎ ОюОћОЎОЏОаОА ОЉОДОюОЋОф ОюОљОфОеОЎОЮ ОЋОюОљОцОюОЎОДОдОЎОЋОф.</translation>
<translation id="3511200754045804813">ОАОеОЎОДОћ ОъОЌОЊОЕ</translation>
<translation id="3511307672085573050">ОћОбОфОДОф ОЏОфОЋОЉ&amp;Оф ОДОЎОЕОЋОе</translation>
<translation id="351152300840026870">ОњОЋОцОЪ ОЉОеОЋОЌОЉ ОДОЉОЋОб</translation>
<translation id="3511528412952710609">ОДОдОеОћ</translation>
<translation id="3514335087372914653">ОЉОДОеОф ОъОЕОЌОДОЎОЮ</translation>
<translation id="3514373592552233661">ОЏОЕОЎОЕ ОЎОЋОфОе ОъОеОЕОф ОќОъОЎОаОћ ОљОЌОф, ОћОеОЕОфОЋОф ОћОъОЋОбОЊОцОЋОф ОЎОДОЉОюОЋ ОбОЊОЎОцОЋОф ОбОю ОцОаОЎ ОеОЕОфОЋОф ОъОЋОЏОеОЋОф ОљОЌОеОЋОф</translation>
<translation id="3515983984924808886">ОЎОЕ ОюОњОбОф ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОцОбОЮ ОаОЋОАОцОф ОЏОЊОЎ ОюОљОЕОе ОљОф ОћОљОЎОцОЋОА. ОЏОю ОћОъОЎОЊОб ОЕОъОљОЋОЌОАОЪ ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОЎОЎОъОЌОД, ОЏОЋОюОю ОДОЋОЊ ОћОљОЎОъОЋОф.</translation>
<translation id="3518985090088779359">ОЉОАОЊОе, ОъОДОЋОЉОю ОбОюОЎОЎ</translation>
<translation id="3519564332031442870">ОЕОЎОеОЋОф ОюОДОдОћ ОћОбОЋОеОцОЎ ОЕОю ОћОъОЊОцОАОф</translation>
<translation id="3519938335881974273">ОЕОъОЎОеОф ОћОЊОБ ОЉОЕОЮРђд</translation>
<translation id="3520824492621090923">ОюОљОЕОе ОљОф ОћОеОЎОЕОЋОЮ ОЕОю ОъОЏОЕОЎОе ОћОЕОЎОюОЋОў ОЋОћОДОЎОЋОАОД?</translation>
<translation id="3521606918211282604">ОЕОЎОаОЋОЎ ОњОЋОЊОю ОћОЏОЋОаОЪ</translation>
<translation id="3522088408596898827">ОаОцОЌ ОћОљОЌОАОЋОЪ ОЏОъОбОў ОаОњОъОе. ОЎОЕ ОюОцОаОЋОф ОъОДОЋОЮ ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3524518036046613664">ОњОЎОюОЋОЎ ОъОЏОЕОЎОеОЎОЮ, ОЏОъОЋ ОъОЊОцОАОЋОф, ОЉОеОЕОф ОћОъОДОЋОъОЎОф</translation>
<translation id="3524965460886318643">ОЎОЎОдОЋОљ ОћОцОбОЎОюОЋОЎОЋОф</translation>
<translation id="3525426269008462093">ОЉОЊОЎОДОћ ОЕОю ОАОаОЏОеОЋОЪ ОћОъОЏОЕОЎОеОЎОЮ ОюОљОЌОе ОћОћОњОЊОеОћ</translation>
<translation id="3526034519184079374">ОљОЎ ОљОцОЕОе ОюОДОеОЋОљ ОљОф ОаОфОЋОаОЎ ОћОљОфОе ОљОЋ ОюОЕОаОЋОф ОљОЋОфОЮ</translation>
<translation id="3527085408025491307">ОфОЎОДОЎОЎОћ</translation>
<translation id="3528498924003805721">ОЎОбОЊОЎОЮ ОЕОю ОДОЎОдОЋОеОЎ ОЊОеОџ</translation>
<translation id="3532273508346491126">ОаОЎОћОЋОю ОАОаОЏОеОЋОЪ</translation>
<translation id="3532521178906420528">ОъОфОЉОдОб ОЌОЎОЉОЋОе ОюОеОЕОф...</translation>
<translation id="353316712352074340"><ph name="WINDOW_TITLE" /> - ОћОљОЋОЊОЎОЋ ОћОЋОЕОфОД</translation>
<translation id="3537881477201137177">ОаОЎОфОЪ ОюОЕОаОЋОф ОќОљОф ОъОљОЋОЌОе ОЎОЋОфОе ОЉ'ОћОњОЊОеОЋОф'</translation>
<translation id="3538066758857505094">РђЈОДОеОфОћ ОЕОњОЎОљОћ ОЉОћОАОеОф ОћОћОфОДОаОћ ОЕОю Linux. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="354060433403403521">РђЈОъОфОљОЮ AC</translation>
<translation id="354068948465830244">ОћОфОЋОАОБ ОЎОЏОЋОю ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОаОфОЋОаОЎ ОљОфОеОЎОЮ</translation>
<translation id="3541823293333232175">ОЉОЋОдОбОћ ОћОДОдОљОћ</translation>
<translation id="3543393733900874979">ОћОбОЊОЏОЋОЪ ОаОЏОЕОю (ОЕОњОЎОљОћ: <ph name="ERROR_NUMBER" />)</translation>
<translation id="3543597750097719865">РђЈОЌОфОЎОъОф X9.62 ECDSA ОбОЮ SHA-512</translation>
<translation id="3544879808695557954">ОЕОЮ ОъОЕОфОъОЕ (ОљОЋОцОдОЎОЋОаОюОЎ)</translation>
<translation id="354602065659584722">ОфОЋОЏОаОћ ОъОќОЎОДОћ ОћОЋОАОеОћ</translation>
<translation id="3547954654003013442">РђЈОћОњОЊОеОЋОф Proxy</translation>
<translation id="3548162552723420559">ОъОфОљОЎОЮ ОљОф ОдОЉОб ОћОъОАОџ ОюОАОЉОЎОЉОћ</translation>
<translation id="3550593477037018652">ОћОфОаОфОДОЋОф ОъОћОеОЕОф ОћОАОюОЋОюОеОЎОф</translation>
<translation id="3550915441744863158">РђЈChrome ОъОфОбОЊОЏОЪ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЏОџ ОЕОфОъОЎОЊ ОъОЕОфОъОЕОЎОЮ ОЉОњОеОАОћ ОћОбОЊОЏОаОЎОф ОЉОЎОЋОфОе</translation>
<translation id="3551320343578183772">ОАОњОЎОеОф ОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="3552097563855472344"><ph name="NETWORK_NAME" /> РђЊ <ph name="SPAN_START" /><ph name="CARRIER_NAME" /><ph name="SPAN_END" /></translation>
<translation id="3552780134252864554">ОъОаОЋОДОћ ОЉОбОф ОћОЎОдОЎОљОћ</translation>
<translation id="3554493885489666172">ОћОъОЏОЕОЎОе ОЕОюОџ ОъОаОЋОћОю ОбОю-ОЎОЊОЎ <ph name="PROFILE_NAME" />. ОюОъОаОћОюОЎ ОћОъОбОеОЏОф ОЎОЕ ОњОЎОЕОћ ОюОаОфОЋОаОЎОЮ ОЕОю ОЏОю ОцОеОЋОцОЎОю ОЉОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="3555812735919707620">ОћОАОеОф ОфОЋОАОБ</translation>
<translation id="3556000484321257665">ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОћОЕОфОаОћ Ою-<ph name="URL" />.</translation>
<translation id="3556433843310711081">ОћОъОаОћОю ОЕОюОџ ОЎОЏОЋОю ОюОЉОўОю ОЉОЕОЉОЎОюОџ ОљОф ОћОЌОАОЎОъОћ</translation>
<translation id="3557101512409028104">РђЈОћОњОЊОеОћ ОЕОю ОћОњОЉОюОЋОф ОњОЎОЕОћ ОюОљОфОеОЎОЮ ОЋОќОъОЪ ОъОАОџ ОЉОбОќОеОф Family Link</translation>
<translation id="3559262020195162408">ОћОфОДОаОф ОћОъОЊОЎОаОЎОЋОф ОЉОъОЏОЕОЎОе ОаОЏОЕОюОћ.</translation>
<translation id="3559533181353831840">ОћОќОъОЪ ОћОаОЋОфОе: ОЉОбОеОџ <ph name="TIME_LEFT" /></translation>
<translation id="3560034655160545939">&amp;ОЉОЊОЎОДОф ОљОЎОЋОф</translation>
<translation id="3562423906127931518">РђЈОћОфОћОюОЎОџ ОћОќОћ ОбОЕОЋОЎ ОюОћОЎОъОЕОџ ОЏОъОћ ОЊОДОЋОф. ОъОфОЉОдОбОф ОћОњОЊОеОћ ОЕОю ОъОљОњОе Linux.</translation>
<translation id="3562655211539199254">РђЈОћОдОњОф ОЏОеОўОЎОАОЎОЋОф Chrome ОљОЌОеОЋОаОЋОф ОЉОўОюОцОЋОЪ</translation>
<translation id="3563432852173030730">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОЋОеОЎОЊ ОљОф ОЎОЎОЕОЋОЮ ОћОДОЎОЋОАОД.</translation>
<translation id="3564334271939054422">РђЈОЎОЎОфОЏОЪ ОЕОЎОћОЎОћ ОдОЋОеОџ ОюОћОЎОЏОаОА ОюОЊОБ ОћОћОфОЌОЉОеОЋОф ОЕОю ОеОЕОф Оћ-Wi-Fi ОЕОЉОћ ОЉОЌОеОф ОюОћОЕОфОъОЕ (<ph name="NETWORK_ID" />).</translation>
<translation id="3564848315152754834">РђЈОъОцОфОЌ ОљОЉОўОЌОћ ОЉОЌОЎОЉОЋОе USB</translation>
<translation id="3566325075220776093">ОъОћОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="3566721612727112615">ОюОљ ОаОЋОАОцОЋ ОљОфОеОЎОЮ</translation>
<translation id="3567284462585300767">ОћОъОЏОЕОЎОе ОЕОюОџ ОдОеОЎОџ ОюОћОЎОЋОф ОњОюОЋОЎ ОЏОЊОЎ ОюОЕОфОБ ОДОЉОдОЎОЮ ОбОЮ ОљОаОЕОЎОЮ ОљОЌОеОЎОЮ ОЉОАОЉОЎОЉОћ ОЋОюОДОЉОю ОъОћОЮ ОДОЉОдОЎОЮ</translation>
<translation id="3569382839528428029">ОеОЋОдОћ ОЕ-<ph name="APP_NAME" /> ОЎОЕОфОБ ОљОф ОћОъОАОџ ОЕОюОџ?</translation>
<translation id="3569407787324516067">ОЕОЋОъОе ОъОАОџ</translation>
<translation id="3569682580018832495">Ою-<ph name="ORIGIN" /> ОЎОЕ ОљОцОЕОеОЋОф ОюОћОдОЎОњ ОљОф ОћОфОЎОДОЎОЋОф ОЋОћОДОЉОдОЎОЮ ОћОЉОљОЎОЮ</translation>
<translation id="3571734092741541777">ОћОњОЊОеОћ</translation>
<translation id="3575121482199441727">ОљОЎОЕОЋОе ОюОљОфОе ОћОќОћ</translation>
<translation id="3577745545227000795">ОљОЎОАОЋОБ ОаОфОЋОаОЎ ОЌОЋОъОеОћ ОЕОю <ph name="DEVICE_OS" /></translation>
<translation id="3578594933904494462">ОћОфОЋОЏОЪ ОЉОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОъОЕОЋОфОБ.</translation>
<translation id="3578874072190212775">ОЉОъОАОњОеОф ОцОбОЎОюОЋОф ОЉОљОфОеОЎОЮ, ОЎОЕ ОљОцОЕОеОЋОф ОюОћОЉОЊОЎОю ОЉОЎОЪ ОЉОЋОўОЎОЮ ОюОљОаОЕОЎОЮ ОЏОЊОЎ ОюОъОаОЋОб ОфОеОъОЎОЋОф</translation>
<translation id="3581605050355435601">РђЈОћОњОЊОеОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЏОфОЋОЉОф IP</translation>
<translation id="3582057310199111521">ОћОЋОќОаОћ ОЉОљОфОе ОъОўОбОћ ОЋОаОъОдОљОћ ОЉОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб</translation>
<translation id="3584169441612580296">ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОДОЋОЉОдОЎ ОфОъОЋОаОЋОф, ОъОЋОќОЎОДОћ ОЋОъОЊОЎОћ ОъОАОЋОњОЎОЮ ОаОЋОАОцОЎОЮ ОъОћОъОЌОЕОЉ ОЕОюОџ</translation>
<translation id="3586806079541226322">ОюОљ ОаОЎОфОЪ ОюОцОфОЋОЌ ОљОф ОћОДОЋОЉОЦ ОћОќОћ</translation>
<translation id="3586931643579894722">ОћОАОфОеОф ОћОцОеОўОЎОЮ</translation>
<translation id="3587482841069643663">ОћОЏОЋОю</translation>
<translation id="3588790464166520201">РђЈОъОЋОеОЕОЎОЮ ОюОћОфОДОЎОЪ ОеОЏОЎОЉОЎ handler ОЕОю ОфОЕОюОЋОъОЎОЮ</translation>
<translation id="3589766037099229847">ОфОЋОЏОЪ ОюОљ ОъОљОЋОЉОўОЌ ОаОЌОАОЮ</translation>
<translation id="3590194807845837023">ОЉОЎОўОЋОю ОаОбОЎОюОф ОцОеОЋОцОЎОю ОЋОћОцОбОюОћ ОъОЌОЊОЕ</translation>
<translation id="3590295622232282437">ОъОфОЉОдОбОф ОЏОаОЎОАОћ ОюОАОЕОЪ ОъОаОЋОћОю.</translation>
<translation id="3592260987370335752">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="3593152357631900254">РђЈОћОцОЎОЏОф ОъОдОЉ Fuzzy-Pinyin ОюОцОбОЎОю</translation>
<translation id="3593965109698325041">ОъОњОЉОюОЋОф ОЕОЮ ОљОЎОЕОЋОе </translation>
<translation id="3596012367874587041">ОћОњОЊОеОЋОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="3596414637720633074">РђЈОЌОАОЎОъОф ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="3599221874935822507">ОЉОЋОюОў</translation>
<translation id="3600051066689725006">ОцОеОўОЎ ОЉОДОЕОф ОљОЎОаОўОеОаОў</translation>
<translation id="360180734785106144">ОюОћОдОЎОб ОфОЏОЋОаОЋОф ОЌОЊОЕОЋОф ОЏОЕОћОЪ ОќОъОЎОаОЋОф</translation>
<translation id="3602290021589620013">ОфОдОЋОњОћ ОъОДОЊОЎОъОћ</translation>
<translation id="3602870520245633055">ОћОЊОцОАОћ ОЋОАОеОЎОДОћ</translation>
<translation id="3603622770190368340">ОћОЕОњОф ОљОЎОЕОЋОе ОеОЕОф</translation>
<translation id="3604713164406837697">ОћОЌОюОцОф ОћОўОцОў</translation>
<translation id="3605780360466892872">ОъОе ОъОЏОЋОцОфОе</translation>
<translation id="3608576286259426129">ОфОдОЋОњОћ ОъОДОЊОЎОъОћ ОЕОю ОфОъОЋОаОф ОћОъОЕОфОъОЕ</translation>
<translation id="3609277884604412258">ОЌОЎОцОЋОЕ ОъОћОЎОе</translation>
<translation id="3610369246614755442">ОћОъОљОЋОЋОеОе ОЕОю ОљОЉОЎОќОе ОћОбОњОЎОаОћ ОдОеОЎОџ ОфОЎОДОЋОЪ</translation>
<translation id="361106536627977100">РђЈОаОфОЋОаОЎ Flash</translation>
<translation id="3611655097742243705">РђЈОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЋОф ОъОЌОЏОЋОф ОюОџ ОЉОЌОаОЋОф Play</translation>
<translation id="3611658447322220736">ОљОфОеОЎОЮ ОЕОаОАОњОеОЋ ОюОљОЌОеОЋОаОћ ОЎОЏОЋОюОЎОЮ ОюОАОЎОЎОЮ ОЕОюОЎОЌОћ ОЋОДОЉОюОћ ОЕОю ОаОфОЋОаОЎОЮ</translation>
<translation id="3612673635130633812">РђЈОћОћОЋОеОЊОћ ОЉОЋОдОбОћ ОЉОљОъОдОбОЋОф &lt;a href="<ph name="URL" />"&gt;<ph name="EXTENSION" />&lt;/a&gt;</translation>
<translation id="3613134908380545408">ОћОдОњОф <ph name="FOLDER_NAME" /></translation>
<translation id="3613422051106148727">&amp;ОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="3615073365085224194">ОЎОЕ ОюОњОбОф ОбОЮ ОћОљОдОЉОб ОЉОЌОЎОЎОЕОЪ ОўОЉОЎОбОф ОћОљОдОЉОб</translation>
<translation id="3615579745882581859">ОъОфОЉОдОбОф ОАОеОЎОДОћ ОЉОДОЋОЉОЦ <ph name="FILE_NAME" />.</translation>
<translation id="3616741288025931835">&amp;ОаОЎОДОЋОЎ ОаОфОЋОаОЎ ОњОюОЎОЕОћ...</translation>
<translation id="3617891479562106823">ОеОДОбОЎОЮ ОљОЎОаОЮ ОќОъОЎОаОЎОЮ. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="3619115746895587757">ОДОцОЋОд'ОЎОаОЋ</translation>
<translation id="3619962278978697442">ОЎОЕ ОюОЉОЌОЋОе ОЉОљОЌОф ОъОћОљОцОЕОеОЋОЎОЋОф ОЉОЏОю ОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ</translation>
<translation id="3621807901162200696">РђЈОбОќОеОћ ОЉОЕОЎОцОЋОе ОћОфОЏОЋОаОЋОф ОЋОћОЉОЎОдОЋОбОЎОЮ ОЕОю ChromeOS</translation>
<translation id="362266093274784978">{COUNT,plural, =1{ОљОцОюОЎОДОдОЎОћ}two{# ОљОцОюОЎОДОдОЎОЋОф}many{# ОљОцОюОЎОДОдОЎОЋОф}other{# ОљОцОюОЎОДОдОЎОЋОф}}</translation>
<translation id="362333465072914957">РђЈОЉОћОъОфОаОћ ОюОћОаОцОДОф ОљОЎОЕОЋОе ОбОю ОЎОЊОЎ Оћ-CA</translation>
<translation id="3624567683873126087">РђЈОЉОЎОўОЋОю ОаОбОЎОюОф ОћОъОЏОЕОЎОе ОЋОЏОаОЎОАОћ ОљОю ОЌОЕОЉОЋОЪ Google</translation>
<translation id="3624583033347146597">РђЈОдОеОЎОџ ОюОЉОЌОЋОе ОљОф ОћОћОбОЊОцОЋОф ОЕОюОџ ОЉОаОЋОњОб ОюОДОЋОЉОдОЎ cookie ОЕОю ОдОЊОЊОЎОЮ ОЕОюОЎОЕОЎОЎОЮ</translation>
<translation id="3625481642044239431">ОЉОЌОеОф ОДОЋОЉОЦ ОюОљ ОЌОЋОДОЎ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3626296069957678981">РђЈОЏОЊОЎ ОюОўОбОЋОЪ ОљОф Оћ-Chromebook ОћОќОћ ОЎОЕ ОюОћОЕОфОъОЕ ОЉОАОЋОюОюОћ ОфОЋОљОъОф ОЕОю Dell.</translation>
<translation id="3627320433825461852">ОаОЋОфОеОћ ОцОЌОЋОф ОъОЊОДОћ ОљОЌОф</translation>
<translation id="3627588569887975815">ОцОфОЎОЌОф ОДОЎОЕОЋОе ОЉОЌОюОЋОЪ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="3627671146180677314">РђЈОъОЋОбОЊ ОЌОЎОЊОЋОЕ ОЕОю ОљОЎОЕОЋОе Netscape</translation>
<translation id="3627879631695760395">ОћОфОДОаОф <ph name="APP" />...</translation>
<translation id="3628275722731025472">РђЈОћОЕОЉОфОф Bluetooth</translation>
<translation id="3629631988386925734">РђЈОЏОЊОЎ ОюОћОцОбОЎОю ОљОф Smart Lock ОдОеОЎОџ ОюОћОќОЎОЪ ОАОЎОАОъОћ. ОЉОцОбОЮ ОћОЉОљОћ, ОћОўОюОцОЋОЪ ОЎОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю <ph name="DEVICE_TYPE" />. ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф Smart Lock ОЊОеОџ ОћОћОњОЊОеОЋОф.</translation>
<translation id="3630132874740063857">ОћОўОюОцОЋОЪ ОЕОюОџ</translation>
<translation id="3630995161997703415">ОЏОЊОЎ ОЕОаОЎОфОЪ ОЎОћОЎОћ ОфОъОЎОЊ ОюОћОЕОфОъОЕ ОЉОљОфОе ОћОќОћ ОЎОЕ ОюОћОЋОАОЎОБ ОљОЋОфОЋ ОюОъОЊОБ</translation>
<translation id="3631680145967006828">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОћОЏОЎОю ОъОЎОЊОб ОЏОъОЋ ОаОАОЎОЉОЋОф ОћОДОеОЎОАОћ ОЕОю ChromeOS, ОћОфОЏОЋОаОЋОф ОЕОъОЕОъОЕОЋОф ОљОЋОфОџ ОЋОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОЕОю ОъОЏОЕОЎОе Chrome. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОбОЉОЋОе ОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.<ph name="END_PARAGRAPH3" /></translation>
<translation id="3634652306074934350">ОцОњ ОфОЋОДОцОћ ОЕОю ОћОЉОДОЕОћ ОюОћОеОЕОљОћ</translation>
<translation id="3635199270495525546">РђЈОќОЋОћОћ ОъОЋОЊОЋОю ОцОюОўОцОЋОеОъОћ ОъОћОЎОъОЪ (TPM)</translation>
<translation id="3635353578505343390">РђЈОЕОюОЎОЌОф ОъОЕОЋОЉ Ою-Google</translation>
