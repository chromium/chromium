<translation id="5901069264981746702">ОаОфОЋОаОЎ ОўОЉОЎОбОЋОф ОћОљОдОЉОб ОъОљОЋОЌОАОаОЎОЮ ОЉОљОЋОцОЪ ОъОљОЋОЉОўОЌ ОЋОљОБ ОцОбОЮ ОюОљ ОаОЕОюОЌОЎОЮ ОъОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" />. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="5901089233978050985">ОюОЏОеОўОЎОАОЎОЎОф ОћОћОДОюОўОћ</translation>
<translation id="5901494423252125310">ОЊОюОф ОћОъОЊОцОАОф ОцОфОЋОЌОћ</translation>
<translation id="5901630391730855834">ОдОћОЋОЉ</translation>
<translation id="5904614460720589786">ОюОљ ОаОЎОфОЪ ОюОћОфОДОЎОЪ ОљОф ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОбОДОЉ ОЉОбОЎОћ ОЉОћОњОЊОеОЋОф. ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="5906655207909574370">ОћОбОЊОЏОЋОЪ ОЏОъОбОў ОћОЋОЕОюОЮ! ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЏОЕОЎОе ОЏОЊОЎ ОюОАОЎОЎОЮ ОљОф ОћОбОЊОЏОЋОЪ.</translation>
<translation id="5906732635754427568">ОћОъОбОеОЏОф ОфОАОЎОе ОъОћОъОЏОЕОЎОе ОћОќОћ ОаОфОЋОаОЎОЮ ОћОъОЕОЋОЎОЏОЎОЮ ОюОљОцОюОЎОДОдОЎОћ ОћОќОЋ.</translation>
<translation id="5908474332780919512">ОћОцОбОюОф ОћОљОцОюОЎОДОдОЎОћ ОЉОќОъОЪ ОћОЏОаОЎОАОћ</translation>
<translation id="5908695239556627796">ОъОћОЎОеОЋОф ОњОюОЎОюОф ОћОбОЏОЉОе</translation>
<translation id="5909379458939060601">ОюОъОЌОЋОД ОљОф ОћОцОеОЋОцОЎОю ОћОќОћ ОЋОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЕОюОЋ?</translation>
<translation id="5910363049092958439">ОЕОъ&amp;ОЎОеОф ОфОъОЋОаОћ ОЉОЕОЮ...</translation>
<translation id="5910726859585389579"><ph name="DEVICE_TYPE" /> ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="5911533659001334206">ОъОдОЎОњ ОДОЎОдОЋОеОЎ ОћОЊОеОџ</translation>
<translation id="5914724413750400082">ОъОЋОЊОЋОюОЋОА (<ph name="MODULUS_NUM_BITS" /> ОЉОЎОўОЎОЮ):
  <ph name="MODULUS_HEX_DUMP" />

  ОъОбОеОЎОџ ОдОЎОЉОЋОеОЎ (<ph name="PUBLIC_EXPONENT_NUM_BITS" /> ОЉОЎОўОЎОЮ):
  <ph name="EXPONENT_HEX_DUMP" /></translation>
<translation id="591556859191968540">ОћОўОюОцОЋОЪ ОЕОюОџ ОъОЌОЋОЉОе ОљОю <ph name="DEVICE_TYPE" /></translation>
<translation id="5916664084637901428">ОцОЋОбОю</translation>
<translation id="59174027418879706">ОъОЋОцОбОю</translation>
<translation id="5920543303088087579">ОћОЌОЎОЉОЋОе ОюОеОЕОф ОћОќОЋ ОћОЋОЕОЉОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="5921257443092182237">РђЈОЏОЊОЎ ОюОћОбОеОЎОџ ОљОф ОћОъОЎОДОЋОЮ ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ, ОЕОЎОеОЋОфОЎ ОћОъОЎОДОЋОЮ ОЕОю Google ОъОАОфОъОЏОЎОЮ ОбОю ОъОДОЋОеОЋОф ОЏОъОЋ Wi-Fi, ОеОЕОфОЋОф ОАОюОЋОюОеОЎОЋОф ОЋОЌОЎОЎОЕОаОЎОЮ.</translation>
<translation id="5924047253200400718">ОДОЉОюОф ОбОќОеОћ<ph name="SCANNING_STATUS" /></translation>
<translation id="5924527146239595929">РђЈОљОцОЕОе ОюОдОюОЮ ОфОъОЋОаОћ ОЌОЊОЕОћ, ОљОЋ ОюОЉОЌОЋОе ОфОъОЋОаОћ ОљОЋ ОАОъОю ОДОЎОЎОъОЎОЮ.
    <ph name="LINE_BREAK" />
    ОћОфОъОЋОаОћ ОфОЋОцОЎОб ОЉОъОАОџ ОћОЏОаОЎОАОћ ОЋОЉОъОАОџ ОћОаОбОЎОюОћ ОЉ-Chromebook.</translation>
<translation id="5925147183566400388">ОъОдОЉОЎОб ОбОю ОћОдОћОеОф ОћОюОЎОЏОЎ ОљОЎОЕОЋОе</translation>
<translation id="592740088639760830">ОбОдОЎОеОф ОћОДОЋОаОўОЎОЎОаОе ОћОќОћ</translation>
<translation id="592880897588170157">РђЈОћОЋОеОЊОф ОДОЋОЉОдОЎ PDF ОЉОъОДОЋОЮ ОцОфОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОюОћОЮ ОЉ-Chrome</translation>
<translation id="592919310198008711">ОЉОюОЌОЎОдОћ ОбОю ОћОфОЋОАОБ</translation>
<translation id="5932209916647644605">ОЏОЊОЎ ОюОћОЎОЏОаОА ОљОю <ph name="MANAGER" /> ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ.</translation>
<translation id="5932224571077948991">ОЉОљОфОе ОъОЋОдОњОЋОф ОъОЋОЊОбОЋОф ОъОцОеОЎОбОЋОф ОљОЋ ОъОўОбОЋОф</translation>
<translation id="59324397759951282">РђЈОћОфОДОЪ USB ОЕОю <ph name="MANUFACTURER_NAME" /></translation>
<translation id="5932441198730183141">РђЈОљОЎОЪ ОЉОеОЕОЋОфОџ ОъОАОцОЎОД ОеОЎОЕОЎОЋОаОЋОф ОќОъОЎОаОЎОЮ ОюОЕОЎОЋОџ ОћОъОЏОЕОЎОе ОћОќОћ Ою-Google Meet. ОбОюОЎОџ ОюОцОаОЋОф ОюОъОЌОюОДОф ОћОъОЏОЎОеОЋОф ОЏОЊОЎ ОюОеОЏОЋОЕ ОеОЎОЕОЎОЋОаОЋОф ОаОЋОАОцОЎОЮ. ОљОЮ ОюОЊОбОфОџ ОћОћОЋОЊОбОћ ОћОќОЋ ОъОЋОдОњОф ОюОџ ОЉОўОбОЋОф, ОљОцОЕОе ОюОцОаОЋОф ОюОфОъОЎОЏОћ.</translation>
<translation id="5932881020239635062">ОАОЎОЊОЋОеОЎ</translation>
<translation id="5933376509899483611">ОљОќОЋОе ОќОъОЪ</translation>
<translation id="5933522550144185133">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОъОЕОфОъОЕОф ОЉОъОдОюОъОћ ОЋОЉОъОЎОДОеОЋОцОЋОЪ ОЕОюОџ</translation>
<translation id="5935158534896975820">ОћОъОбОеОЏОф ОъОЏОЎОаОћ ОљОф ОЉОДОЕОф ОћОЌОфОЎОъОћ ОбОю ОћОљОЎОЕОЋОе (ОЉОћОъОфОаОћ ОюОЕОеОф)</translation>
<translation id="5935656526031444304">ОаОЎОћОЋОю ОњОюОЎОЕОћ ОЉОўОЋОЌОћ</translation>
<translation id="5938002010494270685">ОЎОЕ ОЕОЊОеОЋОњ ОљОЉОўОЌОћ ОќОъОЎОЪ</translation>
<translation id="5939518447894949180">ОљОЎОцОЋОА</translation>
<translation id="5939719276406088041">ОюОљ ОаОЎОфОЪ ОюОЎОдОЋОе ОДОЎОдОЋОе ОЊОеОџ</translation>
<translation id="594048410531370124">ОъОфОњ ОюОљ ОъОќОЋОћОћ. ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОЏОюОЕОћОЋ ОЏОЊОЎ <ph name="RESPONSE" />.</translation>
<translation id="5941153596444580863">ОћОЋОАОцОф ОъОЕОфОъОЕ...</translation>
<translation id="5941343993301164315">ОЏОаОЎОАОћ Ою-<ph name="TOKEN_NAME" />.</translation>
<translation id="5941711191222866238">ОъОќОбОЋОе</translation>
<translation id="5942779427914696408">ОћОеОЕОљОЋОф ОњОЎОЕОћ ОюОъОЏОЕОЎОе</translation>
<translation id="5943127421590245687">ОћОљОЎОъОЋОф ОћОАОфОЎОЎОЮ ОЉОћОдОюОЌОћ. ОЏОЊОЎ ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю ОћОаОфОЋОаОЎОЮ ОћОъОДОЋОъОЎОЎОЮ ОЋОюОЕОЌОќОе ОљОЋОфОЮ, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОћОДОЋОЊОъОф ОЕОюОџ ОбОЉОЋОе <ph name="DEVICE_TYPE" />.</translation>
<translation id="5945002094477276055">РђЈОћОДОЋОЉОЦ <ph name="FILE_NAME" /> ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ. ОюОЕОюОЋОЌ ОљОЋОфОЋ ОюОЕОЎОеОЋОф ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОЕОю Google ОюОдОЋОеОџ ОАОеОЎОДОћ?</translation>
<translation id="5945363896952315544">ОљОЎОЪ ОъОДОЋОЮ ОюОўОЉОЎОбОЋОф ОљОдОЉОб ОаОЋОАОцОЋОф ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ. ОЏОЊОЎ ОюОћОЋОАОЎОБ ОўОЉОЎОбОф ОљОдОЉОб ОЌОЊОЕОћ, ОДОЋОЊОЮ ОдОеОЎОџ ОюОъОЌОЋОД ОљОЌОф ОъОћОДОЎОЎОъОЋОф.</translation>
<translation id="5946591249682680882">ОъОќОћОћ ОЊОЎОЋОЋОЌ <ph name="WEBRTC_LOG_REPORT_ID" /></translation>
<translation id="5948536763493709626">РђЈОЎОЕ ОюОЌОЉОе ОъОДОюОЊОф ОљОЋ ОбОЏОЉОе, ОљОЋ ОюОћОъОЕОЎОџ ОЉОћОњОЊОеОћ ОЉОљОъОдОбОЋОф ОъОАОџ ОћОъОњОб. ОљОЮ ОЉОеОдОЋОаОџ ОюОћОЕОфОъОЕ ОЉОъОЏОЕОЎОеОЎ Bluetooth, ОбОюОЎОџ ОюОЋОЋОЊОљ ОЕОћОъОЏОЕОЎОеОЎОЮ ОъОЋОЏОаОЎОЮ ОюОћОфОљОъОћ.</translation>
<translation id="5949544233750246342">ОюОљ ОаОЎОфОЪ ОюОаОфОЌ ОљОф ОћОДОЋОЉОЦ</translation>
<translation id="5950039854561387265">ОЎОЕ ОюОЕОљОЋОю ОЉОцОбОЮ ОћОЉОљОћ</translation>
<translation id="5950819593680344519">РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОљОфОъОЋОю</translation>
<translation id="5951303645598168883"><ph name="ORIGIN" /> ОеОЋОдОћ ОюОћОЕОфОъОЕ ОЉОњОЋОцОаОЎОЮ ОъОДОЋОъОЎОЎОЮ</translation>
<translation id="5951624318208955736">ОдОњ</translation>
<translation id="5953211687820750364">РђЈОћОеОЕОЎОъОћ ОћОќОЋ ОъОЋОЕОцОбОф ОъОћОъОЊОЎОаОЎОЋОф ОЕОю ОћОеОЕОЎОъОЋОф <ph name="BEGIN_LINK1" />{BrowserSwitcherExternalGreylistUrl}<ph name="END_LINK1" />
          ОЋРђЉ<ph name="BEGIN_LINK2" />{BrowserSwitcherUrlGreylist}<ph name="END_LINK2" /></translation>
<translation id="5955282598396714173">ОфОЋОДОБ ОћОАОЎОАОъОћ ОцОњ. ОЏОЊОЎ ОюОЕОаОЋОф ОљОЋОфОћ, ОдОеОЎОџ ОюОдОљОф ОЋОюОћОЎОЏОаОА ОъОЌОЊОЕ.</translation>
<translation id="5955304353782037793">app</translation>
<translation id="5955721306465922729">ОљОфОе ОъОАОЋОЎОЮ ОеОЋОдОћ ОюОцОфОЋОЌ ОљОф ОћОљОцОюОЎОДОдОЎОћ ОћОќОЋ.</translation>
<translation id="5955809630138889698">ОЎОЎОфОЏОЪ ОЕОћОъОЏОЕОЎОе ОћОќОћ ОЏОЕОЎОе ОеОД ОюОъОдОЉ ОћОЊОњОъОћ ОљОЋОаОюОЎОЎОЪ. ОљОцОЕОе ОюОцОаОЋОф ОюОаОдОЎОњ ОћОфОъОЎОЏОћ ОЏОЊОЎ ОюОДОЉОю ОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ.</translation>
<translation id="5956585768868398362">ОћОљОЮ ОќОћОЋ ОЊОБ ОћОЌОЎОцОЋОЕ ОЕОдОЎОцОЎОф ОюОеОљОЋОф?</translation>
<translation id="5957918771633727933">РђЈОљОЎОЪ ОцОеОЋОцОЎОюОЎОЮ ОќОъОЎОаОЎОЮ ОЕОю eSIM. ОаОЎОфОЪ ОюОћОЋОеОЎОЊ <ph name="BEGIN_LINK" />ОцОеОЋОцОЎОю<ph name="END_LINK" /> ОЌОЊОЕ.</translation>
<translation id="5957987129450536192">ОЎОЕ ОюОћОДОЎОЕ ОбОю ОАОъОю ОћОћОДОеОљОћ ОюОдОЊ ОфОъОЋОаОф ОћОцОеОЋОцОЎОю ОЋОљОќ ОюОЉОЌОЋОе ОЉОўОДОАОў ОюОћОДОеОљОћ.</translation>
<translation id="5959471481388474538">ОћОеОЕОф ОюОљ ОќОъОЎОаОћ</translation>
<translation id="595959584676692139">ОдОеОЎОџ ОюОўОбОЋОЪ ОъОЌОЊОЕ ОљОф ОћОЊОБ ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОћОќОћ</translation>
<translation id="5960410286721553511">ОћОдОњОћ ОЕОю ОћОъОЊОЎОћ ОЋОћОфОъОЋОаОЋОф ОЕОЉОўОюОцОЋОЪ ОъОћОќОъОЪ ОћОљОЌОеОЋОЪ</translation>
<translation id="5963453369025043595"><ph name="NUM_HANDLES" /> (ОЕОЎОљ ОЕОю <ph name="NUM_KILOBYTES_LIVE" />)</translation>
<translation id="5964113968897211042">{COUNT,plural, =0{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}=1{ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}two{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}many{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}other{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}}</translation>
<translation id="5965661248935608907">ОћОњОЊОеОћ ОќОЋ ОњОЮ ОДОЋОЉОбОф ОљОЎОќОћ ОЊОБ ОъОЋОдОњ ОЏОЕОюОЋОЌОдОЎОЮ ОбОю ОћОюОЌОдОЪ 'ОЊОБ ОћОЉОЎОф' ОљОЋ ОъОЉОдОбОЎОЮ ОЌОЎОцОЋОЕ ОъОАОеОњОю ОћОЏОфОЋОЉОЋОф.</translation>
<translation id="5968022600320704045">ОљОЎОЪ ОфОЋОдОљОЋОф ОЌОЎОцОЋОЕ</translation>
<translation id="5969419185858894314">Ою-<ph name="ORIGIN" /> ОЎОЕ ОћОеОЕОљОћ ОюОћОдОЎОњ ОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDERNAME" /></translation>
<translation id="5969728632630673489">ОћОћОЋОЊОбОћ ОюОњОЉОЎ ОъОДОЕОЎ ОћОДОЎОдОЋОе ОаОАОњОеОћ</translation>
<translation id="5971037678316050792">РђЈОћОњОЊОеОф ОъОдОЉ ОЋОЕОюОЎОўОћ ОЉОћОфОљОъОћ ОбОЉОЋОе ОъОфОљОЮ Bluetooth</translation>
<translation id="597235323114979258">ОћОдОњОф ОЎОбОЊОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="5972543790327947908">ОЌОюОД ОъОћОДОЎОЕОЋОеОЎОЮ ОћОаОфОъОЏОЎОЮ ОЎОъОЕОЎОЏОЋ ОюОћОЎОцОфОЌ ОЉОљОцОюОЎОДОдОЎОЋОф <ph name="APP_NAME" />,РђЈ <ph name="APP_NAME_2" /> ОљОЋ <ph name="APP_NAME_3" />.</translation>
<translation id="5972666587303800813">РђЈОЕОЎОеОЋОф ОюОюОљ ОфОцОбОЋОю (no-ops)</translation>
<translation id="5972708806901999743">ОћОбОЉОеОћ ОюОъОбОюОћ</translation>
<translation id="5972826969634861500">ОћОцОбОюОф <ph name="PRODUCT_NAME" /></translation>
<translation id="5973041996755340290">ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЕОю ОћОЊОцОЊОцОЪ ОћОќОћ ОъОфОЉОдОб ОбОю ОЎОЊОЎ "<ph name="CLIENT_NAME" />"</translation>
<translation id="5973605538625120605">ОЕОЎОаОЋОЎ ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="5975056890546437204">{COUNT,plural, =0{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ}=1{ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ}two{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ}many{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ}other{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ}}</translation>
<translation id="5975792506968920132">ОљОЌОЋОќ ОўОбОЎОаОф ОћОАОЋОюОюОћ</translation>
<translation id="5976160379964388480">ОљОЌОеОЎОЮ</translation>
<translation id="5978277834170881274">&amp;ОЕОЎОъОЋОЕ ОЉОЉОЊОЎОДОф ОљОЎОЋОф ОЉОАОЎОАОЎОф</translation>
<translation id="5979084224081478209">ОЉОЊОЎОДОф ОћОАОЎОАОъОљОЋОф</translation>
<translation id="5979156418378918004">{NUM_EXTENSIONS,plural, =1{ОћОцОбОюОф ОъОЌОЊОЕ ОфОЋОАОБ ОљОЌОЊ ОЕОбОЕОЋОЎ ОюОћОЎОЋОф ОъОќОЎОД}two{ОћОцОбОюОф ОъОЌОЊОЕ {NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ}many{ОћОцОбОюОф ОъОЌОЊОЕ {NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ}other{ОћОцОбОюОф ОъОЌОЊОЕ {NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ}}</translation>
<translation id="5979353814339191480">РђЈОљОцОЕОеОЋОф ОќОЋ ОеОюОЋОЋОаОўОЎОф ОюОъОЏОЕОЎОеОЎ Chromebook ОбОЮ ОЌОЉОЎОюОф ОњОюОЎОЕОћ ОљОЋ ОъОфОљОЮ ОеОЕОф ОАОюОЋОюОеОЎОф, ОљОЋ ОЉОќОъОЪ ОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОЉОљОъОдОбОЋОф ОаОДОЋОЊОћ ОюОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОЉОаОЎОЎОЊ</translation>
<translation id="5979421442488174909">&amp;ОфОеОњОЋОЮ Ою-<ph name="LANGUAGE" /></translation>
<translation id="5979469435153841984">ОЏОЊОЎ ОюОћОЋОАОЎОБ ОЊОцОЎОЮ ОюОАОЎОъОаОЎОЋОф, ОљОцОЕОе ОюОюОЌОЋОЦ ОбОю ОћОЏОЋОЏОЉ ОЉОЕОЋОеОф ОЏОфОЋОЉОф ОћОљОфОе</translation>
<translation id="5981362776161841923">ОЏОЊОЎ ОюОљОцОЕОе ОфОЋОАОБ ОЏОюОЕОћОЋ, ОдОеОЎОџ ОюОЕОаОЋОф ОљОф ОћОњОЊОеОф ОЉОеОЎОеОф ОћОъОЌОЊОю ОЉОћОъОЕОџ.</translation>
<translation id="5984222099446776634">ОЉОЎОДОеОф ОюОљОЌОеОЋОаОћ</translation>
<translation id="5985458664595100876">РђЈОцОЋОеОъОў ОЏОфОЋОЉОф ОћОљОфОе ОюОљ ОЌОЋОДОЎ. ОћОцОЋОеОъОўОЎОЮ ОћОаОфОъОЏОЎОЮ ОћОЮ Рђј\\server\share ОЋ-smb://server/share.</translation>
<translation id="598810097218913399">ОћОАОеОф ОћОћОДОдОљОћ</translation>
<translation id="5990266201903445068">РђЈWi-Fi ОЉОюОЉОЊ</translation>
<translation id="5990386583461751448">ОъОфОЋОеОњОЮ</translation>
<translation id="599131315899248751">{NUM_APPLICATIONS,plural, =1{ОЏОЊОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОћОъОЕОЎОџ ОюОњОюОЋОЕ ОЉОљОЎОаОўОеОаОў, ОдОеОЎОџ ОюОЉОДОЕ ОъОъОаОћОю ОћОъОбОеОЏОф ОюОћОАОЎОе ОљОф ОћОљОцОюОЎОДОдОЎОћ ОћОќОЋ.}two{ОЏОЊОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОћОъОЕОЎОџ ОюОњОюОЋОЕ ОЉОљОЎОаОўОеОаОў, ОдОеОЎОџ ОюОЉОДОЕ ОъОъОаОћОю ОћОъОбОеОЏОф ОюОћОАОЎОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОћ.}many{ОЏОЊОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОћОъОЕОЎОџ ОюОњОюОЋОЕ ОЉОљОЎОаОўОеОаОў, ОдОеОЎОџ ОюОЉОДОЕ ОъОъОаОћОю ОћОъОбОеОЏОф ОюОћОАОЎОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОћ.}other{ОЏОЊОЎ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОћОъОЕОЎОџ ОюОњОюОЋОЕ ОЉОљОЎОаОўОеОаОў, ОдОеОЎОџ ОюОЉОДОЕ ОъОъОаОћОю ОћОъОбОеОЏОф ОюОћОАОЎОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОћ.}}</translation>
<translation id="5997337190805127100">ОъОЎОЊОб ОаОЋОАОБ ОбОю ОњОЎОЕОћ ОюОљОфОеОЎОЮ</translation>
