<translation id="2285109769884538519">{COUNT,plural, =0{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}=1{ОцОфОЎОЌОф ОћОЏОфОЋОЉОф ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}two{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}many{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}other{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}}</translation>
<translation id="2285942871162473373">ОюОљ ОаОЎОфОЪ ОюОќОћОЋОф ОљОф ОўОЉОЎОбОф ОћОљОдОЉОб ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
