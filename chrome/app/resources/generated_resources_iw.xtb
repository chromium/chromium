<translation id="4996851818599058005">{NUM_VMS,plural, =0{РђЈОюОљ ОаОъОдОљОЋ ОъОЏОЋОаОЋОф VM ОъОАОЋОњ <ph name="VM_TYPE" />}=1{РђЈОаОъОдОљОћ ОъОЏОЋОаОф VM ОљОЌОф ОъОАОЋОњ <ph name="VM_TYPE" />: РђЈ<ph name="VM_NAME_LIST" />}two{РђЈОаОъОдОљОЋ {NUM_VMS} ОъОЏОЋОаОЋОф VM ОъОАОЋОњ <ph name="VM_TYPE" />: РђЈ<ph name="VM_NAME_LIST" />}many{РђЈОаОъОдОљОЋ {NUM_VMS} ОъОЏОЋОаОЋОф VM ОъОАОЋОњ <ph name="VM_TYPE" />: РђЈ<ph name="VM_NAME_LIST" />}other{РђЈОаОъОдОљОЋ {NUM_VMS} ОъОЏОЋОаОЋОф VM ОъОАОЋОњ <ph name="VM_TYPE" />: РђЈ<ph name="VM_NAME_LIST" />}}</translation>
<translation id="4997086284911172121">ОљОЎОЪ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў.</translation>
