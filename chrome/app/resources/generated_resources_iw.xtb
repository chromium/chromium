<translation id="747507174130726364">{NUM_DAYS,plural, =1{ОаОЊОеОЕОф ОћОЌОќОеОћ ОъОЎОЎОЊОЎОф}two{ОЎОЕ ОюОћОЌОќОЎОе ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ ОЎОЋОъОЎОЎОЮ ({NUM_DAYS})}many{ОЎОЕ ОюОћОЌОќОЎОе ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_DAYS} ОЎОъОЎОЮ}other{ОЎОЕ ОюОћОЌОќОЎОе ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_DAYS} ОЎОъОЎОЮ}}</translation>
<translation id="7475671414023905704">РђЈОЏОфОЋОЉОф ОљОфОе ОюОАОЎОАОъОћ ОЕОљОЉОЊОћ ОЕОю Netscape</translation>
<translation id="7476454130948140105">РђЈОћОАОЋОюОюОћ ОЌОюОЕОћ ОъОЊОЎ ОюОћОфОДОаОф ОћОбОЊОЏОЋОЪ (Рђј<ph name="BATTERY_PERCENT" />%Рђј)</translation>
<translation id="7476989672001283112">ОћОеОЕОљОЋОф <ph name="PERMISSION" /> ОЋОбОЋОЊ <ph name="COUNT" /> ОаОЌОАОъОЋ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="7477748600276493962">РђЈОЎОдОЎОеОф ОДОЋОЊ QR ОюОЊОБ ОћОќОћ</translation>
<translation id="7477793887173910789">ОЕОюОЎОўОћ ОЉОъОЋОќОЎОДОћ, ОЉОАОеОўОЋОаОЎОЮ ОЋОбОЋОЊ</translation>
<translation id="7478485216301680444">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОДОЎОЪ ОљОцОюОЎОДОдОЎОЎОф "ОДОЎОЋОАОД".</translation>
<translation id="7478658909253570368">ОљОЎОЪ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОфОЌОЉОе ОюОЎОдОЎОљОЋОф ОўОЋОеОЎОЋОф</translation>
<translation id="7479221278376295180">ОАОДОЎОеОћ ОЏОюОюОЎОф ОЕОю ОћОЕОЎОъОЋОЕ ОЉОЕОўОЌ ОљОЌОАОЋОЪ</translation>
<translation id="747981547666531654">РђЈОЎОЕ ОЌОЎОЉОЋОе ОюОъОЏОЕОЎОеОЎ Bluetooth ОЉОЕОЮ <ph name="FIRST_DEVICE" /> ОЋ-<ph name="SECOND_DEVICE" /></translation>
<translation id="7481312909269577407">ОДОЊОЎОъОћ</translation>
<translation id="7481358317100446445">ОъОЋОЏОЪ</translation>
<translation id="748138892655239008">ОъОњОЉОюОЋОф ОЉОАОЎОАОЎОЋОф ОЕОю ОљОЎОЕОЋОе </translation>
<translation id="7484645889979462775">ОюОбОЋОюОЮ ОюОљ ОбОЉОЋОе ОљОфОе ОќОћ</translation>
<translation id="7487141338393529395">ОћОцОбОюОћ ОЕОю ОЉОЊОЎОДОф ОљОЎОЋОф ОъОЕОЋОцОеОф</translation>
<translation id="7487969577036436319">ОюОљ ОъОЋОфОДОаОЎОЮ ОеОЏОЎОЉОЎОЮ</translation>
<translation id="7488682689406685343">ОЎОЎОфОЏОЪ ОЕОћОљОфОе ОћОќОћ ОъОаОАОћ ОюОћОўОбОЋОф ОљОЋОфОџ ОЋОюОњОеОЋОЮ ОюОџ ОюОћОцОбОЎОю ОћОфОеОљОЋОф ОъОцОеОЎОбОЋОф.</translation>
<translation id="7489761397368794366">ОЕОЎОЌОћ ОъОћОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="749028671485790643">ОъОЕОфОъОЕ <ph name="VALUE" /></translation>
<translation id="7491962110804786152">tab</translation>
<translation id="7491963308094506985">{NUM_COOKIES,plural, =1{РђЈОДОЋОЉОЦ cookie ОљОЌОЊ}two{РђЈ{NUM_COOKIES} ОДОЋОЉОдОЎ cookie}many{РђЈ{NUM_COOKIES} ОДОЋОЉОдОЎ cookie}other{РђЈ{NUM_COOKIES} ОДОЋОЉОдОЎ cookie}}</translation>
<translation id="7493386493263658176">ОфОЋОАОцОЎ <ph name="EXTENSION_NAME" /> ОбОЕОЋОЎОЎОЮ ОюОфОбОЊ ОљОф ОЏОю ОћОўОДОАОў ОЕОъОДОюОЎОЊОЎОЮ, ОЏОЋОюОю ОаОфОЋОаОЎОЮ ОљОЎОЕОЎОЎОЮ, ОЏОъОЋ ОАОЎОАОъОљОЋОф ОЋОъОАОцОеОЎ ОЏОеОўОЎОА ОљОЕОеОљОЎ. ОћОљОЮ ОЉОеОдОЋОаОџ ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОћОќОћ?</translation>
<translation id="7494694779888133066">РђЈ<ph name="WIDTH" /> РђЈx РђЈ<ph name="HEIGHT" /></translation>
<translation id="7495149565104413027">РђЈОљОцОюОЎОДОдОЎОћ ОюРђЉAndroid</translation>
<translation id="7495778526395737099">ОЕОЏОЌОф ОљОф ОћОАОЎОАОъОћ ОћОДОЋОЊОъОф?</translation>
<translation id="7497981768003291373">РђЈОљОЎОЪ ОюОџ ОЎОЋОъОаОЎ ОўОДОАОў ОЕОю WebRTC ОЕОфОЋОбОЊОЋ ОюОљОЌОеОЋОаОћ.</translation>
<translation id="7501957181231305652">ОљОЋ</translation>
<translation id="7503191893372251637">РђЈОАОЋОњ ОљОЎОЕОЋОе Netscape</translation>
<translation id="7503985202154027481">ОфОЎОбОЋОЊ ОЕОю ОЉОЎОДОЋОеОџ ОЉОљОфОе ОЎОЎОЕОъОе ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ.</translation>
<translation id="750509436279396091">ОцОфОЎОЌОф ОфОЎОДОЎОЎОф ОћОћОЋОеОЊОЋОф</translation>
<translation id="7505717542095249632">ОћОАОфОеОћ ОЕОю <ph name="MERCHANT" /></translation>
<translation id="7506093026325926984">ОћОАОЎОАОъОћ ОћОќОЋ ОфОЎОЕОъОе ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="7506130076368211615">ОћОњОЊОеОф ОеОЕОф ОЌОЊОЕОћ</translation>
<translation id="7506242536428928412">ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОћОЌОЊОЕ, ОЎОЕ ОюОћОњОЊОЎОе ОДОЋОЊ ОљОЎОъОЋОф ОЌОЊОЕ</translation>
<translation id="7506541170099744506">ОћОеОЎОЕОЋОЮ ОЕОю ОћОъОЏОЕОЎОе ОЕОюОџ <ph name="DEVICE_TYPE" /> ОюОаОЎОћОЋОю ОљОеОњОЋОаОЎ ОћОАОфОЎОЎОЮ ОЉОћОдОюОЌОћ.</translation>
<translation id="7507207699631365376">ОћОдОњОф <ph name="BEGIN_LINK" />ОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф<ph name="END_LINK" /> ОЕОю ОћОАОцОД ОћОќОћ</translation>
<translation id="7509097596023256288">ОъОфОЉОдОбОф ОћОњОЊОеОћ ОЕОю ОћОаОЎОћОЋОю</translation>
<translation id="7509246181739783082">ОљОЎОъОЋОф ОќОћОЋОф</translation>
<translation id="7509539379068593709">ОћОАОеОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="7511415964832680006">ОЏОљОЕОе ОћОфОЏОЋОаОћ ОъОЋОцОбОюОф, ОљОфОеОЎОЮ ОЎОЋОЏОюОЋ ОюОАОцОД ОљОф ОћОфОЋОЏОЪ ОЋОљОф ОћОЕОЎОеОЋОфОЎОЮ ОЕОюОћОЮ ОЉОЕОЎОўОЋОф ОћОъОЋОдОњОЋОф ОЏОљОЪ, ОЕОъОљОцОЕОеОЋОф ОюОЕОъОЋОе ОбОю ОћОцОеОўОЎОЋОф. ОћОЕОЎОўОЋОф ОћОљОюОЋ ОЏОЋОюОюОЋОф ОЌОюОЋОцОЋОф ОюОъОбОДОЉ ОЉОЎОЪ ОљОфОеОЎОЮ. ОЎОЎОфОЏОЪ ОЕОЎОфОЋОЋОАОцОЋ ОбОЋОЊ ОфОЏОЋОаОЋОф ОаОЎОАОЎОЋОаОЎОЋОф ОЉОћОъОЕОџ.</translation>
<translation id="7514239104543605883">ОћОбОфОДОћ ОюОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="7514365320538308">ОћОЋОеОЊОћ</translation>
<translation id="7514417110442087199">ОћОЋОАОцОф ОћОДОдОљОћ</translation>
<translation id="751523031290522286">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОаОЌОАОъОћ ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф. ОЎОЕ ОюОЉОДОЕ ОћОеОЕОљОћ ОъОъОаОћОю ОћОъОбОеОЏОф ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОћ ОћОќОЋ.</translation>
<translation id="7515998400212163428">Android</translation>
<translation id="7516981202574715431"><ph name="APP_NAME" /> ОЉОћОЕОћОЎОћ</translation>
<translation id="7520766081042531487">ОцОЋОеОўОю ОљОаОЋОаОЎОъОЎ: <ph name="SUBFRAME_SITE" /></translation>
<translation id="7522255036471229694">РђЈОЎОЕ ОюОЋОъОе "Hey Google"</translation>
<translation id="7523585675576642403">ОЕОЎОаОЋОЎ ОЕОЮ ОћОцОеОЋОцОЎОю</translation>
<translation id="7525067979554623046">ОЎОдОЎОеОћ</translation>
<translation id="7525625923260515951">ОћОДОеОљОф ОћОўОДОАОў ОЕОЉОЌОеОф</translation>
<translation id="7526658513669652747">{NUM_DOWNLOADS,plural, =1{ОбОЋОЊ ОцОеОЎОў ОљОЌОЊ}two{ОбОЋОЊ {NUM_DOWNLOADS} ОцОеОЎОўОЎОЮ}many{ОбОЋОЊ {NUM_DOWNLOADS} ОцОеОЎОўОЎОЮ}other{ОбОЋОЊ {NUM_DOWNLOADS} ОцОеОЎОўОЎОЮ}}</translation>
<translation id="7526989658317409655">Placeholder</translation>
<translation id="7527758104894292229">РђЈОћОЎОљ ОфОбОЋОЊОЏОЪ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, <ph name="ACCOUNT" /></translation>
<translation id="7528224636098571080">ОюОљ ОюОцОфОЋОЌ</translation>
<translation id="7529411698175791732">ОЎОЕ ОюОЉОЊОЋОД ОљОф ОЌОЎОЉОЋОе ОћОљОЎОаОўОеОаОў. ОљОЮ ОћОЉОбОЎОћ ОюОљ ОаОцОфОеОф, ОЎОЕ ОюОаОАОЋОф ОюОдОљОф ОъОћОЌОЕОЉОЋОЪ ОЋОюОћОЎОЏОаОА ОљОюОЎОЋ ОЕОЋОЉ.</translation>
<translation id="7529876053219658589">{0,plural, =1{ОАОњОЎОеОф ОЌОюОЋОЪ ОћОљОЋОеОЌ}two{ОАОњОЎОеОф ОЌОюОЋОаОЋОф ОћОљОЋОеОЌ}many{ОАОњОЎОеОф ОЌОюОЋОаОЋОф ОћОљОЋОеОЌ}other{ОАОњОЎОеОф ОЌОюОЋОаОЋОф ОћОљОЋОеОЌ}}</translation>
<translation id="7530016656428373557">ОЕОЎОбОЋОе ОцОеОЎОДОћ ОЉОЋОЋОљОў</translation>
<translation id="7531310913436731628">РђЈОЕОЎОеОЋОфОЎ ОћОъОЎОДОЋОЮ ОъОЋОЕОЉОфОЎОЮ ОЉОћОбОЊОцОЋОф ОћОъОбОеОЏОф ОЕОю Mac</translation>
<translation id="7531771599742723865">ОћОъОЏОЕОЎОе ОаОъОдОљ ОЉОЕОЎОъОЋОЕ</translation>
<translation id="7531779363494549572">ОбОЋОЉОеОЎОЮ ОљОю 'ОћОњОЊОеОЋОф' &gt; 'ОљОцОюОЎОДОдОЎОЋОф ОЋОћОЋОЊОбОЋОф' &gt; 'ОћОЋОЊОбОЋОф'.</translation>
<translation id="7532009420053991888">ОћОљОцОюОЎОДОдОЎОћ <ph name="LINUX_APP_NAME" /> ОюОљ ОъОњОЎОЉОћ. ОЏОЊОЎ ОюОАОњОЋОе ОљОф ОћОљОцОюОЎОДОдОЎОћ, ОЎОЕ ОюОЉОЌОЋОе ОЉОљОцОЕОеОЋОф "ОљОЎОюОЋОЦ ОАОњОЎОеОћ".</translation>
<translation id="7535730537657706072">ОЏОЊОЎ ОюОъОЌОЋОД ОљОф ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ ОъОћОъОЏОЕОЎОе, ОАОЋОњОеОЎОЮ ОљОф ОЏОю ОћОЏОеОўОЎОАОЎОЋОф ОЕОю ОћОъОдОЉ ОћОљОаОЋОаОЎОъОЎ.</translation>
<translation id="7537451260744431038">РђЈОљОфОеОЎОЮ ОюОљ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОЏОЊОЎ ОюОЕОцОе ОљОф ОЌОЋОЋОЎОЎОф ОћОњОюОЎОЕОћ РђЊ ОюОъОЕОю, ОЏОЊОЎ ОюОъОаОЋОб ОаОЎОфОЋОД ОЕОюОџ ОъОћОЌОЕОЉОЋОЪ ОљОЋ ОЏОЊОЎ ОюОќОЏОЋОе ОљОф ОћОцОеОЎОўОЎОЮ ОЕОћОЋОАОцОф ОюОбОњОюОф ОћОДОаОЎОЋОф</translation>
<translation id="7538932151125743389">РђЈОДОеОЎОљОф ОъОАОцОеОЎОЮ ОАОЎОЊОЋОеОЎОЎОЮ ОЕОю ОъОЏОЕОЎОеОЎ ChromeOS ОЋОЕОю ОеОЏОЎОЉОЎОЮ.</translation>
<translation id="7540972813190816353">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОбОф ОЉОЊОЎОДОф ОбОЊОЏОЋОаОЎОЮ: <ph name="ERROR" /></translation>
<translation id="7541076351905098232">ОћОъОЏОЕОЎОе ОЕОюОџ ОћОЋОбОЉОе ОюОњОеОАОћ ОДОЋОЊОъОф ОбОю ОЎОЊОЎ <ph name="MANAGER" />. ОбОюОЎОџ ОюОЕОъОЋОе ОДОЉОдОЎОЮ ОЌОЕОЋОЉОЎОЮ ОЋОюОћОцОбОЎОю ОљОЋОфОЋ ОъОЌОЊОЕ. ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОЉОъОЏОЕОЎОе ОЎОЎОъОЌОДОЋ.</translation>
<translation id="7541773865713908457"><ph name="ACTION_NAME" /> ОбОЮ ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /></translation>
<translation id="754207240458482646">ОћОАОаОЏОеОЋОЪ ОбОЮ ОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉОЋОдОб. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="7543104066686362383">ОЎОЕ ОюОћОцОбОЎОю ОфОЏОЋОаОЋОф ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОъОЏОЕОЎОе <ph name="IDS_SHORT_PRODUCT_NAME" /> ОќОћ</translation>
<translation id="7543525346216957623">ОЎОЕ ОюОЉОДОЕ ОеОЕОЋОф ОъОћОћОЋОеОЎОЮ</translation>
<translation id="7545466883021407599">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОЕОеОф. ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОеОЕОф ОЋОюОаОАОЋОф ОЕОЋОЉ. ОљОЮ ОћОЉОбОЎОћ ОаОъОЕОЏОф, ОЏОЊОљОЎ ОюОаОАОЋОф ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Оћ-Chromebook. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="7547317915858803630">ОљОќОћОеОћ: ОћОњОЊОеОЋОф <ph name="PRODUCT_NAME" /> ОЕОюОџ ОъОљОЋОЌОАОаОЋОф ОЉОЏОЋОаОЪ ОеОЕОф. ОЊОЉОе ОќОћ ОбОЕОЋОЎ ОюОњОеОЋОЮ ОюОћОљОўОЋОф, ОюОДОеОЎОАОЋОф ОЋОљОцОЎОюОЋ ОюОљОЋОЉОЊОЪ ОаОфОЋОаОЎОЮ.</translation>
<translation id="7548856833046333824">ОюОЎОъОЋОаОЊОћ</translation>
<translation id="7550830279652415241">bookmarks_<ph name="DATESTAMP" />.html</translation>
<translation id="7551059576287086432">ОћОћОЋОеОЊОћ ОЕОю <ph name="FILE_NAME" /> ОћОдОюОЎОЌОћ</translation>
<translation id="7551643184018910560">ОћОдОъОЊОћ ОюОъОЊОБ</translation>
<translation id="7552846755917812628">ОљОЋОюОЎ ОћОўОЎОцОЎОЮ ОћОљОюОЋ ОЎОбОќОеОЋ ОюОџ:</translation>
<translation id="7553012839257224005">РђЈОћОъОбОеОЏОф ОЉОЋОЊОДОф ОљОф ОћОДОЋОаОўОЎОЎОаОе ОЕОю Linux</translation>
<translation id="7553242001898162573">ОћОќОаОф ОћОАОЎОАОъОћ</translation>
<translation id="755472745191515939">ОћОЕОцОћ ОћОќОЋ ОюОљ ОъОљОЋОЕОеОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="7554791636758816595">ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="7556033326131260574">РђЈОъОбОеОЏОф Smart Lock ОюОљ ОћОдОюОЎОЌОћ ОюОљОъОф ОљОф ОЌОЕОЉОЋОаОџ. ОЏОЊОЎ ОюОћОЎОЏОаОА, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ.</translation>
<translation id="7556242789364317684">РђЈОюОдОбОеОаОЋ, <ph name="SHORT_PRODUCT_NAME" /> ОюОљ ОЎОЏОЋОю ОюОЕОЌОќОе ОљОф ОћОћОњОЊОеОЋОф ОЕОюОџ. ОЏОЊОЎ ОюОфОДОЪ ОљОф ОћОЕОњОЎОљОћ, <ph name="SHORT_PRODUCT_NAME" /> ОдОеОЎОџ ОюОљОцОА ОљОф ОћОъОЏОЕОЎОе ОЕОюОџ ОЉОљОъОдОбОЋОф Powerwash.</translation>
<translation id="7557194624273628371">РђЈОћОбОЉОеОћ ОюОЎОдОЎОљОћ ОљОЌОеОф ОЉ-Linux</translation>
<translation id="7557411183415085169">РђЈОљОЎОЪ ОъОАОцОЎОД ОаОцОЌ ОљОЌОАОЋОЪ ОбОЉОЋОе Linux</translation>
<translation id="7559719679815339381">ОЎОЕ ОюОћОъОфОЎОЪ....ОъОфОЉОдОб ОбОЊОЏОЋОЪ ОЕОю ОљОцОюОЎОДОдОЎОф ОћОДОЎОЋОАОД. ОљОЎОЪ ОюОћОАОЎОе ОљОф ОћОЊОЎОАОД ОљОЋОЪ ОДОЎ.</translation>
<translation id="7560756177962144929">ОАОаОЏОеОЋОЪ ОЕОю <ph name="DEVICE_TYPE" /></translation>
<translation id="7561196759112975576">ОфОъОЎОЊ</translation>
<translation id="7562099761826673163">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОъОЏОЕОЎОе</translation>
<translation id="756445078718366910">ОцОфОЎОЌОф ОЌОюОЋОЪ ОЊОцОЊОцОЪ</translation>
<translation id="7564847347806291057">ОАОЎОЋОЮ ОћОфОћОюОЎОџ</translation>
<translation id="756503097602602175">РђЈОЉ<ph name="LINK_BEGIN" />ОћОњОЊОеОЋОф<ph name="LINK_END" /> ОљОцОЕОе ОюОаОћОю ОљОф ОЌОЕОЉОЋОаОЋОф Google ОћОъОЌОЋОЉОеОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОеОЕОљОЋОф ОЕОаОфОф ОюОљОфОеОЎОЮ ОЋОюОљОцОюОЎОДОдОЎОЋОф ОЎОЌОЋОюОЋ ОбОю ОЏОю ОћОЌОЕОЉОЋОаОЋОф. ОљОЮ ОљОЎОаОџ ОеОЋОдОћ ОЕОюОљОфОеОЎОЮ ОљОЋ ОюОљОцОюОЎОДОдОЎОЋОф ОфОћОЎОћ ОњОЎОЕОћ ОюОцОеОўОЎ ОћОЌОЕОЉОЋОЪ ОЕОюОџ, ОаОЎОфОЪ ОюОћОЎОЏОаОА ОљОю <ph name="DEVICE_TYPE" /> ОЏОљОЋОеОЌ ОљОЋ ОюОњОюОЋОЕ ОЉОљОЎОаОўОеОаОў ОЉ<ph name="LINK_2_BEGIN" />ОЌОюОЋОЪ ОљОаОЋОаОЎОъОЎ<ph name="LINK_2_END" />.</translation>
<translation id="7566118625369982896">РђЈОаОЎОћОЋОю ОДОЎОЕОЋОеОЎОЮ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Оъ-Play</translation>
<translation id="756809126120519699">РђЈОаОфОЋОаОЎ Chrome ОаОЋОДОЋ</translation>
<translation id="756876171895853918">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОЊОъОЋОф</translation>
<translation id="7568790562536448087">ОћОбОЊОЏОЋОЪ ОъОфОЉОдОб</translation>
<translation id="7569983096843329377">ОЕОЌОЋОе</translation>
<translation id="7571643774869182231">ОљОЎОЪ ОъОАОцОЎОД ОЕОўОЌ ОљОЌОАОЋОЪ ОюОбОЊОЏОЋОЪ</translation>
<translation id="7573172247376861652">ОўОбОЎОаОф ОАОЋОюОюОћ</translation>
<translation id="7573594921350120855">ОљОфОеОЎОЮ ОъОЕОфОъОЕОЎОЮ ОЉОЊОеОџ ОЏОюОю ОЉОъОдОюОъОф ОћОЋОЋОЎОЊОљОЋ ОЏОЊОЎ ОюОфОъОЋОџ ОЉОфОЏОЋОаОЋОф ОфОДОЕОЋОеОф ОЏОъОЋ ОЋОЎОЊОљОЋ Од'ОљОў</translation>
<translation id="7574650250151586813">РђЈОЏОЊОЎ ОюОћОДОюОЎОЊ ОўОДОАОў ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф ОћОљОцОюОЎОДОдОЎОћ 'ОъОДОюОЊОф Daydream'</translation>
<translation id="7574676002608048667">ОЕОюОЎОЌОф ОћОАОЎОАОъОћ</translation>
<translation id="7576690715254076113">ОљОЎОАОЋОБ</translation>
<translation id="7576976045740938453">ОћОфОеОЌОЕОћ ОЉОбОЎОћ ОЕОДОЕОЋОеОћ ОюОЌОЕОЉОЋОЪ ОъОдОЉ ОћОћОЊОњОъОћ.</translation>
<translation id="7578137152457315135">ОћОњОЊОеОЋОф ОЕОю ОўОЉОЎОбОЋОф ОљОдОЉОбОЋОф</translation>
<translation id="7578692661782707876">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОЕОюОџ.</translation>
<translation id="7580671184200851182">ОљОаОЎ ОеОЋОдОћ ОюОћОЕОъОЎОб ОљОф ОљОЋОфОЋ ОљОЋОЊОЎОЋ ОъОЏОю ОћОеОъОДОЋОюОЎОЮ (ОљОЋОЊОЎОЋ ОъОЋОаОЋ)</translation>
<translation id="7581007437437492586">ОЎОЕ ОюОћОњОЊОЎОе ОљОф ОћОъОЊОЎОаОЎОЋОф ОЏОеОљОЋОЎ</translation>
<translation id="7581462281756524039">ОЏОюОЎ ОюОаОЎОДОЋОЎ</translation>
<translation id="7582582252461552277">ОћОбОЊОцОф ОћОеОЕОф ОћОќОЋ</translation>
<translation id="7582844466922312471">ОаОфОЋОаОЎОЮ ОАОюОЋОюОеОЎОЎОЮ</translation>
<translation id="7583948862126372804">ОъОАОцОе</translation>
<translation id="7586498138629385861">РђЈChrome ОЎОъОЕОЎОџ ОюОцОбОЋОю ОЏОю ОбОЋОЊ ОЎОЕ ОљОцОюОЎОДОдОЎОЋОф Chrome ОцОфОЋОЌОЋОф.</translation>
<translation id="758895749110326677">РђЈОљОцОЕОе ОюОбОќОЋОе ОюОаОЋ ОюОћОЕОфОцОе ОЉОфОЌОЋОЮ ОћОњОЎОЎОъОЎОаОњ ОЉОъОЏОЕОЎОеОЎ Chromebook</translation>
<translation id="7589461650300748890">ОћОЎОЎ! ОќОћОЎОеОЋОф.</translation>
<translation id="7593653750169415785">ОћОљОцОЕОеОЋОф ОЌОАОЋОъОћ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЏОЎ ОЉОЌОеОф ОЉОбОЉОе ОЕОюОљ ОюОфОф ОћОеОЕОљОћ ОюОћОдОњОф ОћОЋОЊОбОЋОф ОЏОъОћ ОцОбОъОЎОЮ</translation>
<translation id="7594725637786616550">РђЈОЎОЕ ОюОЉОдОб Powerwash ОЏОЊОЎ ОюОљОфОЌОю ОљОф Оћ-<ph name="DEVICE_TYPE" /> ОЕОюОџ, ОЏОџ ОЕОЎОћОЎОћ ОЏОъОЋ ОъОЏОЕОЎОе ОЌОЊОЕ.</translation>
<translation id="7595453277607160340">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОЋОф ОЕОю Android ОЋОюОЋОЋОЊОљ ОЕОћ-<ph name="DEVICE_TYPE" /> ОЎОъОЕОЎОџ ОюОцОбОЋОю ОЏОеОљОЋОЎ, ОдОеОЎОџ ОюОћОЎОЏОаОА ОЕОЋОЉ ОЋОюОбОЊОЏОЪ.</translation>
<translation id="7595547011743502844"><ph name="ERROR" /> (ОДОЋОЊ ОЕОњОЎОљОћ <ph name="ERROR_CODE" />).</translation>
<translation id="7598466960084663009">ОћОцОбОюОф ОћОъОЌОЕОЉ ОъОЌОЊОЕ</translation>
<translation id="7599527631045201165">ОЕОЮ ОћОъОЏОЕОЎОе ОљОеОЋОџ ОъОЊОЎ. ОЎОЕ ОюОћОќОЎОЪ ОЕОЮ ОДОдОе ОЎОЋОфОе ОЏОЊОЎ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7600054753482800821">ОаОЎОћОЋОю ОЕОю ОъОаОЋОбОЎ ОЌОЎОцОЋОЕ ОЋОЕОю ОћОЌОЎОцОЋОЕ ОЉОљОфОеОЎОЮ ОАОцОдОЎОцОЎОЎОЮ</translation>
<translation id="7600965453749440009">ОљОЎОаОЎ ОеОЋОдОћ ОюОДОЉОю ОфОеОњОЋОЮ Оъ<ph name="LANGUAGE" /> ОЉОЏОюОю</translation>
<translation id="760197030861754408">ОЏОЊОЎ ОюОћОфОЌОЉОе, ОЎОЕ ОюОбОЉОЋОе ОљОю <ph name="LANDING_PAGE" />.</translation>
<translation id="7602079150116086782">ОљОЎОЪ ОЏОеОўОЎОАОЎОЋОф ОъОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="7602173054665172958">ОаОЎОћОЋОю ОћОЊОцОАОћ</translation>
<translation id="7603785829538808504">ОћОљОфОеОЎОЮ ОЉОеОЕОЎОъОћ ОћОЉОљОћ ОцОЋОбОюОЎОЮ ОюОцОЎ ОћОњОЊОеОћ ОъОЋОфОљОъОф ОљОЎОЕОЎОф</translation>
<translation id="7605594153474022051">ОћОАОаОЏОеОЋОЪ ОюОљ ОбОЋОЉОЊ</translation>
<translation id="7606248551867844312">ОљОЎОЕОЋОе ОћОЌОЎОфОЋОџ</translation>
<translation id="7606560865764296217">ОћОЕОћОЎОЎОф ОћОљОаОЎОъОдОЎОћ</translation>
<translation id="7606992457248886637">ОеОЕОЋОЎОЋОф</translation>
<translation id="7607002721634913082">ОћОћОЋОеОЊОћ ОЉОћОЕОћОЎОћ</translation>
<translation id="7608810328871051088">РђЈОћОбОЊОцОЋОф Android</translation>
<translation id="7609148976235050828">ОдОеОЎОџ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7612655942094160088">ОћОцОбОюОф ОфОЏОЋОаОЋОф ОћОўОюОцОЋОЪ ОћОъОДОЋОЕОе.</translation>
<translation id="7614260613810441905">ОфОЋОдОњ ОЕОљОюОћ ОЏОЕОљОфОе ОЎОеОдОћ ОюОбОеОЋОџ ОДОЉОдОЎОЮ ОљОЋ ОфОЎОДОЎОЋОф ОЉОъОЏОЕОЎОе ОЕОюОџ (ОъОЋОъОюОЦ)</translation>
<translation id="761530003705945209">РђЈОњОЎОЉОЋОЎ ОЉ-Google Drive. ОћОћОњОЊОеОћ ОћОќОЋ ОъОљОцОЕОеОф ОюОљОЌОќОе ОаОфОЋОаОЎОЮ ОЉОДОюОЋОф ОљОЋ ОюОбОЉОЋОе ОюОъОЏОЕОЎОе ОљОЌОе ОЉОЏОю ОЕОюОЉ. ОћОњОЎОЉОЋОЎ ОЏОЋОюОю ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф. ОћОњОЎОЉОЋОЎОЎОЮ ОаОЕОъОеОЎОЮ ОЉ-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОћОАОЎОАОъОћ ОЕОю ОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="7615365294369022248">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОћОЋОАОцОф ОЌОЕОЉОЋОЪ</translation>
<translation id="7616214729753637086">ОеОЎОЕОЋОЮ ОћОъОЏОЕОЎОе ОъОфОЉОдОб...</translation>
<translation id="7617263010641145920">РђЈОћОцОбОюОћ ОЕОю ОЌОаОЋОф Play</translation>
<translation id="7617366389578322136">ОъОфОЉОдОб ОЌОЎОЉОЋОе ОљОю <ph name="DEVICE_NAME" /></translation>
<translation id="7617648809369507487">ОЕОЎОъОЋОЕ ОЉОъОдОЉ ОЕОДОў ОЎОЋОфОе ОЕОю ОћОбОЉОеОф ОћОЋОЊОбОЋОф</translation>
<translation id="7621382409404463535">ОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОЕОъОЋОе ОљОф ОфОдОЋОеОф ОћОъОЏОЕОЎОе.</translation>
<translation id="7622114377921274169">ОЉОўОбОЎОаОћ.</translation>
<translation id="7622768823216805500">РђЈОљОфОеОЎОЮ ОъОфОДОЎОаОЎОЮ ОЉОЊОеОџ ОЏОюОю ОеОЏОЎОЉОЎ handler ОЕОю ОфОЕОюОЋОъОЎОЮ ОЏОЊОЎ ОюОћОдОЎОб ОфОЏОЋОаОЋОф ОДОаОЎОЎОћ, ОЏОъОЋ ОфОЕОюОЋОЮ ОДОю ОЎОЋОфОе ОЉОДОЋОцОћ</translation>
<translation id="7622903810087708234">ОцОеОўОЎ ОАОЎОАОъОћ</translation>
<translation id="7622966771025050155">ОюОЏОеОўОЎОАОЎОЎОћ ОћОъОЋОДОюОўОф</translation>
<translation id="7624337243375417909">РђЈcaps lock ОъОЋОЕОЉОф</translation>
<translation id="7625568159987162309">ОћОдОњОф ОћОеОЕОљОЋОф ОЋОаОфОЋОаОЎОЮ ОћОъОљОЋОЌОАОаОЎОЮ ОЉОљОфОеОЎОЮ ОЕОЋОаОЎОЮ</translation>
<translation id="7625823789272218216">ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОъОдОЊ ОЎОъОЎОЪ</translation>
<translation id="7626032353295482388">РђЈОЉОеОЋОџ ОЉОЋОљОџ ОљОю Chrome</translation>
<translation id="7628201176665550262">ОДОдОЉ ОеОбОаОЋОЪ</translation>
<translation id="7629827748548208700">ОЏОеОўОЎОАОЎОЎОћ: <ph name="TAB_NAME" /></translation>
<translation id="7630426712700473382">ОћОъОЏОЕОЎОе ОћОќОћ ОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="MANAGER" />, ОЋОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОЋ ОдОеОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЉОЏОю ОцОбОЮ.</translation>
<translation id="7631014249255418691">РђЈОћОДОЉОдОЎОЮ ОЋОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Linux ОбОЉОеОЋ ОњОЎОЉОЋОЎ ОЉОћОдОюОЌОћ.</translation>
<translation id="7631205654593498032">ОЌОЎОЉОЋОе ОћОъОЏОЕОЎОеОЎОЮ ОъОЉОўОљ ОљОф ОћОАОЏОъОфОџ ОюОЏОџ ОЕОћ-<ph name="DEVICE_TYPE" /> ОЎОЋОЏОю ОюОЉОдОб ОљОф ОћОцОбОЋОюОЋОф ОћОЉОљОЋОф:</translation>
<translation id="7631887513477658702">&amp;ОцОфОЎОЌОф ОДОЉОдОЎОЮ ОъОАОЋОњ ОќОћ ОфОъОЎОЊ</translation>
<translation id="7632948528260659758">ОбОЊОЏОЋОЪ ОЎОЎОЕОЋОъОЎ ОћОДОЎОЋОАОД ОћОЉОљОЎОЮ ОаОЏОЕОю:</translation>
<translation id="7633724038415831385">РђЈОљОЌОеОЎ ОбОЊОЏОЋОЪ ОќОћ, ОЏОЉОе ОюОљ ОЎОћОЎОћ ОдОЋОеОџ ОюОћОъОфОЎОЪ ОюОбОЊОЏОЋОаОЎОЮ. ОЉОъОЏОЕОЎОеОЎ Chromebook, ОбОЊОЏОЋОаОЎ ОћОфОЋОЏОаОЋОф ОъОфОЉОдОбОЎОЮ ОЉОеОДОб.</translation>
<translation id="7634280112532283638">ОћОцОЌОфОф ОАОцОљОЮ ОЋОћОЋОаОљОЋОф</translation>
<translation id="7634566076839829401">ОъОЕОћОЋ ОћОЕОфОЉОЕ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7635048370253485243">ОъОаОћОю ОћОъОбОеОЏОф ОћОдОъОЎОЊ ОљОф ОћОфОЋОАОБ ОћОќОћ</translation>
<translation id="7636919061354591437">ОћОфОДОаОћ ОЉОъОЏОЕОЎОе ОќОћ</translation>
<translation id="7637593984496473097">ОљОЎОЪ ОъОАОцОЎОД ОаОцОЌ ОљОЌОАОЋОЪ ОЉОЊОЎОАОД</translation>
<translation id="7639914187072011620">РђЈОаОЏОЕОю ОћОаОЎОАОЎОЋОЪ ОюОљОЌОќОе ОљОф ОћОћОцОаОЎОћ ОћОљОЋОўОЋОъОўОЎОф ОљОю SAML ОъОћОЕОеОф</translation>
<translation id="764017888128728"><ph name="PASSWORD_MANAGER_BRAND" /> ОъОЏОаОЎОА ОљОЋОфОџ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОюОљОфОеОЎОЮ ОЏОЕОЎОеОЎОЮ ОЉОљОъОдОбОЋОф ОАОЎОАОъОљОЋОф ОЕОЕОъОеОф.</translation>
<translation id="7641513591566880111">ОћОЕОЮ ОЕОю ОћОцОеОЋОцОЎОю ОћОЌОЊОЕ</translation>
<translation id="764178579712141045">ОћОЋОАОцОф ОљОф <ph name="USER_EMAIL" /></translation>
