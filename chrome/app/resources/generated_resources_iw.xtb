<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1001033507375626788">ОћОеОЕОф ОћОќОЋ ОъОЕОЋОфОцОф ОљОЎОфОџ</translation>
<translation id="1003088604756913841">ОцОфОЎОЌОф ОћОДОЎОЕОЋОе ОЉОЌОюОЋОЪ ОЌОЊОЕ ОЕОю <ph name="APP" /></translation>
<translation id="100323615638474026">РђЈОћОфОДОЪ USB (<ph name="VENDOR_ID" />:<ph name="PRODUCT_ID" />)</translation>
<translation id="1004218526896219317">ОњОЎОЕОћ ОюОљОфОеОЎОЮ</translation>
<translation id="1005274289863221750">ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ ОЋОЉОъОдОюОъОћ</translation>
<translation id="1005333234656240382">РђЈОюОћОцОбОЎОю ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB?</translation>
<translation id="1006873397406093306">ОћОфОЋОАОБ ОћОќОћ ОЎОЏОЋОю ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ. ОљОцОЕОе ОюОДОЉОЋОб ОюОљОЎОюОЋ ОљОфОеОЎОЮ ОћОфОЋОАОБ ОЎОЏОЋОю ОюОњОЕОф.</translation>
<translation id="1008186147501209563">ОЎОЎОдОЋОљ ОАОЎОъОаОЎОЋОф</translation>
<translation id="1008557486741366299">ОюОљ ОбОЏОЕОЎОЋ</translation>
<translation id="1009476156254802388">ОъОЎОДОЋОЮ ОЉ-<ph name="WEB_DRIVE" /></translation>
<translation id="1010498023906173788">ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОъОЌОЋОЉОеОф ОюОЎОдОЎОљОћ ОўОЋОеОЎОф.</translation>
<translation id="1010833424573920260">{NUM_PAGES,plural, =1{ОћОЊОБ ОљОЎОаОЋ ОъОњОЎОЉ}two{ОћОЊОцОЎОЮ ОљОЎОаОЮ ОъОњОЎОЉОЎОЮ}many{ОћОЊОцОЎОЮ ОљОЎОаОЮ ОъОњОЎОЉОЎОЮ}other{ОћОЊОцОЎОЮ ОљОЎОаОЮ ОъОњОЎОЉОЎОЮ}}</translation>
<translation id="1011355516189274711">РђЈОбОЋОдОъОф ОДОЋОю ОЕОю ОћОъОеОф ОўОДОАОў ОюОЊОЎОЉОЋОе (TTS)</translation>
<translation id="1012794136286421601">РђЈОДОЋОЉОдОЎ ОћОъОАОъОЏОЎОЮ, ОћОњОЎОюОЎОЋОаОЋОф, ОћОЕОДОцОЎОЮ ОЋОћОЕОеОўОЋОўОЎОЮ ОъОАОфОаОЏОеОаОЎОЮ ОЏОбОф. ОЎОЕ ОюОцОфОЋОЌ ОљОф ОћОЎОЎОЕОЋОЮ Google Drive ОЏОЊОЎ ОюОњОЕОф ОљОюОЎОћОЮ ОљОЋОаОюОЎОЎОЪ ОљОЋ ОљОЋОцОюОЎОЎОЪ.</translation>
<translation id="1012876632442809908">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОДОЊОъОЎОф)</translation>
<translation id="1015041505466489552">TrackPoint</translation>
<translation id="1015318665228971643">ОбОеОЎОЏОф ОЕОЮ ОћОфОЎОДОЎОЎОћ</translation>
<translation id="1015578595646638936">{NUM_DAYS,plural, =1{ОћОЎОЋОЮ ОћОљОЌОеОЋОЪ ОюОбОЊОЏОЋОЪ ОЕОю <ph name="DEVICE_TYPE" />}two{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ ОЎОЋОъОЎОЎОЮ ({NUM_DAYS})}many{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_DAYS} ОЎОъОЎОЮ}other{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_DAYS} ОЎОъОЎОЮ}}</translation>
<translation id="1016566241875885511">ОъОЎОЊОб ОаОЋОАОБ (ОљОЋОцОдОЎОЋОаОюОЎ)</translation>
<translation id="1017280919048282932">&amp;ОћОЋОАОцОћ ОюОъОЎОюОЋОЪ</translation>
<translation id="1018656279737460067">ОЉОЋОўОю</translation>
<translation id="1022489261739821355">РђЈОћОдОњОћ ОЕОю ОАОЎОАОъОљОЋОф Оъ<ph name="BEGIN_LINK" />ОЌОЕОЉОЋОЪ Google<ph name="END_LINK" /> ОЕОюОџ</translation>
<translation id="1026655690966755180">ОћОЋОАОцОф ОЎОдОЎОљОћ</translation>
<translation id="1026822031284433028">ОўОбОЎОаОф ОфОъОЋОаОћ</translation>
<translation id="1029317248976101138">ОћОфОДОеОЉОЋОф ОюОфОдОЋОњОћ</translation>
<translation id="1031362278801463162">ОўОбОЎОаОф ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОъОфОЉОдОбОф</translation>
<translation id="1032605640136438169">ОЎОЕ ОюОДОеОЋОљ ОљОф ОћОфОаОљОЎОЮ ОћОЌОЊОЕОЎОЮ</translation>
<translation id="103279545524624934">РђЈОбОюОЎОџ ОюОцОаОЋОф ОаОцОЌ ОљОЌОАОЋОЪ ОЏОЊОЎ ОюОћОцОбОЎОю ОљОцОюОЎОДОдОЎОЋОф Android.</translation>
<translation id="1033780634303702874">ОњОЎОЕОћ ОюОћОфОДОаОЎОЮ ОћОАОЎОеОЎОљОюОЎОЎОЮ ОЕОюОџ</translation>
<translation id="1034484273907870301">ОЕОЋОеОф ОЏОеОўОЎОАОЎОЋОф ОбОЮ ОфОъОЋОаОЋОф ОъОъОЋОќОбОеОЋОф ОюОъОдОЉ ОўОљОЉОюОў</translation>
<translation id="1036348656032585052">ОЏОЎОЉОЋОЎ</translation>
<translation id="1036511912703768636">РђЈОњОЎОЕОћ ОюОЏОю ОљОЌОЊ ОъОћОфОДОаОЎ Оћ-USB ОћОљОюОћ</translation>
<translation id="1038168778161626396">ОћОдОцОаОћ ОЉОюОЉОЊ</translation>
<translation id="1038462104119736705">РђЈОъОЋОъОюОЦ ОЕОЕОўОЌ ОћОљОЌОАОЋОЪ ОћОцОаОЋОЎ ОЎОћОЎОћ <ph name="INSTALL_SIZE" /> ОюОцОЌОЋОф ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-Linux. ОЏОЊОЎ ОюОцОаОЋОф ОЕОўОЌ ОљОЌОАОЋОЪ, ОЎОЕ ОюОъОЌОЋОД ОДОЉОдОЎОЮ ОъОћОъОЏОЕОЎОе.</translation>
<translation id="1039337018183941703">ОћОДОЋОЉОЦ ОюОљ ОЌОЋОДОЎ, ОљОЋ ОЕОћОЋОљ ОцОњОЋОЮ</translation>
<translation id="1041175011127912238">ОћОЊОБ ОюОљ ОъОњОЎОЉ</translation>
<translation id="1041263367839475438">ОъОЏОЕОЎОеОЎОЮ ОќОъОЎОаОЎОЮ</translation>
<translation id="1042174272890264476">РђЈОћОъОЌОЕОЉ ОЕОюОџ ОъОњОЎОб ОњОЮ ОбОЮ ОАОцОеОЎОЎОф Оћ-RLZ ОћОъОЋОЉОаОћ ОЕОю <ph name="SHORT_PRODUCT_NAME" />РђЈ. RLZ ОъОДОдОћ ОфОњ ОЕОљОЎОаОЋ ОЎОЎОЌОЋОЊОЎ ОЋОљОЎОаОЋ ОаОЎОфОЪ ОюОќОЎОћОЋОЎ ОбОю ОъОаОф ОюОъОЊОЋОЊ ОљОф ОћОЌОЎОцОЋОЕ ОЋОљОф ОћОЕОЎОъОЋОЕ ОЉ-<ph name="SHORT_PRODUCT_NAME" /> ОћОъОЋОаОбОЎОЮ ОбОю ОЎОЊОЎ ОДОъОцОЎОЎОЪ ОАОцОдОЎОцОЎ ОюОДОЎОЊОЋОЮ ОъОЏОЎОеОЋОф. ОћОфОЋОЋОЎОЋОф ОћОљОюОћ ОъОЋОцОЎОбОЋОф ОюОбОфОЎОЮ ОЉОЕОљОЎОюОфОЋОф ОћОЌОЎОцОЋОЕ ОЕОю Google ОЉ-<ph name="PRODUCT_NAME" />.</translation>
<translation id="1043505821207197890">РђЈОъОЕОћОЋ ОћОЕОфОЉОЕ. ОћОЕОЊОеОЋОњ ОЕОю Linux ОбОЕОЋОЎ ОюОћОЎОЋОф ОЌОюОДОЎ ОЉОюОЉОЊ. ОљОцОЕОе ОюОЉОЊОЋОД ОЉОЎОЋОъОаОЎОЮ ОюОДОЉОюОф ОъОЎОЊОб ОаОЋОАОБ. ОћОЎОЋОъОаОЎОЮ ОаОЕОъОеОЋ ОЉ'ОДОЉОдОЎОЮ' &gt; 'ОћОДОЉОдОЎОЮ ОЕОюОЎ' &gt; <ph name="LOG_FILE" /></translation>
<translation id="1043818413152647937">ОюОаОДОЋОф ОаОфОЋОаОЎОЮ ОњОЮ ОъОћОљОцОюОЎОДОдОЎОЋОф ОћОЉОљОЋОф?</translation>
<translation id="1043824690776631483">ОЎОЕ ОдОЋОеОџ ОЉОћОеОЕОљОћ ОЏОЊОЎ ОюОћОЎОЏОаОА ОљОю ОћОљОфОе ОћОќОћ. ОЎОЎОфОЏОЪ ОЕОЎОЕ ОЉОЋ ОфОЋОЏОЪ ОЉОюОфОЎ ОћОЋОюОЮ.</translation>
<translation id="104710386808485638">РђЈОћОљОЮ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Linux?</translation>
<translation id="1047431265488717055">ОћОбОфОДОф Оў&amp;ОДОАОў ОДОЎОЕОЋОе</translation>
<translation id="1048286738600630630">ОфОдОЋОњОЋОф</translation>
<translation id="1048986595386481879">ОћОДОдОљОћ ОЊОЎОаОъОЎОф</translation>
<translation id="1049324577536766607">{COUNT,plural, =1{ОъОфОДОЉОю <ph name="ATTACHMENTS" /> Оъ-<ph name="DEVICE_NAME" />}two{ОъОфОДОЉОюОЎОЮ <ph name="ATTACHMENTS" /> Оъ-<ph name="DEVICE_NAME" />}many{ОъОфОДОЉОюОЎОЮ <ph name="ATTACHMENTS" /> Оъ-<ph name="DEVICE_NAME" />}other{ОъОфОДОЉОюОЎОЮ <ph name="ATTACHMENTS" /> Оъ-<ph name="DEVICE_NAME" />}}</translation>
<translation id="1049743911850919806">ОњОюОЎОЕОћ ОцОеОўОЎОф</translation>
<translation id="1049795001945932310">ОћОњОЊ&amp;ОеОЋОф ОЕОцОћ</translation>
<translation id="1050693411695664090">ОљОЎОЏОЋОф ОњОеОЋОбОћ</translation>
<translation id="1054048317165655285">ОЎОЕ ОюОћОЕОюОЎОЮ ОљОф ОћОћОњОЊОеОћ ОЉОўОюОцОЋОЪ</translation>
<translation id="1054153489933238809">ОцОфОЎОЌОф Оћ&amp;ОфОъОЋОаОћ ОћОъОДОЋОеОЎОф ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="1055274863771110134">{NUM_WEEKS,plural, =1{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ ОЕОЉОЋОб}two{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ ОЕОЉОЋОбОЎОЎОЮ ({NUM_WEEKS})}many{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_WEEKS} ОЕОЉОЋОбОЋОф}other{ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ {NUM_WEEKS} ОЕОЉОЋОбОЋОф}}</translation>
<translation id="1056898198331236512">ОљОќОћОеОћ</translation>
<translation id="1058262162121953039">PUK</translation>
<translation id="1059065096897445832">{MIN_PIN_LENGTH,plural, =1{ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОЌОЊОЕ. ОДОЋОЊ ОљОЎОъОЋОф ОЌОЎОЎОЉ ОюОћОЎОЋОф ОЉОљОЋОеОџ ОфОЋ ОљОЌОЊ ОюОцОЌОЋОф, ОЋОЎОЏОЋОю ОюОЏОюОЋОю ОљОЋОфОЎОЋОф, ОъОАОцОеОЎОЮ ОЋОфОЋОЋОЎОЮ ОљОЌОеОЎОЮ.}two{ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОЌОЊОЕ. ОДОЋОЊ ОљОЎОъОЋОф ОЌОЎОЎОЉ ОюОћОЎОЋОф ОЉОљОЋОеОџ # ОфОЋОЋОЎОЮ ОюОцОЌОЋОф, ОЋОЎОЏОЋОю ОюОЏОюОЋОю ОљОЋОфОЎОЋОф, ОъОАОцОеОЎОЮ ОЋОфОЋОЋОЎОЮ ОљОЌОеОЎОЮ.}many{ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОЌОЊОЕ. ОДОЋОЊ ОљОЎОъОЋОф ОЌОЎОЎОЉ ОюОћОЎОЋОф ОЉОљОЋОеОџ # ОфОЋОЋОЎОЮ ОюОцОЌОЋОф, ОЋОЎОЏОЋОю ОюОЏОюОЋОю ОљОЋОфОЎОЋОф, ОъОАОцОеОЎОЮ ОЋОфОЋОЋОЎОЮ ОљОЌОеОЎОЮ.}other{ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОЌОЊОЕ. ОДОЋОЊ ОљОЎОъОЋОф ОЌОЎОЎОЉ ОюОћОЎОЋОф ОЉОљОЋОеОџ # ОфОЋОЋОЎОЮ ОюОцОЌОЋОф, ОЋОЎОЏОЋОю ОюОЏОюОЋОю ОљОЋОфОЎОЋОф, ОъОАОцОеОЎОЮ ОЋОфОЋОЋОЎОЮ ОљОЌОеОЎОЮ.}}</translation>
<translation id="1059484610606223931">Hypertext Transport Protocol (HTTPS)</translation>
<translation id="1059944192885972544">ОаОъОдОљОЋ <ph name="NUM" /> ОЏОеОўОЎОАОЎОЋОф ОбОЉОЋОе '<ph name="SEARCH_TEXT" />'</translation>
<translation id="1060292118287751956">ОДОЉОЎОбОф ОћОфОЊОЎОеОЋОф ОЕОю ОеОбОаОЋОЪ ОћОъОАОџ</translation>
<translation id="1061130374843955397">ОўОЋОЉ ОюОеОљОЋОф ОљОЋОфОџ ОЉ-<ph name="DEVICE_TYPE" /></translation>
<translation id="1061373870045429865">РђЈОЎОЕ ОюОЎОдОЋОе ОДОЋОЊ QR ОюОДОЎОЕОЋОе ОћОќОћ</translation>
<translation id="1061904396131502319">ОбОЋОЊ ОъОбОў ОќОъОЪ ОюОћОцОАОДОћ</translation>
<translation id="1062628064301375934">ОеОЋОдОћ ОюОбОќОЋОе ОюОаОЋ ОюОЕОцОе ОљОф ОћОцОеОўОЎОЋОф ОЉОљОЎОаОўОеОаОў?</translation>
<translation id="1067048845568873861">ОаОЋОдОе</translation>
<translation id="1067922213147265141">РђЈОЕОЎОеОЋОфОЎ Google ОљОЌОеОЎОЮ</translation>
<translation id="1069355737714877171">РђЈОћОАОеОћ ОЕОю ОцОеОЋОцОЎОю Оћ-eSIM ОЕОаОДОеОљ <ph name="PROFILE_NAME" /></translation>
<translation id="1070377999570795893">РђЈОфОЋОЏОаОћ ОљОЌОеОф ОЉОъОЌОЕОЉ ОћОЋОАОЎОцОћ ОфОЋОАОБ ОЕОбОЕОЋОЎ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chrome.

<ph name="EXTENSION_NAME" /></translation>
<translation id="1070705170564860382">ОцОфОЎОЌОћ ОЉОЊОцОЊОцОЪ ОЌОюОЋОцОЎ ОЉОбОЋОЊ <ph name="COUNTDOWN_SECONDS" /> ОЕОаОЎОЋОф</translation>
<translation id="1071917609930274619">ОДОЎОЊОЋОЊ ОаОфОЋОаОЎОЮ</translation>
<translation id="1072700771426194907">РђЈОќОЋОћОћ ОћОфОДОЪ USB</translation>
<translation id="107278043869924952">ОЎОЕ ОюОћОЕОфОъОЕ ОЉОДОЋОЊ ОљОЎОъОЋОф ОЉОаОЋОАОБ ОюОАОЎОАОъОћ</translation>
<translation id="1073264809281558926">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОћОЏОЎОю ОъОЎОЊОб ОЏОъОЋ ОћОфОЏОЋОаОЋОф ОЕОЉОћОЪ ОаОбОЕОћ ОЕОЎОъОЋОЕ, ОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю ОЋОЏОЪ ОаОфОЋОаОЎ ОћОЕОЎОъОЋОЕ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Ою-Android. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОъОЏОЕОЎОе ChromeOS ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОюОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.<ph name="END_PARAGRAPH3" />
    <ph name="BEGIN_PARAGRAPH4" />ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОцОЋОбОюОф ОЉОЌОЕОЉОЋОЪ Google ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОаОфОЋОаОЎОЮ ОЕОюОћОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОћОЮ. ОЉОЏОфОЋОЉОф families.google.com ОЎОЕ ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОћОњОЊОеОЋОф ОћОљОюОћ ОЋОћОЋОеОљОЋОф ОюОЕОЎОаОЋОЎ ОЕОюОћОЪ.<ph name="END_PARAGRAPH4" />
    <ph name="BEGIN_PARAGRAPH4" />ОљОЮ ОЉОбОю ОћОъОЏОЕОЎОе ОъОцОбОЎОю ОљОф ОћОљОцОЕОеОЋОф 'ОЕОюОЎОЌОф ОъОЎОЊОб ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ', ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЊОЋОЌОЋОф ОДОеОЎОАОћ ОЎОЋОбОюОЋ ОљОю Google.<ph name="END_PARAGRAPH3" /></translation>
<translation id="1076176485976385390">ОаОЎОЋОЋОў ОЉОЊОцОЎОЮ ОЉОљОъОдОбОЋОф ОАОъОЪ ОћОўОДОАОў</translation>
<translation id="1076382954055048850">РђЈОћОдОњОф ОАОЕОаОЎОЮ ОљОЌОеОЎОЮ ОЕОю ОћОбОЉОеОћ (cast)</translation>
<translation id="1076698951459398590">ОћОцОбОюОф ОбОЎОдОЋОЉ</translation>
<translation id="1076766328672150609">ОюОЎОюОЊ ОљОЋ ОюОЎОюОЊОћ ОЕОюОџ ОЎОЕ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОДОЋОЊ ОљОЎОъОЋОф ОЏОЊОЎ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="1076818208934827215">Microsoft Internet Explorer</translation>
<translation id="1076882167394279216">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОЋОеОЎОЊ ОъОЎОюОЋОЪ ОЉОЊОЎОДОф ОљОЎОЋОф ОЉ<ph name="LANGUAGE" />. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="1079766198702302550">ОфОъОЎОЊ ОюОЌОАОЋОЮ ОњОЎОЕОћ ОюОъОдОюОъОћ</translation>
<translation id="1081956462909987459">{NUM_TABS,plural, =1{<ph name="GROUP_TITLE" /> РђЊ ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}two{<ph name="GROUP_TITLE" /> РђЊ # ОЏОеОўОЎОАОЎОЋОф}many{<ph name="GROUP_TITLE" /> РђЊ # ОЏОеОўОЎОАОЎОЋОф}other{<ph name="GROUP_TITLE" /> РђЊ # ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="1082214733466244292">ОцОЋОаОДОдОЎОЋОф ОъОАОЋОЎОъОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ ОаОЌОАОъОЋ ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="1082398631555931481">РђЈ<ph name="THIRD_PARTY_TOOL_NAME" /> ОеОЋОдОћ ОюОЕОЌОќОе ОљОф ОћОњОЊОеОЋОф Chrome ОюОЉОеОЎОеОф ОћОъОЌОЊОю ОћОъОДОЋОеОЎОф ОЕОюОћОЪ. ОћОцОбОЋОюОћ ОћОќОЋ ОфОњОеОЋОЮ ОюОљОЎОцОЋОА ОЊОБ ОћОЉОЎОф, ОЊОБ ОћОЏОеОўОЎОАОЎОЎОћ ОћОЌОЊОЕОћ ОЋОъОаОЋОб ОћОЌОЎОцОЋОЕ, ОфОЕОЉОЎОф ОљОф ОћОфОЋОАОцОЎОЮ, ОЋОфОЉОўОю ОљОф ОћОћОдОъОЊОћ ОЕОю ОЏОю ОћОЏОеОўОЎОАОЎОЋОф. ОЏОфОЋОдОљОћ ОъОЏОџ ОЎОЎОъОЌОДОЋ ОњОЮ ОаОфОЋОаОЎОЮ ОљОЌОеОЎОЮ ОъОљОЌОАОЋОЪ ОќОъОаОЎ ОЋОъОћОДОЋОЉОЦ ОћОЕОъОЋОе, ОЏОъОЋ ОаОфОЋОаОЎОЮ ОЕОю ОДОЋОЉОдОЎ cookie, ОфОЋОЏОЪ ОЋОљОфОеОЎОЮ.</translation>
<translation id="1084096383128641877">ОћОАОеОф ОћОАОЎОАОъОћ ОћОќОЋ ОюОљ ОфОњОеОЋОЮ ОюОъОЌОЎОДОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-<ph name="DOMAIN" />. ОЏОЊОЎ ОюОъОаОЋОб ОљОф ОћОЌОЕОЎОцОћ ОЕОю ОћОАОЎОАОъОћ, ОЏОЊОљОЎ ОюОЕОаОЋОф ОљОЋОфОћ ОљОЋ ОюОъОЌОЋОД ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-<ph name="DOMAIN_LINK" />.</translation>
<translation id="1084824384139382525">ОћОбОфОДОф ОЏОфОЋ&amp;ОЉОф ОДОЎОЕОЋОе</translation>
<translation id="1085064499066015002">ОцОЋОбОю ОЏОю ОћОќОъОЪ ОЉОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="1085697365578766383">ОДОеОфОћ ОЕОњОЎОљОћ ОЉОћОцОбОюОф ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="1087965115100412394">РђЈОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОеОЎ MIDI</translation>
<translation id="1088654056000736875">РђЈChrome ОъОАОЎОе ОЏОбОф ОфОЋОЏОаОћ ОъОќОЎОДОћ ОъОћОъОЌОЕОЉ ОЕОюОџРђд</translation>
<translation id="1088659085457112967">ОЏОаОЎОАОћ ОюОъОдОЉ ОДОЋОеОљ</translation>
<translation id="1090126737595388931">ОљОЎОЪ ОЎОЎОЕОЋОъОЎОЮ ОцОЋОбОюОЎОЮ ОЉОеОДОб</translation>
<translation id="1090541560108055381">ОюОцОаОЎ ОћОћОфОљОъОћ ОдОеОЎОџ ОюОЋОЋОЊОљ ОЕОъОЕОфОъОЕОЎОЮ ОЉОљОЋОфОЋ ОДОЋОЊ ОЉОЕОаОЎ ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="1091767800771861448">РђЈОЎОЕ ОюОћОДОЎОЕ ОбОю ESCAPE ОЏОЊОЎ ОюОЊОюОњ (ОњОеОАОљОЋОф ОюОљ ОеОЕОъОЎОЋОф ОЉОюОЉОЊ).</translation>
<translation id="1093457606523402488">ОеОЕОфОЋОф ОњОюОЋОЎОЋОф:</translation>
<translation id="1094607894174825014">ОцОбОЋОюОф ОДОеОЎОљОћ ОљОЋ ОЏОфОЎОЉОћ ОћОфОЉОДОЕОћ ОбОЮ ОћОЎОАОў ОюОљ ОЌОЋОДОЎ ОЉОъОЏОЕОЎОе: "<ph name="DEVICE_NAME" />".</translation>
<translation id="1095761715416917775">ОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОаОЎОфОЪ ОюОњОЕОф ОюОаОфОЋОаОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ ОЉОЏОю ОеОњОб</translation>
<translation id="109647177154844434">РђЈОћОАОеОф ОћОћОфОДОаОћ ОЕОю Parallels Desktop ОфОъОЌОД ОљОф ОДОЋОЉОЦ ОћОљОЎОъОњ' ОЕОю Windows. ОћОъОЌОЎОДОћ ОЏОЋОюОюОф ОљОф ОЏОю ОћОљОцОюОЎОДОдОЎОЋОф, ОћОћОњОЊОеОЋОф ОЋОћОаОфОЋОаОЎОЮ. ОюОћОъОЕОЎОџ?</translation>
<translation id="1097658378307015415">ОюОцОаОЎ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОЎОЕ ОюОћОЎОЏОаОА ОЏОљОЋОеОЌ ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОћОеОЕОф <ph name="NETWORK_ID" /></translation>
<translation id="1099383081182863812">РђЈОћОљОЮ Оћ-Chromecast ОЕОюОџ ОъОЋОцОЎОб
    <ph name="BEGIN_LINK" />
    ОЉОљОцОюОЎОДОдОЎОћ Google Home<ph name="END_LINK" />?</translation>
<translation id="1099962274138857708">ОћОфОъОЋОаОћ ОћОЋОбОфОДОћ ОъОћОъОЏОЕОЎОе ОћОЉОљ: <ph name="DEVICE_NAME" /></translation>
<translation id="1100504063505580045">ОћОАОъОю ОћОаОЋОЏОЌОЎ</translation>
<translation id="1102790815296970136">ОЏОљОЪ ОаОЎОфОЪ ОюОбОЎОЎОЪ ОЉ'<ph name="PERSONALIZED_MEMORY_TITLE" />' ОЋОЉОќОЎОЏОеОЋОаОЋОф ОаОЋОАОцОЎОЮ</translation>
<translation id="1103523840287552314">ОЉОеОдОЋОаОЎ ОюОДОЉОю ОфОеОњОЋОЮ Оъ<ph name="LANGUAGE" /> ОфОъОЎОЊ</translation>
<translation id="1108600514891325577">&amp;ОћОцОАОДОћ</translation>
<translation id="1108938384783527433">ОАОаОЏОеОЋОЪ ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="1110155001042129815">ОЎОЕ ОюОћОъОфОЎОЪ</translation>
<translation id="1110965959145884739">ОдОеОЎОџ ОюОЉОЌОЋОе ОљОф ОћОЕОцОЋОф ОЕОеОЋОдОЎОЮ ОюОћОњОЊОЎОе ОЉОъОЏОЕОЎОе ОћОќОћ. ОДОЋОЉОдОЎ ОћОЕОцОћ ОъОЕОЋОфОцОЎОЮ ОбОЮ ОъОЕОфОъОЕОЎОЮ ОЏОЊОЎ ОюОЌОАОЋОџ ОъОДОЋОЮ ОЉОЏОЋОаОЪ. <ph name="BEGIN_LINK_LEARN_MORE" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK_LEARN_MORE" /></translation>
<translation id="1112420131909513020">РђЈОЏОеОўОЎОАОЎОЎОф ОћОеОДОб ОъОЕОфОъОЕОф ОЉ-Bluetooth</translation>
<translation id="1113892970288677790">ОЉОЌОЎОеОф ОфОъОЋОаОЋОф ОЋОЎОдОЎОеОЋОф ОљОЋОъОаОЋОф ОъОфОЋОџ ОљОЋОАОБ</translation>
<translation id="1114102982691049955"><ph name="PRINTER_MANUFACTURER" /> <ph name="PRINTER_MODEL" /> (USB)</translation>
<translation id="1114202307280046356">ОЎОћОюОЋОЮ</translation>
<translation id="1114427165525619358">РђЈОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ ОЋОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="1114525161406758033">ОъОдОЉ ОЕОЎОаОћ ОъОЋОцОбОю ОЏОЕОћОъОЏОАОћ ОАОњОЋОе</translation>
<translation id="1116639326869298217">ОљОЎ ОљОцОЕОе ОћОЎОћ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="1116694919640316211">ОъОЎОЊОб ОЏОюОюОЎ</translation>
<translation id="1116779635164066733">ОћОфОЋОАОБ "<ph name="NAME" />" ОљОЋОЏОБ ОљОф ОћОћОњОЊОеОћ ОћОќОЋ.</translation>
<translation id="1118738876271697201">ОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОќОћОЋОф ОљОф ОЊОњОЮ ОћОъОЏОЕОЎОе ОљОЋ ОљОф ОћОъОАОцОе ОћОАОЎОЊОЋОеОЎ.</translation>
<translation id="1119447706177454957">ОЕОњОЎОљОћ ОцОаОЎОъОЎОф</translation>
<translation id="1122068467107743258">ОбОЉОЋОЊОћ</translation>
<translation id="1122198203221319518">&amp;ОЏОюОЎОЮ</translation>
<translation id="1122242684574577509">РђЈОћОљОЎОъОЋОф ОаОЏОЕОю. ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОбОЉОЋОе ОљОю ОЊОБ ОћОћОфОЌОЉОеОЋОф ОЕОю ОеОЕОф Оћ-Wi-Fi ОЕОЉОћ ОъОЕОфОъОЕОЎОЮ (<ph name="NETWORK_ID" />).</translation>
<translation id="1122913801042512795">ОцОеОўОЎ ОћОЏОаОЎОАОћ ОЕОю ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОюОљ ОъОбОЋОЊОЏОаОЎОЮ. ОбОюОЎОџ ОюОдОљОф ОъОћОЌОЕОЉОЋОЪ ОЋОюОћОЎОЏОаОА ОъОЌОЊОЕ.</translation>
<translation id="1122960773616686544">ОЕОЮ ОАОЎОъОаОЎОЎОћ</translation>
<translation id="1124772482545689468">ОъОЕОфОъОЕ</translation>
<translation id="1125550662859510761">РђЈОаОеОљОћ ОЏОъОЋ <ph name="WIDTH" /> x <ph name="HEIGHT" /> (ОЉОъОДОЋОе)</translation>
<translation id="1126809382673880764">РђЈОЉОъОдОЉ ОћОќОћ ОћОъОбОеОЏОф ОюОљ ОъОњОЎОаОћ ОбОюОЎОџ ОъОцОаОЎ ОљОфОеОЎОЮ, ОћОЋОеОЊОЋОф ОЋОфОЋОАОцОЎОЮ ОъОАОЋОЏОаОЎОЮ. ОњОюОЎОЕОћ ОЉОўОЋОЌОћ ОбОЊОЎОЎОЪ ОфОњОЪ ОбОюОЎОџ ОЉОЕОЎОеОЋОфОЎОЮ ОљОЌОеОЎОЮ ОЕОю Google ОЕОЉОћОЮ ОћОЎОљ ОќОъОЎОаОћ, ОЏОъОЋ Gmail ОЋОћОЌОЎОцОЋОЕ.</translation>
<translation id="1128090040635299943">РђЈОъОфОЉОдОбОф ОбОЏОЕОЎОЋ ОћОњОЊОеОћ ОЕОю Linux. ОфОћОюОЎОџ ОћОћОњОЊОеОћ ОЎОЎОъОЕОџ ОЏОъОћ ОЊОДОЋОф.</translation>
<translation id="1128591060186966949">ОбОеОЎОЏОф ОъОаОЋОб ОЌОЎОцОЋОЕ</translation>
<translation id="1129420403709586868">ОћОдОњОф ОћОъОЊОЎОћ ОЋОћОфОъОЋОаОЋОф ОЕОЉОўОюОцОЋОЪ</translation>
<translation id="1129850422003387628">ОаОЎОћОЋОю ОљОцОюОЎОДОдОЎОЋОф</translation>
