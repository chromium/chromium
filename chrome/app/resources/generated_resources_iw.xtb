<translation id="7710568461918838723">&amp;ОћОбОЉОеОћ...</translation>
<translation id="7711900714716399411">РђЈОЎОЕ ОюОћОЕОфОъОЕ ОЉОЏОЉОю USB ОЏОЊОЎ ОюОЌОЉОе ОљОф ОћОўОюОцОЋОЪ ОюОъОЌОЕОЉ. ОљОЮ ОћОўОюОцОЋОЪ ОЏОЉОе ОъОЌОЋОЉОе, ОЎОЕ ОюОаОфОД ОљОЋОфОЋ ОЋОюОљОЌОе ОъОЏОЪ ОюОЌОЉОе ОЕОЋОЉ.</translation>
<translation id="7712739869553853093">ОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОЕОю ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОюОћОЊОцОАОћ</translation>
<translation id="7714307061282548371">РђЈОДОЋОЉОдОЎ Cookie Оъ-<ph name="DOMAIN" /> ОъОЋОфОеОЎОЮ</translation>
<translation id="7714464543167945231">ОљОЎОЕОЋОе</translation>
<translation id="7716648931428307506">ОЎОЕ ОюОЉОЌОЋОе ОћОЎОЏОЪ ОюОЕОъОЋОе ОљОф ОћОАОЎОАОъОљОЋОф</translation>
<translation id="7716781361494605745">РђЈОЏОфОЋОЉОф ОљОфОе ОЕОю ОъОЊОЎОаОЎОЋОф ОеОЕОЋОф ОљОЎОЕОЋОеОЎОЮ ОЕОю Netscape</translation>
<translation id="7717014941119698257">ОћОЋОеОЊОћ: <ph name="STATUS" /></translation>
<translation id="771721654176725387">ОћОцОбОЋОюОћ ОћОќОЋ ОфОъОЌОД ОЉОљОЋОцОЪ ОАОЋОцОЎ ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЕОюОџ ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОаОфОЋОаОЎОЮ, ОЎОЕ ОюОћОцОбОЎОю ОАОаОЏОеОЋОЪ</translation>
<translation id="7717845620320228976">ОЌОЎОцОЋОЕ ОбОЊОЏОЋОаОЎОЮ</translation>
<translation id="7719367874908701697">ОъОеОЌОД ОъОфОдОЋОњОћ ОЉОЊОБ</translation>
<translation id="7719588063158526969">ОЕОЮ ОћОъОЏОЕОЎОе ОљОеОЋОџ ОъОЊОЎ</translation>
<translation id="7720216670798402294">РђЈОДОеОЎОљОф ОаОфОЋОаОЎ ОћОъОЏОЕОЎОе ОЋОъОЎОЊОб ОъОъОЏОЕОЎОе Оћ-ChromeOS.</translation>
<translation id="7721179060400456005">ОЌОюОЋОаОЋОф ОЎОЏОЋОюОЎОЮ ОюОАОЋОЉОЉ ОљОф ОћОфОдОЋОњОЋОф</translation>
<translation id="7721237513035801311"><ph name="SWITCH" /> (<ph name="DEVICE_TYPE" />)</translation>
<translation id="7721258531237831532">ОћОљОеОњОЋОЪ ОЕОюОџ ОЊОЋОеОЕ ОцОеОЋОцОЎОю</translation>
<translation id="7722040605881499779">ОћОЕОўОЌ ОЕОаОЊОеОЕ ОЏОЊОЎ ОюОбОЊОЏОЪ: <ph name="NECESSARY_SPACE" /></translation>
<translation id="7724603315864178912">ОЌОЎОфОЋОџ</translation>
<translation id="7726391492136714301">ОћОдОњОф ОћОћОфОеОљОЋОф ОЋОћОљОцОюОЎОДОдОЎОЋОф ОЕОЉОўОюОцОЋОЪ</translation>
<translation id="7728465250249629478">ОЕОЎОаОЋОЎ ОћОЕОцОћ ОЉОъОЏОЕОЎОе</translation>
<translation id="7728570244950051353">ОъОАОџ ОаОбОЎОюОћ ОъОъОдОЉ ОЕОЎОаОћ</translation>
<translation id="7728668285692163452">ОЕОЎОаОЋОЎ ОћОбОеОЋОЦ ОЎОЎОЏОаОА ОюОфОЋОДОБ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="7730449930968088409">ОдОЎОюОЋОЮ ОЕОю ОфОЋОЏОЪ ОћОъОАОџ</translation>
<translation id="7730683939467795481">ОћОфОЋОАОБ "<ph name="EXTENSION_NAME" />" ОЕОЎОаОћ ОљОф ОћОЊОБ ОћОќОћ</translation>
<translation id="7737115349420013392">ОъОфОЉОдОбОф ОћОфОљОъОћ ОбОЮ "<ph name="DEVICE_NAME" />" ...</translation>
<translation id="7737846262459425222">РђЈОЎОЕ ОюОџ ОфОъОЎОЊ ОљОцОЕОеОЋОф ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉ'ОћОњОЊОеОЋОф' &gt; РђЈGoogle AssistantРђЈ &gt; 'ОћОДОЕОе ОъОАОџ'.</translation>
<translation id="7737948071472253612">ОюОљ ОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ</translation>
<translation id="7740996059027112821">ОеОњОЎОюОћ</translation>
<translation id="7741307896921365578">ОћОцОбОюОф ОЌОюОЋОаОЎОф ОдОЊОЊОЎОф ОЉОЊОцОЊОцОЪ ОюОдОЋОеОџ ОњОЎОЕОћ ОаОЋОЌОћ ОЋОбОДОЉОЎОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ ОЋОюОАОЎОъОаОЎОЋОф.</translation>
<translation id="7742558784808143689">ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОљОф ОћОћОеОЕОљОЋОф ОюОљОфОе <ph name="SITE_NAME" />, ОюОЏОю ОћОљОфОеОЎОЮ ОЕОфОЌОфОЎОЋ ОЋОюОљОцОюОЎОДОдОЎОЋОф ОћОъОЋОфОДОаОЋОф?</translation>
<translation id="7742706086992565332">ОаОЎОфОЪ ОюОћОњОЊОЎОе ОљОф ОћОъОеОЌОД ОъОћОфОдОЋОњОћ ОЉОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ</translation>
<translation id="7742879569460013116">ОЕОЎОфОЋОБ ОћОДОЎОЕОЋОе ОбОЮ</translation>
<translation id="774377079771918250">ОЉОЌОЎОеОф ОъОЎОДОЋОЮ ОћОЕОъОЎОеОћ</translation>
<translation id="7744047395460924128">ОћОдОњОф ОћОЎОАОўОЋОеОЎОЎОф ОћОћОЊОцОАОЋОф ОЕОюОџ</translation>
<translation id="7744192722284567281">ОаОъОдОљОћ ОЉОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб</translation>
<translation id="7744649840067671761">ОдОеОЎОџ ОюОћОДОЎОЕ ОбОю ОъОфОњ ОЌОЊОЕ ОљОЋ ОъОДОЕ ОЉОъОДОюОЊОф ОЏОЊОЎ ОюОћОфОЌОЎОю ОЉОћОДОдОљОћ.
ОЏОЊОЎ ОюОћОАОЎОе ОљОф ОћОћОДОдОљОћ, ОъОДОЎОЕОЎОЮ ОбОю ОъОфОњ ОљОЋ ОъОДОЕ ОЉОъОДОюОЊОф ОЕОћОЋОДОдОЋ.</translation>
<translation id="7746739418892731373">РђЈОъОЋОдОњ ОюОџ ОћОъОЎОўОЉ ОъОћОфОъОЋОаОЋОф ОЋОћОАОеОўОЋОаОЎОЮ ОъОАОцОеОЎОЎОф Google Photos ОЕОюОџ. ОаОЎОфОЪ ОюОЕОюОЋОў ОЉОъОћ ОЕОъОЋОдОњ ОЉОДОўОб 'ОћОъОЎОўОЉ' ОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK" />photos.google.com/settings<ph name="END_LINK" />.
        <ph name="BREAK" />
        <ph name="BREAK" />
        ОаОЎОфОЪ ОюОаОћОю ОљОф ОћОњОЊОеОЋОф ОћОЏОеОўОЎОА ОћОќОћ ОЊОеОџ ОћОфОцОеОЎОў ОЉОЏОеОўОЎОА ОљОЋ ОюОеОљОЋОф ОбОЋОЊ ОљОцОЕОеОЋОЎОЋОф ОЉ'ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chrome'.</translation>
<translation id="7750228210027921155">ОфОъОЋОаОћ ОЉОфОЋОџ ОфОъОЋОаОћ</translation>
<translation id="7751260505918304024">ОћОдОњОф ОћОЏОЋОю</translation>
<translation id="7751619076382363711">ОюОљ ОћОАОеОф ОљОБ ОљОфОе</translation>
<translation id="7753735457098489144">ОћОћОфОДОаОћ ОаОЏОЕОюОћ ОЏОЎ ОљОЎОЪ ОъОАОцОЎОД ОаОцОЌ ОљОЌОАОЋОЪ. ОЏОЊОЎ ОюОцОаОЋОф ОаОцОЌ ОљОЌОАОЋОЪ, ОбОюОЎОџ ОюОъОЌОЋОД ОДОЉОдОЎОЮ ОъОљОЌОАОЋОЪ ОћОъОЏОЕОЎОе.</translation>
<translation id="7754347746598978109">РђЈОюОљ ОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉ-JavaScript</translation>
<translation id="7754704193130578113">ОЎОЕ ОюОЕОљОЋОю ОћОЎОЏОЪ ОюОЕОъОЋОе ОЏОю ОДОЋОЉОЦ ОюОцОаОЎ ОћОЋОеОЊОфОЋ</translation>
<translation id="7755287808199759310">ОљОЌОЊ ОъОћОћОЋОеОЎОЮ ОЕОюОџ ОЎОЏОЋОю ОюОЉОўОю ОЉОЕОЉОЎОюОџ ОљОф ОћОЌОАОЎОъОћ</translation>
<translation id="7757592200364144203">ОћОљОЮ ОюОЕОаОЋОф ОљОф ОЕОЮ ОћОъОЏОЕОЎОе?</translation>
<translation id="7757739382819740102">ОљОаОЕОЎ ОДОЕОе ОЕОаОъОдОљОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ ОЎОЋОЏОюОЋ ОюОЕОфОБ ОљОЎОфОџ. ОЎОћОЎОћ ОбОюОЎОџ ОюОљОЕОе ОљОф ОћОЕОЎОфОЋОБ.</translation>
<translation id="7757787379047923882">ОћОўОДОАОў ОЕОЋОфОБ ОЊОеОџ <ph name="DEVICE_NAME" /></translation>
<translation id="7758143121000533418">Family Link</translation>
<translation id="7758450972308449809">ОћОфОљОъОф ОћОњОЉОЋОюОЋОф ОЕОю ОћОфОдОЋОњОћ</translation>
<translation id="7760004034676677601">ОћОљОЮ ОќОћОЋ ОЊОБ ОћОцОфОЎОЌОћ ОЕОдОЎОцОЎОф ОюОеОљОЋОф?</translation>
<translation id="7762463735017901568">ОћОљОЊОъОЎОЪ ОЕОю ОћОўОюОцОЋОЪ ОЕОюОџ ОћОЕОЉОЎОф ОљОф ОАОаОЏОеОЋОЪ ОћОћОфОеОљОЋОф</translation>
<translation id="7764225426217299476">ОћОЋОАОцОф ОЏОфОЋОЉОф</translation>
<translation id="7764256770584298012"><ph name="DOWNLOAD_RECEIVED" /> Оъ-<ph name="DOWNLOAD_DOMAIN" /></translation>
<translation id="7764857504908700767">ОЏОЕОњОеОАОљОЋОф ОћОаОЎОАОЎОЋОЪ ОцОбОЎОюОЋОф, ОљОАОЎОъОЋОаОЎ ОъОћОЎОъОаОЋОф ОъОљОцОЕОеОЎОЮ ОюОљОфОеОЎОЮ ОюОћОфОъОЋОЊОЊ ОбОЮ ОАОцОљОЮ ОЋОћОЋОаОљОЋОф ОЋОюОћОЉОЌОЎОЪ ОЉОЎОЪ ОЉОЋОўОЎОЮ ОюОљОаОЕОЎОЮ.</translation>
<translation id="7765158879357617694">ОћОбОЉОеОћ</translation>
<translation id="7765507180157272835">РђЈОаОЊОеОЕОЎОЮ Bluetooth ОЋ-Wi-Fi</translation>
<translation id="7766082757934713382">ОћОъОфОњ ОћОќОћ ОбОЋОќОе ОюОдОъОдОЮ ОљОф ОћОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ ОбОю ОЎОЊОЎ ОћОеОЕОф, ОбОю ОЎОЊОЎ ОћОЕОћОЎОЎОф ОћОбОЊОЏОЋОаОЎОЮ ОћОљОЋОўОЋОъОўОЎОЎОЮ ОЕОю ОћОљОцОюОЎОДОдОЎОћ ОЋОћОъОбОеОЏОф.</translation>
<translation id="7766807826975222231">ОћОдОўОеОБ ОюОАОЎОЋОе</translation>
<translation id="7766838926148951335">ОљОЎОЕОЋОе ОћОеОЕОљОЋОф</translation>
<translation id="7767554953520855281">ОћОцОеОўОЎОЮ ОъОЋОАОфОеОЎОЮ ОЉОќОъОЪ ОЕОЎОфОЋОБ ОћОъОАОџ</translation>
<translation id="7768507955883790804">ОљОфОеОЎОЮ ОЎОцОбОюОЋ ОюОцОЎ ОћОћОњОЊОеОћ ОћОќОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОќОъОЪ ОћОЉОЎОДОЋОе ОЉОћОЮ</translation>
<translation id="7768526219335215384">Ою-<ph name="ORIGIN" /> ОфОћОЎОћ ОћОеОЕОљОћ ОюОеОљОЋОф ОљОф ОћОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDERNAME" /></translation>
<translation id="7768770796815395237">ОЕОЎОаОЋОЎ</translation>
<translation id="7768784765476638775">ОћОДОеОљОћ</translation>
<translation id="7770406201819593386">РђЈОћОеОдОћ ОЕОю ОЉОЊОЎОДОЋОф ОаОЎОфОЋОЌОЎОЮ ОюОњОЉОЎ ChromeOS Flex.</translation>
<translation id="7770450735129978837">ОћОюОЌОдОЪ ОћОЎОъОаОЎ ОЉОбОЏОЉОе</translation>
<translation id="7770566005197683248">ОаОћОаОЎОЮ ОъОљОЋОЋОЎОеОћ ОДОюОЎОюОћ ОЋОќОЋОеОъОф.</translation>
<translation id="7770612696274572992">ОћОфОъОЋОаОћ ОћОЋОбОфОДОћ ОъОъОЏОЕОЎОе ОљОЌОе</translation>
<translation id="7771452384635174008">ОцОеОЎОАОћ</translation>
<translation id="7772032839648071052">ОљОЎОЕОЋОе ОъОЕОцОў-ОАОЎОАОъОћ</translation>
<translation id="7772127298218883077">ОъОЎОЊОб ОбОю <ph name="PRODUCT_NAME" /></translation>
<translation id="7773726648746946405">ОљОЌОАОЋОЪ ОћОцОбОюОћ</translation>
<translation id="7774365994322694683">ОдОЎОцОЋОе</translation>
<translation id="7774792847912242537">ОЎОЋОфОе ОъОЊОЎ ОЉОДОЕОЋОф.</translation>
<translation id="7775694664330414886">ОћОЏОеОўОЎОАОЎОЎОћ ОћОЋОбОЉОеОћ ОюОДОЉОЋОдОћ ОюОюОљ ОЕОЮ РђЊ <ph name="GROUP_CONTENTS" /></translation>
<translation id="7776156998370251340">ОюОљОфОе <ph name="ORIGIN" /> ОфОћОЎОћ ОћОеОЕОљОћ ОюОеОљОЋОф ОљОф ОћОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDERNAME" /> ОбОЊ ОЕОЏОю ОћОЏОеОўОЎОАОЎОЋОф ОЕОю ОћОљОфОе ОћОќОћ ОЎОЎОАОњОеОЋ</translation>
<translation id="7776701556330691704">ОюОљ ОаОъОдОљОЋ ОДОЋОюОЋОф</translation>
<translation id="7781335840981796660">ОфОфОЉОдОб ОћОАОеОћ ОЕОю ОЏОю ОЌОЕОЉОЋОаОЋОф ОћОъОЕОфОъОЕ ОЋОћОаОфОЋОаОЎОЮ ОћОЕОъОЋОеОЎОЮ ОЉОъОЏОЕОЎОе.</translation>
<translation id="7782102568078991263">РђЈОљОЎОЪ ОЎОЋОфОе ОћОдОбОЋОф Оъ-Google</translation>
<translation id="7782717250816686129">ОљОЌОАОЋОЪ ОаОфОЋОаОЎОЮ ОДОЉОЋОбОЎОЮ ОЉОъОАОџ ОћОћОфОЌОЉОеОЋОф ОЋОћОќОаОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОцОеОўОЎ ОћОЏОаОЎОАОћ ОЉОАОЕОЪ.</translation>
<translation id="778330624322499012">ОюОљ ОаОЎОфОЪ ОюОўОбОЋОЪ ОљОф <ph name="PLUGIN_NAME" /></translation>
<translation id="7784067724422331729">ОћОњОЊОеОЋОф ОљОЉОўОЌОћ ОЉОъОЌОЕОЉ ОЕОюОџ ОЌОАОъОЋ ОДОЋОЉОЦ ОќОћ.</translation>
<translation id="7784796923038949829">ОљОЎ ОљОцОЕОе ОюОДОеОЋОљ ОљОф ОаОфОЋОаОЎ ОћОљОфОе ОљОЋ ОюОЕОаОЋОф ОљОЋОфОЮ</translation>
<translation id="778480864305029524">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎ ОЉОЎОЪ ОъОЏОЕОЎОеОЎОЮ, ОдОеОЎОџ ОюОћОцОбОЎОю ОљОф ОћОћОЋОЊОбОЋОф ОЕОю ОЕОЎОеОЋОфОЎ Google Play.</translation>
<translation id="7785471469930192436">ОаОЎОфОЪ ОюОбОЎОЎОЪ ОЉОћОЋОеОљОЋОф ОЕОю ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОъОЕОъОЕ ОљОЋОфОџ ОюОњОЉОЎ ОъОЌОЎОДОф ОћОЎОАОўОЋОеОЎОЎОф ОћОЌОЎОцОЋОЕОЎОЮ, ОљОЮ ОеОюОЋОЋОаОўОЎ</translation>
<translation id="7786889348652477777">&amp;ОўОбОЎОаОф ОћОљОцОюОЎОДОдОЎОћ ОъОЌОЊОЕ</translation>
<translation id="7787308148023287649">ОћОдОњОћ ОЉОъОАОџ ОљОЌОе</translation>
<translation id="7788298548579301890">РђЈОфОЋОЏОаОЎОф ОљОЌОеОф ОЉОъОЌОЕОЉ ОћОЋОАОЎОцОћ ОЎОЎОЕОЋОЮ ОЕОбОЕОЋОЎ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chrome.

<ph name="EXTENSION_NAME" /></translation>
<translation id="7788668840732459509">ОъОЎОДОЋОЮ:</translation>
<translation id="7789963078219276159">ОћОеОДОб ОЕОю ОЊОБ ОћОцОфОЎОЌОћ ОћОЋОЌОюОБ, ОЋОбОЏОЕОЎОЋ ОъОЋОцОЎОбОћ ОЉОЋ ОћОфОъОЋОаОћ<ph name="CATEGORY" />.</translation>
<translation id="7791543448312431591">ОћОЋОАОцОћ</translation>
<translation id="7792012425874949788">ОъОЕОћОЋ ОћОЕОфОЉОЕ ОЉОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ</translation>
<translation id="7792388396321542707">ОћОцОАОДОф ОЕОЎОфОЋОБ</translation>
<translation id="779308894558717334">ОЎОеОЋОД ОЉОћОЎОе</translation>
<translation id="7793098747275782155">ОЏОЌОЋОю ОЏОћОћ</translation>
<translation id="7797571222998226653">ОЏОЉОЋОЎ</translation>
<translation id="7798844538707273832">ОћОћОеОЕОљОћ <ph name="PERMISSION" /> ОаОЌОАОъОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="7799299114731150374">ОћОўОцОў ОћОЋОњОЊОе ОЉОћОдОюОЌОћ</translation>
<translation id="7799817062559422778">ОъОдОЉ ОЉОћОЎОе</translation>
<translation id="7800518121066352902">ОАОЎОЉОЋОЉ Оа&amp;ОњОЊ ОЏОЎОЋОЋОЪ ОћОЕОбОЋОЪ</translation>
<translation id="7801679634091975683">РђЈОЕОЎОаОЋОЎОЎОЮ ОЕОЎОЉОЋОдОбОЋ ОЏОљОЪ ОЎОЌОЋОюОЋ ОеОД ОЉОЊОцОЊОцОЪ Chrome Lacros ОЏОЊОЎ ОюОЉОдОб ОЕОЎОаОЋОЎОЎОЮ ОЉОћОњОЊОеОЋОф ОЕОю ОЊОцОЊОцОЪ Chrome, ОдОеОЎОџ ОюОцОфОЋОЌ ОљОф ОЊОцОЊОцОЪ Chrome ОЋОюОбОЉОЋОе ОюОћОњОЊОеОЋОф.</translation>
<translation id="780301667611848630">ОюОљ ОфОЋОЊОћ</translation>
<translation id="7804072833593604762">ОћОЏОеОўОЎОАОЎОЎОћ ОаОАОњОеОћ</translation>
<translation id="7805768142964895445">ОАОўОўОЋОА</translation>
<translation id="7807067443225230855">РђЈОЌОЎОцОЋОЕ ОЋ-Assistant</translation>
<translation id="7807117920154132308">РђЈОаОеОљОћ ОЕОЏОЉОе ОћОфОЉОдОбОћ ОћОњОЊОеОћ ОЕОю Google Assistant ОбОю ОЎОЊОЎ <ph name="SUPERVISED_USER_NAME" /> ОЉОъОЏОЕОЎОе ОљОЌОе. ОЉОљОъОдОбОЋОф ОћОцОбОюОћ ОЕОю ОћОДОЕОе ОћОъОАОџ, Ою<ph name="SUPERVISED_USER_NAME" /> ОфОћОЎОћ ОљОцОЕОеОЋОф ОюОћОцОЎОД ОЎОЋОфОе ОфОЋОбОюОф Оъ-Assistant ОЉОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="7807711621188256451">ОћОфОеОћ ОфОъОЎОЊ Ою-<ph name="HOST" /> ОюОњОЕОф ОюОъОдОюОъОћ ОЕОюОџ</translation>
<translation id="7810202088502699111">ОЌОюОЋОаОЋОф ОДОЋОцОдОЎОЮ ОаОЌОАОъОЋ ОЉОЊОБ ОќОћ.</translation>
<translation id="781167124805380294">ОћОбОЉОеОћ ОЕОю <ph name="FILE_NAME" /></translation>
<translation id="7811886112806886172">РђЈОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОаОфОЋОаОЎ ОћОЕОЎОъОЋОЕ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ ОљОю Google ОфОбОќОЋОе ОюОЕОцОе ОљОф ОћОфОЏОЋОаОЋОф ОЋОљОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю Chrome ОЋОЕОю ChromeOS. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google. ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОцОЋОбОюОф ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОаОфОЋОаОЎОЮ ОЕОю Android ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="7814458197256864873">&amp;ОћОбОфОДОћ</translation>
<translation id="7815680994978050279">ОаОЌОАОъОћ ОћОЋОеОЊОћ ОъОАОЋОЏОаОф</translation>
<translation id="7817361223956157679">РђЈОћОъОДОюОЊОф ОЕОъОЋОцОЎОбОћ ОЉОъОАОџ ОюОљ ОбОЋОЉОЊОф ОбОЊОЎОЎОЪ ОЉОљОцОюОЎОДОдОЎОЋОф Linux</translation>
<translation id="7818135753970109980">ОбОЎОдОЋОЉ ОЌОЊОЕ ОаОЋОАОБ (<ph name="EXTENSION_NAME" />)</translation>
<translation id="7819605256207059717">ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="7820561748632634942">ОюОћОДОдОЋОф ОбОЋОЊ ОъОфОњОЎОЮ?</translation>
<translation id="782057141565633384">ОћОбОфОДОф ОЏОфОЋОЉОф &amp;ОАОеОўОЋОЪ</translation>
<translation id="7822187537422052256">ОЉОЌОеОф ОюОћОАОЎОе ОљОф ОћОЏОфОЋОЉОф ОћОќОЋ. ОюОћОъОЕОЎОџ?</translation>
<translation id="7824864914877854148">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЋОюОљ ОаОЎОфОЪ ОюОћОЕОюОЎОЮ ОљОф ОћОњОЎОЉОЋОЎ</translation>
<translation id="782590969421016895">ОЕОЎОъОЋОЕ ОЉОЊОцОЎОЮ ОћОаОЋОЏОЌОЎОЎОЮ</translation>
<translation id="7826174860695147464">РђЈОфОъОЎОЏОћ ОЉОЊОцОЊОцОЪ ОъОЊОЋОе ОДОЋОЊОЮ (LBS) РђЊ ОћОњОЊОеОЋОф ОцОаОЎОъОЎОЋОф</translation>
<translation id="7826249772873145665">РђЈОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB ОъОЋОЕОЉОф</translation>
<translation id="7826254698725248775">ОъОќОћОћ ОъОЏОЕОЎОе ОъОфОаОњОЕ.</translation>
<translation id="7828731929332799387">РђЈОћОцОбОЋОюОћ ОћОќОЋ ОфОъОЌОД ОљОф ОЏОю ОДОЋОЉОдОЎ Оћ-cookie ОЋОаОфОЋОаОЎ ОћОљОфОеОЎОЮ ОћОќОъОЎОаОЎОЮ ОЉОћОДОЕОеОЎОЮ ОЕОю ОдОЊ ОЕОюОЎОЕОЎ. ОюОћОъОЕОЎОџ?</translation>
<translation id="7829877209233347340">ОдОеОЎОџ ОюОЉОДОЕ ОъОћОЋОеОћ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЏОЊОЎ ОюОљОЕОе ОћОЋОАОцОћ ОЕОю ОЌОЕОЉОЋОЪ ОЉОЎОф ОАОцОеОЎ</translation>
<translation id="7831754656372780761"><ph name="TAB_TITLE" /> <ph name="EMOJI_MUTING" /></translation>
<translation id="783229689197954457">РђЈОљОЮ Google ОфОъОдОљ ОћОаОЌОћ, ОћОЎОљ ОфОЋОдОњ ОЉОЊОБ ОћОќОћ</translation>
<translation id="7833720883933317473">ОЏОљОЪ ОЎОЋОцОЎОбОЋ ОћОъОЎОюОЎОЮ ОћОъОЋОфОљОъОЋОф ОЕОЕОъОеОф</translation>
<translation id="7835178595033117206">ОћОАОЎОъОаОЎОЎОћ ОћОЋОАОеОћ</translation>
<translation id="7836850009646241041">ОбОюОЎОџ ОюОаОАОЋОф ОюОњОбОф ОЕОЋОЉ ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ</translation>
<translation id="7837776265184002579">ОЊОБ ОћОЉОЎОф ОћОЕОфОаОћ Ою-<ph name="URL" />.</translation>
<translation id="7838838951812478896">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОъОЋОе ОљОф '<ph name="NETWORK_NAME" />' ОЊОеОџ <ph name="DEVICE_NAME" /></translation>
<translation id="7838971600045234625">{COUNT,plural, =1{ОЉОЋОдОбОћ ОЕОюОЎОЌОћ ОЕОю <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}two{ОЉОЋОдОбОћ ОЕОюОЎОЌОћ ОЕОю <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}many{ОЉОЋОдОбОћ ОЕОюОЎОЌОћ ОЕОю <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}other{ОЉОЋОдОбОћ ОЕОюОЎОЌОћ ОЕОю <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}}</translation>
<translation id="7839051173341654115">ОћОдОњОћ/ОњОЎОЉОЋОЎ ОЕОю ОъОЊОЎОћ</translation>
<translation id="7839192898639727867">ОъОќОћОћ ОъОцОфОЌ ОЕОю ОаОЋОЕОљ ОљОЎОЕОЋОе</translation>
<translation id="7842692330619197998">РђЈОљОЮ ОдОеОЎОџ ОюОЎОдОЋОе ОЌОЕОЉОЋОЪ ОЌОЊОЕ, ОаОЎОфОЪ ОюОбОЕОЋОф ОќОљОф ОЉОЏОфОЋОЉОф g.co/ChromeEnterpriseAccount.</translation>
<translation id="784273751836026224">РђЈОћОАОеОћ ОЕОю Linux</translation>
<translation id="7843786652787044762">ОЏОаОЎОАОћ ОљОю <ph name="WEB_DRIVE" /></translation>
<translation id="7844992432319478437">ОћОћОЉОЊОю ОъОфОбОЊОЏОЪ</translation>
<translation id="7846634333498149051">ОъОДОюОЊОф</translation>
<translation id="7847212883280406910">РђЈОЎОЕ ОюОћОДОЎОЕ ОбОю Ctrl РђЈ+ Alt РђЈ+ S ОЏОЊОЎ ОюОбОЉОЋОе ОљОю <ph name="IDS_SHORT_PRODUCT_OS_NAME" /></translation>
<translation id="7849264908733290972">ОцОфОЎОЌОф &amp;ОфОъОЋОаОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="784934925303690534">ОўОЋОЋОЌ ОќОъОЪ</translation>
<translation id="7850717413915978159">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОћОЏОЎОю ОъОЎОЊОб ОЏОъОЋ ОаОАОЎОЉОЋОф ОћОДОеОЎОАОћ ОЕОю ChromeOS, ОћОфОЏОЋОаОЋОф ОЕОъОЕОъОЕОЋОф ОљОЋОфОџ, ОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю ОЋОЏОЪ ОаОфОЋОаОЎ ОћОЕОЎОъОЋОЕ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Ою-Android. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОЕОю ОъОЏОЕОЎОе ChromeOS. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОцОЋОбОюОф ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОаОфОЋОаОЎОЮ ОЕОю Android ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОдОЎОњ ОљОЋ ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОЋОюОЕОаОЋОф ОљОф ОћОњОЊОеОЋОф ОћОЌОЕОЉОЋОЪ ОЉОЏОфОЋОЉОф account.google.com.<ph name="END_PARAGRAPH3" /></translation>
<translation id="7851021205959621355">РђЈ<ph name="BEGIN_BOLD" />ОћОбОеОћ:<ph name="END_BOLD" /> ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОъОЎОЕОћОЋ ОЎОдОюОЎОЌ ОюОњОЕОф ОюОфОЋОдОљОЋОф ОћОљОЎОЕОЎОЋОф ОљОЋ Ою-Assistant ОњОЮ ОЉОљОъОдОбОЋОф ОДОЋОю ОЊОЋОъОћ ОљОЋ ОћОДОюОўОћ. ОЏОЊОЎ ОюОЌОАОЋОџ ОЉОдОеОЎОЏОф ОћОАОЋОюОюОћ, ОљОцОЕОе ОюОДОЉОЋОб ОЉОћОњОЊОеОЋОф ОЕОю Assistant ОЕОћОцОДОЋОЊОћ РђюHey GoogleРђЮ ОфОцОбОю ОеОД ОЏОЕОћОъОЏОЕОЎОе ОъОЌОЋОЉОе ОюОЌОЕОъОю ОљОЋ ОаОъОдОљ ОЉОўОбОЎОаОћ.</translation>
<translation id="7851457902707056880">ОћОЏОаОЎОАОћ ОћОЋОњОЉОюОћ ОюОЌОЕОЉОЋОЪ ОћОЉОбОюОЎОЮ ОЉОюОЉОЊ. ОЎОЕ ОюОЉОдОб ОљОфОЌОЋОю ОъОЌОЊОЕ ОЋОюОћОЎОЏОаОА ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ ОћОЉОбОюОЎОЮ. ОћОъОбОеОЏОф ОфОЉОдОб ОљОфОЌОЋОю ОъОЌОЊОЕ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОфОЋОџ 30 ОЕОаОЎОЋОф.</translation>
<translation id="7851716364080026749">ОљОаОЎ ОеОЋОдОћ ОюОЌОАОЋОЮ ОфОъОЎОЊ ОњОЎОЕОћ ОюОъОдОюОъОћ ОЋОюОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="7851720427268294554">РђЈОъОаОфОЌ IPP</translation>
<translation id="78526636422538552">РђЈОћОЋОАОцОћ ОЕОю ОЌОЕОЉОЋОаОЋОф Google ОћОЋОЕОЉОфОћ</translation>
<translation id="7853747251428735">&amp;ОЏОюОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="7855678561139483478">ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЎОћ ОюОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="7857004848504343806">РђЈОћОъОЌОЕОЉ ОЕОюОџ ОъОЏОЎОю ОъОЋОЊОЋОю ОљОЉОўОЌОћ ОћОъОЕОъОЕ ОюОЎОЎОЕОЋОЮ ОфОЏОЋОаОЋОф ОљОЉОўОЌОћ ОДОеОЎОўОЎОЋОф ОеОЉОЋОф ОЉ-ChromeOS Flex. ОъОЎОЊОб ОаОЋОАОБ ОъОцОЋОеОў ОЉОъОеОЏОќ ОћОбОќОеОћ ОЕОю ChromebookРђЈ: https://support.google.com/chromebook/?p=sm</translation>
<translation id="7857093393627376423">ОћОдОбОЋОф ОюОўОДОАОў</translation>
<translation id="7857949311770343000">ОћОљОЮ ОќОћОЋ ОЊОБ ОћОЏОеОўОЎОАОЎОЎОћ ОћОЌОЊОЕОћ ОЕОдОЎОцОЎОф ОюОеОљОЋОф?</translation>
<translation id="7858328180167661092"><ph name="APP_NAME" /> (Windows)</translation>
<translation id="786073089922909430">ОЕОЎОеОЋОф: <ph name="ARC_PROCESS_NAME" /></translation>
<translation id="7861215335140947162">&amp;ОћОЋОеОЊОЋОф</translation>
<translation id="7861846108263890455">РђЈОћОЕОцОћ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="7864539943188674973">РђЈОћОЕОЉОфОф Bluetooth</translation>
<translation id="7865127013871431856">ОљОцОЕОеОЋОЎОЋОф ОфОеОњОЋОЮ</translation>
<translation id="786957569166715433"><ph name="DEVICE_NAME" /> - ОъОЋОфОљОЮ</translation>
<translation id="7869655448736341731">ОћОЏОЋОю</translation>
<translation id="7870730066603611552">ОЉОЊОЎОДОф ОљОцОЕОеОЋОЎОЋОф ОћОАОЎОаОЏОеОЋОЪ ОљОЌОеОЎ ОћОћОњОЊОеОћ</translation>
<translation id="7870790288828963061">ОюОљ ОаОъОдОљОЋ ОљОцОюОЎОДОдОЎОЋОф ОДОЎОЋОАОД ОЉОњОеОАОћ ОЌОЊОЕОћ ОЎОЋОфОе. ОљОЎОЪ ОдОЋОеОџ ОЉОбОЊОЏОЋОЪ. ОљОцОЕОе ОюОћОЋОдОЎОљ ОљОф ОћОЊОЎОАОД ОљОЋОЪ ОДОЎ.</translation>
<translation id="7871109039747854576">ОъОбОЉОе ОЉОЎОЪ ОћОбОъОЋОЊОЎОЮ ОЕОю ОеОЕОЎОъОф ОћОфОЋОЋОЎОЮ ОћОљОцОЕОеОЎОЎОЮ ОЉОљОъОдОбОЋОф ОћОъОДОЕ <ph name="COMMA" /> ОЋОћОъОДОЕ <ph name="PERIOD" /></translation>
<translation id="787268756490971083">ОЏОЉОЋОЎ</translation>
<translation id="7872758299142009420">ОЎОЋОфОе ОъОЊОЎ ОДОЉОЋОдОЋОф ОъОДОЋОаОаОЋОф: <ph name="ERROR_LINE" /></translation>
<translation id="7874257161694977650">РђЈОеОДОбОЎОЮ ОЕОю Chrome</translation>
<translation id="7876027585589532670">ОюОљ ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ</translation>
<translation id="7877451762676714207">ОЕОњОЎОљОф ОЕОеОф ОюОљ ОЎОЊОЋОбОћ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОљОЋ ОюОцОаОЋОф ОюОъОаОћОю ОћОЕОеОф.</translation>
<translation id="7879631849810108578">ОДОЎОдОЋОе ОћОЊОеОџ ОћОЋОњОЊОе: <ph name="IDS_SHORT_SET_COMMAND" /></translation>
<translation id="7880591377632733558">РђЈОЉОеОЋОџ ОЉОЋОљОџ ОљОю Chrome, <ph name="ACCOUNT_FIRST_NAME" /></translation>
<translation id="7880685873361171388">РђЈОЏОЕОћОћОњОЊОеОћ ОъОЋОцОбОюОф ОЋОћОАОўОўОЋОА ОцОбОЎОю, Chrome ОъОЕОфОъОЕ ОЉОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЕОюОџ ОЉОъОћОюОџ 7 ОЎОъОЎОЮ ОЏОЊОЎ ОюОЕОЎОЎОџ ОљОЋОфОџ ОюОДОЉОЋОдОћ, ОљОЋ "ОДОЉОЋОдОћ ОЉОбОюОф ОъОљОцОЎОЎОаОЎОЮ ОъОЕОЋОфОцОЎОЮ". ОъОцОеОАОъОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОЌОЋОе ОъОЋОЊОбОЋОф ОюОДОЉОЋОдОћ. ОћОЎОАОўОЋОеОЎОЎОф ОћОЌОЎОцОЋОЕОЎОЮ ОаОЕОъОеОф ОЉОљОЋОцОЪ ОцОеОўОЎ ОЉОъОЏОЕОЎОе. ОфОДОЋОцОф ОћОаОЎОАОЎОЋОЪ ОћОќОЋ ОцОбОЎОюОћ ОеОД
    ОЉ<ph name="BEGIN_LINK" />ОљОќОЋОеОЎОЮ ОъОАОЋОЎОъОЎОЮ<ph name="END_LINK" />.</translation>
<translation id="7880823633812189969">ОћОаОфОЋОаОЎОЮ ОћОъОДОЋОъОЎОЎОЮ ОЎОЎОъОЌОДОЋ ОљОЌОеОЎ ОћОцОбОюОћ ОъОЌОЊОЕ</translation>
<translation id="7881066108824108340">DNS</translation>
<translation id="7881483672146086348">ОћОдОњОф ОЌОЕОЉОЋОЪ</translation>
<translation id="7883792253546618164">ОЉОЏОю ОЕОюОЉ ОаОЎОфОЪ ОюОЉОўОю ОљОф ОћОћОеОЕОъОћ.</translation>
<translation id="788453346724465748">ОцОеОўОЎ ОћОЌОЕОЉОЋОЪ ОЉОўОбОЎОаОћРђд</translation>
<translation id="7886279613512920452">{COUNT,plural, =1{ОцОеОЎОў}two{# ОцОеОЎОўОЎОЮ}many{# ОцОеОЎОўОЎОЮ}other{# ОцОеОЎОўОЎОЮ}}</translation>
<translation id="7886605625338676841">eSIM</translation>
<translation id="7887174313503389866">ОАОЎОЋОе ОъОЋОЊОеОџ ОЉОљОъОдОбОЎ ОћОЉОДОеОћ ОћОЌОЕОЋОЉОЎОЮ ОЉОЎОЋОфОе ОбОю ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ. ОюОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф, ОЎОЕ ОюОбОЉОЋОе ОюОћОњОЊОеОЋОф ОАОцОдОЎОцОЎОЋОф.</translation>
<translation id="7887334752153342268">ОЕОЏОцОЋОю</translation>
<translation id="7887864092952184874">РђЈОбОЏОЉОе Bluetooth ОъОЌОЋОЉОе</translation>
<translation id="7889371445710865055">ОЕОЎОаОЋОЎ ОЕОцОф ОћОћОЏОфОЉОћ</translation>
<translation id="7890147169288018054">РђЈОћОдОњОћ ОЕОю ОцОеОўОЎ ОеОЕОф, ОЏОъОЋ ОЏОфОЋОЉОф IP ОљОЋ MAC</translation>
<translation id="7892384782944609022">ОћОћОфОљОъОћ ОаОЏОЕОюОћ. ОЏОЊОЎ ОюОаОАОЋОф ОЕОЋОЉ, ОдОеОЎОџ ОюОЉОЌОЋОе ОъОЏОЕОЎОе.</translation>
<translation id="7893008570150657497">ОюОњОЕОф ОюОфОъОЋОаОЋОф, ОъОЋОќОЎОДОћ ОЋОъОЊОЎОћ ОаОЋОАОцОф ОъОћОъОЌОЕОЉ ОЕОюОџ</translation>
<translation id="7893153962594818789">РђЈBluetooth ОъОЋОЕОЉОф ОЉ-<ph name="DEVICE_TYPE" /> ОќОћ. ОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф Bluetooth.</translation>
<translation id="7893393459573308604"><ph name="ENGINE_NAME" /> (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="789722939441020330">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОЋОеОЎОЊ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОДОЉОдОЎОЮ ОъОеОЋОЉОЎОЮ</translation>
<translation id="7897900149154324287">ОЉОбОфОЎОЊ, ОЎОЕ ОюОћОДОцОЎОЊ ОюОюОЌОЋОЦ ОбОю ОАОъОю ОћОаОЎОфОЋОД ОбОЉОЋОе ОћОћОфОДОЪ ОћОаОЕОюОБ ОЊОеОџ ОљОцОюОЎОДОдОЎОЎОф 'ОДОЉОдОЎОЮ' ОюОцОаОЎ ОЕОъОаОфОДОЎОЮ ОљОЋОфОЋ ОцОЎОќОЎОф. ОљОЮ ОюОљ ОбОЋОЕОЎОЮ ОќОљОф, ОљОцОЕОе ОюОљОЉОЊ ОаОфОЋОаОЎОЮ.</translation>
<translation id="7898725031477653577">ОЉОеОдОЋОаОЎ ОюОДОЉОю ОфОеОњОЋОЮ ОфОъОЎОЊ</translation>
<translation id="7901405293566323524">ОъОеОЏОќ ОўОюОцОЋОаОЎ</translation>
<translation id="7903290522161827520">ОеОЋОдОћ ОюОљОфОе ОљОф ОеОЏОЎОЉОЎ ОћОЊОцОЊОцОЪ? ОЎОЕ ОюОбОЉОЋОе ОюОЏОфОЋОЉОф</translation>
<translation id="7903345046358933331">ОћОЊОБ ОљОЎОаОЋ ОъОњОЎОЉ. ОфОЋОЏОю ОюОћОъОфОЎОЪ ОбОЊ ОЕОЎОњОЎОЉ ОљОЋ ОюОАОњОЋОе ОљОЋОфОЋ.</translation>
<translation id="7903742244674067440">ОЎОЕ ОюОџ ОљОЎОЕОЋОеОЎОЮ ОЉОДОЋОЉОЦ ОћОъОќОћОЎОЮ ОеОЕОЋОЎОЋОф ОљОЎОЕОЋОеОЎОЮ ОљОюОћ</translation>
<translation id="7903925330883316394">ОфОЋОЏОаОЎОф ОЕОЎОеОЋОф: <ph name="UTILITY_TYPE" /></translation>
<translation id="7904526211178107182">РђЈОћОњОЊОеОф ОЎОдОЎОљОЋОф Linux ОЕОќОъОЎОаОЋОф ОюОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ ОЉОеОЕОф.</translation>
<translation id="7907837847548254634">ОћОЋОАОцОћ ОЌОўОЋОцОћ ОЕОю ОъОАОњОеОф ОАОЉОЎОЉ ОљОЋОЉОЎОЎОДОўОЎОЮ ОЕОъОфОъОДОЊОЎОЮ ОЉОћОЮ</translation>
<translation id="7908378463497120834">ОъОдОўОбОеОЎОЮ, ОюОљ ОаОЎОфОЪ ОюОћОбОюОЋОф ОюОцОЌОЋОф ОъОЌОЎОдОћ ОљОЌОф ОЉОъОЏОЕОЎОе ОћОљОЌОАОЋОЪ ОћОЌОЎОдОЋОаОЎ ОЕОюОџ.</translation>
<translation id="7909324225945368569">ОЕОЎОаОЋОЎ ОЕОЮ ОћОцОеОЋОцОЎОю</translation>
<translation id="7909969815743704077">ОћОћОЋОеОЊОћ ОЉОЋОдОбОћ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="7909986151924474987">ОЎОЎОфОЏОЪ ОЕОюОљ ОаОЎОфОЪ ОЎОћОЎОћ ОюОћОфОДОЎОЪ ОъОЌОЊОЕ ОљОф ОћОцОеОЋОцОЎОю</translation>
<translation id="7910768399700579500">&amp;ОфОЎОДОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="7911118814695487383">Linux</translation>
<translation id="79113168483292735">ОћОДОўОб ОЕОю ОЏОеОўОЎОАОЎОЋОф ОћОъОЊОЎОћ ОЉОЌОЎОцОЋОЕ ОЉОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="7912080627461681647">ОћОАОЎОАОъОћ ОЕОюОџ ОЕОЋОаОфОћ ОЉОЕОеОф. ОЎОЕ ОюОдОљОф ОЋОюОљОЌОе ОъОЏОЪ ОюОћОЎОЏОаОА ОъОЌОЊОЕ.</translation>
<translation id="7912974581251770345">ОфОеОњОЋОЮ</translation>
<translation id="7915457674565721553">ОЎОЕ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў ОЏОЊОЎ ОюОћОњОЊОЎОе ОЉОДОеОф ОћОЋОеОЎОЮ</translation>
<translation id="7918257978052780342">ОћОеОЕОъОћ</translation>
<translation id="7919123827536834358">ОфОеОњОЋОЮ ОљОЋОўОЋОъОўОЎ ОЕОю ОЕОцОЋОф ОљОюОћ</translation>
<translation id="7919210519031517829"><ph name="DURATION" /> ОЕОа'</translation>
<translation id="7920363873148656176">Ою-<ph name="ORIGIN" /> ОЎОЕ ОљОцОЕОеОЋОф ОюОћОдОЎОњ ОљОф <ph name="FILENAME" /></translation>
<translation id="7920482456679570420">ОћОЋОАОцОф ОъОЎОюОЎОЮ ОЕОЎОЕ ОюОЊОюОњ ОбОюОЎОћОЪ ОЉОЉОЊОЎОДОЋОф ОљОЎОЋОф</translation>
<translation id="7922935920104868876">РђЈОћОдОњОф ОцОеОўОЎОЮ ОбОю ОЌОАОЎОъОф ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊОЊОЎОЮ ОЕОюОЎОЕОЎОЎОЮ ОЉОъОдОЉ ОцОеОўОЎ</translation>
<translation id="7923564237306226146">РђЈОћОЕОЊОеОЋОњ ОЕОю Linux ОћОЋОЕОюОЮ</translation>
<translation id="7924358170328001543">ОЕОњОЎОљОћ ОЉОћОбОЉОеОф ОћОЎОдОЎОљОћ</translation>
<translation id="7925108652071887026">ОаОфОЋОаОЎ ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="792514962475806987">ОеОъОф ОќОЋОЮ ОЉОъОдОЉ ОъОбОЋОњОЪ:</translation>
<translation id="7925285046818567682">ОЉОћОъОфОаОћ Ою-<ph name="HOST_NAME" />...</translation>
<translation id="7926423016278357561">ОќОћ ОюОљ ОћОЎОЎОфОЎ ОљОаОЎ.</translation>
<translation id="7926975587469166629">ОЏОЎОаОЋОЎ ОћОЏОеОўОЎОА</translation>
<translation id="7928175190925744466">ОЏОЉОе ОЕОЎОаОЎОф ОљОф ОћОАОЎОАОъОћ ОћОќОЋ?</translation>
<translation id="7930294771522048157">ОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЕОаОЕОъОеОЋ ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="79312157130859720"><ph name="APP_NAME" /> ОъОЕОфОБ ОљОф ОћОъОАОџ ОЋОћОљОЋОЊОЎОЋ ОЕОюОџ.</translation>
<translation id="7932741659804096942">ОћОАОЎОАОъОљОЋОф ОаОЕОъОеОЋОф ОЉ<ph name="GOOGLE_PASSWORD_MANAGER" /> ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="793293630927785390">РђЈОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОюОћОЋОАОцОф ОеОЕОф Wi-Fi ОЌОЊОЕОћ</translation>
<translation id="7932969338829957666">РђЈОфОЎОДОЎОЋОф ОъОЕОЋОфОцОЋОф ОќОъОЎОаОЋОф ОЉ-Linux ОЉОАОцОеОЎОЎОћ <ph name="BASE_DIR" />.</translation>
<translation id="7933314993013528982">{NUM_TABS,plural, =1{ОЉОЎОўОЋОю ОћОЕОфОДОф ОћОљОфОе}two{ОЉОЎОўОЋОю ОћОЕОфОДОф ОћОљОфОеОЎОЮ}many{ОЉОЎОўОЋОю ОћОЕОфОДОф ОћОљОфОеОЎОЮ}other{ОЉОЎОўОЋОю ОћОЕОфОДОф ОћОљОфОеОЎОЮ}}</translation>
<translation id="7933518760693751884">ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОАОъОю ОћОАОЎОъОаОЎОЎОћ ОЏОЊОЎ ОюОЕОъОЋОе ОљОф ОћОЊОБ ОюОДОеОЎОљОћ ОЉОъОЋОбОЊ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="7933634003144813719">ОаОЎОћОЋОю ОфОЎОДОЎОЋОф ОъОЕОЋОфОцОЋОф</translation>
<translation id="793531125873261495">ОДОеОфОћ ОЕОњОЎОљОћ ОЉОћОЋОеОЊОф ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7935451262452051102">ОћОЋОЕОюОъОЋ %<ph name="PERCENT" /></translation>
<translation id="7939062555109487992">ОљОцОЕОеОЋОЎОЋОф ОъОфОДОЊОъОЋОф</translation>
<translation id="7939412583708276221">ОЕОъОЎОеОћ ОЉОЏОю ОъОДОеОћ</translation>
<translation id="7942349550061667556">ОљОЊОЋОЮ</translation>
<translation id="7943368935008348579">РђЈОћОЋОеОЊОф ОДОЋОЉОдОЎ Оћ-PDF</translation>
<translation id="7943837619101191061">ОћОЋОАОцОф ОъОЎОДОЋОЮ...</translation>
<translation id="7944772052836377867">ОЏОЊОЎ ОюОАОаОЏОеОЪ ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="7945031593909029181">"<ph name="CHROME_EXTENSION_NAME" />" ОеОЋОдОћ ОюОћОфОЌОЉОе ОљОю</translation>
<translation id="7946586320617670168">ОћОъОДОЋОе ОЌОЎОЎОЉ ОюОћОЎОЋОф ОъОљОЋОЉОўОЌ</translation>
<translation id="794676567536738329">ОљОЎОЕОЋОе ОћОеОЕОљОЋОф</translation>
<translation id="7947962633355574091">ОћОбОфОДОф ОЏОфОЋОЉОф &amp;ОАОеОўОЋОЪ</translation>
<translation id="7947964080535614577">ОљОфОеОЎОЮ ОъОдОЎОњОЎОЮ ОЉОЊОеОџ ОЏОюОю ОъОЋОЊОбОЋОф ОЏОЊОЎ ОЕОЎОЋОЏОюОЋ ОюОАОцОД ОфОЋОЏОЪ ОљОЋ ОЕОЎОеОЋОфОЎОЮ ОЉОЌОЎОаОЮ. ОбОЮ ОќОљОф, ОЎОЊОЋОб ОЕОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОъОдОЎОњОЎОЮ ОъОЋОЊОбОЋОф ОЕОъОцОеОЎОбОЋОф ОљОЋ ОъОўОбОЋОф.</translation>
<translation id="7948407723851303488">ОЏОю ОћОЊОцОЎОЮ ОЕОю <ph name="DOMAIN_NAME" /></translation>
<translation id="7951265006188088697">РђЈОЏОЊОЎ ОюОћОЋОАОЎОБ ОљОЋ ОюОаОћОю ОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЕОю Google Pay, ОЎОЕ ОюОбОЉОЋОе ОљОю <ph name="BEGIN_LINK" />ОЌОЕОЉОЋОЪ Google<ph name="END_LINK" />.</translation>
<translation id="795130320946928025">ОћОЕОЉОфОф ОћОЏОеОўОЎОА ОћОЋОЋОЎОеОўОЋОљОюОЎ</translation>
<translation id="7952708427581814389">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОеОљОЋОф ОўОДОАОў ОЋОфОъОЋОаОЋОф ОЉОюОЋОЌ ОћОбОеОЎОЏОћ</translation>
<translation id="795282463722894016">ОћОЕОЌОќОЋОе ОћОЋОЕОюОЮ</translation>
<translation id="7952904276017482715">ОћОъОќОћОћ ОћОдОцОЋОЎ ОћОЋОљ "<ph name="EXPECTED_ID" />", ОљОџ ОћОъОќОћОћ ОћОЎОћ "<ph name="NEW_ID" />"</translation>
<translation id="7953669802889559161">ОЕОЎОўОЋОф ОДОюОў</translation>
<translation id="7953955868932471628">ОаОЎОћОЋОю ОДОЎОдОЋОеОЎ ОЊОеОџ</translation>
<translation id="7955105108888461311">ОЉОЎОдОЋОб ОЉОДОЕОћ ОцОаОЎОЮ-ОљОю-ОцОаОЎОЮ</translation>
<translation id="7956373551960864128">ОъОЊОцОАОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="7957074856830851026">ОћОдОњОћ ОЕОю ОцОеОўОЎ ОћОъОЏОЕОЎОе, ОЏОъОЋ ОћОъОАОцОе ОћОАОЎОЊОЋОеОЎ ОљОЋ ОъОќОћОћ ОћОаОЏОА ОЕОюОЋ</translation>
<translation id="7957615753207896812">ОцОфОЎОЌОф ОћОњОЊОеОЋОф ОћОъОЏОЕОЎОе ОЕОю ОћОъОДОюОЊОф</translation>
<translation id="7959074893852789871">ОћОДОЋОЉОЦ ОћОЏОЎОю ОљОЎОЕОЋОеОЎОЮ ОъОеОЋОЉОЎОЮ, ОЌОюОДОЮ ОюОљ ОЎОЋОЉОљОЋ:</translation>
<translation id="7959665254555683862">&amp;ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОЌОЊОЕОћ</translation>
<translation id="7961015016161918242">ОљОБ ОцОбОЮ</translation>
<translation id="7963001036288347286">ОћОљОдОф ОюОЋОЌ ОъОњОб</translation>
<translation id="7963608432878156675">РђЈОћОЕОЮ ОћОќОћ ОЎОЋОдОњ ОюОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ ОЉОќОъОЪ ОћОЌОЎОЉОЋОе ОюОеОЕОф ОљОЋ Ою-Bluetooth</translation>
<translation id="7963826112438303517">РђЈAssistant ОъОЕОфОъОЕОф ОЉОћОДОюОўОЋОф ОћОљОюОћ ОЋОЉОЉОДОЕОЋОф ОДОЋОюОЎОЋОф ОЏОЊОЎ ОюОЎОдОЋОе ОЋОюОбОЊОЏОЪ ОљОф ОфОЉОаОЎОф ОћОДОЋОю ОЕОюОџ. ОћОфОЉОаОЎОф ОаОЕОъОеОф ОеОД ОЉОъОЏОЕОЎОеОЎОЮ ОЕОЉОћОЮ ОћОфОЏОЋОаОћ Voice Match ОъОЋОцОбОюОф. ОљОцОЕОе ОюОћОдОЎОњ ОљОф ОћОцОбОЎОюОЋОф ОћОДОЋОюОЎОф ОљОЋ ОюОЕОъОЋОе ОљОЋОфОћ ОЊОеОџ ОћОћОњОЊОеОЋОф ОЕОю Assistant.</translation>
<translation id="7966241909927244760">ОћОбОфОДОф ОЏОфОЋОЉОф &amp;ОфОъОЋОаОћ</translation>
<translation id="7966571622054096916">{COUNT,plural, =1{ОцОеОЎОў ОљОЌОЊ ОЉОеОЕОЎОъОф ОћОАОЎОъОаОЎОЋОф}two{{COUNT} ОцОеОЎОўОЎОЮ ОЉОеОЕОЎОъОф ОћОАОЎОъОаОЎОЋОф}many{{COUNT} ОцОеОЎОўОЎОЮ ОЉОеОЕОЎОъОф ОћОАОЎОъОаОЎОЋОф}other{{COUNT} ОцОеОЎОўОЎОЮ ОЉОеОЕОЎОъОф ОћОАОЎОъОаОЎОЋОф}}</translation>
<translation id="7968072247663421402">ОљОцОЕОеОЋОЎОЋОф ОАОцОД</translation>
<translation id="7968742106503422125">ОДОеОЎОљОћ ОЋОЕОЎОаОЋОЎ ОЕОю ОаОфОЋОаОЎОЮ ОЕОћОбОфОДОф ОЋОћОЊОЉОДОф</translation>
<translation id="7968833647796919681">ОћОцОбОюОф ОљОЎОАОЋОБ ОЕОю ОаОфОЋОаОЎ ОЉОЎОдОЋОбОЎОЮ</translation>
<translation id="7968982339740310781">ОћОдОњОф ОцОеОўОЎОЮ</translation>
<translation id="7969046989155602842">ОцОДОЋОЊОћ</translation>
<translation id="7970673414865679092">ОцОеОўОЎОЮ ОбОю ОљОфОеОаОў</translation>
<translation id="7970882136539140748">ОљОЎ ОљОцОЕОе ОюОЕОъОЋОе ОљОф ОћОЏОеОўОЎОА ОбОЏОЕОЎОЋ</translation>
<translation id="7972714317346275248">РђЈPKCS #1 SHA-384 ОбОЮ ОћОдОцОаОф RSA</translation>
<translation id="7973776233567882054">ОљОЎОќОћ ОъОћОъОЕОцОўОЎОЮ ОћОЉОљОЎОЮ ОъОфОљОе ОљОф ОћОеОЕОф ОЕОюОџ ОЉОдОЋОеОћ ОћОўОЋОЉОћ ОЉОЎОЋОфОе?</translation>
<translation id="797394244396603170">ОЎОЕ ОюОЉОЌОЋОе ОљОф ОћОъОЏОЕОЎОе ОЕОљОЎОфОЋ ОЉОеОдОЋОаОџ ОюОЕОфОБ ОДОЉОдОЎОЮ</translation>
<translation id="7974566588408714340">ОаОЎОАОЎОЋОЪ ОаОЋОАОБ ОЉОљОъОдОбОЋОф <ph name="EXTENSIONNAME" /></translation>
<translation id="7974713334845253259">ОдОЉОб ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="7974936243149753750">ОАОеОЎОДОф ОЎОфОе</translation>
<translation id="7975504106303186033">РђЈОбОюОЎОџ ОюОеОЕОЋОЮ ОљОф ОћОъОЏОЕОЎОе ОбОЮ Chrome Education ОюОЌОЕОЉОЋОЪ ОЕОЕОЎОЎОџ ОюОъОЋОАОЊ ОюОЎОъОЋОЊОЎОЮ. ОЏОЊОЎ ОюОћОЎОеОЕОЮ ОюОЌОЕОЉОЋОЪ ОЌОЊОЕ, ОЎОЕ ОюОћОЎОЏОаОА ОюОЏОфОЋОЉОф g.co/workspace/edusignup.</translation>
<translation id="7978412674231730200">ОъОцОфОЌ ОцОеОўОЎ</translation>
<translation id="7978450511781612192">РђЈОћОцОбОЋОюОћ ОћОќОљОф ОфОЋОдОЎОљ ОљОЋОфОџ ОъОЌОЕОЉОЋОаОЋОф Google ОЕОюОџ. ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ, ОћОАОЎОАОъОљОЋОф ОЋОцОеОўОЎОЮ ОљОЌОеОЎОЮ ОЎОцОАОЎОДОЋ ОюОбОЉОЋОе ОАОаОЏОеОЋОЪ.</translation>
<translation id="7980084013673500153">ОъОќОћОћ ОаОЏОА: <ph name="ASSET_ID" /></translation>
<translation id="7981313251711023384">ОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОЊОцОЎОЮ ОЏОЊОЎ ОюОљОцОЕОе ОњОюОЎОЕОћ ОЋОЌОЎОцОЋОЕ ОъОћОЎОеОЎОЮ ОЎОЋОфОе</translation>
<translation id="798145602633458219">ОћОдОъОЊОф ОћОћОдОбОћ <ph name="SUGGESTION_NAME" /> ОюОфОЎОЉОф ОћОЌОЎОцОЋОЕ</translation>
<translation id="7981662863948574132">РђЈОћОдОњОф ОћОЌОюОЋОЪ ОћОДОЋОцОЦ ОЕОю ОъОАОцОе Оћ-EID ОЋОДОЋОЊ Оћ-QR ОЕОю ОћОъОЏОЕОЎОе</translation>
<translation id="7981670705071137488">ОЉОАОЎОЋОЮ ОћОћОЋОеОЊОћ, ОбОЊОЏОЋОаОЎ ОфОЋОЏОаОћ ОЎОфОЉОдОбОЋ ОЉОеОДОб. ОљОцОЕОе ОюОаОћОю ОљОф ОћОћОбОЊОцОЋОф ОюОњОЉОЎ ОбОЊОЏОЋОаОЎОЮ ОЉОћОњОЊОеОЋОф.</translation>
<translation id="7982083145464587921">ОЏОЊОљОЎ ОюОљОфОЌОю ОљОф ОћОъОЏОЕОЎОе ОЏОЊОЎ ОюОфОДОЪ ОљОф ОћОЕОњОЎОљОћ.</translation>
<translation id="7982789257301363584">ОеОЕОф</translation>
<translation id="7984068253310542383">ОЕОЎОДОЋОБ ОъОАОџ ОЕОю <ph name="DISPLAY_NAME" /></translation>
<translation id="7986295104073916105">ОДОеОЎОљОћ ОЋОЕОЎОаОЋОЎ ОЕОю ОћОњОЊОеОЋОф ОЉОЕОЉОЎОю ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="7987814697832569482">РђЈОћОЌОЎОЉОЋОе ОЎОфОЉОдОб ОфОъОЎОЊ ОЊОеОџ Оћ-VPN ОћОќОћ</translation>
<translation id="7987932397583333141">ОћОњОЊОеОф ОДОЋОЊ ОљОЎОъОЋОф ОљОЋ ОАОЎОАОъОћ</translation>
<translation id="7988355189918024273">ОЎОЕ ОюОћОцОбОЎОю ОфОЏОЋОаОЋОф ОаОњОЎОЕОЋОф</translation>
<translation id="7988805580376093356">РђЈОъОбОеОЏОф ОћОћОцОбОюОћ ОЕОюОџ ОфОъОЕОЎОџ ОюОеОЋОЦ, ОЋОъОбОеОЏОф <ph name="DEVICE_OS" /> ОфОеОЋОЦ ОъОћ-USB.</translation>
<translation id="7991296728590311172">ОћОњОЊОеОЋОф ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ</translation>
<translation id="7997826902155442747">ОбОЊОЎОцОЋОф ОфОћОюОЎОџ</translation>
<translation id="7999229196265990314">ОЎОдОе ОљОф ОћОДОЉОдОЎОЮ ОћОЉОљОЎОЮ:

ОфОЋОАОБ: <ph name="EXTENSION_FILE" />
ОДОЋОЉОЦ ОъОцОфОЌ: <ph name="KEY_FILE" />

ОЎОЕ ОюОЕОъОЋОе ОбОю ОДОЋОЉОЦ ОћОъОцОфОЌ ОЕОюОџ ОЉОъОДОЋОЮ ОЉОўОЋОЌ. ОћОЋОљ ОаОЌОЋОЦ ОљОЋОфОЋ ОЏОЊОЎ ОюОЎОдОЋОе ОњОеОАОљОЋОф ОЌОЊОЕОЋОф ОЕОю ОћОфОЋОАОБ ОЕОюОџ.</translation>
<translation id="8002274832045662704">ОћОњОЊОеОћ ОъОфОДОЊОъОф ОЕОю ОћОъОЊОцОАОф</translation>
<translation id="8002670234429879764">ОћОъОЊОцОАОф <ph name="PRINTER_NAME" /> ОюОљ ОќОъОЎОаОћ ОЎОЋОфОе</translation>
<translation id="8004582292198964060">ОЊОцОЊОцОЪ</translation>
<translation id="8005600846065423578">ОћОфОеОћ ОфОъОЎОЊ Ою-<ph name="HOST" /> ОюОњОЕОф ОюОюОЋОЌ</translation>
<translation id="8006630792898017994">РђЈОъОДОЕ ОћОеОЋОЋОЌ ОљОЋ Tab</translation>
<translation id="8008356846765065031">ОћОљОЎОаОўОеОаОў ОъОаОЋОфОД. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОЌОЎОЉОЋОе ОћОљОЎОаОўОеОаОў.</translation>
<translation id="8009225694047762179">ОаОЎОћОЋОю ОАОЎОАОъОљОЋОф</translation>
<translation id="8011372169388649948">ОћОАОЎОъОаОЎОЎОћ '<ph name="BOOKMARK_TITLE" />' ОћОЋОбОЉОеОћ.</translation>
<translation id="8012647001091218357">ОюОљ ОћОдОюОЌОаОЋ ОюОЎОдОЋОе ОДОЕОе ОбОЮ ОћОћОЋОеОЎОЮ ОЕОюОџ. ОаОАОћ ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="8013993649590906847">РђЈОљОЮ ОљОЎОЪ ОюОфОъОЋОаОћ ОфОЎОљОЋОе ОъОЋОбОЎОю, Chrome ОЎОаОАОћ ОюОАОцОД ОюОџ ОфОЎОљОЋОе. ОЏОЊОЎ ОюОЎОдОЋОе ОфОЎОљОЋОеОЎОЮ, ОћОфОъОЋОаОЋОф ОаОЕОюОЌОЋОф ОљОю Google.</translation>
<translation id="8014154204619229810">ОћОъОбОЊОЏОЪ ОцОЋОбОю ОЏОбОф. ОЎОЕ ОюОеОбОаОЪ ОЉОбОЋОЊ ОЊОДОћ ОЏОЊОЎ ОюОЉОЊОЋОД ОЕОаОЎОф.</translation>
<translation id="8014206674403687691">РђЈ<ph name="IDS_SHORT_PRODUCT_NAME" /> ОљОЎОаОЋ ОЎОЏОЋОю ОюОЌОќОЋОе ОюОњОеОАОћ ОћОъОЋОфОДОаОф ОћОДОЋОЊОъОф. ОЎОЕ ОюОаОАОЋОф ОюОЉОдОб ОЕОЋОЉ Powerwash ОюОъОЏОЕОЎОе.</translation>
<translation id="8015163965024115122">ОаОњОъОе ОћОќОъОЪ ОЕОћОЋОњОЊОе ОбОю-ОЎОЊОЎ ОћОћОЋОеОЎОЮ ОЕОюОџ ОЉОљОцОюОЎОДОдОЎОЋОф <ph name="IDS_SHORT_PRODUCT_NAME" /> ОљОЋ <ph name="IDS_SHORT_PRODUCT_NAME" />.</translation>
<translation id="8016266267177410919">ОљОЌОАОЋОЪ ОќОъОаОЎ</translation>
<translation id="8017176852978888182">РђЈОАОцОеОЎОЋОф ОъОЕОЋОфОцОЋОф ОЕОю Linux</translation>
<translation id="8017335670460187064"><ph name="LABEL" /></translation>
<translation id="8017679124341497925">ОДОЎОдОЋОе ОћОЊОеОџ ОбОЉОе ОбОеОЎОЏОћ</translation>
<translation id="8018298733481692628">ОюОъОЌОЋОД ОљОф ОћОцОеОЋОцОЎОю ОћОќОћ?</translation>
<translation id="8018313076035239964">ОћОћОњОЊОеОЋОф ОъОљОцОЕОеОЋОф ОюОџ ОюОЉОЌОЋОе ОљОф ОћОъОЎОЊОб ОЕОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОЋ ОЋОљОф ОћОфОЋОЏОЪ ОЕОћОЮ ОЎОЏОЋОюОЎОЮ ОюОћОдОЎОњ ОюОџ</translation>
<translation id="8023133589013344428">РђЈОаОЎОћОЋОю ОћОЕОцОЋОф ОЉОћОњОЊОеОЋОф ОЕОю ChromeOS Flex</translation>
<translation id="8023801379949507775">ОбОЊОЏОЋОЪ ОфОЋОАОцОЎОЮ</translation>
<translation id="8025151549289123443">ОъОАОџ ОћОаОбОЎОюОћ ОЋОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ</translation>
<translation id="8026334261755873520">ОаОЎОДОЋОЎ ОаОфОЋОаОЎ ОњОюОЎОЕОћ</translation>
<translation id="8028060951694135607">РђЈОЕОЌОќОЋОе ОъОцОфОЌ ОЕОю Microsoft</translation>
<translation id="8028803902702117856">ОћОДОЋОЉОЦ <ph name="FILE_NAME" /> ОЉОћОЋОеОЊОћ, <ph name="SIZE" /></translation>
<translation id="8028993641010258682">ОњОЋОЊОю</translation>
<translation id="8029492516535178472"><ph name="WINDOW_TITLE" /> РђЊ ОаОЕОюОЌОћ ОЉОДОЕОћ ОюОћОеОЕОљОћ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю Рїў + ОљОцОЕОеОЋОф + ОЌОЦ ОюОъОбОюОћ ОЏОЊОЎ ОюОћОЕОЎОЉ</translation>
<translation id="8029539783236818164">ОљОфОеОЎОЮ ОбОЮ ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОъОЎОЊОб ОюОњОЉОЎ ОћОъОАОЏОЎОЮ ОЕОюОџ ОЏОЊОЎ ОюОцОфОЋОЌ ОЋОюОћОдОЎОЉ ОЌОюОЋОаОЋОф</translation>
<translation id="8030169304546394654">ОъОаОЋОфОД</translation>
<translation id="8030852056903932865">ОљОЎОЕОЋОе</translation>
<translation id="8032244173881942855">ОюОљ ОаОЎОфОЪ ОюОћОбОЉОЎОе ОљОф ОћОЏОеОўОЎОАОЎОЎОћ.</translation>
<translation id="8032569120109842252">ОЉОъОбОДОЉ</translation>
<translation id="8033827949643255796">ОъОАОЋОъОЪ</translation>
<translation id="8033958968890501070">ОћОќОъОЪ ОЕОћОЋОДОдОЉ ОфОЮ</translation>
<translation id="8035059678007243127">ОћОЊОБ ОћОљОаОЋОаОЎОъОЎ ОћОЕОъОЋОе ОЉОъОўОъОЋОЪ ОюОЊОБ ОћОДОЋОЊОЮ/ОћОЉОљ: <ph name="BACK_FORWARD_CACHE_INCOGNITO_PAGE_URL" /></translation>
<translation id="8037117027592400564">ОДОеОЎОљОф ОЏОю ОћОўОДОАОў ОћОаОљОъОе ОЉОљОъОдОбОЋОф ОЊОЎОЉОЋОе ОъОАОЋОаОфОќ</translation>
<translation id="8037357227543935929">ОюОЕОљОЋОю (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="803771048473350947">ОДОЋОЉОЦ</translation>
<translation id="8041089156583427627"> ОЕОюОЎОЌОф ОъОЕОЋОЉ</translation>
<translation id="8041267120753677077">ОЕОЎОЊОЋОе ОљОцОюОЎОДОдОЎОЋОф ОъОћОўОюОцОЋОЪ</translation>
<translation id="8042142357103597104">ОЕОДОЎОцОЋОф ОўОДОАОў</translation>
<translation id="8042331986490021244">РђЈОћОАОЎОАОъОљОЋОф ОЕОюОџ ОъОЋОдОцОаОЋОф ОЉОъОЏОЕОЎОе ОюОцОаОЎ ОЕОћОЪ ОаОЕОъОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="8044262338717486897">ОћОљОцОюОЎОДОдОЎОћ <ph name="LINUX_APP_NAME" /> ОюОљ ОъОњОЎОЉОћ.</translation>
<translation id="8044899503464538266">ОљОЎОўОЎ</translation>
<translation id="8045253504249021590">РђЈОћОАОаОЏОеОЋОЪ ОћОЋОЕОЉОф ОЉОљОъОдОбОЋОф ОъОеОЏОќ ОћОЕОюОЎОўОћ ОЕОю Google.</translation>
<translation id="8045923671629973368">РђЈОЎОЕ ОюОћОќОЎОЪ ОъОќОћОћ ОљОцОюОЎОДОдОЎОћ ОљОЋ ОЏОфОЋОЉОф URL ОЕОю ОЌОаОЋОф ОљОЎОаОўОеОаОў</translation>
<translation id="8046132381940444654">РђЈОаОдОЎОњ ОъОЕОЎОеОЋОф ОћОюОДОЋОЌОЋОф ОЎОЏОЋОю ОюОћОЕОфОъОЕ ОЉОъОАОцОе Оћ-EID ОћОќОћ ОЏОЊОЎ ОюОбОќОЋОе ОюОџ ОюОћОцОбОЎОю ОљОф ОћОЕОЎОеОЋОф</translation>
<translation id="8047242494569930800">РђЈОћОбОЉОеОћ ОюОЌОЕОЉОЋОЪ Google</translation>
<translation id="804786196054284061">ОћОАОЏОЮ ОеОЎОЕОЎОЋОЪ ОюОъОЕОфОъОЕ ОДОдОћ</translation>
<translation id="8048977114738515028">ОЎОдОЎОеОф ОДОЎОдОЋОе ОЊОеОџ ОЉОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ ОЉОъОЏОЕОЎОе ОЕОюОџ ОЏОЊОЎ ОюОњОЕОф ОЎОЕОЎОеОЋОф ОюОцОеОЋОцОЎОю ОќОћ.</translation>
<translation id="8049029041626250638">РђЈОЎОЕ ОюОЌОЉОе ОъОДОюОЊОф ОљОЋ ОбОЏОЉОе. ОљОЮ ОЉОеОдОЋОаОџ ОюОћОЕОфОъОЕ ОЉОъОЏОЕОЎОеОЎ Bluetooth, ОбОюОЎОџ ОюОЋОЋОЊОљ ОЕОћОъОЏОЕОЎОеОЎОЮ ОъОЋОЏОаОЎОЮ ОюОћОфОљОъОћ.</translation>
<translation id="8049705080247101012">РђЈGoogle ОАОЎОъОаОћ ОљОф "<ph name="EXTENSION_NAME" />" ОЏОќОЊОЋОаОЎ, ОЋОћОћОфОДОаОћ ОаОъОаОбОћ</translation>
<translation id="8049948037269924837">ОњОюОЎОюОћ ОћОцОЋОЏОћ ОбОЮ ОюОЋОЌ ОћОъОњОб</translation>
<translation id="8050038245906040378">РђЈОЌОфОЎОъОф ОДОЋОЊ ОъОАОЌОеОЎ ОЕОю Microsoft</translation>
<translation id="8050191834453426339">ОљОЎОъОЋОф ОаОЋОАОБ</translation>
<translation id="8051193500142930381">ОфОЏОЋОаОЋОф ОЕОдОеОЎОЏОЋОф ОъОдОюОъОћ ОюОљ ОЎОцОбОюОЋ</translation>
<translation id="8051390370038326517">РђЈОюОљОЕОе ОфОъОЎОЊ РђЊ Ою-<ph name="HOST" /> ОфОћОЎОћ ОЕОюОЎОўОћ ОъОюОљОћ ОЉОъОЏОЕОЎОеОЎ MIDI</translation>
<translation id="8053278772142718589">РђЈОДОЉОдОЎОЮ ОЕОю PKCS #12</translation>
<translation id="8053390638574070785">ОўОбОЎОаОф ОћОЊОБ ОъОЌОЊОЕ</translation>
<translation id="8054517699425078995">ОДОЋОЉОЦ ОъОАОЋОњ ОќОћ ОЎОЏОЋОю ОюОцОњОЋОб ОЉОъОЏОЕОЎОе ОЕОюОџ. ОћОљОЮ ОюОЕОъОЋОе ОљОф <ph name="FILE_NAME" /> ОЉОЏОю ОќОљОф?</translation>
<translation id="8054563304616131773">ОЎОЕ ОюОћОќОЎОЪ ОЏОфОЋОЉОф ОљОЎОъОЎОЎОю ОЌОЋОДОЎОф</translation>
<translation id="8054883179223321715">ОќОъОЎОЪ ОбОЉОЋОе ОљОфОеОЎ ОЋОЎОЊОљОЋ ОъОАОЋОЎОъОЎОЮ</translation>
<translation id="8054921503121346576">РђЈОъОДОюОЊОф USB ОъОЌОЋОЉОеОф</translation>
<translation id="8057414620575339583">ОЌОЎОцОЋОЕ ОЉОдОЊ ОћОЊОБ</translation>
<translation id="8058655154417507695">ОЕОаОф ОфОцОЋОњОћ</translation>
<translation id="8058986560951482265">ОДОЋОцОдОаОЎ</translation>
<translation id="8059417245945632445">&amp;ОЉОЊОЎОДОф ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="8059456211585183827">ОљОЎОЪ ОъОЊОцОАОЋОф ОќОъОЎОаОЋОф ОюОЕОъОЎОеОћ.</translation>
<translation id="8061091456562007989">ОЌОќОеОћ ОюОћОњОЊОеОЋОф ОћОДОЋОЊОъОЋОф</translation>
<translation id="8061970399284390013">ОЉОЊОЎОДОф ОљОЎОЋОф ОЋОЊОДОЊОЋОД</translation>
<translation id="8061991877177392872">РђЈОаОеОљОћ ОЕОЏОЉОе ОћОњОЊОеОф ОљОф Voice Match ОЉОљОъОдОбОЋОф Assistant ОЉОъОЏОЕОЎОе ОљОЌОе. ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОћОДОюОўОЋОф ОћОДОЋОЊОъОЋОф ОћОљОюОћ ОЏОЊОЎ ОюОЎОдОЋОе ОфОЉОаОЎОф ОДОЋОю ОЉОъОЏОЕОЎОе ОќОћ.</translation>
<translation id="8062844841289846053">{COUNT,plural, =1{ОњОЎОюОЎОЋОЪ ОаОЎОЎОе ОљОЌОЊ}two{{COUNT} ОњОЎОюОЎОЋОаОЋОф ОаОЎОЎОе}many{{COUNT} ОњОЎОюОЎОЋОаОЋОф ОаОЎОЎОе}other{{COUNT} ОњОЎОюОЎОЋОаОЋОф ОаОЎОЎОе}}</translation>
<translation id="8063235345342641131">ОЊОъОЋОф ОЉОеОЎОеОф ОъОЌОЊОю ОЎОеОЋОДОћ</translation>
<translation id="8063535366119089408">ОљОЎОЕОЋОе ОюОеОљОЋОф ОљОф ОћОДОЋОЉОЦ</translation>
<translation id="8064015586118426197">ChromeOS Flex</translation>
<translation id="8064279191081105977">ОДОЉОЋОдОћ <ph name="GROUP_NAME" /> РђЈРђЊ <ph name="GROUP_CONTENTS" /> РђЈРђЊ <ph name="COLLAPSED_STATE" /></translation>
<translation id="8066444921260601116">ОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОюОЌОЎОЉОЋОе</translation>
<translation id="8070662218171013510">ОъОЕОЋОЉ ОцОЎОќОЎ</translation>
<translation id="8071432093239591881">ОћОЊОцОАОћ ОЏОфОъОЋОаОћ</translation>
<translation id="8073499153683482226">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф ОћОЮ ОЏОю ОћОаОфОЋОаОЎОЮ ОћОаОЕОъОеОЎОЮ ОЉОљОцОюОЎОДОдОЎОЋОф (ОЉОћОфОљОЮ ОюОћОњОЊОеОЋОф ОћОъОцОфОЌОЎОЮ), ОЏОЋОюОю ОаОфОЋОаОЎОЮ ОЏОъОЋ ОљОаОЕОЎ ОДОЕОе, ОћОЋОЊОбОЋОф ОЋОфОъОЋОаОЋОф.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОаОфОЋОаОЎ ОћОњОЎОЉОЋОЎ ОљОЎОаОЮ ОфОЋОцОАОЎОЮ ОЌОюОД ОъОћОъОЏОАОћ ОЕОю ОЌОЕОЉОЋОЪ ОћОЎОюОЊ/Оћ ОЕОюОџ ОЉ-Drive.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОљОцОЕОе ОюОЏОЉОЋОф ОљОф ОћОЕОЎОеОЋОф ОћОќОћ ОЉ'ОћОњОЊОеОЋОф'.<ph name="END_PARAGRAPH3" /></translation>
<translation id="8076492880354921740">ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="8076835018653442223">ОъОаОћОю ОћОъОбОеОЏОф ОЉОЎОўОю ОљОф ОћОњОЎОЕОћ ОюОДОЉОдОЎОЮ ОъОДОЋОъОЎОЎОЮ ОЉОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="808089508890593134">Google</translation>
<translation id="8081623398548615289">ОћОАОЕОЪ ОЕОюОџ ОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="MANAGER_NAME" />. ОћОљОЊОъОЎОаОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОъОЌОЋОД ОљОф ОћОцОеОЋОцОЎОю ОЕОюОџ ОЋОюОбОДОЋОЉ ОљОЌОе ОћОфОаОЋОбОћ ОЕОюОџ ОЉОеОЕОф.</translation>
<translation id="8081989000209387414">РђЈОюОћОЕОЉОЎОф ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB?</translation>
<translation id="8082106343289440791">ОћОљОЮ ОюОћОфОљОЎОЮ ОбОЮ "<ph name="DEVICE_NAME" />"?</translation>
<translation id="8082390128630131497">РђЈОћОЕОЉОфОћ ОЕОю ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB ОЎОљОцОА ОљОф Оћ<ph name="DEVICE_TYPE" /> ОћОќОћ ОюОћОњОЊОеОЋОф ОћОЎОдОеОЪ. ОЏОю ОЌОЕОЉОЋОаОЋОф ОћОъОЕОфОъОЕ ОЋОћОаОфОЋОаОЎОЮ ОћОъОДОЋОъОЎОЎОЮ ОЎОЎОъОЌОДОЋ.</translation>
<translation id="8084114998886531721">ОАОЎОАОъОћ ОЕОъОЋОеОћ</translation>
<translation id="8084510406207562688">ОЕ&amp;ОЌОќОЋОе ОЏОю ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="8086015605808120405">ОћОњОЊОеОф <ph name="PRINTER_NAME" /> ОъОфОЉОдОбОф...</translation>
<translation id="8086442853986205778">ОћОњОЊОеОћ ОЕОю <ph name="PRINTER_NAME" /></translation>
<translation id="8086610718778464681">РђЈОюОљ ОаОЎОфОЪ ОюОњОЉОЋОф ОљОцОюОЎОДОдОЎОЋОф ОЋОДОЉОдОЎОЮ ОъРђЉLinux</translation>
<translation id="80866457114322936">{NUM_FILES,plural, =1{ОћОДОЋОЉОЦ ОћОќОћ ОъОЋОдОцОЪ. ОдОеОЎОџ ОюОЉОДОЕ ОъОћОЉОбОюОЎОЮ ОЕОюОЋ ОюОцОбОаОЌ ОљОЋОфОЋ.}two{ОЌОюОД ОъОћОДОЉОдОЎОЮ ОћОљОюОћ ОъОЋОдОцОаОЎОЮ. ОдОеОЎОџ ОюОЉОДОЕ ОъОћОЉОбОюОЎОЮ ОЕОюОћОЮ ОюОцОбОаОЌ ОљОЋОфОЮ.}many{ОЌОюОД ОъОћОДОЉОдОЎОЮ ОћОљОюОћ ОъОЋОдОцОаОЎОЮ. ОдОеОЎОџ ОюОЉОДОЕ ОъОћОЉОбОюОЎОЮ ОЕОюОћОЮ ОюОцОбОаОЌ ОљОЋОфОЮ.}other{ОЌОюОД ОъОћОДОЉОдОЎОЮ ОћОљОюОћ ОъОЋОдОцОаОЎОЮ. ОдОеОЎОџ ОюОЉОДОЕ ОъОћОЉОбОюОЎОЮ ОЕОюОћОЮ ОюОцОбОаОЌ ОљОЋОфОЮ.}}</translation>
<translation id="808894953321890993">ОЕОЎОаОЋОЎ ОћОАОЎОАОъОћ</translation>
<translation id="8090234456044969073">ОбОЎОЋОЪ ОЉОеОЕОЎОъОф ОљОфОеОЎ ОћОљОЎОаОўОеОаОў ОЕОљОюОЎОћОЮ ОаОЏОаОАОф ОЉОфОЊОЎОеОЋОф ОњОЉОЋОћОћ</translation>
<translation id="8093359998839330381"><ph name="PLUGIN_NAME" /> ОюОљ ОъОњОЎОЉ</translation>
<translation id="8095105960962832018">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОњОЎОЉОЋОЎ ОЉ-Google Drive. ОљОцОЕОе ОюОЕОЌОќОе ОаОфОЋОаОЎОЮ ОљОЋ ОюОћОЌОюОЎОБ ОъОЏОЕОЎОе ОЉОДОюОЋОф ОъОфОЎ ОЕОеОЋОдОЎОЮ. ОћОњОЎОЉОЋОЎ ОЏОЋОюОю ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОћОњОЎОЉОЋОЎОЎОЮ ОаОЕОъОеОЎОЮ ОЉ-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОћОАОЎОАОъОћ ОюОЌОЕОЉОЋОЪ Google ОЕОюОџ.
<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф ОћОЮ ОЏОю ОћОаОфОЋОаОЎОЮ ОћОаОЕОъОеОЎОЮ ОЉОљОцОюОЎОДОдОЎОЋОф (ОЉОћОфОљОЮ ОюОћОњОЊОеОЋОф ОћОъОцОфОЌОЎОЮ), ОЏОЋОюОю ОаОфОЋОаОЎОЮ ОЏОъОЋ ОљОаОЕОЎ ОДОЕОе, ОћОЋОЊОбОЋОф ОЋОфОъОЋОаОЋОф.
.<ph name="END_PARAGRAPH3" />
    <ph name="BEGIN_PARAGRAPH4" />ОаОфОЋОаОЎ ОњОЎОЉОЋОЎ ОљОЎОаОЮ ОфОЋОцОАОЎОЮ ОЌОюОД ОъОъОЏОАОф ОћОљОЌОАОЋОЪ ОЉ-Drive.<ph name="END_PARAGRAPH4" />
    <ph name="BEGIN_PARAGRAPH5" />ОљОцОЕОе ОюОЏОЉОЋОф ОљОф ОћОЕОЎОеОЋОф ОћОќОћ ОЉ'ОћОњОЊОеОЋОф'.<ph name="END_PARAGRAPH5" /></translation>
<translation id="8096740438774030488">ОъОбОЉОе ОюОъОдОЉ ОЕОЎОаОћ ОЉОќОъОЪ ОЕОЎОъОЋОЕ ОЉОАОЋОюОюОћ</translation>
<translation id="80974698889265265">ОДОЋОЊОЎ ОћОљОЎОъОЋОф ОљОЎОаОЮ ОфОЋОљОъОЎОЮ</translation>
<translation id="809792523045608178">РђЈ<ph name="IDS_SHORT_PRODUCT_NAME" /> ОъОЕОфОъОЕ ОЉОћОњОЊОеОЋОф ОЕОеОф proxy ОЕОаОДОЉОбОЋ ОбОю-ОЎОЊОЎ ОфОЋОАОБ</translation>
<translation id="8097959162767603171">РђЈОъОаОћОю ОћОъОбОеОЏОф ОдОеОЎОџ ОДОЋОЊОЮ ОюОљОЕОе ОљОф ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОЉОеОЕОЎОъОф ОъОЏОЕОЎОеОЎ Chrome ОЕОЉОъОАОЋОБ Оћ-Admin.</translation>
<translation id="8098156986344908134">ОюОћОфОДОЎОЪ ОљОф <ph name="DEVICE_OS" /> ОЋОюОъОЌОЋОД ОљОф ОћОЏОЋОаОЪ ОћОДОЕОЎОЌ?</translation>
<translation id="8098616321286360457">ОаОЊОеОЕ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="810068641062493918"><ph name="LANGUAGE" /> ОаОЉОЌОеОћ. ОЏОЊОЎ ОюОЉОўОю ОљОф ОћОЉОЌОЎОеОћ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю 'ОЌОЎОцОЋОЕ' ОЋОбОю ОъОДОЕ ОћОеОЋОЋОЌ.</translation>
<translation id="8100972288595615768">ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОљОф ОћОћОеОЕОљОЋОф ОюОљОфОе <ph name="SITE_NAME" />?</translation>
<translation id="810185532889603849">ОдОЉОб ОъОЋОфОљОЮ ОљОЎОЕОЎОф</translation>
<translation id="8101987792947961127">РђЈОЎОЕ ОюОЉОдОб Powerwash ОЉОљОфОЌОЋОю ОћОЉОљ</translation>
<translation id="81020759409809034">ОъОЎОДОЋОЮ ОъОДОЋОъОЎ</translation>
<translation id="8102139037507939978">РђЈОћОАОеОћ ОЕОю ОцОеОўОЎОЮ ОљОЎОЕОЎОЎОЮ ОъОќОћОЎОЮ ОъОћОДОЋОЉОЦ system_logs.txt.</translation>
<translation id="8104088837833760645">РђЈОћОЋОеОЊОф ОцОеОЋОцОЎОю eSIM</translation>
<translation id="8105368624971345109">ОЏОЎОЉОЋОЎ</translation>
<translation id="8105541061909542455">{NUM_APPS,plural, =1{ОљОцОюОЎОДОдОЎОћ ОюОљ ОаОфОъОЏОф}two{ОљОцОюОЎОДОдОЎОЋОф ОюОљ ОаОфОъОЏОЋОф}many{ОљОцОюОЎОДОдОЎОЋОф ОюОљ ОаОфОъОЏОЋОф}other{ОљОцОюОЎОДОдОЎОЋОф ОюОљ ОаОфОъОЏОЋОф}}</translation>
<translation id="8107015733319732394">РђЈОћОћОфОДОаОћ ОЕОю ОЌОаОЋОф Google Play ОЉОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОъОфОЉОдОбОф. ОЎОЎОфОЏОЪ ОЕОћОћОфОДОаОћ ОфОЎОъОЕОџ ОЏОъОћ ОЊОДОЋОф.</translation>
<translation id="810728361871746125">ОеОќОЋОюОЋОдОЎОЎОф ОъОАОџ</translation>
<translation id="8108526232944491552">{COUNT,plural, =0{РђЈОљОЎОЪ ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ}=1{РђЈОДОЋОЉОЦ cookie ОљОЌОЊ ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОаОЌОАОЮ}two{РђЈ# ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОаОЌОАОъОЋ}many{РђЈ# ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОаОЌОАОъОЋ}other{РђЈ# ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОаОЌОАОъОЋ}}</translation>
<translation id="8109109153262930486">ОЊОъОЋОф ОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="8110489095782891123">ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОеОЕОЎОъОф ОљОаОЕОЎ ОДОЕОеРђд</translation>
<translation id="8113476325385351118">РђЈОюОћОъОЕОЎОџ ОюОЌОАОЋОЮ РђЊ ОћОљОфОе ОюОљ ОЎОДОЉОю ОЕОюОЎОўОћ ОъОюОљОћ ОЉОъОЏОЕОЎОеОЎ MIDI</translation>
<translation id="8114199541033039755">РђЈОЉОъОдОЉ ОўОљОЉОюОў ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОюОЌОдОаОЎОЮ ОЏОЊОЎ ОюОбОЉОЋОе ОљОю ОЊОБ ОћОЉОЎОф, ОюОЌОќОЋОе ОюОЊОБ ОћОДОЋОЊОЮ ОЋОюОбОЉОЋОе ОЉОЎОЪ ОљОцОюОЎОДОдОЎОЋОф. ОћОљОцОЕОеОЋОф ОъОЋОцОбОюОф ОЏОЕОъОцОбОЎОюОЎОЮ ОљОф ChromeVox ОљОЋ ОљОф 'ОюОЌОЎОдОЋОф ОљОЋОўОЋОъОўОЎОЋОф'.</translation>
<translation id="8115139559594092084">РђЈОъ-Google Drive ОЕОюОџ</translation>
<translation id="8116972784401310538">&amp;ОъОаОћОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="8118362518458010043">РђЈОћОЋОЕОЉОф ОбОю-ОЎОЊОЎ Chrome. ОЎОЎОфОЏОЪ ОЕОћОфОЋОАОБ ОћОќОћ ОюОљ ОЉОўОЋОЌ.</translation>
<translation id="8118488170956489476">Оћ<ph name="BEGIN_LINK" />ОЊОцОЊОцОЪ ОъОаОЋОћОю<ph name="END_LINK" /> ОбОю-ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="8118515372935001629">ОДОдОЉ ОћОеОбОаОЋОЪ ОЕОю ОћОъОАОџ</translation>
<translation id="8118860139461251237">ОаОЎОћОЋОю ОћОћОЋОеОЊОЋОф ОЕОюОџ</translation>
<translation id="8119438628456698432">ОЎОдОЎОеОф ОДОЋОЉОдОЎ ОЎОЋОъОЪ ОъОфОЉОдОбОф...</translation>
<translation id="811994229154425014">ОеОЋОЋОЌ ОЏОцОЋОю ОюОћОДОюОЊОф ОаОДОЋОЊОћ</translation>
<translation id="8120505434908124087">РђЈОћОфОДОаОф ОцОеОЋОцОЎОю eSim</translation>
<translation id="812260729110117038">ОъОцОеОАОъОЎОЮ ОЋОЉОбОюОЎ ОфОЋОЏОЪ ОЊОЎОњОЎОўОюОЎ ОЎОЏОЋОюОЎОЮ ОюОЉОЌОЋОЪ ОљОф ОЎОбОЎОюОЋОф ОћОъОЋОЊОбОЋОф ОЉОЊОеОџ ОЕОљОЎОаОћ ОЏОЋОюОюОф ОъОбОДОЉ ОљОЌОеОЎОџ ОЉОљОфОеОЎОЮ ОЕОЋОаОЎОЮ.</translation>
<translation id="81238879832906896">ОцОеОЌ ОдОћОЋОЉ ОЋОюОЉОЪ</translation>
<translation id="8124313775439841391">РђЈONC ОъОаОЋОћОю</translation>
<translation id="813082847718468539">ОћОдОњОф ОаОфОЋОаОЎ ОљОфОе</translation>
<translation id="8131740175452115882">ОљОЎОЕОЋОе</translation>
<translation id="8133297578569873332">РђЈОАОЉОЎОе РђЊ FM</translation>
<translation id="8133676275609324831">&amp;ОћОдОњОћ ОЉОфОЎОДОЎОЎОћ</translation>
<translation id="8135557862853121765"><ph name="NUM_KILOBYTES" />K</translation>
<translation id="8136269678443988272">ОДОЋОЊОЎ ОћОљОЎОъОЋОф ОЕОћОќОаОф ОюОљ ОфОЋОљОъОЎОЮ</translation>
<translation id="8137559199583651773">ОаОЎОћОЋОю ОфОЋОАОцОЎОЮ</translation>
<translation id="8138082791834443598">ОљОЋОцОдОЎОЋОаОюОЎ - ОћОќОаОф ОцОеОўОЎОЮ ОЌОЊОЕОЎОЮ ОљОЋ ОбОЊОЏОЋОЪ ОцОеОўОЎОЮ ОДОЎОЎОъОЎОЮ ОюОЕОЎОЋОџ ОљОю ОъОЏОЕОЎОе ОќОћ.</translation>
<translation id="8138217203226449454">ОћОљОЮ ОћОфОЏОЋОЋОаОф ОюОЕОаОЋОф ОљОф ОАОцОД ОћОЌОЎОцОЋОЕ ОЕОюОџ?</translation>
<translation id="8138997515734480534">ОћОАОўОўОЋОА ОЕОю <ph name="VM_NAME" /></translation>
<translation id="8139447493436036221">РђЈОДОЉОдОЎОЮ ОЉ-Google Drive</translation>
<translation id="8140070492745508800"><ph name="FIRST_DEVICE" />, <ph name="SECOND_DEVICE" /></translation>
<translation id="8141584439523427891">ОаОцОфОЌ ОбОЏОЕОЎОЋ ОЉОЊОцОЊОцОЪ ОЌОюОЋОцОЎ</translation>
<translation id="8141725884565838206">ОаОЎОћОЋОю ОћОАОЎОАОъОљОЋОф ОЕОюОџ</translation>
<translation id="814204052173971714">{COUNT,plural, =1{ОАОеОўОЋОЪ}two{# ОАОеОўОЋОаОЎОЮ}many{# ОАОеОўОЋОаОЎОЮ}other{# ОАОеОўОЋОаОЎОЮ}}</translation>
<translation id="8143442547342702591">ОЎОЎОЕОЋОЮ ОюОљ ОЌОЋОДОЎ</translation>
<translation id="8143609395536282994">ОљОЎОџ ОљОцОЕОе ОюОаОћОю ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ:</translation>
<translation id="8143951647992294073">ОЉОЌОЎОеОф <ph name="TOPIC_SOURCE" /> <ph name="TOPIC_SOURCE_DESC" /></translation>
<translation id="8146177459103116374">ОљОЮ ОаОеОЕОъОф ОЏОЉОе ОЉОъОЏОЕОЎОе ОќОћ, ОЎОћОЎОћ ОЉОљОцОЕОеОЋОфОџ <ph name="LINK2_START" />ОюОћОфОЌОЉОе ОЏОъОЕОфОъОЕ ОДОЎОЎОЮ<ph name="LINK2_END" />.</translation>
<translation id="8146287226035613638">ОаОЎОфОЪ ОюОћОЋОАОЎОБ ОЕОцОЋОф ОъОЋОбОЊОцОЋОф ОЋОюОЊОеОњ ОљОЋОфОЪ. ОћОљОфОеОЎОЮ ОЎОЋОдОњОЋ ОЉОЕОцОЋОф ОћОъОЋОбОЊОцОЋОф ОЕОюОџ ОЏОЕОќОћ ОЎОћОЎОћ ОљОцОЕОеОЎ. ОћОћОбОЊОцОЋОф ОћОљОюОћ ОъОАОЋОаОЏОеОаОЋОф ОбОЮ ОћОњОЊОеОЋОф ОћОЊОцОЊОцОЪ. <ph name="BEGIN_LINK_LEARN_MORE" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK_LEARN_MORE" /></translation>
<translation id="8146793085009540321">ОћОЏОаОЎОАОћ ОаОЏОЕОюОћ. ОЎОЕ ОюОЎОдОЋОе ОДОЕОе ОбОЮ ОъОаОћОю ОћОъОбОеОЏОф ОљОЋ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="8147346945017130012">РђЈОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОДОеОЎОАОћ ОЋОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОљОю Google ОфОбОќОЋОе ОюОЕОцОе ОљОф ОћОфОЏОЋОаОЋОф ОЋОљОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю Chrome ОЋОЕОю ChromeOS.</translation>
<translation id="8147900440966275470">ОаОъОдОљОћ ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="NUM" />)</translation>
<translation id="8148760431881541277">ОћОњОЉОюОф ОЏОаОЎОАОћ</translation>
<translation id="8149564499626272569">РђЈОљОЎОъОЋОф ОЉОљОъОдОбОЋОф ОћОўОюОцОЋОЪ ОбОЮ ОЏОЉОю USB</translation>
<translation id="815114315010033526">РђЈОЕОЎОъОЋОЕ ОЉОДОЋОЊ QR ОЉОъОДОЋОЮ ОќОљОф</translation>
<translation id="8151638057146502721">ОћОњОЊОеОћ</translation>
<translation id="8154790740888707867">ОљОЎОЪ ОДОЋОЉОЦ</translation>
<translation id="8154912474061769055">ОЎОЎОфОЏОЪ ОЕОћОфОЏОЋОаОЋОф ОЕОю ОЌОюОД ОњОЊОЋОю ОъОћОљОфОеОЎОЮ ОюОљ ОЎОцОбОюОЋ</translation>
<translation id="815491593104042026">ОљОЋОцОА! ОћОљОЎОъОЋОф ОаОЏОЕОю ОъОцОаОЎ ОЕОћОЋОљ ОћОЋОњОЊОе ОюОћОЕОфОъОЕ ОЉОЏОфОЋОЉОф ОљОфОе ОюОљ-ОъОљОЋОЉОўОЌОф (<ph name="BLOCKED_URL" />). ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф.</translation>
<translation id="8155676038687609779">{COUNT,plural, =0{ОюОљ ОаОъОдОљОЋ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}=1{ОАОЎОАОъОћ ОљОЌОф ({COUNT}) ОЕОаОЌОЕОцОћ}two{{COUNT} ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}many{{COUNT} ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}other{{COUNT} ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}}</translation>
<translation id="8157248655669507702">РђЈОЎОЕ ОюОћОцОбОЎОю ОЌОЉОЎОюОф ОњОюОЎОЕОћ ОЏОЊОЎ ОюОћОфОДОЎОЪ ОцОеОЋОцОЎОю eSIM</translation>
<translation id="8157704005178149728">ОћОъОбОеОЏОф ОъОњОЊОЎОеОћ ОцОЎОДОЋОЌ</translation>
<translation id="8158117992543756526">ОћОъОЏОЕОЎОе ОћОќОћ ОюОљ ОъОДОЉОю ОбОЊОЏОЋОаОЎ ОфОЋОЏОаОћ ОЋОљОЉОўОЌОћ ОљОЋОўОЋОъОўОЎОЎОЮ ОъОљОќ <ph name="MONTH_AND_YEAR" />. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="8159652640256729753">ОДОЉОюОф ОљОЎОЕОЋОе ОЉОеОўОў ОбОю ОЉОЎОдОЋОб ОцОбОЋОюОЋОф ОЏОъОЋ ОцОЎОдОЋОю ОћОъОАОџ ОЋОћОЌОюОцОф ОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="816055135686411707">ОЕОњОЎОљОћ ОЉОћОњОЊОеОф ОљОъОЋОЪ ОЉОљОЎОЕОЋОе</translation>
<translation id="8160775796528709999">ОћОцОбОюОф ОЏОфОЋОЉОЎОЋОф ОъОЎОЎОЊОЎОЋОф ОЉОћОњОЊОеОЋОф ОфОљОцОЕОе ОћОдОњОф ОЏОфОЋОЉОЎОЋОф ОюОљОЋОЊОЎОЋ ОЋОюОЋОЋОЎОЊОљОЋ</translation>
<translation id="816095449251911490"><ph name="SPEED" /> - <ph name="RECEIVED_AMOUNT" />, <ph name="TIME_REMAINING" /></translation>
<translation id="81610453212785426">РђЈОЉОљОъОдОбОЋОф <ph name="BEGIN_LINK" />ОљОеОњОќ ОЌОЋОю ОюОцОеОўОЎОЋОф<ph name="END_LINK" />, ОъОцОфОЌОЎОЮ ОЉ-Chrome ОўОЏОаОЋОюОЋОњОЎОЋОф ОЌОЊОЕОЋОф ОЕОъОњОЎОаОЋОф ОбОюОЎОџ ОъОцОаОЎ ОъОбОДОЉ ОЉОљОфОеОЎОЮ ОЕОЋОаОЎОЮ ОфОЋОџ ОЕОъОЎОеОћ ОбОю ОћОљОЋОцОЎ ОћОцОфОЋОЌ ОЕОю ОеОЕОф ОћОљОЎОаОўОеОаОў.</translation>
<translation id="8161293209665121583">ОъОдОЉ ОДОЋОеОљ ОюОЊОцОЎ ОљОЎОаОўОеОаОў</translation>
<translation id="8162984717805647492">{NUM_TABS,plural, =1{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЎОћ ОюОЌОюОЋОЪ ОЌОЊОЕ}two{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЋОф ОюОЌОюОЋОЪ ОЌОЊОЕ}many{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЋОф ОюОЌОюОЋОЪ ОЌОЊОЕ}other{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЋОф ОюОЌОюОЋОЪ ОЌОЊОЕ}}</translation>
<translation id="8165997195302308593">РђЈОћОбОЉОеОћ ОюОЎОдОЎОљОћ ОљОЌОеОф ОЉ-Crostini</translation>
<translation id="816704878106051517">{COUNT,plural, =1{ОъОАОцОе ОўОюОцОЋОЪ}two{# ОъОАОцОеОЎ ОўОюОцОЋОЪ}many{# ОъОАОцОеОЎ ОўОюОцОЋОЪ}other{# ОъОАОцОеОЎ ОўОюОцОЋОЪ}}</translation>
<translation id="8168071266284693455">ОћОАОЎОъОаОЎОЋОф, ОћОАОЎОАОъОљОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОъОАОЋОаОЏОеОаОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОеОЕОЋОфОџ</translation>
<translation id="8168435359814927499">ОфОЋОЏОЪ</translation>
<translation id="8169165065843881617">{NUM_TABS,plural, =1{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЎОћ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}two{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЋОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}many{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЋОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}other{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЋОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}}</translation>
<translation id="8171334254070436367">ОћОАОфОеОф ОЏОю ОћОЏОеОўОЎОАОЎОЮ</translation>
<translation id="8174047975335711832">ОъОЎОЊОб ОъОћОъОЏОЕОЎОе</translation>
<translation id="8174876712881364124">РђЈОњОЎОЉОЋОЎ ОЉ-Google Drive. ОљОцОЕОе ОюОЕОЌОќОе ОаОфОЋОаОЎОЮ ОљОЋ ОюОћОЌОюОЎОБ ОъОЏОЕОЎОе ОЉОДОюОЋОф ОъОфОЎ ОЕОеОЋОдОЎОЮ. ОћОњОЎОЉОЋОЎ ОЏОЋОюОю ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф. ОћОњОЎОЉОЋОЎОЎОЮ ОаОЕОъОеОЎОЮ ОЉ-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОћОАОЎОАОъОћ ОюОЌОЕОЉОЋОЪ Google ОЕОю ОћОЎОюОЊ/Оћ ОЕОюОџ. <ph name="BEGIN_LINK1" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK1" /></translation>
<translation id="8176332201990304395">ОЋОеОЋОЊ ОЋОюОЉОЪ</translation>
<translation id="8177196903785554304">ОцОеОўОЎ ОћОеОЕОф</translation>
<translation id="8177318697334260664">{NUM_TABS,plural, =1{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЎОћ ОюОЌОюОЋОЪ ОЌОЊОЕ}two{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЋОф ОюОЌОюОЋОЪ ОЌОЊОЕ}many{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЋОф ОюОЌОюОЋОЪ ОЌОЊОЕ}other{ОћОбОЉОеОф ОЏОеОўОЎОАОЎОЋОф ОюОЌОюОЋОЪ ОЌОЊОЕ}}</translation>
<translation id="8179188928355984576">РђЈОюОљ ОЉОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОЋОф Ою-Android</translation>
<translation id="8179976553408161302">Enter</translation>
<translation id="8180786512391440389">"<ph name="EXTENSION" />" ОЎОЏОЋОю ОюОДОеОЋОљ ОЋОюОъОЌОЋОД ОДОЋОЉОдОЎ ОфОъОЋОаОЋОф, ОЋОЎОЊОљОЋ ОЋОљОЋОЊОЎОЋ ОЉОъОЎОДОЋОъОЎОЮ ОћОъОАОЋОъОаОЎОЮ.</translation>
<translation id="8181215761849004992">ОюОљ ОаОЎОфОЪ ОюОћОдОўОеОБ ОюОЊОЋОъОЎОЎОЪ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЌОЕОЉОЋОЪ ОЏОЊОЎ ОюОеОљОЋОф ОљОЮ ОЎОЕ ОюОџ ОћОеОЕОљОЋОф ОъОфОљОЎОъОЋОф ОюОћОЋОАОцОф ОъОЏОЕОЎОеОЎОЮ.</translation>
<translation id="8182105986296479640">ОћОљОцОюОЎОДОдОЎОћ ОюОљ ОъОњОЎОЉОћ</translation>
<translation id="8182412589359523143">ОЏОЊОЎ ОюОъОЌОЋОД ОљОф ОЏОю ОћОаОфОЋОаОЎОЮ ОъОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОќОћ, <ph name="BEGIN_LINK" />ОЎОЕ ОюОюОЌОЋОЦ ОЏОљОЪ<ph name="END_LINK" />.</translation>
<translation id="8182664696082410784"><ph name="REASON" />
    ОюОЊОбОфОЎ ОюОљ ОдОеОЎОџ ОюОЌОАОЋОЮ ОљОф ОћОљОфОе ОћОќОћ.</translation>
<translation id="8184288427634747179">ОъОбОЉОе ОљОю <ph name="AVATAR_NAME" /></translation>
<translation id="8184318863960255706">ОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="8184472985242519288">ОљОЌОЎОЊ</translation>
<translation id="8186609076106987817">ОћОЕОеОф ОюОљ ОћОдОюОЎОЌ ОюОъОдОЋОљ ОљОф ОћОДОЋОЉОЦ.</translation>
<translation id="8186704951085064172">ОЌОЎОцОЋОЕ ОЉОЌОюОД ОъОћОЊОБ ОЉОљОъОдОбОЋОф <ph name="VISUAL_SEARCH_PROVIDER" /></translation>
<translation id="8188389033983459049">ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОњОЊОеОЋОф ОћОъОЏОЕОЎОе ОЋОюОћОцОбОЎОю ОљОЋОфОЋ ОЏОЊОЎ ОюОћОъОЕОЎОџ</translation>
<translation id="8188742492803591566">РђЈОдОеОЎОџ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОњОЎОЕОћ ОЕОъОЋОцОЎОб ОЉ-Chromecast ОљОЋ ОЉОўОюОЋОЋОЎОќОЎОћ ОЏОЊОЎ ОюОћОфОЌОЎОю ОЉОћОбОЉОеОћ ОЕОю ОћОъОАОџ.</translation>
<translation id="8189306097519446565">ОЌОЕОЉОЋОаОЋОф ОЉОЎОф ОАОцОеОЎОЎОЮ</translation>
<translation id="8189750580333936930">ОљОеОњОќ ОЌОЋОю ОюОцОеОўОЎОЋОф</translation>
<translation id="8191230140820435481">ОюОаОћОю ОљОф ОћОЎОЎОЕОЋОъОЎОЮ, ОћОфОЋОАОцОЎОЮ ОЋОћОбОЎОдОЋОЉОЎОЮ ОЕОюОџ</translation>
<translation id="8192944472786724289">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОъОЉОДОЕОф ОћОеОЕОљОћ ОюОЕОфОБ ОљОф ОћОъОАОџ ОЕОюОџ.</translation>
<translation id="8193953846147532858"><ph name="BEGIN_LINK" />ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ<ph name="END_LINK" /> ┬и <ph name="EMAIL" /></translation>
<translation id="8195027750202970175">ОњОЋОЊОю ОЉОЊОЎОАОД</translation>
<translation id="8195191503358432289">ОћОЋОАОцОф ОАОЎОАОъОћ</translation>
<translation id="8198456017687137612">ОћОбОЉОеОф ОћОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="8199300056570174101">ОъОљОцОЎОЎОаОЎ ОеОЕОф (ОЕОЎОеОЋОф) ОЋОъОЏОЕОЎОе</translation>
<translation id="8200772114523450471">ОЌОЎОЊОЋОЕ</translation>
<translation id="8201717382574620700">ОЉОЌОЎОеОф ОљОюОЉОЋОъОЎ <ph name="TOPIC_SOURCE" /></translation>
<translation id="8202160505685531999">ОЎОЕ ОюОћОќОЎОЪ ОЕОЋОЉ ОљОф ОћОАОЎОАОъОћ ОЏОЊОЎ ОюОбОЊОЏОЪ ОљОф ОцОеОЋОцОЎОю <ph name="DEVICE_TYPE" />.</translation>
<translation id="8203152941016626022">ОћОњОЊОеОф ОЕОЮ ОћОъОЏОЕОЎОе ОюОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ</translation>
<translation id="8203732864715032075">ОћОъОбОеОЏОф ОЕОЋОюОЌОф ОюОџ ОћОфОеОљОЋОф ОЋОъОњОЊОЎОеОћ ОљОф ОћОъОЌОЕОЉ ОћОќОћ ОЏОЉОеОЎОеОф ОъОЌОЊОю ОюОЕОюОЎОЌОф ОћОћОЋОЊОбОЋОф. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="8205432712228803050">ОћОъОАОЏОЎОЮ ОЋОћОдОЎОЋОЊ ОћОћОЎОДОцОЎ ОбОЕОЋОЎОЎОЮ ОюОбОЉОЋОе ОљОЎОцОЋОА ОюОќОъОЪ ОДОдОе. ОЏОЊОЎ ОЕОћОЕОЎОаОЋОЎ ОћОќОћ ОЎОЎОЏОаОА ОюОфОЋОДОБ, ОЎОЕ ОюОаОфОД ОљОф ОћОдОЎОЋОЊ ОћОћОЎОДОцОЎ ОЋОюОЌОЉОе ОљОЋОфОЋ ОъОЌОЊОЕ.</translation>
<translation id="820568752112382238">ОћОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОаОЏОаОАОф ОЉОфОЊОЎОеОЋОф ОћОњОЉОЋОћОћ ОЉОЎОЋОфОе</translation>
<translation id="8206745257863499010">ОЉОюОЋОќ</translation>
<translation id="8206859287963243715">ОАОюОЋОюОљОеОЎ</translation>
<translation id="8210398899759134986">{MUTED_NOTIFICATIONS_COUNT,plural, =1{ОћОфОеОљОћ ОЌОЊОЕОћ}two{# ОћОфОеОљОЋОф ОЌОЊОЕОЋОф}many{# ОћОфОеОљОЋОф ОЌОЊОЕОЋОф}other{# ОћОфОеОљОЋОф ОЌОЊОЕОЋОф}}</translation>
<translation id="8212008074015601248">{NUM_DOWNLOAD,plural, =1{ОћОЋОеОЊОћ ОъОфОЉОдОбОф}two{ОћОЋОеОЊОЋОф ОъОфОЉОдОбОЋОф}many{ОћОЋОеОЊОЋОф ОъОфОЉОдОбОЋОф}other{ОћОЋОеОЊОЋОф ОъОфОЉОдОбОЋОф}}</translation>
<translation id="8213449224684199188">ОбОЉОеОф ОюОъОдОЉ ОфОъОЋОаОЋОф</translation>
<translation id="8214489666383623925">ОцОфОЎОЌОф ОДОЋОЉОЦ...</translation>
<translation id="8215129063232901118">ОљОцОЕОе ОюОЎОћОаОЋОф ОъОћОЎОЏОЋОюОЋОф ОЕОю ОћОўОюОцОЋОЪ ОЉ-<ph name="DEVICE_TYPE" /></translation>
<translation id="8217399928341212914">ОюОћОъОЕОЎОџ ОюОЌОАОЋОЮ ОћОЋОеОЊОЋОф ОљОЋОўОЋОъОўОЎОЋОф ОЕОю ОДОЉОдОЎОЮ ОъОеОЋОЉОЎОЮ</translation>
<translation id="822050276545350872">ОъОбОЏОЕОЎОЋ, ОюОљ ОЎОћОЎОћ ОдОЋОеОџ ОюОћОъОфОЎОЪ ОЎОЋОфОе</translation>
<translation id="8221491193165283816">ОћОЉОЌОЎОеОћ ОЕОюОџ ОћОЎОљ ОЉОЊОеОџ ОЏОюОю ОюОЌОАОЋОЮ ОћОфОеОљОЋОф. ОЏОЊОЎ ОюОљОцОЕОе ОюОљОфОе ОћОќОћ ОюОћОдОЎОњ ОћОфОеОљОЋОф ОЎОЕ ОюОюОЌОЋОЦ ОЏОљОЪ.</translation>
<translation id="822347941086490485">РђЈОъОфОЉОдОб ОЌОЎОцОЋОЕ ОЕОю ОъОЏОЕОЎОеОЎ HID...</translation>
<translation id="8225046344534779393">ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="8225265270453771718">ОЕОЎОфОЋОБ ОЌОюОЋОЪ ОЕОю ОљОцОюОЎОДОдОЎОћ</translation>
<translation id="8226222018808695353">ОљОАОЋОе</translation>
<translation id="8226619461731305576">ОфОЋОе</translation>
<translation id="8226628635270268143">ОЉОЌОЎОеОф ОћОфОъОЋОаОЋОф ОЋОћОљОюОЉОЋОъОЎОЮ ОћОљОћОЋОЉОЎОЮ ОбОюОЎОџ</translation>
<translation id="8227119283605456246">ОдОЎОеОЋОБ ОДОЋОЉОЦ</translation>
<translation id="8228783756378591900">ОћОъОбОеОЏОф ОЉОЋОЊОДОф ОљОЮ ОћОъОАОъОџ ОћОќОћ ОъОдОЎОЎОф ОюОъОЊОЎОаОЎОЋОф ОћОљОЉОўОЌОћ ОЕОю ОћОљОеОњОЋОЪ ОЕОюОџРђд</translation>
<translation id="8230134520748321204">ОћОљОЮ ОюОЕОъОЋОе ОљОф ОћОАОЎОАОъОћ ОЕОю <ph name="ORIGIN" />?</translation>
<translation id="8230446983261649357">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОдОЎОњ ОфОъОЋОаОЋОф</translation>
<translation id="8233028084277069927">ОцОфОЎОЌОћ ОбОЏОЕОЎОЋ</translation>
<translation id="8234795456569844941">ОеОЋОдОћ ОюОбОќОЋОе ОюОъОћОаОЊОАОЎОЮ ОЕОюОаОЋ ОюОцОфОЋОе ОљОф ОћОЉОбОЎОћ ОћОќОЋ? ОљОцОЕОе ОюОАОцОе ОюОаОЋ ОъОћ ОДОеОћ ОюОцОаОЎ ОЕОћОЋОдОњОћ ОюОџ ОћОЋОЊОбОф ОћОЕОњОЎОљОћ ОюОњОЉОЎ ОћОцОеОЋОцОЎОю:</translation>
<translation id="8235418492073272647">ОћОЊОБ ОЕОЋОфОБ ОъОћОъОЏОЕОЎОе <ph name="DEVICE_NAME" /></translation>
<translation id="8236911020904880539">ОюОдОљОф</translation>
<translation id="8236917170563564587">ОЕОЎОфОЋОБ ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ</translation>
<translation id="8237647586961940482">ОЋОеОЋОЊ ОЏОћОћ ОЋОљОЊОЋОЮ</translation>
<translation id="8239032431519548577">РђЈОћОћОеОЕОъОћ Ою-Enterprise ОћОЋОЕОюОъОћ</translation>
<translation id="8239932336306009582">ОюОљ ОъОЋОеОЕОЎОЮ ОюОЕОюОЋОЌ ОћОфОеОљОЋОф</translation>
<translation id="8241040075392580210">ОдОю</translation>
<translation id="8241806945692107836">ОДОЉОЎОбОф ОфОдОЋОеОф ОћОъОЏОЕОЎОе...</translation>
<translation id="8241868517363889229">ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОћОАОЎОъОаОЎОЋОф ОЕОюОџ</translation>
<translation id="8242370300221559051">РђЈОћОцОбОюОф ОЌОаОЋОф Play</translation>
<translation id="8242426110754782860">ОћОъОЕОџ</translation>
<translation id="8243948765190375130">ОЎОЎОфОЏОЪ ОЕОљОЎОЏОЋОф ОћОъОЊОЎОћ ОфОћОЎОћ ОаОъОЋОЏОћ ОЎОЋОфОе</translation>
<translation id="8244514732452879619">ОбОЋОЊ ОъОбОў ОЏОЎОЉОЋОЎ ОљОЋОеОЋОф</translation>
<translation id="8246776524656196770">ОљОцОЕОе ОюОћОњОЪ ОбОю ОъОцОфОЌ ОћОљОЉОўОЌОћ ОЉОљОъОдОбОЋОф ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="8248050856337841185">&amp;ОћОЊОЉОДОћ</translation>
<translation id="8248381369318572865">ОњОЎОЕОћ ОюОъОЎОДОеОЋОцОЋОЪ ОЋОаОЎОфОЋОЌ ОћОЊОЎОЉОЋОе</translation>
<translation id="8248887045858762645">РђЈОўОЎОц Ою-Chrome</translation>
<translation id="8249048954461686687">РђЈОфОЎОДОЎОЎОф OEM</translation>
<translation id="8249615410597138718">ОЕОюОЎОЌОћ ОљОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="8249672078237421304">ОљОаОЎ ОеОЋОдОћ ОюОДОЉОю ОћОдОбОЋОф ОюОфОеОњОЋОЮ ОЊОцОЎОЮ ОЕОљОЎОаОЮ ОЉОЕОцОћ ОЕОљОаОЎ ОДОЋОеОљ</translation>
<translation id="8250210000648910632">ОљОЎОЪ ОЎОЋОфОе ОаОцОЌ ОљОЌОАОЋОЪ ОцОаОЋОЎ</translation>
<translation id="8251441930213048644">ОЎОЕ ОюОеОбОаОЪ ОбОЏОЕОЎОЋ</translation>
<translation id="8251509999076836464">ОъОфОЉОдОбОф ОћОфОљОъОћ Ою-<ph name="DEVICE_NAME" /></translation>
<translation id="8251578425305135684">ОћОфОъОЋОаОћ ОћОъОъОЋОќОбОеОф ОћОЋОАОеОћ.</translation>
<translation id="825238165904109940">РђЈОћОдОњОћ ОЕОю ОЏОфОЋОЉОЋОф URL ОъОюОљОЋОф ОЉОЏОю ОћОъОДОеОЎОЮ</translation>
<translation id="8252569384384439529">ОћОћОбОюОљОћ ОъОфОЉОдОбОф...</translation>
<translation id="8253198102038551905">ОЎОЕ ОюОюОЌОЋОЦ ОбОю '+' ОЏОЊОЎ ОюОДОЉОю ОъОљОцОЎОЎОаОЎ ОеОЕОф</translation>
<translation id="8255212965098517578">ОћОфОъОЋОаОЋОф, ОћОћОфОеОљОЋОф ОЋОћОљОцОюОЎОДОдОЎОЋОф ОъОћОќОъОЪ ОћОљОЌОеОЋОЪ</translation>
<translation id="8256319818471787266">ОаОЉОЌОЪ</translation>
<translation id="8257950718085972371">ОћОъОЕОџ ОюОЌОАОЋОЮ ОњОЎОЕОћ ОюОъОдОюОъОћ</translation>
<translation id="8260864402787962391">ОбОЏОЉОе</translation>
<translation id="8261378640211443080">ОћОфОЋОАОБ ОћОќОћ ОюОљ ОеОЕОЋОЮ ОЉ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ОЋОЎОЎОфОЏОЪ ОЕОаОЋОАОБ ОюОюОљ ОЎОЊОЎОбОфОџ.</translation>
<translation id="8261506727792406068">ОъОЌОЎОДОћ</translation>
<translation id="8263336784344783289">ОЏОљОЪ ОаОЋОфОаОЎОЮ ОЕОЮ ОюОДОЉОЋОдОћ</translation>
<translation id="8263744495942430914"><ph name="FULLSCREEN_ORIGIN" /> ОћОЕОЉОЎОф ОљОф ОАОъОЪ ОћОбОЏОЉОе.</translation>
<translation id="8264024885325823677">ОћОћОњОЊОеОћ ОћОќОЋ ОъОаОЋОћОюОф ОбОю-ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ.</translation>
<translation id="8264718194193514834">"<ph name="EXTENSION_NAME" />" ОћОцОбОЎОю ОъОАОџ ОъОюОљ.</translation>
<translation id="826511437356419340">РђЈОаОЏОаОАОф ОюОъОдОЉ ОАОДОЎОеОћ ОЏОюОюОЎОф ОЕОю ОЌОюОЋОЪ. ОЏОЊОЎ ОюОаОЋОЋОў, ОЎОЕ ОюОћОЌОюОЎОД ОбОю ОћОъОАОџ, ОљОЋ ОюОћОДОЎОЕ ОбОю ОъОДОЕ Tab ОљОЮ ОъОЕОфОъОЕОЎОЮ ОЉОъОДОюОЊОф.</translation>
<translation id="8265671588726449108">{COUNT,plural, =1{ОћОЌОюОЋОЪ ОћОцОеОўОЎ ОюОљ ОЎОЎОцОфОЌ ОЕОЋОЉ ОљОЌОеОЎ ОћОћОцОбОюОћ ОъОЌОЊОЕ}two{{COUNT} ОћОЌОюОЋОаОЋОф ОћОцОеОўОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОЕОЋОЉ ОљОЌОеОЎ ОћОћОцОбОюОћ ОъОЌОЊОЕ}many{{COUNT} ОћОЌОюОЋОаОЋОф ОћОцОеОўОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОЕОЋОЉ ОљОЌОеОЎ ОћОћОцОбОюОћ ОъОЌОЊОЕ}other{{COUNT} ОћОЌОюОЋОаОЋОф ОћОцОеОўОЎОЎОЮ ОюОљ ОЎОЎОцОфОЌОЋ ОЕОЋОЉ ОљОЌОеОЎ ОћОћОцОбОюОћ ОъОЌОЊОЕ}}</translation>
<translation id="8266947622852630193">ОЏОю ОЕОЎОўОЋОф ОћОДОюОў</translation>
<translation id="8267539814046467575">ОћОЋОАОцОф ОъОЊОцОАОф</translation>
<translation id="8267961145111171918">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОќОћОЋ ОъОЎОЊОб ОЏОюОюОЎ ОбОю ОћОъОЏОЕОЎОе ОЋОбОю ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОЋ (ОЏОъОЋ ОеОъОф ОўОбОЎОаОф ОћОАОЋОюОюОћ, ОцОбОЎОюОЋОф ОЉОъОбОеОЏОф ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЕОњОЎОљОЋОф). ОћОаОфОЋОаОЎОЮ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОЕОцОе ОљОф Android. ОЏОъОЋ ОЏОЪ, ОЌОюОД ОъОћОъОЎОЊОб ОЕОЎОдОўОЉОе ОЎОбОќОЋОе Ою-Google ОЋОюОЕОЋОфОцОЎОћ, ОЏОъОЋ ОъОцОфОЌОЎ Android, ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЋОћОъОЋОдОеОЎОЮ ОЕОюОћОЮ.<ph name="END_PARAGRAPH1" />
<ph name="BEGIN_PARAGRAPH2" />ОЏОЎОЉОЋОЎ ОфОЏОЋОаОћ ОќОЋ ОюОљ ОЎОЕОцОЎОб ОбОю ОЎОЏОЋОюОф ОћОъОЏОЕОЎОе ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОаОЊОеОЕ ОюОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОбОЊОЏОЋОаОЎ ОъОбОеОЏОф ОЋОљОЉОўОЌОћ.<ph name="END_PARAGRAPH2" />
<ph name="BEGIN_PARAGRAPH3" />ОћОЉОбОюОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЕОюОЋОў ОЉОфОЏОЋОаОћ ОћОќОЋ ОЊОеОџ 'ОћОњОЊОеОЋОф' &gt; 'ОъОфОДОЊОЮ' &gt; 'ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОЕОЎОъОЋОЕ ОљОю Google'.<ph name="END_PARAGRAPH3" />
<ph name="BEGIN_PARAGRAPH4" />ОљОЮ ОћОЋОцОбОюОћ ОћОњОЊОеОћ ОаОЋОАОцОф ОЕОю 'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОЉОЌОЕОЉОЋОЪ ОЕОю ОћОЎОюОЊ/Оћ, ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОЋ/Оћ. ОљОцОЕОе ОюОДОеОЋОљ ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОћОњОЊОеОЋОф ОћОљОюОћ ОЋОљОЋОцОЪ ОћОЕОЎОаОЋОЎ ОЕОюОћОЮ ОЉОЏОфОЋОЉОф families.google.com.<ph name="END_PARAGRAPH4" /></translation>
<translation id="826905130698769948">ОљОЎОЕОЋОе ОюОДОЋОЌ ОюОљ ОЌОЋОДОЎ</translation>
<translation id="827097179112817503">ОћОдОњОф ОюОЌОдОЪ 'ОЊОБ ОћОЉОЎОф'</translation>
<translation id="8271268254812352141">ОЉОюОЌОЎОдОћ ОЎОъОаОЎОф ОљОЋ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю ОўОДОАОў, ОЎОЋОдОњОЋ ОћОњОЊОеОЋОф, ОфОеОњОЋОъОЎОЮ ОљОЋ ОћОъОеОф ОЎОЌОЎОЊОЋОф. ОЉ<ph name="LINK_BEGIN" />ОЕОцОЋОф ОюОљОфОеОЎОЮ<ph name="LINK_END" /> ОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОЕОцОЋОф ОюОфОеОњОЋОЮ.</translation>
<translation id="8271379370373330993">ОбОЏОЕОЎОЋ ОЎОЕ ОЏОъОћ ОЕОюОЉОЎОЮ ОЕОћОЋОеОЎОЮ ОдОеОЎОЏОЎОЮ ОюОћОЕОюОЎОЮ. ОљОцОЕОе ОЎОћОЎОћ ОюОћОЌОќОЎОе ОљОф Оћ-<ph name="DEVICE_TYPE" /> ОюОЎОюОЊ/Оћ ОюОљОЌОе ОћОњОЊОеОф ОћОЌОЕОЉОЋОЪ.</translation>
<translation id="8272194309885535896">ОћОЋОеОЊ ОфОъОЋОаОћ</translation>
<translation id="8272443605911821513">ОљОцОЕОе ОюОаОћОю ОљОф ОћОфОЋОАОцОЎОЮ ОбОю ОЎОЊОЎ ОюОЌОЎОдОћ ОбОю 'ОфОЋОАОцОЎОЮ' ОЉОфОцОеОЎОў 'ОЏОюОЎОЮ ОаОЋОАОцОЎОЮ'.</translation>
<translation id="8273905181216423293">ОюОћОЋОеОЊОћ</translation>
<translation id="8274332263553132018">ОћОбОЉОеОф ОДОЋОЉОЦ</translation>
<translation id="8274921654076766238">ОъОњОЊОЎОе ОбОЋОДОЉ ОљОЌОеОЎ ОъОЎОДОЋОЊ ОћОъОДОюОЊОф</translation>
<translation id="8274924778568117936">ОљОЎОЪ ОюОЏОЉОЋОф ОљОЋ ОюОАОњОЋОе ОљОф Оћ-<ph name="DEVICE_TYPE" /> ОюОцОаОЎ ОАОЎОЋОЮ ОћОбОЊОЏОЋОЪ. Оћ-<ph name="DEVICE_TYPE" /> ОЎОЋОцОбОю ОъОЌОЊОЕ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОАОЎОЋОЮ ОћОћОфОДОаОћ.</translation>
<translation id="8275038454117074363">ОЎОЎОЉОЋОљ</translation>
<translation id="8275080796245127762">ОЕОЎОЌОћ ОъОћОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="8275339871947079271">РђЈОъОЋОъОюОЦ ОюОћОбОЉОЎОе ОљОф ОћОАОЎОАОъОћ ОюОЌОЕОЉОЋОЪ Google ОЏОЊОЎ ОюОњОЕОф ОљОюОЎОћ ОЉОљОЋОцОЪ ОъОљОЋОЉОўОЌ ОюОљОЌОе ОћОфОЌОЉОеОЋОф ОюОЌОЕОЉОЋОЪ</translation>
<translation id="8276560076771292512">ОеОЎОДОЋОЪ ОћОъОўОъОЋОЪ ОЋОўОбОЎОаОћ ОъОЌОЊОЕ ОДОЕОЎОЌОћ</translation>
<translation id="8281886186245836920">ОЊОЎОюОЋОњ</translation>
<translation id="8283475148136688298">ОДОЋОЊ ОћОљОЎОъОЋОф ОаОЊОЌОћ ОЉОбОф ОћОћОфОЌОЉОеОЋОф Ою-"<ph name="DEVICE_NAME" />".</translation>
<translation id="8284279544186306258">ОЏОю ОљОфОеОЎ <ph name="WEBSITE_1" /></translation>
<translation id="8284326494547611709">ОЏОфОЋОЉОЎОЋОф</translation>
<translation id="8286036467436129157">ОЏОаОЎОАОћ</translation>
<translation id="8287902281644548111">РђЈОЌОЎОцОЋОЕ ОюОцОЎ ОДОеОЎОљОћ Ою-API/ОЏОфОЋОЉОф URL</translation>
<translation id="8288032458496410887">ОћОАОеОф <ph name="APP" />...</translation>
<translation id="8289128870594824098">ОњОЋОЊОю ОЏОЋОаОЪ</translation>
<translation id="8289509909262565712">ОЉОеОЋОџ ОЉОЋОљОџ ОљОю <ph name="DEVICE_OS" /></translation>
<translation id="8293206222192510085">ОћОЋОАОцОф ОАОЎОъОаОЎОЎОћ</translation>
<translation id="8294431847097064396">ОъОДОЋОе</translation>
<translation id="8298429963694909221">РђЈОћОфОеОљОЋОф ОЕОћОфОДОЉОюОЋ ОЉОўОюОцОЋОЪ ОЕОюОџ ОЎОЋОцОЎОбОЋ ОбОЏОЕОЎОЋ ОњОЮ ОЉОъОЏОЕОЎОе <ph name="DEVICE_TYPE" />. ОАОњОЎОеОф ОћОфОеОљОЋОф ОЉОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОфОАОњОЋОе ОљОЋОфОЪ ОњОЮ ОЉОўОюОцОЋОЪ ОЕОюОџ. ОЎОЕ ОюОЋОЋОЊОљ ОЕОћОўОюОцОЋОЪ ОаОъОдОљ ОЉОДОеОЉОф ОъОДОЋОЮ ОЋОЕОћ-Bluetooth ОЋОћ-Wi-Fi ОцОЋОбОюОЎОЮ.</translation>
<translation id="8299319456683969623">ОљОЎОаОџ ОъОЌОЋОЉОе ОюОљОЎОаОўОеОаОў ОЏОеОњОб</translation>
<translation id="8300011035382349091">ОбОеОЎОЏОф ОАОЎОъОаОЎОЎОћ ОбОЉОЋОе ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ</translation>
<translation id="8300374739238450534">ОЏОЌОЋОю ОюОЎОюОћ</translation>
<translation id="8303616404642252802">{COUNT,plural, =1{ОЏОфОЋОЉОф}two{# ОЏОфОЋОЉОЋОф}many{# ОЏОфОЋОЉОЋОф}other{# ОЏОфОЋОЉОЋОф}}</translation>
<translation id="8304383784961451596">РђЈОљОЎОЪ ОюОџ ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОъОЏОЕОЎОе ОћОќОћ. ОбОюОЎОџ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф ОюОДОЉОюОф ОћОеОЕОљОф ОЏОаОЎОАОћ ОљОЋ ОюОћОЎОЏОаОА ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google ОЉОцОЎОДОЋОЌ ОЕОю Family Link.</translation>
<translation id="8306885873692337975">ОДОЉОюОћ ОЕОю ОћОфОЏОЋОаОЋОф ОЋОЕОЎОцОЋОеОЎ ОћОљОЉОўОЌОћ ОћОљОЌОеОЋОаОЎОЮ.</translation>
<translation id="8307094075368387939">ОљОцОЕОе ОюОЏОЋОЋОаОЪ ОљОф ОюОЋОЌ ОћОќОъОаОЎОЮ ОЉОъОеОЏОќ ОћОћОфОљОъОћ ОћОљОЎОЕОЎОф, ОЋОњОЮ ОюОћОњОЊОЎОе ОўОцОў ОЋОЕОЋОъОе ОъОАОџ ОЋОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОдОЉОбОЎ ОћОъОбОеОЏОф.</translation>
<translation id="8308016398665340540">ОћОеОЕОф ОћОќОЋ ОъОЕОЋОфОцОф ОбОЮ ОъОЕОфОъОЕОЎОЮ ОљОЌОеОЎОЮ ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="8308179586020895837">ОюОЕОљОЋОю ОљОЮ <ph name="HOST" /> ОеОЋОдОћ ОюОњОЕОф ОюОъОдОюОъОћ ОЕОюОџ</translation>
<translation id="830868413617744215">ОЉОЎОўОљ</translation>
<translation id="8309458809024885768">ОћОљОЎОЕОЋОе ОЏОЉОе ОДОЎОЎОЮ</translation>
<translation id="8310409247509201074"><ph name="NUM" /> ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="831207808878314375">ОћОњОЊОеОћ</translation>
<translation id="8314089908545021657">ОћОфОљОъОћ ОюОўОюОцОЋОЪ ОЌОЊОЕ</translation>
<translation id="8314381333424235892">ОћОфОЋОАОБ ОЌОАОе ОљОЋ ОюОљ ОъОЋОфОДОЪ</translation>
<translation id="831440797644402910">ОюОљ ОаОЎОфОЪ ОюОцОфОЋОЌ ОљОф ОћОфОЎОДОЎОЎОћ ОћОќОЋ</translation>
<translation id="8314835274931377415">ОюОћОфОЌОЎОю ОЉОћОњОЊОеОћ ОЕОю ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ?</translation>
<translation id="8317671367883557781">ОћОЋОАОцОф ОЌОЎОЉОЋОе ОеОЕОф</translation>
<translation id="8319414634934645341">ОЕОЎОъОЋОЕ ОъОЋОеОЌОЉ ОЉОъОцОфОЌ</translation>
<translation id="8321837372750396788">ОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОќОћ ОЎОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="MANAGER" />.</translation>
<translation id="8322814362483282060">ОЊОБ ОќОћ ОаОЌОАОЮ ОюОњОЎОЕОћ ОюОъОЎОДОеОЋОцОЋОЪ ОЕОюОџ.</translation>
<translation id="8323167517179506834">ОћОДОюОЊОф ОЏОфОЋОЉОф ОљОфОе</translation>
<translation id="8323317289166663449">ОДОеОЎОљОћ ОЋОЕОЎОаОЋОЎ ОЕОю ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОъОЌОЕОЉ ОЋОЉОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="8324784016256120271">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ ОЉОљОфОеОЎОЮ ОЕОЋОаОЎОЮ, ОюОъОЕОю ОюОдОЋОеОџ ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОъОЋОЊОбОЋОф</translation>
<translation id="8325413836429495820">ОюОљ ОъОЋОеОЕОЎОЮ ОюОеОљОЋОф ОљОф ОћОюОЋОЌ</translation>
<translation id="8326478304147373412">РђЈPKCS #7, ОЕОеОЕОеОф ОљОЎОЕОЋОеОЎОЮ</translation>
<translation id="8327386430364625757">ОњОЋОцОЪ ОъОфОъОўОЎ</translation>
<translation id="8327676037044516220">ОћОњОЊОеОЋОф ОфОЋОЏОЪ ОЋОћОеОЕОљОЋОф</translation>
<translation id="8330617762701840933">ОеОЕОЎОъОф ОћОљОфОеОЎОЮ ОЕОъОцОаОЎОЮ ОюОЊОцОЊОцОЪ ОЌОюОЋОцОЎ.</translation>
<translation id="8330689128072902965">ОљОаОЕОЎ ОДОЕОе ОЉОДОеОЉОф ОъОДОЋОЮ ОЎОЏОЋОюОЎОЮ ОюОЕОфОБ ОљОЎОфОџ. ОљОцОЕОе ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОЕОаОЋОф.</translation>
<translation id="8331323939220256760">{FILE_TYPE_COUNT,plural, =1{ОАОЋОњ ОћОДОЋОЉОЦ ОћОаОфОъОџ: <ph name="FILE_TYPE1" />}=2{ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОаОфОъОЏОЎОЮ: <ph name="FILE_TYPE1" />, <ph name="FILE_TYPE2" />}=3{ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОаОфОъОЏОЎОЮ: <ph name="FILE_TYPE1" />, <ph name="FILE_TYPE2" />, <ph name="FILE_TYPE3" />}=4{ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОаОфОъОЏОЎОЮ: <ph name="FILE_TYPE1" />, <ph name="FILE_TYPE2" />, <ph name="FILE_TYPE3" />, <ph name="FILE_TYPE4" />}many{ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОаОфОъОЏОЎОЮ: <ph name="FILE_TYPE1" />, <ph name="FILE_TYPE2" />, <ph name="FILE_TYPE3" />, <ph name="FILE_TYPE4" /> (<ph name="LINK" />ОЋОбОЋОЊ {OVERFLOW_COUNT}<ph name="END_LINK" />)}other{ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОаОфОъОЏОЎОЮ: <ph name="FILE_TYPE1" />, <ph name="FILE_TYPE2" />, <ph name="FILE_TYPE3" />, <ph name="FILE_TYPE4" /> (<ph name="LINK" />ОЋОбОЋОЊ {OVERFLOW_COUNT}<ph name="END_LINK" />)}}</translation>
<translation id="8331822764922665615">РђЈОаОЋОфОаОЎОЮ ОЕОЮ ОюОДОЉОЋОдОћ, ОЉОЋОЌОеОЎОЮ ОдОЉОб ОЋОъОДОЎОЕОЎОЮ ОбОю Esc</translation>
<translation id="833256022891467078">РђЈОфОЎОДОЎОЋОф ОъОЕОЋОфОцОЋОф ОЕОю Crostini</translation>
<translation id="8335587457941836791">ОЉОЎОўОЋОю ОћОдОъОЊОћ ОюОъОЊОБ</translation>
<translation id="8336407002559723354">ОћОбОЊОЏОЋОаОЎОЮ ОЎОАОфОЎОЎОъОЋ ОЉОЌОЋОЊОЕ <ph name="MONTH_AND_YEAR" /></translation>
<translation id="8336739000755212683">ОЕОЎОаОЋОЎ ОфОъОЋОаОф ОћОЌОЕОЉОЋОЪ ОЉОъОЏОЕОЎОе</translation>
<translation id="8337047789441383384">ОЏОЉОе ОеОЕОъОф ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ ОћОќОћ. ОљОЎОЪ ОдОЋОеОџ ОюОеОЕОЋОЮ ОљОЋОфОЋ ОЕОЋОЉ.</translation>
<translation id="8338952601723052325">ОљОфОе ОћОљОЎОаОўОеОаОў ОЕОю ОћОъОцОфОЌ</translation>
<translation id="8339059274628563283">ОаОфОЋОаОЎОЮ ОћОъОљОЋОЌОАОаОЎОЮ ОЉОљОЋОцОЪ ОъОДОЋОъОЎ ОбОЉОЋОе <ph name="SITE" /></translation>
<translation id="833986336429795709">ОдОеОЎОџ ОюОЉОЌОЋОе ОљОцОюОЎОДОдОЎОћ ОЏОЊОЎ ОюОцОфОЋОЌ ОљОф ОћОДОЎОЕОЋОе ОћОќОћ</translation>
<translation id="8342221978608739536">ОюОљ ОаОЎОАОЎОфОЎ</translation>
<translation id="8342861492835240085">ОЉОЌОЎОеОф ОљОЋОАОБ</translation>
<translation id="8347227221149377169">ОъОЕОЎОъОЋОф ОћОЊОцОАОћ</translation>
<translation id="834785183489258869">РђЈОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ, ОљОфОеОЎОЮ ОюОљ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОЏОЊОЎ ОюОДОЉОю ОъОЎОЊОб ОбОю ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ ОЉОљОфОеОЎОЮ ОћОЕОЋОаОЎОЮ, ОюОъОЕОю ОюОдОЋОеОџ ОћОдОњОф ОъОЋОЊОбОЋОф ОЉОћОфОљОъОћ ОљОЎОЕОЎОф. ОЎОЎОфОЏОЪ ОЕОфОЏОЋОаОЋОф ОЉОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОюОљ ОЎОцОбОюОЋ.</translation>
<translation id="8350789879725387295">ОЏОюОЎ ОАОўОЎОЎОюОЋОА ОЉОљОќОЋОе ОћОъОЋОдОъОЊ</translation>
<translation id="8351316842353540018">ОюОћОдОЎОњ ОфОъОЎОЊ ОљОцОЕОеОЋОЎОЋОф ОаОњОЎОЕОЋо╝Оф</translation>
<translation id="8351419472474436977">РђЈОфОЋОАОБ ОќОћ ОћОЕОфОюОў ОбОю ОћОњОЊОеОЋОф ОЕОеОф Оћ-Proxy ОЕОюОџ. ОъОЕОъОбОЋОф ОћОЊОЉОе ОћОЎОљ ОЕОћОЋОљ ОЎОЏОЋОю ОюОЕОаОЋОф, ОюОДОўОЋОб ОљОЋ ОюОдОЋОфОф ОюОЏОю ОцОбОЋОюОћ ОЕОфОЉОдОб ОЉОљОЎОаОўОеОаОў. ОљОЮ ОљОЎОаОџ ОЎОЋОЊОб ОЉОЋОЋОЊОљОЋОф ОъОЊОЋОб ОЕОЎОаОЋОЎ ОќОћ ОћОфОеОЌОЕ, ОАОЉОЎОе ОюОћОаОЎОЌ ОЕОќОћОЋ ОЕОЎОаОЋОЎ ОюОљ ОеОдОЋОЎ.</translation>
<translation id="8351630282875799764">ОћОАОЋОюОюОћ ОюОљ ОаОўОбОаОф</translation>
<translation id="835238322900896202">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОъОћОюОџ ОћОАОеОф ОћОћОфОДОаОћ. ОЎОЕ ОюОћОАОЎОе ОљОф ОћОћОфОДОаОћ ОЉОљОъОдОбОЋОф ОћОъОАОЋОБ.</translation>
<translation id="8353683614194668312">ОЎОЏОЋОю:</translation>
<translation id="8354034204605718473">ОДОЋОЊ ОћОљОЎОъОЋОф ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОаОЋОАОБ</translation>
<translation id="8356197132883132838"><ph name="TITLE" /> - <ph name="COUNT" /></translation>
<translation id="8357388086258943206">РђЈОЕОњОЎОљОћ ОЉОћОфОДОаОф Linux</translation>
<translation id="8358685469073206162">ОћОљОЮ ОюОЕОЌОќОе ОљОф ОћОЊОцОЎОЮ?</translation>
<translation id="8358912028636606457">ОъОЏОЕОЎОе ОќОћ ОљОЎОаОЋ ОфОЋОъОџ ОЉОћОбОЉОеОф ОћОљОЋОЊОЎОЋ ОЕОю ОћОЏОеОўОЎОАОЎОЎОћ.</translation>
<translation id="835951711479681002">РђЈОЕОъОЎОеОћ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="8363095875018065315">ОЎОдОЎОЉ</translation>
<translation id="8363142353806532503">ОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ ОЉОЊОБ ОќОћ</translation>
<translation id="8366396658833131068">ОДОЎОЕОЋОеОЎОЋОф ОћОеОЕОф ОЕОюОџ ОћОфОЌОЊОЕОћ. ОЎОЕ ОюОЉОЌОЋОе ОеОЕОф ОљОЌОеОф ОљОЋ ОюОюОЌОЋОЦ ОбОю ОћОюОЌОдОЪ 'ОћОъОЕОџ' ОЕОюОъОўОћ ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОЎОЎОЕОЋОЮ ОћОДОЎОЋОАОД.</translation>
<translation id="8366694425498033255">ОъОДОЕОЎ ОЉОЌОЎОеОћ</translation>
<translation id="8368859634510605990">&amp;ОцОфОЎОЌОф ОЏОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="8370294614544004647">ОъОбОЉОе ОюОъОдОЉ ОЕОЎОаОћ ОЏОЕОћОъОЌОЕОЉ ОћОаОЎОЎОЊ ОаОАОњОе</translation>
<translation id="8371695176452482769">ОЊОЎОЉОЋОе ОбОЏОЕОЎОЋ</translation>
<translation id="8371925839118813971">{NUM_TABS,plural, =1{ОћОЕОфОДОф ОћОљОфОе}two{ОћОЕОфОДОф ОћОљОфОеОЎОЮ}many{ОћОЕОфОДОф ОћОљОфОеОЎОЮ}other{ОћОЕОфОДОф ОћОљОфОеОЎОЮ}}</translation>
<translation id="8373652277231415614">РђЈОАОцОеОЎОЋОф ОъОЕОЋОфОцОЋОф ОЕОю Crostini</translation>
<translation id="8376137163494131156">РђЈОъОћОЎ ОћОЉОбОЎОћ ОЕОЉОћ ОаОфОДОюОф ОЉ-Google Cast?</translation>
<translation id="8376384591331888629">РђЈОЏОЋОюОю ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОЉОљОфОе ОќОћ</translation>
<translation id="8376451933628734023">ОљОЮ ОљОцОюОЎОДОдОЎОЎОф ОћОљОЎОаОўОеОаОў ОћОќОЋ ОъОаОАОћ ОюОћОўОбОЋОф ОљОЋОфОџ ОЋОюОЌОЕОЋОЉ ОЕОъОЊОЋОЉОе ОЉОљОцОюОЎОДОдОЎОћ ОљОЌОеОф, ОдОеОЎОџ ОюОћОАОЎОе ОљОЋОфОћ.</translation>
<translation id="8378714024927312812">ОъОаОЋОћОю ОбОю-ОЎОЊОЎ ОћОљОеОњОЋОЪ</translation>
<translation id="8379156816349755485">ОЏОЕОаОЏОаОАОЎОЮ ОюОЌОЕОЉОЋОЪ, ОЎОљОЋОЌОАОЪ ОљОАОЎОъОЋОЪ ОљОЎОъОЋОф ОЎОЎОЌОЋОЊОЎ ОЋОћОЋОљ ОЎОЕОъОЕ ОюОЏОю ОћОћОЋОеОЊОЋОф ОћОъОфОљОЎОъОЋОф ОћОЉОљОЋОф.</translation>
<translation id="8379878387931047019">ОћОъОЏОЕОЎОе ОюОљ ОфОЋОъОџ ОЉОъОцОфОЌ ОљОЉОўОЌОћ ОъОћОАОЋОњ ОћОъОЉОЋОДОЕ ОЉОљОфОе ОћОќОћ</translation>
<translation id="8379991678458444070">ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЎОћ ОюОАОЎОъОаОЎОЋОф ОфОљОцОЕОе ОюОџ ОюОњОЕОф ОљОюОЎОћ ОЉОъОћОЎОеОЋОф</translation>
<translation id="8380941800586852976">ОъОАОЋОЏОЪ</translation>
<translation id="8382715499079447151">ОћОњОаОћ ОбОю ОфОдОЋОњОћ</translation>
<translation id="8382913212082956454">ОћОбОфОДОф &amp;ОЏОфОЋОЉОф ОљОЎОъОЎОЎОю</translation>
<translation id="8383266303049437646">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОъОЋОъОюОЦ ОюОцОбОЋОю ОюОцОЎ ОћОЕОюОЉОЎОЮ ОћОЉОљОЎОЮ ОюОцОфОеОЋОЪ ОћОЉОбОЎОћ:
    <ph name="BEGIN_LIST" />
    <ph name="LIST_ITEM" />ОъОЋОЋОЊОљОЎОЮ ОЕОЉОъОЏОЕОЎОе ОЎОЕ ОљОЌОАОЋОЪ ОцОаОЎОъОЎ ОцОбОЎОю ОЏОъОЋ HDD,РђЈ SSD ОљОЋ eMMC.
    <ph name="LIST_ITEM" />ОЉОЋОЊОДОЎОЮ ОЕОъОЏОЕОЎОе ОћОљОЌОАОЋОЪ ОћОцОаОЎОъОЎ ОъОЏОЎОю ОЎОЋОфОе Оъ-16GB.
    <ph name="LIST_ITEM" />ОЉОЋОЊОДОЎОЮ ОљОф ОћОЌОЎОЉОЋОе ОюОљОЌОАОЋОЪ ОћОцОаОЎОъОЎ (ОљОЮ ОћОЋОљ ОаОњОЎОЕ ОцОЎОќОЎОф).
    <ph name="LIST_ITEM" />ОъОЋОЋОЊОљОЎОЮ ОЕОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОЊОњОЮ ОЕОДОЎОЉОю ОљОЎОЕОЋОе, ОЋОЉОЋОЊОДОЎОЮ ОљОф ОаОфОЋОаОЎ ОћОћОфОДОаОћ.
    <ph name="END_LIST" />
    <ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОбОќОеОћ ОаОЋОАОцОф ОќОъОЎОаОћ ОЉОЏОфОЋОЉОф: g.co/flex/InstallErrors.<ph name="END_PARAGRAPH2" /></translation>
<translation id="8386091599636877289">ОћОъОЊОЎОаОЎОЋОф ОюОљ ОаОъОдОљОћ.</translation>
<translation id="8387361103813440603">ОюОљ ОъОЋОеОЕОЎОЮ ОюОеОљОЋОф ОљОф ОћОъОЎОДОЋОЮ</translation>
<translation id="8388770971141403598">ОљОЎОЪ ОфОъОЎОЏОћ ОЉОцОеОЋОцОЎОюОЎОЮ ОъОЕОаОЎОЎОЮ</translation>
<translation id="8389492867173948260">ОъОфОЪ ОћОеОЕОљОћ ОюОфОЋОАОБ ОћОќОћ ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОаОЏОаОАОф:</translation>
<translation id="8390449457866780408">ОћОЕОеОф ОљОЎОаОЋ ОќОъОЎОЪ.</translation>
<translation id="8391218455464584335">ОЋОЎОЎОаОЎОю</translation>
<translation id="8393511274964623038">ОћОцОАОДОф ОћОцОюОљОњОЎОЪ</translation>
<translation id="839363317075970734">РђЈОцОеОўОЎОЮ ОбОю ОъОЏОЕОЎОе Bluetooth</translation>
<translation id="8393700583063109961">ОЕОюОЎОЌОф ОћОЋОЊОбОћ</translation>
<translation id="8397825320644530257">ОаОЎОфОЋОД ОћОўОюОцОЋОЪ ОћОъОЌОЋОЉОе</translation>
<translation id="8398877366907290961">ОюОћОъОЕОЎОџ ОЉОЏОю ОќОљОф</translation>
<translation id="8399282673057829204">ОћОдОњОф ОћОАОЎОАОъОћ</translation>
<translation id="8401432541486058167">ОбОюОЎОџ ОюОдОЎОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОъОЕОЋОЎОџ ОюОЏОеОўОЎОА ОћОЌОЏОЮ ОЕОюОџ.</translation>
<translation id="8404893580027489425">ОЌОЎОЎОЕОЪ ОўОЉОЎОбОЋОф ОћОљОдОЉОб ОъОЋОцОЎОб ОЉОдОЊ ОЎОъОЎОЪ ОЕОю ОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОЕОюОџ. ОЎОЕ ОюОњОбОф ОЉОЋ ОЉОбОЊОЎОаОЋОф ОЉОљОЌОф ОћОљОдОЉОбОЋОф.</translation>
<translation id="8405046151008197676">ОеОЎОЏОќОаОЋ ОбОЉОЋОеОџ ОљОф ОћОцОеОўОЎОЮ ОћОЌОЕОЋОЉОЎОЮ ОюОњОЉОЎ ОћОбОЊОЏОЋОЪ ОћОљОЌОеОЋОЪ</translation>
<translation id="8407199357649073301">ОеОъОф ОћОеОЎОЕОЋОЮ ОЉОЎОЋОъОЪ:</translation>
<translation id="8408270600235826886">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЌОюОЎОў ОљОЎОќОћ ОъОЎОЊОб ОЎОЕОЋОфОБ ОбОЮ Google. ОфОъОЎОЊ ОљОцОЕОе ОюОЕОаОЋОф ОќОљОф ОЉ'ОћОњОЊОеОЋОф'. ОћОаОфОЋОаОЎОЮ ОЎОЕОъОЕОЋ ОЉОћОфОљОЮ Ою<ph name="BEGIN_LINK" />ОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф<ph name="END_LINK" /> ОЕОю Google.</translation>
<translation id="8410775397654368139">Google Play</translation>
<translation id="8412136526970428322">ОЎОЕ ОљОЎОЕОЋОе ОюОћОеОЕОљОЋОф <ph name="PERMISSION" /> ОЋОбОЋОЊ <ph name="COUNT" /></translation>
<translation id="8413385045638830869">ОЎОЕ ОюОЕОљОЋОю ОДОЋОЊОЮ (ОъОЋОъОюОЦ)</translation>
<translation id="8413956290606243087">РђЈОеОЋОдОћ ОюОћОцОбОЎОю ОљОф ChromeVox, ОДОЋОеОљ ОћОъОАОџ ОћОъОЋОЉОаОћ ОЕОю ChromeOS?</translation>
<translation id="8414249071344507766">ОћОцОеОЎОўОЎОЮ ОЕОю ОљОЋОАОБ ОћОќОЎОЏОеОЋОЪ ОъОЋОАОфОеОЎОЮ ОюОъОЕОџ ОЎОЋОъОЎОЎОЮ</translation>
<translation id="8414396119627470038">ОЏОаОЎОАОћ ОљОю <ph name="SITE_ETLD_PLUS_ONE" /> ОЉОљОъОдОбОЋОф <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="8414685983518053656">ОћОбОеОЋОф</translation>
<translation id="8416730306157376817">%<ph name="BATTERY_PERCENTAGE" /> (ОаОеОфОЎОД)</translation>
<translation id="8417548266957501132">ОАОЎОАОъОф ОћОЋОеОћ</translation>
<translation id="8418445294933751433">&amp;ОћОдОњОћ ОЏОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="8419098111404128271">ОфОЋОдОљОЋОф ОюОЌОЎОцОЋОЕ "<ph name="SEARCH_TEXT" />"</translation>
<translation id="8420308167132684745">ОбОеОЎОЏОф ОбОеОЏОЎОЮ ОЉОъОЎОюОЋОЪ</translation>
<translation id="8421361468937925547">ОЏОфОЋОЉОЎОЋОф ОъОЎОЎОЊОЎОЋОф (ОЉОљОаОњОюОЎОф ОЉОюОЉОЊ)</translation>
<translation id="8422787418163030046">ОћОъОњОЕ ОЌОАОе</translation>
<translation id="8424250197845498070">ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОћОћОњОаОћ ОћОъОфОДОЊОъОф</translation>
<translation id="8425213833346101688">ОЕОЎОаОЋОЎ</translation>
<translation id="8425492902634685834">ОћОдОъОЊОћ ОюОЕОЋОеОф ОћОъОЕОЎОъОЋОф</translation>
<translation id="8425768983279799676">ОДОЋОЊ ОћОљОЎОъОЋОф ОъОљОцОЕОе ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе.</translation>
<translation id="8426111352542548860">ОЕОъОЎОеОф ОћОДОЉОЋОдОћ</translation>
<translation id="8426713856918551002">ОћОћОцОбОюОћ ОъОфОЉОдОбОф</translation>
<translation id="8427213022735114808">РђЈОћОЏОфОЉОћ ОЕОЋОюОЌОф ОћОДОюОўОћ ОЕОю ОћОДОЋОю ОЕОюОџ ОљОю Google ОЏОЊОЎ ОюОљОцОЕОе ОћОДОюОЊОћ ОДОЋОюОЎОф ОЉОфОЎОЉОф ОўОДОАОў ОЏОюОЕОћОЎ.</translation>
<translation id="8427292751741042100">ОъОЋОўОъОб ОЉОъОљОеОЌ ОЏОюОЕОћОЋ</translation>
<translation id="8428213095426709021">ОћОњОЊОеОЋОф</translation>
<translation id="8428271547607112339">ОћОЋОАОцОф ОЌОЕОЉОЋОЪ ОЉОЎОф ОАОцОеОЎ</translation>
<translation id="8428628598981198790">ОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ ОЉОљОфОе ОћОќОћ</translation>
<translation id="8428634594422941299">ОћОЉОаОфОЎ</translation>
<translation id="84297032718407999">ОЉОбОЋОЊ <ph name="LOGOUT_TIME_LEFT" /> ОфОЉОЋОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ</translation>
<translation id="8431190899827883166">ОћОдОњОф ОћОДОЕОЋОф</translation>
<translation id="8434480141477525001">ОЎОдОЎОљОф ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЕОю ОюОДОЋОЌ ОъОДОЋОъОЎ</translation>
<translation id="8435395510592618362">ОљОЎОъОЋОф ОћОќОћОЋОф ОЕОюОџ ОЉОљОъОдОбОЋОф <ph name="APP_NAME" /></translation>
<translation id="8437209419043462667">ОљОеОћ"ОЉ</translation>
<translation id="8438328416656800239">ОћОЌОюОцОћ ОюОЊОцОЊОцОЪ ОЌОЏОЮ</translation>
<translation id="8438566539970814960">ОЕОЎОцОЋОе ОћОЌОЎОцОЋОЕОЎОЮ ОЋОћОњОюОЎОЕОћ</translation>
<translation id="8439506636278576865">ОћОдОбОЋОф ОюОфОеОњОЋОЮ ОЊОцОЎОЮ ОЕОаОЏОфОЉОЋ ОЉОЕОцОћ ОќОЋ</translation>
<translation id="8440630305826533614">РђЈОљОцОюОЎОДОдОЎОЋОф Linux</translation>
<translation id="8443795068008423036">ОдОеОЎОџ ОюОЋОЋОЊОљ ОЕОћОъОЏОЕОЎОе ОъОбОЋОЊОЏОЪ ОЋОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="8446884382197647889">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="8447409163267621480">РђЈОЎОЕ ОюОЏОюОЋОю ОљОф Ctrl ОљОЋ Alt</translation>
<translation id="844850004779619592">ОюОљ ОаОъОдОљОЋ ОцОДОЋОЊОЋОф</translation>
<translation id="8448729345478502352">ОћОњОЊОюОћ ОљОЋ ОћОДОўОаОћ ОЕОю ОцОеОЎОўОЎОЮ ОЉОъОАОџ</translation>
<translation id="8449008133205184768">ОћОЊОЉОДОћ ОЋОћОфОљОъОћ ОЕОю ОАОњОаОЋОЪ</translation>
<translation id="8449036207308062757">ОаОЎОћОЋОю ОћОљОЌОАОЋОЪ</translation>
<translation id="8456512334795994339">ОЌОЎОцОЋОЕ ОљОцОюОЎОДОдОЎОЋОф ОюОбОЉОЋОЊОћ ОЋОюОцОаОљОЎ</translation>
<translation id="845702320058262034">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе. ОЎОЕ ОюОЋОЋОЊОљ ОЕОћ-Bluetooth ОЕОю ОћОўОюОцОЋОЪ ОъОЋОцОбОю.</translation>
<translation id="8457451314607652708">ОЎОЎОЉОЋОљ ОАОЎОъОаОЎОЋОф</translation>
<translation id="8458341576712814616">ОДОЎОдОЋОе ОЊОеОџ</translation>
<translation id="8458627787104127436">ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф (<ph name="URL_COUNT" />) ОЉОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="8460448946170646641">ОЉОЊОЎОДОћ ОЕОю ОљОъОдОбОЎ ОћОЉОДОеОћ ОћОЌОЕОЋОЉОЎОЮ ОЉОЎОЋОфОе ОбОю ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ</translation>
<translation id="8460490661223303637">РђЈОЏОЊОЎ ОюОЌОАОЋОџ ОЉОќОЎОЏОеОЋОЪ, Chrome ОћОАОЎОе ОЌОюОД ОъОћОфОЋОЏОЪ</translation>
<translation id="8460932807646981183">ОаОЎОћОЋОю ОЕОю ОъОаОЋОбОЎ ОћОЌОЎОцОЋОЕ ОЋОЕОю ОћОЌОЎОцОЋОЕ ОЉОљОфОеОЎОЮ ОАОцОдОЎОцОЎОЎОЮ</translation>
<translation id="84613761564611563">ОаОЋОдОеОћ ОЉОДОЕОћ ОбОЉОЋОе ОъОъОЕОД ОъОЕОфОъОЕ ОюОћОњОЊОеОЋОф ОћОеОЕОф, ОаОљ ОюОћОъОфОЎОЪ...</translation>
<translation id="8461914792118322307">РђЈОЕОеОф proxy</translation>
<translation id="8463001014623882202">ОћОћОеОЕОљОћ ОаОЏОЕОюОћ</translation>
<translation id="846374874681391779">ОАОеОњОю ОћОћОЋОеОЊОЋОф</translation>
<translation id="8463955938112983119"><ph name="PLUGIN_NAME" /> ОъОЋОЕОЉОф.</translation>
<translation id="8464132254133862871">ОЌОЕОЉОЋОЪ ОъОЕОфОъОЕ ОќОћ ОљОЎОаОЋ ОќОЏОљОЎ ОюОДОЉОюОф ОћОЕОЎОеОЋОф.</translation>
<translation id="8464735509712879725">ОюОЌОЊОеОЎОЮ ОбОЮ ОфОљОЋОеОћ ОЌОюОЕОћ. ОЉОаОЋОАОБ, ОъОљОеОЎОЏОЎОЮ ОљОф ОЌОЎОЎ ОћОАОЋОюОюОћ.</translation>
<translation id="8465252176946159372">ОюОљ ОЌОЋОДОЎ</translation>
<translation id="8465444703385715657"><ph name="PLUGIN_NAME" /> ОдОеОЎОџ ОљОЎОЕОЋОе ОъОъОџ ОЏОЊОЎ ОюОцОбОЋОю</translation>
<translation id="8466417995783206254">ОЉОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОъОЋОцОбОю ОАОеОўОЋОЪ ОЉОъОдОЉ 'ОфОъОЋОаОћ ОЉОфОЋОџ ОфОъОЋОаОћ'.</translation>
<translation id="8467326454809944210">ОЉОЌОЎОеОф ОЕОцОћ ОљОЌОеОф</translation>
<translation id="8470513973197838199">ОАОЎОАОъОљОЋОф ОЕОаОЕОъОеОЋ ОЉОЕОЉОЎОю <ph name="ORIGIN" /></translation>
<translation id="8471525937465764768">РђЈОљОфОеОЎОЮ ОъОфОЌОЉОеОЎОЮ ОЉОЊОеОџ ОЏОюОю ОюОћОфОДОаОЎ USB ОЏОЊОЎ ОюОфОъОЋОџ ОЉОфОЏОЋОаОЋОф ОЏОъОЋ ОћОЊОцОАОф ОъОАОъОЏОЎОЮ ОљОЋ ОЕОъОЎОеОћ ОЉОћОфОДОЪ ОљОЌОАОЋОЪ</translation>
<translation id="8471959340398751476">ОћОћОаОЌОЋОф ОЏОЉОЋОЎОЋОф. ОаОЎОфОЪ ОюОћОцОбОЎОю ОљОЋОфОЪ ОЉОфОцОеОЎОў ОћОћОфОљОъОћ ОћОљОЎОЕОЎОф</translation>
<translation id="8472623782143987204">ОњОЎОЉОЋОЎ ОЌОЋОъОеОћ</translation>
<translation id="8473863474539038330">ОЏОфОЋОЉОЋОф ОЋОбОЋОЊ</translation>
<translation id="8475313423285172237">РђЈОфОЋОЏОаОћ ОљОЌОеОф ОЉОъОЌОЕОЉ ОЕОюОџ ОћОЋОАОЎОцОћ ОфОЋОАОБ ОЕОбОЕОЋОЎ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chrome.</translation>
<translation id="8477241577829954800">ОћОЋОЌОюОБ</translation>
<translation id="8477384620836102176">&amp;ОЏОюОюОЎ</translation>
<translation id="8479176401914456949">ОДОЋОЊ ОюОљ ОЌОЋОДОЎ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="8480082892550707549">ОњОЮ ОљОЮ ОћОЋОеОЊОф ОДОЉОдОЎОЮ ОъОћОљОфОе ОћОќОћ ОЉОбОЉОе, ОЎОЎОфОЏОЪ ОЕОћОљОфОе ОбОЊОЎОЎОЪ ОюОљ ОЉОўОЋОЌ (ОаОцОеОЦ) ОЉОљОЋОцОЪ ОќОъОаОЎ. ОљОцОЕОе ОюОаОАОЋОф ОюОћОЋОеОЎОЊ ОљОф ОћОДОЋОЉОЦ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="8480869669560681089">ОъОЏОЕОЎОе ОюОљ ОъОЋОЏОе ОЕОю <ph name="VENDOR_NAME" /></translation>
<translation id="8481187309597259238">РђЈОљОЎОЕОЋОе ОћОеОЕОљОф ОњОЎОЕОћ Ою-USB</translation>
<translation id="8481980314595922412">ОћОфОЏОЋОаОЋОф ОћОаОЎОАОЎОЋОаОЎОЋОф ОъОЋОцОбОюОЋОф</translation>
<translation id="848666842773560761">ОаОЊОеОЕОф ОюОљОцОюОЎОДОдОЎОћ ОњОЎОЕОћ ОюОъОдОюОъОћ. ОЎОЕ ОюОЏОЉОЋОф ОљОф ОъОфОњ ОћОцОеОўОЎОЋОф ОЕОю ОћОъОдОюОъОћ ОЏОЊОЎ ОюОћОфОЎОе ОњОЎОЕОћ.</translation>
<translation id="8487678622945914333">ОћОфОДОеОЉОЋОф ОюОфОдОЋОњОћ</translation>
<translation id="8489156414266187072">ОћОдОбОЋОф ОъОЋОфОљОъОЋОф ОљОЎОЕОЎОф ОъОЋОдОњОЋОф ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉОюОЉОЊ</translation>
<translation id="8490896350101740396">ОљОцОюОЎОДОдОЎОф ОћОДОЎОЋОАОД ОћОЉОљОЋОф "<ph name="UPDATED_APPS" />" ОбОЋОЊОЏОаОЋ. ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЏОЕОЎОе ОЏОЊОЎ ОюОћОЕОюОЎОЮ ОљОф ОфОћОюОЎОџ ОћОбОЊОЏОЋОЪ.</translation>
<translation id="8492685019009920170">ОЎОЕ ОюОњОбОф ОбОЮ ОћОљОдОЉОб ОЉОЌОЎОЎОЕОЪ ОўОЉОЎОбОЋОф ОћОљОдОЉОб. ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОъОљОЋОЌОАОаОЎОЮ ОЉОљОЋОцОЪ ОъОљОЋОЉОўОЌ ОЋОљОБ ОцОбОЮ ОюОљ ОаОЕОюОЌОЎОЮ ОъОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" />.</translation>
<translation id="8492822722330266509">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОдОЎОњ ОЌОюОЋОаОЋОф ОДОЋОцОдОЎОЮ ОЋОюОћОЕОфОъОЕ ОЉОћОцОаОЎОЋОф ОљОЋОўОЋОъОўОЎОЋОф</translation>
<translation id="8492960370534528742">РђЈОъОЕОЋОЉ ОбОю Google Cast</translation>
<translation id="8493236660459102203">ОъОЎОДОеОЋОцОЋОЪ:</translation>
<translation id="8496717697661868878">ОћОеОдОф ОцОюОљОњОЎОЪ ОќОћ</translation>
<translation id="8497219075884839166">РђЈОфОЋОЏОаОЎОЋОф ОЕОЎОеОЋОф ОЕОю Windows</translation>
<translation id="8498214519255567734">ОъОДОю ОбОюОЎОџ ОюОћОЉОЎОў ОЉОъОАОџ ОљОЋ ОюОДОеОЋОљ ОЉОљОЋОе ОъОбОЋОъОбОЮ</translation>
<translation id="8498395510292172881">РђЈОћОъОЕОџ ОДОеОЎОљОћ ОЉ-Chrome</translation>
<translation id="8499083585497694743">ОЉОЎОўОЋОю ОЕОю ОћОЕОфОДОф ОћОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="8502536196501630039">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОЋОф Оъ-Google Play, ОдОеОЎОџ ОюОЕОЌОќОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ. ОЎОЎОфОЏОЪ ОЕОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОљОЉОЊОЋ.</translation>
<translation id="8503813439785031346">ОЕОЮ ОъОЕОфОъОЕ</translation>
<translation id="850382998924680137">ОаОдОцОћ ОћОЎОЋОЮ</translation>
<translation id="8507227974644337342">ОеОќОЋОюОЋОдОЎОЎОф ОъОАОџ</translation>
<translation id="850875081535031620">ОюОљ ОаОъОдОљОЋ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф</translation>
<translation id="8509177919508253835">ОљОЎОцОЋОА ОъОцОфОЌОЋОф ОћОљОЉОўОЌОћ ОЋОЎОдОЎОеОф ОДОЋОЊОЎ ОљОЎОъОЋОф</translation>
<translation id="8509646642152301857">ОћОЋОеОЊОф ОћОъОЎОюОЋОЪ ОюОЉОЊОЎОДОф ОљОЎОЋОф ОаОЏОЕОюОћ.</translation>
<translation id="8509967119010808787">ОюОЌОЎОцОЋОЕ ОЉОЏОеОўОЎОАОЎОЋОф, ОдОеОЎОџ ОюОюОЌОЋОЦ ОЏОљОЪ</translation>
<translation id="8512396579636492893">{COUNT,plural, =0{ОюОљ ОаОъОдОљОЋ ОАОЎОАОъОљОЋОф ОЌОюОЕОЋОф}=1{ОаОъОдОљОћ ОАОЎОАОъОћ ОЌОюОЕОћ ОљОЌОф ({COUNT})}two{ОаОъОдОљОЋ {COUNT} ОАОЎОАОъОљОЋОф ОЌОюОЕОЋОф}many{ОаОъОдОљОЋ {COUNT} ОАОЎОАОъОљОЋОф ОЌОюОЕОЋОф}other{ОаОъОдОљОЋ {COUNT} ОАОЎОАОъОљОЋОф ОЌОюОЕОЋОф}}</translation>
<translation id="8512476990829870887">ОАОЎОЋОЮ ОфОћОюОЎОџ</translation>
<translation id="851263357009351303">ОћОфОеОћ Ою-<ph name="HOST" /> ОюОћОдОЎОњ ОфОъОЋОаОЋОф ОфОъОЎОЊ</translation>
<translation id="8513108775083588393">ОАОЎОЉОЋОЉ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="8514746246728959655">ОЎОЕ ОюОаОАОЋОф ОъОцОфОЌ ОљОЉОўОЌОћ ОЕОЋОаОћ</translation>
<translation id="8523493869875972733">ОЕОъОЎОеОф ОћОЕОЎОаОЋОЎОЎОЮ</translation>
<translation id="8523849605371521713">ОаОЋОАОБ ОбОю-ОЎОЊОЎ ОъОЊОЎОаОЎОЋОф</translation>
<translation id="8524783101666974011">РђЈОЕОъОЎОеОф ОЏОеОўОЎОАОЎОЮ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="8525306231823319788">ОъОАОџ ОъОюОљ</translation>
<translation id="8526813720153458066">SSH</translation>
<translation id="8528074251912154910">ОћОЋОАОцОф ОЕОцОЋОф</translation>
<translation id="8528962588711550376">ОфОћОюОЎОџ ОћОЏОаОЎОАОћ ОъОфОЉОдОб.</translation>
<translation id="8529925957403338845">ОЎОдОЎОеОф ОћОЌОЎОЉОЋОе ОюОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎ ОЉОЎОЪ ОаОЎОЎОЊОЎОЮ ОаОЏОЕОюОћ</translation>
<translation id="8531701051932785007">ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОъОЋОЕОЉОфОф</translation>
<translation id="8534656636775144800">ОљОЋОцОА! ОъОЕОћОЋ ОћОЕОфОЉОЕ ОЏОЕОаОЎОАОЎОаОЋ ОюОдОеОБ ОљОф ОћОЊОЋОъОЎОЎОЪ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="8535005006684281994">РђЈОЏОфОЋОЉОф ОљОфОе ОюОЌОЎОЊОЋОЕ ОљОЎОЕОЋОе Netscape</translation>
<translation id="8536713137312218707">ОцОДОЋОЊОЋОф ОъОћОЎОеОЋОф</translation>
<translation id="8536956381488731905">ОдОюОЎОюОЎОЮ ОЉОћОДОЕОћ</translation>
<translation id="8539727552378197395">РђЈОюОљ (Http ОЉОюОЉОЊ)</translation>
<translation id="8539766201049804895">ОЕОЊОеОЋОњ</translation>
<translation id="8540136935098276800">РђЈОЎОЕ ОюОћОќОЎОЪ ОЏОфОЋОЉОф URL ОЉОцОЋОеОъОў ОЌОЋОДОЎ</translation>
<translation id="8540503336857689453">ОъОўОбОъОЎ ОљОЉОўОЌОћ, ОюОљ ОъОЋОъОюОЦ ОюОћОЕОфОъОЕ ОЉОеОЕОф ОъОЋОАОфОеОф.</translation>
<translation id="854071720451629801">ОАОЎОъОЋОЪ ОЏОцОеОЎОў ОЕОаОДОеОљ</translation>
<translation id="8540942859441851323">ОаОЊОЎОЊОћ ОЉОћОфОљОЮ ОюОЊОеОЎОЕОф ОћОАОцОД</translation>
<translation id="8541462173655894684">ОюОљ ОаОъОдОљОЋ ОъОЊОцОАОЋОф ОћОъОЕОЋОЎОЏОЋОф ОюОЕОеОф ОћОћОЊОцОАОћ</translation>
<translation id="8541838361296720865">ОдОеОЎОџ ОюОћОДОЎОЕ ОбОю ОъОфОњ ОљОЋ ОъОДОЕ ОЉОъОДОюОЊОф ОЏОЊОЎ ОюОћОДОдОЋОф ОљОЋОфОЮ ОюОцОбОЋОюОћ "<ph name="ACTION" />"</translation>
<translation id="8543556556237226809">ОЎОЕ ОюОџ ОЕОљОюОЋОф? ОбОюОЎОџ ОюОцОаОЋОф ОюОљОЎОЕ ОћОДОЕОе ОЕОъОцОДОЌ ОбОю ОћОцОеОЋОцОЎОю ОЕОюОџ.</translation>
<translation id="8546186510985480118">ОЌОАОе ОЕОўОЌ ОљОЌОАОЋОЪ ОЉОъОЏОЕОЎОе</translation>
<translation id="8546306075665861288">ОъОўОъОЋОЪ ОфОъОЋОаОЋОф</translation>
<translation id="8546930481464505581">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОАОеОњОю ОћОъОњОб</translation>
<translation id="8547013269961688403">ОћОцОбОюОћ ОЕОю ОћОњОЊОюОф ОЏОю ОћОъОАОџ</translation>
<translation id="85486688517848470">ОЎОЕ ОюОћОЌОќОЎОД ОљОф ОъОДОЕ ОћОЌОЎОцОЋОЕ ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОћОфОаОћОњОЋОф ОЕОю ОъОДОЕОЎ ОћОЕОЋОеОћ ОћОбОюОЎОЋОаОћ</translation>
<translation id="8549316893834449916">РђЈОћОЏОаОЎОАОћ ОљОю Chromebook ОфОфОЉОдОб ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google ОЕОюОџ РђЊ ОљОЋОфОЋ ОЌОЕОЉОЋОЪ ОЕОъОЕОъОЕ ОљОЋОфОџ ОЉ-Gmail, ОЉ-Drive, ОЉ-YouTube ОЋОбОЋОЊ.</translation>
<translation id="8551388862522347954">ОеОЎОЕОЎОЋОаОЋОф</translation>
<translation id="8551588720239073785">ОћОњОЊОеОЋОф ОфОљОеОЎОџ ОЋОЕОбОћ</translation>
<translation id="8553342806078037065">ОаОЎОћОЋОю ОљОаОЕОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="8554899698005018844">ОюОљ ОћОЋОњОЊОеОћ ОЕОцОћ</translation>
<translation id="855604308879080518">РђЈОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЎОЋОЏОюОЋ ОюОДОЉОю ОњОЎОЕОћ ОюОћОфОДОаОЎ USB ОЉ-Chromebook ОћОќОћ. ОЉОЏОю ОцОбОЮ ОЕОЎОЌОЋОЉОе ОћОфОДОЪ USB, ОфОЎОЕОюОЌ ОЉОДОЕОћ ОюОћОеОЕОљОћ. ОљОцОюОЎОДОдОЎОЋОф ОаОцОеОЊОЋОф Ою-Android ОЎОЕОюОЌОЋ ОЉОДОЕОЋОф ОюОћОеОЕОљОЋОф ОаОЋОАОцОЋОф.</translation>
<translation id="8557022314818157177">ОдОеОЎОџ ОюОћОъОЕОЎОџ ОюОњОбОф ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОбОЊ ОюОфОЎОбОЋОЊ ОўОЉОЎОбОф ОћОљОдОЉОб</translation>
<translation id="8557180006508471423">РђЈОћОцОбОюОф "Google Chrome" ОЉОЕОЎОеОЋОфОЎ ОћОъОЎОДОЋОЮ ОЕОю ОъОЏОЕОЎОе Оћ-Mac</translation>
<translation id="8557856025359704738">ОћОћОЋОеОЊОћ ОћОЉОљОћ ОфОћОЎОћ ОЉОЕОбОћ <ph name="NEXT_DATE_DOWNLOAD" />.</translation>
<translation id="8560327176991673955">{COUNT,plural, =0{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}=1{ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}two{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}many{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}other{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉОЌОюОЋОЪ &amp;ОЌОЊОЕ}}</translation>
<translation id="8561206103590473338">ОцОЎОю</translation>
<translation id="8561565784790166472">ОЎОЕ ОюОћОъОЕОЎОџ ОЉОќОћОЎОеОЋОф</translation>
<translation id="8561853412914299728"><ph name="TAB_TITLE" /> <ph name="EMOJI_PLAYING" /></translation>
<translation id="8565650234829130278">ОЉОЋОдОб ОаОЎОАОЎОЋОЪ ОюОЕОЊОеОњ ОЎОЎОЕОЋОЮ ОюОљОЌОЋОе.</translation>
<translation id="8569682776816196752">ОюОљ ОаОъОдОљОЋ ОЎОбОЊОЎОЮ</translation>
<translation id="8571213806525832805">ОъОљОеОЉОбОф ОћОЕОЉОЋОбОЋОф ОћОљОЌОеОЋОаОЎОЮ</translation>
<translation id="8571687764447439720">РђЈОћОЋОАОцОћ ОЕОю ОЏОеОўОЎОА Kerberos</translation>
<translation id="8574990355410201600">ОЎОЕ ОюОћОфОЎОе ОфОъОЎОЊ ОћОЕОъОбОф ОдОюОЎОюОЎОЮ ОЉ-<ph name="HOST" /></translation>
<translation id="8575286410928791436">ОЏОЊОЎ ОюОдОљОф, ОдОеОЎОџ ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю <ph name="KEY_EQUIVALENT" />.</translation>
<translation id="8576885347118332789">{NUM_TABS,plural, =1{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЎОћ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}two{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЋОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}many{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЋОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}other{ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЋОф ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ}}</translation>
<translation id="8578639784464423491">ОћОъОњОЉОюОћ ОћОЎОљ 99 ОљОЋОфОЎОЋОф</translation>
<translation id="857943718398505171">ОъОЋОфОеОф (ОъОЋОъОюОЦ)</translation>
<translation id="8581809080475256101">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОфОДОЊОЮ, ОфОцОеОЎОў ОћОДОЕОе ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="8584280235376696778">ОцОфОЎОЌОф ОЋОЎОЊОљОЋ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="8584427708066927472">ОћОАОЎОАОъОћ ОаОъОЌОДОћ ОъОћОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="8584843865238667486">РђЈОъОЏОЕОЎОеОЎ HID ОбОЮ ОЕОЎОъОЋОЕ ОЕОю <ph name="USAGE" /> ОъОЊОБ ОћОЕОЎОъОЋОЕ <ph name="USAGE_PAGE" /></translation>
<translation id="8585480574870650651">РђЈОћОАОеОћ ОЕОю Crostini</translation>
<translation id="8585841788766257444">ОћОљОфОеОЎОЮ ОЉОеОЕОЎОъОћ ОЕОЉОћОъОЕОџ ОцОЋОбОюОЎОЮ ОюОцОЎ ОћОњОЊОеОћ ОъОЋОфОљОъОф ОљОЎОЕОЎОф ОЉОъОДОЋОЮ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="8588866096426746242">ОћОдОњОф ОаОфОЋОаОЎОЮ ОАОўОўОЎОАОўОЎОЎОЮ ОЕОю ОцОеОЋОцОЎОю</translation>
<translation id="8588868914509452556">РђЈ<ph name="WINDOW_TITLE" /> - VR ОъОЋОдОњ ОЉОъОЕОДОцОЎ VR</translation>
<translation id="8590375307970699841">ОћОњОЊОеОф ОбОЊОЏОЋОаОЎОЮ ОљОЋОўОЋОъОўОЎОЎОЮ</translation>
<translation id="8591783563402255548">ОЕОаОЎОЎОћ</translation>
<translation id="8592141010104017453">ОюОљ ОюОћОдОЎОњ ОћОЋОЊОбОЋОф</translation>
<translation id="859246725979739260">ОаОЌОАОъОћ ОћОњОЎОЕОћ ОЕОю ОћОљОфОе ОћОќОћ ОюОъОЎОДОЋОЮ ОЕОюОџ.</translation>
<translation id="8593121833493516339">РђЈОЕОюОЎОЌОћ ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОбОю ОћОЕОЎОъОЋОЕ. ОљОцОЕОе ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОћОЌОЋОЋОЎОћ ОЕОю ОћОЎОюОЊ/Оћ ОЕОюОџ ОЉ-Android. ОюОЕОЮ ОЏОџ ОЎОЕ ОюОЕОюОЋОЌ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОЋОЉОљОцОюОЎОДОдОЎОЋОф. ОаОфОЋОаОЎОЮ ОљОюОћ ОюОљ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОќОћОЋОф ОљОф ОћОЎОюОЊ/Оћ ОЕОюОџ, ОЋОћОЮ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОЎОдОЎОЉОЋОф ОћОъОбОеОЏОф ОЋОћОљОцОюОЎОДОдОЎОЋОф, ОЏОъОЋ ОњОЮ ОюОЉОЎОдОЋОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎ Android. ОљОЮ ОћОЋОцОбОюОћ ОЉОЕОЉОЎОю ОћОЎОюОЊ/Оћ ОЕОюОџ ОћОљОцОЕОеОЋОф 'ОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОЋ/Оћ. <ph name="BEGIN_LINK1" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK1" /></translation>
<translation id="8594908476761052472">ОдОЎОюОЋОЮ ОАОеОўОЋОЪ</translation>
<translation id="8596540852772265699">ОДОЉОдОЎОЮ ОъОЋОфОљОъОЎОЮ ОљОЎОЕОЎОф</translation>
<translation id="8597845839771543242">ОцОЋОеОъОў ОъОљОцОЎОЎОЪ:</translation>
<translation id="8599681327221583254">ОюОцОЌОЋОф ОъОЊОЎОаОЎОЋОф ОљОЌОф ОюОљ ОъОЋОњОЊОеОф ОЏОеОљОЋОЎ. ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="8601206103050338563">РђЈОљОЎОъОЋОф ОюОДОЋОЌ TLS WWW</translation>
<translation id="8601611099293226919">РђЈОЌОЎОцОЋОЕ ОЉОъОАОџ ОЉОљОъОдОбОЋОф Google Lens</translation>
<translation id="8602851771975208551">РђЈОфОЋОЏОаОЎОф ОљОЌОеОф ОЉОъОЌОЕОЉ ОЕОюОџ ОћОЋОАОЎОцОћ ОљОцОюОЎОДОдОЎОћ ОЕОбОЕОЋОЎОћ ОюОЕОаОЋОф ОљОф ОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю Chrome.</translation>
<translation id="8605428685123651449">РђЈОќОЎОЏОеОЋОЪ SQLite</translation>
<translation id="8608618451198398104">РђЈОћОЋОАОцОф ОЏОеОўОЎОА Kerberos</translation>
<translation id="8609465669617005112">ОћОќОќОћ ОюОъОбОюОћ</translation>
<translation id="8610103157987623234">ОцОЋОеОъОў ОюОљ ОаОЏОЋОЪ, ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="8611682088849615761">РђЈОюОљОЕОе РђЊ ОћОљОфОе ОЎОъОЕОЎОџ ОюОДОЉОю ОЕОюОЎОўОћ ОъОюОљОћ ОЉОъОЏОЕОЎОеОЎ MIDI</translation>
<translation id="8613164732773110792">ОљОЋОфОЎОЋОф ОДОўОаОЋОф, ОАОцОеОЋОф, ОфОЋОЋОЎ ОДОЋ ОфОЌОфОЋОЪ ОљОЋ ОфОЋОЋОЎ ОДОЋ ОъОцОеОЎОЊ ОЉОюОЉОЊ</translation>
<translation id="8613645710357126807">ОљОфОеОЎОЮ ОЕОљОЎОЪ ОюОћОЮ ОћОеОЕОљОћ ОюОЕОЎОъОЋОЕ ОЉОфОЋОАОцОЎОЮ</translation>
<translation id="8613786722548417558">РђЈ<ph name="FILE_NAME" /> ОњОЊОЋОю ОъОЊОЎ ОюОЉОЎОдОЋОб ОЉОЊОЎОДОф ОљОЉОўОЌОћ. ОљОцОЕОе ОюОцОфОЋОЌ ОДОЉОдОЎОЮ ОЉОњОЋОЊОю ОЕОю ОбОЊ 50 MB.</translation>
<translation id="8615618338313291042">ОЎОЎОЕОЋОЮ ОњОюОЎОЕОћ ОљОаОЋОаОЎОъОЎОф: <ph name="APP_NAME" /></translation>
<translation id="8616441548384109662">ОћОЋОАОцОф <ph name="CONTACT_NAME" /> ОюОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ</translation>
<translation id="8617748779076050570">ОъОќОћОћ ОЌОЎОЉОЋОе ОЉОўОЋОЌ: <ph name="CONNECTION_ID" /></translation>
<translation id="8619803522055190423">ОћОўОюОф ОдОюОюОЎОф</translation>
<translation id="8619892228487928601"><ph name="CERTIFICATE_NAME" />: <ph name="ERROR" /></translation>
<translation id="8620436878122366504">ОћОћОЋОеОЎОЮ ОЕОюОџ ОбОЊОЎОЎОЪ ОюОљ ОљОЎОЕОеОЋ ОќОљОф</translation>
<translation id="8621866727807194849">РђЈОЎОЕ ОЉОъОЌОЕОЉ ОЕОюОџ ОфОЋОЏОаОћ ОъОќОЎОДОћ. Chrome ОъОАОЎОе ОљОЋОфОћ, ОъОЕОЌОќОе ОљОф ОћОћОњОЊОеОЋОф ОЋОъОЕОЉОЎОф ОфОЋОАОцОЎОЮ. ОюОљОЌОе ОъОЏОЪ ОћОЊОцОЊОцОЪ ОЎОЌОќОЋОе ОюОцОбОЋОюОћ ОеОњОЎОюОћ.</translation>
<translation id="8621979332865976405">ОЕОЎОфОЋОБ ОћОъОАОџ ОЏОЋОюОЋ</translation>
<translation id="8624315169751085215">ОћОбОфОДОћ ОюОюОЋОЌ</translation>
<translation id="8624354461147303341">ОюОДОЉОюОф ОћОаОЌОЋОф</translation>
<translation id="8624944202475729958"><ph name="PROFILE_NAME" />: <ph name="ERROR_DESCRIPTION" /></translation>
<translation id="862542460444371744">&amp;ОфОЋОАОцОЎОЮ</translation>
<translation id="8625663000550647058">ОюОљ ОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="8625916342247441948">РђЈОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОеОЎ HID</translation>
<translation id="8627139822566724903">ОЎОЕ ОюОћОќОЎОЪ ОъОЎОюОЋОф ОъОцОфОЌ ОЏОъОЋ 'ОЏОеОўОЎОАОЎОЋОф' ОљОЋ 'ОЌОюОЋОаОЋОф' ОЏОЊОЎ ОюОЌОцОЕ ОцОбОЋОюОћ</translation>
<translation id="862727964348362408">ОъОЋОЕОбОћ</translation>
<translation id="862750493060684461">РђЈОъОўОъОЋОЪ ОЕОю CSS</translation>
<translation id="8627795981664801467">ОћОфОЌОЉОеОЋОЎОЋОф ОЉОўОЋОЌОЋОф ОЉОюОЉОЊ</translation>
<translation id="8627804903623428808">ОЉОЊОЎОДОф ОћОфОаОљОЎОЮ ОћОљОюОћ ОЋОЕОюОЎОўОћ ОЉОаОфОЋОаОЎОЮ ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ</translation>
<translation id="8630338733867813168">ОъОбОЉОе ОюОъОдОЉ ОЕОЎОаОћ ОЉОќОъОЪ ОўОбОЎОаОћ</translation>
<translation id="8631032106121706562">ОбОюОЎ ОЏОЋОфОеОф</translation>
<translation id="863109444997383731">ОљОфОеОЎОЮ ОюОљ ОЎОЋОЏОюОЋ ОюОЉОДОЕ ОћОдОњОћ ОЕОю ОћОфОеОљОЋОф. ОљОЮ ОљОфОе ОЎОЉОДОЕ ОюОћОдОЎОњ ОћОфОеОљОЋОф, ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОЎОЋОцОЎОб ОЌОЎОЋОЋОЎ ОюОњОЉОЎ ОЌОАОЎОъОћ ОЕОЉОЋОдОбОћ.</translation>
<translation id="8632104508818855045">ОЉОЌОеОф ОЉОбОЉОе ОюОљ ОюОфОф ОћОеОЕОљОћ ОюОЕОЋОЮ ОфОЋОАОБ ОЉРђЉ<ph name="ORIGIN" /></translation>
<translation id="8633025649649592204">ОцОбОЎОюОЋОф ОљОЌОеОЋОаОћ</translation>
<translation id="8634348081024879304">РђЈОюОљ ОфОћОЎОћ ОюОџ ОЎОЋОфОе ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОЏОеОўОЎОА ОћОЋОЋОЎОеОўОЋОљОюОЎ ОЉОљОъОдОбОЋОф Google Pay. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОбОю ОЏОеОўОЎОАОЎОЮ ОЋОЎОеОўОЋОљОюОЎОЎОЮ<ph name="END_LINK" /></translation>
<translation id="8635628933471165173">ОЉОўОбОЎОаОћ ОъОЌОЊОЕ...</translation>
<translation id="8636284842992792762">ОћОцОбОюОф ОћОфОЋОАОцОЎОЮ ОЉОфОћОюОЎОџРђд</translation>
<translation id="8636500887554457830">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОЕОюОЋОЌ ОЌОюОЋОаОЋОф ОДОЋОцОдОЎОЮ ОљОЋ ОюОћОЕОфОъОЕ ОЉОћОцОаОЎОЋОф ОљОЋОўОЋОъОўОЎОЋОф</translation>
<translation id="8637688295594795546">ОбОЊОЏОЋОЪ ОъОбОеОЏОф ОќОъОЎОЪ. ОћОъОбОеОЏОф ОъОфОЏОЋОаОаОф ОюОћОЋОеОЊОћРђд</translation>
<translation id="8639047128869322042">ОъОфОЉОдОб ОЌОЎОцОЋОЕ ОЕОю ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф...</translation>
<translation id="8639635302972078117">РђЈОЕОюОЎОЌОф ОъОЎОЊОб ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ. ОћОъОЏОЕОЎОе ОћОќОћ ОЕОЋОюОЌ ОбОЏОЕОЎОЋ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ, ОаОфОЋОаОЎ ОъОЏОЕОЎОе ОЋОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОЋОф. ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОюОљ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОќОћОЋОф ОљОф ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ, ОЋОћОЮ ОЎОбОќОеОЋ ОюОаОЋ ОюОЕОъОЋОе ОбОю ОћОЎОдОЎОЉОЋОф ОЕОю ОћОъОбОеОЏОф ОЋОЕОю ОћОљОцОюОЎОДОдОЎОЋОф ОЋОюОЉОдОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android. ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОаОЋОАОцОЎОЮ' ОћОЋОцОбОюОћ ОбОЉОЋОе ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ, ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОћОЮ.</translation>
<translation id="8642900771896232685">ОЕОфОЎ ОЕОаОЎОЋОф</translation>
<translation id="8642947597466641025">ОћОњОЊОюОф ОўОДОАОў</translation>
<translation id="8643443571868262066">РђЈОћОДОЋОЉОЦ <ph name="FILE_NAME" /> ОбОЕОЋОЎ ОюОћОЎОЋОф ОъОАОЋОЏОЪ. ОћОљОЮ ОюОЕОюОЋОЌ ОљОЋОфОЋ ОюОАОеОЎОДОћ ОЉОљОъОдОбОЋОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф ОЕОю Google?</translation>
<translation id="8644047503904673749">{COUNT,plural, =0{РђЈОљОЎОЪ ОДОЋОЉОдОЎ cookie}=1{РђЈОДОЋОЉОЦ cookie ОљОЌОЊ ОЌОАОЋОЮ}two{РђЈ# ОДОЋОЉОдОЎ cookie ОЌОАОЋОъОЎОЮ}many{РђЈ# ОДОЋОЉОдОЎ cookie ОЌОАОЋОъОЎОЮ}other{РђЈ# ОДОЋОЉОдОЎ cookie ОЌОАОЋОъОЎОЮ}}</translation>
<translation id="8644655801811752511">ОюОљ ОаОЎОфОЪ ОюОљОцОА ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ ОћОќОћ. ОдОеОЎОџ ОюОаОАОЋОф ОюОљОцОА ОљОЋОфОЋ ОъОЎОЊ ОљОЌОеОЎ ОћОЌОЎОЉОЋОе.</translation>
<translation id="8645354835496065562">ОћОъОЕОџ ОћОфОеОф ОћОњОЎОЕОћ ОюОЌОЎОЎОЕОаОЎОЮ</translation>
<translation id="8645920082661222035">ОћОъОбОеОЏОф ОЌОЋОќОћ ОљОЎОеОЋОбОЎОЮ ОъОАОЋОЏОаОЎОЮ ОЋОъОќОћОЎОеОћ ОљОЋОфОџ ОюОњОЉОЎОћОЮ ОюОцОаОЎ ОЕОћОЮ ОъОфОеОЌОЕОЎОЮ</translation>
<translation id="8646209145740351125">ОћОЕОЉОфОф ОАОаОЏОеОЋОЪ</translation>
<translation id="864637694230589560">ОЉОЊОеОџ ОЏОюОю, ОљОфОеОЎОЮ ОЕОЋОюОЌОЎОЮ ОћОфОеОљОЋОф ОЏОЊОЎ ОюОљОцОЕОе ОюОџ ОюОћОфОбОЊОЏОЪ ОЉОъОЉОќОДОЎ ОћОЌОЊОЕОЋОф ОљОЋ ОюОДОЉОю ОћОЋОЊОбОЋОф ОЉОд'ОљОў</translation>
<translation id="8647385344110255847">РђЈОЉОљОЎОЕОЋОеОџ, ОюОЎОюОЊ ОљОЋ ОюОЎОюОЊОћ ОфОћОЎОћ ОљОцОЕОеОЋОф ОюОћОфОДОЎОЪ ОљОцОюОЎОДОдОЎОЋОф Оъ-Google Play</translation>
<translation id="8647834505253004544">ОЏОфОЋОЉОф ОћОљОЎОаОўОеОаОў ОюОљ ОЌОЋОДОЎОф</translation>
<translation id="8648252583955599667"><ph name="GET_HELP_LINK" /> ОљОЋ <ph name="RE_SCAN_LINK" /></translation>
<translation id="8648408795949963811">ОўОъОцОеОўОЋОеОф ОћОдОЉОб ОЕОю ОфОљОЋОеОф ОюОЎОюОћ</translation>
<translation id="8648544143274677280">ОћОљОфОе <ph name="SITE_NAME" /> ОъОЉОДОЕ ОљОф ОћОћОеОЕОљОЋОф: <ph name="FIRST_PERMISSION" />, <ph name="SECOND_PERMISSION" /> ОЋОћОеОЕОљОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="864892689521194669">РђЈОбОќОеОћ ОЉОЕОЎОцОЋОе ОћОфОЏОЋОаОЋОф ОЋОћОЉОЎОдОЋОбОЎОЮ ОЕОю ChromeOS Flex</translation>
<translation id="8650543407998814195">ОюОъОеОЋОф ОЕОЏОЉОе ОљОЎОЪ ОюОџ ОњОЎОЕОћ ОюОцОеОЋОцОЎОю ОћОЎОЕОЪ, ОљОцОЕОе ОбОЊОЎОЎОЪ ОюОћОАОЎОе ОљОЋОфОЋ.</translation>
<translation id="8651585100578802546">ОљОЎОюОЋОЦ ОўОбОЎОаОћ ОъОЌОЊОЕ ОЕОю ОЊОБ ОќОћ</translation>
<translation id="8652400352452647993">ОЕОњОЎОљОф 'ОљОеОЋОќ ОфОЋОАОБ'</translation>
<translation id="8654151524613148204">ОћОДОЋОЉОЦ ОњОЊОЋОю ОъОЏОЊОЎ ОЕОћОъОЌОЕОЉ ОЕОюОџ ОЎОЋОЏОю ОюОўОцОю ОЉОЋ. ОъОдОўОбОеОЎОЮ.</translation>
<translation id="8655295600908251630">ОбОеОЋОЦ</translation>
<translation id="8655972064210167941">ОћОЏОаОЎОАОћ ОаОЏОЕОюОћ ОъОцОаОЎ ОЕОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОљОъОф ОљОф ОћОАОЎОАОъОћ. ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф ОљОЋ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="8657393004602556571">ОеОЋОдОћ ОюОъОЌОЋОД ОљОф ОћОъОЕОЋОЉ?</translation>
<translation id="8661290697478713397">ОцОфОЎОЌОф ОћОДОЎОЕОЋОе ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ</translation>
<translation id="8662671328352114214">ОћОфОЌОЉОеОЋОф ОюОеОЕОф <ph name="TYPE" /></translation>
<translation id="8662733268723715832">ОаОеОљОћ ОЕОћОцОбОЋОюОћ ОаОъОЕОЏОф ОЎОЋОфОе ОќОъОЪ ОъОћОдОцОЋОЎ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЊОюОњ ОљОЋ ОюОћОъОфОЎОЪ ОбОЊ ОАОЎОЋОЮ ОћОцОбОЋОюОћ.</translation>
<translation id="8662795692588422978">ОљОаОЕОЎОЮ</translation>
<translation id="8662811608048051533">ОфОЉОЋОдОб ОЎОдОЎОљОћ ОЕОюОџ ОъОеОЋОЉ ОћОљОфОеОЎОЮ.</translation>
<translation id="8662911384982557515">ОЕОЎОаОЋОЎ ОЕОю ОЊОБ ОћОЉОЎОф Ою: <ph name="HOME_PAGE" /></translation>
<translation id="8662978096466608964">РђЈChrome ОљОЎОаОЋ ОЎОЏОЋОю ОюОћОњОЊОЎОе ОўОцОў.</translation>
<translation id="8663099077749055505">ОЎОЕ ОюОЌОАОЋОЮ ОфОъОЎОЊ ОћОЋОеОЊОЋОф ОъОеОЋОЉОЋОф ОљОЋОўОЋОъОўОЎОЋОф ОЉ-<ph name="HOST" /></translation>
<translation id="8664389313780386848">&amp;ОћОдОњОф ОъОДОЋОе ОћОЊОБ</translation>
<translation id="8665110742939124773">ОћОќОаОф ОДОЋОЊ ОњОЎОЕОћ ОЕОњОЋОЎ. ОбОюОЎОџ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="8665180165765946056">ОћОњОЎОЉОЋОЎ ОћОЋОЕОюОЮ</translation>
<translation id="866611985033792019">ОЎОЕ ОюОфОф ОљОъОЋОЪ ОЉОљОЎОЕОЋОе ОќОћ ОюОќОЎОћОЋОЎ ОъОЕОфОъОЕОЎ ОљОЎОъОЎОЎОю</translation>
<translation id="8666759526542103597">ОъОЎОЊОб ОбОю ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОъОЋОЊОбОЋОф ОбОю ОАОъОџ ОћОЊОцОЊОцОЪ</translation>
<translation id="8667328578593601900"><ph name="FULLSCREEN_ORIGIN" /> ОЏОбОф ОЉОъОАОџ ОъОюОљ ОЋОАОъОЪ ОћОбОЏОЉОе ОЕОюОџ ОћОЋОЕОЉОф.</translation>
<translation id="8667760277771450375">ОљОаОЌОаОЋ ОЉОЋОЌОаОЎОЮ ОЊОеОЏОЎОЮ ОЌОЊОЕОЋОф ОюОћОњОЉОЎОю ОъОбОДОЉ ОЉОЎОЪ-ОљОфОеОЎОЮ ОЋОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОбОдОЋОе ОаОЎОАОЎОЋОаОЋОф ОћОЋОаОљОћ ОЋОАОцОљОЮ ОЕОю ОъОЋОЊОбОЋОф.</translation>
<translation id="8669284339312441707">ОЌОъОЎОЮ ОЎОЋОфОе</translation>
<translation id="8670537393737592796">ОЏОЊОЎ ОюОЌОќОЋОе ОюОЏОљОЪ ОЉОъОћОЎОеОЋОф, ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОюОЌОдОЪ ОћОћОфОДОаОћ ОЋОюОћОфОДОЎОЪ ОљОф <ph name="APP_NAME" /></translation>
<translation id="867085395664725367">ОћОфОеОЌОЕОћ ОЕОњОЎОљОф ОЕОеОф ОќОъОаОЎОф.</translation>
<translation id="8673026256276578048">ОЌОЎОцОЋОЕ ОЉОљОЎОаОўОеОаОў...</translation>
<translation id="8673383193459449849">ОЎОЕ ОЉОбОЎОћ ОЉОЕОеОф</translation>
<translation id="8674903726754070732">РђЈОюОдОбОеОаОЋ, ОћОъОЌОЕОЉ ОЕОюОџ ОъОЋОњОЊОе ОЉОљОъОдОбОЋОф ОъОќОћОћ ОЌОЋОъОеОћ ОцОњОЋОЮ. ОћОъОдОЉ ОћОќОћ ОъОЋОаОб Оъ-ChromeOS ОюОћОфОДОЎОЪ ОљОф ОбОЊОЏОЋОаОЎ ОћОљОЉОўОЌОћ ОћОљОЌОеОЋОаОЎОЮ, <ph name="BEGIN_BOLD" />ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОъОЌОЕОЉ ОЕОюОџ ОЎОћОЎОћ ОЌОЕОЋОБ ОюОћОфОДОцОЋОф ОќОЊОЋОаОЎОЋОф<ph name="END_BOLD" />.</translation>
<translation id="8675704450909805533">ОъОаОћОю ОћОћОфОДОаОћ ОюОљ ОъОдОљ ОЎОбОЊ ОфОДОЎОЪ ОюОћОфОДОаОћ ОЕОю <ph name="DEVICE_OS" />.</translation>
<translation id="8676152597179121671">{COUNT,plural, =1{ОАОеОўОЋОЪ}two{# ОАОеОўОЋОаОЎОЮ}many{# ОАОеОўОЋОаОЎОЮ}other{# ОАОеОўОЋОаОЎОЮ}}</translation>
<translation id="8676313779986170923">ОфОЋОЊОћ ОЕОЕОюОЌОф ОъОЕОЋОЉ.</translation>
<translation id="8676374126336081632">ОаОЎОДОЋОЎ ОДОюОў</translation>
<translation id="8676770494376880701">ОЌОЋОЉОе ОъОўОбОЪ ОЉОбОю ОъОфОЌ ОаОъОЋОџ</translation>
<translation id="8677212948402625567">ОЏОЎОЋОЋОЦ ОћОЏОЋОю...</translation>
<translation id="867767487203716855">ОћОбОЊОЏОЋОЪ ОћОЉОљ</translation>
<translation id="8677859815076891398">РђЈОљОЎОЪ ОљОюОЉОЋОъОЎОЮ. ОаОЎОфОЪ ОюОЎОдОЋОе ОљОюОЉОЋОЮ ОЉ<ph name="LINK_BEGIN" />ОфОъОЋОаОЋОф Google<ph name="LINK_END" />.</translation>
<translation id="8678538439778360739">РђЈОћОаОфОЋОаОЎОЮ ОћОЋОдОцОаОЋ ОЉОљОъОдОбОЋОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЕОюОџ ОюОАОаОЏОеОЋОЪ ОЉОЕОбОћ <ph name="TIME" />. ОћОаОфОЋОаОЎОЮ ОћОъОЋОдОцОаОЎОЮ ОюОљ ОЏОЋОюОюОЎОЮ ОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЋОЏОфОЋОЉОЋОф Оъ-Google Pay.</translation>
<translation id="8678582529642151449">ОћОЏОеОўОЎОАОЎОЋОф ОюОљ ОЎОфОЏОЋОЋОдОЋ</translation>
<translation id="8678933587484842200">ОљОЎОџ ОюОћОцОбОЎОю ОљОф ОћОљОцОюОЎОДОдОЎОћ ОћОќОЋ?</translation>
<translation id="8680251145628383637">РђЈОЎОЕ ОюОћОЎОЏОаОА ОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОљОю ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ, ОћОАОЎОАОъОљОЋОф ОЋОћОњОЊОеОЋОф ОаОЋОАОцОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОеОЕОЋОфОџ. ОЉОаОЋОАОБ, ОфОЌОЋОЉОе ОљОЋОўОЋОъОўОЎОф ОљОю ОЕОЎОеОЋОфОЎ Google.</translation>
<translation id="8681614230122836773">РђЈChrome ОњОЎОюОћ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ</translation>
<translation id="8682730193597992579">ОћОъОЊОцОАОф <ph name="PRINTER_NAME" /> ОъОЌОЋОЉОеОф ОЋОъОЋОЏОаОћ</translation>
<translation id="8683081248374354009">ОљОЎОцОЋОА ОћОДОЉОЋОдОћ</translation>
<translation id="8688672835843460752">ОќОъОЎОаОЋОф</translation>
<translation id="8690129572193755009">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОўОцОю ОЉОцОеОЋОўОЋОДОЋОюОЎОЮ</translation>
<translation id="8695139659682234808">ОћОЋОАОцОћ ОЕОю ОЉОДОеОф ОћОЋОеОЎОЮ ОюОљОЌОе ОћОћОњОЊОеОћ</translation>
<translation id="8695825812785969222">ОцОфОЎОЌОф &amp;ОъОЎОДОЋОЮ...</translation>
<translation id="8698269656364382265">ОЏОЊОЎ ОюОЌОќОЋОе ОюОъОАОџ ОћОДОЋОЊОЮ, ОъОЌОюОЎОДОЎОЮ ОъОдОЊ ОЎОъОЎОЪ.</translation>
<translation id="869884720829132584">ОфОцОеОЎОў ОЎОЎОЕОЋОъОЎОЮ</translation>
<translation id="869891660844655955">ОфОљОеОЎОџ ОфОцОЋОњОћ</translation>
<translation id="8699120352855309748">ОљОЎОЪ ОюОћОдОЎОњ ОљОф ОћОћОдОбОћ ОюОфОеОњОЮ ОљОф ОћОЕОцОЋОф ОћОљОюОћ</translation>
<translation id="8702825062053163569">Оћ-<ph name="DEVICE_TYPE" /> ОћОЎОћ ОаОбОЋОю.</translation>
<translation id="8703346390800944767">ОЊОЎОюОЋОњ ОбОю ОћОъОЋОЊОбОћ</translation>
<translation id="8705331520020532516">ОъОАОцОе ОАОЎОЊОЋОеОЎ</translation>
<translation id="8705580154597116082">РђЈОЎОЕ Wi-Fi ОќОъОЎОЪ ОЉОўОюОцОЋОЪ</translation>
<translation id="8705629851992224300">ОюОљ ОаОЎОфОЪ ОюОДОеОЋОљ ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ</translation>
<translation id="8706111173576263877">РђЈОДОЋОЊ Оћ-QR ОаОАОеОД.</translation>
<translation id="8708000541097332489">ОъОЌОЎОДОћ ОЉОбОф ОћОЎОдОЎОљОћ</translation>
<translation id="870805141700401153">РђЈОЌОфОЎОъОф ОДОЋОЊ ОцОеОўОЎ ОЕОю Microsoft</translation>
<translation id="8708671767545720562">&amp;ОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="8711402221661888347">ОЌОъОЋОдОЎОЮ</translation>
<translation id="8712637175834984815">ОћОЉОаОфОЎ</translation>
<translation id="8713570323158206935">ОЕОюОЎОЌОф <ph name="BEGIN_LINK1" />ОцОеОўОЎ ОъОбОеОЏОф<ph name="END_LINK1" /></translation>
<translation id="8714838604780058252">ОњОеОцОЎОДОф ОеОДОб</translation>
<translation id="871515167518607670">РђЈОЎОЕ ОюОЉОЌОЋОе ОъОЏОЕОЎОе. ОюОљОЌОе ОъОЏОЪ, ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОћОЊОБ, ОбОюОЎОџ ОюОцОфОЋОЌ ОЉОЋ ОљОф ОЊОцОЊОцОЪ Chrome.</translation>
<translation id="8715480913140015283">ОЏОеОўОЎОАОЎОЎОф ОћОеОДОб ОъОЕОфОъОЕОф ОЉОъОдОюОъОћ</translation>
<translation id="8716931980467311658">РђЈОюОъОЌОЋОД ОљОф ОЏОю ОћОљОцОюОЎОДОдОЎОЋОф ОЋОаОфОЋОаОЎ Linux ОъОфОЎОДОЎОЎОф ОДОЋОЉОдОЎ Linux ОЉ-<ph name="DEVICE_TYPE" /> ОћОќОћ?</translation>
<translation id="8717864919010420084">ОћОбОфОДОф ОћОДОЎОЕОЋОе</translation>
<translation id="8718994464069323380">ОќОЋОћОћ ОъОАОџ ОъОњОб</translation>
<translation id="8719472795285728850">ОЉОћОљОќОаОћ ОюОцОбОЎОюОЋОф ОфОЋОАОцОЎОЮРђд</translation>
<translation id="8719653885894320876">ОћОЋОеОЊОф <ph name="PLUGIN_NAME" /> ОаОЏОЕОюОћ</translation>
<translation id="8720200012906404956">ОћОъОбОеОЏОф ОъОЌОцОЕОф ОеОЕОф ОАОюОЋОюОеОЎОф. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="8720816553731218127">ОфОЮ ОћОќОъОЪ ОћОДОдОЋОЉ ОюОљОфОЌОЋОю ОЕОю ОъОљОцОЎОЎОаОЎ ОќОъОЪ ОћОћОфОДОаОћ.</translation>
<translation id="8722912030556880711">РђЈОЕОюОЎОЌОћ ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОбОю ОћОЕОЎОъОЋОЕ. ОћОъОЏОЕОЎОе ОћОќОћ ОЕОЋОюОЌ ОбОЏОЕОЎОЋ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОЋОЉОљОцОюОЎОДОдОЎОЋОф. ОаОфОЋОаОЎОЮ ОљОюОћ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОЎОдОЎОЉОЋОф ОћОъОбОеОЏОф ОЋОћОљОцОюОЎОДОдОЎОЋОф, ОЏОъОЋ ОњОЮ ОюОЉОЎОдОЋОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎ Android. ОљОЮ ОћОЋОцОбОюОћ ОћОљОцОЕОеОЋОф 'ОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. <ph name="BEGIN_LINK2" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK2" /></translation>
<translation id="8724405322205516354">ОЏОЕОЎОЋОдОњ ОюОџ ОћОАОъОю ОћОќОћ, ОъОЕОъОбОЋОф ОћОЊОЉОе ОћОЎОљ ОЕОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОўОЉОЎОбОф ОљОдОЉОб ОюОдОЋОеОЏОЎ ОќОЎОћОЋОЎ ОљОЋ ОюОљОЎОЕОЋОе ОеОЏОЎОЕОћ.</translation>
<translation id="8724409975248965964">ОўОЉОЎОбОф ОћОљОдОЉОб ОаОДОюОўОћ</translation>
<translation id="8724859055372736596">&amp;ОћОдОњОћ ОЉОфОЎОДОЎОЎОћ</translation>
<translation id="8725066075913043281">ОаОЎОАОЎОЋОЪ ОЌОЋОќОе</translation>
<translation id="8725178340343806893">ОъОЋОбОЊОцОЎОЮ/ОАОЎОъОаОЎОЋОф</translation>
<translation id="8726206820263995930">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОбОф ОћОЉОљОф ОћОњОЊОеОЋОф ОъОЊОЎОаОЎОЋОф ОъОћОЕОеОф: <ph name="CLIENT_ERROR" />.</translation>
<translation id="8728351286589123703">ОћОћОеОЕОљОЋОф ОЕОЉОЌОеОф ОЎОљОЋОцОАОЋ</translation>
<translation id="8729133765463465108">РђЈОАОеОЎОДОф ОДОЋОЊ QR ОЉОљОъОдОбОЋОф ОћОъОдОюОъОћ</translation>
<translation id="8730621377337864115">ОЉОЋОдОб</translation>
<translation id="8731629443331803108">ОћОљОфОе <ph name="SITE_NAME" /> ОъОЉОДОЕ ОљОф ОћОћОеОЕОљОћ ОћОЉОљОћ: <ph name="PERMISSION" /></translation>
<translation id="8731787661154643562">ОъОАОцОе ОЎОдОЎОљОћ</translation>
<translation id="8731851055419582926">ОћОАОЎОАОъОљОЋОф ОаОЉОЊОДОЋ</translation>
<translation id="8732030010853991079">ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОбОю ОЎОЊОЎ ОюОЌОЎОдОћ ОбОю ОАОъОю ОћОќОћ.</translation>
<translation id="8732212173949624846">ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОћОЮ ОћОфОЌОЉОеОф ОюОЌОЕОЉОЋОЪ</translation>
<translation id="8732844209475700754">ОбОЋОЊ ОћОњОЊОеОЋОф ОћОДОЕОЋОеОЋОф ОюОцОеОўОЎОЋОф, ОљОЉОўОЌОћ ОЋОљОЎОАОЋОБ ОаОфОЋОаОЎОЮ</translation>
<translation id="8734073480934656039">ОћОцОбОюОф ОћОћОњОЊОеОћ ОћОќОЋ ОъОљОцОЕОеОф ОћОцОбОюОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЎОЎОЕОЋОъОЎ ОДОЎОЋОАОД ОЉОбОф ОћОљОфОЌОЋОю.</translation>
<translation id="8734674662128056360">РђЈОЌОАОЎОъОф ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ</translation>
<translation id="873545264931343897">ОюОљОЌОе ОЕОћОбОЊОЏОЋОЪ ОЕОю <ph name="PLUGIN_NAME" /> ОЎОАОфОЎОЎОЮ, ОЎОЕ ОюОўОбОЋОЪ ОъОЌОЊОЕ ОљОф ОћОЊОБ ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОћОцОюОљОњОЎОЪ</translation>
<translation id="8736288397686080465">ОћОљОфОе ОћОќОћ ОбОЋОЊОЏОЪ ОЉОеОДОб.</translation>
<translation id="8737709691285775803">Shill</translation>
<translation id="8737914367566358838">ОЉОЌОЎОеОф ОћОЕОцОћ ОюОфОеОњОЋОЮ ОћОЊОБ</translation>
<translation id="8740247629089392745">РђЈОљОцОЕОе ОюОћОбОЉОЎОе ОљОф Оћ-Chromebook ОћОќОћ ОљОю <ph name="SUPERVISED_USER_NAME" />. ОћОћОфОДОаОћ ОЏОъОбОў ОћОАОфОЎОЎОъОћ. ОъОЎОЊ ОаОЎОфОЪ ОЎОћОЎОћ ОюОЌОДОЋОе ОЋОюОћОфОаОАОЋОф.</translation>
<translation id="8740672167979365981">РђЈОаОЊОеОЕ ОбОЊОЏОЋОЪ ОЕОю ChromeOS Flex</translation>
<translation id="8741944563400125534">ОъОЊОеОЎОџ ОюОћОњОЊОеОф ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ</translation>
<translation id="8742998548129056176">РђЈОќОћОЋ ОъОЎОЊОб ОЏОюОюОЎ ОЉОаОЋОњОб ОюОъОЏОЕОЎОе ОЋОюОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОЋ (ОЏОъОЋ ОеОъОф ОћОАОЋОюОюОћ, ОцОбОЎОюОЋОф ОћОъОбОеОЏОф, ОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЕОњОЎОљОЋОф). ОћОаОфОЋОаОЎОЮ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОЕОцОе ОљОф Android. ОЌОюОД ОъОћОъОЎОЊОб ОћОаОдОЉОе ОЎОбОќОЋОе ОњОЮ ОюОЕОцОе ОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОЋОе ОюОЕОЋОфОцОЎОЮ ОЕОю Google (ОюОъОЕОю ОюОъОцОфОЌОЎОЮ ОЕОю Android) ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЋОћОъОЋОдОеОЎОЮ ОЕОюОћОЮ.</translation>
<translation id="8746654918629346731">ОЏОЉОе ОћОњОЕОф ОЉОДОЕОћ ОЉОаОЋОЕОљ "<ph name="EXTENSION_NAME" />"</translation>
<translation id="874689135111202667">{0,plural, =1{ОюОћОбОюОЋОф ОДОЋОЉОЦ ОљОЌОЊ ОљОю ОћОљОфОе ОћОќОћ?}two{ОюОћОбОюОЋОф # ОДОЉОдОЎОЮ ОљОю ОћОљОфОе ОћОќОћ?}many{ОюОћОбОюОЋОф # ОДОЉОдОЎОЮ ОљОю ОћОљОфОе ОћОќОћ?}other{ОюОћОбОюОЋОф # ОДОЉОдОЎОЮ ОљОю ОћОљОфОе ОћОќОћ?}}</translation>
<translation id="8749805710397399240">ОюОљ ОаОЎОфОЪ ОюОћОбОЉОЎОе ОљОф ОћОъОАОџ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОеОЕОљОф ОъОДОюОЎОў ОћОъОАОџ ОЉ'ОћОбОЊОцОЋОф ОъОбОеОЏОф'.</translation>
<translation id="8749826920799243530">ОћОъОЏОЕОЎОе ОюОљ ОеОЕОЋОЮ</translation>
<translation id="8749863574775030885">РђЈОњОЎОЕОћ ОюОъОЏОЕОЎОеОЎ USB ОъОАОцОД ОюОљ ОЎОЊОЋОб</translation>
<translation id="8750155211039279868"><ph name="ORIGIN" /> ОеОЋОдОћ ОюОћОфОЌОЉОе ОљОю ОЎОдОЎОљОћ ОўОЋОеОЎОф</translation>
<translation id="8750346984209549530">РђЈAPN ОАОюОЋОюОеОЎ</translation>
<translation id="8751419011949619279">ОцОфОЎОЌОф ОљОфОеОЎОЮ ОЉОљОцОюОЎОДОдОЎОЋОф ОЕОъОЋОфОДОаОЋОф ОЉОъОЏОЕОЎОе</translation>
<translation id="8752451679755290210">ОъОбОЉОе ОљОЋОўОЋОъОўОЎ ОЉОЎОЪ ОцОеОЎОўОЎОЮ</translation>
<translation id="8753868764580670305">ОћОдОњОћ ОЋОаОЎОћОЋОю ОЕОю ОћОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="8753948258138515839">РђЈОћОљОцОюОЎОДОдОЎОћ 'ОДОЉОдОЎОЮ' ОаОЋОфОаОф ОњОЎОЕОћ ОъОћОЎОеОћ ОюОДОЉОдОЎОЮ ОЕОЕОъОеОф ОЉ-Google Drive, ОЉОћОфОДОЪ ОљОЌОАОЋОЪ ОЌОЎОдОЋОаОЎ ОљОЋ ОЉОъОЏОЕОЎОе ОЕОюОџ ОбОЮ ChromeOS Flex.</translation>
<translation id="8754200782896249056">РђЈ&lt;p&gt;ОЉОбОф ОћОцОбОюОф <ph name="PRODUCT_NAME" /> ОЉОАОЉОЎОЉОћ ОЕОю ОЕОЋОюОЌОаОЋОф ОбОЉОЋОЊОћ ОаОфОъОЏОЎОЮ, ОЎОЎОбОЕОћ ОЕОЎОъОЋОЕ ОЉОћОњОЊОеОЋОф Оћ-Proxy ОЕОю ОћОъОбОеОЏОф. ОбОЮ ОќОљОф, ОЎОЎОфОЏОЪ ОЕОћОъОбОеОЏОф ОЕОюОџ ОљОЎОаОћ ОаОфОъОЏОф, ОљОЋ ОЕОљОЎОеОбОћ ОЉОбОЎОћ ОЉОћОцОбОюОф ОфОдОЋОеОф ОћОъОбОеОЏОф.&lt;/p&gt;

          &lt;p&gt;ОЉОљОцОЕОеОЋОфОџ ОбОЊОЎОЎОЪ ОюОЉОдОб ОћОњОЊОеОф ОфОдОЋОеОћ ОЉОљОъОдОбОЋОф ОЕОЋОеОф ОћОцОДОЋОЊОћ. ОљОцОЕОе ОюОбОЎОЎОЪ ОЉОДОўОб &lt;code&gt;man<ph name="PRODUCT_BINARY_NAME" />&lt;/code&gt; ОюОДОЉОюОф ОъОЎОЊОб ОаОЋОАОБ ОбОю ОАОЎОъОЋОаОЎОЮ ОЋОъОЕОфОаОЎОЮ ОАОЉОЎОЉОфОЎОЎОЮ.&lt;/p&gt;</translation>
<translation id="8755175579224030324">ОЉОЎОдОЋОб ОъОЕОЎОъОЋОф ОћОДОЕОЋОеОЋОф ОюОљОЉОўОЌОћ ОбОЉОЋОе ОћОљОеОњОЋОЪ. ОюОъОЕОю, ОаОЎОћОЋОю ОљОЎОЕОЋОеОЎОЮ ОЋОъОцОфОЌОЋОф ОћОъОљОЋОЌОАОаОЎОЮ ОЉОъОЏОЕОЎОе</translation>
<translation id="8755376271068075440">&amp;ОњОЊОЋОю ОЎОЋОфОе</translation>
<translation id="875604634276263540">РђЈОЏОфОЋОЉОф Оћ-URL ОЕОю ОћОфОъОЋОаОћ ОюОљ ОфОДОЎОаОћ</translation>
<translation id="8756969031206844760">ОюОбОЊОЏОЪ ОљОф ОћОАОЎОАОъОћ?</translation>
<translation id="8757203080302669031">РђЈОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОъОЉОдОбОф ОАОеОЎОДОћ ОЉОљОЋОцОЪ ОцОбОЎОю ОЏОЊОЎ ОюОљОфОе ОћОфОДОаОЎ Bluetooth.</translation>
<translation id="8757368836647541092">ОћОАОеОф ОљОф <ph name="USER_NAME_OR_EMAIL" /></translation>
<translation id="8758418656925882523">ОћОцОбОюОф ОћОЏОфОЉОћ (ОЊОЎОЉОЋОе ОюОћОДОюОЊОћ)</translation>
<translation id="8759753423332885148">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="8761945298804995673">ОъОЕОфОъОЕ ОќОћ ОЏОЉОе ОДОЎОЎОЮ</translation>
<translation id="8762886931014513155">ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Оћ-<ph name="DEVICE_TYPE" /></translation>
<translation id="8763927697961133303">РђЈОћОфОДОЪ USB</translation>
<translation id="87646919272181953">РђЈОљОюОЉОЋОЮ ОЕОю Google Photos</translation>
<translation id="8767621466733104912">РђЈОбОЊОЏОЋОЪ ОљОЋОўОЋОъОўОЎ ОЕОю Chrome ОљОдОю ОЏОю ОћОъОЕОфОъОЕОЎОЮ</translation>
<translation id="8767765348545497220">ОАОњОЎОеОћ ОЕОю ОЉОЋОбОф ОћОбОќОеОћ</translation>
<translation id="8769901904650373714">РђЈОћОЎОЎОфОћ ОЉОбОЎОћ ОЉОћОњОЊОеОћ ОЕОю Steam</translation>
<translation id="8770406935328356739">ОАОцОеОЎОЎОф ОћОЉОАОЎОА ОЕОю ОфОЋОАОБ</translation>
<translation id="8771300903067484968">ОеОДОб ОЊОБ ОћОцОфОЎОЌОћ ОбОЉОе ОљОЎОцОЋОА ОюОеОДОб ОЉОеОЎОеОф ОћОъОЌОЊОю.</translation>
<translation id="8773302562181397928">ОЕОъОЎОеОф <ph name="PRINTER_NAME" /></translation>
<translation id="8774379074441005279">ОљОЎОЕОЋОе ОћОЕОЌОќОЋОе</translation>
<translation id="8774934320277480003">ОЕОЋОюОЎОЎОЮ ОбОюОЎОЋОаОЎОЮ</translation>
<translation id="8775144690796719618">ОЏОфОЋОЉОф ОљОфОе ОюОљ ОЌОЋОДОЎОф</translation>
<translation id="8775653927968399786">{0,plural, =1{ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЎОЎОаОбОю ОљОЋОўОЋОъОўОЎОф ОЉОбОЋОЊ ОЕОаОЎОЎОћ ОљОЌОф.
ОЏОЊОЎ ОюОбОЉОЋОЊ ОбОЮ ОћОЊОЋОъОЎОЎОЪ <ph name="DOMAIN" />, ОдОеОЎОџ ОюОћОЕОљОЎОе ОљОф ОћОЏОеОўОЎОА ОћОЌОЏОЮ ОЉОцОаОЎОЮ.}two{ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЎОЎОаОбОю ОљОЋОўОЋОъОўОЎОф ОЉОбОЋОЊ # ОЕОаОЎОЋОф.
ОЏОЊОЎ ОюОбОЉОЋОЊ ОбОЮ ОћОЊОЋОъОЎОЎОЪ <ph name="DOMAIN" />, ОдОеОЎОџ ОюОћОЕОљОЎОе ОљОф ОћОЏОеОўОЎОА ОћОЌОЏОЮ ОЉОцОаОЎОЮ.}many{ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЎОЎОаОбОю ОљОЋОўОЋОъОўОЎОф ОЉОбОЋОЊ # ОЕОаОЎОЋОф.
ОЏОЊОЎ ОюОбОЉОЋОЊ ОбОЮ ОћОЊОЋОъОЎОЎОЪ <ph name="DOMAIN" />, ОдОеОЎОџ ОюОћОЕОљОЎОе ОљОф ОћОЏОеОўОЎОА ОћОЌОЏОЮ ОЉОцОаОЎОЮ.}other{ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЎОЎОаОбОю ОљОЋОўОЋОъОўОЎОф ОЉОбОЋОЊ # ОЕОаОЎОЋОф.
ОЏОЊОЎ ОюОбОЉОЋОЊ ОбОЮ ОћОЊОЋОъОЎОЎОЪ <ph name="DOMAIN" />, ОдОеОЎОџ ОюОћОЕОљОЎОе ОљОф ОћОЏОеОўОЎОА ОћОЌОЏОЮ ОЉОцОаОЎОЮ.}}</translation>
