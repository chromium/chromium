<translation id="3048917188684939573">ОЎОЋОъОаОЎ ОћОбОЉОеОћ ОЋОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="3051250416341590778">ОњОЋОЊОю ОфОдОЋОњОћ</translation>
<translation id="3053013834507634016">ОЕОЎОъОЋОЕ ОЉОъОцОфОЌ ОљОЎОЕОЋОе </translation>
<translation id="3053273573829329829">ОћОцОбОюОћ ОЕОю ОДОЋОЊ ОљОЎОъОЋОф ОъОЕОфОъОЕ</translation>
<translation id="3054766768827382232">ОюОљОЌОе ОћОЕОЉОфОћ, ОЎОЎОфОЏОЪ ОЕОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОъОЏОЕОЎОеОЎОЮ ОћОЎОДОцОЎОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЎОЕОфОцОеОЋ, ОљОЉОю ОћОаОфОЋОаОЎОЮ ОћОљОЎОЕОЎОЎОЮ ОбОюОЋОюОЎОЮ ОюОћОЎОЌОЕОБ ОбОДОЉ ОЕОЎОъОЋОЕ ОюОљ ОъОЋОеОЕОћ.</translation>
<translation id="3055113921564083271">ОфОЌОЋОъОЎ ОбОаОЎОЎОЪ ОЕОћОАОеОф</translation>
<translation id="3055590424724986000">ОЉОљОъОдОбОЋОф ОАОцОД ОЕОаОЉОЌОе ОбОю ОЎОЊОџ</translation>
<translation id="3058498974290601450">ОљОцОЕОе ОюОћОцОбОЎОю ОљОф ОћОАОаОЏОеОЋОЪ ОЉОЏОю ОќОъОЪ ОЊОеОџ ОћОћОњОЊОеОЋОф</translation>
<translation id="3058517085907878899">ОЕОЮ ОћОъОЏОЕОЎОе</translation>
<translation id="3059195548603439580">ОеОЋОдОћ ОюОљОфОе ОљОф ОеОЏОЎОЉОЎ ОћОъОбОеОЏОф? ОЎОЕ ОюОбОЉОЋОе ОюОЏОфОЋОЉОф</translation>
<translation id="3060379269883947824">ОћОцОбОюОф ОћОДОеОљОћ</translation>
<translation id="3060952009917586498">ОЕОЎОаОЋОЎ ОћОЕОцОћ ОЉОъОЏОЕОЎОе. ОћОЕОцОћ ОћОаОЋОЏОЌОЎОф ОћОЎОљ <ph name="LANGUAGE" />.</translation>
<translation id="3060987956645097882">РђЈОюОљ ОћОдОюОЌОаОЋ ОюОћОфОЌОЉОе ОюОўОюОцОЋОЪ ОЕОюОџ. ОЎОЕ ОюОЋОЋОЊОљ ОЕОћОўОюОцОЋОЪ ОаОъОдОљ ОЉОДОеОЉОф ОъОДОЋОЮ, ОљОЎОаОЋ ОаОбОЋОю, ОЋОЕОћ-Bluetooth ОЋОћ-Wi-Fi ОцОЋОбОюОЎОЮ.</translation>
<translation id="3064871050034234884">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОъОЎОб ОдОюОЎОюОЎОЮ</translation>
<translation id="3065041951436100775">ОъОЕОЋОЉ ОбОю ОЏОеОўОЎОАОЎОЎОћ ОЕОаОАОњОеОћ.</translation>
<translation id="3065522099314259755">ОДОдОЉ ОЌОќОеОћ ОбОю ОцОбОЋОюОф ОъОДОюОЊОф</translation>
<translation id="3067198179881736288">ОюОћОфОДОЎОЪ ОљОф ОћОљОцОюОЎОДОдОЎОћ?</translation>
<translation id="3067198360141518313">ОћОеОдОф ОцОюОљОњОЎОЪ ОќОћ</translation>
<translation id="3071624960923923138">ОљОцОЕОе ОюОюОЌОЋОЦ ОЏОљОЪ ОЏОЊОЎ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="3072775339180057696">ОћОљОЮ ОюОљОцОЕОе ОюОљОфОе ОюОеОљОЋОф ОљОф <ph name="FILE_NAME" />?</translation>
<translation id="3075874217500066906">РђЈОаОЊОеОЕОф ОћОцОбОюОћ ОъОЌОЊОЕ ОбОю ОъОаОф ОюОћОфОЌОЎОю ОљОф ОфОћОюОЎОџ Оћ-Powerwash. ОюОљОЌОе ОћОћОцОбОюОћ ОъОЌОЊОЕ ОЎОЎОЊОеОЕ ОъОъОџ ОљОЎОЕОЋОе ОюОћОъОЕОЎОџ.</translation>
<translation id="3076909148546628648"><ph name="DOWNLOAD_RECEIVED" />/<ph name="DOWNLOAD_TOTAL" /></translation>
<translation id="3076966043108928831">ОЕОъОЎОеОћ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="3076977359333237641">ОцОеОўОЎ ОћОЏОаОЎОАОћ ОЕОюОџ ОаОъОЌОДОЋ</translation>
<translation id="3080933187214341848">ОћОеОЕОф ОћОќОЋ ОюОљ ОъОАОЋОаОЏОеОаОф ОюОЌОЕОЉОЋОЪ ОЕОюОџ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="3082374807674020857"><ph name="PAGE_TITLE" /> - <ph name="PAGE_URL" /></translation>
<translation id="308268297242056490">URI</translation>
<translation id="3082780749197361769">ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОъОЕОфОъОЕОф ОЉОъОдОюОъОћ ОљОЋ ОЉОъОЎОДОеОЋОцОЋОЪ ОЕОюОџ.</translation>
<translation id="3083193146044397360">ОћОљОфОе ОаОЌОАОЮ ОќОъОаОЎОф ОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОљОЉОўОЌОћ ОЕОюОџ</translation>
<translation id="3083899879156272923">ОћОќОќОф ОћОъОАОџ ОЏОЕОћОбОЏОЉОе ОаОЕОљОе ОЉОъОеОЏОќ ОћОъОАОџ</translation>
<translation id="3084548735795614657">ОЎОЕ ОюОЕОЌОеОе ОЏОЊОЎ ОюОћОфОДОЎОЪ</translation>
<translation id="3084771660770137092">РђЈОЎОЎОфОЏОЪ ОЕОћОќОЎОЏОеОЋОЪ ОЕОю Chrome ОљОќОю ОљОЋ ОЕОфОћОюОЎОџ ОЕОцОбОю ОбОю ОЊОБ ОћОљОЎОаОўОеОаОў ОћОЋОцОАОД ОъОАОЎОЉОћ ОЏОюОЕОћОЎ. ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОЎОЕ ОюОўОбОЋОЪ ОъОЌОЊОЕ ОљОЋ ОюОбОЉОЋОе ОюОЊОБ ОљОЌОе.</translation>
<translation id="3084958266922136097">ОћОЕОЉОфОф ОЕОЋОъОе ОћОъОАОџ</translation>
<translation id="3085412380278336437">ОћОљОфОе ОеОЕОљОЎ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ</translation>
<translation id="3085431803365340433">РђЈОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОбОЊОЏОЪ ОљОф ОЊОцОЊОцОЪ Chrome</translation>
<translation id="3088052000289932193">РђЈОћОљОфОе ОъОЕОфОъОЕ ОЉ-MIDI</translation>
<translation id="3088128611727407543">ОцОеОЋОцОЎОю ОћОљОцОюОЎОДОдОЎОћ ОЉОћОЏОаОћ...</translation>
<translation id="3088325635286126843">&amp;ОЕОЎОаОЋОЎ ОЕОЮ...</translation>
<translation id="3089137131053189723">ОћОЌОЎОцОЋОЕ ОаОЋОДОћ</translation>
<translation id="3090589793601454425">ОљОЎОЪ ОюОћОбОЉОЎОе</translation>
<translation id="3090819949319990166">РђЈОюОљ ОаОЎОфОЪ ОюОћОбОфОЎОД ОДОЋОЉОЦ crx ОЌОЎОдОЋОаОЎ Ою-<ph name="TEMP_CRX_FILE" />.</translation>
<translation id="3090871774332213558">"<ph name="DEVICE_NAME" />" ОъОЋОфОљОЮ</translation>
<translation id="3093714882666365141">РђЈОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОфОДОЎОЪ ОъОбОЉОЊОЎ handler ОюОфОЕОюОЋОъОЎОЮ</translation>
<translation id="3094141017404513551">ОЏОџ ОфОЋОцОеОЊ ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ ОъОћОцОбОЎОюОЋОф ОЕОю <ph name="EXISTING_USER" /></translation>
<translation id="3095871294753148861">ОАОЎОъОаОЎОЋОф, ОАОЎОАОъОљОЋОф ОЋОаОфОЋОаОЎ ОЊОцОЊОцОЪ ОљОЌОеОЎОЮ ОъОАОЋОаОЏОеОаОЎОЮ ОбОЮ ОћОЌОЕОЉОЋОЪ ОћОеОљОЕОЎ.</translation>
<translation id="3096047748133487529">ОћОДОЋОЉОЦ ОћОќОћ ОЏОЋОюОю ОфОЋОЏОЪ ОеОњОЎОЕ ОЋОюОЏОЪ ОћОЋОљ ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="3099836255427453137">{NUM_EXTENSIONS,plural, =1{ОфОЋОАОБ ОљОЌОЊ ОЕОбОЕОЋОЎ ОюОћОЎОЋОф ОъОќОЎОД ОЏОЉОЋОЎ ОбОЏОЕОЎОЋ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОЋОфОЋ.}two{{NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ ОЏОЉОЋОЎОЎОЮ ОбОЏОЕОЎОЋ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОЋОфОЮ.}many{{NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ ОЏОЉОЋОЎОЎОЮ ОбОЏОЕОЎОЋ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОЋОфОЮ.}other{{NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ ОЏОЉОЋОЎОЎОЮ ОбОЏОЕОЎОЋ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОЋОфОЮ.}}</translation>
<translation id="3101126716313987672">ОбОъОбОЋОЮ ОфОљОЋОеОф ОћОъОАОџ</translation>
<translation id="3101709781009526431">ОфОљОеОЎОџ ОЋОЕОбОћ</translation>
<translation id="3103451787721578293">ОЎОЕ ОюОћОќОЎОЪ ОАОЎОЉОћ ОюОћОбОюОљОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ:</translation>
<translation id="3105796011181310544">РђЈОюОћОЌОќОЎОе ОљОю Google?</translation>
<translation id="310671807099593501">РђЈОћОљОфОе ОъОЕОфОъОЕ ОЉ-Bluetooth</translation>
<translation id="3108931485517391283">ОюОљ ОаОЎОфОЪ ОюОДОЉОю ОљОф ОћОДОЋОЉОЦ</translation>
<translation id="3109206895301430738">ОДОЉОЋОдОЋОф ОЏОеОўОЎОАОЎОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="3109724472072898302">ОъОЏОЋОЋОЦ</translation>
<translation id="311214366526552035">ОюОћОЋОеОЎОЊ ОЉОЏОю ОќОљОф</translation>
<translation id="3112292765614504292">ОњОЋОЊОю ОћОљОцОюОЎОДОдОЎОћ: <ph name="APP_SIZE" /></translation>
<translation id="311394601889664316">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОбОеОЋОџ ОДОЉОдОЎОЮ ОљОЋ ОфОЎОДОЎОЋОф ОЉОъОЏОЕОЎОе</translation>
<translation id="3115147772012638511">ОЉОћОъОфОаОћ ОюОъОўОъОЋОЪ...</translation>
<translation id="3115580024857770654">ОЏОЎОЋОЋОЦ ОћОЏОЋОю</translation>
<translation id="3115743155098198207">РђЈОаОЎОћОЋОю ОћОЕОцОћ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="3117362587799608430">ОљОЉОЎОќОе ОћОбОњОЎОаОћ ОљОЎОаОЋ ОфОЋОљОЮ ОЉОљОЋОцОЪ ОъОюОљ</translation>
<translation id="3117791853215125017">{COUNT,plural, =1{ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОюОЋОЌ <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}two{ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОюОЋОЌ <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}many{ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОюОЋОЌ <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}other{ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОюОЋОЌ <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}}</translation>
<translation id="3118319026408854581">ОбОќОеОћ ОЕОю <ph name="PRODUCT_NAME" /></translation>
<translation id="3118654181216384296">РђЈОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ ОюОћОцОбОЎОю ОљОф Linux ОЉОбОЋОЊ ОЏОъОћ ОеОњОбОЎОЮ.</translation>
<translation id="3119948370277171654">РђЈОљОЎОќОћ ОфОЋОЏОЪ ОљОЋ ОЏОфОЋОЉОф URL ОћОбОЉОеОф?</translation>
<translation id="3120430004221004537">ОћОћОдОцОаОћ ОюОљ ОъОАОцОЎОДОћ ОюОцОбОЋОюОћ ОаОфОЋОаОћ ОЉОъОЏОЕОЎОе: "<ph name="DEVICE_NAME" />".</translation>
<translation id="3122464029669770682">CPU</translation>
<translation id="3122496702278727796">ОЎОдОЎОеОф ОАОцОеОЎОЎОф ОаОфОЋОаОЎОЮ ОаОЏОЕОюОћ</translation>
<translation id="3124111068741548686">ОъОќОћОЎОЮ ОЎОЎОЌОЋОЊОЎОЎОЮ ОЕОю ОъОЕОфОъОЕ</translation>
<translation id="3126026824346185272">Ctrl</translation>
<translation id="3127156390846601284">ОцОбОЋОюОћ ОќОЋ ОфОъОЌОД ОљОф ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОаОЕОъОеОЋ ОЉОъОЏОЕОЎОе ОбОЉОЋОе ОЏОю ОћОљОфОеОЎОЮ ОћОъОЋОдОњОЎОЮ. ОюОћОъОЕОЎОџ?</translation>
<translation id="3127860049873093642">РђЈОЏОЊОЎ ОюОћОЎОъОаОб ОъОЉОбОЎОЋОф ОЉОўОбОЎОаОћ ОЋОЉОЉОЎОдОЋОбОЎОЮ, ОЎОЕ ОюОћОЕОфОъОЕ ОЉОъОфОљОЮ ОъОфОЌ ОфОЋОљОЮ ОЕОю Dell, ОљОЋ ОъОАОЋОњ USB-C.</translation>
<translation id="3127862849166875294">РђЈОЕОЎОаОЋОЎ ОћОњОЋОЊОю ОЕОю ОЕОўОЌ ОћОљОЌОАОЋОЪ ОЕОю Linux ОЉОЏОЋОаОЪ</translation>
<translation id="3127882968243210659">РђЈОЏОЊОЎ ОюОћОцОбОЎОю ОљОф Google Play, ОбОюОЎОџ ОюОњОЉОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОюОљОцОА ОљОф Оћ-Chromebook ОћОќОћ ОюОћОњОЊОеОЋОф ОћОЎОдОеОЪ ОбОю ОцОЎ ОЊОеОЎОЕОф <ph name="MANAGER" />.</translation>
<translation id="3129173833825111527">ОЕОЋОюОЎОЎОЮ ОЕОъОљОюОЎОЎОЮ</translation>
<translation id="3129215702932019810">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОћОцОбОюОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="3130528281680948470">ОЎОфОЉОдОб ОљОЎОцОЋОА ОЕОю ОћОъОЏОЕОЎОе ОЕОюОџ ОЋОЏОю ОЌОЕОЉОЋОаОЋОф ОћОъОЕОфОъОЕОЎОЮ ОЋОћОаОфОЋОаОЎОЮ ОћОъОДОЋОъОЎОЎОЮ ОЎОЋОАОеОЋ ОъОъОаОЋ. ОюОљ ОаОЎОфОЪ ОюОЉОўОю ОцОбОЋОюОћ ОќОЋ.</translation>
<translation id="313205617302240621">ОЕОЏОЌОф ОљОф ОћОАОЎОАОъОћ?</translation>
<translation id="3132277757485842847">РђЈОюОљ ОћОдОюОЌОаОЋ ОюОЕОъОЋОе ОбОю ОћОЌОЎОЉОЋОе ОюОўОюОцОЋОЪ ОЕОюОџ. ОЎОЕ ОюОЋОЋОЊОљ ОЕОћОўОюОцОЋОЪ ОаОъОдОљ ОЉОДОеОЉОф ОъОДОЋОЮ, ОљОЎОаОЋ ОаОбОЋОю, ОЋОЕОћ-Bluetooth ОЋОћ-Wi-Fi ОцОЋОбОюОЎОЮ.</translation>
<translation id="3132896062549112541">ОЏОюОю</translation>
<translation id="3132996321662585180">ОеОбОаОЋОЪ ОъОЊОЎ ОЎОЋОЮ</translation>
<translation id="3134393957315651797">ОЎОЕ ОюОЉОЌОЋОе ОъОдОЉ ОюОаОЎОАОЋОЎ <ph name="EXPERIMENT_NAME" />. ОфОЎОљОЋОе ОћОаОЎОАОЋОЎ: <ph name="EXPERIMENT_DESCRIPTION" /></translation>
<translation id="313963229645891001">ОЉОћОЋОеОЊОћ, <ph name="STATUS" /></translation>
<translation id="3139925690611372679">ОЊОъОЋОф ОЉОеОЎОеОф ОъОЌОЊОю ОдОћОЋОЉОћ</translation>
<translation id="3141318088920353606">ОћОъОбОеОЏОф ОъОДОЕОЎОЉОћ...</translation>
<translation id="3141917231319778873">ОћОЉОДОЕОћ ОћОаОфОЋОаОћ ОљОЎОаОћ ОаОфОъОЏОф ОЉОъОЏОЕОЎОе: "<ph name="DEVICE_NAME" />".</translation>
<translation id="3142562627629111859">ОДОЉОЋОдОћ ОЌОЊОЕОћ</translation>
<translation id="3143515551205905069">ОЉОЎОўОЋОю ОАОаОЏОеОЋОЪ</translation>
<translation id="3143754809889689516">ОћОцОбОюОћ ОъОћОћОфОЌОюОћ</translation>
<translation id="3144647712221361880">ОцОфОЎОЌОф ОДОЎОЕОЋОе ОЉОфОЋОе</translation>
<translation id="3149510190863420837">РђЈОљОцОюОЎОДОдОЎОЋОф Chrome</translation>
<translation id="3150693969729403281">ОћОцОбОюОф ОЉОЊОЎОДОф ОЉОўОЎОЌОЋОф</translation>
<translation id="3150927491400159470">ОўОбОЎОаОћ ОъОЌОЊОЕ ОДОЕОЎОЌОћ</translation>
<translation id="315116470104423982">ОаОфОЋОаОЎ ОаОЎОЎОЊ</translation>
<translation id="3151539355209957474">ОЕОбОф ОћОфОЌОюОћ</translation>
<translation id="3151562827395986343">РђЈОъОЌОЎОДОћ ОЕОю ОћОћОЎОАОўОЋОеОЎОћ, ОЕОю ОДОЋОЉОдОЎ Оћ-cookie, ОЕОю ОћОъОўОъОЋОЪ ОЋОбОЋОЊ</translation>
<translation id="3151786313568798007">ОЏОЎОЋОЋОЪ</translation>
<translation id="3152356229013609796">ОћОеОЕОљОћ ОюОћОдОЎОњ ОљОф ОћОћОфОеОљОЋОф ОЕОЉОўОюОцОЋОЪ, ОюОАОњОЋОе ОљОЋОфОЪ ОЋОюОћОЕОЎОЉ ОюОћОЪ</translation>
<translation id="3157387275655328056">ОћОЋОАОБ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ</translation>
<translation id="3157931365184549694">ОЕОЌОќОЋОе</translation>
<translation id="3158033540161634471">ОћОњОЊОеОф ОўОЉОЎОбОф ОћОљОдОЉОб</translation>
<translation id="3158770568048368350">ОфОћОюОЎОџ ОћОћОњОЊОеОћ ОбОюОЋОю ОюОњОеОЋОЮ ОюОаОЎОфОЋОД ОДОдОе ОъОћОеОЕОф ОћОАОюОЋОюОеОЎОф</translation>
<translation id="3159493096109238499">ОЉОќ'</translation>
<translation id="3159978855457658359">ОбОеОЎОЏОф ОЕОЮ ОћОъОЏОЕОЎОе</translation>
<translation id="3160928651883997588">РђЈОћОбОЊОцОЋОф VPN</translation>
<translation id="3161522574479303604">ОЏОю ОћОЕОцОЋОф</translation>
<translation id="3162853326462195145">ОЌОЕОЉОЋОЪ ОЉОЎОф ОАОцОеОЎ</translation>
<translation id="3162899666601560689">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОЏОЊОЎ ОюОЕОцОе ОљОф ОЌОЋОЋОЎОЎОф ОћОњОюОЎОЕОћ РђЊ ОюОъОЕОю, ОЏОЊОЎ ОюОъОаОЋОб ОаОЎОфОЋОД ОЕОюОџ ОъОћОЌОЕОЉОЋОЪ ОљОЋ ОЏОЊОЎ ОюОќОЏОЋОе ОљОф ОћОцОеОЎОўОЎОЮ ОЕОћОЋОАОцОф ОюОбОњОюОф ОћОДОаОЎОЋОф</translation>
<translation id="3163201441334626963">ОъОЋОдОе ОюОљ ОЎОЊОЋОб <ph name="PRODUCT_ID" /> ОъОћОАОцОД <ph name="VENDOR_ID" /></translation>
<translation id="3163511056918491211">РђЈОДОю ОюОЕОЌОќОе ОаОфОЋОаОЎОЮ ОљОЋ ОюОћОЌОюОЎОБ ОъОЏОЕОЎОеОЎОЮ ОЉОЏОю ОЕОюОЉ. ОћОњОЎОЉОЋОЎОЎОЮ ОаОЕОъОеОЎОЮ ОЉ-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОћОАОЎОАОъОћ ОюОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="3164329792803560526">ОћОъОбОеОЏОф ОъОЕОфОцОф ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОбОЮ <ph name="APP_NAME" /></translation>
<translation id="3165390001037658081">ОЎОЎОфОЏОЪ ОЕОАОцОДОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЌОЋОАОъОЎОЮ ОљОф ОћОфОЏОЋОаОћ ОћОќОЋ.</translation>
<translation id="3170072451822350649">ОаОЎОфОЪ ОњОЮ ОюОЊОюОњ ОбОю ОћОЏОаОЎОАОћ ОЋ<ph name="LINK_START" />ОюОњОюОЋОЕ ОЏОљОЋОеОЌ<ph name="LINK_END" />.</translation>
<translation id="31774765611822736">ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОъОдОЊ ОЎОъОЎОЪ</translation>
<translation id="3177909033752230686">ОЕОцОф ОћОЊОБ:</translation>
<translation id="3179982752812949580">ОњОЋОцОЪ ОћОўОДОАОў</translation>
<translation id="3181954750937456830">ОњОюОЎОЕОћ ОЉОўОЋОЌОћ (ОъОњОаОћ ОбОюОЎОџ ОЋОбОю ОћОъОЏОЕОЎОе ОъОцОаОЎ ОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ)</translation>
<translation id="3182749001423093222">ОЉОЊОЎОДОф ОљОЎОЋОф</translation>
<translation id="3183139917765991655">ОъОЎОЎОЉОљ ОцОеОЋОцОЎОюОЎОЮ</translation>
<translation id="3183143381919926261">ОеОЕОфОЋОф ОаОфОЋОаОЎОЮ ОАОюОЋОюОеОЎОЋОф</translation>
<translation id="3183944777708523606">ОцОеОЎОАОф ОдОњОЎОЮ</translation>
<translation id="3184536091884214176">РђЈОћОњОЊОеОћ ОљОЋ ОаОЎОћОЋОю ОЕОю ОъОЊОцОАОЋОф CUPS. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="3185014249447200271">{NUM_APPS,plural, =1{ОћОљОцОюОЎОДОдОЎОћ ОћОќОЋ ОЌОАОЋОъОћ}two{ОЌОюОД ОъОћОљОцОюОЎОДОдОЎОЋОф ОЌОАОЋОъОЋОф}many{ОЌОюОД ОъОћОљОцОюОЎОДОдОЎОЋОф ОЌОАОЋОъОЋОф}other{ОЌОюОД ОъОћОљОцОюОЎОДОдОЎОЋОф ОЌОАОЋОъОЋОф}}</translation>
<translation id="3187472288455401631">ОъОЊОЎОЊОф ОъОЋОЊОбОЋОф</translation>
<translation id="3188257591659621405">ОћОДОЉОдОЎОЮ ОЕОюОЎ</translation>
<translation id="3188465121994729530">ОъОъОЋОдОб ОаОб</translation>
<translation id="3189187154924005138">ОАОъОЪ ОњОЊОЋОю</translation>
<translation id="3190558889382726167">ОћОАОЎОАОъОћ ОаОЕОъОеОћ</translation>
<translation id="3192947282887913208">ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ</translation>
<translation id="3194786596445804250">РђЈОћОдОњОф ОцОеОўОЎОЮ ОбОю ОЌОАОЎОъОф ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊОЊОЎОЮ ОЕОюОЎОЕОЎОЎОЮ</translation>
<translation id="3197453258332670132">ОЉОюОЌОЎОдОћ ОЎОъОаОЎОф ОљОЋ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ, ОЎОЋОдОњ ОъОЎОЊОб ОЕОДОЕОЋОе ОюОўОДОАОў ОЕОЉОЌОеОф</translation>
<translation id="3199127022143353223">ОЕОеОфОЎОЮ</translation>
<translation id="3200061262156232574">ОЉОбОњОюОф ОћОДОаОЎОЋОф ОЕОюОџ</translation>
<translation id="3201422919974259695">РђЈОћОфОДОаОЎ USB ОќОъОЎОаОЎОЮ ОЎОЋОцОЎОбОЋ ОЏОљОЪ.</translation>
<translation id="3202131003361292969">ОаОфОЎОЉ</translation>
<translation id="3202173864863109533">ОћОљОЋОЊОЎОЋ ОЉОЏОеОўОЎОАОЎОЎОћ ОќОЋ ОъОЋОЕОфОД.</translation>
<translation id="3204648577100496185">ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЎОЋОАОеОЋ ОъОћОъОЏОЕОЎОе ОаОфОЋОаОЎОЮ ОћОъОЕОЋОЎОЏОЎОЮ ОюОљОцОюОЎОДОдОЎОћ ОћОќОЋ</translation>
<translation id="3208321278970793882">ОљОцОюОЎОДОдОЎОћ</translation>
<translation id="3208584281581115441">ОЉОЊОЎОДОћ ОбОЏОЕОЎОЋ</translation>
<translation id="3208703785962634733">ОюОљ ОъОљОЋОЕОе</translation>
<translation id="32101887417650595">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОъОЊОцОАОф</translation>
<translation id="3210736980143419785">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОАОЎОЎОЮ ОљОф ОћОћОЋОеОЊОћ</translation>
<translation id="321084946921799184">ОдОћОЋОЉ ОЋОюОЉОЪ</translation>
<translation id="321356136776075234">РђЈOU ОЕОю ОъОЏОЕОЎОе (ОюОЊОЋОњОъОћ OU=Chromebooks,DC=example,DC=com)</translation>
<translation id="3214531106883826119"><ph name="BEGIN_BOLD" />ОћОбОеОћ:<ph name="END_BOLD" /> ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОъОЎОЕОћОЋ ОЎОдОюОЎОЌ ОюОњОЕОф ОљОю ОћОфОЋОдОљОЋОф ОћОљОЎОЕОЎОЋОф ОЕОю <ph name="SUPERVISED_USER_NAME" /> ОњОЮ ОЉОљОъОдОбОЋОф ОДОЋОю ОЊОЋОъОћ ОљОЋ ОћОДОюОўОћ.</translation>
<translation id="3217843140356091325">ОюОЎОдОЋОе ОДОЎОдОЋОе ОЊОеОџ?</translation>
<translation id="321834671654278338">РђЈОъОаОћОю ОћОАОеОф ОћОћОфОДОаОћ ОЕОю Linux</translation>
<translation id="3220943972464248773">ОЏОЊОЎ ОюОАОаОЏОеОЪ ОљОф ОћОАОЎОАОъОљОЋОф ОбОюОЎОџ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="3222066309010235055">ОДОЊОЮ-ОбОЎОЉОЋОЊ: <ph name="PRERENDER_CONTENTS_NAME" /></translation>
<translation id="3222779980972075989">ОћОфОЌОЉОеОЋОф ОљОю <ph name="USB_VM_NAME" /></translation>
<translation id="3223531857777746191">ОюОЌОдОЪ ОљОЎОцОЋОА</translation>
<translation id="3225084153129302039">ОЊОъОЋОф ОЉОеОЎОеОф ОъОЌОЊОю ОАОњОЋОюОћ</translation>
<translation id="3225319735946384299">ОЌОфОЎОъОф ОДОЋОЊ</translation>
<translation id="3226487301970807183">ОћОЌОюОцОф ОъОдОЉ ОюОЌОюОЋОаОЎОф ОћОдОЊОЊОЎОф ОъОЕОъОљОю</translation>
<translation id="3227137524299004712">ОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="3232754137068452469">ОљОцОюОЎОДОдОЎОЎОф ОљОЎОаОўОеОаОў</translation>
<translation id="3233271424239923319">РђЈОњОЎОЉОЋОЎ ОДОЉОдОЎОЮ ОЋОљОцОюОЎОДОдОЎОЋОф ОЕОю Linux</translation>
<translation id="3234978181857588512">ОЕОъОЎОеОћ ОЉОъОЏОЕОЎОе</translation>
<translation id="3238192140106069382">ОъОфОЉОдОбОЎОЮ ОћОфОЌОЉОеОЋОф ОЋОљОЎОъОЋОф</translation>
<translation id="3239373508713281971">ОъОњОЉОюОф ОћОќОъОЪ ОЕОю <ph name="APP_NAME" /> ОћОЋОАОеОћ</translation>
<translation id="3241680850019875542">ОЎОЕ ОюОЉОЌОЋОе ОљОф ОАОцОеОЎОЎОф ОћОЉОАОЎОА ОЕОю ОћОфОЋОАОБ ОЕОЎОЕ ОюОљОеОЋОќ. ОЏОЊОЎ ОюОбОЊОЏОЪ ОфОЋОАОБ, ОЎОЕ ОюОЉОЌОЋОе ОњОЮ ОљОф ОДОЋОЉОЦ ОћОъОцОфОЌ ОћОцОеОўОЎ ОЕОЉОЋ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЕОЋОЉ.</translation>
<translation id="3242289508736283383">РђЈОЉОъОдОЉ ОДОЎОЋОАОД ОЕОю ChromeOS, ОЎОЕ ОюОћОфОДОЎОЪ ОљОцОюОЎОДОдОЎОЋОф ОбОЮ ОъОљОцОЎОЎОЪ ОћОъОаОЎОцОАОў 'kiosk_only'</translation>
<translation id="3242665648857227438">РђЈОЉОцОеОЋОцОЎОю ОћОќОћ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОћОњОЊОеОЋОф ОюОЕОеОф proxy ОЕОю ChromeOS.</translation>
<translation id="3244294424315804309">ОћОъОЕОџ ОћОЕОфОДОф ОћОдОюОЎОюОЎОЮ</translation>
<translation id="324849028894344899"><ph name="WINDOW_TITLE" /> - ОЕОњОЎОљОф ОеОЕОф</translation>
<translation id="3248902735035392926">ОЌОЕОЋОЉ ОюОћОфОаОћОю ОЉОдОЋОеОћ ОЉОўОЋОЌОћ. ОЏОЊОљОЎ ОюОћОДОЊОЎОЕ ОЏОъОћ ОеОњОбОЎОЮ ОЏОЊОЎ <ph name="BEGIN_LINK" />ОюОЉОЊОЋОД ОбОЏОЕОЎОЋ ОљОф ОћОфОЋОАОцОЎОЮ<ph name="END_LINK" /></translation>
<translation id="3251714896659475029">РђЈОћОеОЕОљОћ Ою<ph name="SUPERVISED_USER_NAME" /> ОюОћОцОбОЎОю ОљОф Google Assistant ОЉОљОъОдОбОЋОф ОћОцОаОЎОЎОћ РђюHey GoogleРђЮ</translation>
<translation id="3251759466064201842">&lt;ОюОљ ОЌОюОД ОъОћОљОЎОЕОЋОе&gt;</translation>
<translation id="325238099842880997">ОъОЋОъОюОЦ ОюОћОњОЊОЎОе ОЏОюОюОЎОЮ ОЊОЎОњОЎОўОюОЎОЎОЮ ОЏОЊОЎ ОюОбОќОЋОе ОюОЎОюОЊОЎОЮ ОюОЕОЌОД, ОюОЌОДОЋОе ОЋОюОбОЕОЋОф ОЕОЎОбОЋОеОЎ ОЉОЎОф</translation>
<translation id="3253448572569133955">ОЌОЕОЉОЋОЪ ОюОљ ОЎОЊОЋОб</translation>
<translation id="3254084468305910013">{COUNT,plural, =0{ОюОљ ОаОъОдОљОЋ ОЉОбОЎОЋОф ОљОЉОўОЌОћ}=1{ОаОъОдОљОћ ОЉОбОЎОЎОф ОљОЉОўОЌОћ ОљОЌОф ({COUNT})}two{ОаОъОдОљОЋ {COUNT} ОЉОбОЎОЋОф ОљОЉОўОЌОћ}many{ОаОъОдОљОЋ {COUNT} ОЉОбОЎОЋОф ОљОЉОўОЌОћ}other{ОаОъОдОљОЋ {COUNT} ОЉОбОЎОЋОф ОљОЉОўОЌОћ}}</translation>
<translation id="3254516606912442756">ОќОЎОћОЋОЎ ОљОЋОўОЋОъОўОЎ ОЕОю ОљОќОЋОе ОћОќОъОЪ ОъОЋОЕОЉОф</translation>
<translation id="3254715652085014625">РђЈОцОЋОфОЌОЎОЮ ОљОф Chrome ОЉОўОюОцОЋОЪ Android, ОбОЋОЉОеОЎОЮ ОљОю "ОћОњОЊОеОЋОф &gt; ОАОЎОАОъОљОЋОф &gt; ОЕОЎОъОЋОЕ ОЉОўОюОцОЋОЪ ОЏОъОцОфОЌ ОљОЉОўОЌОћ" ОЋОцОЋОбОюОЎОЮ ОюОцОЎ ОћОћОЋОеОљОЋОф.</translation>
<translation id="3255355328033513170">РђЈОЏОю ОћОаОфОЋОаОЎОЮ ОЕОљОЋОЌОАОаОЋ ОбОю-ОЎОЊОЎ <ph name="SITE_GROUP_NAME" />, ОљОЋ ОбОю ОЎОЊОЎ ОљОфОеОЎОЮ ОћОаОЏОюОюОЎОЮ ОЉОДОЉОЋОдОћ, ОЎОЎОъОЌОДОЋ. ОњОЮ ОДОЋОЉОдОЎ cookie ОЎОЎОъОЌОДОЋ. ОфОЉОЋОдОб ОЎОдОЎОљОћ ОъОћОљОфОеОЎОЮ ОћОљОюОћ, ОњОЮ ОЉОЏОеОўОЎОАОЎОЋОф ОцОфОЋОЌОЋОф.</translation>
<translation id="3257733480216378006">ОеОЋОдОћ ОюОљОЕОе ОљОф <ph name="EXTENSIONS_REQUESTING_ACCESS_COUNT" />?</translation>
<translation id="3259723213051400722">ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3261268979727295785">РђЈОЉОЌОЕОЉОЋОаОЋОф ОЕОю ОЎОюОЊОЎОЮ ОЉОЋОњОеОЎОЮ ОЎОЋОфОе ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЋОАОЎОБ ОЉОДОеОф ОћОЋОеОЎОЮ ОюОљОЌОе ОАОЎОЋОЮ ОћОћОњОЊОеОћ. ОЉОљОцОюОЎОДОдОЎОћ 'ОъОћ ОЌОЊОЕ ОЉ-Chromebook' ОъОцОЋОеОў ОъОЎОЊОб ОаОЋОАОБ ОбОю ОЉОДОеОф ОћОЋОеОЎОЮ.</translation>
<translation id="3262986719682892278">ОњОЊОЋОю ОъОЊОЎ</translation>
<translation id="3264544094376351444">РђЈОњОЋОцОЪ Sans-Serif</translation>
<translation id="3264582393905923483">ОћОДОЕОе</translation>
<translation id="3265118321284789528">ОЉОћОъОфОаОћ ОюОљОЎОЕОЋОе ОћОЋОеОћ</translation>
<translation id="3265459715026181080">ОАОњОЎОеОф ОЌОюОЋОЪ</translation>
<translation id="3266022278425892773">РђЈОАОЉОЎОЉОф ОцОЎОфОЋОЌ ОЕОю Linux</translation>
<translation id="3266274118485960573">ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОЋОбОюОф.</translation>
<translation id="3267726687589094446">ОюОћОъОЕОЎОџ ОюОљОцОЕОе ОћОЋОеОЊОЋОф ОљОЋОўОЋОъОўОЎОЋОф ОЕОю ОДОЉОдОЎОЮ ОъОеОЋОЉОЎОЮ</translation>
<translation id="3268451620468152448">ОЏОеОўОЎОАОЎОЋОф ОцОфОЋОЌОЋОф</translation>
<translation id="3269093882174072735">ОўОбОЎОаОф ОфОъОЋОаОћ</translation>
<translation id="326911502853238749">ОљОЎОЪ ОюОћОдОЎОњ <ph name="MODULE_NAME" /></translation>
<translation id="3269612321104318480">ОЏОЌОЋОю-ОЎОеОДОеОД ОЉОћОЎОе ОЋОюОЉОЪ</translation>
<translation id="3269689705184377744">{COUNT,plural, =1{ОДОЋОЉОЦ}two{# ОДОЉОдОЎОЮ}many{# ОДОЉОдОЎОЮ}other{# ОДОЉОдОЎОЮ}}</translation>
<translation id="326999365752735949">ОћОЋОеОЊОф ОћОћОЉОЊОюОЎОЮ ОъОфОЉОдОбОф</translation>
<translation id="3270965368676314374">ОДОеОЎОљОћ, ОЕОЎОаОЋОЎ ОЋОъОЌОЎОДОћ ОЕОю ОДОЋОЉОдОЎ ОфОъОЋОаОЋОф, ОъОЋОќОЎОДОћ ОЋОъОЊОЎОћ ОъОАОЋОњОЎОЮ ОаОЋОАОцОЎОЮ ОъОћОъОЌОЕОЉ ОЕОюОџ</translation>
<translation id="327147043223061465">РђЈОћОдОњОћ ОЕОю ОЏОю ОДОЋОЉОдОЎ Оћ-Cookie ОЋОаОфОЋОаОЎ ОћОљОфОеОЎОЮ</translation>
<translation id="3274763671541996799">ОбОЉОеОф ОюОъОАОџ ОъОюОљ.</translation>
<translation id="3275778809241512831">ОъОцОфОЌ ОћОљОЉОўОЌОћ ОћОцОаОЎОъОЎ ОюОљ ОъОљОЋОЉОўОЌ ОЏОеОњОб. ОЎОЕ ОюОћОАОЎОе ОљОЋОфОЋ ОъОЏОю ОћОЕОЎОеОЋОфОЎОЮ ОЕОЉОћОЮ ОћОЕОфОъОЕОф ОЉОЋ. ОЏОЊОЎ ОюОцОфОЋОе ОљОф ОћОЉОбОЎОћ, ОЎОЕ ОюОљОцОА ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ.</translation>
<translation id="3275778913554317645">ОцОфОЎОЌОћ ОЏОЌОюОЋОЪ</translation>
<translation id="3278001907972365362">РђЈОЏОЊОљОЎ ОюОЉОЊОЋОД ОљОЮ ОдОеОЎОџ ОюОЉОдОб ОцОбОЋОюОћ ОЏОюОЕОћОЎ ОЉОЌОЕОЉОЋОаОЋОф Google ОЕОюОџ</translation>
<translation id="3279092821516760512">ОљОаОЕОЎ ОћОДОЕОе ОЕОаОЉОЌОеОЋ ОЎОЋОЏОюОЋ ОюОЕОфОБ ОљОЎОфОџ ОЏОЕОћОЮ ОЎОЎОъОдОљОЋ ОЉОДОеОЉОф ОъОДОЋОЮ. ОфОћОюОЎОџ ОћОћОбОЉОеОћ ОюОљ ОЎОфОЌОЎОю ОюОцОаОЎ ОЕОЎОфОДОЉОю ОъОъОџ ОљОЎОЕОЋОе.</translation>
<translation id="3279230909244266691">ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф. ОъОфОЉОдОбОф ОћОцОбОюОћ ОЕОю ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф.</translation>
<translation id="3280237271814976245">ОЕОъОЎОеОћ &amp;ОЉОЕОЮ...</translation>
<translation id="3280243678470289153">РђЈОюОћОЎОЕОљОе ОЉ-Chrome</translation>
<translation id="3281892622610078515">ОДОЉОдОЎОЮ ОЋОфОЋОЏОаОЋОф ОЕОЎОЕ ОюОћОбОЉОЎОе ОюОћОАОњОе:</translation>
<translation id="3282210178675490297">ОћОъОбОеОЏОф ОъОЕОфОцОф ОЏОеОўОЎОАОЎОЎОћ ОбОЮ ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /></translation>
<translation id="3282568296779691940">РђЈОЏОаОЎОАОћ Ою-Chrome</translation>
<translation id="3285322247471302225">ОЏОеОўОЎОАОЎОЎОћ &amp;ОЌОЊОЕОћ</translation>
<translation id="328571385944182268">ОюОЕОъОЋОе ОљОф ОћОАОЎОАОъОљОЋОф?</translation>
<translation id="3288047731229977326">ОфОЋОАОцОЎОЮ ОћОеОдОЎОЮ ОЉОъОдОЉ ОъОцОфОЌ ОЎОЏОЋОюОЎОЮ ОюОћОќОЎОД ОюОъОЌОЕОЉ ОЕОюОџ. ОљОЮ ОљОЎОаОџ ОъОцОфОЌ, ОбОюОЎОџ ОюОћОЕОЉОЎОф ОљОф ОћОфОЋОАОцОЎОЮ ОћОеОдОЎОЮ ОЉОъОдОЉ ОъОцОфОЌ ОЏОЊОЎ ОюОЕОъОЋОе ОбОю ОЉОЎОўОЌОЋОаОџ.</translation>
<translation id="3289668031376215426">ОљОЋОфОЎОЋОф ОеОЎОЕОЎОЋОф ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="3289856944988573801">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОбОЊОЏОЋОаОЎОЮ, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉОљОфОеОаОў ОљОЋ ОЉ-Wi-Fi.</translation>
<translation id="3290249595466894471">ОЉОаОЋОАОБ, ОаОЕОюОЌОф ОЊОњОЎОъОћ ОДОўОаОћ ОЕОЏОЋОюОюОф ОЊОцОЎОЮ, ОћОЋОеОЊОЋОф, ОцОбОЎОюОЋОф ОЕОю ОфОЋОАОцОЎОЮ ОЋОцОеОўОЎ ОъОбОеОЏОф ОЏОЊОЎ ОюОљОфОе ОљОЎОЋОъОЎОЮ ОЌОЊОЕОЎОЮ</translation>
<translation id="3293644607209440645">ОЕОюОЎОЌОф ОћОЊОБ ОћОќОћ</translation>
<translation id="32939749466444286">РђЈОћОДОЋОаОўОЎОЎОаОе ОЕОю Linux ОюОљ ОћОЋОцОбОю. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3294437725009624529">ОљОЋОеОЌ</translation>
<translation id="3294686910656423119">ОАОўОўОЎОАОўОЎОДОЋОф ОЕОЎОъОЋОЕ ОЋОЊОЋОЌОЋОф ОДОеОЎОАОћ</translation>
<translation id="3297536526040732495">РђЈОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОЉОЏОю ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google, ОЉОъОћОюОџ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОъОфОЉОдОб ОДОЎОЕОЋОе ОќОъОаОЎ ОЕОю ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОюОЌОЕОЉОЋОЪ Google.</translation>
<translation id="329838636886466101">ОфОЎОДОЋОЪ</translation>
<translation id="3298789223962368867">ОћОЋОќОаОћ ОЏОфОЋОЉОф ОљОфОе ОюОљ ОЌОЋОДОЎОф.</translation>
<translation id="32991397311664836">ОъОЏОЕОЎОеОЎОЮ:</translation>
<translation id="33022249435934718">РђЈОъОќОћОЎОЮ ОЎОЎОЌОЋОЊОЎОЎОЮ ОЕОю GDI</translation>
<translation id="3302388252085547855">ОЎОЕ ОюОћОќОЎОЪ ОћОдОЊОДОћРђд</translation>
<translation id="3303260552072730022">ОфОЋОАОБ ОћОцОбОЎОю ОъОАОџ ОъОюОљ.</translation>
<translation id="3303795387212510132">ОюОљОЕОе ОюОљОцОюОЎОДОдОЎОћ ОюОцОфОЋОЌ ОДОЎОЕОЋОеОЎ <ph name="PROTOCOL_SCHEME" />?</translation>
<translation id="3303818374450886607">ОбОЋОфОДОЎОЮ</translation>
<translation id="3303855915957856445">ОюОљ ОаОъОдОљОЋ ОфОЋОдОљОЋОф ОЌОЎОцОЋОЕ</translation>
<translation id="3304212451103136496"><ph name="DISCOUNT_AMOUNT" /> ОћОаОЌОћ</translation>
<translation id="3305389145870741612">ОфОћОюОЎОџ ОћОцОеОъОЋОў ОбОЕОЋОЎ ОюОћОЎОъОЕОџ ОъОАОцОе ОЕОаОЎОЋОф. ОЎОЕ ОюОћОъОфОЎОЪ.</translation>
<translation id="3305661444342691068">РђЈОцОфОЎОЌОф PDF ОЉОфОдОЋОњОћ ОъОДОЊОЎОъОћ</translation>
<translation id="3307176291962384345">ОДОЉОюОф ОћОаОЌОЋОф ОбОю ОъОЋОдОеОЎ <ph name="MERCHANT_NAME" /></translation>
<translation id="3308116878371095290">РђЈОюОљ ОаОЎОфОЪ ОюОћОњОЊОЎОе ОДОЋОЉОдОЎ Cookie ОюОЊОБ ОќОћ.</translation>
<translation id="3308134619352333507">ОюОЌОдОЪ 'ОћОАОфОеОћ'</translation>
<translation id="3308852433423051161">РђЈОўОбОЎОаОф Google Assistant ОъОфОЉОдОбОф...</translation>
<translation id="3309330461362844500">ОъОќОћОћ ОцОеОЋОцОЎОю ОћОљОЎОЕОЋОе</translation>
<translation id="3311445899360743395">ОЎОЎОфОЏОЪ ОЕОЎОЋОАОеОЋ ОъОћОъОЏОЕОЎОе ОаОфОЋОаОЎОЮ ОћОъОЕОЋОЎОЏОЎОЮ ОюОљОцОюОЎОДОдОЎОћ ОћОќОЋ.</translation>
<translation id="3312883087018430408">РђЈОЏОЊОЎ ОюОЌОцОЕ ОЉОљОфОе ОАОцОдОЎОцОЎ ОљОЋ ОЉОЌОюОД ОЏОюОЕОћОЋ ОЕОю Chrome, ОъОДОюОЎОЊОЎОЮ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОЕОюОћОЮ ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОЋОюОљОЌОе ОъОЏОЪ ОъОДОЎОЕОЎОЮ ОбОю ОъОДОЕ ОћОДОЎОдОЋОе ОћОъОЋОбОЊОБ. ОюОЊОЋОњОъОћ: ОЏОЊОЎ ОюОЌОцОЕ ОеОД ОЉ-Bookmarks, ОъОДОюОЎОЊОЎОЮ "Рђј@bookmarks" ОЋОъОДОЎОЕОЎОЮ ОбОю ОъОДОЕ Оћ-Tab ОљОЋ ОбОю ОъОДОЕ ОћОеОЋОЋОЌ.</translation>
<translation id="3313622045786997898">ОбОеОџ ОЌОфОЎОъОф ОљОЎОЕОЋОе </translation>
<translation id="3313950410573257029">ОЉОЊОЎОДОф ОћОЌОЎОЉОЋОе</translation>
<translation id="3315158641124845231">ОћОАОфОеОф <ph name="PRODUCT_NAME" /></translation>
<translation id="3315442055907669208">ОЏОаОЎОАОћ ОюОъОдОЉ ОДОЋОеОљ</translation>
<translation id="3317459757438853210">ОЊОЋ-ОдОЊОЊОЎ</translation>
<translation id="3317678681329786349">ОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОЊОБ ОќОћ ОЉОъОдОюОъОћ ОЋОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="3320620783302968370">ОљОЮ ОћОЉОбОЎОћ ОаОъОЕОЏОф, ОЎОЕ ОюОаОАОЋОф ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЏОЕОЎОе
    ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="3320630259304269485">ОњОюОЎОЕОћ ОЉОўОЋОЌОћ (ОћОњОаОћ ОъОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ) ОЋОћОњОЊОеОЋОф ОљОЉОўОЌОћ ОљОЌОеОЋОф</translation>
<translation id="3323295311852517824">{NUM_FILES,plural, =0{ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОъОЏОЎОюОЎОЮ ОфОЋОЏОЪ ОеОњОЎОЕ ОљОЋ ОъОАОЋОЏОЪ. ОдОеОЎОџ ОюОћОАОЎОе ОљОф ОћОфОЋОЏОЪ ОћОќОћ ОЋОюОаОАОЋОф ОЕОЋОЉ.}=1{ОћОДОЋОЉОЦ ОћОќОћ ОъОЏОЎОю ОфОЋОЏОЪ ОеОњОЎОЕ ОљОЋ ОъОАОЋОЏОЪ. ОдОеОЎОџ ОюОћОАОЎОе ОљОф ОћОфОЋОЏОЪ ОћОќОћ ОЋОюОаОАОЋОф ОЕОЋОЉ.}two{ОћОДОЉОдОЎОЮ ОћОљОюОћ ОъОЏОЎОюОЎОЮ ОфОЋОЏОЪ ОеОњОЎОЕ ОљОЋ ОъОАОЋОЏОЪ. ОдОеОЎОџ ОюОћОАОЎОе ОљОф ОћОфОЋОЏОЪ ОћОќОћ ОЋОюОаОАОЋОф ОЕОЋОЉ.}many{ОћОДОЉОдОЎОЮ ОћОљОюОћ ОъОЏОЎОюОЎОЮ ОфОЋОЏОЪ ОеОњОЎОЕ ОљОЋ ОъОАОЋОЏОЪ. ОдОеОЎОџ ОюОћОАОЎОе ОљОф ОћОфОЋОЏОЪ ОћОќОћ ОЋОюОаОАОЋОф ОЕОЋОЉ.}other{ОћОДОЉОдОЎОЮ ОћОљОюОћ ОъОЏОЎОюОЎОЮ ОфОЋОЏОЪ ОеОњОЎОЕ ОљОЋ ОъОАОЋОЏОЪ. ОдОеОЎОџ ОюОћОАОЎОе ОљОф ОћОфОЋОЏОЪ ОћОќОћ ОЋОюОаОАОЋОф ОЕОЋОЉ.}}</translation>
<translation id="3323521181261657960">ОЉОЋОаОЋОА! ОДОЎОЉОюОф ОбОЋОЊ ОќОъОЪ ОъОАОџ</translation>
<translation id="3323577066981719144">РђЈОЕОЎОаОЋОЎОЎОЮ ОЕОЎОЉОЋОдОбОЋ ОЏОљОЪ ОЎОЌОЋОюОЋ ОеОД ОЉОЊОцОЊОцОЪ Chrome. ОЏОЊОЎ ОюОЉОдОб ОЕОЎОаОЋОЎОЎОЮ ОЉОћОњОЊОеОЋОф ОЕОю ОЊОцОЊОцОЪ Chrome Lacros, ОбОюОЎОџ ОюОцОфОЋОЌ ОљОф ОЊОцОЊОцОЪ Chrome Lacros ОЋОюОбОЉОЋОе ОюОћОњОЊОеОЋОф.</translation>
<translation id="3325804108816646710">ОъОфОЉОдОб ОЌОЎОцОЋОЕ ОЕОю ОцОеОЋОцОЎОюОЎОЮ ОќОъОЎОаОЎОЮРђд</translation>
<translation id="3325910708063135066">РђЈОћОъОдОюОъОћ ОЋОћОъОЎОДОеОЋОцОЋОЪ ОъОЋОЕОЉОфОЎОЮ ОЉОћОбОЊОцОЋОф ОћОъОбОеОЏОф ОЕОю Mac</translation>
<translation id="3327050066667856415">РђЈОљОЉОўОЌОф ОћОъОЏОЕОЎОе ОъОфОЋОЏОаОаОф ОЉ-Chromebook ОЉОљОЋОцОЪ ОъОЋОЉОаОћ. ОћОъОЏОЕОЎОе ОЕОюОџ ОъОЋОњОЪ ОъОфОЋОЏОаОЋОф ОќОЊОЋОаОЎОЋОф ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ, ОЋОюОљ ОаОЊОеОЕОЋОф ОЉОЋ ОфОЋОЏОаОЋОф ОаОЋОАОцОЋОф.</translation>
<translation id="3328489342742826322">РђЈОЕОЌОќОЋОе ОъОњОЎОЉОЋОЎ ОЎОЉОЎОљ ОюОъОЌОЎОДОф ОћОљОцОюОЎОДОдОЎОЋОф ОЋОћОаОфОЋОаОЎОЮ ОћОДОЎОЎОъОЎОЮ ОЕОю Linux ОЉОфОЎОДОЎОЎОф ОДОЋОЉОдОЎ Linux.</translation>
<translation id="3331321258768829690">(<ph name="UTCOFFSET" />) <ph name="LONGTZNAME" /> (<ph name="EXEMPLARCITY" />)</translation>
<translation id="3331974543021145906">ОцОеОўОЎ ОљОцОюОЎОДОдОЎОћ</translation>
<translation id="3333190335304955291">ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф ОћОЕОЎОеОЋОф ОћОќОћ ОЊОеОџ ОћОћОњОЊОеОЋОф.</translation>
<translation id="3333961966071413176">ОЏОю ОљОаОЕОЎ ОћОДОЕОе</translation>
<translation id="3334632933872291866"><ph name="WINDOW_TITLE" /> - ОћОАОеОўОЋОЪ ОцОЋОбОю ОЉОъОдОЉ ОфОъОЋОаОћ ОЉОфОЋОџ ОфОъОЋОаОћ</translation>
<translation id="3335947283844343239">ОцОфОЎОЌОћ ОъОЌОЊОЕ ОЏОеОўОЎОАОЎОЎОћ ОЕОаОАОњОеОћ</translation>
<translation id="3336855445806447827">ОюОљ ОЉОўОЋОЌ</translation>
<translation id="3337568642696914359">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОўОцОю ОЉОцОеОЋОўОЋОДОЋОюОЎОЮ</translation>
<translation id="3340251637492627067">ОюОцОЎ ОЊОеОЎОЕОЋОф ОћОљОеОњОЋОЪ ОЕОюОџ, ОдОеОЎОџ ОюОЕОъОЋОе ОћОЋОеОЊОЋОф ОъОфОљОЎОъОЋОф ОЉ-<ph name="WEB_DRIVE" />. ОЉОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОЎОљОЋОЌОАОЪ ОљОАОЎОъОЋОЪ ОљОЎОъОЋОф ОЎОЎОЌОЋОЊОЎ ОЋОћОЋОљ ОЎОЕОъОЕ ОюОЏОю ОћОћОЋОеОЊОЋОф ОћОъОфОљОЎОъОЋОф ОћОбОфОЎОЊОЎОЋОф.</translation>
<translation id="3340620525920140773">ОћОћОЋОеОЊОћ ОћОЋОЕОюОъОћ: <ph name="FILE_NAME" />.</translation>
<translation id="3341699307020049241">ОДОЋОЊ ОљОЎОъОЋОф ОЕОњОЋОЎ. ОаОЕОљОеОЋ ОюОџ ОбОЋОЊ <ph name="RETRIES" /> ОаОЎОАОЎОЋОаОЋОф.</translation>
<translation id="3341703758641437857">ОћОфОеОф ОњОЎОЕОћ ОюОЏОфОЋОЉОЋОф ОљОфОеОЎОЮ ОЕОю ОДОЉОдОЎОЮ</translation>
<translation id="3342361181740736773">"<ph name="TRIGGERING_EXTENSION_NAME" />" ОеОЋОдОћ ОюОћОАОЎОе ОљОф ОћОфОЋОАОБ.</translation>
<translation id="3345135638360864351">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОюОЋОЌ ОљОю <ph name="NAME" /> ОљОф ОћОЉОДОЕОћ ОЕОюОџ ОюОњОЕОф ОюОљОфОе ОћОќОћ. ОаОАОћ ОЕОЋОЉ.</translation>
<translation id="3345634917232014253">ОЉОЊОЎОДОф ОћОљОЉОўОЌОћ ОцОбОюОћ ОюОцОаОЎ ОЏОъОћ ОеОњОбОЎОЮ</translation>
<translation id="3345886924813989455">ОюОљ ОаОъОдОљ ОЊОцОЊОцОЪ ОаОфОъОџ</translation>
<translation id="3347086966102161372">ОћОбОфОДОф ОЏОфОЋОЉОф &amp;ОфОъОЋОаОћ</translation>
<translation id="3348038390189153836">ОќОЋОћОћ ОћОфОДОЪ ОаОЕОюОБ</translation>
<translation id="3348131053948466246">РђЈОћОдОбОЋОф ОюОљОъОЋОњ'ОЎ. ОЏОЊОЎ ОюОбОЉОЋОе ОЉОЎОЪ ОћОћОдОбОЋОф, ОъОДОЎОЕОЎОЮ ОбОю ОћОЌОЎОдОЎОЮ ОюОъОбОюОћ ОљОЋ ОюОъОўОћ. ОЏОЊОЎ ОюОћОЋОАОЎОБ ОљОъОЋОњ'ОЎ, ОъОДОЎОЕОЎОЮ ОбОю Enter.</translation>
<translation id="3349933790966648062">ОћОќОЎОЏОеОЋОЪ ОЕОЉОЕОЎОъОЋОЕ</translation>
<translation id="335153035108712532">ОюОљ ОдОеОЎОџ ОюОќОЏОЋОе ОљОф ОћОАОЎОАОъОћ ОћОќОЋ. ОћОЎОљ ОфОЎОЕОъОе ОЉ-<ph name="GOOGLE_PASSWORD_MANAGER" /> ОбОЉОЋОе <ph name="EMAIL" /></translation>
<translation id="3354972872297836698">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЉОдОб ОћОфОљОъОћ ОюОъОЏОЕОЎОе <ph name="DEVICE_NAME" />. ОЎОЕ ОюОЉОЌОЋОе ОъОЏОЕОЎОе ОЏОЊОЎ ОюОаОАОЋОф ОЕОЋОЉ</translation>
