<translation id="3708684582558000260">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОАОњОЋОеОЎОЮ ОюОАОЎОЎОЮ ОЕОюОЎОЌОћ ОљОЋ ОДОЉОюОћ ОЕОю ОаОфОЋОаОЎОЮ</translation>
<translation id="3709244229496787112">ОћОЊОцОЊОцОЪ ОаОАОњОе ОюОцОаОЎ ОЕОћОћОЋОеОЊОћ ОћОЋОЕОюОъОћ.</translation>
<translation id="371174301504454251">ОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОцОеОўОЎОЋОф ОЕОюОџ, ОћОљОфОеОЎОЮ ОЕОаОЋОАОцОЋ ОюОеОЕОЎОъОћ ОюОцОаОЎ ОЎОЋОфОе Оъ-4 ОЕОЉОЋОбОЋОф ОаОъОЌОДОЎОЮ ОъОъОаОћ ОљОЋОўОЋОъОўОЎОф. ОљОфОе ОЕОЉОЎОДОеОф ОЉОЋ ОЕОЋОЉ ОбОЕОЋОЎ ОюОЌОќОЋОе ОЋОюОћОЋОцОЎОб ОЉОеОЕОЎОъОћ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОфОе ОљОЮ ОюОљ ОеОЋОдОЎОЮ ОЕОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЎОЋОњОЊОеОЋ ОюОцОЎ ОћОЉОЎОДОЋОе ОЉОЋ.</translation>
<translation id="3711931198657368127">ОћОЊ&amp;ОЉОДОћ ОЋОъОбОЉОе ОљОю <ph name="URL" /></translation>
<translation id="3711945201266135623">ОаОъОдОљОЋ <ph name="NUM_PRINTERS" /> ОъОЊОцОАОЋОф ОћОъОЕОЋОЎОЏОЋОф ОюОЕОеОф ОћОћОЊОцОАОћ</translation>
<translation id="3712050472459130149">ОЎОЕ ОюОбОЊОЏОЪ ОљОф ОћОЌОЕОЉОЋОЪ</translation>
<translation id="3712897371525859903">ОЕОъОЎОеОф ОЊОБ &amp;ОЉОЕОЮ...</translation>
<translation id="371300529209814631">ОћОДОЋОЊОЮ/ОћОЉОљ</translation>
<translation id="3713047097299026954">ОљОЎОЪ ОцОеОўОЎ ОЏОаОЎОАОћ ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОћОќОћ</translation>
<translation id="3714195043138862580">ОъОЏОЕОЎОе ОћОћОЊОњОъОћ ОћОќОћ ОћОЋОбОЉОе ОюОъОдОЉ ОЉОЎОўОЋОю ОЕОю ОаОЎОћОЋОю ОфОдОЋОеОћ.</translation>
<translation id="3719826155360621982">ОЊОБ ОћОЉОЎОф</translation>
<translation id="372062398998492895">CUPS</translation>
<translation id="3721119614952978349">РђЈОћОћОњОЊОеОЋОф ОЕОюОџ ОЉ-Google</translation>
<translation id="3722108462506185496">ОДОеОфОћ ОЕОњОЎОљОћ ОЉОћОцОбОюОф ОЕОЎОеОЋОф ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3727144509609414201">РђЈОеОЕОфОЋОф Wi-Fi ОќОъОЎОаОЋОф</translation>
<translation id="3727187387656390258">ОЉОЊОЎОДОф ОЌОюОЋОЪ ОъОЋОДОцОЦ</translation>
<translation id="372722114124766626">ОеОД ОцОбОЮ ОљОЌОф</translation>
<translation id="3727473233247516571">ОфОф-ОћОъОАОњОеОф ОћОЕОъОЋОеОћ ОЉОъОўОъОЋОЪ ОюОЊОБ ОћОДОЋОЊОЮ/ОћОЉОљ: <ph name="BACK_FORWARD_CACHE_PAGE_URL" /></translation>
<translation id="3728188878314831180">ОЕОЎОДОЋОБ ОћОфОеОљОЋОф ОъОћОўОюОцОЋОЪ</translation>
<translation id="3728681439294129328">ОћОњОЊОеОф ОЏОфОЋОЉОф ОћОеОЕОф</translation>
<translation id="3729303374699765035">РђЈОћОъОбОеОЏОф ОъОЉОДОЕОф ОљОЎОЕОЋОе ОЏОЕОљОфОе ОеОЋОдОћ ОюОљОфОе ОћОфОДОаОЎ Bluetooth ОДОеОЋОЉОЎОЮ</translation>
<translation id="3729506734996624908">ОљОфОеОЎОЮ ОъОЋОеОЕОЎОЮ</translation>
<translation id="3730076362938942381">ОљОцОюОЎОДОдОЎОћ ОюОЏОфОЎОЉОћ ОбОЮ ОАОўОЎОЎОюОЋОА</translation>
<translation id="3732078975418297900">ОЕОњОЎОљОћ ОЉОЕОЋОеОћ <ph name="ERROR_LINE" /></translation>
<translation id="3732530910372558017">ОДОЋОЊ ОћОљОЎОъОЋОф ОЎОЏОЋОю ОюОћОЎОЋОф ОЉОљОЋОеОџ ОЕОю 63 ОфОЋОЋОЎОЮ ОюОЏОю ОћОЎОЋОфОе</translation>
<translation id="3732857534841813090">РђЈОћОдОњОф ОъОЎОЊОб ОДОЕОЋОе ОбОю ОЎОЊОЎ Google Assistant</translation>
<translation id="3733296813637058299">РђЈОаОфОДОЎОЪ ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОЋ ОЉОЕОЉОЎОюОџ. ОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЋОф ОЉОЕОЉОЎОю <ph name="DEVICE_TYPE" /> ОќОъОЎОаОЋОф ОЉОЌОаОЋОф Play.</translation>
<translation id="3735740477244556633">ОъОЎОЋОЪ ОюОцОЎ</translation>
<translation id="3738632186060045350">ОћОаОфОЋОаОЎОЮ ОЕОю <ph name="DEVICE_TYPE" /> ОЎОЎОъОЌОДОЋ ОЉОфОЋОџ 24 ОЕОбОЋОф</translation>
<translation id="3738924763801731196"><ph name="OID" />:</translation>
<translation id="3739254215541673094">ОюОцОфОЋОЌ ОљОф <ph name="APPLICATION" />?</translation>
<translation id="3741056951918180319">ОфОъОЎОЊ ОљОцОЕОе ОюОюОЌОЋОЦ ОбОю ОћОфОЋОАОБ ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОЋ ОЉОЏОю ОљОфОе ОЕОћОЋОљ</translation>
<translation id="3742235229730461951">ОцОеОЎОАОф ОъОДОюОЊОф ОЉОДОЋОеОЎОљОаОЎОф</translation>
<translation id="3742666961763734085">ОюОљ ОаОЎОфОЪ ОюОъОдОЋОљ ОЎОЌОЎОЊОћ ОљОеОњОЋОаОЎОф ОЉОЕОЮ ОћОќОћ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3743842571276656710">ОдОеОЎОџ ОюОћОќОЎОЪ ОДОЋОЊ ОљОЎОъОЋОф ОЏОЊОЎ ОюОЎОдОЋОе ОћОфОљОъОћ ОбОЮ <ph name="DEVICE_NAME" /></translation>
<translation id="3747077776423672805">РђЈОЏОЊОЎ ОюОћОАОЎОе ОљОцОюОЎОДОдОЎОЋОф, ОдОеОЎОџ ОюОбОЉОЋОе ОљОю 'ОћОњОЊОеОЋОф' &gt; 'ОЌОаОЋОф Google Play' &gt; 'ОаОЎОћОЋОю ОћОбОЊОцОЋОф Android' &gt;'ОљОцОюОЎОДОдОЎОЋОф' ОљОЋ 'ОъОаОћОю ОљОцОюОЎОДОдОЎОЋОф'. ОюОљОЌОе ОъОЏОЪ ОдОеОЎОџ ОюОћОДОЎОЕ ОбОю ОћОљОцОюОЎОДОдОЎОћ ОЕОеОЋОдОЎОЮ ОюОћОАОЎОе (ОЎОЎОфОЏОЪ ОЕОЎОћОЎОћ ОдОЋОеОџ ОюОћОЌОюОЎОД ОЎОъОЎОаОћ ОљОЋ ОЕОъОљОюОћ ОЏОЊОЎ ОюОъОдОЋОљ ОљОф ОћОљОцОюОЎОДОдОЎОћ). ОюОАОЎОЋОЮ, ОЎОЕ ОюОћОДОЎОЕ ОбОю 'ОћОАОеОф ОћОфОДОаОћ' ОљОЋ 'ОћОЕОЉОфОћ'.</translation>
<translation id="3747603683749989726">ОюОћОцОбОЎОю ОљОф ОћОљОЉОўОЌОћ ОћОъОЕОЋОцОеОф?</translation>
<translation id="3748706263662799310">ОЊОЎОЋОЋОЌ ОбОю ОЉОљОњ</translation>
<translation id="3750562496035670393">РђЈОъОбОеОЏОф Chrome ОЕОъОеОћ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ ОЉОъОЏОЕОЎОе ОћОќОћ, ОљОЉОю ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЕОъОЋОе ОљОЋОфОћ ОЉОЌОЕОЉОЋОЪ Google ОЉОъОДОЋОЮ. ОюОљОЌОе ОъОЏОЪ, ОЏОю ОћОАОЎОАОъОљОЋОф ОЕОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ ОЎОћОЎОЋ ОќОъОЎОаОЋОф ОњОЮ ОЏОЕОЎОћОЎОћ ОюОџ ОЌОЎОЉОЋОе ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="3752253558646317685">ОЏОЊОЎ ОюОЕОъОЋОе ОљОф ОўОЉОЎОбОф ОћОљОдОЉОб, ОбОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОюОћОеОЎОЮ ОЋОюОћОЌОќОЎОе ОљОф ОћОљОдОЉОб ОЏОъОћ ОцОбОъОЎОЮ</translation>
<translation id="3752582316358263300">ОљОЎОЕОЋОе...</translation>
<translation id="3753033997400164841">ОъОљОЌОАОаОЎОЮ ОАОЎОАОъОћ ОцОбОЮ ОљОЌОф. ОъОЕОфОъОЕОЎОЮ ОЉОћ ОЉОЏОю ОъОДОЋОЮ.</translation>
<translation id="3755411799582650620">Оћ-<ph name="PHONE_NAME" /> ОЎОЏОЋОю ОЏОбОф ОюОЉОўОю ОњОЮ ОљОф ОћОаОбОЎОюОћ ОЕОю <ph name="DEVICE_TYPE" /> ОќОћ.</translation>
<translation id="375636864092143889">ОћОљОфОе ОъОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="3756485814916578707">ОћОбОЉОеОф ОћОъОАОџ ОъОфОЉОдОбОф</translation>
<translation id="3756578970075173856">ОћОњОЊОеОф ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="3756795331760037744">РђЈОћОеОЕОљОћ Ою-Google Assistant ОюОћОЕОфОъОЕ ОЉОъОЎОЊОб ОЕОъОЋОцОЎОб ОЉОъОАОџ ОЏОЊОЎ ОюОбОќОЋОе Ою<ph name="SUPERVISED_USER_NAME" /></translation>
<translation id="3757733214359997190">ОюОљ ОаОъОдОљОЋ ОљОфОеОЎОЮ</translation>
<translation id="375841316537350618">РђЈОъОЋОеОЎОЊ ОАОДОеОЎОцОў ОЕОю ОЕОеОф proxy...</translation>
<translation id="3758842566811519622">РђЈОДОЋОЉОдОЎ Cookie ОћОЋОњОЊОеОЋ</translation>
<translation id="3759933321830434300">ОЌОАОЎОъОф ОЌОюОДОЎОЮ ОЕОю ОЊОцОЎ ОљОЎОаОўОеОаОў</translation>
<translation id="3760460896538743390">ОЉОЊОЎОДОф ОЊОБ Оћ&amp;ОеОДОб</translation>
<translation id="37613671848467444">ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ</translation>
<translation id="3761556954875533505">ОћОљОЮ ОюОљОцОЕОе ОюОљОфОе ОюОбОеОЋОџ ОДОЉОдОЎОЮ?</translation>
<translation id="3763549179847864476">ОюОЌОдОЪ 'ОћОДОЋОЊОЮ' ОЉОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф</translation>
<translation id="3764314093345384080">ОъОЎОЊОб ОъОцОЋОеОў ОбОю ОћОњОеОАОћ</translation>
<translation id="3764583730281406327">{NUM_DEVICES,plural, =1{РђЈОфОДОЕОЋОеОф ОбОЮ ОъОЏОЕОЎОе USB ОљОЌОЊ}two{РђЈОфОДОЕОЋОеОф ОбОЮ # ОъОЏОЕОЎОеОЎ USB}many{РђЈОфОДОЕОЋОеОф ОбОЮ # ОъОЏОЕОЎОеОЎ USB}other{РђЈОфОДОЕОЋОеОф ОбОЮ # ОъОЏОЕОЎОеОЎ USB}}</translation>
<translation id="3764753550716962406">РђЈОюОљОцОЕОе Ою-Google ОюОћОЕОфОъОЕ ОЉОбОњОюОф ОћОДОаОЎОЋОф ОЕОюОџ ОЏОЊОЎ ОюОъОдОЋОљ ОћОаОЌОЋОф ОќОъОЎОаОЋОф?</translation>
<translation id="3764974059056958214">{COUNT,plural, =1{ОћОъОбОеОЏОф ОЕОЋОюОЌОф <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}two{ОћОъОбОеОЏОф ОЕОЋОюОЌОф <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}many{ОћОъОбОеОЏОф ОЕОЋОюОЌОф <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}other{ОћОъОбОеОЏОф ОЕОЋОюОЌОф <ph name="ATTACHMENTS" /> ОљОю <ph name="DEVICE_NAME" />}}</translation>
<translation id="3765246971671567135">ОюОљ ОаОЎОфОЪ ОюОДОеОЋОљ ОъОЊОЎОаОЎОЋОф ОЕОю ОъОдОЉ ОћОЊОњОъОћ ОюОљ ОъОДОЋОЋОЪ.</translation>
<translation id="3766811143887729231"><ph name="REFRESH_RATE" /> ОћОеОЦ</translation>
<translation id="377050016711188788">ОњОюОЎОЊОћ</translation>
<translation id="3771290962915251154">ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф ОъОљОЌОе ОЕОЉОДОеОф ОћОћОЋОеОЎОЮ ОъОЋОцОбОюОф</translation>
<translation id="3771294271822695279">ОДОЋОЉОдОЎ ОЋОЎОЊОљОЋ</translation>
<translation id="3771851622616482156">ОћОъОбОеОЏОф ОфОЋОдОЎОљ ОљОЋОфОџ ОъОћОљОфОе ОћОќОћ, ОњОЮ ОЉОЏОеОўОЎОАОЎОЋОф ОћОцОфОЋОЌОЋОф</translation>
<translation id="3772046291955677288">РђЈОДОеОљОфОЎ ОљОф <ph name="BEGIN_LINK1" />ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОЕОю GoogleРђј<ph name="END_LINK1" />РђЈ ОЋОљОф <ph name="BEGIN_LINK2" />ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОћОаОЋОАОцОЎОЮ ОЕОю Chrome ОЋОЕОю ChromeOS<ph name="END_LINK2" /> ОЋОљОаОЎ ОъОљОЕОе/Оф ОљОЋОфОЮ.</translation>
<translation id="3774166835015494435">ОћОфОеОљОЋОф ОЋОфОъОЋОаОЋОф ОъОћОќОъОЪ ОћОљОЌОеОЋОЪ</translation>
<translation id="3775432569830822555">РђЈОљОЎОЕОЋОе ОЕОеОф SSL</translation>
<translation id="3775705724665058594">ОЕОюОЎОЌОћ ОљОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="3776508619697147021">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОћОЋОеОЎОЊ ОъОАОцОе ОДОЉОдОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="3776796446459804932">РђЈОћОфОЋОАОБ ОъОцОе ОљОф ОћОъОЊОЎОаОЎОЋОф ОЉОЌОаОЋОф ОћОљОЎОаОўОеОаОў ОЕОю Chrome.</translation>
<translation id="3777483481409781352">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОцОбОЎОю ОљОф ОћОўОюОцОЋОЪ ОћОАОюОЋОюОеОЎ</translation>
<translation id="3777806571986431400">ОћОфОЋОАОБ ОћОЋОцОбОю</translation>
<translation id="3778152852029592020">ОћОћОЋОеОЊОћ ОЉОЋОўОюОћ.</translation>
<translation id="3778208826288864398">ОъОцОфОЌ ОћОљОЉОўОЌОћ ОаОбОЋОю ОЏОЎ ОћОќОаОф ОДОЋОЊ ОљОЎОъОЋОф ОЕОњОЋОЎ ОЎОЋОфОе ОъОЊОЎ ОцОбОъОЎОЮ. ОдОеОЎОџ ОюОљОцОА ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ.</translation>
<translation id="3778369586810509692">ОћОДОЋОЉОЦ ОћОќОћ ОЎОЎОЕОъОе ОЉОъОЏОЕОЎОе ОЋОЏОЋОюОЮ ОЎОЋОЏОюОЋ ОюОеОљОЋОф ОљОЋОфОЋ.</translation>
<translation id="3778740492972734840">&amp;ОЏОюОЎОЮ ОбОЉОЋОе ОъОцОфОЌОЎОЮ</translation>
<translation id="3778868487658107119">РђЈОљОцОЕОе ОюОЕОљОЋОю ОљОЋОфОЋ ОЕОљОюОЋОф ОЋОюОЋОъОе ОюОЋ ОюОЉОдОб ОцОбОЋОюОЋОф. ОћОбОЋОќОе ОћОцОеОўОЎ ОЕОю Google ОъОЋОЏОЪ ОфОъОЎОЊ ОюОАОЎОЎОб ОюОџ.</translation>
<translation id="3781742599892759500">РђЈОњОЎОЕОћ ОЕОю Linux ОюОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="378312418865624974">ОДОеОЎОљОћ ОЕОю ОъОќОћОћ ОЎОЎОЌОЋОЊОЎ ОбОЉОЋОе ОъОЌОЕОЉ ОќОћ</translation>
<translation id="3784472333786002075">РђЈОДОЋОЉОдОЎ cookie ОћОЮ ОДОЉОдОЎОЮ ОЕОаОЋОдОеОЎОЮ ОбОю ОЎОЊОЎ ОљОфОеОЎОЮ. ОЎОЕ ОЕОаОЎ ОАОЋОњОЎОЮ ОЕОю ОДОЋОЉОдОЎ cookie: ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОеОљОЕОЋОЪ ОаОЋОдОеОЎОЮ ОбОю ОЎОЊОЎ ОћОљОфОе ОЕОаОЏОаОАОф ОљОюОЎОЋ. ОћОљОфОе ОъОЋОцОЎОб ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф. ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОаОЋОдОеОЎОЮ ОбОю-ОЎОЊОЎ ОљОфОеОЎОЮ ОљОЌОеОЎОЮ. ОћОљОфОеОЎОЮ ОћОљОюОћ ОћОЮ ОћОЉОбОюОЎОЮ ОЕОю ОЌОюОД ОъОћОфОЋОЏОЪ ОЉОЊОБ ОћОљОЎОаОўОеОаОў ОЕОаОЏОаОАОф ОљОюОЎОЋ, ОЏОъОЋ ОъОЋОЊОбОЋОф ОљОЋ ОфОъОЋОаОЋОф.</translation>
<translation id="3785308913036335955">ОћОдОњОф ОДОЎОдОЋОе ОЊОеОџ ОљОю ОЎОЎОЕОЋОъОЎОЮ</translation>
<translation id="3785727820640310185">ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОюОљОфОе ОћОќОћ</translation>
<translation id="3788301286821743879">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОцОбОЎОю ОљОф ОљОцОюОЎОДОдОЎОЎОф ОћОДОЎОЋОАОД.</translation>
<translation id="3788331399335602504">ОћОДОЉОдОЎОЮ ОћОљОюОћ</translation>
<translation id="3788401245189148511">ОъОбОЋОаОЎОЎОаОЎОЮ:</translation>
<translation id="3789841737615482174">ОћОфОДОаОћ</translation>
<translation id="3790417903123637354">ОъОЕОћОЋ ОћОЕОфОЉОЕ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОЉОћОъОЕОџ</translation>
<translation id="379082410132524484">ОфОЋОДОБ ОћОЏОеОўОЎОА ОЕОюОџ ОцОњ</translation>
<translation id="3793588272211751505">{NUM_DAYS,plural, =1{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ ОЎОЋОЮ ОљОЌОЊ}two{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ ОЎОЋОъОЎОЎОЮ ({NUM_DAYS})}many{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ {NUM_DAYS} ОЎОъОЎОЮ}other{РђЈChrome ОюОљ ОъОдОљ ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЕОюОџ Рђб ОћОЉОЊОЎОДОћ ОЉОЋОдОбОћ ОюОцОаОЎ {NUM_DAYS} ОЎОъОЎОЮ}}</translation>
<translation id="379500251094592809">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ', ОЎОЕ ОюОЋОЋОЊОљ ОЕОЕОаОЎ ОћОъОЏОЕОЎОеОЎОЮ ОљОЎОаОЮ ОаОбОЋОюОЎОЮ, ОЕОћОЮ ОДОеОЋОЉОЎОЮ ОќОћ ОюОќОћ ОЋОЕОЉОЕОаОЎОћОЮ ОъОЋОцОбОю Bluetooth. ОљОЮ ОћОЕОЎОфОЋОБ ОаОбОЕОћ ОбОЮ Chromebook ОЕОљОЎОаОЋ ОеОЕОЋОЮ ОЉОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ, ОЎОЕ ОюОЋОЋОЊОљ ОЕОћОЋОцОбОюОЋ ОћОеОЕОљОЋОф ОћОњОЎОЕОћ ОЉОДОеОЉОф ОъОДОЋОЮ (ОЎОЕ ОюОцОфОЋОЌ ОљОф ОљОќОЋОе ОћОАОўОўОЋОА ОЉОљОъОдОбОЋОф ОЉОЌОЎОеОћ ОЉОЕОбОћ ОЋОљОќ ОюОћОцОбОЎОю ОљОф ОћОеОЕОљОЋОф ОћОњОЎОЕОћ ОЉОДОеОЉОф ОъОДОЋОЮ). <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="379509625511193653">ОЏОЉОЋОЎ</translation>
<translation id="3796648294839530037">ОеОЕОфОЋОф ОъОЋОбОЊОцОЋОф:</translation>
<translation id="3797739167230984533"><ph name="BEGIN_LINK" /><ph name="DEVICE_TYPE" /> ОќОћ ОъОаОЋОћОю<ph name="END_LINK" /> ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="3797900183766075808">&amp;ОЌОЎОцОЋОЕ ОЉ-<ph name="SEARCH_ENGINE" /> ОљОЌОе '<ph name="SEARCH_TERMS" />'</translation>
<translation id="3798449238516105146">ОњОеОАОћ</translation>
<translation id="379850776451304458">ОъОдОЉ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="3799128412641261490">ОћОњОЊОеОЋОф ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ</translation>
<translation id="3800806661949714323">ОћОдОњОф ОћОЏОЋОю (ОъОЋОъОюОЦ)</translation>
<translation id="3800828618615365228">РђЈОфОаОљОЎОЮ ОаОЋОАОцОЎОЮ ОЕОю Google Chrome ОЋ-ChromeOS</translation>
<translation id="3802486193901166966">ОљОЎОЪ ОдОЋОеОџ ОЉОћОеОЕОљОЋОф ОъОЎОЋОЌОЊОЋОф ОљОЋ ОћОеОЕОљОЋОф ОњОЎОЕОћ ОаОЋОАОцОЋОф ОюОљОфОеОЎОЮ ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОћОќОћ</translation>
<translation id="380329542618494757">ОЕОЮ</translation>
<translation id="3803345858388753269">ОљОЎОЏОЋОф ОћОЋОЋОЎОЊОљОЋ</translation>
<translation id="380408572480438692">РђЈОћОцОбОюОф ОћОљОцОЕОеОЋОф ОюОљОЎОАОЋОБ ОаОфОЋОаОЎ ОЉОЎОдОЋОбОЎОЮ ОфОАОЎОЎОб Ою-Google ОюОЕОцОе ОљОф ОћОъОбОеОЏОф ОбОЮ ОћОќОъОЪ. ОћОаОфОЋОаОЎОЮ ОаОЕОюОЌОЎОЮ ОеОД ОюОљОЌОе ОЕОъОњОЎОЕОЎОЮ ОЊОЋОЌ ОъОЕОЋОЉ (Alt-Shift-I) ОЋОЏОЋОюОюОЎОЮ ОљОф ОаОфОЋОаОЎ ОћОЉОЎОдОЋОбОЎОЮ. ОаОЎОфОЪ ОюОЌОќОЋОе ОюОъОАОџ ОќОћ ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОљОЎОАОЋОБ ОћОаОфОЋОаОЎОЮ ОЉОЏОю ОбОф.</translation>
<translation id="3807249107536149332">ОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉ-<ph name="EXTENSION_NAME" /> (ОъОќОћОћ ОфОЋОАОБ "<ph name="EXTENSION_ID" />") ОЉОъОАОџ ОћОфОЌОЉОеОЋОф.</translation>
<translation id="3807747707162121253">&amp;ОЉОЎОўОЋОю</translation>
<translation id="3808443763115411087">РђЈОцОЎОфОЋОЌ ОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЉ-Crostini</translation>
<translation id="38089336910894858">РђЈОћОдОњОф ОљОќОћОеОћ ОюОцОаОЎ ОЎОдОЎОљОћ ОЉОљОъОдОбОЋОф РђјРїўQ</translation>
<translation id="3809272675881623365">ОљОеОаОЉ</translation>
<translation id="3809280248639369696">ОъОе ОЎОеОЌ</translation>
<translation id="3810593934879994994">Ою-<ph name="ORIGIN" /> ОЎОЕ ОћОеОЕОљОћ ОюОћОдОЎОњ ОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЋОф ОћОЉОљОЋОф</translation>
<translation id="3810914450553844415">РђЈОъОаОћОю ОћОъОбОеОЏОф ОюОљ ОъОљОцОЕОе ОюОџ ОюОћОЋОАОЎОБ ОЌОЕОЉОЋОаОЋОф Google.</translation>
<translation id="3810973564298564668">ОаОЎОћОЋОю</translation>
<translation id="381202950560906753">ОюОћОъОЕОџ ОћОЋОАОцОћ</translation>
<translation id="3812525830114410218">ОљОЎОЕОЋОе ОцОњОЋОЮ</translation>
<translation id="3813296892522778813">РђЈОљОЮ ОюОљ ОъОдОљОф ОљОф ОъОћ ОЕОЌОЎОцОЕОф, ОЎОЕ ОюОбОЉОЋОе ОљОю <ph name="BEGIN_LINK_CHROMIUM" />ОъОеОЏОќ ОћОбОќОеОћ ОЕОю Google Chrome<ph name="END_LINK_CHROMIUM" /></translation>
<translation id="3813358687923336574">ОћОЕОцОћ ОЕОљОюОЎОћ ОЎОфОЋОеОњОъОЋ ОЊОцОЎОЮ ОЋОфОЕОЋОЉОЋОф ОъОћОЎОеОЋОф</translation>
<translation id="3814529970604306954">ОЌОЕОЉОЋОЪ ОЉОЎОф ОАОцОеОЎ</translation>
<translation id="3816118180265633665">РђЈОдОЉОбОЎ Chrome</translation>
<translation id="3817524650114746564">РђЈОцОфОЎОЌОф ОћОњОЊОеОЋОф ОЕОеОф Оћ-proxy ОЕОю ОћОъОЌОЕОЉ</translation>
<translation id="3819257035322786455">ОњОЎОЉОЋОЎ</translation>
<translation id="3819261658055281761">РђЈОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОљОЌОАОЪ ОљОф ОљОАОЎОъОЋОЪ ОћОњОЎОЕОћ ОюОўОЋОЋОЌ ОљОеОЋОџ ОљОю ОъОъОЕОД Оћ-API ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="3819800052061700452">&amp;ОъОАОџ ОъОюОљ</translation>
<translation id="3820638253182943944">{MUTED_NOTIFICATIONS_COUNT,plural, =1{ОћОдОњОћ}two{ОћОдОњОф ОћОЏОЋОю}many{ОћОдОњОф ОћОЏОЋОю}other{ОћОдОњОф ОћОЏОЋОю}}</translation>
<translation id="3820749202859700794">РђЈОбОДОЋОъОћ ОљОюОЎОцОўОЎОф SECG ОъОАОЋОњ secp521r1 (ОъОЋОЏОеОф ОњОЮ ОЉОЕОЮ NIST P-521)</translation>
<translation id="3821074617718452587">РђЈОћОфОеОљОЋОф ОЕОю Phone Hub</translation>
<translation id="3821372858277557370">{NUM_EXTENSIONS,plural, =1{ОфОЋОАОБ ОљОЋОЕОе}two{# ОфОЋОАОцОЎОЮ ОљОЋОЕОеОЋ}many{# ОфОЋОАОцОЎОЮ ОљОЋОЕОеОЋ}other{# ОфОЋОАОцОЎОЮ ОљОЋОЕОеОЋ}}</translation>
<translation id="3823310065043511710">РђЈОъОЋОъОюОЦ ОЕОЕОўОЌ ОћОљОЌОАОЋОЪ ОћОцОаОЋОЎ ОЎОћОЎОћ <ph name="INSTALL_SIZE" /> ОюОцОЌОЋОф ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-Linux.</translation>
<translation id="3824621460022590830">ОљОАОЎОъОЋОЪ ОћОеОЕОъОф ОћОъОЏОЕОЎОе ОюОљ ОЌОЋОДОЎ. ОЎОЕ ОюОцОаОЋОф ОюОЉОбОюОЎОЮ ОљОЋ ОюОъОаОћОю ОЕОю ОћОъОЏОЕОЎОе. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="3825041664272812989">{FILE_TYPE_COUNT,plural, =1{ОљОаОЎ ОеОЋОдОћ ОЕОћОЉОЌОЎОеОћ ОЕОюОЎ ОбОЉОЋОе ОАОЋОњ ОћОДОЋОЉОЦ ОћОќОћ ОфОЎОЕОъОе: <ph name="FILE_TYPES" />}two{ОљОаОЎ ОеОЋОдОћ ОЕОћОЉОЌОЎОеОћ ОЕОюОЎ ОбОЉОЋОе ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОљОюОћ ОфОЎОЕОъОе: <ph name="FILE_TYPES" />}many{ОљОаОЎ ОеОЋОдОћ ОЕОћОЉОЌОЎОеОћ ОЕОюОЎ ОбОЉОЋОе ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОљОюОћ ОфОЎОЕОъОе: <ph name="FILE_TYPES" />}other{ОљОаОЎ ОеОЋОдОћ ОЕОћОЉОЌОЎОеОћ ОЕОюОЎ ОбОЉОЋОе ОАОЋОњОЎ ОћОДОЉОдОЎОЮ ОћОљОюОћ ОфОЎОЕОъОе: <ph name="FILE_TYPES" />}}</translation>
<translation id="3826071569074535339">ОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉОЌОЎОЎОЕОаОЎ ОфОаОЋОбОћ</translation>
<translation id="3826440694796503677">РђЈОъОаОћОю ОћОъОбОеОЏОф ОћОЕОЉОЎОф ОљОф ОћОљОцОЕОеОЋОф ОюОћОЋОАОЎОБ ОЌОЕОЉОЋОаОЋОф Google</translation>
<translation id="3827774300009121996">&amp;ОъОАОџ ОъОюОљ</translation>
<translation id="3828029223314399057">ОЌОЎОцОЋОЕ ОАОЎОъОаОЎОЋОф</translation>
<translation id="3828953470056652895">РђЈОДОеОљОфОЎ ОљОф <ph name="BEGIN_LINK1" />ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОЕОю Google<ph name="END_LINK1" />, <ph name="BEGIN_LINK2" />ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОћОаОЋОАОцОЎОЮ ОЕОю Chrome ОЋОЕОю ChromeOS<ph name="END_LINK2" /> ОЋ<ph name="BEGIN_LINK3" />ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОЕОю Google Play<ph name="END_LINK3" /> ОЋОљОаОЎ ОъОљОЕОе/Оф ОљОЋОфОЮ.</translation>
<translation id="3829765597456725595">РђЈОћОфОДОаОф ОеОЕОф ОюОЕОЎОфОЋОБ ОДОЉОдОЎОЮ ОЉ-SMB</translation>
<translation id="3830654885961023588">{NUM_EXTENSIONS,plural, =1{ОъОаОћОю ОћОъОбОеОЏОф ОћОцОбОЎОю ОъОЌОЊОЕ ОфОЋОАОБ ОљОЌОЊ ОЕОбОЕОЋОЎ ОюОћОЎОЋОф ОъОќОЎОД}two{ОъОаОћОю ОћОъОбОеОЏОф ОћОцОбОЎОю ОъОЌОЊОЕ {NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ}many{ОъОаОћОю ОћОъОбОеОЏОф ОћОцОбОЎОю ОъОЌОЊОЕ {NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ}other{ОъОаОћОю ОћОъОбОеОЏОф ОћОцОбОЎОю ОъОЌОЊОЕ {NUM_EXTENSIONS} ОфОЋОАОцОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОЎОЋОф ОъОќОЎОДОЎОЮ}}</translation>
<translation id="3831436149286513437">РђЈОћОдОбОЋОф ОюОЌОЎОцОЋОЕОЎОЮ ОЕОю Google Drive</translation>
<translation id="3834728400518755610">РђЈОћОЕОЎОаОЋОЎ ОЉОћОњОЊОеОф ОћОъОЎОДОеОЋОцОЋОЪ ОъОЌОЎОЎОЉ ОљОф ОћОЏОЎОЉОЋОЎ ОЕОю Linux. ОЎОЕ ОюОЏОЉОЋОф ОљОф Linux ОЏОЊОЎ ОюОћОъОЕОЎОџ.</translation>
<translation id="3834775135533257713">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОЋОАОЎОБ ОљОф ОћОЎОЎОЕОЋОЮ "<ph name="TO_INSTALL_APP_NAME" />" ОъОцОаОЎ ОЕОћОЋОљ ОъОфОаОњОЕ ОбОЮ "<ph name="INSTALLED_APP_NAME" />".</translation>
<translation id="3835904559946595746">РђЈОюОљ ОћОЎОЎОфОћ ОљОцОЕОеОЋОф ОюОЕОЌОќОе ОљОф ОћОњОЎОЉОЋОЎ ОЕОю Linux</translation>
<translation id="3836093801854521982">РђЈОћОљОцОюОЎОДОдОЎОћ '<ph name="EXTENSION_NAME" />' ОћОЋОфОДОаОћ ОбОю ОЎОЊОЎ ОћОљОЊОъОЎОЪ ОЕОюОџ, ОљОЉОю ОљОЎОЪ ОЎОЋОфОе ОфОъОЎОЏОћ ОЉОљОцОюОЎОДОдОЎОЎОф Chrome ОћОќОЋ. ОЎОЕ ОюОцОаОЋОф ОюОљОЊОъОЎОЪ ОЏОЊОЎ ОюОћОАОЎОе ОљОЋОфОћ.</translation>
<translation id="383669374481694771">РђЈОќОћОЋ ОъОЎОЊОб ОЏОюОюОЎ ОбОю ОћОъОЏОЕОЎОе ОћОќОћ ОЋОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОЋ (ОюОъОЕОю ОеОъОф ОћОАОЋОюОюОћ, ОцОбОЎОюОЋОф ОћОъОбОеОЏОф, ОћОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЕОњОЎОљОЋОф). ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЕОъОЕОЋ ОЏОЊОЎ ОюОЕОцОе ОљОф Android. ОЌОюОД ОъОћОъОЎОЊОб ОћОаОдОЉОе ОЎОбОќОЋОе ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google, ОЋОЏОЪ ОЎОбОќОЋОе ОюОЕОЋОфОцОЎОЮ ОЕОю Google (ОюОъОЕОю ОюОъОцОфОЌОЎОЮ ОЕОю Android) ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЋОћОъОЋОдОеОЎОЮ ОЕОюОћОЮ.</translation>
<translation id="3838085852053358637">ОўОбОЎОаОф ОћОфОЋОАОБ ОаОЏОЕОюОћ</translation>
<translation id="3838486795898716504"><ph name="PAGE_TITLE" /> ОаОЋОАОцОЎОЮ</translation>
<translation id="383891835335927981">ОЉОљОБ ОљОфОе ОюОљ ОћОЕОфОаОћ ОћОъОеОЌОД ОъОћОфОдОЋОњОћ</translation>
<translation id="3839509547554145593">ОћОцОбОюОћ ОЕОю ОћОљОдОф ОњОюОЎОюОћ ОЉОбОЏОЉОе</translation>
<translation id="3839516600093027468">ОЎОЕ ОюОъОаОЋОб ОфОъОЎОЊ Оъ-<ph name="HOST" /> ОюОњОЕОф ОљОю ОћОюОЋОЌ</translation>
<translation id="3841964634449506551">ОћОАОЎОАОъОћ ОюОљ ОЌОЋОДОЎОф</translation>
<translation id="3842552989725514455">РђЈОњОЋОцОЪ Serif</translation>
<translation id="3843464315703645664">ОЉОеОЕОЎОъОф ОћОћОЎОфОеОЎОЮ ОћОцОаОЎОъОЎОф</translation>
<translation id="3844888638014364087">ОћОљОъОЋОњ'ОЎ ОаОЋОАОБ</translation>
<translation id="3846116211488856547">РђЈОљОцОЕОе ОюОћОЋОеОЎОЊ ОЏОюОЎОЮ ОюОцОЎОфОЋОЌ ОљОфОеОЎОЮ, ОљОцОюОЎОДОдОЎОЋОф Android ОЋОбОЋОЊ. ОћОфОДОаОф Linux ОфОЋОеОЎОЊ ОаОфОЋОаОЎОЮ ОЉОаОцОЌ ОЕОю <ph name="DOWNLOAD_SIZE" />.</translation>
<translation id="3847319713229060696">ОАОЎОЋОб ОюОЕОЎОцОЋОе ОћОљОЉОўОЌОћ ОЉОљОЎОаОўОеОаОў ОюОўОЋОЉОф ОЏОЋОюОЮ</translation>
<translation id="3848547754896969219">ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ</translation>
<translation id="385051799172605136">ОЌОќОеОћ</translation>
<translation id="3851428669031642514">ОўОбОЎОаОћ ОЕОю ОАОДОеОЎОцОўОЎОЮ ОюОљ ОЉОўОЋОЌОЎОЮ</translation>
<translation id="3854599674806204102">ОдОеОЎОџ ОюОЉОЌОЋОе ОљОцОЕОеОЋОф</translation>
<translation id="3854967233147778866">ОћОдОбОћ ОюОфОеОњОЋОЮ ОљОфОеОЎОЮ ОЉОЕОцОЋОф ОљОЌОеОЋОф</translation>
<translation id="3854976556788175030">ОъОњОЕ ОћОцОюОў ОъОюОљ</translation>
<translation id="3855441664322950881">ОљОеОЎОќОф ОфОЋОАОБ</translation>
<translation id="3855676282923585394">ОЎОЎОЉОЋОљ ОАОЎОъОаОЎОЋОф ОЋОћОњОЊОеОЋОф...</translation>
<translation id="3856096718352044181">ОЎОЕ ОюОљОъОф ОЕОћОАОцОД ОћОќОћ ОЌОЋОДОЎ ОљОЋ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="3856800405688283469">ОЉОЌОЎОеОф ОљОќОЋОе ОќОъОЪ</translation>
<translation id="3857807444929313943">ОЎОЕ ОюОћОеОЎОЮ ОЋОюОњОбОф ОЉОЌОЎОЎОЕОЪ ОЕОЋОЉ</translation>
<translation id="3858860766373142691">ОЕОЮ</translation>
<translation id="3861638017150647085">ОЕОЮ ОћОъОЕОфОъОЕ "<ph name="USERNAME" />" ОюОљ ОќОъОЎОЪ</translation>
<translation id="3861977424605124250">ОћОдОњОћ ОЉОбОф ОћОћОцОбОюОћ</translation>
<translation id="386239283124269513">&amp;ОЕОЌОќОЋОе ОћОДОЉОЋОдОћ</translation>
<translation id="3865414814144988605">ОеОќОЋОюОЋОдОЎОћ</translation>
<translation id="3866249974567520381">ОфОЎОљОЋОе</translation>
<translation id="3867134342671430205">ОљОцОЕОе ОюОњОеОЋОе ОљОф ОћОфОдОЋОњОћ ОљОЋ ОюОћОЕОфОъОЕ ОЉОъОДОЕОЎ ОћОЌОдОЎОЮ ОЏОЊОЎ ОюОћОќОЎОќ ОљОЋОфОћ</translation>
<translation id="3867944738977021751">ОЕОЊОЋОф ОљОЎОЕОЋОе </translation>
<translation id="3869917919960562512">ОљОЎОаОЊОДОА ОЕОњОЋОЎ.</translation>
<translation id="3870931306085184145">ОюОљ ОаОЕОъОеОЋ ОАОЎОАОъОљОЋОф ОЉОЕОЉОЎОю <ph name="DOMAIN" /></translation>
<translation id="3871350334636688135">ОЏОбОЉОЋОе 24 ОЕОбОЋОф, ОъОаОћОю ОћОъОбОеОЏОф ОЎОЉОдОб ОбОЊОЏОЋОЪ ОЌОЊ-ОцОбОъОЎ ОЕОЎОъОЌОД ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОДОЋОъОЎОЎОЮ ОЏОЕОћОъОЏОЕОЎОе ОЎОЋОцОбОю ОъОЌОЊОЕ. ОЌОЕОЋОЉ ОюОЕОъОЋОе ОЉОљОЌОАОЋОЪ ОЉОбОаОЪ ОфОЋОџ 24 ОЕОбОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОДОЋОъОЎОЎОЮ ОћОаОЌОЋОдОЎОЮ ОюОџ.</translation>
<translation id="3872220884670338524">ОбОЋОЊ ОцОбОЋОюОЋОф, ОЌОЕОЉОЋОЪ ОЕОъОЋОе ОЕОю <ph name="USERNAME" /> ОЉ-<ph name="DOMAIN" /></translation>
<translation id="3872991219937722530">ОљОЮ ОюОљ ОъОцОаОЎОЮ ОЕОўОЌ ОљОЌОАОЋОЪ, ОћОъОЏОЕОЎОе ОЎОцОАОЎОД ОюОћОњОЎОЉ.</translation>
<translation id="3873315167136380065">ОюОћОцОбОюОф ОћОљОцОЕОеОЋОф ОћОќОљОф, ОдОеОЎОџ <ph name="BEGIN_LINK" />ОюОљОцОА ОљОф ОћОАОаОЏОеОЋОЪ<ph name="END_LINK" /> ОЏОЊОЎ ОюОћОАОЎОе ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЕОю ОћОАОаОЏОеОЋОЪ</translation>
<translation id="3873423927483480833">ОћОдОњОф ОДОЋОЊОЎ ОљОЎОъОЋОф</translation>
<translation id="3873915545594852654">РђЈОћОфОеОЌОЕОћ ОЉОбОЎОћ ОћОДОЕОЋОеОћ Ою-ARC++Рђј.</translation>
<translation id="3874164307099183178">РђЈОћОцОбОюОф Google Assistant</translation>
<translation id="3875783148670536197">ОљОЎОџ ОбОЋОЕОЎОЮ ОќОљОф?</translation>
<translation id="3875815154304214043">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОћОЋОњОЊОеОћ ОЏОџ ОЕОфОЎОцОфОЌ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЉОЊОцОЊОцОЪ. ОњОЮ ОћОДОЎОЕОЋОеОЎОЮ ОћОаОфОъОЏОЎОЮ ОЎОЎОцОфОЌОЋ ОЉОЊОцОЊОцОЪ. <ph name="BEGIN_LINK_LEARN_MORE" />ОюОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK_LEARN_MORE" /></translation>
<translation id="3877075909000773256">ОћОњОЊОеОЋОф ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ ОюОъОЏОЕОЎОе ОЕОю <ph name="USER_NAME" />. ОћОЕОЎОфОЋОБ ОЎОфОЉОдОб ОЉОЕОЮ <ph name="USER_EMAIL" />.</translation>
<translation id="3879748587602334249">ОъОаОћОю ОћОћОЋОеОЊОЋОф</translation>
<translation id="3882165008614329320">ОАОеОўОЋОЪ ОДОЎОЎОЮ ОъОъОдОюОъОћ ОљОЋ ОъОДОЋОЉОЦ</translation>
<translation id="3883306461188700142">РђЈОЕОЎОъОЋОЕ ОЉОћОДОюОЊОћ ОДОЋОюОЎОф. ОюОЋОЌОдОЎОЮ ОбОю ОЌОЎОцОЋОЕ + D, ОЋОъОфОЌОЎОюОЎОЮ ОюОЊОЉОе.</translation>
<translation id="3883482240657453056">ОДОЉОюОф ОћОаОЌОЋОф ОбОю ОћОъОЋОдОеОЎОЮ ОЕОю <ph name="MERCHANT_NAME_1" /> ОЋ-<ph name="MERCHANT_NAME_2" /></translation>
<translation id="3884152383786131369">ОфОЋОЏОЪ ОљОЎОаОўОеОаОў ОЕОќОъОЎОЪ ОЉОъОАОцОе ОЕОцОЋОф ОЎОЋОдОњ ОЉОЕОцОћ ОћОаОфОъОЏОф ОћОеОљОЕОЋОаОћ ОЉОеОЕОЎОъОћ ОћОќОЋ. ОћОћОбОЊОцОЋОф ОћОљОюОћ ОъОАОЋОаОЏОеОаОЋОф ОбОЮ ОћОњОЊОеОЋОф ОћОЊОцОЊОцОЪ. <ph name="BEGIN_LINK_LEARN_MORE" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK_LEARN_MORE" /></translation>
<translation id="3885112598747515383">ОћОбОЊОЏОЋОаОЎОЮ ОъОаОЋОћОюОЎОЮ ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="3886446263141354045">ОћОЉОДОЕОћ ОЕОюОџ ОюОњОЕОф ОюОљОфОе ОћОќОћ ОаОЕОюОЌОћ ОљОю <ph name="NAME" /></translation>
<translation id="3887022758415973389">ОћОдОњОћ ОЕОю ОеОЕОЎОъОф ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="3888053818972567950">ОЌОЎОЉОЋОе ОљОю <ph name="WEB_DRIVE" /></translation>
<translation id="3888550877729210209">ОЏОфОЎОЉОф ОћОбОеОЋОф ОЉОбОќОеОф <ph name="LOCK_SCREEN_APP_NAME" /></translation>
<translation id="3888586133700543064">РђЈОћОъОЎОЊОб ОћОќОћ ОбОЋОќОе ОюОаОЋ ОюОћОЉОЎОЪ ОЉОдОЋОеОћ ОўОЋОЉОћ ОЎОЋОфОе ОљОф ОћОЉОбОЎОћ ОЕОюОџ ОЉ-Assistant. ОћОЋОљ ОаОЕОъОе ОюОфОДОЋОцОћ ОЕОю ОбОЊ 90 ОЎОъОЎОЮ ОЋОћОњОЎОЕОћ ОљОюОЎОЋ ОъОЋОњОЉОюОф: ОеОД ОдОЋОЋОфОЎ ОћОћОаОЊОАОћ ОЋОћОъОЕОЋОЉ ОћОъОфОљОЎОъОЎОЮ ОеОЕОљОЎОЮ ОюОњОЕОф ОљОюОЎОЋ.</translation>
<translation id="3890064827463908288">РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОАОаОЏОеОЋОЪ Chrome ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОАОаОЏОеОЋОЪ Wi-Fi</translation>
<translation id="389313931326656921">ОћОДОдОљОф ОъОфОњ ОюОцОбОЋОюОћ "ОћОЉОљ"</translation>
<translation id="3893295674388762059">ОЏОЊОЎ ОюОаОДОЋОф ОаОфОЋОаОЎОЮ, ОЎОЕ ОюОдОљОф ОъОЏОю ОћОЌОюОЋОаОЋОф ОћОљОаОЋОаОЎОъОЎОЎОЮ</translation>
<translation id="3893536212201235195">ОДОеОЎОљОћ ОЋОЕОЎОаОЋОЎ ОЕОю ОћОњОЊОеОЋОф ОћОаОњОЎОЕОЋОф ОЕОюОџ</translation>
<translation id="3893630138897523026">РђЈChromeVox (ОъОЕОЋОЉ ОДОЋОюОЎ)</translation>
<translation id="3893764153531140319"><ph name="DOWNLOADED_SIZE" />/<ph name="DOWNLOAD_SIZE" /></translation>
<translation id="3894123633473837029">РђЈОћОЊОЋОЌ ОЎОЏОюОЋОю ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОЕОю Assistant ОъОћОќОъОЪ ОћОљОЌОеОЋОЪ ОЊОеОџ Sherlog. ОћОцОеОўОЎОЮ ОбОЕОЋОЎОЎОЮ ОюОЏОюОЋОю ОљОф ОћОќОћОЋОф ОЋОћОъОЎОДОЋОЮ ОЕОюОџ, ОЏОъОЋ ОњОЮ ОъОЎОЊОб ОбОю ОфОЋОдОљОЋОф ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="3894427358181296146">ОћОЋОАОцОф ОфОЎОДОЎОЎОћ</translation>
<translation id="3894770151966614831">РђЈОюОћОбОЉОЎОе ОюОЌОЕОЉОЋОЪ Google?</translation>
<translation id="3895076768659607631">&amp;ОаОЎОћОЋОю ОъОаОЋОбОЎ ОћОЌОЎОцОЋОЕРђд</translation>
<translation id="3895090224522145010">РђЈОЕОЮ ОъОЕОфОъОЕ ОЉ-Kerberos</translation>
<translation id="389521680295183045">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОЊОбОф ОъОфОЎ ОћОъОЏОЕОЎОе ОћОќОћ ОъОЕОъОЕ ОљОЋОфОџ ОЉОљОЋОцОЪ ОцОбОЎОю</translation>
<translation id="3897298432557662720">{COUNT,plural, =1{ОфОъОЋОаОћ}two{# ОфОъОЋОаОЋОф}many{# ОфОъОЋОаОЋОф}other{# ОфОъОЋОаОЋОф}}</translation>
<translation id="3898233949376129212">ОЕОцОф ОћОъОЏОЕОЎОе</translation>
<translation id="3898327728850887246">ОћОљОфОе <ph name="SITE_NAME" /> ОъОЉОДОЕ ОљОф ОћОћОеОЕОљОЋОф ОћОЉОљОЋОф: <ph name="FIRST_PERMISSION" /> ОЋОњОЮ <ph name="SECOND_PERMISSION" /></translation>
<translation id="389901847090970821">ОЉОЌОЎОеОф ОъОДОюОЊОф</translation>
<translation id="3900966090527141178">ОЎОЎОдОЋОљ ОАОЎОАОъОљОЋОф</translation>
<translation id="3903187154317825986">ОъОДОюОЊОф ОъОЋОЉОаОЎОф</translation>
<translation id="3904326018476041253">ОЕОЎОеОЋОфОЎ ОъОЎОДОЋОЮ</translation>
<translation id="3904849010307028014">ОбОю ОАОъОџ ОћОцОбОЋОюОЋОф ОЕОюОџ ОЉОљОфОе, ОюОъОЕОю ОЏОаОЎОАОЋОф ОЕОњОеОфОЎОЋОф ОюОЌОЕОЉОЋОЪ, ОћОљОфОе ОЎОЏОЋОю ОюОћОаОцОЎОД ОљОАОЎОъОЋОЪ ОъОћОЎОъОаОЋОф ОюОЊОцОЊОцОЪ ОЕОюОџ. ОюОљОЌОе ОъОЏОЪ, ОљОЮ ОљОфОеОЎОЮ ОљОЌОеОЎОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ ОЉОЋОЊОДОЎОЮ ОЋОъОЋОдОљОЎОЮ ОљОАОЎОъОЋОЪ ОъОћОЎОъОаОЋОф ОфОДОБ, ОЎОЕ ОАОЎОЏОЋОЎ ОњОЉОЋОћ ОЎОЋОфОе ОЕОћОЮ ОЎОфОЎОЎОЌОАОЋ ОљОюОЎОџ ОЏОљОю ОљОЊОЮ ОЋОюОљ ОЏОЉОЋОў.</translation>
<translation id="3905761538810670789">ОфОЎОДОЋОЪ ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="3908393983276948098"><ph name="PLUGIN_NAME" /> ОюОљ ОъОбОЋОЊОЏОЪ</translation>
<translation id="3908501907586732282">ОћОцОбОюОф ОфОЋОАОБ</translation>
<translation id="3909701002594999354">ОћОдОњОф ОЏОю &amp;ОћОцОДОЊОЎОЮ</translation>
<translation id="3909791450649380159">ОњОќ&amp;ОЎОеОћ</translation>
<translation id="39103738135459590">ОДОЋОЊ ОћОцОбОюОћ</translation>
<translation id="3911824782900911339">ОЊОБ 'ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ'</translation>
<translation id="3914173277599553213">ОаОЊОеОЕ</translation>
<translation id="3915280005470252504">ОЌОЎОцОЋОЕ ОДОЋОюОЎ</translation>
<translation id="3916233823027929090">ОЉОЊОЎОДОЋОф ОћОљОЉОўОЌОћ ОћОАОфОЎОЎОъОЋ</translation>
<translation id="3916445069167113093">ОАОЋОњ ОДОЋОЉОЦ ОќОћ ОбОюОЋОю ОюОњОеОЋОЮ ОаОќОД ОюОъОЌОЕОЉ ОЕОюОџ. ОћОљОЮ ОЉОеОдОЋОаОџ ОюОЕОъОЋОе ОљОф <ph name="FILE_NAME" /> ОЉОЏОю ОъОДОеОћ?</translation>
<translation id="3917184139185490151">РђЈОћОъОЌОЕОЉ ОЕОюОџ ОъОЏОЎОю ОъОЋОЊОЋОю ОъОљОЋОЉОўОЌ ОћОъОЕОъОЕ ОюОЎОЎОЕОЋОЮ ОфОЏОЋОаОЋОф ОљОЉОўОЌОћ ОДОеОЎОўОЎОЋОф ОеОЉОЋОф ОЉ-ChromeOS. ОљОцОЕОе ОюОћОЎОЏОаОА ОюОъОеОЏОќ ОћОбОќОеОћ ОЕОю Chromebook ОЏОЊОЎ ОюОДОЉОю ОъОЎОЊОб ОаОЋОАОБ: https://support.google.com/chromebook/?p=sm</translation>
<translation id="3918972485393593704">РђЈОЕОюОЎОЌОф ОћОцОеОўОЎОЮ ОљОю Google</translation>
<translation id="3919145445993746351">ОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОљОю ОћОфОЋОАОцОЎОЮ ОЕОюОџ ОЉОЏОю ОћОъОЌОЕОЉОЎОЮ ОЕОЉОеОЕОЋОфОџ, ОЎОЕ ОюОћОцОбОЎОю ОљОф ОћОАОаОЏОеОЋОЪ</translation>
<translation id="3919229493046408863">ОћОЕОЉОфОф ОћОћОфОеОљОћ ОЏОЕОъОќОЋОћОЎОЮ ОъОЏОЕОЎОеОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ</translation>
<translation id="3919798653937160644">РђЈОћОЊОцОЎОЮ ОћОъОЋОдОњОЎОЮ ОЉОЌОюОЋОЪ ОќОћ ОюОљ ОЎОЋОцОЎОбОЋ ОЉОћОЎОАОўОЋОеОЎОЎОф ОћОЊОцОЊОцОЪ, ОЋОюОљОЌОе ОАОњОЎОеОф ОЏОю ОЌОюОЋОаОЋОф ОћОљОЋОеОЌ ОћОцОфОЋОЌОЎОЮ, ОюОљ ОЎОЋОфОЎОеОЋ ОЉОъОЌОЕОЉ ОбОДОЉОЋОф, ОЏОъОЋ ОДОЋОЉОдОЎ Cookie. ОбОЮ ОќОљОф, ОЏОю ОћОДОЉОдОЎОЮ ОЕОЎОЋОеОЊОЋ ОЎОЎОЕОъОеОЋ.</translation>
<translation id="3920504717067627103">ОъОЊОЎОаОЎОЋОф ОљОЎОЕОЋОеОЎОЮ </translation>
<translation id="392089482157167418">РђЈОћОцОбОюОф ChromeVox (ОъОЕОЋОЉ ОДОЋОюОЎ)</translation>
<translation id="3920909973552939961">РђЈОюОљ ОъОЋОеОЕОЎОЮ ОюОћОфОДОЎОЪ ОеОЏОЎОЉОЎ handler ОЕОю ОфОЕОюОЋОъОЎОЮ</translation>
<translation id="3922823422695198027">ОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф ОъОЋОњОЊОеОЋОф ОюОцОфОЋОЌ ОљОф ОљОЋОфОЮ ОДОЎОЕОЋОеОЎОЮ ОЏОъОЋ <ph name="APP_NAME" />. ОЏОфОЋОдОљОћ ОъОЏОџ, <ph name="APP_NAME_2" />, <ph name="APP_NAME_3" /> ОЋОњОЮ <ph name="APP_NAME_4" /> ОюОљ ОЎОцОфОЌОЋ ОДОЎОЕОЋОеОЎОЮ ОаОфОъОЏОЎОЮ.</translation>
<translation id="3923184630988645767">ОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="3923676227229836009">ОюОЊОБ ОћОќОћ ОЎОЕ ОћОеОЕОљОћ ОюОћОдОЎОњ ОДОЉОдОЎОЮ</translation>
<translation id="3924145049010392604">Meta</translation>
<translation id="3924487862883651986">РђЈОЏОЕОћОћОњОЊОеОћ 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ' ОъОЋОцОбОюОф, ОЏОфОЋОЉОЋОф URL ОаОЕОюОЌОЋОф ОюОЉОЊОЎОДОћ. ОЉОаОЋОАОБ, ОаОЕОюОЌОф ОЊОЋОњОъОЎОф ОДОўОаОћ ОћОЏОЋОюОюОф ОЊОцОЎОЮ, ОћОЋОеОЊОЋОф, ОцОбОЎОюОЋОф ОЕОю ОфОЋОАОцОЎОЮ ОЋОцОеОўОЎ ОъОбОеОЏОф ОЉОъОўОеОћ ОюОљОфОе ОљОЎОЋОъОЎОЮ ОЌОЊОЕОЎОЮ. ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОЉОЏОю ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОъОДОЋОЕОеОЎОЮ ОЉОљОЋОцОЪ ОќОъОаОЎ ОюОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОћОћОњОаОћ ОћОќОЋ ОцОбОЎОюОћ ОеОД ОљОЮ ОаОЏОаОАОЎОЮ ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="3925573269917483990">ОъОдОюОъОћ:</translation>
<translation id="3926002189479431949">РђЈОћОўОюОцОЋОЪ ОћОъОЕОъОЕ Ою-Smart Lock ОћОЋОЌОюОБ</translation>
<translation id="3927932062596804919">ОЊОЌОЎОЎОћ</translation>
<translation id="3928570707778085600">ОЕОЎОаОЎОф ОљОф <ph name="FILE_OR_FOLDER_NAME" />. ОюОЕОъОЋОе ОљОф ОћОЕОЎОаОЋОЎОЎОЮ?</translation>
<translation id="3928659086758780856">ОћОЊОЎОЋ ОљОЋОќОю</translation>
<translation id="3929426037718431833">ОћОфОЋОАОцОЎОЮ ОћОљОюОћ ОбОЕОЋОЎОЎОЮ ОюОћОдОЎОњ ОЋОюОЕОаОЋОф ОљОф ОћОъОЎОЊОб ОЉОљОфОе ОћОќОћ.</translation>
<translation id="3930155420525972941">ОћОбОЉОеОф ОћОДОЉОЋОдОћ ОюОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="3930602610362250897">ОЏОЊОЎ ОюОћОцОбОЎОю ОфОЋОЏОЪ ОЕОъОЋОњОЪ ОЉОќОЏОЋОЎОЋОф ОЎОЋОдОеОЎОЮ, ОЎОЎОфОЏОЪ ОЕОЉОљОфОеОЎОЮ ОЎОћОЎОћ ОдОЋОеОџ ОюОћОЕОфОъОЕ ОЉОЕОЎОеОЋОф ОюОћОњОаОф ОфОЋОЏОЪ</translation>
<translation id="3930737994424905957">ОЌОЎОцОЋОЕ ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="3930968231047618417">ОдОЉОб ОеОДОб</translation>
<translation id="3933283459331715412">ОЕОЌОќОЋОе ОћОАОЎОАОъОћ ОЕОю <ph name="USERNAME" /> ОЕОаОъОЌОДОћ</translation>
<translation id="3936260554100916852">РђЈОћОъОЏОЕОЎОе <ph name="DEVICE_NAME" /> ОъОЕОфОБ ОљОЎОфОџ ОеОЕОф Wi-Fi</translation>
<translation id="3936390757709632190">&amp;ОцОфОЎОЌОф ОљОЋОЊОЎОЋ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="3936925983113350642">ОћОАОЎОАОъОћ ОЕОЉОЌОеОф ОфОЎОЊОеОЕ ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОљОЎОЕОЋОе ОћОќОћ ОъОљОЋОЌОе ОЎОЋОфОе. ОЎОЕ ОюОфОбОЊ ОљОЋОфОћ ОЉОъОДОЋОЮ ОЉОўОЋОЌ.</translation>
<translation id="3937640725563832867">ОЕОЮ ОЌОюОЋОцОЎ ОЕОю ОъОаОцОЎОД ОћОљОЎОЕОЋОе</translation>
<translation id="3937734102568271121">ОфОъОЎОЊ ОЎОЕ ОюОфОеОњОЮ <ph name="LANGUAGE" /></translation>
<translation id="3938128855950761626">ОъОЏОЕОЎОеОЎОЮ ОЕОю ОћОАОцОД <ph name="VENDOR_ID" /></translation>
<translation id="3940233957883229251">ОћОцОбОюОф ОЌОќОеОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="3941565636838060942">ОюОћОАОфОеОф ОћОњОЎОЕОћ ОюОфОЏОаОЎОф ОћОќОЋ, ОбОюОЎОџ ОюОћОАОЎОе ОљОЋОфОћ ОЉОљОъОдОбОЋОф
<ph name="CONTROL_PANEL_APPLET_NAME" /> ОЉОюОЋОЌ ОћОЉОДОеОћ.

ОюОћОцОбОЎОю ОљОф <ph name="CONTROL_PANEL_APPLET_NAME" />?</translation>
<translation id="3942420633017001071">ОљОЉОЌОЋОЪ</translation>
<translation id="3943582379552582368">&amp;ОљОЌОЋОеОћ</translation>
<translation id="3943857333388298514">ОћОЊОЉОДОћ</translation>
<translation id="3945513714196326460">ОЎОЕ ОюОаОАОЋОф ОЕОЮ ОДОдОе ОЎОЋОфОе</translation>
<translation id="3948027458879361203">ОЕОЎОаОЋОЎ ОЕОЮ ОћОъОљОеОЌ</translation>
<translation id="3948116654032448504">&amp;ОЌОЎОцОЋОЕ ОфОъОЋОаОћ ОЉ-<ph name="SEARCH_ENGINE" /></translation>
<translation id="3948507072814225786">Ою-<ph name="ORIGIN" /> ОЎОЕ ОћОеОЕОљОћ ОюОбОеОЋОџ ОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЋОф ОћОЉОљОЋОф</translation>
<translation id="394984172568887996">РђЈОъОЎОЋОЉОљ Оъ-IE</translation>
<translation id="3950820424414687140">ОЏОаОЎОАОћ</translation>
<translation id="3953834000574892725">ОћОЌОЕОЉОЋОаОЋОф ОЕОюОЎ</translation>
<translation id="3954354850384043518">ОъОфОЉОдОб</translation>
<translation id="3954469006674843813">РђЈ<ph name="HEIGHT" />x<ph name="WIDTH" /> (<ph name="REFRESH_RATE" /> ОћОеОЦ)</translation>
<translation id="3954953195017194676">РђЈОљОЎОЪ ОюОџ ОЎОЋОъОаОЎОЮ ОЕОю ОљОЎОеОЋОбОЎ WebRTC ОЕОфОЋОбОЊОЋ ОюОљОЌОеОЋОаОћ.</translation>
<translation id="3955193568934677022">ОљОфОеОЎОЮ ОЎОЋОЏОюОЋ ОюОћОцОбОЎОю ОфОЋОЏОЪ ОъОЋОњОЪ (ОъОЋОъОюОЦ)</translation>
<translation id="3955321697524543127">РђЈОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОеОЎ USB</translation>
<translation id="3955896417885489542">РђЈОАОДОЎОеОф ОћОљОцОЕОеОЋОЎОЋОф ОЕОю Google Play ОљОЌОеОЎ ОћОћОњОЊОеОћ</translation>
<translation id="3957079323242030166">РђЈОаОфОЋОаОЎ ОњОЎОЉОЋОЎ ОљОЎОаОЮ ОаОЌОЕОЉОЎОЮ ОЏОЌОюОД ОъОъОЏОАОф ОћОљОЌОАОЋОЪ ОЉ-Drive.</translation>
<translation id="3957149833646341246">{NUM_APPS,plural, =1{ОюОљОЌОф ОъОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ ОљОЎОЪ ОЎОЋОфОе ОфОъОЎОЏОћ.}two{Ою-# ОъОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ ОљОЎОЪ ОЎОЋОфОе ОфОъОЎОЏОћ.}many{Ою-# ОъОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ ОљОЎОЪ ОЎОЋОфОе ОфОъОЎОЏОћ.}other{Ою-# ОъОћОљОцОюОЎОДОдОЎОЋОф ОЕОюОџ ОљОЎОЪ ОЎОЋОфОе ОфОъОЎОЏОћ.}}</translation>
<translation id="3957844511978444971">РђЈОЎОЕ ОюОћОДОЎОЕ ОбОю "ОљОЎОЕОЋОе" ОЏОЊОЎ ОюОљОЕОе ОљОф ОЉОЌОЎОеОф ОћОћОњОЊОеОЋОф ОћОљОюОћ ОЕОю ОЕОЎОеОЋОфОЎ Google.</translation>
<translation id="3958088479270651626">ОЎОЎОЉОЋОљ ОАОЎОъОаОЎОЋОф ОЋОћОњОЊОеОЋОф</translation>
<translation id="3960566196862329469">ONC</translation>
<translation id="3962119236270174787">ОћОњОаОћ ОеОњОЎОюОћ ОъОцОаОЎ ОљОфОеОЎОЮ, ОћОЋОеОЊОЋОф ОЋОфОЋОАОцОЎОЮ ОЕОЎОЊОЋОбОЎОЮ ОЏОъОАОЋОЏОаОЎОЮ</translation>
<translation id="3964480518399667971">ОЏОЎОЉОЋОЎ ОћОеОЕОф ОћОАОюОЋОюОеОЎОф</translation>
<translation id="3965811923470826124">ОЉОљОъОдОбОЋОф</translation>
<translation id="3965965397408324205">ОЎОдОЎОљОћ Оъ-<ph name="PROFILE_NAME" /></translation>
<translation id="3966072572894326936">ОЉОЌОЎОеОф ОфОЎОДОЎОЎОћ ОљОЌОеОф...</translation>
<translation id="3967822245660637423">ОћОћОЋОеОЊОћ ОћОЋОЕОюОъОћ</translation>
<translation id="3967841595862839006">ОЉОЌОе ОЕОцОћ ОЋОъОДОюОЊОф</translation>
<translation id="3970114302595058915">ОъОќОћОћ</translation>
<translation id="397105322502079400">ОъОфОЉОдОб ОЌОЎОЕОЋОЉ...</translation>
<translation id="3971764089670057203">ОўОЉОЎОбОЋОф ОљОдОЉОбОЋОф ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ ОћОќОћ</translation>
<translation id="3973005893595042880">ОћОъОЕОфОъОЕ ОљОЎОаОЋ ОъОЋОеОЕОћ</translation>
<translation id="3973660817924297510">ОћОъОбОеОЏОф ОЉОЋОЊОДОф ОАОЎОАОъОљОЋОф (<ph name="CHECKED_PASSWORDS" /> ОъОфОЋОџ <ph name="TOTAL_PASSWORDS" />)Рђд</translation>
<translation id="3974514184580396500">ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОъОфОњ ОћОаОњОЎОЕОЋОф 'ОћОЉОљ' ОЏОЊОЎ ОюОћОбОЉОЎОе ОљОф ОћОъОЎОДОЋОЊ ОюОцОеОЎОў ОћОЉОљ ОЉОъОАОџ</translation>
<translation id="3975201861340929143">ОћОАОЉОе</translation>
<translation id="3975565978598857337">ОЎОдОЎОеОф ОћОДОЕОе ОбОЮ ОћОЕОеОф ОЕОю ОћОфОЌОЋОЮ ОаОЏОЕОюОћ</translation>
<translation id="3976108569178263973">ОљОЎОЪ ОъОЊОцОАОЋОф ОќОъОЎОаОЋОф.</translation>
<translation id="397703832102027365">ОЉОЕОюОЉОЎ ОАОЎОЋОЮ...</translation>
<translation id="3977145907578671392">ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОфОЏОЋОаОЋОф ОЉОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОюОљ ОЎОцОбОюОЋ ОЉОъОдОЉ ОцОеОўОЎ</translation>
<translation id="3977886311744775419">ОЉОеОЕОф ОъОАОЋОњ ОќОћ ОюОљ ОЎОЏОЋОюОЎОЮ ОюОћОфОЉОдОб ОбОЊОЏОЋОаОЎОЮ ОљОЋОўОЋОъОўОЎОЎОЮ, ОљОЉОю ОљОцОЕОе ОюОЉОЊОЋОД ОЎОЊОаОЎОф ОљОЮ ОЎОЕ ОбОЊОЏОЋОаОЎОЮ.</translation>
<translation id="3979395879372752341">ОфОЋОАОБ ОЌОЊОЕ ОаОЋОАОБ (<ph name="EXTENSION_NAME" />)</translation>
<translation id="3979748722126423326">ОЎОЕ ОюОћОцОбОЎОю <ph name="NETWORKDEVICE" /></translation>
<translation id="3981058120448670012">ОћОъОЏОЕОЎОе ОњОюОЋОЎ ОюОъОЏОЕОЎОеОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ ОЉОфОЋОе <ph name="DEVICE_NAME" /> ОюОъОЕОџ <ph name="REMAINING_TIME" />Рђд</translation>
<translation id="3981760180856053153">ОћОЋОќОЪ ОАОЋОњ ОЕОъОЎОеОћ ОюОљ ОЌОЋОДОЎ.</translation>
<translation id="3981902534690264083">ОъОцОеОАОъОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОДОЉОю ОфОЋОЉОаОЋОф ОюОњОЉОЎ ОЉОЎОдОЋОбОЎОЮ ОЕОю ОъОЋОЊОбОЋОф</translation>
<translation id="3982375475032951137">ОљОцОЕОе ОюОћОњОЊОЎОе ОљОф ОћОЊОцОЊОцОЪ ОЉОЏОъОћ ОЕОюОЉОЎОЮ ОцОЕОЋОўОЎОЮ</translation>
<translation id="3983400541576569538">ОЎОЎОфОЏОЪ ОљОЋОЉОЊОЪ ОЕОю ОаОфОЋОаОЎОЮ ОъОЏОъОћ ОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="3983586614702900908">ОъОЏОЕОЎОеОЎОЮ ОъОАОцОД ОюОљ ОЎОЊОЋОб</translation>
<translation id="3983764759749072418">РђЈОюОљОцОюОЎОДОдОЎОЋОф ОъОЌОаОЋОф Play ОЎОЕ ОњОЎОЕОћ ОюОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="3983769721878416534">ОћОЕОћОЎОЎОћ ОюОцОаОЎ ОюОЌОЎОдОћ</translation>
<translation id="3984135167056005094">ОљОЎОЪ ОюОЏОюОЋОю ОЏОфОЋОЉОф ОљОЎОъОЎОЎОю</translation>
<translation id="3984159763196946143">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОЌОЎОю ОъОдОЉ ОћОЊОњОъОћ</translation>
<translation id="3984431586879874039">ОћОљОЮ ОюОљОцОЕОе ОюОљОфОе ОюОеОљОЋОф ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ?</translation>
<translation id="398477389655464998">ОћОбОфОДОф ОДОЎОЕОЋОе ОюОўОДОАОў ОћОъОЋОЊОњОЕ</translation>
<translation id="3984862166739904574">ОћОњОЊОеОћ ОЕОю ОфОЕОЋОЉОЋОф ОъОћОЎОеОЋОф</translation>
<translation id="3986164906089840270">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОЏОюОЋОю ОъОЎОЊОб ОЏОъОЋ ОъОЋОбОЊ ОћОДОеОЎОАОћ ОЕОю ChromeOS, ОћОфОЏОЋОаОЋОф ОЕОЉОћОЪ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЋОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЋ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОъОЏОЕОЎОе Chrome ОЕОюОџ. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОбОЉОЋОе ОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.<ph name="END_PARAGRAPH3" /></translation>
<translation id="3987544746655539083">ОюОћОъОЕОЎОџ ОюОЌОАОЋОЮ РђЊ ОћОљОфОе ОюОљ ОЎОДОЉОю ОњОЎОЕОћ ОюОъОЎОДОЋОЮ ОЕОюОџ</translation>
<translation id="3987938432087324095">ОќОћ ОюОљ ОћОЎОћ ОЉОеОЋОе.</translation>
<translation id="3987993985790029246">ОћОбОфОДОф ОДОЎОЕОЋОе</translation>
<translation id="3988996860813292272">ОЉОЌОЎОеОф ОљОќОЋОе ОќОъОЪ</translation>
<translation id="399179161741278232">ОъОЎОЋОЉОљОЋОф</translation>
<translation id="3993887353483242788">РђЈОдОеОЎОџ ОюОАОаОЏОеОЪ ОљОф <ph name="DEVICE_TYPE" /> ОЏОЊОЎ ОЕОћОћОбОЊОцОЋОф ОЕОюОџ ОЎОћОЎОЋ ОъОЋОЏОаОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЉОбОф ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ Google. ОћОћОбОЊОцОЋОф ОъОфОЎОЎОЌОАОЋОф ОюОљОцОюОЎОДОдОЎОЋОф, ОюОћОњОЊОеОЋОф, ОюОАОЎОАОъОљОЋОф Ою-Wi-Fi, ОюОЕОцОЋОф, ОюОўОцОў, ОюОъОДОЕОЎ ОДОЎОдОЋОе ОЋОбОЋОЊ.</translation>
<translation id="3994318741694670028">РђЈОюОдОбОеОаОЋ, ОћОъОЌОЕОЉ ОЕОюОџ ОъОЋОњОЊОе ОЉОљОъОдОбОЋОф ОъОќОћОћ ОЌОЋОъОеОћ ОцОњОЋОЮ. ОћОъОдОЉ ОћОќОћ ОъОЋОаОб Оъ-ChromeOS Flex ОюОћОфОДОЎОЪ ОљОф ОбОЊОЏОЋОаОЎ ОћОљОЉОўОЌОћ ОћОљОЌОеОЋОаОЎОЮ, <ph name="BEGIN_BOLD" />ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОъОЌОЕОЉ ОЕОюОџ ОЎОћОЎОћ ОЌОЕОЋОБ ОюОћОфОДОцОЋОф ОќОЊОЋОаОЎОЋОф<ph name="END_BOLD" />.</translation>
<translation id="3994374631886003300">ОбОюОЎОџ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОўОюОцОЋОЪ ОЋОюОДОеОЉ ОљОЋОфОЋ Ою-<ph name="DEVICE_TYPE" /> ОЏОЊОЎ ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОюОЋ.</translation>
<translation id="3994878504415702912">ОъОеОЌОД ОъОфОдОЋОњОћ</translation>
<translation id="3995138139523574647">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЎОъОаОЎОф-ОљОЌОЋОеОЎОф)</translation>
<translation id="3995963973192100066">ОћОцОбОюОф ОћОљОаОЎОъОдОЎОћ</translation>
<translation id="4002329649066944389">ОаОЎОћОЋОю ОЌОеОЎОњОЎОЮ ОћОАОцОдОЎОцОЎОЎОЮ ОюОљОфОе</translation>
<translation id="4002440992267487163">ОћОњОЊОеОф ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="4005817994523282006">ОЕОЎОўОћ ОюОќОЎОћОЋОЎ ОљОќОЋОе ОќОъОЪ</translation>
<translation id="4007856537951125667">ОћОАОфОеОф ОДОЎОдОЋОеОЎ ОћОЊОеОџ</translation>
<translation id="4008291085758151621">РђЈОцОеОўОЎ ОћОљОфОе ОљОЎОаОЮ ОќОъОЎОаОЎОЮ ОЉ-VR</translation>
<translation id="4010917659463429001">ОЏОЊОЎ ОюОњОЕОф ОюОАОЎОъОаОЎОЋОф ОЕОюОџ ОЉОаОЎОЎОЊ, <ph name="GET_IOS_APP_LINK" />.</translation>
<translation id="4014432863917027322">ОюОфОДОЪ ОљОф '<ph name="EXTENSION_NAME" />'?</translation>
<translation id="4015163439792426608">ОъОЋОфОДОаОЎОЮ ОљОдОюОџ ОфОЋОАОцОЎОЮ? ОљОцОЕОе <ph name="BEGIN_LINK" />ОюОаОћОю ОљОф ОћОфОЋОАОцОЎОЮ<ph name="END_LINK" /> ОЉОДОюОЋОф ОЉОъОДОЋОЮ ОљОЌОЊ.</translation>
<translation id="4017225831995090447">РђЈОдОеОЎОџ ОюОЎОдОЋОе ОДОЋОЊ QR ОюОДОЎОЕОЋОе ОћОќОћ</translation>
<translation id="4020327272915390518">ОфОцОеОЎОў ОљОцОЕОеОЋОЎОЋОф</translation>
<translation id="4021279097213088397">РђЈРђЊ</translation>
<translation id="402184264550408568">(TCP)</translation>
<translation id="4021909830315618592">РђЈОћОбОфОДОф ОцОеОўОЎ build</translation>
<translation id="4021941025609472374">ОАОњОЎОеОф ОћОЏОеОўОЎОАОЎОЋОф ОъОЎОъОЎОЪ</translation>
<translation id="4022426551683927403">&amp;ОћОЋОАОцОћ ОюОъОЎОюОЋОЪ</translation>
<translation id="4023146161712577481">ОДОЉОЎОбОф ОћОфОдОЋОеОћ ОЕОю ОћОъОЏОЕОЎОе.</translation>
<translation id="4025039777635956441">ОћОЕОфОДОф ОћОљОфОеОЎОЮ ОЕОаОЉОЌОеОЋ</translation>
<translation id="4028467762035011525">ОћОЋОАОцОћ ОЕОю ОЕОЎОўОЋОф ОДОюОў</translation>
<translation id="4029556917477724407">ОЌОќОеОћ ОъОћОЊОБ <ph name="PAGE_TITLE" /></translation>
<translation id="4031179711345676612">ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ ОЉОЊОБ ОќОћ</translation>
<translation id="4031308539321678562">РђЈОћОцОбОЋОюОћ ОћОќОЋ ОфОъОЌОД ОЉОљОЋОцОЪ ОАОЋОцОЎ ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЉОъОЏОЕОЎОе ОћОќОћ. ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЎОЕ ОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф ОЉ-Chromebook ОЕОюОџ ОЕОъОЌОЋОЉОеОЋОф ОюОЌОЕОЉОЋОаОЋОф Google ОЕОЉОцОеОЋОцОЎОю ОћОќОћ. ОЏОЊОЎ ОюОћОАОЎОе ОљОф ОћОЌОЕОЉОЋОаОЋОф ОћОљОюОћ, ОбОюОЎОџ ОюОбОЉОЋОе ОљОю <ph name="BEGIN_LINK" /><ph name="SETTING_SECTION" /> &gt; <ph name="ACCOUNTS_SECTION" /><ph name="END_LINK" />.</translation>
<translation id="4031527940632463547">ОћОЌОЎОЎОЕОаОЎОЮ ОЌОАОЋОъОЎОЮ</translation>
<translation id="4033415645631238123">РђЈОљОЎ ОљОцОЕОе ОЎОЋОфОе ОюОћОЎОЏОаОА ОЉОљОъОдОбОЋОф Smart Lock. ОљОцОЕОе ОюОћОъОЕОЎОџ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе ОЉОљОъОдОбОЋОф Smart Lock.</translation>
<translation id="4033471457476425443">ОћОЋОАОцОф ОфОЎОДОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="4033963223187371752">ОЉОљОфОеОЎОЮ ОъОљОЋОЉОўОЌОЎОЮ ОъОЋОўОъОб ОюОцОбОъОЎОЮ ОфОЋОЏОЪ ОюОљ ОъОљОЋОЉОўОЌ, ОЏОъОЋ ОфОъОЋОаОЋОф ОљОЋ ОъОАОњОеОЋОф ОЕОю ОљОфОеОЎОЮ</translation>
<translation id="4034824040120875894">ОъОЊОцОАОф</translation>
<translation id="4035758313003622889">&amp;ОъОаОћОю ОћОъОЕОЎОъОЋОф</translation>
<translation id="4035877632587724847">ОљОЎОЪ ОљОЎОЕОЋОе</translation>
<translation id="4036778507053569103">ОћОъОЊОЎОаОЎОЋОф ОЕОћОЋОеОЊОћ ОъОћОЕОеОф ОљОЎОаОћ ОЌОЋОДОЎОф.</translation>
<translation id="4037084878352560732">ОАОЋОА</translation>
<translation id="403725336528835653">ОљОаОЎ ОеОЋОдОћ ОюОаОАОЋОф ОДОЋОЊОЮ</translation>
<translation id="4040105702484676956">ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОљОф ОћОћОеОЕОљОЋОф ОюОљОфОе <ph name="SITE_NAME" /> ОЋОюОљОцОюОЎОДОдОЎОЋОф ОћОъОЋОфОДОаОЋОф ОЉОЋ?</translation>
<translation id="4042863763121826131">{NUM_PAGES,plural, =1{ОЎОдОЎОљОћ ОъОћОЊОБ}two{ОЎОдОЎОљОћ ОъОћОЊОцОЎОЮ}many{ОЎОдОЎОљОћ ОъОћОЊОцОЎОЮ}other{ОЎОдОЎОљОћ ОъОћОЊОцОЎОЮ}}</translation>
<translation id="4044612648082411741">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОАОЎОАОъОф ОћОљОЎОЕОЋОе</translation>
<translation id="4044708573046946214">ОАОЎОАОъОф ОаОбОЎОюОф ОъОАОџ</translation>
<translation id="404493185430269859">ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОћОъОЋОњОЊОе ОЏОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="4045180775310929593">ОЏОљОЪ ОъОЋОАОЎОцОЎОЮ ОћОбОеОЋОфРђд</translation>
<translation id="4046013316139505482">ОюОфОЋОАОцОЎОЮ ОћОљОюОћ ОюОљ ОЊОеОЋОЕОћ ОЎОЏОЋОюОф ОюОеОљОЋОф ОљОф ОћОъОЎОЊОб ОЉОљОфОе ОћОќОћ ОЋОюОЕОаОЋОф ОљОЋОфОЋ.</translation>
<translation id="4046123991198612571">ОћОеОдОЋОбОћ ОћОЉОљОћ</translation>
<translation id="4047345532928475040">ОюОљ ОќОъОЎОЪ</translation>
<translation id="4047581153955375979">USB4</translation>
<translation id="4047726037116394521">ОЌОќОеОћ ОюОЊОБ ОћОЉОЎОф</translation>
<translation id="4049783682480068824">{COUNT,plural, =1{РђЈОљОЎОЕ ОДОЕОе ОљОЌОЊ ОюОљ ОќОъОЎОЪ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ' ОбОЮ ОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ, ОЎОЕ ОюОћОЋОАОЎОБ ОюОћОЮ ОљОф ОЏОфОЋОЉОф ОћОљОЎОъОЎОЎОю ОЕОъОЕОЋОЎОЏОф ОюОЌОЕОЉОЋОЪ Google ОЕОюОћОЮ.}two{РђЈ# ОљОаОЕОЎ ОДОЕОе ОљОЎОаОЮ ОќОъОЎОаОЎОЮ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ' ОбОЮ ОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ, ОЎОЕ ОюОћОЋОАОЎОБ ОюОћОЮ ОљОф ОЏОфОЋОЉОЋОф ОћОљОЎОъОЎОЎОю ОЕОъОЕОЋОЎОЏОЋОф ОюОЌОЕОЉОЋОаОЋОф Google ОЕОюОћОЮ.}many{РђЈ# ОљОаОЕОЎ ОДОЕОе ОљОЎОаОЮ ОќОъОЎОаОЎОЮ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ' ОбОЮ ОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ, ОЎОЕ ОюОћОЋОАОЎОБ ОюОћОЮ ОљОф ОЏОфОЋОЉОЋОф ОћОљОЎОъОЎОЎОю ОЕОъОЕОЋОЎОЏОЋОф ОюОЌОЕОЉОЋОаОЋОф Google ОЕОюОћОЮ.}other{РђЈ# ОљОаОЕОЎ ОДОЕОе ОљОЎОаОЮ ОќОъОЎОаОЎОЮ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ' ОбОЮ ОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ, ОЎОЕ ОюОћОЋОАОЎОБ ОюОћОЮ ОљОф ОЏОфОЋОЉОЋОф ОћОљОЎОъОЎОЎОю ОЕОъОЕОЋОЎОЏОЋОф ОюОЌОЕОЉОЋОаОЋОф Google ОЕОюОћОЮ.}}</translation>
<translation id="4050225813016893843">ОЕОЎОўОф ОљОЎОъОЋОф</translation>
<translation id="4050534976465737778">РђЈОЎОЕ ОюОЋОЋОЊОљ ОЕОЕОаОЎ ОћОъОЏОЕОЎОеОЎОЮ ОљОЎОаОЮ ОаОбОЋОюОЎОЮ, ОЕОћОЮ ОДОеОЋОЉОЎОЮ ОќОћ ОюОќОћ ОЋОЕОЉОЕОаОЎОћОЮ ОъОЋОцОбОю Bluetooth. ОљОЮ ОћОЕОЎОфОЋОБ ОаОбОЕОћ ОбОЮ Chromebook ОЕОљОЎОаОЋ ОеОЕОЋОЮ ОЉОљОаОЕОЎ ОћОДОЕОе ОЕОюОџ, ОЎОЕ ОюОЋОЋОЊОљ ОЕОћОЋОцОбОюОЋ ОћОеОЕОљОЋОф ОћОњОЎОЕОћ ОЉОДОеОЉОф ОъОДОЋОЮ (ОЎОЕ ОюОцОфОЋОЌ ОљОф ОљОќОЋОе ОћОАОўОўОЋОА ОЋОљОќ ОюОћОцОбОЎОю ОљОф ОћОеОЕОљОЋОф ОћОњОЎОЕОћ ОЉОДОеОЉОф ОъОДОЋОЮ). <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="4052120076834320548">ОќОбОЎОе</translation>
<translation id="4054070260844648638">ОњОюОЋОЎ ОюОЏОЋОюОЮ</translation>
<translation id="4056908315660577142">РђЈОћОњОбОф ОюОъОњОЉОюОф ОћОќОъОЪ ОЕОћОЋОњОЊОеОћ ОбОю ОЎОЊОЎ ОћОћОЋОеОћ ОЕОюОџ ОюОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОЉ-Chrome. ОъОЌОе ОљОцОЕОе ОЎОћОЎОћ ОюОћОЕОфОъОЕ ОЉОћ ОюОъОЕОџ <ph name="TIME_LIMIT" />.</translation>
<translation id="4057041477816018958"><ph name="SPEED" /> - <ph name="RECEIVED_AMOUNT" /></translation>
<translation id="4057896668975954729">ОћОдОњОћ ОЉОЌОаОЋОф</translation>
<translation id="4058720513957747556">РђјAppSocket (TCP/IP)Рђј</translation>
<translation id="4058793769387728514">ОЉОЊОЎОДОф ОћОъОАОъОџ ОЏОбОф</translation>
