<translation id="6007240208646052708">ОюОљ ОаОЎОфОЪ ОюОЉОдОб ОЌОЎОцОЋОЕ ОДОЋОюОЎ ОЉОЕОцОћ ОЕОюОџ.</translation>
<translation id="6011193465932186973">ОўОЉОЎОбОф ОљОдОЉОб</translation>
<translation id="6011449291337289699">ОъОЌОЎОДОћ ОЕОю ОаОфОЋОаОЎ ОљОфОе</translation>
<translation id="6011908034087870826">ОЕОюОЎОЌОф ОћОДОЎОЕОЋОе ОљОю <ph name="DEVICE_NAME" /> ОъОфОЉОдОбОф</translation>
<translation id="6013027779243312217">ОћОцОбОюОф ОЏОфОЋОЉОЎОЋОф ОюОљОЋОЊОЎОЋ ОЋОюОЋОЋОЎОЊОљОЋ</translation>
<translation id="6015796118275082299">ОЕОаОћ</translation>
<translation id="6016178549409952427">ОаОЎОЋОЋОў ОљОю ОфОЋОЏОЪ ОаОЋОАОБ <ph name="CURRENT_ELEMENT" /> ОъОфОЋОџ <ph name="TOTAL_ELEMENTS" /></translation>
<translation id="6016551720757758985">РђЈОљОЎОЕОЋОе ОцОбОЋОюОф Powerwash ОЉОбОф ОЌОќОеОћ ОюОњОеОАОћ ОДОЋОЊОъОф</translation>
<translation id="6016972670657536680">ОюОЌОдОЪ ОюОЉОЌОЎОеОф ОЕОцОћ ОЋОъОДОюОЊОф. ОћОЕОцОћ ОћОъОЋОњОЊОеОф ОбОЏОЕОЎОЋ ОћОЎОљ <ph name="LANGUAGE" />.</translation>
