<translation id="6098793583803863900">ОДОЋОЉОЦ ОюОљ ОЎОЊОЋОб ОаОАОеОД ОЏОбОф ОюОљОЎОфОЋОе ОфОЋОЏОЪ ОъОАОЋОЏОЪ.</translation>
<translation id="609942571968311933">ОћОўОДОАОў ОћОЋОбОфОД ОъОћОъОЏОЕОЎОе ОћОЉОљ: <ph name="DEVICE_NAME" /></translation>
<translation id="6100736666660498114">ОфОцОеОЎОў ОћОфОЌОюОћ</translation>
<translation id="6101226222197207147">ОЎОЎОЕОЋОЮ ОЌОЊОЕ ОаОЋОАОБ (<ph name="EXTENSION_NAME" />)</translation>
<translation id="6102043788063419338">ОћОДОЋОЉОЦ ОћОќОћ ОаОЌОАОЮ ОбОю-ОЎОЊОЎ ОћОћОњОаОћ ОћОъОфОДОЊОъОф.</translation>
<translation id="6103681770816982672">РђЈОљОќОћОеОћ: ОъОфОЉОдОб ОъОбОЉОе Ою-developer channel</translation>
<translation id="6104068876731806426">РђЈОЌОЕОЉОЋОаОЋОф Google</translation>
<translation id="6104311680260824317">РђЈОљОЎ ОљОцОЕОе ОюОдОеОБ ОљОф ОћОъОЏОЕОЎОе ОћОќОћ ОљОю ОћОЊОЋОъОЎОЎОЪ. ОћОЕОеОф ОюОљ ОфОЋОъОџ ОЉОАОЋОњОЎ ОћОдОцОаОф Kerberos ОЕОдОЋОЎОаОЋ. ОЎОЕ ОюОбОЎОЎОЪ ОЉ"ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф" ОЏОЊОЎ ОюОДОеОЋОљ ОбОю ОћОњОЊОеОЋОф ОћОћОдОцОаОћ.</translation>
<translation id="6104796831253957966">ОфОЋОе ОћОъОЊОцОАОф ОъОюОљ</translation>
<translation id="6111972606040028426">РђЈОћОцОбОюОф Google Assistant</translation>
<translation id="6112294629795967147">ОЕОЎОаОЋОЎ ОњОЋОЊОю ОЉОљОъОдОбОЋОф ОаОњОЎОбОћ</translation>
<translation id="6112727384379533756">ОћОЋОАОцОф ОЏОеОўОЎОА</translation>
<translation id="6112931163620622315">ОЉОЊОЎОДОф ОћОўОюОцОЋОЪ</translation>
<translation id="6113434369102685411">РђЈОбОюОЎОџ ОюОћОњОЊОЎОе ОљОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОЎОЋОњОЊОе ОЏОЉОеОЎОеОф ОћОъОЌОЊОю ОюОЊОцОЊОцОЪ Chrome ОЋОюОъОеОЏОќ ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю <ph name="DEVICE_TYPE" /></translation>
<translation id="6113942107547980621">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-Smart Lock ОЎОЕ ОюОбОЉОЋОе ОљОю ОцОеОЋОцОЎОю ОћОъОЕОфОъОЕ ОћОеОљОЕОЎ ОЉОўОюОцОЋОЪ</translation>
<translation id="6116921718742659598">ОЕОЎОаОЋОЎ ОћОњОЊОеОЋОф ОћОДОюОў ОЋОћОЕОцОћ</translation>
<translation id="6119927814891883061">ОЕОъОЎОеОф ОЕОЮ ОћОъОЏОЕОЎОе <ph name="DEVICE_NAME" /></translation>
<translation id="6120205520491252677">ОћОдОъОЊОф ОЊОБ ОќОћ ОюОъОАОџ ОћОцОфОЎОЌОћ...</translation>
<translation id="6120707837086723438">РђЈОъОЋОдОњОЋОф ОюОџ ОћОдОбОЋОф ОюОъОфОЏОЋОаОЎОЮ ОбОю ОАОъОџ ОцОбОЎОюОЋОф ОЌОЎОцОЋОЕ ОћОъОфОЏОЋОаОЎОЮ ОЕОюОџ ОъОћОќОъОЪ ОћОљОЌОеОЋОЪ.
        <ph name="BREAK" />
        <ph name="BREAK" />
        ОаОЎОфОЪ ОюОаОћОю ОљОф ОћОћОњОЊОеОЋОф ОЊОеОџ ОћОфОцОеОЎОў ОЉОЏОеОўОЎОА ОљОЋ ОюОеОљОЋОф ОбОЋОЊ ОљОцОЕОеОЋОЎОЋОф ОЉ'ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chrome'.</translation>
<translation id="6121773125605585883">ОћОдОњОф ОћОАОЎОАОъОћ ОЕОю ОЕОЮ ОћОъОЕОфОъОЕ <ph name="USERNAME" /> ОюОљОфОе <ph name="WEBSITE" /></translation>
<translation id="6122081475643980456">ОћОЌОЎОЉОЋОе ОЕОюОџ ОюОљОЎОаОўОеОаОў ОаОЕОюОў ОбОю ОЎОЊОЎ ОњОЋОеОЮ ОЏОюОЕОћОЋ</translation>
<translation id="6122093587541546701">ОљОЎОъОЎОЎОю (ОљОЋОцОдОЎОЋОаОюОЎ):</translation>
<translation id="6122095009389448667">ОћОъОЕОџ ОЌОАОЎОъОф ОћОњОЎОЕОћ ОЕОю ОћОљОфОе ОћОќОћ ОюОюОЋОЌ</translation>
<translation id="6122600716821516697">ОюОЕОфОБ ОбОЮ ОћОъОЏОЕОЎОе ОћОќОћ?</translation>
<translation id="6122831415929794347">ОюОћОЕОЉОЎОф ОљОф 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ'?</translation>
<translation id="6122875415561139701">ОцОбОЋОюОф ОЏОфОЎОЉОћ ОљОАОЋОеОћ ОЉОъОЏОЕОЎОе: "<ph name="DEVICE_NAME" />".</translation>
<translation id="6124213551517593835">РђЈОћОцОбОЋОюОћ ОћОќОЋ ОфОњОеОЋОЮ ОюОъОЌОЎОДОф ОЏОю ОћОаОфОЋОаОЎОЮ ОЋОДОЋОЉОдОЎ Оћ-cookie ОЕОљОЋОЌОАОаОЋ ОбОю ОЎОЊОЎ ОДОЉОЋОдОф ОћОљОфОеОЎОЮ <ph name="SITE_GROUP_NAME" /> ОЋОбОю-ОЎОЊОЎ ОЏОю ОћОљОфОеОЎОЮ ОћОЏОюОЋОюОЎОЮ ОЉОДОЉОЋОдОћ</translation>
<translation id="6124650939968185064">ОћОфОЋОАОцОЎОЮ ОћОЉОљОЎОЮ ОфОюОЋОЎОЎОЮ ОЉОфОЋОАОБ ОћОќОћ:</translation>
<translation id="6124698108608891449">ОћОљОфОе ОћОќОћ ОдОеОЎОџ ОћОеОЕОљОЋОф ОаОЋОАОцОЋОф.</translation>
<translation id="6125479973208104919">ОЎОћОЎОћ ОбОюОЎОџ ОюОћОЋОАОЎОБ ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-<ph name="DEVICE_TYPE" /> ОцОбОЮ ОаОЋОАОцОф.</translation>
<translation id="6126601353087978360">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОъОЕОЋОЉ ОЕОюОџ ОЏОљОЪ:</translation>
<translation id="6129691635767514872">РђЈОћОаОфОЋОаОЎОЮ ОЕОЉОЌОеОф ОћОЋОАОеОЋ Оъ-Chrome ОЋОъОћОъОЏОЕОЎОеОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ. ОЎОЎОфОЏОЪ ОЕОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK" />myactivity.google.com<ph name="END_LINK" /> ОбОЊОЎОЎОЪ ОЎОфОљОцОЕОе ОюОџ ОюОњОЕОф ОюОАОЋОњОЎОЮ ОљОЌОеОЎОЮ ОЕОю ОћОЎОАОўОЋОеОЎОЎОф ОњОюОЎОЕОћ ОЉОЌОЕОЉОЋОЪ Google, ОЏОъОЋ ОЌОЎОцОЋОЕОЎОЮ ОЋОцОбОЎОюОЋОф ОъОЕОЎОеОЋОфОЎОЮ ОљОЌОеОЎОЮ ОЕОю Google.</translation>
<translation id="6129938384427316298">РђЈОћОбОеОћ ОюОљОЎОЕОЋОе Netscape</translation>
<translation id="6129953537138746214">ОеОЋОЋОЌ</translation>
<translation id="6130692320435119637">РђЈОћОЋОАОцОф Wi-Fi</translation>
<translation id="6130887916931372608">ОъОДОЕ ОЉОъОДОюОЊОф</translation>
<translation id="6136114942382973861">ОАОњОЎОеОф ОАОеОњОю ОћОћОЋОеОЊОЋОф</translation>
<translation id="6136287496450963112">ОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ ОљОЎОаОЋ ОъОЋОњОЪ ОЉОљОъОдОбОЋОф ОДОЋОЊ ОљОЎОъОЋОф. ОЏОЊОЎ ОюОаОћОю ОўОЉОЎОбОЋОф ОљОдОЉОб, ОЎОЕ ОюОЎОдОЋОе ОфОЌОЎОюОћ ОДОЋОЊ ОљОЎОъОЋОф.</translation>
<translation id="6138680304137685902">РђЈОЌОфОЎОъОф X9.62 ECDSA ОбОЮ SHA-384</translation>
<translation id="6141988275892716286">ОљОЎОЕОЋОе ОћОЋОеОЊОћ</translation>
<translation id="6143186082490678276">ОДОЉОюОф ОбОќОеОћ</translation>
<translation id="6143366292569327983">ОЉОЌОЎОеОф ОЕОцОф ОћОЊОБ ОЕОфОфОЋОеОњОЮ</translation>
<translation id="6144938890088808325">РђЈОеОЋОдОћ ОюОбОќОЋОе ОюОаОЋ ОюОЕОцОе ОљОф ОъОЌОЕОЉОЎ Chromebook?</translation>
<translation id="6146409560350811147">ОћОАОаОЏОеОЋОЪ ОюОљ ОцОЋОбОю. ОЎОЕ ОюОаОАОЋОф ОюОћОЎОЏОаОА ОЕОЋОЉ.</translation>
<translation id="6147020289383635445">ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОЕОю ОћОћОЊОцОАОћ ОаОЏОЕОюОћ.</translation>
<translation id="6148576794665275391">ОцОфОЎОЌОћ ОбОЏОЕОЎОЋ</translation>
<translation id="6149015141270619212">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="6150116777338468525">ОљОЎОЏОЋОф ОћОЕОъОбОф ОћОљОЋОЊОЎОЋ</translation>
<translation id="6150278227694566734">ОЌОюОД ОъОљОаОЕОЎ ОћОДОЕОе</translation>
<translation id="6150961653851236686">ОќОЋ ОћОЕОцОћ ОЕОЊОцОЎОЮ ОЎОфОЋОеОњОъОЋ ОљОюОЎОћ</translation>
<translation id="6151323131516309312">ОЎОЕ ОюОюОЌОЋОЦ ОбОю <ph name="SEARCH_KEY" /> ОЏОЊОЎ ОюОЌОцОЕ ОЉ-<ph name="SITE_NAME" /></translation>
<translation id="6151771661215463137">ОћОДОЋОЉОЦ ОЏОЉОе ОДОЎОЎОЮ ОЉОфОЎОДОЎОЎОф ОћОћОЋОеОЊОЋОф ОЕОюОџ.</translation>
<translation id="6154240335466762404">ОћОАОеОћ ОЕОю ОЏОю ОћОЎОдОЎОљОЋОф</translation>
<translation id="615436196126345398">ОцОеОЋОўОЋОДОЋОю</translation>
<translation id="6155141482566063812">ОЏОеОўОЎОАОЎОЎОф ОћОеОДОб ОъОЕОфОцОф ОљОф ОћОъОАОџ ОЕОюОџ</translation>
<translation id="6156323911414505561">ОћОдОњОф ОАОеОњОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="6156863943908443225">ОъОўОъОЋОЪ ОАОДОеОЎОцОўОЎОЮ</translation>
<translation id="615930144153753547">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОдОЎОњ ОфОъОЋОаОЋОф</translation>
<translation id="6160625263637492097">ОљОАОцОДОф ОљОЎОЕОЋОеОЎОЮ ОюОљОЎОъОЋОф</translation>
<translation id="6163363155248589649">&amp;ОеОњОЎОю</translation>
<translation id="6163376401832887457">РђЈОћОњОЊОеОЋОф Kerberos</translation>
<translation id="6163522313638838258">ОћОеОЌОЉОф ОћОЏОЋОю...</translation>
<translation id="6165508094623778733">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="6166185671393271715">РђЈОЎОЎОЉОЋОљ ОАОЎОАОъОљОЋОф ОљОю Chrome</translation>
<translation id="6169040057125497443">ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОъОЎОДОеОЋОцОЋОЪ.</translation>
<translation id="6169967265765719844">РђЈОљОцОЕОе ОюОаОћОю ОљОф ОћОћОеОЕОљОЋОф ОюОъОЕОЌОДОЎОЮ ОЋОюОљОцОюОЎОДОдОЎОЋОф ОЕОћОЋОфОДОаОЋ ОЊОеОџ Steam <ph name="LINK_BEGIN" />ОЉОћОњОЊОеОЋОф ОЕОю ОљОцОюОЎОДОдОЎОЎОф Steam<ph name="LINK_END" />.</translation>
<translation id="6170470584681422115">ОЏОеОЎОџ</translation>
<translation id="6170498031581934115">РђЈОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОцОбОЎОю ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB. ОбОюОЎОџ ОюОбОЉОЋОе ОюОћОњОЊОеОЋОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="617213288191670920">ОюОљ ОаОЋОАОцОЋ ОЕОцОЋОф</translation>
<translation id="6173623053897475761">ОЎОЕ ОюОћОДОюОЎОЊ ОЕОЋОЉ ОљОф ОћОДОЋОЊ</translation>
<translation id="6175314957787328458">Microsoft Domain GUID</translation>
<translation id="6176043333338857209">РђЈОћОъОбОеОЏОф ОфОцОбОЎОю ОљОф Bluetooth ОЉОљОЋОцОЪ ОќОъОаОЎ ОЏОЊОЎ ОюОљОцОЕОе ОфОДОЕОЋОеОф ОбОЮ ОъОцОфОЌ ОћОљОЉОўОЌОћ</translation>
<translation id="6178664161104547336">ОЉОЌОЎОеОф ОљОЎОЕОЋОе</translation>
<translation id="6178682841350631965">ОцОеОўОЎ ОћОЏОаОЎОАОћ ОЕОюОџ ОбОЋОЊОЏОаОЋ</translation>
<translation id="6180510783007738939">ОЏОюОЎ ОћОЕОЋОеОћ</translation>
<translation id="6181431612547969857">ОћОћОЋОеОЊОћ ОаОЌОАОъОћ</translation>
<translation id="6184099524311454384">ОЌОЎОцОЋОЕ ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="6185132558746749656">ОъОЎОДОЋОЮ ОъОЏОЕОЎОе</translation>
<translation id="6188346519670155113">РђЈОћОАОаОЏОеОЋОЪ ОЕОю ОЊОцОЊОцОЪ Chrome ОцОЋОбОю</translation>
<translation id="6190953336330058278">РђЈОљОцОюОЎОДОдОЎОЋОф ОЕОю Phone Hub</translation>
<translation id="6195005504600220730">ОДОеОЎОљОф ОъОЎОЊОб ОбОю ОћОЊОцОЊОцОЪ, ОъОбОеОЏОф ОћОћОцОбОюОћ ОЋОћОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="6195693561221576702">ОљОЎ ОљОцОЕОе ОюОћОњОЊОЎОе ОљОф ОћОъОЏОЕОЎОе ОћОќОћ ОЉОъОдОЉ ОћОЊОњОъОћ ОљОЋОцОюОЎОЎОЪ.</translation>
<translation id="6196640612572343990">РђЈОЌОАОЎОъОф ОДОЋОЉОдОЎ Cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ</translation>
<translation id="6196854373336333322">РђЈОћОфОЋОАОБ "<ph name="EXTENSION_NAME" />" ОћОЕОфОюОў ОбОю ОћОњОЊОеОЋОф ОЕОеОф Оћ-Proxy. ОцОЎОеОЋОЕ ОћОЊОЉОе ОЕОћОЋОљ ОЎОЏОЋОю ОюОЕОаОЋОф ОЋОюОДОўОЋОб ОюОЏОю ОцОбОЋОюОћ ОЕОЉОЎОдОбОф ОЉОљОЎОаОўОеОаОў ОљОЋ ОюОдОЋОфОф ОюОћ. ОљОЮ ОюОљ ОЎОЊОЋОб ОюОџ ОЉОЋОЋОЊОљОЋОф ОъОЊОЋОб ОЕОЎОаОЋОЎ ОќОћ ОћОфОеОЌОЕ, ОАОЉОЎОе ОюОћОаОЎОЌ ОЕОќОћОЋ ОЕОЎОаОЋОЎ ОюОљ ОеОдОЋОЎ.</translation>
<translation id="6197128521826316819">РђЈОЎОдОЎОеОф ОДОЋОЊ QR ОюОЊОБ ОћОќОћ</translation>
<translation id="6198102561359457428">ОЎОЕ ОюОдОљОф ОЋОюОћОЎОЏОаОА ОЕОЋОЉ...</translation>
<translation id="6198252989419008588">ОЕОЎОаОЋОЎ ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="6200047250927636406">ОъОЌОЎОДОф ОћОДОЋОЉОЦ</translation>
<translation id="6200151268994853226">ОаОЎОћОЋОю ОћОфОЋОАОцОЎОЮ</translation>
<translation id="6201608810045805374">ОюОћОАОЎОе ОљОф ОћОЌОЕОЉОЋОЪ ОћОќОћ?</translation>
<translation id="6202304368170870640">ОДОЋОЊ ОћОљОЎОъОЋОф ОъОљОцОЕОе ОюОћОЎОЏОаОА ОюОъОЏОЕОЎОе ОљОЋ ОюОЉОўОю ОљОф ОаОбОЎОюОфОЋ.</translation>
<translation id="6206311232642889873">ОћОбОф&amp;ОДОф ОфОъОЋОаОћ</translation>
<translation id="6207200176136643843">ОљОЎОцОЋОА ОюОъОеОЌОД ОћОфОдОЋОњОћ ОћОъОЋОњОЊОе ОЏОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="6207937957461833379">ОъОЊОЎОаОћ/ОљОќОЋОе</translation>
<translation id="6208382900683142153">ОљОАОЎОъОЋОаОЎ ОъОћОЎОъОаОЋОф ОъОЕОцОеОЎОЮ ОљОф ОћОцОеОўОЎОЋОф ОЉОљОЎОаОўОеОаОў ОЋОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЏОЊОЎ ОюОњОюОЋОф ОљОф ОћОќОћОЋОф ОЕОюОџ.</translation>
<translation id="6208521041562685716">ОћОъОбОеОЏОф ОъОцОбОЎОюОћ ОљОф ОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="6208725777148613371">ОаОЏОЕОюОћ ОћОЕОъОЎОеОћ ОЉ-<ph name="WEB_DRIVE" /> РђЊ <ph name="INTERRUPT_REASON" /></translation>
<translation id="6209838773933913227">ОбОЊОЏОЋОЪ ОеОЏОЎОЉОЎОЮ</translation>
<translation id="6209908325007204267">РђЈОћОъОЏОЕОЎОе ОЏОЋОюОю ОљОцОЕОеОЋОф ОЕОЊОеОЋОњ Ою-Chrome Enterprise, ОљОЉОю ОЕОЮ ОћОъОЕОфОъОЕ ОЕОюОџ ОюОљ ОъОЕОЋОЎОџ ОюОЌОЕОЉОЋОЪ ОљОеОњОЋОаОЎ. ОЏОЊОЎ ОюОЎОдОЋОе ОЌОЕОЉОЋОЪ ОљОеОњОЋОаОЎ, ОЎОЕ ОюОћОЎОЏОаОА ОюОЏОфОЋОЉОф g.co/ChromeEnterpriseAccount ОЉОъОЏОЕОЎОе ОљОЌОе.</translation>
<translation id="6210282067670792090">ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉОъОДОЕ ОћОДОЎОдОЋОе ОћОќОћ ОЉОЕОЎОюОЋОЉ ОбОЮ ОДОЎОдОЋОеОЎ ОЊОеОџ ОюОъОаОЋОбОЎ ОЌОЎОцОЋОЕ ОЋОюОЌОЎОцОЋОЕ ОЉОљОфОеОЎОЮ.</translation>
<translation id="621172521139737651">{COUNT,plural, =0{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}=1{ОцОфОЎОЌОф ОћОЏОфОЋОЉОф ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}two{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}many{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}other{ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT}) ОЉ&amp;ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ}}</translation>
<translation id="6212039847102026977">ОћОдОњОф ОъОљОцОЎОЎОаОЎ ОеОЕОф ОъОфОДОЊОъОЎОЮ</translation>
<translation id="6212168817037875041">ОЏОЎОЉОЋОЎ ОћОъОАОџ</translation>
<translation id="6212752530110374741">ОЕОюОЎОЌОф ОДОЎОЕОЋОе ОЉОљОЎОъОЎОЎОю</translation>
<translation id="621470880408090483">РђЈОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОеОЎ Bluetooth</translation>
<translation id="6216601812881225442">РђЈОљОЎ ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОћОњОЋОЊОю ОЕОю ОћОДОЋОаОўОЎОЎОаОе. ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОаОцОЌ ОЕОъОЋОДОдОћ ОъОеОљОЕ Ою-Linux, ОЎОЕ ОюОњОЉОЋОф ОЋОюОљОЌОе ОъОЏОЪ ОюОЕОЌОќОе ОЉОДОЋОаОўОЎОЎОаОе ОЌОЊОЕ.</translation>
<translation id="6216696360484424239">ОЏОаОЎОАОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="6218058416316985984"><ph name="DEVICE_TYPE" /> ОюОљ ОъОЌОЋОЉОе ОюОеОЕОф. ОдОеОЎОџ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="6220413761270491930">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОўОбОЎОаОф ОфОЋОАОБ</translation>
<translation id="6223447490656896591">ОфОъОЋОаОћ ОъОЋОфОљОъОф ОљОЎОЕОЎОф:</translation>
<translation id="62236885217374510">{NUM_APPS,plural, =1{ОюОъОЌОЎОДОф ОћОљОцОюОЎОДОдОЎОћ}two{ОюОъОЌОЎОДОф ОћОљОцОюОЎОДОдОЎОЋОф}many{ОюОъОЌОЎОДОф ОћОљОцОюОЎОДОдОЎОЋОф}other{ОюОъОЌОЎОДОф ОћОљОцОюОЎОДОдОЎОЋОф}}</translation>
<translation id="6224481128663248237">ОћОцОеОъОЋОў ОћОАОфОЎОЎОЮ ОЉОћОдОюОЌОћ!</translation>
<translation id="622537739776246443">ОћОцОеОЋОцОЎОю ОЎОЎОъОЌОД</translation>
<translation id="6225475702458870625">ОЎОЕ ОЌОЎОЉОЋОе ОаОфОЋОаОЎОЮ ОќОъОЎОЪ ОЉ-<ph name="PHONE_NAME" /></translation>
<translation id="6226777517901268232">ОДОЋОЉОЦ ОъОцОфОЌ ОцОеОўОЎ (ОљОЋОцОдОЎОЋОаОюОЎ)</translation>
<translation id="6227002569366039565">ОъОДОЎОЕОЎОЮ ОбОю |<ph name="ACCELERATOR" />| ОЏОЊОЎ ОюОћОфОъОДОЊ ОЉОЉОЋОбОћ ОћОќОЋ, ОЋОъОДОЎОЕОЎОЮ ОЕОЋОЉ ОЏОЊОЎ ОюОћОфОъОДОЊ ОЉОеОЏОЎОЉ ОЕОљОюОЎОЋ ОћОЎОљ ОъОцОаОћ.</translation>
<translation id="6227280783235722609">ОфОЋОАОБ</translation>
<translation id="6229849828796482487">РђЈОаОЎОфОЋОД ОеОЕОф Оћ-Wi-Fi</translation>
<translation id="6230165830166519105">ОеОЋОдОћ ОюОаОАОЋОф ОЊОеОџ ОљОЌОеОф?</translation>
<translation id="6231782223312638214">ОъОЋОдОб</translation>
<translation id="6231881193380278751">РђЈОЎОЕ ОюОћОЋОАОЎОБ ОцОеОъОўОе ОЕОљОЎОюОфОћ ОЉОЏОфОЋОЉОф ОћОљОфОе ОЏОЊОЎ ОюОеОбОаОЪ ОљОф ОћОЊОБ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ: chrome://device-log/?refresh=&lt;sec&gt;</translation>
<translation id="6232017090690406397">ОАОЋОюОюОћ</translation>
<translation id="6232116551750539448">ОћОЌОЎОЉОЋОе ОљОю <ph name="NAME" /> ОаОЋОфОД</translation>
<translation id="6233154960150021497">ОЕОЎОъОЋОЕ ОЉОДОЋОю ОЉОъОДОЋОЮ ОЉОъОДОюОЊОф ОЏОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="6234108445915742946">РђЈОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОЕОю Chrome ОЎОЕОфОаОЋ ОЉ-31 ОЉОъОеОЦ</translation>
<translation id="6234474535228214774">ОћОћОфОДОаОћ ОЉОћОъОфОаОћ</translation>
<translation id="6235208551686043831">РђЈОћОъОдОюОъОћ ОЕОю ОћОъОЏОЕОЎОе ОцОЋОбОюОф. ОдОеОЎОџ ОюОъОДОЮ ОљОф ОДОЋОЊ Оћ-QR ОЕОю Оћ-eSIM ОъОЋОю ОћОъОдОюОъОћ.</translation>
<translation id="6237474966939441970">ОљОцОюОЎОДОдОЎОћ ОюОЏОфОЎОЉОф ОћОбОеОЋОф ОЉОбОќОеОф ОАОўОЎОЎОюОЋОА</translation>
<translation id="6237816943013845465">ОћОњОЊОеОћ ОќОЋ ОъОљОцОЕОеОф ОюОџ ОюОДОЉОЋОб ОљОф ОеОќОЋОюОЋОдОЎОЎОф ОћОъОАОџ</translation>
<translation id="6238624845858322552">РђЈОћОфОЌОЉОеОЋОф ОюОъОЏОЕОЎОе Bluetooth</translation>
<translation id="6238767809035845642">ОўОДОАОў ОЕОЕОЋОфОБ ОъОъОЏОЕОЎОе ОљОЌОе</translation>
<translation id="6238923052227198598">ОћОъОЕОџ ОћОдОњОф ОћОћОЋОЊОбОћ ОћОљОЌОеОЋОаОћ ОЉОъОАОџ ОћОаОбОЎОюОћ</translation>
<translation id="6239558157302047471">ОўОбОЎОаОф Оћ&amp;ОъОАОњОеОф ОъОЌОЊОЕ</translation>
<translation id="6240821072888636753">ОЎОЕ ОюОЕОљОЋОю ОЉОЏОю ОцОбОЮ</translation>
<translation id="6241530762627360640">РђЈОцОеОўОЎ ОњОЎОЕОћ ОЕОю ОъОЏОЕОЎОеОЎ Bluetooth ОћОъОЋОфОљОъОЎОЮ ОюОъОбОеОЏОф ОЕОюОџ ОЋОъОњОюОЎОЮ ОъОЏОЕОЎОеОЎ Bluetooth ОДОеОЋОЉОЎОЮ.</translation>
<translation id="6241844896329831164">ОљОЎОЪ ОдОЋОеОџ ОЉОњОЎОЕОћ</translation>
<translation id="6242574558232861452">ОћОъОбОеОЏОф ОЉОЋОЊОДОф ОљОЮ ОћОДОЋОЉОЦ ОбОЋОъОЊ ОЉОЊОеОЎОЕОЋОф ОЕОю ОъОЊОЎОаОЎОЋОф ОћОљОЉОўОЌОћ ОЕОю ОћОљОеОњОЋОЪ.</translation>
<translation id="6242589501614145408">ОљОЎОцОЋОА ОъОцОфОЌ ОћОљОЉОўОЌОћ ОЕОюОџ</translation>
<translation id="6242852299490624841">ОћОЊОњОЕОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ</translation>
<translation id="6243280677745499710">ОъОЋОњОЊОе ОбОЏОЕОЎОЋ</translation>
<translation id="6243774244933267674">ОћОЕОеОф ОљОЎОаОЋ ОќОъОЎОЪ</translation>
<translation id="6244245036423700521">РђЈОЎОЎОЉОЋОљ ОДОЋОЉОЦ ONC</translation>
<translation id="6246790815526961700">ОћОбОюОљОћ ОъОћОъОЏОЕОЎОе</translation>
<translation id="6247557882553405851">РђЈОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="6247620186971210352">ОюОљ ОаОъОдОљОЋ ОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="6247708409970142803">%<ph name="PERCENTAGE" /></translation>
<translation id="6247802389331535091">ОъОбОеОЏОф: <ph name="ARC_PROCESS_NAME" /></translation>
<translation id="624789221780392884">ОћОбОЊОЏОЋОЪ ОъОЋОЏОЪ</translation>
<translation id="6248988683584659830">ОЌОЎОцОЋОЕ ОЉОћОњОЊОеОЋОф</translation>
<translation id="6249200942125593849">ОаОЎОћОЋОю ОћОаОњОЎОЕОЋо╝Оф</translation>
<translation id="6250186368828697007">ОћОцОеОўОЎОЮ ОъОЋОАОфОеОЎОЮ ОЉОќОъОЪ ОЕОЎОфОЋОБ ОћОъОАОџ</translation>
<translation id="6251870443722440887">РђЈОъОќОћОЎОЮ ОЎОЎОЌОЋОЊОЎОЎОЮ ОЕОю GDI</translation>
<translation id="625369703868467034">ОфОДОЎОаОЋОф ОћОеОЕОф</translation>
<translation id="6254503684448816922">ОћОъОцОфОЌ ОЉОАОЏОаОћ</translation>
<translation id="6254892857036829079">ОъОЋОЕОюОЮ</translation>
<translation id="6257602895346497974">ОћОцОбОюОф ОАОаОЏОеОЋОЪ...</translation>
<translation id="62586649943626337">ОъОљОеОњОаОЎОЮ ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЉОљОъОдОбОЋОф ОДОЉОЋОдОЋОф ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="6262371516389954471">РђЈОћОњОЎОЉОЋОЎОЎОЮ ОаОЕОъОеОЎОЮ ОЉ-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОћОАОЎОАОъОћ ОЕОю ОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="6263082573641595914">РђЈОњОеОАОф ОеОЕОЋОф ОљОЎОЕОЋОеОЎОЮ ОЕОю Microsoft</translation>
<translation id="6263284346895336537">ОюОљ ОДОеОЎОўОЎ</translation>
<translation id="6264365405983206840">ОЉОЌОЎОеОф &amp;ОћОЏОЋОю</translation>
<translation id="6265687851677020761">ОћОАОеОф ОћОЎОдОЎОљОћ</translation>
<translation id="6266532094411434237">ОъОфОЉОдОбОф ОћОфОЌОЉОеОЋОф ОљОю <ph name="DEVICE" /></translation>
<translation id="6267166720438879315">ОЎОЕ ОюОЉОЌОЋОе ОљОЎОЕОЋОе ОЏОЊОЎ ОюОљОъОф ОљОф ОбОдОъОџ ОъОЋОю <ph name="HOST_NAME" /></translation>
<translation id="6268252012308737255">ОцОфОЎОЌОћ ОЉОљОъОдОбОЋОф <ph name="APP" /></translation>
<translation id="6270391203985052864">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОюОЕОюОЋОЌ ОћОфОеОљОЋОф</translation>
<translation id="6270770586500173387">ОЕОюОЎОЌОф <ph name="BEGIN_LINK1" />ОцОеОўОЎ ОъОбОеОЏОф ОЋОЎОЎОЕОЋОъОЎОЮ<ph name="END_LINK1" />, ОЏОъОЋ ОњОЮ <ph name="BEGIN_LINK2" />ОъОЊОЊОЎОЮ<ph name="END_LINK2" /></translation>
<translation id="6271348838875430303">ОћОфОЎОДОЋОЪ ОЉОЋОўОю</translation>
<translation id="6271780480930459892">ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф ОюОДОЉОюОф ОћОњОеОАОћ ОћОЌОЊОЕОћ ОЉОЎОЋОфОе.</translation>
<translation id="6272643420381259437">ОљОЎОеОбОћ ОЕОњОЎОљОћ (<ph name="ERROR" />) ОЉОъОћОюОџ ОћОЋОеОЊОф ОћОцОюОљОњОЎОЪ</translation>
<translation id="6273677812470008672">ОљОЎОЏОЋОф</translation>
<translation id="6274202259872570803">ОћОДОюОўОф ОъОАОџ</translation>
<translation id="6276210637549544171">РђЈОюОЕОеОф Оћ-proxy РђЈ<ph name="PROXY_SERVER" /> ОаОЊОеОЕОЎОЮ ОЕОЮ ОъОЕОфОъОЕ ОЋОАОЎОАОъОћ.</translation>
<translation id="6277105963844135994">ОфОЮ ОћОќОъОЪ ОћОДОдОЋОЉ ОюОфОцОЋОњОћ ОЕОю ОћОеОЕОф</translation>
<translation id="6277518330158259200">Од&amp;ОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="6278057325678116358">РђЈОЕОЎОъОЋОЕ ОЉ-GTK+Рђј</translation>
<translation id="6278428485366576908">ОбОЎОдОЋОЉ</translation>
<translation id="6278776436938569440">ОЕОЎОаОЋОЎ ОъОЎОДОЋОЮ</translation>
<translation id="6279183038361895380">ОЎОЕ ОюОћОДОЎОЕ ОбОю |<ph name="ACCELERATOR" />| ОЏОЊОЎ ОюОћОдОЎОњ ОљОф ОћОАОъОЪ</translation>
<translation id="6280215091796946657">ОЎОЕ ОюОћОЎОЏОаОА ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ ОљОЌОе</translation>
<translation id="6280912520669706465">ARC</translation>
<translation id="6282180787514676874">{COUNT,plural, =1{ОЌОеОњОф ОъОћОъОњОЉОюОћ ОЕОю ОњОЎОюОЎОЋОЪ ОаОЎОЎОе ОљОЌОЊ}two{ОЌОеОњОф ОъОћОъОњОЉОюОћ ОЕОю {COUNT} ОњОЎОюОЎОЋОаОЋОф ОаОЎОЎОе}many{ОЌОеОњОф ОъОћОъОњОЉОюОћ ОЕОю {COUNT} ОњОЎОюОЎОЋОаОЋОф ОаОЎОЎОе}other{ОЌОеОњОф ОъОћОъОњОЉОюОћ ОЕОю {COUNT} ОњОЎОюОЎОЋОаОЋОф ОаОЎОЎОе}}</translation>
<translation id="6283438600881103103">ОбОЏОЕОЎОЋ ОфОфОЉОдОб ОЎОдОЎОљОћ ОљОЋОўОЋОъОўОЎОф ОъОћОЌОЕОЉОЋОЪ.
ОЏОЊОЎ ОюОбОЉОЋОЊ ОбОЮ ОћОЊОЋОъОЎОЎОЪ <ph name="DOMAIN" />, ОдОеОЎОџ ОюОћОЕОљОЎОе ОљОф ОћОЏОеОўОЎОА ОћОЌОЏОЮ ОЉОцОаОЎОЮ.</translation>
<translation id="628352644014831790">4 ОЕОаОЎОЋОф</translation>
<translation id="6285120108426285413">ОћОЋОеОЊОф ОћОДОЋОЉОЦ <ph name="FILE_NAME" /> ОљОЎОаОћ ОаОцОЋОдОћ ОЋОћОЋОљ ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ.</translation>
<translation id="6285770818046456882">ОћОћОбОЉОеОћ ОЉОЋОўОюОћ ОЉОъОЏОЕОЎОе ОЕОъОЕОфОБ ОљОЎОфОџ</translation>
<translation id="6290613030083731160">ОљОЎОЪ ОъОЏОЕОЎОеОЎОЮ ОќОъОЎОаОЎОЮ ОЕОъОЕОфОцОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="6291086328725007688">ОъОфОЉОдОб ОљОЎОъОЋОф ОЕОю ОДОЋОЊ ОћОћОцОбОюОћ. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="6291741848715722067">ОДОЋОЊ ОљОЎОЕОЋОе</translation>
<translation id="6291949900244949761">РђЈОдОеОЎОџ ОюОЉОДОЕ ОъОъОаОЎ ОљОЎОЕОЋОе ОЏОЕОљОфОе ОеОЋОдОћ ОюОњОЕОф ОюОъОЏОЕОЎОеОЎ USB (ОъОЋОъОюОЦ)</translation>
<translation id="6291953229176937411">РђЈ&amp;ОћОдОњОћ ОЉ-Finder</translation>
<translation id="6292699686837272722">ОћОЏОеОўОЎОАОЎОЋОф ОЎОфОЏОЋОЋОдОЋ ОюОфОдОЋОњОћ ОЉОЎОаОЋОаОЎОф</translation>
<translation id="6294759976468837022">ОъОћОЎОеОЋОф ОћОАОеОЎОДОћ ОћОљОЋОўОЋОъОўОЎОф</translation>
<translation id="6295158916970320988">ОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="6295855836753816081">ОЉОфОћОюОЎОџ ОЕОъОЎОеОћ...</translation>
<translation id="629730747756840877">ОЌОЕОЉОЋОЪ</translation>
<translation id="6298962879096096191">РђЈОћОфОДОаОф ОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЉОљОъОдОбОЋОф Google Play</translation>
<translation id="6300177430812514606">ОюОљ ОъОЋОеОЕОЎОЮ ОюОАОЎОЎОЮ ОЕОюОЎОЌОћ ОљОЋ ОДОЉОюОћ ОЕОю ОаОфОЋОаОЎОЮ</translation>
<translation id="630065524203833229">ОЎОд&amp;ОЎОљОћ</translation>
<translation id="6300718114348072351">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОњОЊОЎОе ОљОф <ph name="PRINTER_NAME" /> ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ. ОЎОЕ ОюОДОЉОЋОб ОљОф ОћОћОњОЊОеОЋОф ОћОъОфОДОЊОъОЋОф ОЕОю ОћОъОЊОцОАОф. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="6301300352769835063">РђЈОъОфОЪ ОћОеОЕОљОћ Ою-Google ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ ОћОЌОЋОъОеОћ ОЏОЊОЎ ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОЕОю <ph name="DEVICE_OS" />. ОљОЮ ОюОљ ОъОбОаОЎОДОЎОЮ ОћОеОЕОљОћ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОбОЊОЎОЎОЪ ОаОЕОюОЌОЎОЮ ОљОю Google ОЏОЊОЎ ОюОДОЉОЋОб ОъОћОЮ ОћОбОЊОЏОЋОаОЎОЮ ОћОъОфОљОЎОъОЎОЮ, ОљОЉОю ОћОаОфОЋОаОЎОЮ ОюОљ ОаОЕОъОеОЎОЮ ОЋОюОљ ОаОбОЕОћ ОЉОћОЮ ОЕОЎОъОЋОЕ ОљОЌОе. ОъОЎОЊОб ОаОЋОАОБ ОќОъОЎОЪ ОЉОЏОфОЋОЉОф g.co/flex/HWDataCollection.</translation>
<translation id="630292539633944562">ОћОдОбОЋОф ОъОЎОЊОб ОљОЎОЕОЎ</translation>
<translation id="6305607932814307878">ОъОЊОЎОаОЎОЋОф ОњОюОЋОЉОюОЎОф:</translation>
<translation id="6307990684951724544">ОћОъОбОеОЏОф ОбОъОЋОАОћ</translation>
<translation id="6308493641021088955">ОћОЏОаОЎОАОћ ОъОЉОЋОдОбОф ОЉОбОќОеОф <ph name="EXTENSION_NAME" /></translation>
<translation id="6308937455967653460">ОЕОъОЎОеОф ОДОЎОЕОЋОе&amp; ОЉОЕОЮ...</translation>
<translation id="6309443618838462258">ОЕОЎОўОф ОћОДОюОў ОћОќОЋ ОюОљ ОъОљОЋОЕОеОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="630948338437014525">ОќОЎОЏОеОЋОаОЋОф</translation>
<translation id="6309510305002439352">ОћОъОЎОДОеОЋОцОЋОЪ ОъОЋОЕОЉОф</translation>
<translation id="6310141306111263820">РђЈОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОДОЎОЪ ОљОф ОцОеОЋОцОЎОю Оћ-eSim. ОбОюОЎОџ ОюОцОаОЋОф ОюОАОцОД ОюОДОЉОюОф ОбОќОеОћ.</translation>
<translation id="6311220991371174222">РђЈОюОљ ОаОЎОфОЪ ОюОћОцОбОЎОю ОљОф Chrome ОъОЏОЎОЋОЋОЪ ОЕОъОЕОћОЋ ОћОЕОфОЉОЕ ОЉОцОфОЎОЌОф ОћОцОеОЋОцОЎОю ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chrome.</translation>
<translation id="6312567056350025599">{NUM_DAYS,plural, =1{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ ОЎОЋОЮ ОљОЌОЊ}two{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ {NUM_DAYS} ОЎОъОЎОЮ}many{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ {NUM_DAYS} ОЎОъОЎОЮ}other{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ {NUM_DAYS} ОЎОъОЎОЮ}}</translation>
<translation id="6312638141433622592">ОћОъОбОеОЏОф ОъОдОЎОбОћ ОюОћОдОЎОњ ОъОљОъОеОЎОЮ ОЉОъОдОЉ ОДОЋОеОљ, ОЏОЕОЎОЕ ОфОъОЎОЏОћ ОЉОљОцОЕОеОЋОф ОћОќОЋ</translation>
<translation id="6313641880021325787">РђЈОЎОдОЎОљОћ Оъ-VR</translation>
<translation id="6313950457058510656">ОЏОЎОЉОЋОЎ ОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎ ОЉОЎОЪ ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="6314819609899340042">ОћОцОбОюОф ОЉОћОдОюОЌОћ ОфОЏОЋОаОЋОф ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОъОЏОЕОЎОе <ph name="IDS_SHORT_PRODUCT_NAME" /> ОќОћ.</translation>
<translation id="6315493146179903667">ОћОЉОљОф ОћОЏОЋОю ОюОЌОќОЎОф</translation>
<translation id="6316432269411143858">РђЈОфОЋОЏОЪ ОћОфОаОљОЎОЮ ОЕОю Google ChromeOS</translation>
<translation id="6317369057005134371">ОЉОћОъОфОаОћ ОюОЌОюОЋОЪ ОћОЎОЎОЕОЋОЮ...</translation>
<translation id="6318125393809743217">РђЈОћОЏОюОюОћ ОЕОю ОДОЋОЉОЦ policies.json ОбОЮ ОћОњОЊОеОЋОф ОћОъОЊОЎОаОЎОЋОф.</translation>
<translation id="6318407754858604988">ОћОћОЋОеОЊОћ ОћОфОЌОЎОюОћ</translation>
<translation id="6318944945640833942">ОюОљ ОљОЋОфОеОћ ОъОЊОцОАОф. ОЎОЕ ОюОћОќОЎОЪ ОЕОЋОЉ ОљОф ОЏОфОЋОЉОф ОћОъОЊОцОАОф.</translation>
<translation id="6321407676395378991">ОћОцОбОюОф ОЕОЋОъОе ОъОАОџ</translation>
<translation id="6322370287306604163">ОЉОЎОўОЋОю ОаОбОЎОюОћ ОъОћОЎОе ОЎОЋОфОе ОЉОљОъОдОбОЋОф ОўОЉОЎОбОф ОљОдОЉОб</translation>
<translation id="6322559670748154781">ОЉОЊОеОџ ОЏОюОю ОюОљ ОъОЋОеОЎОЊОЎОЮ ОљОф ОћОДОЋОЉОЦ ОћОќОћ ОЋОюОЏОЪ ОћОЋОљ ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОћОћОњОаОћ ОћОъОфОДОЊОъОф</translation>
<translation id="6324916366299863871">ОбОеОЎОЏОф ОДОЎОдОЋОе ОЊОеОџ</translation>
<translation id="6325191661371220117">ОћОЕОЉОфОф ОћОцОбОюОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="6326175484149238433">РђЈОћОАОеОћ Оъ-Chrome</translation>
<translation id="6326855256003666642">РђЈОАОцОЎОеОф Keepalive</translation>
<translation id="6327785803543103246">РђЈОњОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЕОю ОЕОеОф proxy ОЉОљОЎОаОўОеОаОў</translation>
<translation id="6331818708794917058">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОћОфОЌОЉОе ОљОю ОъОЏОЕОЎОеОЎ MIDI</translation>
<translation id="6333064448949140209">РђЈОћОДОЋОЉОЦ ОЎОЎОЕОюОЌ ОљОю Google ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ</translation>
<translation id="6335920438823100346">РђЈОЏОЊОЎ ОюОћОцОбОЎОю ОљОф Linux, ОбОюОЎОџ ОюОњОЉОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЋОюОљОцОА ОљОф Оћ-Chromebook ОћОќОћ ОюОћОњОЊОеОЋОф ОћОъОДОЋОеОЎОЋОф ОбОю ОцОЎ ОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />.</translation>
<translation id="6336038146639916978">РђЈОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB ОћОЋОЕОЉОф ОбОю-ОЎОЊОЎ <ph name="MANAGER" />. ОцОбОЋОюОћ ОќОЋ ОфОљОцОА ОљОф <ph name="DEVICE_TYPE" /> ОЉОфОЋОџ 24 ОЕОбОЋОф. ОЏОЊОљОЎ ОюОњОЉОЋОф ОДОЉОдОЎОЮ ОЕОЉОеОдОЋОаОџ ОюОЕОъОЋОе.</translation>
<translation id="6338981933082930623">ОЏОю ОљОфОе ОЎОЏОЋОю ОюОћОдОЎОњ ОюОџ ОЏОю ОъОЋОЊОбОћ</translation>
<translation id="6339668969738228384">ОЎОдОЎОеОф ОцОеОЋОцОЎОю ОЌОЊОЕ ОЉОЕОЉОЎОю <ph name="USER_EMAIL_ADDRESS" /></translation>
<translation id="6340071272923955280">РђЈОцОеОЋОўОЋОДОЋОю ОћОЊОцОАОћ ОЉОљОЎОаОўОеОаОў (IPPS)</translation>
<translation id="6340526405444716530">ОћОфОљОъОћ ОљОЎОЕОЎОф</translation>
<translation id="6341850831632289108">ОюОќОћОЋОф ОљОф ОћОъОЎОДОЋОЮ ОћОцОЎОќОЎ ОЕОюОџ</translation>
<translation id="6342069812937806050">ОќОћ ОбОфОћ</translation>
<translation id="6343003829431264373">ОеОД ОЊОцОЎОЮ ОбОЮ ОъОАОцОеОЎОЮ ОќОЋОњОЎОЎОЮ</translation>
<translation id="6344170822609224263">ОњОЎОЕОћ ОюОеОЕОЎОъОф ОћОЌОЎОЉОЋОеОЎОЮ ОюОеОЕОф</translation>
<translation id="6344576354370880196">ОъОЊОцОАОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="6345418402353744910">РђЈОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОЕОЮ ОћОъОЕОфОъОЕ ОЋОћОАОЎОАОъОћ ОЕОюОџ ОЏОЊОЎ ОЕОъОаОћОю ОъОбОеОЏОф ОЎОЋОЏОю ОюОћОњОЊОЎОе ОљОф ОћОеОЕОф ОЕОюОџ ОЉОЕОеОф Оћ-proxy <ph name="PROXY" /></translation>
<translation id="6345878117466430440">ОАОЎОъОЋОЪ ОЏОцОеОЎОў ОЕОаОДОеОљ</translation>
<translation id="6347010704471250799">ОћОдОњОф ОћОфОеОљОћ</translation>
<translation id="6349101878882523185">ОћОфОДОаОф <ph name="APP_NAME" /></translation>
<translation id="6351383110065274390">РђЈОаОћОаОЎОЮ ОъОъОЕОЌОДОЎОЮ ОЉ-Chromebook</translation>
<translation id="6354918092619878358">РђЈОбОДОЋОъОћ ОљОюОЎОцОўОЎОф SECG ОъОАОЋОњ secp256r1 (ОъОЋОЏОеОф ОњОЮ ОЉОЕОЮ ANSI X9.62 prime256v1РђЈ, NIST P-256)</translation>
<translation id="6355789186038748882">ОЊОцОЊОцОЪ ОаОЎОАОЎОЋОаОЎ (ОЉОљОЎОЏОЋОф ОљОюОцОљ)! ОЏОъОћ ОъОћОфОЏОЋОаОЋОф ОЌОАОеОЋОф ОљОЋ ОЌОюОДОЎОЋОф. ОљОцОЕОе ОюОЊОЋОЋОЌ ОбОю ОЉОбОЎОЋОф ОЊОеОџ 'ОбОќОеОћ' &gt; "ОЊОЎОЋОЋОЌ ОбОю ОЉОбОЎОћРђд".</translation>
<translation id="635609604405270300">ОљОЎОЪ ОюОЏОЉОЋОф ОљОф ОћОъОЏОЕОЎОе</translation>
<translation id="63566973648609420">РђЈОеОД ОъОЎ ОЕОЎОЋОЊОб ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЎОЏОЋОю ОюОДОеОЋОљ ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОЋОдОцОаОЎОЮ. ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОюОљ ОаОЕОюОЌ ОљОю Google ОЋОћОЎОљ ОљОЎОаОћ ОъОљОЌОАОаОф ОљОЋОфОЋ. ОљОЮ ОюОљ ОќОЋОЏОеОЎОЮ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОљОЮ ОеОЋОдОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, ОЎОЕ <ph name="BEGIN_LINK" />ОюОљОцОА ОљОф ОћОАОаОЏОеОЋОЪ<ph name="END_LINK" />.</translation>
<translation id="6357305427698525450">ОЌОюОД ОъОћОДОЎОЕОЋОеОЎОЮ ОћОаОфОъОЏОЎОЮ ОЎОъОЕОЎОЏОЋ ОюОћОЎОцОфОЌ ОЉ-<ph name="APP_NAME" /> ОљОЋ ОЉ-<ph name="APP_NAME_2" />.</translation>
<translation id="6358884629796491903">ОЊОеОДОЋОЪ</translation>
<translation id="6361470537267923629">ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЕОюОџ ОЉОЏОю ОъОЏОЕОЎОе. ОћОЪ ОаОЕОъОеОЋОф ОЉ<ph name="GOOGLE_PASSWORD_MANAGER" /> ОЉОЌОЕОЉОЋОЪ <ph name="EMAIL" />.</translation>
<translation id="6361850914223837199">ОцОеОўОЎ ОћОЕОњОЎОљОћ:</translation>
<translation id="6362853299801475928">&amp;ОЊОЎОЋОЋОЌ ОбОю ОЉОбОЎОћ...</translation>
<translation id="6363786367719063276">ОћОдОњОф ОћОЎОЋОъОаОЎОЮ</translation>
<translation id="6363990818884053551">ОЏОЊОЎ ОюОћОфОЌОЎОю ОЉОАОаОЏОеОЋОЪ ОбОюОЎОџ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="6365069501305898914">Facebook</translation>
<translation id="6365411474437319296">ОћОЋОАОцОф ОЉОаОЎ ОъОЕОцОЌОћ ОЋОЌОЉОеОЎОЮ</translation>
<translation id="6367097275976877956">РђЈОеОЋОдОћ ОюОћОцОбОЎОю ОљОф ChromeVox, ОДОЋОеОљ ОћОъОАОџ ОћОъОЋОЉОаОћ ОЕОю ChromeOS? ОљОЮ ОЏОЪ, ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОеОЋОЋОЌ.</translation>
<translation id="6367985768157257101">ОћОљОЮ ОюОДОЉОю ОЉОљОъОдОбОЋОф 'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ'?</translation>
<translation id="6368276408895187373">ОъОЋОцОбОюОф РђЊ <ph name="VARIATION_NAME" /></translation>
<translation id="636850387210749493">РђЈОћОеОЕОъОћ Ою-Enterprise</translation>
<translation id="6370021412472292592">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОўОбОЋОЪ ОљОф ОћОъОаОЎОцОАОў.</translation>
<translation id="6374077068638737855">Iceweasel</translation>
<translation id="6374469231428023295">ОаОЎОАОЎОЋОЪ ОаОЋОАОБ</translation>
<translation id="6374635887697228982">ОеОЋОдОћ ОюОДОЉОю ОћОаОЌОЋОф?</translation>
<translation id="6377268785556383139">ОфОЋОдОљОћ ОљОЌОф ОЉОЕОЉОЎОю '<ph name="SEARCH_TEXT" />'</translation>
<translation id="6378392501584240055">РђЈОцОфОЎОЌОћ ОЉОеОЕОфОЋОф Оћ-Wi-Fi</translation>
<translation id="6380143666419481200">ОЉОАОЊОе, ОъОДОЋОЉОю ОбОюОЎОЎ</translation>
<translation id="6382616130475191723">ОЎОЕ ОћОеОЕОљОћ ОюОбОЎОЎОЪ ОЉ-<ph name="SITE_NAME" /> ОЋОюОЉОдОб ОЉОЋ ОЕОЎОаОЋОЎОЎОЮ</translation>
<translation id="6382958439467370461">ОљОЎОЪ ОДОЎОдОЋОеОЎ ОЊОеОџ ОЕОљОЎОаОЮ ОцОбОЎОюОЎОЮ</translation>
<translation id="638418309848716977">ОДОЎОЕОЋОеОЎОЮ ОаОфОъОЏОЎОЮ</translation>
<translation id="6384275966486438344">ОЕОЎОаОЋОЎ ОћОњОЊОеОЋОф ОћОЌОЎОцОЋОЕ ОЕОюОџ Ою: <ph name="SEARCH_HOST" /></translation>
<translation id="63849924261838903">{NUM_TABS,plural, =1{ОДОЉОЋОдОћ ОюОюОљ ОЕОЮ РђЊ ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}two{ОДОЉОЋОдОћ ОюОюОљ ОЕОЮ РђЊ # ОЏОеОўОЎОАОЎОЋОф}many{ОДОЉОЋОдОћ ОюОюОљ ОЕОЮ РђЊ # ОЏОеОўОЎОАОЎОЋОф}other{ОДОЉОЋОдОћ ОюОюОљ ОЕОЮ РђЊ # ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="6385149369087767061">ОЎОЕ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў ОЋОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="6385543213911723544">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЕОъОЋОе ОЋОюОДОеОЋОљ ОаОфОЋОаОЎОЮ ОЕОю ОДОЋОЉОдОЎ cookie</translation>
<translation id="6385599849914981574">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОћОЏОЎОю ОъОЎОЊОб ОЏОъОЋ ОћОфОЏОЋОаОЋОф ОЕОъОЕОъОЕОЋОф ОљОЋОфОџ ОЋОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОЕОю ОъОЏОЕОЎОе Chrome. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОбОЉОЋОе ОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.<ph name="END_PARAGRAPH3" />
    <ph name="BEGIN_PARAGRAPH4" />ОљОЮ ОЉОбОю ОћОъОЏОЕОЎОе ОъОцОбОЎОю ОљОф ОћОљОцОЕОеОЋОф 'ОЕОюОЎОЌОф ОъОЎОЊОб ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ', ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЊОЋОЌОЋОф ОћОДОеОЎОАОћ ОЎОЋОбОюОЋ ОљОю Google.<ph name="END_PARAGRAPH3" /></translation>
<translation id="6385994920693662133">РђЈОљОќОћОеОћ - ОћОеОЎОЕОЋОЮ ОћОъОцОЋОеОў ОцОЋОбОю. ОЎОЋОъОаОЎ ОћОеОЎОЕОЋОЮ ОЕОЉОћОъОЕОџ ОбОЕОЋОЎОЎОЮ ОюОЏОюОЋОю ОЏОфОЋОЉОЋОф URL ОљОЋ ОъОЎОЊОб ОеОњОЎОЕ ОљОЌОе. ОЎОЕ ОюОбОЎОЎОЪ ОЉОћОЮ ОЏОЊОЎ ОюОЋОЋОЊОљ ОЕОљОЎОЪ ОюОџ ОЉОбОЎОћ ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОќОћ.</translation>
