<translation id="3030311804857586740">{NUM_DAYS,plural, =1{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОћОЋОеОЎОЊ ОбОЊОЏОЋОЪ ОћОЎОЋОЮ. ОћОЋОеОЊОф ОћОбОЊОЏОЋОЪ ОфОфОЉОдОб ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОЌОЎОЉОЋОе ОћОЉОљ ОюОљОЎОаОўОеОаОў.}two{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОћОЋОеОЎОЊ ОбОЊОЏОЋОЪ ОюОцОаОЎ ОћОъОЋОбОЊ ОћОљОЌОеОЋОЪ. ОћОЋОеОЊОф ОћОбОЊОЏОЋОЪ ОфОфОЉОдОб ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОЌОЎОЉОЋОе ОћОЉОљ ОюОљОЎОаОўОеОаОў.}many{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОћОЋОеОЎОЊ ОбОЊОЏОЋОЪ ОюОцОаОЎ ОћОъОЋОбОЊ ОћОљОЌОеОЋОЪ. ОћОЋОеОЊОф ОћОбОЊОЏОЋОЪ ОфОфОЉОдОб ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОЌОЎОЉОЋОе ОћОЉОљ ОюОљОЎОаОўОеОаОў.}other{ОюОцОЎ ОћОЊОеОЎОЕОћ ОЕОю <ph name="MANAGER" />, ОбОюОЎОџ ОюОћОЋОеОЎОЊ ОбОЊОЏОЋОЪ ОюОцОаОЎ ОћОъОЋОбОЊ ОћОљОЌОеОЋОЪ. ОћОЋОеОЊОф ОћОбОЊОЏОЋОЪ ОфОфОЉОдОб ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОЌОЎОЉОЋОе ОћОЉОљ ОюОљОЎОаОўОеОаОў.}}</translation>
<translation id="3030967311408872958">ОъОћОЕОДОЎОбОћ ОЋОбОЊ ОюОќОеОЎОЌОћ</translation>
<translation id="3031417829280473749">РђЈОАОЋОЏОаОф X</translation>
<translation id="3031557471081358569">ОЎОЕ ОюОЉОЌОЋОе ОцОеОЎОўОЎОЮ ОюОЎОЎОЉОЋОљ:</translation>
<translation id="3033348223765101500">ОЏОџ ОљОцОЕОе ОюОЕОюОЋОў ОЉОаОфОЋОаОЎОЮ ОЕОюОџ</translation>
<translation id="3034627908241330765">РђЈОъОфОаОћОю ОфОћОюОЎОџ ОћОњОЊОеОћ ОаОЋОАОБ ОЕОю Steam. ОюОцОаОЎ ОЕОъОцОбОЎОюОЎОЮ ОЕОЋОЉ ОљОф ОћОћОњОЊОеОћ, ОдОеОЎОџ ОюОћОъОфОЎОЪ ОЕОфОћОюОЎОџ ОћОћОњОЊОеОћ ОЎОЋОЕОюОЮ.</translation>
<translation id="3036327949511794916">ОфОљОеОЎОџ ОћОЎОбОЊ ОюОћОЌОќОеОф ОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЌОюОБ.</translation>
<translation id="3036546437875325427">РђЈОћОцОбОюОф Flash</translation>
<translation id="3037754279345160234">ОљОЎ ОљОцОЕОе ОюОаОфОЌ ОљОф ОћОфОдОЋОеОћ ОЏОЊОЎ ОюОћОдОўОеОБ ОюОЊОЋОъОЎОЎОЪ. ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф.</translation>
<translation id="3038612606416062604">ОћОЋОАОцОћ ОЎОЊОаОЎОф ОЕОю ОъОЊОцОАОф</translation>
<translation id="3039491566278747710">ОћОфОДОаОф ОћОъОЊОЎОаОЎОЋОф ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ ОЉОъОЏОЕОЎОе ОаОЏОЕОюОћ.</translation>
<translation id="3043218608271070212"><ph name="GROUP_NAME" /> РђЊ <ph name="GROUP_CONTENT_STRING" /></translation>
<translation id="3043581297103810752">Оъ-<ph name="ORIGIN" /></translation>
<translation id="304499331062371949">ОљОЎОЪ ОюОфОф ОћОеОЕОљОћ ОюОљОБ ОфОЋОАОБ ОюОДОеОЋОљ ОљОф ОћОљОфОе <ph name="SITE_NAME" /> ОЋОюОЕОаОЋОф ОљОЋОфОЋ</translation>
<translation id="3045447014237878114">ОћОљОфОе ОћОќОћ ОћОЋОеОЎОЊ ОДОЉОдОЎОЮ ОъОеОЋОЉОЎОЮ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
