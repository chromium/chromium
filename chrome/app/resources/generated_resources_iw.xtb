<translation id="7405938989981604410">{NUM_HOURS,plural, =1{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ ОЕОбОћ}two{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ {NUM_HOURS} ОЕОбОЋОф}many{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ {NUM_HOURS} ОЕОбОЋОф}other{ОЉОЊОЎОДОф ОћОЉОўОЎОЌОЋОф ОцОбОюОћ ОюОцОаОЎ {NUM_HOURS} ОЕОбОЋОф}}</translation>
