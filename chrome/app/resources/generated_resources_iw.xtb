<translation id="2322622365472107569">ОЕОбОф ОћОАОЎОЋОЮ: <ph name="TIME" /></translation>
<translation id="2323018538045954000">РђЈОеОЕОфОЋОф Wi-Fi ОЕОъОЋОеОЋОф</translation>
<translation id="2325444234681128157">ОЕОъОЎОеОф ОАОЎОАОъОћ</translation>
<translation id="2326188115274135041">ОЎОЕ ОюОљОЕОе ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОЉОЎОўОЋОю ОћОаОбОЎОюОћ ОћОљОЋОўОЋОъОўОЎ</translation>
<translation id="2326931316514688470">&amp;ОўОбОЎОаОф ОћОљОцОюОЎОДОдОЎОћ ОъОЌОЊОЕ</translation>
<translation id="2327492829706409234">ОћОцОбОюОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="2327920026543055248">ОћОќОаОф ОфОЋ <ph name="CHARACTER" /> ОъОфОЋОџ <ph name="TOTAL" /></translation>
<translation id="2328561734797404498">ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЏОЕОЎОе ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-<ph name="APP_NAME" />.</translation>
<translation id="2328636661627946415">РђЈОЉОъОдОЉ ОцОеОўОЎ, ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie ОеОД ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ ОЉОљОфОе ОЕОюОћОЮ ОЉОюОЉОЊ. ОДОЋОЉОдОЎ cookie ОаОъОЌОДОЎОЮ ОЉОАОЎОЋОЮ ОћОАОЕОЪ ОћОцОеОўОЎ.</translation>
<translation id="2329597144923131178">ОЎОЕ ОюОћОЎОЏОаОА ОЏОЊОЎ ОюОДОЉОю ОњОЎОЕОћ ОљОю ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ, ОћОАОЎОАОъОљОЋОф ОЋОћОњОЊОеОЋОф ОаОЋОАОцОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОЉОеОЕОЋОфОџ.</translation>
<translation id="2330878972945412956">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОћОЏОЎОю ОъОЎОЊОб ОЏОъОЋ ОћОфОЏОЋОаОЋОф ОЕОъОЕОъОЕОЋОф ОљОЋОфОџ, ОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю, ОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЋОЕОњОЎОљОЋОф. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОЕОцОе ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю Google ОЋОЏОЪ ОЎОбОќОеОЋ ОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎОЮ ОЕОю Android.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОЕОю ОъОЏОЕОЎОе ChromeOS. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОљОЮ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф' ОцОЋОбОюОф ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОаОфОЋОаОЎОЮ ОЕОю Android ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОдОЎОњ ОљОЋ ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОЋОюОЕОаОЋОф ОљОф ОћОњОЊОеОЋОф ОћОЌОЕОЉОЋОЪ ОЉОЏОфОЋОЉОф account.google.com.<ph name="END_PARAGRAPH3" />
    <ph name="BEGIN_PARAGRAPH4" />ОљОЮ ОЉОбОю ОћОъОЏОЕОЎОе ОъОцОбОЎОю ОљОф ОћОљОцОЕОеОЋОф 'ОЕОюОЎОЌОф ОъОЎОЊОб ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОаОЎОфОЋОЌ ОћОЉОЎОдОЋОбОЎОЮ', ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЊОЋОЌОЋОф ОћОДОеОЎОАОћ ОЎОЋОбОюОЋ ОљОю Google.<ph name="END_PARAGRAPH3" /></translation>
<translation id="2332131598580221120">ОћОдОњОћ ОЉОЌОаОЋОф</translation>
<translation id="2332192922827071008">ОцОфОЎОЌОф ОћОћОбОЊОцОЋОф</translation>
<translation id="2332515770639153015">ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОъОЋОцОбОюОф</translation>
<translation id="2332742915001411729">ОљОЎОцОЋОА ОюОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="2332948465534020594">ОъОдОЉ 'ОаОљ ОюОљ ОюОћОцОеОЎОб' ОцОЋОбОю</translation>
<translation id="233471714539944337">ОфОЋОЏОЪ ОеОњОЎОЕ</translation>
<translation id="2335111415680198280">{0,plural, =1{ОАОњОЎОеОф ОЌОюОЋОЪ ОљОЌОЊ (#)}two{ОАОњОЎОеОф # ОЌОюОЋОаОЋОф}many{ОАОњОЎОеОф # ОЌОюОЋОаОЋОф}other{ОАОњОЎОеОф # ОЌОюОЋОаОЋОф}}</translation>
<translation id="2335122562899522968">РђЈОЊОБ ОќОћ ОъОњОЊОЎОе ОДОЋОЉОдОЎ Cookie.</translation>
<translation id="2336228925368920074">ОЎОдОЎОеОф ОАОЎОъОаОЎОЎОћ ОюОЏОю ОћОЏОеОўОЎОАОЎОЋОф...</translation>
<translation id="2336376423977300504">РђЈОаОЎОДОЋОЎ ОДОЋОЉОдОЎ cookie ОЉОЏОю ОцОбОЮ ОЕОЌОюОЋОаОЋОф ОаОАОњОеОЎОЮ</translation>
<translation id="2336381494582898602">ОЕОЌОќОЋОе ОћОњОЊОеОЋОф ОЎОдОеОЪ</translation>
<translation id="2337236196941929873">РђЈОЊОцОЊОцОЪ Chrome ОЎОўОбОЪ ОъОеОљОЕ ОЊОцОЎОЮ ОЕОАОЉОЎОе ОЕОЎОЎОбОЕОћ ОЉОћОЮ ОЕОЎОъОЋОЕ. ОЏОЊОЎ ОюОЉОдОб ОљОф ОћОцОбОЋОюОћ, ОЊОцОЊОцОЪ Chrome ОбОЕОЋОЎ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie (ОљОЮ ОЉОЌОеОф ОюОљОцОЕОе ОљОЋОфОЮ), ОЋОбОЕОЋОЎ ОњОЮ ОюОћОдОцОЎОЪ ОЋОюОЕОюОЋОЌ ОЊОцОЎОЮ ОЊОеОџ Google, ОЏОџ ОЕОћОќОћОЋОф ОЕОюОџ ОфОЋОАОфОе ОъОцОаОЎ ОљОфОеОЎОЮ.</translation>
<translation id="2340239562261172947">ОюОљ ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОф <ph name="FILE_NAME" /> ОЉОдОЋОеОћ ОъОљОЋОЉОўОЌОф</translation>
<translation id="2342180549977909852">ОюОЎОюОЊ ОљОЋ ОюОЎОюОЊОћ ОЕОюОџ ОЎОЕ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОъОАОцОе (ОДОЋОЊ ОљОЎОъОЋОф) ОЉОъОДОЋОЮ ОЉОАОЎОАОъОћ ОЏОЊОЎ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе ОћОќОћ. ОаОЎОфОЪ ОюОћОњОЊОЎОе ОљОф ОћОДОЋОЊ ОъОљОЋОЌОе ОЎОЋОфОе ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="2342740338116612727">ОАОЎОъОаОЎОЋОф ОаОЋОАОцОЋ</translation>
<translation id="2343747224442182863">ОћОЊОњОЕОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ</translation>
<translation id="2344032937402519675">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОЕОеОф. ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОеОЕОф ОЋОюОаОАОЋОф ОЕОЋОЉ. ОљОЮ ОћОЉОбОЎОћ ОаОъОЕОЏОф, ОЏОЊОљОЎ ОюОаОАОЋОф ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Оћ-Chromebook.</translation>
<translation id="2345723121311404059">ОбОъОЋОЊ ОљОЌОЊ ОљОю <ph name="PRINTER_NAME" /></translation>
<translation id="23463457491630512">ОюОЊОЋОњОъОћ, ОљОЮ ОЉОЎОДОеОф ОЉОљОфОе ОЏОЊОЎ ОюОДОаОЋОф ОаОбОюОЎОЎОЮ ОюОъОеОфОЋОЪ, ОћОљОфОе ОбОЕОЋОЎ ОюОћОњОЊОЎОе 'ОеОЎОдОф ОъОеОфОЋОЪ' ОЏОфОЌОЋОЮ ОбОаОЎОЎОЪ ОЕОюОџ. ОюОљОЌОе ОъОЏОЪ, ОЉОЉОЎОДОЋОе ОЉОљОфОе ОЕОЋОаОћ, ОюОъОЕОю ОЏОЊОЎ ОюОћОЎОеОЕОЮ ОюОъОеОЋОЦ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОЋОдОњ ОюОџ ОъОЋОЊОбОћ ОюОаОбОюОЎ ОеОЎОдОћ ОбОю ОАОъОџ ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ.</translation>
<translation id="2348176352564285430">ОљОцОюОЎОДОдОЎОћ: <ph name="ARC_PROCESS_NAME" /></translation>
<translation id="2348729153658512593">РђЈ<ph name="WINDOW_TITLE" /> РђЊ ОаОЕОюОЌОћ ОЉОДОЕОф ОћОеОЕОљОћ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю Ctrl + 'ОДОЊОЎОъОћ' ОЏОЊОЎ ОюОћОЕОЎОЉ</translation>
<translation id="234889437187286781">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОъОћОюОџ ОўОбОЎОаОф ОћОаОфОЋОаОЎОЮ</translation>
<translation id="2349610121459545414">ОюОљОЕОе РђЊ ОћОљОфОе ОЎОъОЕОЎОџ ОюОДОЉОю ОњОЎОЕОћ ОюОъОЎОДОЋОЮ ОЕОюОџ</translation>
<translation id="2349896577940037438">РђЈОљОЮ ОћОЋОцОбОюОћ ОћОћОњОЊОеОћ 'ОцОбОЎОюОЋОф ОЉОљОцОюОЎОДОдОЎОЋОф ОЋОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОљОцОЕОе ОюОћОдОЎОњ ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ, ОюОъОЌОЋОД ОљОЋОфОЮ ОЋОюОЕОаОЋОф ОљОф ОћОњОЊОеОЋОф ОћОЌОЕОЉОЋОЪ ОЉОЏОфОЋОЉОф account.google.com.</translation>
<translation id="2350133097354918058">ОаОўОбОЪ ОъОЌОЊОЕ</translation>
<translation id="2350182423316644347">ОљОфОЌОЋОю ОћОЎОЎОЕОЋОЮ ОъОфОЉОдОб...</translation>
<translation id="235028206512346451">ОљОЮ ОъОфОеОЌОДОЎОЮ ОъОћОъОЏОЕОЎОе, ОћОъОАОџ ОаОаОбОю ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ. ОЏОЕОаОъОдОљОЎОЮ ОъОЋОю ОћОъОЏОЕОЎОе, ОћОъОАОџ ОюОљ ОаОЏОаОА ОюОъОдОЉ ОЕОЎОаОћ ОюОъОЕОџ ОЎОЋОфОе ОќОъОЪ. ОљОЮ ОюОљ ОъОЕОфОъОЕОЎОЮ ОЉОъОАОџ ОаОбОЎОюОћ, ОћОъОЏОЕОЎОе ОаОЏОаОА ОюОъОдОЉ ОЕОЎОаОћ ОЉОъОДОЋОЮ ОюОћОЎОаОбОю.</translation>
<translation id="2352495879228166246">{NUM_ITEMS,plural, =1{ОцОеОЎОў ОљОЌОЊ}two{{NUM_ITEMS} ОцОеОЎОўОЎОЮ}many{{NUM_ITEMS} ОцОеОЎОўОЎОЮ}other{{NUM_ITEMS} ОцОеОЎОўОЎОЮ}}</translation>
<translation id="2352662711729498748">РђЈ&lt; MBРђЈ 1</translation>
<translation id="2352810082280059586">ОћОбОеОЋОф ОЕОаОЏОфОЉОЋОф ОЏОЕОъОАОџ ОћОаОбОЎОюОћ ОцОЋОбОю ОаОЕОъОеОЋОф ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉ-<ph name="LOCK_SCREEN_APP_NAME" />. ОћОћОбОеОћ ОћОљОЌОеОЋОаОћ ОЕОЏОфОЉОф ОфОъОЕОЎОџ ОюОћОЋОцОЎОб ОЉОъОАОџ ОћОаОбОЎОюОћ.</translation>
<translation id="2353297238722298836">ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОЊОБ ОќОћ ОЉОъОдОюОъОћ ОЋОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="2355314311311231464">ОћОДОдОљОф ОћОъОЕОљОЉОЎОЮ ОаОЏОЕОюОћ ОъОљОЌОе ОЕОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОљОЌОќОе ОљОф ОцОеОўОЎ ОћОЌОЕОЉОЋОЪ ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ. ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="2355604387869345912">ОћОцОбОюОф ОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎ ОЉОЎОЪ ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="2356070529366658676">ОюОЕОљОЋОю</translation>
<translation id="2357330829548294574">ОћОАОеОћ ОЕОю <ph name="USER_NAME" /></translation>
<translation id="2358561147588818967">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉ-JavaScript</translation>
<translation id="2359071692152028734">РђЈОЎОЎОфОЏОЪ ОЕОљОцОюОЎОДОдОЎОЋОф Linux ОЎОцОАОЎОДОЋ ОюОћОњОЎОЉ.</translation>
<translation id="2359345697448000899">ОаОЎОћОЋОю ОћОфОЋОАОцОЎОЮ ОЕОюОџ ОбОю ОЎОЊОЎ ОюОЌОЎОдОћ ОбОю 'ОфОЋОАОцОЎОЮ' ОЉОфОцОеОЎОў ОЏОюОЎОЮ.</translation>
<translation id="2359556993567737338">РђЈОЌОЎОЉОЋОе ОћОфОДОЪ Bluetooth</translation>
<translation id="2359808026110333948">ОћОъОЕОџ</translation>
<translation id="2361100938102002520">ОЉОЌОеОф ОюОћОЋОАОЎОБ ОцОеОЋОцОЎОю ОъОаОЋОћОю ОюОЊОцОЊОцОЪ ОћОќОћ. ОюОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ ОЎОЕ ОЕОюОЎОўОћ ОбОю ОћОцОеОЋОцОЎОю ОЋОњОЎОЕОћ ОюОаОфОЋОаОЎОЮ ОЕОюОЋ.</translation>
<translation id="236117173274098341">ОљОЋОцОўОЎОъОЎОќОдОЎОћ</translation>
<translation id="2361340419970998028">ОћОъОЕОЋОЉ ОъОЎОЊ ОЎОЎОЕОюОЌРђд</translation>
<translation id="236141728043665931">ОфОъОЎОЊ ОюОЌОАОЋОЮ ОњОЎОЕОћ ОюОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="2363744066037724557">&amp;ОЕОЌОќОЋОе ОћОЌОюОЋОЪ</translation>
<translation id="2364498172489649528">ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОбОЉОеОЋ ОљОф ОћОЉОЊОЎОДОћ ОЉОћОдОюОЌОћ</translation>
<translation id="2365507699358342471">ОюОљОфОе ОћОќОћ ОЎОЕ ОњОЎОЕОћ ОљОю ОўОДОАОў ОЋОфОъОЋОаОЋОф ОЕОћОЋОбОфОДОЋ ОљОю ОюОЋОЌ ОћОбОеОЎОЏОћ.</translation>
<translation id="2367972762794486313">ОћОдОњОф ОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="236939127352773362">ОЉОќОъОЪ ОЕОЎОфОЋОБ ОъОъОЏОЕОЎОеОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ</translation>
<translation id="2371076942591664043">ОцОфОЎОЌОћ &amp;ОЉОАОЎОЋОЮ</translation>
<translation id="2373666622366160481">ОћОфОљОъОћ ОюОњОЋОЊОю ОћОаОЎОЎОе</translation>
<translation id="2375406435414127095">ОћОфОЌОЉОеОЋОф ОюОўОюОцОЋОЪ</translation>
<translation id="2377588536920405462">РђЈОЏОЊОЎ ОюОЏОЉОЋОф ОљОф ОћОъОЎОДОЋОЮ, ОбОюОЎОџ ОюОћОЕОЉОЎОф ОљОф ОћОћОњОЊОеОћ ОћОеОљОЕОЎОф ОЕОю ОћОъОЎОДОЋОЮ ОЉОъОЏОЕОЎОе ОЕОюОџ. ОЉОћОњОЊОеОЋОф ОћОъОЎОДОЋОЮ ОљОцОЕОе ОњОЮ ОюОћОЕОЉОЎОф ОљОф ОћОљОцОЕОеОЋОф ОюОћОАОфОъОџ ОбОю Wi-Fi, ОеОЕОфОЋОф ОАОюОЋОюОеОЎОЋОф ОЋОЌОЎОЎОЕОаОЎОЮ ОЏОЊОЎ ОюОДОЉОЋОб ОљОф ОћОъОЎОДОЋОЮ.</translation>
<translation id="2377667304966270281">ОЕОњОЎОљОЋОф ОЌОъОЋОеОЋОф</translation>
<translation id="237828693408258535">ОюОфОеОњОЮ ОљОф ОћОЊОБ ОћОќОћ?</translation>
<translation id="2378982052244864789">ОЉОЌОе ОљОф ОАОцОеОЎОЎОф ОћОћОеОЌОЉОћ.</translation>
<translation id="2379281330731083556">ОћОЊОцОАОћ ОЉОљОъОдОбОЋОф ОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОЕОю ОћОъОбОеОЏОф... <ph name="SHORTCUT_KEY" /></translation>
<translation id="2381499968174336913">ОфОдОЋОњОћ ОъОДОЊОЎОъОћ ОЕОю ОЏОеОўОЎОАОЎОЎОћ ОъОЕОЋОфОцОф</translation>
<translation id="2381756643783702095">ОЎОЕ ОюОЕОљОЋОю ОюОцОаОЎ ОћОЕОюОЎОЌОћ (ОъОЋОъОюОЦ)</translation>
<translation id="2386202302581016807">ОљОЎОЪ ОъОАОцОЎОД ОъОДОЋОЮ ОљОЌОАОЋОЪ ОцОаОЋОЎ ОюОћОЕОюОъОф ОћОћОњОЊОеОћ</translation>
<translation id="2387052489799050037">ОъОбОЉОе ОюОЊОБ ОћОЉОЎОф</translation>
<translation id="2387602571959163792"><ph name="DESK_NAME" /> (ОћОаОЋОЏОЌОЎ)</translation>
<translation id="2389775852302560582">РђЈОЏОфОЋОЉОф Оћ-IP</translation>
<translation id="2390347491606624519">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОЕОеОф proxy, ОЎОЕ ОюОћОЎОЏОаОА ОЕОЋОЉ</translation>
<translation id="2390782873446084770">РђЈОАОаОЏОеОЋОЪ Wi-Fi</translation>
<translation id="2391419135980381625">ОњОЋОцОЪ ОеОњОЎОю</translation>
<translation id="2392163307141705938">ОаОњОъОе ОћОќОъОЪ ОЕОћОћОЋОеОЎОЮ ОћОДОдОЋ ОюОџ ОЉ-<ph name="IDS_SHORT_PRODUCT_NAME" />.</translation>
<translation id="2392369802118427583">ОћОцОбОюОћ</translation>
<translation id="2393136602862631930">РђЈОћОњОЊОеОф ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОЉ-Chromebook</translation>
<translation id="2393313392064891208">РђЈОфОЋОЏОЪ ОћОфОаОљОЎОЮ ОЕОю Google ChromeOS Flex</translation>
<translation id="2395616325548404795">ОеОЎОЕОЋОЮ ОћОъОЏОЕОЎОе ОЕОюОџ <ph name="DEVICE_TYPE" /> ОюОаОЎОћОЋОю ОљОеОњОЋОаОЎ ОћОАОфОЎОЎОЮ ОЉОћОдОюОЌОћ, ОљОџ ОћОЕОюОЎОЌОћ ОЕОю ОцОеОўОЎ ОћОаОЏОА ОЋОћОъОЎОДОЋОЮ ОЕОюОЋ ОаОЏОЕОюОћ. ОЎОЕ ОюОћОќОЎОЪ ОљОф ОћОъОЎОЊОб ОћОќОћ ОЎОЊОаОЎОф ОЉОъОАОЋОБ ОћОаОЎОћОЋОю ОЕОю ОћОъОЏОЕОЎОе.</translation>
<translation id="2396783860772170191">ОЎОЕ ОюОћОќОЎОЪ ОДОЋОЊ ОљОЎОъОЋОф ОЉОЪ 4 ОАОцОеОЋОф (0000-9999)</translation>
<translation id="2398546389094871088">РђЈОЉОЎОдОЋОб Powerwash ОюОъОЏОЕОЎОе ОюОљ ОЎОАОЎОе ОљОф ОцОеОЋОцОЎОюОЎ Оћ-eSIM. ОЎОЕ ОюОбОЉОЋОе ОљОю Оћ<ph name="LINK_BEGIN" />ОћОњОЊОеОЋОф ОюОаОЎОЎОЊ<ph name="LINK_END" /> ОЏОЊОЎ ОюОћОАОЎОе ОљОф ОћОцОеОЋОцОЎОюОЎОЮ ОћОљОюОћ ОЉОљОЋОцОЪ ОЎОЊОаОЎ.</translation>
<translation id="2399699884460174994">ОћОћОфОеОљОЋОф ОцОЋОбОюОЋОф</translation>
<translation id="2399939490305346086">ОаОфОЋОаОЎ ОЏОаОЎОАОћ ОЉОъОцОфОЌ ОљОЉОўОЌОћ</translation>
<translation id="2400664245143453337">ОЊОеОЋОЕ ОбОЊОЏОЋОЪ ОъОЎОЊОЎ</translation>
<translation id="2406153734066939945">ОюОъОЌОЋОД ОљОф ОћОцОеОЋОцОЎОю ОћОќОћ ОЋОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОЋ?</translation>
<translation id="2408018932941436077">ОЕОъОЎОеОф ОћОЏОеОўОЎОА ОъОфОЉОдОбОф</translation>
<translation id="2408955596600435184">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф</translation>
<translation id="2409268599591722235">ОћОфОЌОю ОюОћОЕОфОъОЕ</translation>
<translation id="2410079346590497630">РђЈОцОеОўОЎ ОњОеОАОф Оћ-Build</translation>
<translation id="2410754283952462441">ОЉОЌОЎОеОф ОЌОЕОЉОЋОЪ</translation>
<translation id="241082044617551207">ОцОюОљОњОЎОЪ ОюОљ ОЎОЊОЋОб</translation>
<translation id="2412753904894530585">Kerberos</translation>
<translation id="2416435988630956212">ОъОДОЕОЎ ОцОЋОаОДОдОЎОћ ОЉОъОДОюОЊОф</translation>
<translation id="2419131370336513030">ОдОцОЎОЎОћ ОЉОљОцОюОЎОДОдОЎОЋОф ОћОъОЋОфОДОаОЋОф</translation>
<translation id="2419706071571366386">ОъОўОбОъОЎ ОљОЉОўОЌОћ, ОЎОЕ ОюОдОљОф ОъОћОЌОЕОЉОЋОЪ ОЏОЕОћОъОЌОЕОЉ ОюОљ ОЉОЕОЎОъОЋОЕ.</translation>
<translation id="2422125132043002186">РђЈОЕОЌОќОЋОе Linux ОЉОЋОўОю</translation>
<translation id="2423578206845792524">ОЕОъ&amp;ОЎОеОф ОфОъОЋОаОћ ОЉОЕОЮ...</translation>
<translation id="2424424966051154874">{0,plural, =1{ОъОдОЉ ОљОЋОеОЌ}two{ОъОдОЉ ОљОЋОеОЌ (#)}many{ОъОдОЉ ОљОЋОеОЌ (#)}other{ОъОдОЉ ОљОЋОеОЌ (#)}}</translation>
<translation id="2428510569851653187">ОЎОЕ ОюОфОљОе ОъОћ ОбОЕОЎОф ОюОцОаОЎ ОЕОћОЏОеОўОЎОАОЎОЎОћ ОДОеОАОћ</translation>
<translation id="2428939361789119025">РђЈОЏОЎОЉОЋОЎ Wi-Fi</translation>
<translation id="2428978615149723410">ОбОњОюОЋОф ОћОДОаОЎОЋОф ОћОљОюОћ</translation>
<translation id="2431027948063157455">РђЈОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОўОбОЋОЪ ОљОф Google Assistant. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОЌОЎОЉОЋОе ОћОеОЕОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="243179355394256322">РђЈОћОљОеОњОЋОЪ ОЕОюОџ ОъОфОЎОе ОеОД ОюОъОЕОфОъОЕОЎОЮ ОъОЋОеОЕОЎОЮ ОюОЕОЎОЎОџ ОъОЏОЕОЎОеОЎОЮ. ОъОЕОфОъОЕ ОќОћ ОљОЎОаОЋ ОъОЋОеОЕОћ ОюОЕОЎОЎОџ ОъОЏОЕОЎОеОЎОЮ. ОЎОЕ ОюОЋОЋОЊОљ ОЕОюОъОЕОфОъОЕ ОЎОЕ ОћОеОЕОљОф ОљОЊОъОЎОЪ ОъОАОЋОњ "ОЕОЎОЋОџ ОдОЎОЋОЊ Ою-Google Meet" ОЉОДОўОб 'ОъОЕОфОъОЕОЎОЮ' ОЕОю ОъОАОЋОБ Оћ-Admin.</translation>
<translation id="243275146591958220">ОЉОЎОўОЋОю ОћОћОЋОеОЊОћ</translation>
<translation id="2433452467737464329">РђЈОЎОЕ ОюОћОЋОАОЎОБ ОцОеОъОўОе ОЕОљОЎОюОфОћ ОЉОЏОфОЋОЉОф ОљОфОе ОюОеОЎОбОаОЋОЪ ОљОЋОўОЋОъОўОЎ ОЕОю ОћОЊОБ: chrome://network/?refresh=&lt;sec&gt;Рђј</translation>
<translation id="2433507940547922241">ОъОеОљОћ</translation>
<translation id="2433836460518180625">ОЉОЎОўОЋОю ОћОаОбОЎОюОћ ОЕОю ОћОъОЏОЕОЎОе ОЉОюОЉОЊ</translation>
<translation id="2434449159125086437">ОюОљ ОаОЎОфОЪ ОюОћОњОЊОЎОе ОљОф ОћОъОЊОцОАОф. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОфОдОЋОеОћ ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="2434758125294431199">ОљОаОЕОЎ ОДОЕОе ОюОЉОЌОЎОеОфОџ ОЕОЎОЋОЏОюОЋ ОюОЕОфОБ ОљОЎОфОџ</translation>
<translation id="2435137177546457207">РђЈОфОаОљОЎОЮ ОаОЋОАОцОЎОЮ ОЕОю Google Chrome ОЋ-ChromeOS Flex</translation>
<translation id="2435248616906486374">ОћОеОЕОф ОъОаОЋОфОДОф</translation>
<translation id="2435457462613246316">ОћОдОњОф ОАОЎОАОъОћ</translation>
<translation id="2439626940657133600"><ph name="WINDOW_TITLE" /> ОЉОўОбОЎОаОћ</translation>
<translation id="2440604414813129000">ОдОцОЎОЎОћ &amp;ОЉОъОДОЋОе</translation>
<translation id="2441719842399509963">ОљОцОА ОюОћОњОЊОеОЋОф ОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="244231003699905658">ОЏОфОЋОЉОф ОюОљ ОЌОЋОДОЎОф. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЏОфОЋОЉОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="2442916515643169563">ОдОюОюОЎОф ОўОДОАОў</translation>
<translation id="2443487764245141020">ОЎОЎОфОЏОЪ ОЕОњОЮ ОЉОљОфОеОЎОЮ ОЎОћОЎОћ ОдОЋОеОџ ОюОќОћОЋОф ОљОф ОћОъОЏОЕОЎОе ОЕОюОџ ОЉОљОъОдОбОЋОф ОъОќОћОћ</translation>
<translation id="244475495405467108">ОАОњОЎОеОф ОћОЏОеОўОЎОАОЎОЋОф ОъОЎОъОЎОЪ</translation>
<translation id="2445081178310039857">ОАОцОеОЎОЎОф ОћОЉОАОЎОА ОЕОю ОћОћОеОЌОЉОћ ОаОЌОЋОдОћ.</translation>
<translation id="2445484935443597917">ОЎОдОЎОеОф ОцОеОЋОцОЎОю ОЌОЊОЕ</translation>
<translation id="244641233057214044">ОДОЕОЋОе ОюОЌОЎОцОЋОЕ ОЕОюОџ</translation>
<translation id="2448312741937722512">ОАОЋОњ</translation>
<translation id="2448810255793562605">ОАОеОЎОДОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ</translation>
<translation id="2450223707519584812">РђЈОюОљ ОфОћОЎОћ ОљОцОЕОеОЋОф ОюОћОЋОАОЎОБ ОъОЕОфОъОЕОЎОЮ ОъОцОаОЎ ОЕОћОъОцОфОЌОЋОф ОЕОю Google API ОЌОАОеОЎОЮ. ОюОцОеОўОЎОЮ, ОЎОЕ ОюОбОЉОЋОе ОљОю <ph name="DETAILS_URL" />.</translation>
<translation id="2450849356604136918">ОљОЎОЪ ОфОдОЋОњОЋОф ОцОбОЎОюОЋОф</translation>
<translation id="2451298179137331965">2x</translation>
<translation id="245322989586167203">ОљОфОеОЎОЮ ОъОфОЌОЉОеОЎОЮ ОЉОЊОеОџ ОЏОюОю ОюОЎОдОЎОљОЋОф ОўОЋОеОЎОЋОф ОЏОЊОЎ ОюОфОъОЋОџ ОЉОфОЏОЋОаОЋОф ОЕОю ОћОбОЉОеОф ОаОфОЋОаОЎОЮ, ОЏОъОЋ ОћОњОЊОеОф ОћОеОЕОф</translation>
<translation id="2453706416476934374">РђЈОЏОЊОЎ ОюОДОЉОю ОфОЕОЋОЉОЋОф ОъОЋОфОљОъОЋОф ОљОЎОЕОЎОф ОюОЕОљОюОЋОф ОЕОю <ph name="SUPERVISED_USER_NAME" />, ОЏОЊОљОЎ ОюОфОф Ою-Assistant ОњОЎОЕОћ ОюОдОЎОюОЋОЮ ОЕОю ОфОЋОЏОЪ ОћОъОАОџ ОЕОю <ph name="SUPERVISED_USER_NAME" />. ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОъОЎОЊОб ОЎОЏОюОЋОю ОњОЮ ОцОеОўОЎОЮ ОбОю ОћОЕОЎОеОЎОЮ ОљОЋ ОбОю ОћОАОеОўОЋОаОЎОЮ ОЕОцОЋОбОюОЎОЮ.</translation>
<translation id="2453860139492968684">ОАОЎОЋОЮ</translation>
<translation id="2454206500483040640">ОЌОЋОюОДОЋ ОюОъОЌОЎОдОЋОф</translation>
<translation id="2454247629720664989">ОъОЎОюОф ОъОцОфОЌ</translation>
<translation id="2454264884354864965">ОћОъОдОюОъОћ ОЏОЉОЋОЎОћ</translation>
<translation id="2454524890947537054">ОюОљОЕОе ОљОф ОћОЉОДОЕОћ ОюОњОЉОЎ ОћОљОфОе?</translation>
<translation id="245650153866130664">ОЏОЊОЎ ОюОеОбОаОЪ ОЏОеОўОЎОА ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ, ОЎОЕ ОюОАОъОЪ ОљОф ОћОљОцОЕОеОЋОф "ОЕОъОЎОеОф ОАОЎОАОъОћ". ОћОАОЎОАОъОћ ОфОЎОЕОъОе ОЉОъОЏОЕОЎОе ОЕОюОџ ОЉОюОЉОЊ.</translation>
<translation id="2456827790665612305">ОЉОЎОўОЋОю ОћОъОбОДОЉ ОљОЌОеОЎ ОћОљОфОе</translation>
<translation id="2457246892030921239"><ph name="APP_NAME" /> ОеОЋОдОћ ОюОћОбОфОЎОД ОДОЉОдОЎОЮ Оъ-<ph name="VOLUME_NAME" />.</translation>
<translation id="2457842160081795172">ОЉОбОеОЋОЦ <ph name="CHANNEL_NAME" /> ОЏОеОњОб</translation>
<translation id="2458379781610688953">ОбОЊОЏОЋОЪ ОЌОЕОЉОЋОЪ, <ph name="EMAIL" /></translation>
<translation id="2458591546854598341">ОљОАОЎОъОЋОЪ ОаОЎОћОЋОю ОћОъОЏОЕОЎОе ОљОЎОаОЋ ОЌОЋОДОЎ.</translation>
<translation id="2459703812219683497">ОќОЋОћОћ ОДОЋОЊ ОћОцОбОюОћ</translation>
<translation id="2462724976360937186">ОъОќОћОћ ОъОцОфОЌ ОЕОю ОеОЕОЋОф ОљОЎОЕОЋОеОЎОЮ</translation>
<translation id="2462752602710430187">ОћОъОЊОцОАОф <ph name="PRINTER_NAME" /> ОаОЋОАОцОћ</translation>
<translation id="2467755475704469005">ОюОљ ОќОЋОћОћ ОъОЏОЕОЎОе. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="2468178265280335214">ОћОљОдОф ОњОюОЎОюОћ ОЉОюОЋОЌ ОъОњОб</translation>
<translation id="2468205691404969808">РђЈОЕОЎОъОЋОЕ ОЉОДОЋОЉОдОЎ cookie ОЏОЊОЎ ОюОЕОъОЋОе ОљОф ОћОћОбОЊОцОЋОф ОЕОюОџ, ОњОЮ ОљОЮ ОюОљ ОаОЏОаОАОф ОљОю ОћОЊОцОЎОЮ ОћОљОюОћ</translation>
<translation id="2468402215065996499">ОўОъОњОЋОд'ОЎ</translation>
<translation id="2468845464436879514">{NUM_TABS,plural, =1{<ph name="GROUP_TITLE" /> РђЊ ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}two{<ph name="GROUP_TITLE" /> РђЊ # ОЏОеОўОЎОАОЎОЋОф}many{<ph name="GROUP_TITLE" /> РђЊ # ОЏОеОўОЎОАОЎОЋОф}other{<ph name="GROUP_TITLE" /> РђЊ # ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="2469141124738294431">РђЈОАОўОўОЋОА Оћ-VM</translation>
<translation id="2469259292033957819">ОљОЎОЪ ОюОџ ОъОЊОцОАОЋОф ОЕОъОЋОеОЋОф.</translation>
<translation id="2469375675106140201">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОЉОЊОЎОДОф ОћОљОЎОЋОф</translation>
<translation id="247051149076336810">ОЏОфОЋОЉОф ОљОфОе ОЕОю ОћОфОДОЪ ОеОЕОф ОюОЕОЎОфОЋОБ ОДОЉОдОЎОЮ</translation>
<translation id="2470702053775288986">ОфОЋОАОцОЎОЮ ОЕОюОљ ОаОфОъОЏОЎОЮ ОћОЋОЕОЉОфОЋ</translation>
