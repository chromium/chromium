<translation id="413121957363593859">ОеОЏОЎОЉОЎОЮ</translation>
<translation id="4131410914670010031">ОЕОЌОЋОе ОЋОюОЉОЪ</translation>
<translation id="413193092008917129">ОфОеОЌОЎОЕОЎОЮ ОЕОю ОљОЉОЌОЋОЪ ОеОЕОф</translation>
<translation id="4132183752438206707">РђЈОЌОЎОцОЋОЕ ОљОцОюОЎОДОдОЎОЋОф ОЉОЌОаОЋОф Google Play</translation>
<translation id="4132364317545104286">РђЈОЕОЎОаОЋОЎ ОЕОЮ ОЕОю ОцОеОЋОцОЎОю eSIM</translation>
<translation id="4133076602192971179">ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОћ, ОЎОЕ ОюОцОфОЋОЌ ОљОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="4135746311382563554">РђЈОфОаОљОЎОЮ ОЋОћОњОЉОюОЋОф ОаОЋОАОцОЎОЮ ОЕОю Google Chrome ОЋ-ChromeOS</translation>
<translation id="4136203100490971508">ОфОљОЋОеОф ОћОюОЎОюОћ ОфОЏОЉОћ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОЕОбОф ОћОќОеОЎОЌОћ</translation>
<translation id="41365691917097717">РђЈОЉОЌОЎОеОћ ОюОћОъОЕОЎОџ ОфОњОеОЋОЮ ОюОћОцОбОюОф ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB ОЉОъОћОюОџ ОћОЎОдОЎОеОћ ОЋОћОЉОЊОЎОДОћ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Ою-Android. ОЌОЕОЋОЉ ОюОЕОЎОЮ ОюОЉ ОЕОћОцОбОЋОюОћ ОћОќОЋ ОъОљОцОЕОеОф ОљОф ОћОћОфОДОаОћ ОЕОю ОљОцОюОЎОДОдОЎОЋОф Ою-Android ОЕОюОљ ОљОЋОъОфОЋ ОбОю ОЎОЊОЎ Google. ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОћОфОЏОЋОаОћ, ОЎОЕ ОюОљОцОА ОљОф ОћОъОЏОЕОЎОе ОюОћОњОЊОеОЋОф ОћОъОДОЋОеОЎОЋОф.</translation>
<translation id="4138267921960073861">ОћОдОњОф ОЕОъОЋОф ОъОЕОфОъОЕОЎОЮ ОЋОфОъОЋОаОЋОф ОЉОъОАОџ ОћОЏОаОЎОАОћ</translation>
<translation id="4138598238327913711">ОЉОЕОюОЉ ОќОћ, ОЉОЊОЎОДОф ОћОЊОДОЊОЋОД ОќОъОЎОаОћ ОеОД ОЉОљОаОњОюОЎОф</translation>
<translation id="413915106327509564">РђЈ<ph name="WINDOW_TITLE" /> - ОћОфОДОЪ HID ОъОЌОЋОЉОе</translation>
<translation id="4139326893730851150">ОбОЊОЏОЋОаОЎ ОДОЋОЕОЌОћ</translation>
<translation id="4142052906269098341">ОљОцОЕОе ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю <ph name="DEVICE_TYPE" /> ОЉОбОќОеОф ОћОўОюОцОЋОЪ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="4142518881503042940">ОаОЎОфОЪ ОюОЕОъОЋОе ОљОф ОћОъОЊОцОАОЋОф ОЕОќОЋОћОЋ ОЉОцОеОЋОцОЎОю ОЕОюОџ ОљОЋ ОюОћОЋОАОЎОБ ОъОЊОцОАОф ОЌОЊОЕОћ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="4144218403971135344">ОЕОЎОцОЋОе ОљОЎОЏОЋОф ОћОЋОЋОЎОЊОљОЋ ОЋОЌОЎОАОЏОЋОЪ ОЉОЌОЎОЎ ОћОАОЋОюОюОћ. ОфОЋОЏОЪ ОЋОЎОЊОљОЋ ОЎОЋОцОбОю ОеОД ОЉОъОАОџ ОћОфОЋОъОџ ОЉОћОбОЉОеОћ.</translation>
<translation id="4144468798716165316">ОцОДОЋОЊОЋОф ОъОћОЎОеОЋОф</translation>
<translation id="4146026355784316281">ОцОфОЎОЌОћ ОфОъОЎОЊ ОЉОљОъОдОбОЋОф ОъОдОЎОњ ОћОъОбОеОЏОф</translation>
<translation id="4146785383423576110">ОљОЎОцОЋОА ОЋОаОЎОДОЋОЎ</translation>
<translation id="4147897805161313378">Google Photos</translation>
<translation id="4147911968024186208">ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ. ОљОЮ ОћОЕОњОЎОљОћ ОћОќОљОф ОъОъОЕОЎОЏОћ ОюОћОЋОцОЎОб, ОаОЎОфОЪ ОюОцОаОЋОф ОюОаОдОЎОњ ОћОфОъОЎОЏОћ.</translation>
<translation id="4150201353443180367">ОфОдОЋОњОћ</translation>
<translation id="4150569944729499860">ОћОДОЕОе ОъОАОџ</translation>
<translation id="4152670763139331043">{NUM_TABS,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}two{# ОЏОеОўОЎОАОЎОЋОф}many{# ОЏОеОўОЎОАОЎОЋОф}other{# ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="4154406342347435125">ОъОдОЉ ОЉОћОЎОе ОЉОќОеОЎОЌОћ ОЋОъОдОЉ ОЏОћОћ ОЉОЕОДОЎОбОћ. ОћОъОбОЉОе ОъОфОЉОдОб ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ.</translation>
<translation id="4154664944169082762">ОўОЉОЎОбОЋОф ОљОдОЉОб</translation>
<translation id="4157869833395312646">Microsoft Server Gated Cryptography</translation>
<translation id="4158364720893025815">ОћОдОюОЌОћ</translation>
<translation id="4159681666905192102">ОќОћОЋ ОЌОЕОЉОЋОЪ ОюОЎОюОЊОЎОЮ ОћОъОаОЋОћОю ОбОю-ОЎОЊОЎ <ph name="CUSTODIAN_EMAIL" /> ОЋОбОю-ОЎОЊОЎ <ph name="SECOND_CUSTODIAN_EMAIL" />.</translation>
<translation id="4163560723127662357">ОъОДОюОЊОф ОюОљ ОЎОЊОЋОбОћ</translation>
<translation id="4165942112764990069">РђЈОћОЌОЕОЉОЋОЪ <ph name="USER_EMAIL" /> ОюОљ ОЕОЎОЎОџ ОюОљОеОњОЋОЪ ОфОДОЎОЪ. ОЎОЕ ОюОцОаОЋОф ОљОю ОъОаОћОю ОћОъОбОеОЏОф. ОъОаОћОюОЎ ОъОбОеОЏОф ОЎОЏОЋОюОЎОЮ ОюОћОњОЊОЎОе ОљОф ОћОљОеОњОЋОЪ ОЕОюОћОЮ ОЉОЏОфОЋОЉОф: g.co/ChromeEnterpriseAccount</translation>
<translation id="4167393659000039775">РђЈGoogle ОюОљ ОљОЌОеОљОЎОф ОюОљОЋОЉОЊОЪ ОаОфОЋОаОЎОЮ, ОЋОЎОЎОфОЏОЪ ОЕОъОбОеОЏОф <ph name="DEVICE_OS" /> ОюОљ ОфОцОбОю ОЉОЊОњОъОЎОЮ ОЕОюОљ ОљОЋОЕОеОЋ. ОъОЎОЊОб ОаОЋОАОБ ОќОъОЎОЪ ОЉОЏОфОЋОЉОф g.co/flex/InstallGuide.</translation>
<translation id="4167686856635546851">РђЈОљОфОеОЎОЮ ОъОЕОфОъОЕОЎОЮ ОЉОЊОеОџ ОЏОюОю ОЉ-JavaScript ОЏОЊОЎ ОюОћОдОЎОњ ОфОЏОЋОаОЋОф ОљОЎОаОўОеОљОДОўОЎОЉОЎОЋОф, ОЏОъОЋ ОъОЕОЌОДОЎ ОЋОЎОЊОљОЋ ОљОЋ ОўОцОАОЎОЮ ОЉОеОЕОф</translation>
<translation id="4168015872538332605">ОЌОюОД ОъОћОћОњОЊОеОЋОф ОћОЕОЎОЎОЏОЋОф Ою-<ph name="PRIMARY_EMAIL" /> ОъОЕОЋОфОцОЋОф ОљОЎОфОџ. ОћОћОњОЊОеОЋОф ОћОљОюОћ ОъОЕОцОЎОбОЋОф ОбОю ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОеОД ОЉОбОф ОЕОЎОъОЋОЕ ОЉОЏОаОЎОАОћ ОбОЮ ОъОАОцОе ОЌОЕОЉОЋОаОЋОф.</translation>
<translation id="4168651806173792090"><ph name="NETWORK_NAME" /> ОћОъОАОфОЎОЎОЮ ОЉОАОцОеОЋОф <ph name="LAST_FOUR_DIGITS" /></translation>
<translation id="4170314459383239649">ОъОЌОЎОДОћ ОЉОЎОдОЎОљОћ</translation>
<translation id="417096670996204801">ОЉОЌОЎОеОф ОцОеОЋОцОЎОю</translation>
<translation id="4175137578744761569">ОАОњОЋОю ОЉОћОЎОе ОЋОюОЉОЪ</translation>
<translation id="4175737294868205930">ОљОЌОАОЋОЪ ОДОЉОЋОб</translation>
<translation id="4176463684765177261">ОъОЋОЕОЉОф</translation>
<translation id="4180788401304023883">РђЈОюОъОЌОЋОД ОљОф ОљОЎОЕОЋОе CA ОЕОю "<ph name="CERTIFICATE_NAME" />"?</translation>
<translation id="4181602000363099176">20x</translation>
<translation id="4181841719683918333">ОЕОцОЋОф</translation>
<translation id="4184803915913850597">РђЈОъОЏОЕОЎОе HID (<ph name="VENDOR_ID" />:<ph name="PRODUCT_ID" />)</translation>
<translation id="4187424053537113647">ОћОћОњОЊОеОћ ОЕОю <ph name="APP_NAME" /> ОъОфОЉОдОбОфРђд</translation>
<translation id="4190828427319282529">ОћОЊОњОЕОф ОъОЎОДОЋОЊ ОћОъОДОюОЊОф</translation>
<translation id="4193836101014293726">ОюОљ ОаОЎОфОЪ ОюОъОЌОЋОД ОљОф ОћОцОеОЋОцОЎОю ОћОќОћ</translation>
<translation id="419427585139779713">ОдОеОЎОџ ОюОћОќОЎОЪ ОЏОю ОћОЉОеОћ ОЉОаОцОеОЊ</translation>
<translation id="4194570336751258953">ОћОцОбОюОф ОћОљОцОЕОеОЋОф 'ОаОњОЎОбОћ ОДОюОћ'</translation>
<translation id="4195421689821407315">ОћОЋОеОЊОћ ОюОљ ОъОљОЋОЉОўОЌОф</translation>
<translation id="4195643157523330669">ОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="4195814663415092787">ОљОаОЎ ОеОЋОдОћ ОюОћОъОЕОЎОџ ОъОћОъОДОЋОЮ ОЕОЉОЋ ОћОцОАОДОфОЎ</translation>
<translation id="4198268995694216131">ОљОфОеОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="4200689466366162458">ОъОЎОюОЎОЮ ОъОЋОфОљОъОЋОф ОљОЎОЕОЎОф</translation>
<translation id="4200983522494130825">&amp;ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="4201546031411513170">ОљОцОЕОе ОюОЉОЌОЋОе ОъОћ ОюОАОаОЏОеОЪ ОЉОЏОю ОЕОюОЉ ОЊОеОџ ОћОћОњОЊОеОЋОф.</translation>
<translation id="420283545744377356">ОћОЕОЉОфОћ ОЕОю ОЕОЋОъОе ОћОъОАОџ</translation>
<translation id="4203065553461038553">ОЕОЮ ОћОДОЋОЉОЦ ОљОЋ ОћОаОфОЎОЉ ОЕОюОЋ ОљОеОЋОЏОЎОЮ ОъОЊОЎ</translation>
<translation id="4204851595694839599">РђЈОљОЎОџ ОћОЎОЎОфОћ ОћОЌОЋОЋОЎОћ ОЕОю ОъОћОюОџ ОћОъОЕОЌОД (gameplay)?</translation>
<translation id="4205157409548006256">РђЈОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОъОћОюОџ ОћОћОњОЊОеОћ ОЕОю Linux.</translation>
<translation id="4206144641569145248">ОЌОЎОЎОќОе</translation>
<translation id="4206323443866416204">ОЊОЋОЌ ОъОЕОЋОЉ</translation>
<translation id="4207522141889799150">ОбОеОЎОЏОћ ОЕОю ОћОеОЕОљОЋОф ОћОљОфОе <ph name="SITE" /></translation>
<translation id="4207932031282227921">РђЈОаОЕОюОЌОћ ОЉОДОЕОф ОћОеОЕОљОћ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю F6 ОЏОЊОЎ ОюОћОЕОЎОЉ</translation>
<translation id="4208390505124702064">ОЌОЎОцОЋОЕ ОЉ-<ph name="SITE_NAME" /></translation>
<translation id="4209092469652827314">ОњОЊОЋОю</translation>
<translation id="4209251085232852247">ОъОЋОЕОЉОф</translation>
<translation id="4210048056321123003">ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф</translation>
<translation id="421182450098841253">&amp;ОћОдОњОф ОљОф ОАОеОњОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="4211851069413100178">РђЈОЕОюОЎОЌОћ ОЕОю ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОбОю ОћОЕОЎОъОЋОЕ. ОљОцОЕОе ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОћОЌОЋОЋОЎОћ ОЉ-Android. ОюОЕОЮ ОЏОџ ОЎОЕ ОюОЕОюОЋОЌ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОЋОЉОљОцОюОЎОДОдОЎОЋОф. ОаОфОЋОаОЎОЮ ОљОюОћ ОЎОбОќОеОЋ ОюОЕОъОЋОе ОбОю ОЎОдОЎОЉОЋОф ОћОъОбОеОЏОф ОЋОћОљОцОюОЎОДОдОЎОЋОф, ОЏОъОЋ ОњОЮ ОюОЉОЎОдОЋОб ОЕОЎОцОЋОеОЎОЮ ОљОЌОеОЎОЮ. ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОћОаОдОЉОеОЎОЮ ОЎОбОќОеОЋ ОњОЮ ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЋОфОцОЎОЮ ОЕОю Google, ОЏОъОЋ ОъОцОфОЌОЎ Android. Оћ<ph name="BEGIN_LINK1" />ОћОњОЊОеОћ<ph name="END_LINK1" /> ОћОќОЋ ОаОљОЏОцОф ОбОю-ОЎОЊОЎ ОћОЉОбОюОЎОЮ. ОЎОЎОфОЏОЪ ОЕОћОЉОбОюОЎОЮ ОЎОЉОЌОеОЋ ОюОЕОюОЋОЌ ОљОю Google ОаОфОЋОаОЎ ОљОЉОЌОЋОЪ ОЋОаОфОЋОаОЎОЮ ОюОњОЉОЎ ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОћОќОћ. ОљОЮ ОћОЋОцОбОюОћ ОћОљОцОЕОеОЋОф 'ОцОбОЎОюОЋОф ОЉОљОфОеОЎ ОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОаОЋОАОцОЎОЮ', ОЎОЎОфОЏОЪ ОЕОћОаОфОЋОаОЎОЮ ОЎОЎОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. <ph name="BEGIN_LINK2" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK2" /></translation>
<translation id="4211904048067111541">РђЈОћОцОАОДОф ОћОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОЋОф Ою-Android</translation>
<translation id="42126664696688958">ОЎОЎОдОЋОљ</translation>
<translation id="42137655013211669">ОћОњОЎОЕОћ ОюОъОЕОљОЉ ОќОћ ОаОљОАОеОћ ОбОю-ОЎОЊОЎ ОћОЕОеОф.</translation>
<translation id="4217558091331485702">ОАОеОЎОДОћ ОюОцОаОЎ ОћОцОфОЎОЌОћ</translation>
<translation id="4217571870635786043">ОћОЏОфОЉОћ</translation>
<translation id="4218081191298393750">ОдОеОЎОџ ОюОюОЌОЋОЦ ОбОю ОАОъОю ОћОеОъОДОЋОю ОЏОЊОЎ ОюОћОЕОфОЎОД ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ</translation>
<translation id="4219558185499589032">Box</translation>
<translation id="4220648711404560261">ОДОеОфОћ ОЕОњОЎОљОћ ОЉОќОъОЪ ОћОћОцОбОюОћ.</translation>
<translation id="4225397296022057997">ОЉОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="4227605727325220318">РђЈОћОЋОАОцОф ОўОюОцОЋОЪ Android ОЌОЊОЕ</translation>
<translation id="4228209296591583948">{NUM_EXTENSIONS,plural, =1{ОљОАОЋОе ОюОћОфОДОЎОЪ ОљОф ОћОфОЋОАОБ ОћОќОћ}two{ОљОАОЋОе ОюОћОфОДОЎОЪ ОљОф ОЌОюОД ОъОћОфОЋОАОцОЎОЮ ОћОљОюОћ}many{ОљОАОЋОе ОюОћОфОДОЎОЪ ОљОф ОЌОюОД ОъОћОфОЋОАОцОЎОЮ ОћОљОюОћ}other{ОљОАОЋОе ОюОћОфОДОЎОЪ ОљОф ОЌОюОД ОъОћОфОЋОАОцОЎОЮ ОћОљОюОћ}}</translation>
<translation id="4231095370974836764">РђЈОаОЎОфОЪ ОюОћОфОДОЎОЪ ОљОцОюОЎОДОдОЎОЋОф ОЋОъОЕОЌОДОЎОЮ Оъ-Google Play ОЉ-<ph name="DEVICE_TYPE" />. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="4232375817808480934">РђЈОћОњОЊОеОф Kerberos</translation>
<translation id="4235965441080806197">ОЉОЎОўОЋОю ОЏОаОЎОАОћ</translation>
<translation id="4236163961381003811">ОфОЋОАОцОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="4241182343707213132">ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОЏОЊОЎ ОюОбОЊОЏОЪ ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОю ОћОљОеОњОЋОЪ</translation>
<translation id="4242145785130247982">ОљОЎОЪ ОфОъОЎОЏОћ ОЉОљОЎОЕОЋОеОЎ ОюОДОЋОЌ ОъОеОЋОЉОЎОЮ.</translation>
<translation id="4242533952199664413">ОцОфОЎОЌОф ОћОћОњОЊОеОЋОф</translation>
<translation id="4242577469625748426">ОћОфОДОаОф ОћОњОЊОеОЋОф ОћОъОЊОЎОаОЎОЋОф ОЉОъОЏОЕОЎОе: <ph name="VALIDATION_ERROR" /> ОаОЏОЕОюОћ.</translation>
<translation id="4243504193894350135">ОћОъОЊОцОАОф ОъОЋОЕОћОЎОф</translation>
<translation id="4244238649050961491">ОЌОЎОцОЋОЕ ОбОЋОЊ ОљОцОюОЎОДОдОЎОЋОф ОюОЕОЎОъОЋОЕ ОЉОАОўОЎОЎОюОЋОА</translation>
<translation id="4246980464509998944">ОћОбОеОЋОф ОаОЋОАОцОЋОф:</translation>
<translation id="424726838611654458">РђЈОцОфОЎОЌОћ ОфОъОЎОЊ ОЉ-Adobe Reader</translation>
<translation id="4247901771970415646">ОюОљ ОаОЎОфОЪ ОюОАОаОЏОеОЪ ОбОЮ <ph name="USERNAME" /></translation>
<translation id="4248098802131000011">ОћОњОаОћ ОбОю ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОъОцОаОЎ ОцОеОдОЋОф ОЉОљОЉОўОЌОф ОћОъОЎОЊОб ОЋОЉОбОЎОЋОф ОљОЉОўОЌОћ ОљОЌОеОЋОф</translation>
<translation id="4249248555939881673">ОфОЎОЏОБ ОаОфОЌОЉОе ОюОеОЕОфРђд</translation>
<translation id="4249373718504745892">ОћОњОЎОЕОћ ОЕОю ОћОЊОБ ОћОќОћ ОюОъОдОюОъОћ ОЋОюОъОЎОДОеОЋОцОЋОЪ ОаОЌОАОъОћ.</translation>
<translation id="424963718355121712">ОћОцОбОюОф ОљОцОюОЎОДОдОЎОЋОф ОЌОЎОЎОЉОф ОюОћОфОЉОдОб ОъОћОъОљОеОЌ ОЕОбОюОЎОЋ ОћОЪ ОъОЕОцОЎОбОЋОф</translation>
<translation id="4250229828105606438">ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="4250680216510889253">ОюОљ</translation>
<translation id="4251377547188244181">ОеОЎОЕОЋОЮ ОЕОю ОъОЏОЕОЎОе ОЕОЎОюОЋОў ОЋОДОЎОЋОАОД</translation>
<translation id="4252035718262427477">РђЈОЊОБ ОљОЎОаОўОеОаОў, ОДОЋОЉОЦ ОЎОЌОЎОЊ (Web Bundle)</translation>
<translation id="4252899949534773101">РђЈBluetooth ОъОЋОЕОЉОф</translation>
<translation id="4252996741873942488"><ph name="WINDOW_TITLE" /> - ОфОЋОЏОЪ ОћОЏОеОўОЎОАОЎОЎОћ ОЕОЋОфОБ</translation>
<translation id="4253168017788158739">ОћОбОеОћ</translation>
<translation id="4253183225471855471">РђЈОюОљ ОаОъОдОљОћ ОеОЕОф. ОюОцОаОЎ ОЕОъОаОАОЎОЮ ОЕОЋОЉ, ОЎОЕ ОюОћОЏОаОЎОА ОљОф ОЏОеОўОЎОА Оћ-SIM ОЋОюОћОцОбОЎОю ОљОф ОћОъОЏОЕОЎОе ОъОЌОЊОЕ.</translation>
<translation id="4254813446494774748">ОЕОцОф ОћОфОеОњОЋОЮ:</translation>
<translation id="425573743389990240">ОЕОЎОбОЋОе ОцОеОЎОДОф ОАОЋОюОюОћ ОЉОЋОЋОљОў (ОћОъОЕОъОбОЋОф ОЕОю ОбОеОџ ОЕОюОЎОюОЎ ОћОЎОљ ОЕОћОАОЋОюОюОћ ОЉОўОбОЎОаОћ)</translation>
<translation id="4256316378292851214">ОЕОъОЎ&amp;ОеОф ОАОеОўОЋОЪ ОЋОЎОЊОљОЋ ОЏ...</translation>
<translation id="4258348331913189841">ОъОбОеОЏОЋОф ОДОЉОдОЎОЮ</translation>
<translation id="4259388776256904261">ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОќОъОЪ ОъОћ</translation>
<translation id="4260182282978351200">РђЈОћОДОЋОЉОЦ <ph name="FILE_NAME" /> ОбОюОЋОю ОюОћОЎОЋОф ОъОАОЋОЏОЪ. ОћОљОЮ ОюОЕОюОЋОЌ ОљОЋОфОЋ ОюОАОеОЎОДОћ ОЉОљОъОдОбОЋОф ОћОћОњОаОћ ОћОъОфОДОЊОъОф ОЕОю Google? ОљОцОЕОе ОюОћОДОЎОЕ ОбОю Shift+F6 ОЏОЊОЎ ОюОбОЉОЋОе ОюОљОќОЋОе ОАОеОњОю ОћОћОЋОеОЊОЋОф.</translation>
<translation id="4261429981378979799">ОћОеОЕОљОЋОф ОЕОю ОфОЋОАОцОЎОЮ</translation>
<translation id="4262004481148703251">ОАОњОЎОеОф ОћОљОќОћОеОћ</translation>
<translation id="4263223596040212967">ОЏОЊОљОЎ ОюОЉОЊОЋОД ОљОф ОцОеОЎОАОф ОћОъОДОюОЊОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="426564820080660648">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОбОЊОЏОЋОаОЎОЮ, ОдОеОЎОџ ОюОћОЕОфОъОЕ ОЉ-Ethernet, ОЉ-Wi-Fi ОљОЋ ОЉОЌОЉОЎОюОф ОњОюОЎОЕОћ.</translation>
<translation id="4266679478228765574">ОћОАОеОћ ОЕОю ОфОЎОДОЎОЋОф ОфОцОАОЎОД ОљОф ОћОЕОЎОфОЋОБ, ОљОЉОю ОюОљ ОфОъОЌОД ОДОЉОдОЎОЮ.</translation>
<translation id="4267455501101322486">ОЏОЊОЎ ОюОћОЋОАОЎОБ ОЌОЕОЉОЋОЪ ОюОдОЋОеОџ ОњОЎОЕОћ ОюОъОДОЋОеОЋОф ОъОЎОЊОб ОЌОЎОаОЋОЏОЎОЎОЮ, ОЎОЕ ОюОЉОДОЕ ОћОеОЕОљОћ ОъОћОЋОеОћ</translation>
<translation id="4267924571297947682">ОЉОДОЕОф ОеОЕОЋОф ОъОћОћОЋОеОЎОЮ</translation>
<translation id="4267953847983678297">ОћОфОЌОЉОеОЋОф ОљОЋОўОЋОъОўОЎОф ОљОю ОеОЕОф ОАОюОЋОюОеОЎОф</translation>
<translation id="4268025649754414643">ОДОЎОЊОЋОЊ ОъОцОфОЌ</translation>
<translation id="4268670020635416342">ОЎОЕ ОюОћОЋОАОЎОБ ОЕОЮ ОљОЋ ОфОЋОЋОЎОф ОЏОъОЋ 'ОбОЉОЋОЊОћ', 'ОљОЎОЕОЎ' ОљОЋ 'ОЎОюОЊОЎОЮ'</translation>
<translation id="4270393598798225102">ОњОеОАОћ <ph name="NUMBER" /></translation>
<translation id="4274604968379621964">ОЕОъОЎОеОф ОћОДОЉОЋОдОћ</translation>
<translation id="4274667386947315930">ОцОеОўОЎ ОЏОаОЎОАОћ</translation>
<translation id="4274673989874969668">ОюОљОЌОе ОЎОдОЎОљОћ ОъОљОфОеОЎОЮ, ОЎОЎОфОЏОЪ ОЕОцОбОЋОюОЋОф ОАОаОЏОеОЋОЪ ОЕОюОћОЮ ОЎОъОЕОЎОЏОЋ ОЏОЊОЎ ОюОћОЕОюОЎОЮ ОъОЕОЎОъОЋОф, ОЏОъОЋ ОћОбОюОљОф ОфОъОЋОаОЋОф ОљОЋ ОЕОюОЎОЌОф ОћОЋОЊОбОЋОф Од'ОљОў</translation>
<translation id="4275291496240508082">ОћОцОбОюОф ОдОюОЎОю</translation>
<translation id="4275830172053184480">ОћОцОбОюОф ОћОъОЏОЕОЎОе ОъОЌОЊОЕ</translation>
<translation id="4277434192562187284">РђЈОъОДОЋОе ОюОћОњОЊОеОЋОф XML</translation>
<translation id="4278390842282768270">ОъОЋОфОе</translation>
<translation id="4279129444466079448">РђЈОаОЎОфОЪ ОюОћОфОДОЎОЪ ОбОЊ <ph name="PROFILE_LIMIT" /> ОцОеОЋОцОЎОюОЎОЮ ОЕОю eSIM ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЋОАОЎОБ ОцОеОЋОцОЎОю ОаОЋОАОБ, ОДОЋОЊОЮ ОдОеОЎОџ ОюОћОАОЎОе ОцОеОЋОцОЎОю ОДОЎОЎОЮ.</translation>
<translation id="4280325816108262082">ОљОЮ ОћОъОЏОЕОЎОе ОъОЋОЕОЉОф ОљОЋ ОЕОљОЎОаОЋ ОЉОЕОЎОъОЋОЕ, ОћОЋОљ ОЎОаОЋОфОД ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="4281844954008187215">ОфОаОљОЎ ОЕОЎОеОЋОф</translation>
<translation id="4282196459431406533">РђЈSmart Lock ОъОЋОцОбОю</translation>
<translation id="4284755288573763878">ОюОћОЕОЉОЎОф ОљОф ОћОљОЉОўОЌОћ ОћОъОЕОЋОцОеОф?</translation>
<translation id="4285418559658561636">ОбОЊОЏОЋОЪ ОАОЎОАОъОћ</translation>
<translation id="4285498937028063278">ОЉОЎОўОЋОю ОћОдОъОЊОћ</translation>
<translation id="428565720843367874">ОфОЋОЏОаОф ОћОљОаОўОЎ-ОЋОЎОеОЋОА ОаОЏОЕОюОћ ОЉОљОЋОцОЪ ОЉОюОфОЎ ОдОцОЋОЎ ОЉОбОф ОАОеОЎОДОф ОДОЋОЉОЦ ОќОћ.</translation>
<translation id="4287099557599763816">ОДОЋОеОљ ОъОАОџ</translation>
<translation id="428715201724021596">ОъОфОЉОдОб ОЌОЎОЉОЋОе ОюОцОеОЋОцОЎОю. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="4287157641315808225">РђЈОЏОЪ, ОюОћОцОбОюОф ChromeVox</translation>
<translation id="4287502603002637393">{MUTED_NOTIFICATIONS_COUNT,plural, =1{ОћОдОњОћ}two{ОћОдОњОф ОћОЏОЋОю}many{ОћОдОњОф ОћОЏОЋОю}other{ОћОдОњОф ОћОЏОЋОю}}</translation>
<translation id="4289540628985791613">ОАОДОЎОеОћ ОЏОюОюОЎОф</translation>
<translation id="4289732974614035569">ОЉОЌОЎОеОф ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="4290791284969893584">ОюОљОЌОе ОАОњОЎОеОф ОЊОБ, ОЎОЎОфОЏОЪ ОЕОъОЕОЎОъОЋОф ОЕОћОфОЌОюОф ОюОљ ОЎОАОфОЎОЎОъОЋ</translation>
<translation id="4291265871880246274">ОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОюОћОфОЌОЉОеОЋОф</translation>
<translation id="429234155571566255">ОћОъОфОЏОЋОаОЎОЮ ОћОљОюОћ ОЕОдОцОЎОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ</translation>
<translation id="4295072614469448764">ОћОљОцОюОЎОДОдОЎОћ ОќОъОЎОаОћ ОЉОъОАОЋОБ ОЕОюОџ. ОЉОЌОюОД ОъОћОъОДОеОЎОЮ ОъОЋОцОЎОб ОАОъОю ОЉОъОеОЏОќ ОћОљОцОюОЎОДОдОЎОЋОф.</translation>
<translation id="4295979599050707005">РђЈОЎОЕ ОюОћОЎОЏОаОА ОЕОЋОЉ ОЏОЊОЎ ОюОљОЕОе ОљОф ОћОЕОЎОъОЋОЕ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ, <ph name="USER_EMAIL" />, ОЉОЎОЌОЊ ОбОЮ ОљОфОеОЎОЮ, ОљОцОюОЎОДОдОЎОЋОф ОЋОфОЋОАОцОЎОЮ ОЉ-Chrome ОЋОЉ-Google Play. ОаОЎОфОЪ ОњОЮ ОюОћОАОЎОе ОљОф ОћОЌОЕОЉОЋОЪ ОћОќОћ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="4297219207642690536">ОћОцОбОюОћ ОъОЌОЊОЕ ОЋОљОфОЌОЋОю</translation>
<translation id="4297813521149011456">ОАОЎОЉОЋОЉ ОъОАОџ</translation>
<translation id="4299022904780065004">ОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ ОЌОЊОЕ</translation>
<translation id="4301011537467809690">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЕОюОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОЊОЋОЌОЋОф ОъОъОЏОЕОЎОеОЎ ChromeOS ОбОЋОќОеОф ОюОаОЋ ОюОДОЉОЋОб ОљОф ОАОЊОе ОћОбОЊОЎОцОЋОЎОЋОф ОЕОю ОћОфОЎОДОЋОаОЎОЮ ОЋОћОЕОЎОцОЋОеОЎОЮ ОЉ-ChromeOS. ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОЋОюОЎОЮ ОюОЏОюОЋОю ОъОЎОЊОб ОЏОъОЋ ОъОЋОбОЊ ОћОДОеОЎОАОћ ОЕОю ChromeOS, ОћОфОЏОЋОаОЋОф ОЕОЉОћОЪ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЋОаОцОЌ ОћОќОЎОЏОеОЋОЪ ОЕОЉОЋ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОЊОеОџ ОЏОюОю.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОфОъОЎОЊ ОљОцОЕОе ОюОћОбОаОЎОД ОљОЋ ОюОЉОўОю ОљОф ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЉОћОњОЊОеОЋОф ОъОЏОЕОЎОе ChromeOS ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ. ОъОаОћОюОЎ ОЊОЋОъОЎОЎОЪ ОЎОЏОЋОюОЎОЮ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЉОъОАОЋОБ Admin.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОћОЕОЉОфОф ОћОфОЏОЋОаОћ ОћОќОЋ ОюОљ ОъОЕОцОЎОбОћ ОбОю ОћОЎОЏОЋОюОф ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ ОюОЕОюОЋОЌ ОљОф ОћОъОЎОЊОб ОћОЊОеОЋОЕ ОюОЕОЎОеОЋОфОЎОЮ ОЌОЎОЋОаОЎОЎОЮ, ОЏОъОЋ ОљОЉОўОЌОћ ОЋОбОЊОЏОЋОаОЎ ОъОбОеОЏОф.<ph name="END_PARAGRAPH3" /></translation>
<translation id="4301671483919369635">ОюОЊОБ ОћОќОћ ОЎОЕ ОћОеОЕОљОћ ОюОбОеОЋОџ ОДОЉОдОЎОЮ</translation>
<translation id="4302577930366020750">РђЈОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЏОЕОЎОе ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-Steam</translation>
<translation id="4303079906735388947">ОћОњОЊОеОф ОДОЋОЊ ОљОЎОъОЋОф ОЌОЊОЕ ОюОъОцОфОЌ ОћОљОЉОўОЌОћ</translation>
<translation id="4304713468139749426">ОъОаОћОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="4305402730127028764">ОћОбОфОДОћ ОљОю <ph name="DEVICE_NAME" /></translation>
<translation id="4305817255990598646">ОъОбОЉОе</translation>
<translation id="4306119971288449206">ОћОцОбОюОф ОљОцОюОЎОДОдОЎОЋОф ОЌОЎОЎОЉОф ОюОћОфОЉОдОб ОбОЮ ОАОЋОњ ОфОЋОЏОЪ "<ph name="CONTENT_TYPE" />"</translation>
<translation id="4307992518367153382">ОћОЎОАОЋОЊОЋОф</translation>
<translation id="4309165024397827958">РђЈОъОЋОъОюОЦ ОюОљОцОЕОе ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОЕОЎОеОЋОфОЎОЮ ОЕОю Android ОбОЮ ОћОеОЕОљОф ОъОЎОДОЋОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОДОЋОЮ ОЕОю ОћОъОЏОЕОЎОе ОЕОюОџ. Google ОбОЕОЋОЎОћ ОюОљОАОЋОБ ОаОфОЋОаОЎ ОъОЎОДОЋОЮ ОъОЊОЎ ОцОбОЮ, ОЋОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОћОљОюОћ ОЉОдОЋОеОћ ОљОаОЋОаОЎОъОЎОф ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОЊОЎОЋОД ОЕОю ОћОъОЎОДОЋОЮ ОЋОљОф ОћОљОЎОЏОЋОф ОЕОю ОћОЕОЎОеОЋОфОЎОЮ ОъОЉОЋОАОАОЎ-ОћОъОЎОДОЋОЮ.</translation>
<translation id="4309420042698375243">РђЈРђј<ph name="NUM_KILOBYTES" />K РђЈРђј(<ph name="NUM_KILOBYTES_LIVE" />K ОЉОЕОЎОъОЋОЕ)РђјРђј</translation>
<translation id="4310139701823742692">РђЈОцОЋОеОъОў ОћОДОЋОЉОЦ ОЕОњОЋОЎ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОДОЋОЉОЦ Оћ-PPD ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="431076611119798497">&amp;ОцОеОўОЎОЮ</translation>
<translation id="4312701113286993760">{COUNT,plural, =1{РђЈОЌОЕОЉОЋОЪ Google ОљОЌОЊ}two{РђЈ<ph name="EXTRA_ACCOUNTS" /> ОЌОЕОЉОЋОаОЋОф Google}many{РђЈ<ph name="EXTRA_ACCOUNTS" /> ОЌОЕОЉОЋОаОЋОф Google}other{РђЈ<ph name="EXTRA_ACCOUNTS" /> ОЌОЕОЉОЋОаОЋОф Google}}</translation>
<translation id="4312866146174492540">ОЌОАОЋОъОћ (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="4314497418046265427">ОљОцОЕОе ОюОЕОцОе ОљОф ОћОцОеОЋОЊОЋОДОўОЎОЉОЎОЋОф ОбОю ОЎОЊОЎ ОЌОЎОЉОЋОе ОћОўОюОцОЋОЪ ОљОю <ph name="DEVICE_TYPE" /></translation>
<translation id="4314815835985389558">ОаОЎОћОЋОю ОћОАОаОЏОеОЋОЪ</translation>
<translation id="4315933848520197627">ОЉОЎОўОЋОю ОЕОю ОДОЎОЕОЋОе ОћОЌОЕОЉОЋОЪ</translation>
<translation id="4316850752623536204">ОљОфОе ОћОъОцОфОЌ</translation>
<translation id="4317820549299924617">ОюОљ ОћОдОюОЌОаОЋ ОюОЉОдОб ОљОЎОъОЋОф</translation>
<translation id="4320177379694898372">ОљОЎОЪ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="4322394346347055525">ОАОњОЎОеОф ОЏОеОўОЎОАОЎОЋОф ОљОЌОеОЋОф</translation>
<translation id="4324577459193912240">ОћОДОЋОЉОЦ ОюОљ ОћОЋОЕОюОЮ</translation>
<translation id="4325237902968425115">ОћОАОеОф ОћОћОфОДОаОћ ОЕОю <ph name="LINUX_APP_NAME" /> ОъОфОЉОдОбОфРђд</translation>
<translation id="4330191372652740264">ОъОЎОЮ ОбОЮ ОДОеОЌ</translation>
<translation id="4330387663455830245">ОљОЎОаОЎ ОеОЋОдОћ ОюОДОЉОю ОфОеОњОЋОЮ Оъ<ph name="LANGUAGE" /> ОЉОЏОюОю</translation>
<translation id="4332976768901252016">ОћОњОЊОеОћ ОЕОю ОЉОДОеОф ОћОЋОеОЎОЮ</translation>
<translation id="4333854382783149454">РђЈPKCS #1 SHA-1 ОбОЮ ОћОдОцОаОф RSA</translation>
<translation id="4336434711095810371">ОаОЎОДОЋОЎ ОЏОю ОћОаОфОЋОаОЎОЮ</translation>
<translation id="4339203724549370495">ОћОАОеОф ОљОцОюОЎОДОдОЎОћ</translation>
<translation id="4340125850502689798">ОЕОЮ ОъОЕОфОъОЕ ОюОљ ОфОДОЎОЪ</translation>
<translation id="4340515029017875942"><ph name="ORIGIN" /> ОеОЋОдОћ ОюОфОДОЕОе ОбОЮ ОћОљОцОюОЎОДОдОЎОћ "<ph name="EXTENSION_NAME" />"</translation>
<translation id="4340799661701629185">ОюОљ ОюОљОцОЕОе ОюОљОфОеОЎОЮ ОюОЕОюОЋОЌ ОћОфОеОљОЋОф</translation>
<translation id="4341577178275615435">РђЈОЏОЊОЎ ОюОћОцОбОЎОю ОљОЋ ОюОћОЕОЉОЎОф ОљОф ОћОњОюОЎОЕОћ ОЉОљОъОдОбОЋОф ОАОъОЪ ОћОўОДОАОў, ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОъОДОЕ ОћОДОЎОдОЋОе F7</translation>
<translation id="4341905082470253054">РђЈОАОўОўОЋОА Оћ-TPM ОЉОЉОЊОЎОДОћРђд</translation>
<translation id="434198521554309404">ОъОћОЎОе. ОъОљОЋОЉОўОЌ. ОюОюОљ ОъОљОъОЦ.</translation>
<translation id="4343250402091037179">РђЈОЏОЊОЎ ОюОЌОцОЕ ОЉОљОфОе ОАОцОдОЎОцОЎ ОљОЋ ОЉОЌОюОД ОЏОюОЕОћОЋ ОЕОю Chrome, ОъОДОюОЎОЊОЎОЮ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОЕОюОћОЮ ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОЋОюОљОЌОе ОъОЏОЪ ОъОДОЎОЕОЎОЮ ОбОю ОъОДОЕ ОћОДОЎОдОЋОе ОћОъОЋОбОЊОБ.</translation>
<translation id="434404122609091467">ОЉОљОъОдОбОЋОф ОАОцОД ОћОЕОЎОеОЋОф ОћОаОЋОЏОЌОЎ</translation>
<translation id="4345587454538109430">ОћОњОЊОеОћ...</translation>
<translation id="4345732373643853732">ОЕОЮ ОћОъОЕОфОъОЕ ОюОљ ОъОЋОЏОе ОюОЕОеОф</translation>
<translation id="4348426576195894795">РђЈОљОЮ ОћОЌОЕОЉОЋОЪ ОћОќОћ ОЎОЋОАОе, ОЎОЎОъОЌОДОЋ ОЏОю ОћОцОеОЋОцОЎОюОЎОЮ ОЕОю Chrome ОЕОъОЌОЋОЉОеОЎОЮ ОюОЌОЕОЉОЋОЪ ОћОќОћ</translation>
<translation id="4348766275249686434">ОфОЎОбОЋОЊ ОЕОњОЎОљОЋОф</translation>
<translation id="4349828822184870497">ОъОЋОбОЎОюОћ</translation>
<translation id="4350230709416545141">ОюОЌОАОЋОЮ ОфОъОЎОЊ РђЊ Ою-<ph name="HOST" /> ОюОљ ОфОћОЎОћ ОЎОЋОфОе ОњОЎОЕОћ ОюОъОЎОДОЋОЮ ОЕОюОџ</translation>
<translation id="4350782034419308508">Hey Google</translation>
<translation id="4351770750390404505">РђЈ<ph name="BEGIN_PARAGRAPH1" />ОЏОЊОЎ ОюОАОцОД ОљОф ОћОЌОЋОЋОЎОћ ОћОўОЋОЉОћ ОЉОЎОЋОфОе, ОъОбОеОЏОф <ph name="DEVICE_OS" /> ОљОЋОАОцОф ОаОфОЋОаОЎ ОЌОЋОъОеОћ ОЉОаОЋОњОб ОюОъОЏОЕОЎОеОЎОЮ ОЋОъОЕОфОцОф ОљОЋОфОЮ ОбОЮ Google ОЏОЊОЎ ОюОДОЉОЋОб ОљОЎОюОЋ ОбОЊОЏОЋОаОЎОЮ ОдОеОЎОџ ОюОЕОюОЋОЌ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОфОф Ою-Google ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎОЮ ОћОљОюОћ ОюОъОўОеОЋОф ОаОЋОАОцОЋОф, ОЏОъОЋ ОфОъОЎОЏОћ ОЋОЕОЎОцОЋОеОЎОЮ ОЉОЌОЋОЋОЎОЎОф ОћОъОЕОфОъОЕ ОЋОЉОЕОЎОеОЋОфОЎОЮ ОЕОю <ph name="DEVICE_OS" />.<ph name="END_PARAGRAPH1" />
    <ph name="BEGIN_PARAGRAPH2" />ОљОцОЕОе ОюОћОфОЌОЉОе ОюОЌОЕОЉОЋОЪ ОЉОъОЏОЕОЎОе ОћОќОћ ОЋОюОбОЉОЋОе ОљОю ОћОДОўОб CHROMEOSFLEX_HARDWARE_INFO ОЕОЉОЏОфОЋОЉОф chrome://system ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЕОаОЕОюОЌОЋ ОљОю Google ОюОАОЎОаОЋОЪ ОбОЊОЏОЋОаОЎОЮ. ОЉОДОўОб ОћОќОћ ОъОЋОцОЎОбОЎОЮ ОњОЮ ОаОфОЋОаОЎОЮ ОЕОаОЕОюОЌОЋ ОљОю Google ОЉОъОДОеОЎОЮ ОљОЌОеОЎОЮ ОЕОЉОћОЮ ОЉОЌОеОф ОюОЕОфОБ ОљОЋОфОЮ ОбОЮ Google.<ph name="END_PARAGRAPH2" />
    <ph name="BEGIN_PARAGRAPH3" />ОюОъОЎОЊОб ОаОЋОАОБ ОбОю ОаОфОЋОаОЎОЮ ОЕОъОбОеОЏОф <ph name="DEVICE_OS" /> ОЎОЏОЋОюОћ ОюОЕОфОБ ОбОЮ Google ОЋОбОю ОћОљОЋОцОЪ ОЕОЉОЋ ОаОбОЕОћ ОЉОћОЮ ОЕОЎОъОЋОЕ, ОЎОЕ ОюОбОЉОЋОе ОюОЏОфОЋОЉОф g.co/flex/HWDataCollection.<ph name="END_PARAGRAPH3" /></translation>
<translation id="4354073718307267720">ОфОЋОдОњ ОЕОљОюОћ ОЏОЕОљОфОе ОЎОеОдОћ ОюОЎОдОЋОе ОъОцОћ ОЉОфОюОф ОъОъОЊ ОЕОю ОћОАОЉОЎОЉОћ ОЕОюОџ ОљОЋ ОюОбОДОЋОЉ ОљОЌОе ОъОЎОДОЋОЮ ОћОъОдОюОъОћ</translation>
<translation id="4354344420232759511">ОљОфОеОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="435527878592612277">ОЉОЌОЎОеОф ОћОфОъОЋОаОћ ОЕОюОџ</translation>
<translation id="4358302248024731679">РђЈОЏОЊОЎ ОюОЕОцОе ОљОф ОћОљОЉОЌОЋОЪ ОЕОю ОЉОбОЎОЋОф ОЉОЌОЎОЉОЋОе Bluetooth, ОњОЋОњОюОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЏОюОЋОю ОЎОЋОъОаОЎ Bluetooth ОаОЋОАОцОЎОЮ ОЉОЊОЋОЌОЋОф ОћОъОЕОЋОЉ ОЕОюОћОЮ. ОЏОЕОъОАОъОаОЎОЮ ОљОф ОћОљОцОЕОеОЋОф ОћОќОЋ, ОћОЊОЋОЌ ОЎОЏОюОЋОю ОљОф ОЎОЋОъОаОЎ btsnoop ОЋ-HCI ОъОћОАОЕОЪ ОћОаОЋОЏОЌОЎ, ОЕОЎОбОЉОеОЋ ОаОЎОДОЋОЎ ОЏОЊОЎ ОюОћОАОЎОе ОЏОъОћ ОЕОЎОЋОфОе ОцОеОўОЎОЮ ОљОЎОЕОЎОЎОЮ ОъОќОћОЎОЮ (PII). ОћОњОЎОЕОћ ОюОЎОЋОъОаОЎОЮ ОћОљОюОћ ОфОЋОњОЉОю ОюОъОаОћОюОЎОЮ ОЕОю ОДОЉОЋОдОф ОъОЋОдОеОЎ ChromeOS ОЉ-Listnr. ОћОЎОЋОъОаОЎОЮ ОЎОЎОъОЌОДОЋ ОюОдОъОЎОфОЋОф ОюОљОЌОе 90 ОЎОъОЎОЮ.</translation>
<translation id="4358313196493694334">ОЎОЎОдОЋОЉ ОъОЎОДОЋОЮ ОћОДОюОЎОД</translation>
<translation id="4358643842961018282">ОћОъОЏОЕОЎОе ОЕОюОџ ОъОбОЋОЊОЏОЪ</translation>
<translation id="4359408040881008151">ОћОЋОфОДОЪ ОъОцОаОЎ ОЕОЎОЕ ОфОЋОАОцОЎОЮ ОћОфОюОЋОЎОЎОЮ ОЉОЋ.</translation>
<translation id="4359717112757026264">ОаОЋОБ ОбОЎОеОЋОаОЎ</translation>
<translation id="4361142739114356624">ОћОъОцОфОЌ ОћОцОеОўОЎ ОюОљОЎОЕОЋОе ОюОДОЋОЌ ОќОћ ОЌОАОе ОљОЋ ОљОЎОаОЋ ОЌОЋОДОЎ</translation>
<translation id="4361745360460842907">ОцОфОЎОЌОћ ОЏОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="4362675504017386626"><ph name="ACCOUNT_EMAIL" /> ОћОЋОљ ОЌОЕОЉОЋОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю ОЉ-<ph name="DEVICE_TYPE" /> ОЕОюОџ</translation>
<translation id="4363771538994847871">ОюОљ ОаОъОдОљ ОЎОбОЊ ОюОћОбОЉОеОћ. ОеОЋОдОћ ОбОќОеОћ?</translation>
<translation id="4364327530094270451">ОъОюОЋОЪ</translation>
<translation id="4364567974334641491"><ph name="APP_NAME" /> ОъОЕОфОБ ОЌОюОЋОЪ.</translation>
<translation id="4364830672918311045">ОћОдОњОф ОћОЋОЊОбОЋОф</translation>
<translation id="4366138410738374926">ОћОћОЊОцОАОћ ОћОЌОюОћ</translation>
<translation id="4369121877634339065">ОњОЋОеОеОЎОЮ ОфОъОЋОаОћ ОЏОюОЕОћОЎ ОЏОЊОЎ ОюОЌОцОЕ</translation>
<translation id="4369215744064167350">ОћОЉОДОЕОћ ОюОњОЉОЎ ОћОљОфОе ОљОЋОЕОеОћ</translation>
<translation id="4370975561335139969">ОЏОфОЋОЉОф ОћОљОЎОъОЎОЎОю ОЋОћОАОЎОАОъОћ ОЕОћОќОаОф ОљОЎОаОЪ ОфОЋОљОъОЋОф</translation>
<translation id="4374831787438678295">РђЈОъОаОћОю ОћОћОфОДОаОћ ОЕОю Linux</translation>
<translation id="4375035964737468845">ОцОфОЎОЌОћ ОЕОю ОДОЉОдОЎОЮ ОЕОћОЋОеОЊОЋ</translation>
<translation id="4376226992615520204">ОЕОЎОеОЋОф ОћОъОЎОДОЋОЮ ОЏОЉОЋОЎ</translation>
<translation id="4377058670119819762">ОаОЎОфОЪ ОюОњОюОЋОю ОЎОъОЎОаОћ ОЋОЕОъОљОюОћ ОЉОЕОЋОеОф ОћОЏОеОўОЎОАОЎОЋОф ОЏОЕОћОЎОљ ОъОюОљОћ.</translation>
<translation id="4377363674125277448">ОћОЎОЎОфОћ ОЉОбОЎОћ ОЉОљОЎОЕОЋОе ОћОЕОеОф.</translation>
<translation id="4378154925671717803">ОўОюОцОЋОЪ</translation>
<translation id="4378551569595875038">ОћОфОЌОЉОеОЋОф...</translation>
<translation id="4378556263712303865">ОЊОеОЎОЕОћ ОюОъОЏОЕОЎОе</translation>
<translation id="4379281552162875326">ОюОћОАОЎОе ОљОф "<ph name="APP_NAME" />"?</translation>
<translation id="4380648069038809855">ОћОфОЉОдОб ОъОбОЉОе ОюОъОАОџ ОъОюОљ</translation>
<translation id="4384312707950789900">ОћОЋОАОцОћ ОюОеОЕОфОЋОф ОћОъОЋОбОЊОцОЋОф</translation>
<translation id="4384652540891215547">ОћОцОбОюОф ОћОфОЋОАОБ</translation>
<translation id="4384886290276344300">ОЕОЎОаОЋОЎ ОћОњОЊОеОЋОф ОћОъОДОюОЊОф</translation>
<translation id="438503109373656455">ОљОЉОЎОе</translation>
<translation id="4385146930797718821">ОдОЎОюОЋОЮ ОћОъОАОџ ОћОЋОбОфОД ОюОюОЋОЌ</translation>
<translation id="4385905942116811558">РђЈОћОъОбОеОЏОф ОъОЌОцОЕОф ОъОЏОЕОЎОеОЎ Bluetooth ОЋ-USB</translation>
<translation id="4387890294700445764">ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ</translation>
<translation id="4389091756366370506"><ph name="VALUE" /> ОъОЕОфОъОЕ</translation>
<translation id="4390396490617716185"><ph name="FIRST_SWITCH" />, <ph name="SECOND_SWITCH" />, <ph name="THIRD_SWITCH" /> ОЋОбОЋОЊ <ph name="NUMBER_OF_OTHER_SWITCHES" /> ОъОфОњОЎОЮ</translation>
<translation id="439266289085815679">РђЈОћОњОЊОеОф Оћ-Bluetooth ОћОЎОљ ОЉОЕОюОЎОўОф <ph name="USER_EMAIL" />.</translation>
<translation id="4392896746540753732">ОбОеОЎОЏОф ОДОЋОЉОЦ ОћОфОдОЋОеОћ</translation>
<translation id="4394049700291259645">ОћОЕОЉОфОћ</translation>
<translation id="4396956294839002702">{COUNT,plural, =0{&amp;ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф}=1{&amp;ОцОфОЎОЌОф ОћОАОЎОъОаОЎОЎОћ}two{&amp;ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT})}many{&amp;ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT})}other{&amp;ОцОфОЎОЌОф ОЏОю ОћОЏОфОЋОЉОЋОф ({COUNT})}}</translation>
<translation id="439817266247065935">РђЈОћОъОЏОЕОЎОе ОЕОюОџ ОюОљ ОЏОЋОЉОћ ОЏОћОюОЏОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОЋОф ОЕОю Linux, ОЎОЕ ОюОћОцОбОЎОю ОљОф Linux ОъОЌОЊОЕ.</translation>
<translation id="4400367121200150367">ОЏОљОЪ ОЎОЋОцОЎОбОЋ ОћОљОфОеОЎОЮ ОЕОљОБ ОцОбОЮ ОљОЎОаОЮ ОЕОЋОъОеОЎОЮ ОАОЎОАОъОљОЋОф</translation>
<translation id="4400632832271803360">ОЎОЕ ОюОћОЌОќОЎОД ОљОф ОћОъОДОЕ ОЕОю ОъОеОЏОќ ОћОљОцОюОЎОДОдОЎОЋОф ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОћОфОаОћОњОЋОф ОЕОю ОъОДОЕОЎ ОћОЕОЋОеОћ ОћОбОюОЎОЋОаОћ</translation>
<translation id="4400963414856942668">ОЉОюОЌОЎОдОћ ОбОю ОАОЎОъОЪ ОћОЏОЋОЏОЉ ОљОцОЕОе ОюОћОЋОАОЎОБ ОЏОеОўОЎОАОЎОЎОћ ОюОАОЎОъОаОЎОЋОф</translation>
<translation id="4401912261345737180">РђЈОћОфОЌОЉОеОЋОф ОбОЮ ОДОЋОЊ ОЏОЊОЎ ОюОћОбОЉОЎОе (cast)</translation>
<translation id="4402755511846832236">ОљОфОеОЎОЮ ОюОљ ОЎОЋОЏОюОЋ ОюОЊОбОф ОъОфОЎ ОћОъОЏОЕОЎОе ОћОќОћ ОъОЕОъОЕ ОљОЋОфОџ ОЉОљОЋОцОЪ ОцОбОЎОю</translation>
<translation id="4403266582403435904">РђЈОДОю ОюОЕОЌОќОе ОаОфОЋОаОЎОЮ ОљОЋ ОюОћОЌОюОЎОБ ОъОЏОЕОЎОеОЎОЮ ОЉОЏОю ОЕОюОЉ. ОћОњОЎОЉОЋОЎОЎОЮ ОъОЋОбОюОЎОЮ Ою-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОћОАОЎОАОъОћ ОюОЌОЕОЉОЋОЪ Google ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЕОюОџ.</translation>
<translation id="4403775189117163360">ОЉОЌОЎОеОф ОфОЎОДОЎОЎОћ ОљОЌОеОф</translation>
<translation id="4404136731284211429">ОАОеОЎОДОћ ОЌОЋОќОеОф</translation>
<translation id="4404843640767531781">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОаОЌОАОъОћ ОбОю ОЎОЊОЎ ОћОћОЋОеОћ ОЕОюОџ. ОЎОЕ ОюОЉОДОЕ ОеОЕОЋОф ОъОћОћОЋОеОћ ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОћ ОћОќОЋ.</translation>
<translation id="4405117686468554883">РђЈРђј*.jpegРђЈ, РђјРђЈРђј*.jpgРђЈ, Рђј*.png</translation>
<translation id="440653823335387109">ОЊОцОЎОЮ ОЕОаОДОеОљОЋ</translation>
<translation id="4406883609789734330">ОЏОфОЋОЉОЎОЋОф ОъОЎОЎОЊОЎОЋОф</translation>
<translation id="4408599188496843485">Об&amp;ОќОеОћ</translation>
<translation id="4409271659088619928">ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОюОџ ОћОЋОљ <ph name="DSE" />. ОаОЎОфОЪ ОюОбОЎОЎОЪ ОЉОћОЋОеОљОЋОф ОЕОюОЋ ОюОњОЉОЎ ОъОЌОЎОДОф ОћОЎОАОўОЋОеОЎОЎОф ОћОЌОЎОцОЋОЕОЎОЮ, ОљОЮ ОеОюОЋОЋОаОўОЎ.</translation>
<translation id="4409697491990005945">ОЕОЋОюОЎОЎОЮ</translation>
<translation id="4410545552906060960">ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОъОАОцОе (ОДОЋОЊ) ОЉОъОДОЋОЮ ОЉОАОЎОАОъОћ ОЏОЊОЎ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе. ОаОЎОфОЪ ОюОћОњОЊОЎОе ОљОф ОћОДОЋОЊ ОъОљОЋОЌОе ОЎОЋОфОе ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="4411578466613447185">ОЌОЋОфОЮ ОДОЋОЊ</translation>
<translation id="4412698727486357573">ОъОеОЏОќ ОћОбОќОеОћ</translation>
<translation id="44141919652824029">РђЈОеОЋОдОћ ОюОћОбОаОЎОД ОюОљОцОюОЎОДОдОЎОћ "<ph name="APP_NAME" />" ОњОЎОЕОћ ОюОеОЕОЎОъОф ОћОћОфОДОаОЎОЮ ОћОъОЌОЋОЉОеОЎОЮ ОЉ-USB?</translation>
<translation id="4414232939543644979">ОЌОюОЋОЪ &amp;ОљОаОЋОаОЎОъОЎ ОЌОЊОЕ</translation>
<translation id="4415213869328311284">Оћ-<ph name="DEVICE_TYPE" /> ОЕОюОџ ОъОЋОЏОЪ ОюОЕОЎОъОЋОЕ.</translation>
<translation id="4415245286584082850">ОюОљ ОаОъОдОљОЋ ОъОЏОЕОЎОеОЎОЮ. ОљОцОЕОе ОюОцОфОЋОЌ ОъОљОъОе ОъОеОЏОќ ОбОќОеОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ.</translation>
<translation id="4415276339145661267">РђЈОаОЎОћОЋОю ОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="4415748029120993980">РђЈОбОДОЋОъОћ ОљОюОЎОцОўОЎОф SECG ОъОАОЋОњ secp384r1 (ОъОЋОЏОеОф ОњОЮ ОЉОЕОЮ NIST P-384)</translation>
<translation id="4416450511678320850">ОљОЎОЪ ОљОцОюОЎОДОдОЎОЋОф ОќОъОЎОаОЋОф ОюОфОЋОЏОЪ ОћОќОћ</translation>
<translation id="4416582610654027550">ОЎОЕ ОюОћОДОюОЎОЊ ОЏОфОЋОЉОф ОљОфОе ОЌОЋОДОЎОф</translation>
<translation id="4417162649853416189">ОњОЋОеОеОЎОЮ ОљОф ОАОъОЪ ОћОбОЏОЉОе ОъОбОю ОфОъОЋОаОЋОф ОЏОЊОЎ ОюОЌОцОЕ ОЉОљОъОдОбОЋОф <ph name="VISUAL_SEARCH_PROVIDER" /></translation>
<translation id="4419409365248380979">РђЈОюОљОцОЕОе ОфОъОЎОЊ Ою-<ph name="HOST" /> ОюОћОњОЊОЎОе ОДОЋОЉОдОЎ Cookie</translation>
<translation id="4421932782753506458">ОюОДОЎОД</translation>
<translation id="4423376891418188461">ОЕОЌОќОЋОе ОћОњОЊОеОЋОф</translation>
<translation id="442397852638519243"><ph name="USER_NAME" />, ОъОаОћОю ОћОъОбОеОЏОф ОъОЉОДОЕ ОъОъОџ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОћ ОЕОюОџ.</translation>
<translation id="4426464032773610160">РђЈОЏОЊОЎ ОюОћОфОЌОЎОю, ОбОюОЎОџ ОюОЋОЋОЊОљ ОЕОћОъОфОњ ОЉ-USB ОљОЋ ОЉ-Bluetooth ОъОЌОЋОЉОе Ою-Chromebook. ОаОЎОфОЪ ОњОЮ ОюОћОЕОфОъОЕ ОЉОъОДОЕОЎ ОћОъОДОюОЊОф.</translation>
<translation id="4427306783828095590">ОбОЮ ОћОћОњОаОћ ОћОъОЕОЋОцОеОф, ОћОЌОАОЎОъОћ ОЕОю ОцОЎОЕОЎОаОњ ОЋОфОЋОЏОаОЋОф ОќОЊОЋОаОЎОЋОф ОъОДОЎОцОћ ОЎОЋОфОе</translation>
<translation id="4427365070557649936">ОЉОфОћОюОЎОџ ОљОЎОъОЋОф ОЕОю ОДОЋОЊ ОћОљОЎОЕОЋОе...</translation>
<translation id="4429163740524851942">ОцОеОЎОАОф ОъОДОюОЊОф ОцОЎОќОЎОф</translation>
<translation id="4429239357082509581">РђЈОљОЎОЪ ОћОеОЕОљОћ ОюОћОеОЎОЦ ОљОф Steam</translation>
<translation id="4430019312045809116">ОбОЋОдОъОф ОДОЋОю</translation>
<translation id="4430369329743628066">ОћОАОЎОъОаОЎОЎОћ ОаОЋОАОцОћ</translation>
<translation id="4430422687972614133">ОћОцОбОюОф ОћОЏОеОўОЎОА ОћОЋОЋОЎОеОўОЋОљОюОЎ</translation>
<translation id="4432621511648257259">ОћОАОЎОАОъОћ ОЕОњОЋОЎОћ</translation>
<translation id="443454694385851356">ОЊОЋОе ОДОЋОЊОЮ (ОюОљ ОъОљОЋОЉОўОЌ)</translation>
<translation id="443475966875174318">ОбОЊОЏОЋОЪ ОљОЋ ОћОАОеОћ ОЕОю ОљОцОюОЎОДОдОЎОЋОф ОюОљ ОфОЋОљОъОЋОф</translation>
<translation id="4438043733494739848">ОЕОДОЋОБ</translation>
<translation id="4440097423000553826">ОаОЕОюОЌОћ ОћОфОеОљОћ ОбОю ОЎОЊОЎ <ph name="WEBSITE" /> ОљОю ОћОўОюОцОЋОЪ. ОЏОЊОЎ ОюОљОъОф ОљОф ОќОћОЋОфОџ, ОЎОЕ ОюОћОДОЎОЕ ОбОю ОћОћОфОеОљОћ "<ph name="NOTIFICATIONTITLE" />" ОЋОюОцОбОЋОю ОюОцОЎ ОћОћОЋОеОљОЋОф.</translation>
<translation id="4441124369922430666">ОюОћОцОбОЎОю ОљОф ОћОљОцОюОЎОДОдОЎОћ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОбОф ОћОцОбОюОф ОћОъОЌОЕОЉ?</translation>
<translation id="4441147046941420429">ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОЎОЕ ОюОаОфОД ОљОф ОъОцОфОЌ ОћОљОЉОўОЌОћ ОъОћОъОЏОЕОЎОе, ОюОЌОЉОе ОљОЋОфОЋ ОъОЌОЊОЕ ОЋОюОњОбОф ОЉОЋ</translation>
<translation id="444134486829715816">ОћОеОЌОЉОћ...</translation>
<translation id="4441928470323187829">ОъОаОћОю ОћОъОбОеОЏОф ОћОдОъОЎОЊ ОљОф ОћОфОЋОАОБ ОћОќОћ</translation>
<translation id="4443536555189480885">&amp;ОбОќОеОћ</translation>
<translation id="4444304522807523469">РђЈОњОЎОЕОћ ОюОАОЋОеОДОЎ ОъОАОъОЏОЎОЮ ОћОъОЌОЋОЉОеОЎОЮ ОЉОљОъОдОбОЋОф USB ОљОЋ ОЉОеОЕОф ОћОъОДОЋОъОЎОф</translation>
<translation id="4444512841222467874">ОљОЮ ОюОљ ОъОцОаОЎОЮ ОаОцОЌ ОљОЌОАОЋОЪ, ОЎОЎОфОЏОЪ ОЕОъОЕОфОъОЕОЎОЮ ОЋОаОфОЋОаОЎОЮ ОЎОЋОАОеОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ.</translation>
<translation id="4446933390699670756">ОЕОЎОДОЋОБ</translation>
<translation id="4448914100439890108">ОћОАОфОеОф ОћОАОЎОАОъОћ ОЕОю <ph name="USERNAME" /> ОЉ-<ph name="DOMAIN" /></translation>
<translation id="4449948729197510913">РђЈОЕОЮ ОћОъОЕОфОъОЕ ОЕОюОџ ОЕОЎОЎОџ ОюОЌОЕОЉОЋОЪ ОћОљОеОњОЋОаОЎ ОЕОю ОћОљОеОњОЋОЪ ОЕОюОџ. ОЏОЊОЎ ОюОеОЕОЋОЮ ОъОЏОЕОЎОеОЎОЮ ОЉОЌОЕОЉОЋОЪ, ОфОЌОЎОюОћ ОЎОЕ ОюОљОъОф ОЕОЎОЕ ОюОџ ОЉОбОюОЋОф ОбОю ОћОЊОЋОъОЎОЎОЪ ОЉОъОАОЋОБ Admin. ОаОЊОеОЕОЋОф ОћОеОЕОљОЋОф ОљОЊОъОЎОЪ ОЉОЌОЕОЉОЋОЪ ОЏОЊОЎ ОюОЉОдОб ОљОф ОћОљОЎОъОЋОф.</translation>
<translation id="4449996769074858870">ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОъОцОбОЎОюОћ ОфОЋОЏОЪ ОљОЋОЊОЎОЋ.</translation>
<translation id="4450274068924249931">ОЏОљОЕОе ОћОъОАОџ ОюОљ ОцОбОЎОю, ОЎОЋОдОњОЋ ОЉОЋ ОфОъОЋОаОЋОф, ОћОЕОбОћ ОћОаОЋОЏОЌОЎОф, ОаОфОЋОаОЎ ОъОќОњ ОћОљОЋОЋОЎОе ОЋОцОеОўОЎ ОъОЊОЎОћ ОаОЋОАОцОЎОЮ. ОћОцОбОюОф ОЕОЋОъОе ОъОАОџ ОфОЕОъОЋОе ОбОю ОћОфОдОЋОњОћ ОЕОюОџ ОЉОќОъОЪ ОўОбОЎОаОћ.</translation>
<translation id="4450974146388585462">ОљОЉОЌОЪ</translation>
<translation id="445099924538929605">РђЈОъОбОеОЏОф <ph name="DEVICE_OS" /> ОќОЎОћОфОћ TPM ОцОбОЎОю ОЕОаОЎОфОЪ ОюОЕОъОЋОе ОЉОЋ ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОЋОцОЪ ОъОљОЋОЉОўОЌ ОЎОЋОфОе.</translation>
<translation id="4451479197788154834">РђЈОћОАОЎОАОъОћ ОЕОюОџ ОЕОъОЋОеОћ ОЉОъОЏОЕОЎОе ОћОќОћ ОЋОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="4451757071857432900">ОЌОАОЋОъОЋОф ОЉОљОфОеОЎОЮ ОЕОъОЋОдОњОЋОф ОЉОћОЮ ОъОЋОЊОбОЋОф ОъОцОеОЎОбОЋОф ОљОЋ ОъОўОбОЋОф (ОъОЋОъОюОЦ)</translation>
<translation id="4453946976636652378">ОљОцОЕОе ОюОЌОцОЕ ОЉ-<ph name="SEARCH_ENGINE_NAME" /> ОљОЋ ОюОћОДОюОЎОЊ ОЏОфОЋОЉОф ОљОфОе</translation>
<translation id="4459169140545916303">ОЕОЎОъОЋОЕ ОљОЌОеОЋОЪ: ОюОцОаОЎ <ph name="DEVICE_LAST_ACTIVATED_TIME" /> ОЎОъОЎОЮ</translation>
<translation id="4460014764210899310">ОцОЎОќОЋОе ОћОДОЉОЋОдОћ</translation>
<translation id="4462159676511157176">ОЕОеОфОЎ ОЕОъОЋОф ОъОЋОфОљОъОЎОЮ ОљОЎОЕОЎОф</translation>
<translation id="4465236939126352372">ОъОњОЉОюОф ОќОъОЪ ОЕОю <ph name="TIME" /> ОћОЋОњОЊОеОћ ОюОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /></translation>
<translation id="4466068638972170851">РђЈОЎОЕ ОюОћОЊОњОЎОЕ ОљОф ОћОўОДОАОў ОюОћОЕОъОбОћ ОЋОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЎОцОЋОЕ ОЎОЌОЊ ОбОЮ ОъОДОЕ S. ОюОЌОюОЋОцОЎОЪ, ОљОцОЕОе ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю ОъОДОЕ ОћОЌОЎОцОЋОЕ ОљОЋ ОюОћОДОЎОЕ ОбОю ОАОъОю ОћОћОДОеОљОћ ОюОЎОЊ ОъОњОЕ ОћОАОўОўОЋОА ОЏОЊОЎ ОюОЉОЌОЋОе.</translation>
<translation id="4466839823729730432">ОЏОљОЪ ОъОЋОдОњОЎОЮ ОћОќОЎОЏОеОЋОаОЋОф ОЕОюОџ</translation>
<translation id="4469324811108161144">ОљОцОЕОе ОюОЕОъОЋОе ОЉОћОбОеОЋОф ОбОЊ <ph name="CHARACTER_LIMIT" /> ОфОЋОЋОЎОЮ.</translation>
<translation id="4469762931504673593">Ою-<ph name="ORIGIN" /> ОЎОЕ ОћОеОЕОљОћ ОюОбОеОЋОџ ОДОЉОдОЎОЮ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDERNAME" /></translation>
<translation id="4470957202018033307">ОћОбОЊОцОЋОф ОљОЌОАОЋОЪ ОЌОЎОдОЋОаОЎ</translation>
<translation id="4471354919263203780">РђЈОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОДОЋОЉОдОЎ ОќОЎОћОЋОЎ ОЊОЎОЉОЋОеРђд Рђј<ph name="PERCENT" />%Рђј</translation>
<translation id="447252321002412580">РђЈОбОќОеОћ ОЉОЕОЎОцОЋОе ОћОфОЏОЋОаОЋОф ОЋОћОЉОЎОдОЋОбОЎОЮ ОЕОю Chrome</translation>
<translation id="4472575034687746823">ОфОЌОЎОюОф ОћОбОЉОЋОЊОћ</translation>
<translation id="4474155171896946103">ОЎОдОЎОеОф ОАОЎОъОаОЎОЎОћ ОюОЏОю ОћОЏОеОўОЎОАОЎОЋОф...</translation>
<translation id="4475552974751346499">ОЌОЎОцОЋОЕ ОЉОћОЋОеОЊОЋОф</translation>
<translation id="4475830133618397783">ОЎОЕ ОюОЉОЌОЋОе ОљОф ОћОАОЎОАОъОљОЋОф ОюОћОбОЉОеОћ. ОфОћОЎОћ ОюОџ ОњОЎОЕОћ ОљОюОЎОћОЪ ОЏОю ОбОЋОЊ ОћОЌОЕОЉОЋОЪ ОъОЌОЋОЉОе.</translation>
<translation id="4476590490540813026">ОАОцОЋОеОўОљОЎОф</translation>
<translation id="4476659815936224889">РђЈОЏОЊОЎ ОюОАОеОЋОД ОљОф ОћОДОЋОЊ ОћОќОћ, ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОљОцОюОЎОДОдОЎОћ ОЕОю ОАОЋОеОД ОДОЋОЊОЎ Оћ-QR ОЉОўОюОцОЋОЪ ОљОЋ ОЉОљОцОюОЎОДОдОЎОЋОф ОъОдОюОъОћ ОъОфОљОЎОъОЋОф.</translation>
<translation id="4477015793815781985">РђЈОдОеОЎОџ ОюОЏОюОЋОю Ctrl, РђЈAlt ОљОЋ Рїў</translation>
<translation id="4478664379124702289">ОЕОъОЎОеОф ОДОЎОЕОЋ&amp;Ое ОЉОфОЋОе...</translation>
<translation id="4479424953165245642">ОаОЎОћОЋОю ОЎОЎОЕОЋОъОЎ ОДОЎОЋОАОД</translation>
<translation id="4479639480957787382">ОљОфОеОаОў</translation>
<translation id="4479877282574735775">ОћОъОбОеОЏОф ОъОњОЊОЎОеОћ ОљОф ОћОъОЏОЋОаОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОф. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОЏОъОћ ОЊОДОЋОф.</translation>
<translation id="4480590691557335796">РђЈChrome ОЎОЏОЋОю ОюОљОфОе ОфОЋОЏОаОЋОф ОъОќОЎОДОЋОф ОЉОъОЌОЕОЉ ОЋОюОћОАОЎОе ОљОЋОфОЪ</translation>
<translation id="4481448477173043917">ОЉОЋОдОбОћ ОћОцОбОюОћ ОъОЌОЊОЕ ОЕОю Оћ-<ph name="DEVICE_TYPE" /> ОЉОљОЋОцОЪ ОЉОюОфОЎ ОдОцОЋОЎ</translation>
<translation id="4481467543947557978">РђЈОДОЋОЉОЦ ОЕОЎОеОЋОф (service worker)</translation>
<translation id="4481530544597605423">ОъОЏОЕОЎОеОЎОЮ ОюОљ ОъОЋОфОљОъОЎОЮ</translation>
<translation id="4482990632723642375">ОЏОеОўОЎОАОЎОЎОћ ОЕОаОАОњОеОћ ОюОљОЌОеОЋОаОћ</translation>
<translation id="4484922932728109422">ОљОфОеОЎОЮ ОюОљ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОъОЎОЊОб ОюОњОЉОЎ ОћОъОАОЏОЎОЮ ОЕОюОџ ОЏОЊОЎ ОюОцОфОЋОЌ ОЋОюОћОдОЎОЉ ОЌОюОЋОаОЋОф</translation>
<translation id="4487489714832036847">РђЈОЉОъОЏОЕОЎОеОЎ Chromebook ОъОЕОфОъОЕОЎОЮ ОЉОљОцОюОЎОДОдОЎОЋОф ОЉОъОДОЋОЮ ОЉОфОЋОЏОаОЋОф ОеОњОЎОюОЋОф. ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОцОюОЎОДОдОЎОЋОф ОюОцОеОЋОЊОЋОДОўОЎОЉОЎОЋОф, ОюОЉОЎОЊОЋОе ОЋОбОЋОЊ.</translation>
<translation id="4488257340342212116">ОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ</translation>
<translation id="4488502501195719518">ОюОаОДОЋОф ОљОф ОЏОю ОћОаОфОЋОаОЎОЮ?</translation>
<translation id="4490086832405043258">РђЈОЕОЎОъОЋОЕ ОЉОћОњОЊОеОЋОф ОюОЕОеОф proxy ОЕОю ChromeOS ОбОЉОЋОе ОћОцОеОЋОцОЎОю ОћОќОћ.</translation>
<translation id="449126573531210296">РђЈОћОдОцОаОф ОАОЎОАОъОљОЋОф ОъОАОЋОаОЏОеОаОЋОф ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ Google</translation>
<translation id="449232563137139956">ОљОфОеОЎОЮ ОъОдОЎОњОЎОЮ ОЉОЊОеОџ ОЏОюОю ОфОъОЋОаОЋОф ОюОдОЋОеОџ ОћОъОЌОЕОћ, ОЏОъОЋ ОфОъОЋОаОЋОф ОЉОЌОаОЋОЎОЋОф ОЋОЎОеОўОЋОљОюОЎОЋОф ОљОЋ ОЉОъОљОъОеОЎ ОЌОЊОЕОЋОф</translation>
<translation id="4492698018379445570">ОљОцОЕОе ОюОеОљОЋОф ОљОф ОъОћ ОЕОћОЋОАОцОф ОюОбОњОюОЋОф ОДОаОЎОЋОф ОЋОюОЕОюОЮ ОЏОЕОъОфОљОЎОЮ ОюОџ</translation>
<translation id="4493468155686877504">ОъОЋОъОюОЦ (<ph name="INSTALL_SIZE" />)</translation>
<translation id="4495419450179050807">ОюОљ ОюОћОдОЎОњ ОЉОЊОБ ОќОћ</translation>
<translation id="4497145443434063861">РђЈОъОЌОЕОЉ ОЋ-Chromecast ОЉОеОЕОфОЋОф Wi-Fi ОЕОЋОаОЋОф (ОюОъОЕОю, 2.4GHz
    ОюОбОЋОъОф 5GHz)</translation>
<translation id="4500114933761911433"><ph name="PLUGIN_NAME" /> ОДОеОА</translation>
<translation id="450099669180426158">ОАОъОю ОЕОю ОАОЎОъОЪ ОДОеОЎОљОћ</translation>
<translation id="4501530680793980440">ОљОЎОЕОЋОе ОћОАОеОћ</translation>
<translation id="4502423230170890588">ОћОАОеОћ ОъОћОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="4502477450742595012">ОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОЎОъОаОЎОф ОбОю ОћОЏОеОўОЎОАОЎОЎОћ ОЋОЉОЋОЌОеОЎОЮ ОЉОљОцОЕОеОЋОф 'ОћОЋОАОцОф ОЏОеОўОЎОАОЎОЎОћ ОюОДОЉОЋОдОћ ОЌОЊОЕОћ'</translation>
<translation id="4503748371388753124">РђЈОћОъОЌОЕОЉ ОЕОюОџ ОъОЏОЎОю ОћОфОДОЪ ОљОЉОўОЌОћ ОъОАОЋОњ Trusted Platform ModuleРђЈ (TPM), ОћОъОЕОъОЕ ОюОЎОЎОЕОЋОЮ ОфОЏОЋОаОЋОф ОљОЉОўОЌОћ ОДОеОЎОўОЎОЋОф ОеОЉОЋОф ОЕОю ChromeOS Flex. ОЉОъОеОЏОќ ОћОбОќОеОћ ОЕОю Chromebook ОъОцОЋОеОў ОъОЎОЊОб ОаОЋОАОБ: https://support.google.com/chromebook/?p=tpm</translation>
<translation id="4504374760782163539">{COUNT,plural, =0{РђЈОДОЋОЉОдОЎ Оћ-cookie ОъОЋОфОеОЎОЮ}=1{РђЈОДОЋОЉОдОЎ Оћ-cookie ОъОЋОфОеОЎОЮ, ОЌОеОЎОњ ОљОЌОЊ}two{РђЈОДОЋОЉОдОЎ Оћ-cookie ОъОЋОфОеОЎОЮ, {COUNT} ОЌОеОЎОњОЎОЮ}many{РђЈОДОЋОЉОдОЎ Оћ-cookie ОъОЋОфОеОЎОЮ, {COUNT} ОЌОеОЎОњОЎОЮ}other{РђЈОДОЋОЉОдОЎ Оћ-cookie ОъОЋОфОеОЎОЮ, {COUNT} ОЌОеОЎОњОЎОЮ}}</translation>
<translation id="4504940961672722399">ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОћОќОћ ОбОю ОЎОЊОЎ ОюОЌОЎОдОћ ОбОю ОћОАОъОю ОљОЋ ОбОю ОЎОЊОЎ ОћОДОЕОћ ОбОю <ph name="EXTENSION_SHORTCUT" />.</translation>
<translation id="450552327874992444">ОћОъОЎОюОћ ОЏОЉОе ОаОЋОАОцОћ</translation>
<translation id="4507128560633489176">ОћОаОфОЋОаОЎОЮ ОаОЋОДОЋ.</translation>
<translation id="450867954911715010">ОћОњОЊОеОЋОф ОаОњОЎОЕОЋОф</translation>
<translation id="4508765956121923607">ОћОдОњОф Оъ&amp;ОДОЋОе</translation>
<translation id="4509421746503122514">ОћОцОбОюОћ ОъОЌОЊОЕ ОюОдОЋОеОџ ОбОЊОЏОЋОЪ</translation>
<translation id="4510195992002502722">ОЕОюОЎОЌОф ОћОъОЕОЋОЉ ОаОЏОЕОюОћ. ОъОфОЉОдОб ОаОЎОАОЎОЋОЪ ОаОЋОАОБРђд</translation>
<translation id="4510479820467554003">ОеОЕОЎОъОф ОЌОЕОЉОЋОаОЋОф ОћОЋОеОЎОЮ</translation>
<translation id="451102079304155829">ОбОњОюОЋОф ОДОаОЎОЋОф</translation>
<translation id="4513872120116766993">ОћОЕОюОъОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="4513946894732546136">ОъОЕОЋОЉ</translation>
<translation id="451407183922382411">ОъОЋОцОбОю ОбОю-ОЎОЊОЎ <ph name="COMPANY_NAME" /></translation>
<translation id="4514610446763173167">ОћОцОбОюОф ОЋОЎОЊОљОЋ ОљОЋ ОћОцОАОДОф ОћОцОбОЋОюОћ</translation>
<translation id="451515744433878153">ОћОАОеОћ</translation>
<translation id="4515872537870654449">РђЈОЎОЕ ОюОцОаОЋОф ОљОю Dell ОЏОЊОЎ ОюОДОЉОю ОАОЎОЋОб. ОљОЉОЎОќОе ОћОбОњОЎОаОћ ОЎОЏОЉОћ ОљОЮ ОћОъОљОЋОЋОеОе ОюОљ ОцОЋОбОю.</translation>
<translation id="4519331665958994620">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ</translation>
<translation id="4519935350946509010">ОЕОњОЎОљОф ОЌОЎОЉОЋОе.</translation>
<translation id="4520385623207007473">РђЈОДОЋОЉОдОЎ Cookie ОЉОЕОЎОъОЋОЕ</translation>
<translation id="452039078290142656">ОъОЏОЕОЎОеОЎОЮ ОЉОюОфОЎ ОЎОЊОЋОбОЎОЮ ОЕОю <ph name="VENDOR_NAME" /></translation>
<translation id="4522570452068850558">ОцОеОўОЎОЮ</translation>
<translation id="4522600456902129422">ОћОљОфОе ОћОќОћ ОЎОЋОЏОю ОюОћОъОЕОЎОџ ОюОњОЕОф ОюОюОЋОЌ</translation>
<translation id="4522890784888918985">ОљОЎОЪ ОфОъОЎОЏОћ ОЉОЌОЕОЉОЋОаОЋОф ОЕОю ОЎОюОЊОЎОЮ</translation>
<translation id="4523876148417776526">РђЈОћОеОЕОЎОъОЋОф ОЕОю ОљОфОеОЎ Оћ-XML ОбОЊОЎОЎОЪ ОюОљ ОљОЋОЌОќОеОЋ.</translation>
<translation id="4524832533047962394">ОъОдОЉ ОћОћОеОЕОъОћ ОЕОАОЋОцОД ОюОљ ОаОфОъОџ ОбОю ОЎОЊОЎ ОћОњОеОАОћ ОћОќОЋ ОЕОю ОъОбОеОЏОф ОћОћОцОбОюОћ. ОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОъОЕОфОъОЕОЎОЮ ОЉОњОеОАОћ ОћОЌОЊОЕОћ ОЉОЎОЋОфОе.</translation>
<translation id="452750746583162491">ОАОДОЎОеОф ОћОаОфОЋОаОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ</translation>
<translation id="4527929807707405172">ОћОцОбОюОф ОњОюОЎОюОћ ОћОцОЋОЏОћ. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="4528494169189661126">ОћОдОбОћ ОюОфОеОњОЋОЮ</translation>
<translation id="4530494379350999373">ОъОДОЋОе</translation>
<translation id="4531924570968473143">ОљОф ОъОЎ ОЉОеОдОЋОаОџ ОюОћОЋОАОЎОБ ОљОю <ph name="DEVICE_TYPE" /> ОќОћ?</translation>
<translation id="4532625150642446981">"<ph name="USB_DEVICE_NAME" />" ОаОъОдОљ ОЉОЕОЎОъОЋОЕ. ОЕОЎОаОЋОЎ ОћОћОДОдОљОћ ОЕОю ОћОъОЏОЕОЎОе ОЉОќОъОЪ ОЕОћОЋОљ ОЉОЕОЎОъОЋОЕ ОбОюОЋОю ОюОњОеОЋОЮ ОюОЕОњОЎОљОЋОф. ОюОћОъОЕОЎОџ?</translation>
<translation id="4532646538815530781">ОЉОљОфОе ОћОќОћ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОЌОЎОЎОЕОаОЎ ОфОаОЋОбОћ.</translation>
<translation id="4533846798469727141">РђЈОбОЏОЕОЎОЋ ОљОЋОъОеОЎОЮ "Hey Google"</translation>
<translation id="4533985347672295764">РђЈОќОъОЪ CPU (ОЎОЌОЎОЊОф ОбОЎОЉОЋОЊ ОъОеОЏОќОЎОф)</translation>
<translation id="4534661889221639075">ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="4535127706710932914">ОцОеОЋОцОЎОю ОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="4535767533210902251">ОЌОЎОЎОЕОЪ ОўОЉОЎОбОф ОћОљОдОЉОб ОъОЋОфОДОЪ ОЉОъОДОЕ ОћОЎОъОаОЎ ОћОбОюОЎОЋОЪ ОЉОъОДОюОЊОф. ОЎОЕ ОюОњОбОф ОЉОЋ ОЉОбОЊОЎОаОЋОф ОЉОљОЌОф ОћОљОдОЉОбОЋОф.</translation>
<translation id="4536140153723794651">РђЈОљОфОеОЎОЮ ОЕОфОъОЎОЊ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ cookie</translation>
<translation id="4538417792467843292">ОъОЌОЎОДОф ОъОЎОюОћ</translation>
<translation id="4538792345715658285">ОъОЋОфОДОЪ ОюОцОЎ ОъОЊОЎОаОЎОЋОф ОЕОю ОљОеОњОЋОЪ.</translation>
<translation id="4541123282641193691">РђЈОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОљОъОф ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОљОЋ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Оћ-Chromebook.</translation>
<translation id="4541662893742891060">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОцОеОЋОцОЎОю ОћОќОћ. ОбОюОЎОџ ОюОцОаОЋОф ОюОАОцОД ОюОДОЉОюОф ОфОъОЎОЏОћ ОўОЏОаОЎОф.</translation>
<translation id="4541706525461326392">ОћОАОеОф ОћОцОеОЋОцОЎОю ОъОфОЉОдОбОф. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="4542520061254486227">ОДОеОЎОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОљОфОеОЎОЮ <ph name="WEBSITE_1" /> ОЋ-<ph name="WEBSITE_2" /></translation>
<translation id="4543778593405494224">ОъОаОћОю ОћОљОЎОЕОЋОеОЎОЮ</translation>
<translation id="4544174279960331769">ОЊОъОЋОф ОЉОеОЎОеОф ОъОЌОЊОю ОЏОЌОЋОюОћ</translation>
<translation id="4545028762441890696">ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф ОћОфОЋОАОБ ОъОЌОЊОЕ, ОЎОЕ ОюОљОЕОе ОљОф ОћОћОеОЕОљОЋОф ОћОЌОЊОЕОЋОф:</translation>
<translation id="4545759655004063573">ОюОљ ОаОЎОфОЪ ОюОЕОъОЋОе ОбОДОЉ ОћОеОЕОљОЋОф ОюОљ ОъОАОцОЎОДОЋОф. ОЎОЕ ОюОЕОъОЋОе ОЉОъОЎОДОЋОЮ ОљОЌОе.</translation>
<translation id="4546308221697447294">РђЈОњОюОЎОЕОћ ОъОћОЎОеОћ ОбОЮ Google Chrome</translation>
<translation id="4546345569117159016">ОћОюОЌОдОЪ ОћОЎОъОаОЎ</translation>
<translation id="4546692474302123343">РђЈОДОюОў ОДОЋОюОЎ ОЉ-Google Assistant</translation>
<translation id="4547659257713117923">ОљОЎОЪ ОЏОеОўОЎОАОЎОЋОф ОъОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="4547672827276975204">ОћОњОЊОеОћ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="4549791035683739768">ОюОљ ОаОЕОъОеОЋ ОўОЉОЎОбОЋОф ОљОдОЉОбОЋОф ОЉОъОцОфОЌ ОћОљОЉОўОЌОћ</translation>
<translation id="4550926046134589611">ОЌОюОД ОъОћОДОЎОЕОЋОеОЎОЮ ОћОаОфОъОЏОЎОЮ ОЎОъОЕОЎОЏОЋ ОюОћОЎОцОфОЌ ОЉ-<ph name="APP_NAME" />.</translation>
<translation id="4551763574344810652">ОљОцОЕОе ОюОЉОўОю ОљОф ОћОцОбОЋОюОћ ОЉОћОДОЕОћ ОбОю <ph name="MODIFIER_KEY_DESCRIPTION" /></translation>
<translation id="4553526521109675518">РђЈОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОЕОцОф ОћОъОЏОЕОЎОе, ОбОюОЎОџ ОюОћОцОбОЎОю ОљОф Chromebook ОъОЌОЊОЕ. <ph name="BEGIN_LINK_LEARN_MORE" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK_LEARN_MORE" /></translation>
<translation id="4554491709904933912">ОњОЋОеОеОЎОЮ ОљОф ОАОъОЪ ОћОбОЏОЉОе ОъОбОю ОфОъОЋОаОЋОф ОЏОЊОЎ ОюОЌОцОЕ ОЉОљОъОдОбОЋОф <ph name="VISUAL_SEARCH_PROVIDER" /></translation>
<translation id="4554591392113183336">ОћОфОЋОАОБ ОћОЌОЎОдОЋОаОЎ ОћОЋОљ ОъОњОеОАОћ ОќОћОћ ОљОЋ ОДОЋОЊОъОф ОюОќОЋ ОЕОю ОћОфОЋОАОБ ОћОДОЎОЎОЮ.</translation>
<translation id="4555769855065597957">ОдОю</translation>
<translation id="4555863373929230635">РђЈОЏОЊОЎ ОюОЕОъОЋОе ОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google, ОЎОЕ ОюОћОЎОЏОаОА ОЋОюОћОцОбОЎОю ОљОф ОћОАОаОЏОеОЋОЪ.</translation>
<translation id="4558426062282641716">ОћОфОЉОДОЕОћ ОћОеОЕОљОћ ОюОћОцОбОюОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="4559617833001311418">ОћОљОфОе ОћОќОћ ОаОЎОњОЕ ОюОЌОЎОЎОЕОаОЎ ОћОфОаОЋОбОћ ОљОЋ ОћОфОљОЋОеОћ ОЕОюОџ.</translation>
<translation id="4561893854334016293">ОљОЎОЪ ОћОеОЕОљОЋОф ОЕОћОЕОфОаОЋ ОюОљОЌОеОЋОаОћ</translation>
<translation id="4562155214028662640">ОћОЋОАОцОф ОўОЉОЎОбОф ОљОдОЉОб</translation>
<translation id="4563210852471260509">ОЕОцОф ОћОДОюОў ОћОеОљОЕОЋОаОЎОф ОћОЎОљ ОАОЎОаОЎОф</translation>
<translation id="4563880231729913339">ОљОдОЉОб ОЕОюОЎОЕОЎОф</translation>
<translation id="4564245002465020751">ОАОЎОЋОЮ ОћОћОњОЊОеОћ ОЉОўОюОцОЋОЪ</translation>
<translation id="4565377596337484307">ОћОАОфОеОф ОАОЎОАОъОћ</translation>
<translation id="4565917129334815774">ОљОЌОАОЋОЪ ОЎОЋОъОаОЎ ОъОбОеОЏОф</translation>
<translation id="4566170377336116390">РђЈОљОЮ ОеОЋОдОЎОЮ ОюОћОЌОюОЎОБ ОљОЌОеОЎ ОћОеОЎОЕОЋОЮ, ОдОеОЎОџ ОюОЉОдОб ОљОЎОцОЋОА ОюОћОњОЊОеОЋОф ОћОъОДОЋОеОЎОЋОф (Powerwash) ОЉОъОЏОЕОЎОе.</translation>
<translation id="4566417217121906555">ОћОЕОфОДОф ОћОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="456717285308019641">ОЕОцОф ОћОЊОБ ОЕОЎОЕ ОюОфОеОњОЮ</translation>
<translation id="4567512141633030272">ОљОцОЕОеОЋОф ОћОЏОаОЎОАОћ ОЕОњОЋОЎОћ?</translation>
<translation id="4567533462991917415">ОфОъОЎОЊ ОљОцОЕОе ОюОћОЋОАОЎОБ ОбОЋОЊ ОљОаОЕОЎОЮ ОюОљОЌОе ОћОћОњОЊОеОћ. ОЏОю ОъОЕОфОъОЕ ОЎОЏОЋОю ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОЋ ОЋОюОћОњОЪ ОбОю ОцОеОўОЎОЋОф ОћОаОфОЋОаОЎОЮ.</translation>
<translation id="4567772783389002344">ОћОЋОАОцОф ОъОЎОюОћ</translation>
<translation id="4568025708905928793">ОћОъОбОеОЏОф ОъОЉОДОЕОф ОъОцОфОЌ ОљОЉОўОЌОћ</translation>
<translation id="4568213207643490790">РђЈОъОдОўОбОеОЎОЮ, ОюОљ ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОЌОЕОЉОЋОаОЋОф Google ОЉОъОЏОЕОЎОе ОќОћ.</translation>
<translation id="4569747168316751899">ОЉОъОдОЉ ОюОљ ОцОбОЎОю</translation>
<translation id="4570201855944865395">ОћОћОдОЊОДОћ ОюОЉОДОЕОф ОћОфОЋОАОБ ОћОќОћ:</translation>
<translation id="4572659312570518089">ОћОљОЎОъОЋОф ОЉОЋОўОю ОЉОбОф ОћОћОфОЌОЉОеОЋОф Ою-"<ph name="DEVICE_NAME" />".</translation>
<translation id="4572779512957829735">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОЕОю ОъОцОфОЌ ОћОљОЉОўОЌОћ</translation>
<translation id="457386861538956877">ОбОЋОЊ...</translation>
<translation id="4574741712540401491">Рђб  <ph name="LIST_ITEM_TEXT" /></translation>
<translation id="4576541033847873020">РђЈОћОфОљОъОф ОъОЏОЕОЎОе Bluetooth</translation>
<translation id="4576763597586015380">РђЈОбОюОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ ОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОЕОъОЋОе ОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="4579453506923101210">ОћОАОеОф ОћОўОюОцОЋОЪ ОћОъОЌОЋОЉОе</translation>
<translation id="4579581181964204535">ОюОљ ОаОЎОфОЪ ОюОћОбОЉОЎОе ОљОф <ph name="HOST_NAME" />.</translation>
<translation id="4579876313423027742">РђЈОЏОЊОЎ ОюОбОЉОЋОе ОюОћОфОеОљОЋОф ОЕОю ОћОЊОцОЊОцОЪ, ОаОЏОаОАОЎОЮ ОљОю <ph name="LINK_BEGIN" />ОћОњОЊОеОЋОф ОћОЊОцОЊОцОЪ Chrome<ph name="LINK_END" /></translation>
<translation id="4581774856936278355">РђЈОЕОњОЎОљОћ ОЉОќОъОЪ ОћОЕОЌОќОЋОе ОЕОю Linux</translation>
<translation id="4582297591746054421">ОљОфОеОЎОЮ ОДОЋОеОљОЎОЮ ОЉОЊОеОџ ОЏОюОю ОљОф ОћОюОЋОЌ ОЏОЊОЎ ОюОфОъОЋОџ ОЉОфОЏОЋОаОЋОф ОЏОъОЋ ОЕОъОЎОеОћ ОбОю ОбОЎОдОЋОЉ ОћОўОДОАОў ОЕОћОЋОбОфОД ОљОюОЎОЋ</translation>
<translation id="4582563038311694664">ОљОЎОцОЋОА ОЏОю ОћОћОњОЊОеОЋОф</translation>
<translation id="4585793705637313973">ОбОеОЎОЏОф ОћОЊОБ</translation>
<translation id="4586275095964870617">ОюОљ ОаОЎОфОЪ ОюОцОфОЋОЌ ОљОф <ph name="URL" /> ОЉОЊОцОЊОцОЪ ОЌОюОЋОцОЎ. ОЎОЕ ОюОцОаОЋОф ОюОъОаОћОю ОћОъОбОеОЏОф.</translation>
<translation id="4589713469967853491">ОћОЎОЋОъОаОЎОЮ ОаОЏОфОЉОЋ ОЉОћОдОюОЌОћ ОЉОАОцОеОЎОЎОћ 'ОћОЋОеОЊОЋОф'.</translation>
<translation id="4590324241397107707">ОљОЌОАОЋОЪ ОъОАОЊОЎ ОаОфОЋОаОЎОЮ</translation>
<translation id="4592891116925567110">ОљОцОюОЎОДОдОЎОћ ОюОдОЎОЋОе ОбОЮ ОАОўОЎОЎОюОЋОА</translation>
<translation id="4593021220803146968">&amp;ОъОбОЉОе ОљОю <ph name="URL" /></translation>
<translation id="4594577641390224176">ОеОЋОдОћ ОюОљОфОе ОљОф ОЊОБ ОћОъОЎОЊОб ОбОю ОћОъОбОеОЏОф? ОЎОЕ ОюОбОЉОЋОе ОюОЏОфОЋОЉОф</translation>
<translation id="4595560905247879544">ОеОД ОћОъОаОћОю (<ph name="CUSTODIAN_NAME" />) ОЎОЏОЋОю ОюОЕОаОЋОф ОЎОЎОЕОЋОъОЎОЮ ОЋОфОЋОАОцОЎОЮ.</translation>
<translation id="4596295440756783523">ОЎОЕ ОюОџ ОљОЎОЕОЋОеОЎОЮ ОЉОДОЋОЉОЦ ОћОъОќОћОЎОЮ ОЕОеОфОЎОЮ ОљОюОћ</translation>
<translation id="4598556348158889687">ОаОЎОћОЋОю ОљОЌОАОЋОЪ</translation>
<translation id="4598776695426288251">РђЈОЎОЕ ОљОцОЕОеОЋОЎОЋОф ОЌОЎОЉОЋОе Ою-Wi-Fi ОъОъОАОцОе ОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="4601426376352205922">ОАОЎОъОЋОЪ ОЏОцОеОЎОў ОЕОюОљ ОаОДОеОљ</translation>
<translation id="4602466770786743961">ОљОаОЎ ОеОЋОдОћ ОфОъОЎОЊ ОюОћОеОЕОЋОф Ою-<ph name="HOST" /> ОюОњОЕОф ОюОъОдОюОъОћ ОЋОюОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="4606551464649945562">ОљОфОеОЎОЮ ОюОљ ОЎОЋОЏОюОЋ ОюОЎОдОЋОе ОъОцОћ ОЉОфОюОф ОъОъОЊ ОЕОю ОћОАОЉОЎОЉОћ ОЕОюОџ ОљОЋ ОюОбОДОЋОЉ ОљОЌОе ОъОЎОДОЋОЮ ОћОъОдОюОъОћ</translation>
<translation id="4608500690299898628">&amp;ОЌОЎОцОЋОЕ...</translation>
<translation id="4608703838363792434"><ph name="FILE_NAME" /> ОъОЏОЎОю ОфОЋОЏОЪ ОеОњОЎОЕ</translation>
<translation id="4609987916561367134">РђЈОъОЋОеОЕОЎОЮ ОюОћОЕОфОъОЕ ОЉ-JavaScript</translation>
<translation id="4610162781778310380"><ph name="PLUGIN_NAME" /> ОаОфОДОю ОЉОЕОњОЎОљОћ</translation>
<translation id="4610637590575890427">ОћОљОЮ ОћОфОЏОЋОЋОаОф ОюОбОЉОЋОе ОљОю <ph name="SITE" />?</translation>
<translation id="4611114513649582138">ОЎОЕ ОЌОЎОЉОЋОеОЎ ОаОфОЋОаОЎОЮ ОќОъОЎОаОЎОЮ</translation>
<translation id="4613144866899789710">РђЈОЉОЎОўОЋОю ОћОћОфОДОаОћ ОЕОю Linux...</translation>
<translation id="4613271546271159013">ОфОЋОАОБ ОъОАОЋОЎОЮ ОЕОЎОаОћ ОљОф ОћОЊОБ ОћОъОЋОдОњ ОЉОбОф ОцОфОЎОЌОф ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ.</translation>
<translation id="4615586811063744755">РђЈОюОљ ОаОЉОЌОе ОДОЋОЉОЦ Cookie</translation>
<translation id="461661862154729886">ОъОДОЋОе ОЌОЕОъОю</translation>
<translation id="4617001782309103936">ОДОдОе ОъОЊОЎ</translation>
<translation id="4617270414136722281">ОљОцОЕОеОЋОЎОЋОф ОЕОю ОфОЋОАОцОЎОЮ</translation>
<translation id="4619564267100705184">ОљОЎОъОЋОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="4619615317237390068">ОЏОеОўОЎОАОЎОЋОф ОъОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="4620809267248568679">ОћОњОЊОеОћ ОќОЋ ОаОљОЏОцОф ОбОю ОЎОЊОЎ ОфОЋОАОБ.</translation>
<translation id="4622051949285931942">ОюОћОЕОЉОЎОф ОљОф ОЏОю ОћОбОЊОЏОЋОаОЎОЮ ОћОљОЋОўОЋОъОўОЎОЎОЮ?</translation>
<translation id="4623167406982293031">ОЎОЕ ОюОљОъОф ОљОф ОћОЌОЕОЉОЋОЪ</translation>
<translation id="4623189117674524348">РђЈОћОъОбОеОЏОф ОюОљ ОћОдОюОЎОЌОћ ОюОљОъОф ОљОф ОћОњОЎОЕОћ ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ ОюОъОъОЕОД Оћ-API.</translation>
<translation id="4625078469366263107">ОћОцОбОюОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="4627427111733173920">РђЈОДОЋОЉОдОЎ Cookie ОаОЌОАОъОЋ</translation>
<translation id="4627442949885028695">ОћОъОЕОџ ОЉОъОЏОЕОЎОе ОљОЌОе</translation>
<translation id="4628762811416793313">РђЈОћОњОЊОеОф ОъОљОњОе Linux ОюОљ ОћОЋОЕОюОъОћ. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="4629521233550547305">ОцОфОЎОЌОф ОћОцОеОЋОцОЎОю <ph name="PROFILE_NAME" /></translation>
<translation id="4632655012900268062">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОЏОеОўОЎОАОЎОЮ</translation>
<translation id="4633003931260532286">ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОфОЋОАОБ ОЎОЕ ОдОЋОеОџ ОЉ-"<ph name="IMPORT_NAME" />" ОЉОњОеОАОћ "<ph name="IMPORT_VERSION" />" ОюОцОЌОЋОф, ОљОџ ОћОњОеОАОћ ОћОъОЋОфОДОаОф ОћОЎОљ ОеОД "<ph name="INSTALLED_VERSION" />"</translation>
<translation id="4633757335284074492">РђЈОњОЎОЉОЋОЎ ОЉ-Google Drive. ОљОцОЕОе ОюОЕОЌОќОе ОаОфОЋОаОЎОЮ ОљОЋ ОюОћОЌОюОЎОБ ОъОЏОЕОЎОе ОЉОЏОю ОЕОюОЉ. ОћОњОЎОЉОЋОЎ ОћОќОћ ОЏОЋОюОю ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф. ОћОњОЎОЉОЋОЎОЎОЮ ОъОЋОбОюОЎОЮ Ою-Google ОЋОъОЋОдОцОаОЎОЮ ОЉОљОъОдОбОЋОф ОАОЎОАОъОф ОЌОЕОЉОЋОЪ Google ОЕОю ОћОЎОюОЊ/Оћ ОЕОюОџ.</translation>
<translation id="4634575639321169635">ОљОцОЕОе ОюОћОњОЊОЎОе ОљОф ОћОъОЏОЕОЎОе ОюОбОЉОЋОЊОћ ОљОЋ ОюОЕОЎОъОЋОЕ ОљОЎОЕОЎ</translation>
<translation id="4634771451598206121">ОЏОаОЎОАОћ ОъОЌОЊОЕ...</translation>
<translation id="4635072447747973225">РђЈОћОАОеОћ ОЕОю Crostini</translation>
<translation id="4635398712689569051"><ph name="PAGE_NAME" /> ОюОљ ОќОъОЎОЪ ОюОъОЕОфОъОЕОЎОЮ ОЉОъОдОЉ ОљОЋОеОЌ.</translation>
<translation id="4636682061478263818">РђЈОДОЋОЉОдОЎ Drive</translation>
<translation id="4636930964841734540">ОъОЎОЊОб</translation>
<translation id="4637083375689622795">ОцОбОЋОюОЋОф ОаОЋОАОцОЋОф, <ph name="EMAIL" /></translation>
<translation id="4637189644956543313">ОЕОЎОъОЋОЕ ОаОЋОАОБ ОЉОъОдОюОъОћ</translation>
<translation id="4637252186848840278">{COUNT,plural, =1{ОўОДОАОў}two{# ОДОўОбОЎ ОўОДОАОў}many{# ОДОўОбОЎ ОўОДОАОў}other{# ОДОўОбОЎ ОўОДОАОў}}</translation>
<translation id="4638930039313743000">РђЈОћОцОбОюОћ ОЕОю ОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОљОъОдОбОЋОф ADB</translation>
<translation id="4641539339823703554">РђЈChrome ОюОљ ОћОдОюОЎОЌ ОюОћОњОЊОЎОе ОљОф ОЕОбОф ОћОъОбОеОЏОф. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЕОбОћ ОћОъОдОЋОЎОаОф ОЉОћОъОЕОџ ОЋОюОфОДОЪ ОљОЋОфОћ ОЉОъОДОеОћ ОћОдОЋОеОџ.</translation>
<translation id="4643612240819915418">&amp;ОцОфОЎОЌОф ОАОеОўОЋОЪ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="4643833688073835173">РђЈОЌОЎОЎОЕОЪ ОъОЋОЉОаОћ ОЉ-Chromebook ОъОЕОъОЕ ОюОќОЎОћОЋОЎ ОљОаОЕОЎОЮ ОЕОаОъОдОљОЎОЮ ОъОЋОю ОћОъОЏОЕОЎОе. ОъОфОЉОдОб ОбОЎОЉОЋОЊ ОъОЎОЎОЊОЎ ОЕОю ОЏОю ОћОаОфОЋОаОЎОЮ ОЉОъОЏОЕОЎОе ОЋОљОќ ОћОЮ ОаОъОЌОДОЎОЮ. ОаОфОЋОаОЎ ОћОЌОЎОЎОЕОаОЎОЮ ОљОБ ОцОбОЮ ОюОљ ОаОЕОюОЌОЎОЮ ОљОю Google.</translation>
<translation id="4644205769234414680">ОюОљОцОЕОе ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="4645676300727003670">&amp;ОЕОъОЎОеОћ</translation>
<translation id="4646675363240786305">ОЎОдОЎОљОЋОф</translation>
<translation id="4647090755847581616">&amp;ОАОњОЎОеОф ОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="4647283074445570750">ОЕОюОЉ <ph name="CURRENT_STEP" /> ОъОфОЋОџ <ph name="TOTAL_STEPS" /></translation>
<translation id="4647697156028544508">ОћОќОаОф ОДОЋОЊ ОљОЎОъОЋОф ОбОЉОЋОе "<ph name="DEVICE_NAME" />":</translation>
<translation id="4648491805942548247">ОћОеОЕОљОЋОф ОюОљ ОъОАОцОЎОДОЋОф</translation>
<translation id="4650591383426000695">ОЎОЕ ОюОаОфОД ОљОф ОћОўОюОцОЋОЪ ОъОћ-<ph name="DEVICE_TYPE" /></translation>
<translation id="4651484272688821107">ОюОљ ОаОЎОфОЪ ОюОўОбОЋОЪ ОеОЏОЎОЉ ОљОЋОаОюОЎОЎОЪ ОбОЮ ОъОЕОљОЉОЎ ОъОдОЉ ОћОћОЊОњОъОћ.</translation>
<translation id="4652935475563630866">РђЈОћОЕОЎОаОЋОЎ ОЉОћОњОЊОеОф ОћОъОдОюОъОћ ОъОЌОЎОЎОЉ ОћОцОбОюОћ ОъОЌОЊОЕ ОЕОю Parallels Desktop. ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Parallels Desktop ОЏОЊОЎ ОюОћОъОЕОЎОџ.</translation>
<translation id="4653405415038586100">РђЈОЕОњОЎОљОћ ОЉОъОћОюОџ ОћОћОњОЊОеОћ ОЕОю Linux</translation>
<translation id="465406513924180949">РђЈОъОЋОдОњОЋОф ОюОџ ОбОњОюОЋОф ОДОаОЎОЋОф ОЏОЊОЎ ОЕОЎОћОЎОћ ОюОџ ОДОю ОюОЌОќОЋОе ОюОцОеОЎОўОЎОЮ ОЕОћОЋОАОцОф ОюОбОњОюОЋОф ОћОДОаОЎОЋОф ОЉОеОЌОЉОЎ ОћОљОЎОаОўОеОаОў.
        <ph name="BREAK" />
        <ph name="BREAK" />
        ОаОЎОфОЪ ОюОаОћОю ОљОф ОћОћОњОЊОеОЋОф ОЊОеОџ ОћОфОцОеОЎОў ОЉОЏОеОўОЎОА ОљОЋ ОюОеОљОЋОф ОбОЋОЊ ОљОцОЕОеОЋОЎОЋОф ОЉ'ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю Chrome'.</translation>
<translation id="4654236001025007561">РђЈОЕОЎОфОЋОБ ОДОЉОдОЎОЮ ОбОЮ ОъОЏОЕОЎОеОЎ Chromebook ОЋ-Android ОЉОАОЉОЎОЉОћ</translation>
<translation id="4657914796247705218">РђЈОъОћОЎОеОЋОф TrackPoint</translation>
<translation id="4658285806588491142">ОЕОъОЎОеОћ ОбОю ОцОеОўОЎОЋОф ОћОъОАОџ</translation>
<translation id="465878909996028221">РђЈОЉОћОцОаОЎОћ ОЕОю ОЊОцОЊОцОЪ ОюОЏОфОЋОЉОф URL ОљОЌОеОф, ОаОфОъОЏОЎОЮ ОеОД ОћОцОеОЋОўОЋОДОЋОюОЎОЮ http, РђЈhttps ОЋ-file.</translation>
<translation id="4659126640776004816">РђЈОћОфОЏОЋОаОћ ОћОќОЋ ОъОЋОцОбОюОф ОЉОбОф ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ Google.</translation>
<translation id="4660465405448977105">{COUNT,plural, =1{ОфОъОЋОаОћ}two{# ОфОъОЋОаОЋОф}many{# ОфОъОЋОаОЋОф}other{# ОфОъОЋОаОЋОф}}</translation>
<translation id="4660476621274971848">ОћОњОеОАОћ ОћОдОцОЋОЎОћ ОћОЎОљ "<ph name="EXPECTED_VERSION" />", ОљОЉОю ОћОњОеОАОћ ОћОЎОЎОфОћ "<ph name="NEW_ID" />"</translation>
<translation id="4660540330091848931">ОЕОЎОаОЋОЎ ОћОњОЋОЊОю ОъОфОЉОдОб</translation>
<translation id="4661407454952063730">ОаОфОЋОаОЎ ОљОцОюОЎОДОдОЎОЋОф ОћОЮ ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОаОЕОъОеОЎОЮ ОЉОљОцОюОЎОДОдОЎОЋОф (ОЉОћОфОљОЮ ОюОћОњОЊОеОЋОф ОЕОю ОћОъОцОфОЌОЎОЮ), ОЏОЋОюОю ОаОфОЋОаОЎОЮ ОЏОъОЋ ОљОаОЕОЎ ОДОЕОе, ОћОЋОЊОбОЋОф ОЋОфОъОЋОаОЋОф.</translation>
<translation id="4662373422909645029">ОљОЎОЪ ОюОЏОюОЋОю ОъОАОцОеОЎОЮ ОЉОЏОЎОаОЋОЎ</translation>
<translation id="4662788913887017617">РђЈОЕОЎОфОЋОБ ОћОАОЎОъОаОЎОЎОћ ОЉОљОъОдОбОЋОф Оћ-iPhone</translation>
<translation id="4663373278480897665">ОаОЎОфОЪ ОюОћОЕОфОъОЕ ОЉОъОдОюОъОћ ОЉОЊОБ ОќОћ</translation>
<translation id="4664482161435122549">РђЈОЕОњОЎОљОф ОЎОЎОдОЋОљ ОЕОю PKCS #12</translation>
<translation id="4665014895760275686">ОЎОдОеОЪ</translation>
<translation id="4665446389743427678">ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОъОљОЋОЌОАОаОЎОЮ ОбОю ОЎОЊОЎ <ph name="SITE" /> ОЎОЎОъОЌОДОЋ.</translation>
<translation id="4666472247053585787">ОДОЉОюОф ОћОфОеОљОЋОф ОъОћОўОюОцОЋОЪ ОЉОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЕОюОџ</translation>
<translation id="4666911709726371538">ОбОЋОЊ ОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="4667027203988048332">ОљОЎОюОЋ ОаОфОЋОаОЎОЮ ОЎОћОЎОЋ ОЉОЕОЎОъОЋОЕ:</translation>
<translation id="46733273239502219">ОћОъОбОеОЏОф ОфОъОЌОД ОњОЮ ОаОфОЋОаОЎОЮ ОЕОаОЕОъОеОЋ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ ОЉОљОцОюОЎОДОдОЎОЋОф ОъОЋОфОДОаОЋОф</translation>
<translation id="4673442866648850031">ОцОфОЎОЌОф ОЏОюОЎ ОћОАОўОЎОЎОюОЋОА ОюОљОЌОе ОЕОюОЎОцОф ОћОАОўОЎОЎОюОЋОА</translation>
<translation id="4675065861091108046">ОЉОЌОеОф ОЉОбОЉОе ОюОфОф ОћОеОЕОљОћ ОюОЏОю ОћОфОЋОАОцОЎОЮ ОЉРђЉ<ph name="ORIGIN" /></translation>
<translation id="4675828034887792601">ОЎОдОЎОеОф ОДОЎОдОЋОеОЎ ОЊОеОџ ОюОЌОЎОцОЋОЕ ОЉОљОфОеОЎОЮ ОАОцОдОЎОцОЎОЎОЮ ОЋОаОЎОћОЋОю ОЕОю ОъОаОЋОбОЎ ОћОЌОЎОцОЋОЕ</translation>
<translation id="4676595058027112862">РђЈPhone Hub, ОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="4677772697204437347">РђЈОќОЎОЏОеОЋОЪ GPU</translation>
<translation id="4677970983462111944">РђЈОљОЎ ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉ-Steam ОЉОъОЏОЕОЎОе ОћОќОћ. ОдОеОЎОџ ОюОцОаОЋОф ОюОљОЊОъОЎОЪ ОюОДОЉОюОф ОћОеОЕОљОћ
    ОДОЋОЊ ОЕОњОЎОљОћ: <ph name="ERROR_CODE" />.</translation>
<translation id="467823995058589466">ОћОъОдОюОъОћ ОЏОЉОЋОЎОћ</translation>
<translation id="4680105648806843642">ОћОдОюОЎОюОЎОЮ ОћОЋОЕОфОДОЋ ОЉОЊОБ ОћОќОћ</translation>
<translation id="4681453295291708042">ОћОЕОЉОфОћ ОЕОю 'ОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ'</translation>
<translation id="4681512854288453141">ОъОЊОЎОаОЎОЋОф ОћОъОДОЋОе</translation>
<translation id="4681930562518940301">ОцОфОЎОЌОф Оћ&amp;ОфОъОЋОаОћ ОћОъОДОЋОеОЎОф ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="4682551433947286597">ОўОцОўОЎОЮ ОъОЋОцОЎОбОЎОЮ ОЉОъОАОџ ОћОЏОаОЎОАОћ.</translation>
<translation id="4682830185876172415">ОћОћОЋОеОЊОЋОф ОћОљОЌОеОЋОаОЋОф</translation>
<translation id="4683629100208651599">ОЕОЎОаОЋОЎ ОюОљОЋОфОЎОЋОф ОДОўОаОЋОф</translation>
<translation id="4683947955326903992">РђЈРђј<ph name="PERCENTAGE" />%Рђј (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="4684427112815847243">ОАОаОЏОеОЋОЪ ОћОЏОю</translation>
<translation id="4684471265911890182"><ph name="APP_NAME" /> ОъОаОАОћ ОюОњОЕОф ОюОъОдОюОъОћ. ОЎОЕ ОюОЏОЉОЋОф ОљОф ОъОфОњ ОћОцОеОўОЎОЋОф ОЕОю ОћОъОдОюОъОћ ОЏОЊОЎ ОюОћОфОЎОе ОњОЎОЕОћ.</translation>
<translation id="4687613760714619596">ОъОЏОЕОЎОе ОюОљ ОЎОЊОЋОб (<ph name="DEVICE_ID" />)</translation>
<translation id="4688036121858134881">ОъОќОћОћ ОЎОЋОъОЪ ОъОДОЋОъОЎ: <ph name="WEBRTC_EVENT_LOG_LOCAL_ID" />.</translation>
<translation id="4688176403504673761">ОћОъОЏОЕОЎОе ОћОќОћ ОъОЋОбОЉОе ОюОњОеОАОћ ОДОЋОЊОъОф (<ph name="PROGRESS_PERCENT" />) ОбОю ОЎОЊОЎ <ph name="MANAGER" /></translation>
<translation id="4689235506267737042">ОЉОЌОЎОеОф ОћОбОЊОцОЋОф ОћОћОЊОњОъОћ</translation>
<translation id="4689421377817139245">РђЈОАОаОЏОеОЋОЪ ОћОАОЎОъОаОЎОЎОћ ОбОЮ Оћ-iPhone</translation>
<translation id="4690091457710545971">РђЈ&lt;ОДОЋОЕОЌОф Оћ-Wi-Fi ОЕОю Intel ОЎОдОеОћ ОљОеОЉОбОћ ОДОЉОдОЎОЮ: csr.lstРђЈ, fh_regs.lstРђЈ, radio_reg.lstРђЈ, monitor.lst.sysmon. ОЕОюОЋОЕОф ОћОДОЉОдОЎОЮ ОћОеОљОЕОЋОаОЎОЮ ОћОЮ ОДОЋОЉОдОЎ Dump ОЉОЎОаОљОеОЎОЎОЮ ОЕОю ОћОеОЎОЕОЋОЮ, ОЋОћОъОбОеОЏОф ОЕОю Intel ОъОўОцОюОф ОЉОћОЮ ОъОфОЋОџ ОћОаОЌОћ ОЕОћОЮ ОюОљ ОъОЏОЎОюОЎОЮ ОъОЎОЊОб ОЕОъОљОцОЕОе ОќОЎОћОЋОЎ ОљОЎОЕОЎ ОљОЋ ОќОЎОћОЋОЎ ОЕОю ОћОъОЏОЕОЎОе. ОћОДОЋОЉОЦ ОћОљОЌОеОЋОЪ ОћОЋОљ ОъОбОДОЉ ОЉОЎОдОЋОб ОъОћОДОЋОЕОЌОћ ОЕОю Intel. ОаОъОЌОД ОъОъОаОЋ ОъОЎОЊОб ОЕОъОљОцОЕОе ОќОЎОћОЋОЎ ОљОЎОЕОЎ ОљОЋ ОќОЎОћОЋОЎ ОЕОю ОћОъОЏОЕОЎОе, ОљОЉОю ОћОЋОљ ОњОЊОЋОю ОъОЊОЎ ОъОЏОЊОЎ ОюОћОдОЎОњ ОљОЋОфОЋ ОЏОљОЪ. ОћОДОЉОдОЎОЮ ОћОљОюОћ ОаОЋОдОеОЋ ОЉОфОњОЋОЉОћ ОюОЉОбОЎОЋОф ОЕОљОЎОеОбОЋ ОюОљОЌОеОЋОаОћ ОЉОЌОЎОЉОЋОе Оћ-Wi-Fi ОЕОю ОћОъОЏОЕОЎОе ОЕОюОџ, ОЋОћОЮ ОЎОЕОЋОфОцОЋ ОбОЮ Intel ОЉОаОЎОАОЎОЋОЪ ОюОцОфОЋОе ОљОф ОћОЉОбОЎОЋОф ОћОљОюОћ.&gt;</translation>
<translation id="4691791363716065510">ОюОљОфОе <ph name="ORIGIN" /> ОфОћОЎОћ ОћОеОЕОљОћ ОюОћОдОЎОњ ОљОф <ph name="FILENAME" /> ОбОЊ ОЕОЏОю ОћОЏОеОўОЎОАОЎОЋОф ОЕОю ОћОљОфОе ОЎОЎОАОњОеОЋ</translation>
<translation id="4692623383562244444">ОъОаОЋОбОЎ ОЌОЎОцОЋОЕ</translation>
<translation id="4692736633446859167">ОЉОЌОеОф ОЉОбОЉОе ОюОљ ОюОфОф ОћОеОЕОљОћ ОюОЕОЋОЮ ОфОЋОАОБ ОЉОљОфОе <ph name="SITE" />. ОљОЮ ОъОЋОАОЎОцОЎОЮ ОљОф ОћОљОфОе ОюОЏОљОЪ, ОњОЮ ОфОЋОАОцОЎОЮ ОљОЌОеОЎОЮ ОЎОЋОЏОюОЋ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОДОеОЋОљ ОЋОюОЕОаОЋОф ОљОф ОаОфОЋОаОЎ ОћОљОфОе ОЕОюОџ ОЉРђЉ<ph name="SITE" />.</translation>
<translation id="4693155481716051732">ОАОЋОЕОЎ</translation>
<translation id="4694024090038830733">ОъОаОћОю ОћОъОбОеОЏОф ОДОЋОЉОб ОљОф ОфОдОЋОеОф ОћОъОЊОцОАОф.</translation>
<translation id="4694604912444486114">ОДОЋОБ</translation>
<translation id="4697071790493980729">ОюОљ ОаОъОдОљОЋ ОфОЋОдОљОЋОф</translation>
<translation id="4697551882387947560">ОЏОљОЕОе ОћОцОбОюОф ОћОњОюОЎОЕОћ ОъОАОфОЎОЎОъОф</translation>
<translation id="469838979880025581">ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЉОДОЕ ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="4699172675775169585">ОфОъОЋОаОЋОф ОЋОДОЉОдОЎОЮ ОЉОъОўОъОЋОЪ</translation>
<translation id="4699357559218762027">(ОъОЋОцОбОюОф ОљОЋОўОЋОъОўОЎОф)</translation>
