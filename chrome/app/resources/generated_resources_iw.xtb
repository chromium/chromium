<translation id="5119173345047096771">Mozilla Firefox</translation>
<translation id="5120886753782992638">ОљОцОЕОе ОюОюОЌОЋОЦ ОЏОљОЪ ОЏОЊОЎ ОюОбОЉОЋОе ОљОю <ph name="APPROVED_URL" /></translation>
<translation id="5121052518313988218">РђЈОъОбОеОЏОф ОћОћОцОбОюОћ ОЉОДОЋОаОўОЎОЎОаОе ОЕОю Linux ОюОљ ОаОфОъОЏОф ОЎОЋОфОе. ОюОљ ОЎОфОДОЉОюОЋ ОЎОЋОфОе ОбОЊОЏОЋОаОЎ ОљОЉОўОЌОћ ОЋОфОЎОДОЋОаОЎ ОЉОљОњОЎОЮ, ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОЏОЋОаОЋОф ОЕОцОЋОбОюОЋОф ОЏОеОњОб ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОљОЋОцОЪ ОЉОюОфОЎ ОдОцОЋОЎ. ОдОеОЎОџ ОюОЕОЊОеОњ ОюОњОеОАОћ ОћОљОЌОеОЋОаОћ ОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉ-Linux.</translation>
<translation id="5121130586824819730">ОћОЊОЎОАОД ОћОДОЕОЎОЌ ОъОюОљ. ОЎОЕ ОюОЕОъОЋОе ОЉОъОЎОДОЋОЮ ОљОЌОе ОљОЋ ОюОцОаОЋОф ОъОДОЋОЮ ОЉОЊОЎОАОД ОћОДОЕОЎОЌ.</translation>
<translation id="5123433949759960244">ОЏОЊОЋОеОАОю</translation>
<translation id="5125751979347152379">ОЏОфОЋОЉОф ОљОфОе ОюОљ ОЌОЋОДОЎОф.</translation>
<translation id="5125967981703109366">ОъОЎОЊОб ОбОю ОћОЏОеОўОЎОА ОћОќОћ</translation>
<translation id="5126611267288187364">ОдОцОЎОЎОћ ОЉОЕОЎОаОЋОЎОЎОЮ</translation>
<translation id="5127242257756472928">ОљОфОеОЎОЮ ОюОюОљ ОћОеОЕОљОћ ОюОћОЕОфОъОЕ ОЉОъОЎОЊОб ОюОњОЉОЎ ОћОъОАОЏОЎОЮ ОЕОюОџ ОЏОЊОЎ ОюОцОфОЋОЌ ОЋОюОћОдОЎОЉ ОЌОюОЋОаОЋОф</translation>
