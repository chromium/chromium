<translation id="2299941608784654630">ОћОЏОюОюОћ ОЕОю ОЏОю ОДОЋОЉОдОЎ ОћОЎОЋОъОЪ ОЕОаОљОАОцОЋ ОбОю-ОЎОЊОЎ ОаОЎОцОЋОЎ ОћОЉОљОњОЎОЮ ОЏОљОеОЏОЎОЋОЪ ОаОцОеОЊ.</translation>
<translation id="2300214399009193026">PCIe</translation>
<translation id="2300332192655962933">ОћОДОЋОЉОЦ ОюОљ ОћОЎОћ ОќОъОЎОЪ ОЉОљОфОе</translation>
<translation id="2300383962156589922">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОЕОюОЎОўОћ ОЉ-<ph name="APP_NAME" /></translation>
<translation id="2301382460326681002">ОАОцОеОЎОЎОф ОћОЉОАОЎОА ОЕОю ОћОћОеОЌОЉОћ ОљОЎОаОћ ОЌОЋОДОЎОф.</translation>
<translation id="2301402091755573488">ОЏОеОўОЎОАОЎОЎОћ ОъОЕОЋОфОцОф</translation>
<translation id="2302342861452486996">РђЈ<ph name="BEGIN_H3" />ОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ<ph name="END_H3" />
      <ph name="BR" />
      ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОцОбОЎОю ОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОъОЏОЕОЎОе ChromeOS Flex ОЏОЊОЎ ОюОћОфОДОЎОЪ ОЋОюОЉОЊОЋОД ОДОЋОЊ ОъОЋОфОљОЮ ОљОЎОЕОЎОф ОЉОъОЏОЕОЎОе ОЕОюОџ. ОЏОџ ОаОЎОфОЪ:<ph name="BR" />
      <ph name="BEGIN_LIST" />
        <ph name="LIST_ITEM" />ОюОћОАОЎОе ОљОЎОъОЋОф rootfs ОЏОЊОЎ ОюОЕОаОЋОф ОДОЉОдОЎОЮ ОЕОю ОъОбОеОЏОф ОћОћОцОбОюОћ
        <ph name="LIST_ITEM" />ОюОћОцОбОЎОю ОњОЎОЕОф SSH ОюОъОЏОЕОЎОе ОЉОљОъОдОбОЋОф ОъОцОфОЌОЋОф ОћОЉОЊОЎОДОћ ОћОеОњОЎОюОЎОЮ ОЏОџ ОЕОљОцОЕОе ОЎОћОЎОћ ОюОћОЕОфОъОЕ ОЉОЏОюОЎОЮ ОЏОъОЋ <ph name="BEGIN_CODE" />'cros flashРђЈ'<ph name="END_CODE" /> ОЏОЊОЎ ОюОњОЕОф ОюОъОЏОЕОЎОе
        <ph name="LIST_ITEM" />ОюОљОцОЕОе ОљОфОЌОЋОю Оъ-USB, ОЏОЊОЎ ОЕОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОћОфОДОЎОЪ ОДОЋОЉОЦ ОљОЎОъОњ' ОЕОю ОъОбОеОЏОф ОћОћОцОбОюОћ ОъОЏОЋОаОЪ USB
        <ph name="LIST_ITEM" />ОюОћОњОЊОЎОе ОљОф ОАОЎОАОъОф ОћОЏОаОЎОАОћ ОЕОю ОћОъОцОфОЌ ОЋОљОф ОАОЎОАОъОф ОћОеОъОћ ОћОЉОАОЎОАОЎОф (root) ОюОбОеОџ ОъОЋОфОљОЮ ОљОЎОЕОЎОф ОЏОЊОЎ ОюОЉОдОб SSH ОЎОЊОаОЎ ОюОъОЏОЕОЎОе
      <ph name="END_LIST" />
      <ph name="BR" />
      ОюОљОЌОе ОћОћОцОбОюОћ ОЕОю ОћОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ, ОеОЋОЉОЪ ОЎОЎОЕОљОеОЋ ОъОЋОцОбОюОЋОф ОњОЮ ОюОљОЌОе ОЉОЎОдОЋОб Powerwash ОљОЋ ОаОЎОДОЋОЎ ОЕОю ОћОаОфОЋОаОЎОЮ ОЉОъОЏОЕОЎОе ОЕОъОаОЋОћОю ОЉОљОеОњОЋОЪ. ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОЏОю ОћОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОЉОъОюОЋОљОЪ, ОдОеОЎОџ ОюОћОЕОюОЎОЮ ОљОф ОфОћОюОЎОџ ОћОЕОЌОќОЋОе ОЕОю ChromeOSРђЈ (https://support.google.com/chromebook/answer/1080595).
      <ph name="BR" />
      <ph name="BR" />
      ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОфОЏОЋОаОЋОф ОюОаОЎОцОЋОЎ ОЉОљОњОЎОЮ ОъОцОЋОеОў ОЉОЏОфОЋОЉОф:<ph name="BR" />
      https://www.chromium.org/chromium-os/how-tos-and-troubleshooting/debugging-features
      <ph name="BR" />
      <ph name="BR" />
      <ph name="BEGIN_BOLD" />ОћОбОеОћ:<ph name="END_BOLD" /> ОћОъОбОеОЏОф ОфОЉОдОб ОћОцОбОюОћ ОъОЌОЊОЕ ОЉОќОъОЪ ОћОфОћОюОЎОџ.</translation>
<translation id="23030561267973084">"<ph name="EXTENSION_NAME" />" ОЉОЎОДОЕ ОљОЎОЕОЋОеОЎОЮ ОаОЋОАОцОЎОЮ.</translation>
<translation id="23055578400314116">ОЎОЕ ОюОЉОЌОЋОе ОЕОЮ ОъОЕОфОъОЕ</translation>
<translation id="2307462900900812319">ОћОњОЊОеОф ОеОЕОф</translation>
<translation id="2307553512430195144">РђЈОљОЮ ОаОДОЉОю ОљОф ОћОАОЏОъОфОџ, Google Assistant ОфОбОЉОЋОе ОюОъОдОЉ ОћОъОфОаОћ ОюОќОЎОћОЋОЎ ОћОцОДОЋОЊОћ РђюHey GoogleРђЮ ОЋОфОЋОЏОю ОюОќОћОЋОф ОЉОљОъОдОбОЋОф Voice Match ОЕОћОцОДОЋОЊОћ ОаОљОъОеОћ ОбОю ОЎОЊОЎ <ph name="SUPERVISED_USER_NAME" />.
    <ph name="BR" />
    ОћОфОЏОЋОаОћ Voice Match ОбОЋОќОеОф Ою-Google Assistant ОюОќОћОЋОф ОљОф ОћОДОЋОю ОЕОю <ph name="SUPERVISED_USER_NAME" /> ОЉОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЕОюОџ ОЋОюОћОЉОЊОЎОю ОЉОЎОаОЋ ОюОЉОЎОЪ ОљОЌОеОЎОЮ.
    <ph name="BR" />
    Assistant ОъОЕОфОъОЕОф ОЉОДОўОбОЎ ОћОДОЋОю ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОЏОЊОЎ ОюОЎОдОЋОе ОфОЉОаОЎОф ОДОЋОю ОЎОЎОЌОЋОЊОЎОф. ОћОфОЉОаОЎОф ОћОќОљОф ОаОЕОъОеОф ОеОД ОЉОъОЏОЕОЎОеОЎОЮ ОЕОюОћОЮ. ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОЉОаОЎОф ОћОДОЋОю ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОфОЎОЕОюОЌ ОЉОљОЋОцОЪ ОќОъОаОЎ ОљОю Google ОЏОЊОЎ ОюОЕОцОе ОљОф ОќОЎОћОЋОЎ ОћОДОЋОю ОЕОюОћОЮ.
    <ph name="BR" />
    ОћОЌОюОўОф ОЕОћОфОЏОЋОаОћ Voice Match ОюОљ ОъОфОљОЎОъОћ ОюОЎОюОЊ ОљОЋ ОюОЎОюОЊОћ? ОЉОЏОю ОЕОюОЉ ОаОЎОфОЪ ОюОћОАОЎОе ОљОф ОћОфОЏОЋОаОћ ОЉОћОњОЊОеОЋОф ОЕОю Assistant ОЕОюОћОЮ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОеОљОЋОф ОљОЋ ОюОъОЌОЋОД ОљОф ОДОўОбОЎ ОћОДОЋОю ОЕОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ ОћОДОюОЎОўОЋ ОЉОћОњОЊОеОћ ОЕОю Voice Match ОЉОЏОфОЋОЉОф <ph name="VOICE_MATCH_SETTINGS_URL" />, ОъОћОЌОЕОЉОЋОЪ ОЕОю ОћОЎОюОЊ ОљОЋ ОћОЎОюОЊОћ.
    <ph name="BR" />
    <ph name="FOOTER_MESSAGE" /></translation>
<translation id="2307630946657910723">ОЌОЎОцОЋОЕ ОЉОЌОюОД ОъОћОЊОБ ОЉОљОъОдОбОЋОф <ph name="VISUAL_SEARCH_PROVIDER" /></translation>
<translation id="2309620859903500144">ОаОЌОАОъОћ ОћОњОЎОЕОћ ОЕОю ОћОљОфОе ОћОќОћ ОљОю ОЌОЎОЎОЕОаОЎ ОћОфОаОЋОбОћ ОљОЋ ОћОфОљОЋОеОћ.</translation>
