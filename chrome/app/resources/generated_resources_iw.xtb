<translation id="2473195200299095979">ОфОеОњОЋОЮ ОћОЊОБ</translation>
<translation id="2475982808118771221">ОљОЎОеОбОћ ОЕОњОЎОљОћ</translation>
<translation id="2476578072172137802">ОћОћОњОЊОеОЋОф ОюОљОфОеОЎОЮ</translation>
<translation id="2476974672882258506">РђЈОЎОЕ ОюОЏОЉОЋОф ОљОф Windows ОЏОЊОЎ ОюОћОАОЎОе ОљОф <ph name="PARALLELS_DESKTOP" />.</translation>
<translation id="2477065602824695373">ОћОАОеОЎОДОћ ОћОљОЋОўОЋОъОўОЎОф ОъОЋОЕОЉОфОф ОЏОЎ ОћОњОЊОеОф ОЏОъОћ ОъОфОњОЎОЮ.</translation>
<translation id="2478176599153288112">ОћОеОЕОљОЋОф ОЕОю ОДОЋОЉОЦ ОъОЊОЎОћ ОбОЉОЋОе "<ph name="EXTENSION" />"</translation>
<translation id="248003956660572823">ОћОАОЎОАОъОљОЋОф ОюОљ ОаОЕОъОеОЋ</translation>
<translation id="2480868415629598489">ОЕОЎОаОЋОЎ ОаОфОЋОаОЎОЮ ОЕОћОбОфОДОф ОЋОћОЊОЉОДОф</translation>
<translation id="2482878487686419369">ОћОфОеОљОЋОф</translation>
<translation id="2482895651873876648">ОћОЏОеОўОЎОАОЎОЎОћ ОћОЋОбОЉОеОћ ОюОДОЉОЋОдОћ <ph name="GROUP_NAME" /> РђЈРђЊ <ph name="GROUP_CONTENTS" /></translation>
<translation id="2484959914739448251">РђЈОЏОЊОЎ ОюОаОДОЋОф ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОъОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ ОЋОъОЌОЕОЉОЋОЪ Google ОЕОюОџ, <ph name="BEGIN_LINK" />ОЎОЕ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ<ph name="END_LINK" />.</translation>
<translation id="2485394160472549611">ОћОъОюОдОЋОф ОЉОЕОЉОЎОюОџ</translation>
<translation id="2485422356828889247">ОћОАОеОф ОћОфОДОаОћ</translation>
<translation id="2485681265915754872">РђЈОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф ОЕОю Google Play</translation>
<translation id="2487067538648443797">ОћОЋОАОцОф ОАОЎОъОаОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="2487268545026948104">ОЏОЊОЎ ОюОЕОЌОќОе ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ, ОЎОЕ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="2489686758589235262">ОћОДОдОљОф 2 ОъОфОњОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="2489829450872380594">РђЈОЉОцОбОЮ ОћОЉОљОћ, ОўОюОцОЋОЪ ОЌОЊОЕ ОЎОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю Оћ-<ph name="DEVICE_TYPE" /> ОћОќОћ. ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф Smart Lock ОЊОеОџ ОћОћОњОЊОеОЋОф.</translation>
<translation id="2489918096470125693">ОћОЋОАОцОф &amp;ОфОЎОДОЎОЎОћ...</translation>
<translation id="2489931062851778802">ОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОћОфОЋОЋОЎОЮ ОћОљОюОћ ОЉОъОЏОЕОЎОе <ph name="DEVICE_NAME" /></translation>
<translation id="2490481887078769936">'<ph name="FILE_NAME" />' ОћОЋОАОе ОъОћОеОЕОЎОъОћ</translation>
<translation id="249113932447298600">ОъОдОўОбОеОЎОЮ, ОћОъОЏОЕОЎОе <ph name="DEVICE_LABEL" /> ОљОЎОаОЋ ОаОфОъОџ ОЉОЕОюОЉ ОќОћ.</translation>
<translation id="2492461744635776704">ОћОъОбОеОЏОф ОъОЏОЎОаОћ ОљОф ОЉОДОЕОф ОћОЌОфОЎОъОћ ОбОю ОљОЎОЕОЋОе</translation>
<translation id="2493126929778606526">ОћОфОъОЋОаОЋОф ОћОўОЋОЉОЋОф ОЉОЎОЋОфОе ОЕОюОџ ОЕОаОЉОЌОеОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="2495524171012645395">ОъОфОЏОЋОаОЎОЮ ОЕОдОцОЎОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ</translation>
<translation id="2496180316473517155">ОћОЎОАОўОЋОеОЎОЎОф ОњОюОЎОЕОћ</translation>
<translation id="2497229222757901769">ОъОћОЎОеОЋОф ОбОЏОЉОе</translation>
<translation id="2497852260688568942">ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ ОћОЕОЉОЎОф ОљОф ОћОАОаОЏОеОЋОЪ</translation>
