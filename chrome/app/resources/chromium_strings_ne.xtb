<!DOCTYPE translationbundle>
<translationbundle lang="ne">
<translation id="1026101648481255140">इन्स्टल गर्ने प्रक्रिया सुचारु गर्नुहोस्</translation>
<translation id="1029669172902658969">&amp;ChromiumOS अपडेट गर्न यसलाई रिलन्च गर्नुहोस्</translation>
<translation id="1040916596585577953">Chromium तपाईंलाई यो एक्स्टेन्सनको समीक्षा गर्न सिफारिस गर्छ</translation>
<translation id="1042552502243217427">कुनै साइटले आफ्नो पेजमा भएका लिंकहरू गोप्य तरिकाले प्रिलोड गर्न लगाएका खण्डमा Chromium ले Google का सर्भरहरू प्रयोग गर्छ। यसो गर्दा प्रिलोड गरिएको साइटमा भएको तपाईंको पहिचान खुलाउने जानकारी लुकाइन्छ तर Google ले कुन कुन साइट प्रिलोड गरिन्छन् भन्ने कुरा सिक्छ।</translation>
<translation id="1065672644894730302">तपाइँका प्राथमिकातहरू पढ्न सकिदैन।

केही सुविधाहरू अनुपलब्ध हुन सक्छन् र प्राथमिकताहरूमा परिवर्तनहरू बचत हुने छैनन्।</translation>
<translation id="1083934481477628225">तपाईंका अभिभावकले Chromium का हकमा "साइट, एप तथा एक्सटेन्सनसम्बन्धी अनुमति" अफ गर्नुभएको छ</translation>
<translation id="1098170124587656448">Chromium ले तपाईंलाई डेटा चोरीका घटना, हानिकारक एक्स्टेन्सन र थप समस्याहरूबाट सुरक्षित रहन मद्दत गर्न सक्छ</translation>
<translation id="1104942323762546749">Chromium तपाईंका पासवर्डहरू निर्यात गर्न चाहन्छ। यसो गर्ने अनुमति दिन Windows को आफ्नो पासवर्ड टाइप गर्नुहोस्‌।</translation>
<translation id="112640046208448578">वस्तु वा ठाउँहरू पहिचान गर्नुहोस् र टेक्स्ट कपी वा अनुवाद गर्नुहोस्। तपाईंले फोटो प्रयोग गरी खोज्ने सुविधा प्रयोग गर्दा यो पेजको एउटा स्क्रिनसट सर्भरमा पठाइन्छ। <ph name="LEARN_MORE" /></translation>
<translation id="113122355610423240">Chromium तपाईंको डिफल्ट ब्राउजर हो</translation>
<translation id="1131805035311359397">तपाईंका पासवर्डहरू कतै खुलासा भएका छन् कि छैनन् तथा सुरक्षासम्बन्धी अन्य समस्याबाट सुरक्षित छन् कि छैनन् भन्ने कुरा जाँच्न <ph name="BEGIN_LINK" />Chromium मा साइन इन गर्नुहोस्<ph name="END_LINK" />।</translation>
<translation id="1153368717515616349">Chromium मेनुमा क्लिक गर्नुहोस्</translation>
<translation id="1157985233335035034">हालसालै चयन गरिएका भाषाहरू</translation>
<translation id="1184145431117212167">तपाईंको डिभाइसमा भएको Windows को संस्करणमा नचल्ने भएकाले इन्स्टल गर्न सकिएन।</translation>
<translation id="1185134272377778587">Chromium का बारेमा</translation>
<translation id="1188705220418984327">आफ्नो विन्डो सेयर गर्न सिस्टमका प्राथमिकताहरूमा गई Chromium लाई स्क्रिन रेकर्ड गर्ने अनुमति दिनुहोस्।</translation>
<translation id="1203500561924088507">इन्स्टल गर्नुभएकोमा धन्यवाद। <ph name="BUNDLE_NAME" /> प्रयोग गर्नुअघि तपाईंले अनिवार्य रूपमा आफ्नो ब्राउजर रिस्टार्ट गर्नु पर्छ।</translation>
<translation id="1262876892872089030">यो ट्याब निष्क्रिय हुँदा Chromium छिटो चल्ने बनाइराख्न मेमोरी खाली गरिएको थियो। तपाईं यो साइटलाई जुनसुकै बेला सक्रिय राखिराख्ने विकल्प छनौट गर्न सक्नुहुन्छ।</translation>
<translation id="1265577313130862557">यो फाइल खतरनाक भएकाले Chromium ले यो फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="126567311906253476"><ph name="USER_EMAIL" /> मार्फत Google का Gmail वा YouTube लगायतका सेवाहरूमा साइन इन गर्दा तपाईं उही खातामार्फत Chromium मा स्वतः साइन इन गर्न सक्नुहुन्छ</translation>
<translation id="1290883685122687410">सेटअप गर्ने क्रममा निम्न त्रुटि भयो: <ph name="METAINSTALLER_EXIT_CODE" />। <ph name="WINDOWS_ERROR" /></translation>
<translation id="1315551408014407711">Chromium मा आफ्नो नयाँ प्रोफाइल सेटअप गर्नुहोस्</translation>
<translation id="1324107359134968521">Chromium सँग ब्लुटुथ डिभाइसहरू खोज्नका निम्ति 
 ब्लुटुथको एक्सेस हुनु पर्छ। <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK" /></translation>
<translation id="1330562121671411446">भाषा पहिचान गर्नुहोस्</translation>
<translation id="1342274909142618978">यो जानकारी Chromium बाट पनि मेटाउनुहोस् (<ph name="URL" />)</translation>
<translation id="1345251407431278948">पिन गरियो! तपाईं टुलबारमा भएको नयाँ बटन थिचेर फोटो प्रयोग गरी खोज्ने सुविधा फेरि एक्सेस गर्न सक्नुहुन्छ</translation>
<translation id="1414495520565016063">तपाइँ Chromium मा साइन इन</translation>
<translation id="1478370723027452770">Chrome for Testing का सम्बन्धमा मद्दत प्राप्त गर्नुहोस्</translation>
<translation id="1497802159252041924">इन्स्टल गर्ने क्रममा त्रुटि भयो: <ph name="INSTALL_ERROR" /></translation>
<translation id="1524282610922162960">Chromium को ट्याब सेयर गर्नुहोस्</translation>
<translation id="1553461853655228091">Chromium लाई तपाईं वरपरको ठाउँको 3D नक्सा बनाउन तपाईंको क्यामेरा प्रयोग गर्ने अनुमति चाहिन्छ</translation>
<translation id="1555494096857516577">{NUM_EXTENSIONS,plural, =1{यो एक्स्टेन्सन अब प्रयोग गर्न मिल्दैन। Chromium ले तपाईंलाई यो एक्स्टेन्सन हटाउन सिफारिस गर्छ।}other{यी एक्स्टेन्सनहरू अब प्रयोग गर्न मिल्दैनन्। Chromium ले तपाईंलाई यी एक्स्टेन्सनहरू हटाउन सिफारिस गर्छ।}}</translation>
<translation id="1574377791422810894">Chromium का सुरक्षासम्बन्धी टुलहरू</translation>
<translation id="1591808205441691831">Chromium ले तपाईंको पहिचान पुष्टि गरेपछि मात्र तपाईं आफ्नो Google खातामा कुनै डेटा सेभ गर्न र उक्त डेटा आफ्ना सबै डिभाइसहरूमा प्रयोग गर्न सक्नुहुन्छ। तपाईंले साइन आउट गर्नुभयो भने उक्त डेटा यो डिभाइसमा रहिरहने छ।</translation>
<translation id="1594928384848033697">Chromium तपाईंको पासवर्ड म्यानेजरमा भएको जानकारी मेटाउन चाहन्छ। यसो गर्ने अनुमति दिन Windows को पासवर्ड टाइप गर्नुहोस्।</translation>
<translation id="1607715478322902680">{COUNT,plural, =0{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न Chromium पुनः सुरु गर्नु पर्ने हुन्छ}=1{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न Chromium पुनः सुरु गर्नु पर्ने हुन्छ। तपाईंको इन्कोग्निटो विन्डो पुनः खुल्ने छैन।}other{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न Chromium पुनः सुरु गर्नु पर्ने हुन्छ। तपाईंका # वटा इन्कोग्निटो विन्डो पुनः खुल्ने छैनन्।}}</translation>
<translation id="1625909126243026060">Chromium मा भएका गोपनीयता र सुरक्षासम्बन्धी मुख्य नियन्त्रण सुविधाहरूको समीक्षा गर्नुहोस्</translation>
<translation id="1632539827495546968">तपाईं यो खाता एक पटक मात्र प्रयोग गर्न चाहनुहुन्छ भने तपाईं Chromium ब्राउजरमार्फत <ph name="GUEST_LINK_BEGIN" />गेस्ट मोड<ph name="GUEST_LINK_END" /> प्रयोग गर्न सक्नुहुन्छ। तपाईं अरू कसैको खाता लिंक गर्न चाहनुहुन्छ भने उहाँलाई <ph name="LINK_BEGIN" />नयाँ व्यक्तिका रूपमा<ph name="LINK_END" /> आफ्नो <ph name="DEVICE_TYPE" /> मा सामेल गराउनुहोस्।

तपाईंले वेबसाइट तथा एपहरूलाई दिइसक्नुभएका अनुमति यो खाताका हकमा पनि लागू हुन सक्छ। तपाईं <ph name="SETTINGS_LINK_BEGIN" />सेटिङ<ph name="SETTINGS_LINK_END" />मा गई आफ्ना Google खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ।</translation>
<translation id="1640672724030957280">डाउनलोड गरिँदै छ...</translation>
<translation id="167397405791113306">तपाईंको पासफ्रेज प्रयोग गरी तपाईंको डेटा इन्क्रिप्ट गरिएको छ। आफ्नो Google खातामा Chromium को डेटा सेभ गर्न तथा सो डेटा प्रयोग गर्न तपाईंको पासफ्रेज हाल्नुहोस्।</translation>
<translation id="1709772298389099340">यो सेवाले <ph name="BROWSER_NAME" /> का खास विशेषाधिकारहरू उपलब्ध गराउँछ।</translation>
<translation id="1715127912119967311">यी सुविधाहरूको गुणस्तर सुधार्ने प्रयोजनका लागि Chromium ले तपाईंले यी सुविधासँग गरेका अन्तर्क्रियासम्बन्धी जानकारी Google लाई पठाउँछ। समीक्षकहरू यो जानकारी पढ्न, प्रोसेस गर्न र एनोटेट गर्न सक्छन्।</translation>
<translation id="1722488837206509557">तपाईंले यो अनुमति दिनुभयो भने तपाईं उपलब्ध डिभाइसहरूमध्येबाट कुनै डिभाइस चयन गर्न र उक्त डिभाइसमा सामग्री देखाउन सक्नु हुने छ।</translation>
<translation id="17264556997921157">तपाईं वेबसाइटहरूले तपाईंलाई विज्ञापन देखाउन प्रयोग गर्ने रुचिका विषयहरू हेर्न तथा हटाउन सक्नुहुन्छ। Chromium ले तपाईंको हालसालैको ब्राउजिङ इतिहासका आधारमा तपाईंलाई रुचि लाग्न सक्ने विषयहरू पत्ता लगाउँछ।</translation>
<translation id="1733725117201708356">Chromium ले चाँडै नै ब्राउजिङ डेटा मेटाउने छ</translation>
<translation id="1736443181683099871">Chromium ले वेबपेजहरू लोड गर्न HTTPS प्रयोग गर्ने प्रयास गर्ने छ</translation>
<translation id="1736662517232558588">Chromium सम्बन्धी डेटा हटाइयो</translation>
<translation id="1745121272106313518">Chromium <ph name="REMAINING_TIME" /> पछि रिस्टार्ट हुने छ</translation>
<translation id="1749104137266986751">HTTPS उपलब्ध नहुँदा Chromium ले तपाईंलाई चेतावनी नदिइकनै असुरक्षित कनेक्सन प्रयोग गर्ने छ</translation>
<translation id="1774152462503052664">क्रोमियम पृष्ठभूमिमा चलाउछन्</translation>
<translation id="1779356040007214683">Chromium लाई अझ सुरक्षित बनाउनको लागि, हामीले <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> मा सूचीकृत नगरिएका केही एक्स्टेन्सनहरूलाई अक्षम बनाएका छौँ र तपाईंलाई थाहा दिए बिना थपिएको हुन सक्छ।</translation>
<translation id="1808667845054772817">Chromium पुनर्स्थापित गर्नुहोस्</translation>
<translation id="1820835682567584003">Chromium <ph name="AUTHENTICATION_PURPOSE" /> प्रयास गर्दै छ</translation>
<translation id="18552579716432081">तपाईंको Google खातामा ब्राउजिङ डेटा यथावत् राखी यो डिभाइसबाट मात्र ब्राउजिङ डेटा मेटाउन <ph name="BEGIN_LINK" />Chromium बाट साइन आउट गर्नुहोस्<ph name="END_LINK" />।</translation>
<translation id="185970820835152459">तपाईं साइन इन गरिएका आफ्ना Google खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ। तपाईंका Google खाताहरू Chromium ब्राउजर, Play स्टोर, Gmail र अन्य एपहरूमा प्रयोग गरिन्छन्। तपाईं परिवारका सदस्य जस्ता अरू कसैको खाता थप्न चाहनुहुन्छ भने उहाँको खाता थप्नुको साटो उहाँलाई नयाँ व्यक्तिका रूपमा आफ्नो <ph name="DEVICE_TYPE" /> मा सामेल गराउनुहोस्। <ph name="LINK_BEGIN" />थप जान्नुहोस्<ph name="LINK_END" /></translation>
<translation id="1862852878885210965">फोटो प्रयोग गरी खोज्ने सुविधामार्फत खोज्नुहोस्</translation>
<translation id="1863308913976887472">साइटहरूले Chromium मा तपाईंका रुचिसम्बन्धी जानकारी भण्डारण गर्न सक्छन्। उदाहरणका लागि, तपाईंले कुनै साइटमा गएर म्याराथनमा दौडिँदा लगाइने जुत्ता किन्नुभयो भने उक्त साइटले तपाईं म्याराथन दौडमा रुचि राख्नुहुन्छ भन्ने कुरा बुझ्न सक्छ। पछि तपाईं दौड प्रतियोगितामा आफ्नो नाम लेखाउन अर्कै साइटमा जानुभयो भने उक्त साइटले तपाईंको रुचिका आधारमा तपाईंलाई दौडिँदा लगाइने जुत्ताको विज्ञापन देखाउन सक्छ।</translation>
<translation id="1880677175115548835">टेक्स्ट म्यासेज चयन गर्नुहोस्</translation>
<translation id="1881322772814446296">तपाईंले व्यवस्थित खातासँगै साइन इन गरि यसको व्यवस्थापकलाई तपाईंको क्रोमियम प्रोफाइल माथि नियन्त्रण दिइरहनुभएको छ। तपाईंको क्रोमियम डाटा, जस्तै तपाईंका एप्स, बुकमार्कहरू, इतिहास, पासवर्डहरू, र अन्य सेटिङहरू <ph name="USER_NAME" /> मा स्थायी रूपमा बाँधिनेछन्। तपाईं यस डाटालाई गूगल खाता ड्यासबोर्ड मार्फत मेटाउन सक्षम हुनुहुनेछ, तर तपाईं यस खातालाई अर्को खातामा संलग्न गर्न सक्षम हुनुहुनेछैन। तपाईंले आफ्नो विद्यमान क्रोमियम डाटालाई अलग राख्न वैकल्पिक रूपमा नयाँ प्रोफाइल सिर्जना गर्न सक्नुहुन्छ। <ph name="LEARN_MORE" /></translation>
<translation id="1900969832270057921">Chromium अपडेटर सर्भिस</translation>
<translation id="1906696617298807388">तपाईंले एड्रेस बार वा खोज बाकसमा टाइप गर्दा तपाईंलाई सामग्रीसम्बन्धी सुझावहरू देखाउन सकियोस् भन्नाका लागि Chromium ले तपाईंले टाइप गर्ने कुरा Google Drive मा पठाउँछ। इन्कोग्निटो मोडमा यो सुविधा अफ हुन्छ।</translation>
<translation id="1911763535808217981">यसलाई निष्क्रिय पारेर, तपाईं Chromium मा साइन इन नगरिकनै Gmail जस्ता Google का साइटहरूमा साइन इन गर्न सक्नुहुन्छ</translation>
<translation id="1929939181775079593">Chromium ले कुनै प्रतिक्रिया जनाइरहेको छैन। अहिले नै पुन: लन्च गर्ने?</translation>
<translation id="1933341829955786215">तपाईंको सङ्गठन <ph name="MANAGER" /> को नीतिअनुसार तपाईंले Chromium मा साइन इन गर्नु पर्ने हुन्छ</translation>
<translation id="193439633299369377">यो अपडेट लागू गर्न ChromiumOS रिस्टार्ट गर्नु पर्ने हुन्छ।</translation>
<translation id="1951406923938785464">यस प्रकारको फाइल सामान्यतया डाउनलोड नगरिने र खतरनाक हुन सक्ने भएकाले Chromium ले उक्त प्रकारको फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="1953553007165777902">डाउनलोड गरिँदै छ... <ph name="MINUTE" /> मिनेट बाँकी छ</translation>
<translation id="1966382378801805537">Chromium ले डिफल्ट ब्राउजर निर्धारण वा सेट गर्न सक्दैन</translation>
<translation id="1990262977744080398">Chromium ले केही फाइलहरू ब्लक गर्नुको कारण जान्नुहोस् (नयाँ ट्याबमा खुल्छ)</translation>
<translation id="1999715455684970349">तपाईंको Chromium सफ्टवेयर अप टू डेट राख्छ। यो सेवा अफ गरिएका वा रोकिएका खण्डमा तपाईंको Chromium सफ्टवेयर अप टू डेट राखिने छैन। त्यसकारण, उक्त सफ्टवेयरमा देखिन सक्ने समस्याहरू समाधान गर्न सकिँदैन र त्यसमा भएका सुविधाहरूले काम नगर्न सक्छन्। कुनै पनि Chromium सफ्टवेयरले यो सेवा प्रयोग गरिरहेको छैन भने यो सेवा स्वतः अनइन्स्टल हुन्छ।</translation>
<translation id="2008474315282236005">यसले यो डिभाइसको १ वस्तु मेट्नेछ। पछि आफ्नो डेटा प्राप्त गर्न Chromium मा <ph name="USER_EMAIL" /> को रूपमा साइन इन गर्नुहोस्।</translation>
<translation id="2018879682492276940">इन्स्टल गर्न सकिएन। कृपया फेरि प्रयास गर्नुहोस्।</translation>
<translation id="2020032459870799438">तपाईंका अन्य पासवर्डहरू कतै खुलासा भएका छन् कि छैनन् तथा सुरक्षासम्बन्धी अन्य समस्याबाट सुरक्षित छन् कि छैनन् भन्ने कुरा जाँच्न <ph name="BEGIN_LINK" />Chromium मा साइन इन गर्नुहोस्<ph name="END_LINK" />।</translation>
<translation id="2049376729098081731">Google का सेवाहरूमा आफ्नो आवश्यकताअनुसारका सुविधाहरू पाउन Chromium को ब्राउजिङ इतिहास समावेश गर्ने कि नगर्ने भन्ने कुरा छनौट गर्नुहोस्</translation>
<translation id="2086476982681781442">यो फाइल भ्रामक भएको र यसले तपाईंको डिभाइसमा अनपेक्षित परिवर्तन गर्न सक्ने भएकाले Chromium ले यो फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="2088953378266246249">Chromium ले आफ्ना मूल प्रमाणपत्र कसरी व्यवस्थापन गर्छ भन्ने कुरासम्बन्धी जानकारी</translation>
<translation id="2120965832000301375">{COUNT,plural, =1{Chromium १ मिनेटसम्म प्रयोग नगरिएका खण्डमा तपाईंको सङ्गठनले ब्राउजिङ डेटा स्वतः मेटाउँछ। यसअन्तर्गत हिस्ट्री, अटोफिल तथा डाउनलोड समावेश हुन सक्छन्। तपाईंका ट्याबहरू खुलै रहने छन्।}other{Chromium # मिनेटसम्म प्रयोग नगरिएका खण्डमा तपाईंको सङ्गठनले ब्राउजिङ डेटा स्वतः मेटाउँछ। यसअन्तर्गत हिस्ट्री, अटोफिल तथा डाउनलोड समावेश हुन सक्छन्। तपाईंका ट्याबहरू खुलै रहने छन्।}}</translation>
<translation id="2126108037660393668">डाउनलोड गरिएको फाइल पुष्टि गर्न सकिएन।</translation>
<translation id="2137162749895930932">अनुवाद गर्ने सुविधा भएको स्क्रिन बन्द गर्नुहोस्</translation>
<translation id="215352261310130060">यो साइटले सुरक्षित कनेक्सन प्रयोग नगरिरहेको र यो फाइलमा छेडखानी गरिएको हुन सक्ने भएकाले Chromium ले यो फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="2157600032285353789">तपाईं Chromium मेनुबाट बुकमार्क, रिडिङ मोड र अन्य कुराहरू खोल्न सक्नुहुन्छ</translation>
<translation id="2174178932569897599">Chromium आफूले चाहे जस्तो बनाउनुहोस्</translation>
<translation id="2174917724755363426">इन्स्टल गर्ने प्रक्रिया पूरा भएन। तपाईंले यो प्रक्रिया रद्द गर्न खोज्नुभएकै हो?</translation>
<translation id="2185166961232948079">Chromium - नेटवर्क साइन इन - <ph name="PAGE_TITLE" /></translation>
<translation id="2190166659037789668">अपडेट उपलब्ध छ कि छैन भन्ने कुरा जाँच्ने क्रममा निम्न त्रुटि भयो: <ph name="UPDATE_CHECK_ERROR" />।</translation>
<translation id="2199210295479376551">Chromium बाट खाता हटाउनुहोस्</translation>
<translation id="2210682093923538346">खतरनाक साइट। Chromium ले नोटिफिकेसनसम्बन्धी अनुमतिहरू रद्द गरेको छ।</translation>
<translation id="2236949375853147973">मेरो गतिविधि</translation>
<translation id="2240214816234246077">तपाईंले हालसालै कुनै पनि साइट खोल्नुभएको छैन। Chromium ले <ph name="PERMISSION_1" />, <ph name="PERMISSION_2" /> रद्द गरेको छ</translation>
<translation id="2241627712206172106">यदि तपाईँले कम्प्युटरलाई साझा गर्नुभयो भने, साथी तथा परिवारले अलग रूपमा ब्राउज गर्न सक्छन् र तिनीहरूले चाहे अनुरूपको क्रोमियम सेटअप गर्न सक्छन्।</translation>
<translation id="2313870531055795960">Chromium मा भण्डारण गरिएका असुरक्षित साइटको सूची जाँच गरी URL हरू सुरक्षित छन् कि छैनन् भन्ने कुरा यकिन गर्छ। कुनै साइटले तपाईंको पासवर्ड चोरी गर्न खोज्दा वा तपाईंले कुनै हानिकारक फाइल डाउनलोड गर्दा Chromium ले पेजमा भएका केही सामग्रीसहित उक्त साइटका URL हरू Safe Browsing मा पठाउन पनि सक्छ।</translation>
<translation id="2343156876103232566">यहाँबाट आफ्नो Android फोनमा कुनै नम्बर पठाउन दुवै यन्त्रमा Chromium मा साइन इन गर्नुहोस्।</translation>
<translation id="2359808026110333948">जारी राख्नुहोस्</translation>
<translation id="2361918034042471035">"<ph name="EXTENSION_NAME" />" एक्स्टेन्सनले तपाईंलाई Chromium मा साइन गर्न अनुरोध गरिरहेको छ</translation>
<translation id="2374216753258219393"><ph name="USER_EMAIL_ADDRESS" /> मार्फत यो एक्स्टेन्सन प्रयोग गर्न Chromium मा साइन इन गर्नुहोस्।</translation>
<translation id="2384373936468275798">तपाईंको खाताको साइन इनसम्बन्धी विवरणको म्याद सकिएको हुनाले ChromiumOS ले तपाईंको डेटा सिंक गर्न सकेन।</translation>
<translation id="2398377054246527950">{NUM_DEVICES,plural, =0{एउटा वा सोभन्दा बढी Chromium एक्स्टेन्सनले एउटा HID डिभाइस प्रयोग गरेका थिए}=1{एउटा वा सोभन्दा बढी Chromium एक्स्टेन्सनले एउटा HID डिभाइस प्रयोग गरिरहेका छन्}other{एउटा वा सोभन्दा बढी Chromium एक्स्टेन्सनले # वटा HID डिभाइस प्रयोग गरिरहेका छन्}}</translation>
<translation id="2401032172288869980">यो साइट चलाउन Chromium लाई क्यामेरा तथा माइक्रोफोन प्रयोग गर्ने अनुमति दिनु पर्ने हुन्छ</translation>
<translation id="2403703063067034158">स्टार्टअप गर्ने क्रममा निम्न त्रुटि भयो: हाल कुनै अर्को कुरा सेटअप गरिँदै छ, कृपया पछि फेरि प्रयास गर्नुहोस्।</translation>
<translation id="2440750600860946460">तपाईं <ph name="BEGIN_LINK" />Chromium मा उपलब्ध टुलहरू<ph name="END_LINK" /> प्रयोग गरी सुरक्षित तरिकाले र आफ्नै नियन्त्रणमा ब्राउज गर्न सक्नुहुन्छ</translation>
<translation id="2451727308784734061">पासवर्ड म्यानेजरमा तुरुन्तै जान आफ्नो सर्टकट प्रयोग गर्नुहोस्। तपाईं आफ्नो सर्टकट सारेर कम्प्युटरको होम स्क्रिन वा एप लन्चरमा लैजान सक्नुहुन्छ।</translation>
<translation id="2478295928299953161">Chromium ले चाँडै नै विन्डोहरू बन्द गर्ने छ</translation>
<translation id="2483889755041906834">Chromium मा</translation>
<translation id="2485422356828889247">विस्थापन गर्नुहोस्</translation>
<translation id="2513154137948333830">रिबुट गर्नु पर्ने हुन्छ: <ph name="INSTALL_SUCCESS" /></translation>
<translation id="2542968102051442371">फोटो प्रयोग गरी खोज्ने सुविधा प्रयोग गरी टेक्स्ट चयन गर्नुहोस्</translation>
<translation id="2554739539410784893">Chromium ले हालका पासवर्डहरू बदल्न खोजिरहेको छ। यसो गर्ने अनुमति दिन Windows को पासवर्ड टाइप गर्नुहोस्।</translation>
<translation id="2560420686485554789">Chromium लाई फाइलहरू डाउनलोड गर्न भण्डारणमाथिको पहुँच आवश्यक पर्छ</translation>
<translation id="2572494885440352020">Chromium सहायक</translation>
<translation id="2575822587468774919">फोटो प्रयोग गरी खोज्ने सुविधामार्फत खोज्नका निम्ति जुनसुकै कुरा चयन गर्नुहोस्</translation>
<translation id="2576118232315942160">आफ्ना सबै डिभाइसमा आफ्ना पासवर्डलगायतका थप कुराहरू प्राप्त गर्न Chromium मा साइन इन गर्नुहोस्</translation>
<translation id="2583187216237139145">कार्य प्रोफाइलका एड्मिन यो प्रोफाइल चलाउँदा Chromium मा सिर्जना हुने (बुकमार्क, इतिहास, पासवर्ड र अन्य सेटिङलगायतका) सबै डेटा हटाउन सक्नुहुन्छ। <ph name="LEARN_MORE" /></translation>
<translation id="2592940277904433508">Chromium प्रयोग गरिराख्नुहोस्</translation>
<translation id="259935314519650377">डाउनलोड गरिएको इन्स्टलरको क्यास बनाउन सकिएन। त्रुटि भयो: <ph name="UNPACK_CACHING_ERROR_CODE" />।</translation>
<translation id="264613044588233783">Chromium अझ चाँडो चल्छ र JavaScript प्रयोग गर्ने सुविधाहरूले डिजाइन गरिएअनुसार काम गर्नु पर्ने हो (सिफारिस गरिएको)</translation>
<translation id="2648074677641340862">स्थापना अवधिमा अपरेटिङ सिस्टम त्रुटि भयो। कृपया पुन: क्रोमियम डाउनलोड गर्नुहोस्।</translation>
<translation id="2661879430930417727">तपाईं आफ्ना परिवार र साथीभाइसँग मिलेर यन्त्र चलाउनुहुन्छ भने उनीहरू सबै जना सोही यन्त्रमा आ-आफ्नो खातामार्फत ब्राउज गर्न र आफूले चाहेअनुसार Chromium सेटअप गर्न सक्छन्</translation>
<translation id="268602741124540128">Chromium मा स्वागत छ, <ph name="ACCOUNT_FIRST_NAME" /></translation>
<translation id="2711502716910134313">Chromium को ट्याब</translation>
<translation id="2718390899429598676">थप गरिएको सुरक्षाका लागि क्रोमियमले तपाईँको डेटा इन्क्रिप्ट गर्ने छ।</translation>
<translation id="2721354645805494590">Chromium बाट आफ्नो Google खाता हटाउन साइन आउट गर्नुहोस्</translation>
<translation id="2727713483500953825">लेन्समार्फत खोज्न फोटो/टेक्स्ट चयन गर्नुहोस्</translation>
<translation id="2738871930057338499">इन्टरनेटमा कनेक्ट गर्न सकिएन। HTTP ४०३ निषेधित। कृपया आफ्नो प्रोक्सी कन्फिगुरेसन जाँच्नुहोस्।</translation>
<translation id="2753623023919742414">खोज्न क्लिक गर्नुहोस्</translation>
<translation id="2770231113462710648">डिफल्ट ब्राउजरलाई यसमा बदल्नुहोस्:</translation>
<translation id="2785438272836277133">यो एक्स्टेन्सनमा मालवेयर छ र उक्त एक्स्टेन्सन असुरक्षित छ। यो एक्स्टेन्सनले अबदेखि तपाईंले खोल्ने साइटहरूमा रहेका तपाईंको व्यक्तिगत जानकारीलगायतका तपाईंको डेटा हेर्न र प्रयोग गर्न नसकोस् भन्नाका लागि यसलाई Chromium बाट हटाउनुहोस्।</translation>
<translation id="2799223571221894425">पुन: सुरुवात गर्नुहोस्</translation>
