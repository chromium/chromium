        </message>
        <message name="IDS_LENS_OVERLAY_CURSOR_TOOLTIP_CLICK_MESSAGE"
          desc="Text that is shown in the Lens Overlay tooltip that appears beneath the cursor. Informs the user to click on an object to search it.">
