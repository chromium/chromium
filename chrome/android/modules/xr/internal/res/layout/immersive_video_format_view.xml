<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/immersive_video_card_background"
    android:orientation="vertical"
    android:gravity="start"
    android:clickable="true"
    android:padding="20dp">

    <TextView
        android:id="@+id/format_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp"
        android:text="@string/immersive_playback_confirmation_format_title"
        android:textAppearance="@style/TextAppearance.TextLarge"
        android:textColor="@color/immersive_video_theme_foreground" />

    <org.chromium.chrome.browser.media.immersive_playback.ImmersiveVideoFormatRadioGroup
        android:id="@+id/format_radio_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:theme="@style/ImmersiveVideoRadioGroupTheme" />

</LinearLayout>
