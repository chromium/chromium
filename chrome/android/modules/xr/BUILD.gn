    "internal/junit/src/org/chromium/chrome/browser/xr/scenecore/XrResizableComponentImplTest.java",
    "internal/junit/src/org/chromium/chrome/browser/xr/scenecore/XrSceneCoreSessionInitializerImplTest.java",
    "internal/junit/src/org/chromium/chrome/browser/xr/scenecore/XrSceneCoreSessionManagerImplTest.java",
    "internal/junit/src/org/chromium/chrome/browser/xr/scenecore/XrSurfaceEntityHolderImplTest.java",
  ]
  deps = [
    ":java",
    "//base:base_java_test_support",
    "//base:base_junit_test_support",
    "//chrome/android:chrome_app_java_resources",
    "//chrome/android:chrome_java",
    "//chrome/browser/android/lifecycle:java",
    "//third_party/androidx:androidx_activity_activity_java",
