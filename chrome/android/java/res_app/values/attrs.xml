<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="DrawableTintTextView">
        <attr name="drawable_tint_color" format="color" />
    </declare-styleable>

    <declare-styleable name="ShadowLayout">
        <!--阴影的圆角大小-->

        <attr name="hl_cornerRadius" format="dimension" />
        <attr name="hl_cornerRadius_leftTop" format="dimension" />
        <attr name="hl_cornerRadius_rigthTop" format="dimension" />
        <attr name="hl_cornerRadius_leftBottom" format="dimension" />
        <attr name="hl_cornerRadius_rightBottom" format="dimension" />
        <!--阴影的扩散范围(也可以理解为扩散程度)-->
        <attr name="hl_shadowLimit" format="dimension" />
        <attr name="hl_shadowColor" format="color" />
        <attr name="hl_shadowBackColor" format="color" />
        <attr name="hl_shadowBackColorClicked" format="color" />
        <!--x轴的偏移量-->
        <attr name="hl_dx" format="dimension" />
        <!--y轴的偏移量-->
        <attr name="hl_dy" format="dimension" />
        <!--左边是否显示阴影-->
        <attr name="hl_leftShow" format="boolean" />
        <!--右边是否显示阴影-->
        <attr name="hl_rightShow" format="boolean" />
        <!--上边是否显示阴影-->
        <attr name="hl_topShow" format="boolean" />
        <!--下面是否显示阴影-->
        <attr name="hl_bottomShow" format="boolean" />

        <!-- 新增selector样式，是pressed叫是sectored还是2者都需要 -->
        <attr name="hl_selectorMode">
            <flag name="pressed" value="1" />
            <flag name="selected" value="2" />
        </attr>

        <!--        是否要显示应用，可能有只想用shape这块，不想要阴影-->
        <attr name="hl_isShowShadow" format="boolean" />

        <!--控件区域是否对称，默认是对称。不对称的话，那么控件区域随着阴影区域走-->
        <attr name="hl_isSym" format="boolean" />

    </declare-styleable>


    <attr name="backgroundColor" format="color" />
    <attr name="backgroundColorDark" format="color" />
    <attr name="backgroundColorAccent" format="color" />
    <attr name="backgroundTintColor" format="color" />
    <attr name="backgroundColorCard" format="color" />
    <attr name="backgroundBottomDialog" format="reference"/>
    <attr name="backgroundSearchBar" format="color" />
    <attr name="backgroundShadowBottom" format="reference"/>
    <attr name="backgroundShadowUp" format="reference"/>
    <attr name="backgroundShortcutFolder" format="reference"/>
    <attr name="wallpaperTintColor" format="color" />
    <attr name="textColorMajor" format="color" />
    <attr name="textColorNormal" format="color" />
    <attr name="textColorMinor" format="color" />

    <attr name="_dialog_background_color" format="color" />
    <attr name="_dialog_text_color_major" format="color" />
    <attr name="_dialog_text_color_normal" format="color" />
    <attr name="_dialog_text_color_negative" format="color" />
    <attr name="_dialog_text_color_positive" format="color" />
    <attr name="_dialog_text_color_minus" format="color" />

</resources>