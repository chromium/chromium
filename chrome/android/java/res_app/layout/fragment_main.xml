<org.chromium.components.browser_ui.widget.CoordinatorLayoutForPointer
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="1" >

<!--    <FrameLayout-->
<!--        android:id="@+id/launcher_layout"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="match_parent"-->
<!--        />-->

    <com.ark.browser.ui.widget.homepage.ArkLauncherLayout
        android:id="@+id/launcher_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <include layout="@layout/layout_browser"
        android:id="@+id/browser_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        />

    <include layout="@layout/layout_smart_search"
        android:visibility="invisible"
        />

    <com.ark.browser.ui.widget.homepage.TabSwitcherLayout
        android:id="@+id/tab_switcher_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        />

</org.chromium.components.browser_ui.widget.CoordinatorLayoutForPointer>

