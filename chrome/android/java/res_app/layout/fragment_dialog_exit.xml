<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <com.ark.browser.ui.widget.DialogHeaderLayout
        android:id="@+id/layout_dialog_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dialog_header_title="退出"
        />

    <com.ark.browser.ui.widget.CheckLayout
        android:id="@+id/close_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:check_title="关闭未关闭的网页"
        app:title_text_size="14"
        app:title_text_color="?attr/textColorMajor"
        />

    <com.ark.browser.ui.widget.CheckLayout
        android:id="@+id/clear_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:check_title="清除浏览历史"
        app:title_text_size="14"
        app:title_text_color="?attr/textColorMajor"
        />

    <com.ark.browser.ui.widget.CheckLayout
        android:id="@+id/send_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:check_title="保持后台"
        app:title_text_size="14"
        app:title_text_color="?attr/textColorMajor"
        />

    <include layout="@layout/_dialog_buttons" />

</LinearLayout>