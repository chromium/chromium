<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorAccent"
    >

    <com.zpj.widget.toolbar.ZToolBar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:z_toolbar_fillStatusBar="true"
        app:z_toolbar_statusBarColor="?attr/backgroundColor"
        app:z_toolbar_titleBarColor="?attr/backgroundColor"
        app:z_toolbar_showBottomLine="false"
        app:z_toolbar_leftType="imageButton"
        app:z_toolbar_leftImageResource="@drawable/btn_back"
        app:z_toolbar_centerType="textView"
        app:z_toolbar_centerText="设置"
        app:z_toolbar_centerTextColor="@color/google_black_400"
        app:z_toolbar_rightType="imageButton"
        app:z_toolbar_rightImageResource="@drawable/ic_more"
        />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/backgroundColor"
            app:cardUseCompatPadding="false"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_margin="16dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >

                <com.zpj.widget.setting.SwitchSettingItem
                    android:id="@+id/item_saved_passwords"
                    style="@style/setting_item_style"
                    app:z_setting_titleText="保存密码"
                    />

                <com.zpj.widget.setting.SwitchSettingItem
                    android:id="@+id/item_auto_sign_in"
                    style="@style/setting_item_style"
                    app:z_setting_titleText="自动登录"
                    />

                <com.zpj.widget.setting.CommonSettingItem
                    android:id="@+id/item_1"
                    style="@style/setting_item_style"
                    app:z_setting_titleText="已保存的密码将显示在这里"
                    app:z_setting_titleTextColor="@color/google_grey_400"
                    />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </ScrollView>



</LinearLayout>