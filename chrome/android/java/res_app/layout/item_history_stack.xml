<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:padding="12dp"
    android:minHeight="40dp"
    >

    <com.ark.browser.ui.widget.ShadowLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:hl_shadowLimit="8dp"
        app:hl_cornerRadius="8dp"
        app:hl_shadowColor="#40000000"
        app:hl_isShowShadow="true"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/backgroundColor"
            app:cardCornerRadius="8dp"
            app:cardUseCompatPadding="false"
            app:cardElevation="0dp"
            >

            <!--            <ImageView-->
            <!--                android:id="@+id/iv_thumbnail"-->
            <!--                android:layout_width="80dp"-->
            <!--                android:layout_height="128dp"-->
            <!--                android:layout_gravity="center_vertical"-->
            <!--                android:scaleType="fitCenter"-->
            <!--                android:src="@drawable/background"-->
            <!--                />-->

            <com.ark.browser.ui.widget.FitWidthImageView
                android:id="@+id/iv_thumbnail"
                android:layout_width="80dp"
                android:layout_height="128dp"
                android:layout_gravity="center_vertical"
                />

        </androidx.cardview.widget.CardView>

    </com.ark.browser.ui.widget.ShadowLayout>





    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginVertical="8dp"
        >

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="title"
            android:layout_gravity="center"
            android:maxLines="3"
            android:textSize="16sp"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textColor="?attr/textColorMajor" />

        <TextView
            android:id="@+id/tv_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="content"
            android:maxLines="5"
            android:ellipsize="end"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:textColor="?attr/textColorNormal"
            />

    </LinearLayout>

    <com.zpj.widget.checkbox.ZCheckBox
        android:id="@+id/check_box"
        app:z_checkbox_border_size="2dp"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginHorizontal="12dp"
        android:layout_gravity="center_vertical|end"
        />

</LinearLayout>