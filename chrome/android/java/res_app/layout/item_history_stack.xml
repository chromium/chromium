<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    >

    <com.ark.browser.ui.widget.ShadowLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:hl_shadowLimit="8dp"
        app:hl_cornerRadius="16dp"
        app:hl_shadowColor="#20000000"
        app:hl_isShowShadow="true"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/backgroundColor"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="false"
            app:cardElevation="0dp"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                >

                <ImageView
                    android:id="@+id/iv_thumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintStart_toStartOf="@id/content"
                    app:layout_constraintEnd_toEndOf="@id/content"
                    app:layout_constraintTop_toTopOf="@id/content"
                    app:layout_constraintBottom_toBottomOf="@id/content"
                    />


                <LinearLayout
                    android:id="@+id/content"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="#DDFFFFFF"
                    android:padding="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    >

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="title"
                        android:layout_gravity="center"
                        android:maxLines="3"
                        android:textSize="16sp"
                        android:ellipsize="end"
                        android:textStyle="bold"
                        android:textColor="?attr/textColorMajor" />


                    <com.ark.browser.ui.widget.RedirectChainView
                        android:id="@+id/url_chain_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        >


                    </com.ark.browser.ui.widget.RedirectChainView>

                </LinearLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </com.ark.browser.ui.widget.ShadowLayout>

</LinearLayout>