<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    >

    <LinearLayout
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="16dp"
        >

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_launcher"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Ark浏览器"
            android:layout_gravity="center_vertical"
            android:textColor="#333333"
            />


    </LinearLayout>

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:orientation="horizontal"
        app:columnCount="4"
        app:rowCount="2"
        >

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_user_agent"
            style="@style/menu_item"
            android:drawableTop="@drawable/ic_more_vert_24dp"
            android:text="浏览器标识"
            />

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_refresh"
            style="@style/menu_item"
            android:drawableTop="@drawable/ic_refresh"
            android:text="刷新"
            />

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_download_manager"
            style="@style/menu_item"
            android:drawableTop="@drawable/ic_file_download_24dp"
            android:text="下载"
            />

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_history"
            style="@style/menu_item"
            android:drawableTop="@drawable/ic_history"
            android:text="历史"
            />

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_bookmark"
            style="@style/menu_item"
            android:drawableTop="@drawable/ic_refresh"
            android:text="书签"
            />


    </androidx.gridlayout.widget.GridLayout>

</LinearLayout>