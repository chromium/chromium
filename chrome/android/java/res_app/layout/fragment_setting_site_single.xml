<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorAccent"
    >

    <include layout="@layout/layout_header"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        >

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            >


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardUseCompatPadding="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_margin="8dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.ark.browser.ui.widget.TitleHeaderLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title_header_title="网站信息"
                        />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:background="#99999999"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_site_title"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="www.xxxx.com"
                        app:z_setting_leftIcon="@drawable/permission_midi"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_user_agent"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="网站UA"
                        app:z_setting_infoText="手机UA"
                        app:z_setting_leftIcon="@drawable/ic_h5"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_site_usage"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="@string/website_settings_usage_category"
                        app:z_setting_infoText="100kb"
                        app:z_setting_leftIcon="@drawable/wechat_icon_zip"
                        />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardUseCompatPadding="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_margin="8dp">

                <LinearLayout
                    android:id="@+id/ll_container_permision"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">


                    <com.ark.browser.ui.widget.TitleHeaderLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title_header_title="权限管理"
                        />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:background="#99999999"/>

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_cookies_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="Cookie"
                        app:z_setting_infoText="允许"
                        app:z_setting_leftIcon="@drawable/permission_cookie"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_location_access"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="定位"
                        app:z_setting_infoText="询问"
                        app:z_setting_leftIcon="@drawable/permission_location"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_camera_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="使用摄像头"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/ic_videocam"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_microphone_permission"
                        style="@style/setting_item_style"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_mic"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        app:z_setting_titleText="使用麦克风" />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_push_notifications"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="通知"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_push_notification"
                        app:z_setting_leftIconTint="?attr/textColorMajor"/>

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_javascript_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="JavaScript"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_javascript"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_popup_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="弹出式窗口"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_popups"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_ads_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="广告拦截"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_ad"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_background_sync_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="后台同步"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_background_sync"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_protected_media_identifier_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="受保护内容"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_protected_media"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_autoplay_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="自动播放"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_autoplay"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_sound_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="声音"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/ic_volume"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <com.ark.browser.ui.widget.TintSettingItem
                        android:id="@+id/item_midi_sysex_permission"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="全面控制MIDI设备"
                        app:z_setting_infoText="禁止"
                        app:z_setting_leftIcon="@drawable/permission_midi"
                        app:z_setting_leftIconTint="?attr/textColorMajor"
                        />

                    <!--                <com.ark.browser.ui.widget.TintSettingItem-->
                    <!--                    android:id="@+id/item_usb_permission"-->
                    <!--                    android:layout_width="match_parent"-->
                    <!--                    android:layout_height="wrap_content"-->
                    <!--                    app:isShowUnderLine="false"-->
                    <!--                    app:z_setting_titleText="USB"-->
                    <!--                    app:showInfoBtn="false"-->
                    <!--                    android:layout_marginBottom="10dp"-->
                    <!--                    app:LtextColor="@color/google_black_400"-->
                    <!--                    app:isShowRightText="true"-->
                    <!--                    app:z_setting_infoText="禁止"-->
                    <!--                    app:z_setting_leftIcon="@drawable/permission_midi"-->
                    <!--                    />-->


                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <org.chromium.ui.widget.ButtonCompat
                xmlns:chrome="http://schemas.android.com/apk/res-auto"
                android:id="@+id/btn_reset_site"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:focusable="false"
                android:paddingVertical="12dp"
                android:paddingHorizontal="24dp"
                android:textColor="@android:color/white"
                chrome:buttonColor="@color/colorPrimary"
                android:text="@string/text_clear_and_reset"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp"
                />

        </LinearLayout>


    </ScrollView>



</LinearLayout>