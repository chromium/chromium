<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/backgroundColor"
    >

    <com.zpj.widget.toolbar.ZSearchBar
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:z_toolbar_fillStatusBar="true"
        app:z_toolbar_isLightStyle="false"
        app:z_toolbar_statusBarColor="@color/transparent"
        app:z_toolbar_titleBarColor="@color/transparent"
        app:z_toolbar_background="@drawable/bg_search_inset"
        app:z_toolbar_padding="8dp"
        app:z_toolbar_showLeftImageButton="true"
        app:z_toolbar_leftImageResource="@drawable/btn_back"
        app:z_toolbar_rightImageResource="@drawable/ic_search_v2"
        android:elevation="4dp"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        >

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_filter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingVertical="8dp"
            android:layout_marginStart="16dp"/>

        <ImageView
            android:id="@+id/iv_expand"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_enter_arrow"
            android:padding="12dp"
            android:tint="?attr/textColorMinor"
            />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>