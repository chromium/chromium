<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor"
    android:orientation="vertical"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <com.ark.browser.ui.widget.StatusBarView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?android:attr/actionBarSize"
            android:gravity="center_vertical"
            >

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="?android:attr/actionBarSize"
                android:layout_height="?android:attr/actionBarSize"
                android:src="@drawable/btn_back"
                android:background="?android:attr/actionBarItemBackground"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="下载管理"
                android:textColor="?attr/textColorMajor"
                android:textSize="18sp"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="-1"
                />

            <ImageButton
                android:id="@+id/btn_search"
                android:layout_width="?android:attr/actionBarSize"
                android:layout_height="?android:attr/actionBarSize"
                android:src="@drawable/ic_search_v2"
                android:background="?android:attr/actionBarItemBackground"
                />

            <ImageButton
                android:id="@+id/btn_more"
                android:layout_width="?android:attr/actionBarSize"
                android:layout_height="?android:attr/actionBarSize"
                android:src="@drawable/ic_more"
                android:background="?android:attr/actionBarItemBackground"
                />

        </LinearLayout>

    </LinearLayout>

    <net.lucode.hackware.magicindicator.MagicIndicator
        android:id="@+id/magic_indicator"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginHorizontal="36dp"
        android:layout_marginVertical="6dp" />

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/view_pager"
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        />

    <TextView android:id="@+id/storage_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="可用:1GB / 总共:128GB"
        android:padding="8dp"
        android:textSize="12sp"
        android:textColor="?attr/textColorMinor"
        android:gravity="center"
        />

</LinearLayout>
