<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <View
        android:layout_width="56dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_round_accent"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_edit"
        android:textColor="?attr/textColorMajor"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="24dp"
        />

    <com.ark.browser.ui.widget.DrawableTintEditText
        android:id="@+id/title_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/text_name"
        android:imeOptions="flagNoExtractUi"
        android:inputType="textCapSentences|textAutoCorrect"
        android:singleLine="true"
        android:background="@drawable/bg_round_accent"
        android:padding="16dp"
        android:textSize="13sp"
        android:layout_marginBottom="6dp"
        app:alertMessage="@string/text_missing_title"
        android:drawableStart="@drawable/ic_language_black_24dp"
        android:drawablePadding="8dp"
        android:cursorVisible="false"
        android:textColor="?attr/textColorMajor"
        android:textColorHint="?attr/textColorNormal"
        android:layout_marginHorizontal="24dp"
        app:drawable_tint_color="?attr/textColorMajor"
        />

    <com.ark.browser.ui.widget.DrawableTintEditText
        android:id="@+id/url_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/text_site"
        android:drawableStart="@drawable/ic_link_black_24dp"
        android:imeOptions="flagNoExtractUi"
        android:inputType="textUri"
        android:singleLine="true"
        android:background="@drawable/bg_round_accent"
        android:padding="16dp"
        android:textSize="13sp"
        android:textColor="?attr/textColorMajor"
        android:textColorHint="?attr/textColorNormal"
        app:alertMessage="@string/text_missing_url"
        android:layout_marginVertical="16dp"
        android:drawablePadding="8dp"
        android:cursorVisible="false"
        android:layout_marginHorizontal="24dp"
        app:drawable_tint_color="?attr/textColorMajor"
        />

    <include layout="@layout/_dialog_buttons" />

</LinearLayout>