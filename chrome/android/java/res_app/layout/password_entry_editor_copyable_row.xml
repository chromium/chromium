<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    >

    <TextView
        android:id="@+id/password_entry_editor_row_data"
        android:textColor="?attr/textColorMajor"
        android:layout_width="0dp"
        android:layout_gravity="center_vertical"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        />

    <ImageButton
        android:id="@+id/password_entry_editor_copy"
        app:srcCompat="@drawable/ic_content_copy_black"
        android:background="@null"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:padding="8dp"
        android:tint="?attr/textColorMajor"
        android:contentDescription="@string/password_entry_editor_copy_stored_username"/>

</LinearLayout>
