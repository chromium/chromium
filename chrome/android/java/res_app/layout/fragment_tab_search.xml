<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/backgroundColor"
    >

    <com.zpj.widget.toolbar.ZSearchBar
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:z_toolbar_fillStatusBar="true"
        app:z_toolbar_isLightStyle="false"
        app:z_toolbar_statusBarColor="@color/transparent"
        app:z_toolbar_titleBarColor="@color/transparent"
        app:z_toolbar_background="@drawable/bg_search_inset"
        app:z_toolbar_padding="8dp"
        app:z_toolbar_showLeftImageButton="true"
        app:z_toolbar_leftImageResource="@drawable/btn_back"
        app:z_toolbar_rightImageResource="@drawable/ic_search_v2"
        android:elevation="4dp"
        />

    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="24dp"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        />

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_move"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingHorizontal="28dp"
            android:paddingVertical="8dp"
            android:gravity="center"
            android:text="移动"
            android:textColor="?attr/textColorMajor"
            android:background="?android:attr/selectableItemBackground"
            android:drawableTop="@drawable/bookmark_move_active"
            android:drawablePadding="4dp"
            app:drawable_tint_color="?attr/textColorMajor"
            android:textSize="12sp"
            />

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingHorizontal="28dp"
            android:paddingVertical="8dp"
            android:gravity="center"
            android:text="成组"
            android:textColor="?attr/textColorMajor"
            android:background="?android:attr/selectableItemBackground"
            android:drawableTop="@drawable/ic_group_icon_16dp"
            android:drawablePadding="4dp"
            app:drawable_tint_color="?attr/textColorMajor"
            android:textSize="12sp"
            />

        <com.ark.browser.ui.widget.DrawableTintTextView
            android:id="@+id/btn_remove"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingHorizontal="28dp"
            android:paddingVertical="8dp"
            android:gravity="center"
            android:text="移除"
            android:textColor="?attr/textColorMajor"
            android:background="?android:attr/selectableItemBackground"
            android:drawableTop="@drawable/ic_delete"
            android:drawablePadding="4dp"
            app:drawable_tint_color="?attr/textColorMajor"
            android:textSize="12sp"
            />

    </LinearLayout>

</LinearLayout>