<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorAccent"
    >

    <include layout="@layout/layout_header"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        >

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            >

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="false"
                app:cardElevation="0dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                    <ImageView
                        android:id="@+id/iv_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_round_accent"
                        android:padding="12dp"
                        android:layout_marginTop="24dp"
                        android:layout_gravity="center_horizontal"
                        android:src="@drawable/ic_favicon" />

                    <org.chromium.components.page_info.ElidedUrlTextView
                        android:id="@+id/tv_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:padding="16dp"
                        android:text="www.baidu.com"/>

                    <TextView
                        android:id="@+id/tv_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:text="xx\n\n\n\ndfkgjfh"
                        android:padding="16dp"
                        android:textColor="?attr/textColorNormal"
                        android:textSize="12sp" />

                    <com.zpj.widget.setting.SimpleSettingItem
                        android:id="@+id/tv_permission"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:z_setting_titleTextColor="?attr/textColorMajor"
                        app:z_setting_titleText="权限管理"
                        app:z_setting_rightIconTint="?attr/textColorMajor"
                        />


                </LinearLayout>



            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="false"
                app:cardElevation="0dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                    <com.zpj.widget.setting.CommonSettingItem
                        android:id="@+id/item_cookies_usage"
                        style="@style/setting_item_style"
                        app:z_setting_titleText="@string/website_settings_usage_category"
                        app:z_setting_infoText="100kb"
                        app:z_setting_leftIcon="@drawable/permission_cookie"
                        app:z_setting_arrowIcon="@drawable/ic_delete"
                        app:z_setting_leftIconTint="?attr/colorPrimary"
                        app:z_setting_arrowIconTint="?attr/colorPrimary"
                        />

                    <TextView
                        android:id="@+id/tv_cookies_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="false"
                app:cardElevation="0dp"
                >

                <LinearLayout
                    android:id="@+id/ll_sections"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="16dp"
                    >



                </LinearLayout>


            </androidx.cardview.widget.CardView>

        </LinearLayout>


    </ScrollView>



</LinearLayout>