<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorAccent"
    >

    <include layout="@layout/layout_header"/>

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            >

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="false"
                app:cardElevation="0dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="16dp"
                        >

                        <ImageView
                            android:id="@+id/icon_file"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_launcher"
                            android:layout_gravity="center_vertical"
                            />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:id="@+id/task_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="XXX.xx"
                                android:textColor="?attr/textColorMajor"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/file_size"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:singleLine="true"
                                    android:text="100.00MB"
                                    android:textColor="?attr/textColorNormal"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/task_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_centerVertical="true"
                                    android:layout_marginStart="6dp"
                                    android:layout_toLeftOf="@+id/item_more"
                                    android:singleLine="true"
                                    android:text="100%"
                                    android:textColor="?attr/textColorNormal"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="这里显示速度曲线图"
                        android:gravity="center"
                        android:textColor="?attr/textColorMajor"
                        >


                    </TextView>

                </LinearLayout>




            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="false"
                app:cardElevation="0dp"
                >

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="15dp"
                        android:text="分块图(共100块/已完成30块)"
                        android:textColor="?attr/textColorNormal"
                        />

                    <com.ark.browser.ui.widget.BlockGraphView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/info_graph"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginBottom="16dp"
                        />


                </LinearLayout>


            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="false"
                app:cardElevation="0dp"
                >

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    >

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="任务详情"
                        android:textColor="?attr/textColorNormal"
                        />


                    <!--                    <View-->
                    <!--                        android:layout_width="match_parent"-->
                    <!--                        android:layout_height="wrap_content"-->
                    <!--                        android:background="@drawable/all_apps_divider"-->
                    <!--                        android:layout_marginHorizontal="16dp"-->
                    <!--                        android:layout_marginBottom="16dp"-->
                    <!--                        android:layout_marginTop="0dp"-->
                    <!--                        />-->

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/download_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="下载链接"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/oringin_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="原始链接"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/download_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="下载路径"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/create_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="创建时间"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/thread_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="线程数"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/breakpoint_resume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="断点续传"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/user_agent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="用户代理UA"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:id="@+id/cookie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="Cookie"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="文件类型"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="MD5"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="SHA1"
                        app:right_text="xxxx"
                        />

                    <com.ark.browser.ui.widget.TitleTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:left_text="CRC32"
                        app:right_text="xxxx"
                        />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="16dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>



        </LinearLayout>

    </ScrollView>

</LinearLayout>