<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorAccent"
    >

    <include layout="@layout/layout_header"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/backgroundColor"
            app:cardUseCompatPadding="false"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_margin="16dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >

                <include
                    layout="@layout/layout_preference_text_scale"
                    />

                <com.zpj.widget.setting.SwitchSettingItem
                    android:id="@+id/item_force_enable_zoom"
                    style="@style/setting_item_style"
                    app:z_setting_titleText="强制缩放"
                    />

                <com.zpj.widget.setting.SwitchSettingItem
                    android:id="@+id/item_reader_for_accessibility"
                    style="@style/setting_item_style"
                    app:z_setting_titleText="简化版视图"
                    />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </ScrollView>



</LinearLayout>