<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColorAccent"
    >

    <com.zpj.widget.toolbar.ZToolBar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:z_toolbar_fillStatusBar="true"
        app:z_toolbar_statusBarColor="?attr/backgroundColor"
        app:z_toolbar_titleBarColor="?attr/backgroundColor"
        app:z_toolbar_showBottomLine="false"
        app:z_toolbar_leftType="imageButton"
        app:z_toolbar_leftImageResource="@drawable/btn_back"
        app:z_toolbar_centerType="textView"
        app:z_toolbar_centerText="保存的密码"
        app:z_toolbar_rightType="imageButton"
        app:z_toolbar_rightImageResource="@drawable/ic_delete_white_24dp"
        />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:title="@string/password_entry_editor_title"
            android:padding="8dp"
            >

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardUseCompatPadding="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_margin="8dp"
                >

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    >

                    <com.ark.browser.ui.widget.TitleHeaderLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title_header_title="@string/password_entry_editor_site_title"
                        />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:background="#eeeeee"
                        />

                    <include android:id="@+id/url_row"
                        layout="@layout/password_entry_editor_copyable_row"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardUseCompatPadding="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_margin="8dp"
                >

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    >

                    <com.ark.browser.ui.widget.TitleHeaderLayout
                        android:id="@+id/password_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title_header_title="@string/password_entry_editor_username_title"
                        />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:background="#eeeeee"
                        />

                    <include android:id="@+id/username_row"
                        layout="@layout/password_entry_editor_copyable_row"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/backgroundColor"
                app:cardUseCompatPadding="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_margin="8dp"
                >

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    >

                    <com.ark.browser.ui.widget.TitleHeaderLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title_header_title="@string/password_entry_editor_password"
                        />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:background="#eeeeee"
                        />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/password_data"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        >

                        <TextView
                            android:id="@+id/password_entry_editor_password"
                            android:textColor="?attr/textColorMajor"
                            android:layout_width="0dp"
                            android:layout_gravity="center_vertical"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            />

                        <ImageButton
                            android:id="@+id/password_entry_editor_view_password"
                            android:background="@null"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:padding="8dp"
                            android:layout_marginEnd="2dp"
                            app:srcCompat="@drawable/ic_visibility_black"
                            android:tint="?attr/textColorMajor"
                            android:contentDescription="@string/password_entry_editor_view_stored_password" />

                        <ImageButton
                            android:id="@+id/password_entry_editor_copy_password"
                            app:srcCompat="@drawable/ic_content_copy_black"
                            android:background="@null"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:padding="8dp"
                            android:tint="?attr/textColorMajor"
                            android:contentDescription="@string/password_entry_editor_copy_stored_password"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!--            <TextView-->
