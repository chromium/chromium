<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <org.chromium.ui.widget.ButtonCompat
        android:id="@+id/tips_promo_settings_button" style="@style/FilledButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tips_promo_bottom_sheet_positive_button_text"/>

    <org.chromium.ui.widget.ButtonCompat
        android:id="@+id/tips_promo_details_button" style="@style/TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tips_promo_bottom_sheet_negative_button_text"/>
</LinearLayout>