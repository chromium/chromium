<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/context_menu_list_lateral_padding"
    android:gravity="start"
    android:background="@drawable/list_item_ripple"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/checkbox"
        android:layout_width="@dimen/list_item_start_icon_width"
        android:layout_height="@dimen/list_item_start_icon_width"
        android:layout_marginEnd="@dimen/context_menu_chip_icon_margin_end"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/checkbox_title"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:maxLines="1"
        android:ellipsize="end"
        style="@style/ContextMenuItemText" />

</LinearLayout>
