<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

  <ImageView
      android:importantForAccessibility="no"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center_horizontal"
      android:layout_marginTop="8dp"
      android:src="@drawable/drag_handlebar"
      app:tint="@macro/drag_handle_color" />

  <ScrollView
      android:id="@+id/personal_context_scroll_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/personal_context_sheet_padding_horizontal"
        android:paddingRight="@dimen/personal_context_sheet_padding_horizontal"
        android:layout_marginTop="@dimen/personal_context_spacing_medium">

      <com.airbnb.lottie.LottieAnimationView
          android:id="@+id/personal_context_icon"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="center_horizontal"
          android:minHeight="60dp"
          android:maxHeight="60dp"
          android:importantForAccessibility="no"
          android:scaleType="fitCenter"
          android:adjustViewBounds="true"/>

      <TextView
          android:id="@+id/personal_context_title"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="4dp"
          android:textAppearance="@style/TextAppearance.Headline.Primary"
          android:textAlignment="center" />

      <TextView
          android:id="@+id/personal_context_description"
          android:layout_height="wrap_content"
          android:layout_width="match_parent"
          android:layout_marginTop="@dimen/personal_context_spacing_large"
          android:textAppearance="@style/TextAppearance.TextMedium.Secondary"
          android:textAlignment="viewStart" />

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:layout_marginTop="@dimen/personal_context_spacing_large"
          android:background="@drawable/card_container_background">
        <TextView
            android:id="@+id/personal_context_card_1_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?android:attr/listPreferredItemHeightSmall"
            android:padding="@dimen/personal_context_spacing_large"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/personal_context_first_run_card_1"
            android:drawablePadding="@dimen/personal_context_spacing_large"
            android:textAppearance="@style/TextAppearance.TextMediumThick.Primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:importantForAccessibility="no"
            android:background="@color/bottom_sheet_bg_color" />

        <TextView
            android:id="@+id/personal_context_card_2_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?android:attr/listPreferredItemHeightSmall"
            android:padding="@dimen/personal_context_spacing_large"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/personal_context_first_run_card_2"
            android:drawablePadding="@dimen/personal_context_spacing_large"
            android:textAppearance="@style/TextAppearance.TextMediumThick.Primary" />
      </LinearLayout>

      <org.chromium.ui.widget.TextViewWithClickableSpans
          android:id="@+id/personal_context_learn_more_description"
          android:layout_height="wrap_content"
          android:layout_width="match_parent"
          android:layout_marginTop="@dimen/personal_context_spacing_large"
          android:textAppearance="@style/TextAppearance.TextMedium.Secondary"
          android:textAlignment="viewStart" />

      <org.chromium.ui.widget.ButtonCompat
          android:id="@+id/personal_context_primary_button"
          style="@style/FilledButton"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textAlignment="center"
          android:layout_marginTop="20dp"
          android:minHeight="@dimen/min_touch_target_size"
          android:minWidth="@dimen/min_touch_target_size" />

      <org.chromium.ui.widget.ButtonCompat
          android:id="@+id/personal_context_secondary_button"
          style="@style/TextButton"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textAlignment="center"
          android:layout_marginTop="@dimen/personal_context_spacing_medium"
          android:layout_marginBottom="@dimen/personal_context_spacing_medium"
          android:minHeight="@dimen/min_touch_target_size"
          android:minWidth="@dimen/min_touch_target_size" />

    </LinearLayout>
  </ScrollView>
</LinearLayout>
