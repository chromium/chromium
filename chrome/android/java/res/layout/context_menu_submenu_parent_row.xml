<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/list_item_ripple"
    android:orientation="horizontal">

    <org.chromium.ui.widget.ChromeImageView
        android:id="@+id/menu_item_icon"
        android:layout_width="@dimen/context_menu_chip_icon_size"
        android:layout_height="@dimen/context_menu_chip_icon_size"
        android:layout_marginEnd="@dimen/context_menu_chip_icon_margin_end"
        android:gravity="center"
        android:duplicateParentState="true"
        android:importantForAccessibility="no"
        android:visibility="gone"
        android:tint="@color/default_icon_color_secondary_tint_list"
        android:tintMode="src_in" />

    <TextView
        android:id="@+id/menu_row_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="@dimen/context_menu_row_item_horizontal_padding"
        android:paddingEnd="@dimen/context_menu_row_item_horizontal_padding"
        style="@style/ContextMenuItemText" />

    <ImageView
        android:id="@+id/submenu_arrow"
        android:src="@drawable/outline_chevron_right_24dp"
        android:importantForAccessibility="no"
        android:layout_width="@dimen/list_item_end_icon_width"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:paddingTop="@dimen/context_menu_row_item_vertical_padding"
        android:paddingBottom="@dimen/context_menu_row_item_vertical_padding"
        android:paddingStart="@dimen/context_menu_row_item_horizontal_padding"
        android:paddingEnd="@dimen/context_menu_row_item_horizontal_padding"
        android:background="@android:color/transparent" />
</LinearLayout>
