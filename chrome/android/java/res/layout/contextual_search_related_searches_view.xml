<!-- Displays Related Searches suggestions in a section of the Contextual
     Search bottom sheet. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contextual_search_related_searches_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="invisible"
    android:layout_gravity="bottom">
    <!-- TODO(donnd): replace this plain TextViewWithLeading with ChipViews.
         -->
    <org.chromium.ui.widget.TextViewWithLeading
        android:id="@+id/related_searches_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="3"
        android:textAppearance="@style/TextAppearance.TextSmall.Primary"
        android:background="@color/overlay_panel_bar_background_color"
        android:padding="5dp" />
</FrameLayout>
