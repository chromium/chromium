<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- TODO(mdjones): This is pulled from search_toolbar.xml; share that layout instead. -->
    <LinearLayout
        android:id="@+id/search_view"
        android:layout_width="match_parent"
        android:layout_height="@dimen/selectable_list_toolbar_height"
        android:orientation="horizontal"
        android:background="@color/default_bg_color">

        <EditText
            tools:ignore="Autofill,LabelFor"
            android:id="@+id/search_text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="24dp"
            android:background="@null"
            android:imeOptions="flagNoExtractUi|actionSearch"
            android:inputType="text"
            android:singleLine="true"
            android:textAppearance="@style/TextAppearance.TextLarge.Primary"
            android:textColorHint="@color/search_box_hint"/>

        <org.chromium.ui.widget.ChromeImageButton
            android:id="@+id/clear_text_button"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:src="@drawable/btn_delete_24dp"
            android:background="@null"
            android:scaleType="center"
            android:contentDescription="@string/accessibility_toolbar_btn_delete_url"
            android:visibility="gone"
            app:tint="@color/default_icon_color_tint_list" />
    </LinearLayout>

    <org.chromium.chrome.browser.bookmarks.shopping.ChipList
        android:id="@+id/chip_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/shopping_saved_products"
        android:layout_margin="8dp"
        style="@style/TextAppearance.TextMedium.Secondary" />

</LinearLayout>