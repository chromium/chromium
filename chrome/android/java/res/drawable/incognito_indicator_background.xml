<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/colorSurfaceContainerHigh">
    <item>
        <selector>
            <!-- Pressed state (while menu is showing) -->
            <item android:state_selected="true">
                <shape android:shape="rectangle">
                    <solid android:color="?attr/colorSurfaceContainerHigh"/>
                    <corners android:radius="@dimen/modern_toolbar_background_corner_radius" />
                </shape>
            </item>

            <!-- Default state -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/toolbar_text_box_background_incognito"/>
                    <corners android:radius="@dimen/modern_toolbar_background_corner_radius" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
