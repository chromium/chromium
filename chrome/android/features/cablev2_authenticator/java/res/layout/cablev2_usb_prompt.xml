<LinearLayout xmlns:a="http://schemas.android.com/apk/res/android"
    a:layout_width="match_parent"
    a:layout_height="match_parent"
    a:gravity="center"
    a:orientation="vertical">

  <ImageView
      a:id="@+id/usb_icon"
      a:layout_height="200dp"
      a:layout_width="296dp"
      a:layout_marginLeft="100dp"
      a:layout_marginRight="100dp"
      a:layout_marginBottom="100dp"
      a:contentDescription="@null"
      a:gravity="center_horizontal"
      a:src="@drawable/usb_conn"/>

  <TextView
      a:id="@+id/usb_label"
      xmlns:tools="http://schemas.android.com/tools"
      tools:ignore="HardcodedText"
      style="@style/TextAppearance.Headline.Primary"
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:gravity="center"
      a:text="Connection seems to be taking quite long…" />

  <TextView
      a:id="@+id/usb_title"
      xmlns:tools="http://schemas.android.com/tools"
      tools:ignore="HardcodedText"
      style="@style/TextAppearance.TextLarge.Secondary"
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:gravity="center"
      a:text="Try connecting your phone with a USB cable" />

</LinearLayout>
