<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1049697408958544531">{NUM_WEEKS,plural, =1{бһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸ <ph name="NUM_WEEKS_ONE" /> бһҹбһ”бҹ’бһҠбһ¶бһ бҹҚбһҳбһ»бһ“}other{бһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸ <ph name="NUM_WEEKS_MANY" /> бһҹбһ”бҹ’бһҠбһ¶бһ бҹҚбһҳбһ»бһ“}}</translation>
<translation id="1063300264396686489">бһ”бһҫбһҖбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһ–бһёбһ§бһ”бһҖбһҡбһҺбҹҚбһ•бҹ’бһҹбҹҒбһ„бһ‘бҹҖбһҸ</translation>
<translation id="1075622780330595106">бһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="NUMBER_OF_TABS" /> бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһҳбһ·бһ“бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“вҖӢбһ”бҹ’бһҡбһҫбһ‘бҹҒвҖӢбһ“бһ¶бһ–бҹҒбһӣвҖӢбһҗбҹ’бһҳбһёбҹ—бһ“бҹҒбҹҮбҹ” бһ”бһ·бһ‘бһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһ‘бһ¶бҹҶбһ„бһ“бҹ„бҹҮбһ¬?</translation>
<translation id="1092908249939127748">{NUM_MONTHS,plural, =1{бһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸ <ph name="NUM_YEARS_ONE" /> бһҶбҹ’бһ“бһ¶бҹҶбһҳбһ»бһ“}other{бһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸ <ph name="NUM_YEARS_MANY" /> бһҶбҹ’бһ“бһ¶бҹҶбһҳбһ»бһ“}}</translation>
<translation id="1137385688780024041">{DAY_COUNT,plural, =1{бһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ“бһ·бһ„вҖӢбһҖбҹ’бһҡбһ»бһҳвҖӢбһҠбҹӮбһӣбһўбһҹбһҖбһҳбҹ’бһҳвҖӢбһ“бһ№бһ„бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“вҖӢбһ”бһ·бһ‘вҖӢбһҖбҹ’бһҡбҹ„бһҷбһ–бҹҒбһӣ 1 бһҒбҹӮ}other{бһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ“бһ·бһ„вҖӢбһҖбҹ’бһҡбһ»бһҳвҖӢбһҠбҹӮбһӣбһўбһҹбһҖбһҳбҹ’бһҳвҖӢбһ“бһ№бһ„бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“вҖӢбһ”бһ·бһ‘вҖӢбһҖбҹ’бһҡбҹ„бһҷбһ–бҹҒбһӣ <ph name="MONTH_COUNT_MANY" /> бһҒбҹӮ}}</translation>
<translation id="1173894706177603556">бһ”бҹ’бһҸбһјбһҡбһҲбҹ’бһҳбҹ„бҹҮ</translation>
<translation id="1203747227183434426">бһҖбҹҶбһ–бһ»бһ„бһҗбһҸвҖӢбһҳбҹҒбһҢбҹҖ</translation>
<translation id="1245862538775272968">{TAB_COUNT,plural, =1{бһ”бһҫбһҖ <ph name="TITLE_OF_GROUP" /> бһҠбҹӮбһӣбһҳбһ¶бһ“ <ph name="TAB_COUNT2" /> бһ•бҹ’бһ‘бһ¶бҹҶбһ„}other{бһ”бһҫбһҖ <ph name="TITLE_OF_GROUP" /> бһҠбҹӮбһӣбһҳбһ¶бһ“ <ph name="TAB_COUNT2" /> бһ•бҹ’бһ‘бһ¶бҹҶбһ„}}</translation>
<translation id="1273910660700874265">бһҮбһҳбҹ’бһҡбһҫбһҹбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TITLE_OF_GROUP" /></translation>
<translation id="1300188005269437765">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹвҖӢбһҗбһ¶бһҸбһҫвҖӢбһ–бҹҒбһӣбһҺбһ¶вҖӢбһ•бҹ’бһӣбһ¶бһҹбҹӢбһ‘бһёвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ“бһ·бһ„вҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһ‘бҹ…бһ•бҹ’бһ“бҹӮбһҖвҖӢбһўбһҹбһҖбһҳбҹ’бһҳвҖӢбһҠбҹ„бһҷвҖӢбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бҹ”</translation>
<translation id="1321004960118052490">бһ’бһ¶бһҸбһ»вҖӢбһўбһҹбһҖбһҳбҹ’бһҳвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһ“бһ№бһ„бһҳбһ·бһ“вҖӢбһҖбһҫбһ“бһЎбһҫбһ„вҖӢбһ‘бҹҒ</translation>
<translation id="1329584516321524826">бһ‘бһҫбһ”бһҸбҹӮвҖӢбһ”бһ¶бһ“вҖӢбһ’бҹ’бһңбһҫвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–</translation>
<translation id="1340839264183302272">бһ…бһ¶бһҖбһ…бҹҒбһүвҖӢбһ–бһёвҖӢбһҖбҹ’бһҡбһ»бһҳ</translation>
<translation id="1403729629346559879">{NUMBER_OF_TABS,plural, =1{бһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TITLE_OF_GROUP" /> бһҠбҹӮбһӣбһ”бһ¶бһ“вҖӢбһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖвҖӢбһҠбҹӮбһӣбһҳбһ¶бһ“ <ph name="TABS_COUNT_ONE" /> бһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ–бһҺбҹҢ<ph name="COLOR_NAME" /> бһҮбһ¶бһҳбһҪбһҷвҖӢбһҹбҹ’бһӣбһ¶бһҖ <ph name="CARD_LABEL" />бҹ”}other{бһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TITLE_OF_GROUP" /> бһҠбҹӮбһӣбһ”бһ¶бһ“вҖӢбһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖвҖӢбһҠбҹӮбһӣбһҳбһ¶бһ“ <ph name="TABS_COUNT_MANY" /> бһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ–бһҺбҹҢ<ph name="COLOR_NAME" /> бһҮбһ¶бһҳбһҪбһҷбһҹбҹ’бһӣбһ¶бһҖ <ph name="CARD_LABEL" />бҹ”}}</translation>
<translation id="1486715732399361704">бһўбҹ’бһ“бһҖбһўбһ¶бһ…вҖӢбһҡбһҖбһғбһҫбһүвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһ“бҹ…бһ‘бһёбһ“бҹҒбҹҮ</translation>
<translation id="149054111719651807">{NUM_MINS,plural, =1{бһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸ <ph name="NUM_MINS_ONE" /> бһ“бһ¶бһ‘бһёбһҳбһ»бһ“}other{бһ”бһ¶бһ“бһ”бһ„бҹ’бһҖбһҫбһҸ <ph name="NUM_MINS_MANY" /> бһ“бһ¶бһ‘бһёбһҳбһ»бһ“}}</translation>
<translation id="1499635324672558517">бһ”бһ·бһ‘вҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҜбһҖбһҮбһ“вҖӢбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһ¬?</translation>
<translation id="1501480321619201731">бһӣбһ»бһ”бһҖбҹ’бһҡбһ»бһҳ</translation>
<translation id="1553638665176794706">{TABS_COUNT,plural, =1{бһ’бһ¶бһҸбһ»вҖӢбһўбһҹбһҖбһҳбҹ’бһҳ <ph name="TABS_COUNT_ONE" />}other{бһ’бһ¶бһҸбһ»вҖӢбһўбһҹбһҖбһҳбҹ’бһҳ <ph name="TABS_COUNT_MANY" />}}</translation>
<translation id="1568067597247500137">бһ”бһ·бһ‘бһҹбҹҶбһЎбҹҒбһ„вҖӢбһ‘бҹҶбһ–бҹҗбһҡ</translation>
<translation id="1645759014353344461">бһ”бһ¶бһ“бһҠбһ¶бһҖбҹӢ <ph name="TABS_COUNT_MANY" /> бһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҮбһ¶бһҖбҹ’бһҡбһ»бһҳ</translation>
<translation id="1657719826150349398">бһ•бҹ’бһӣбһ¶бһҹбҹӢбһ‘бһёвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһ…бһ»бҹҮбһҖбҹ’бһҡбҹ„бһҳ</translation>
<translation id="1670942869417022142">бһ”бһ¶бһ“бһ”бһ·бһ‘вҖӢбһҹбҹҶбһЎбҹҒбһ„</translation>
<translation id="1697284962337958118">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ‘бҹ…</translation>
<translation id="1713541401465507417">бһ”бһ·бһ‘бһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ“бһ·бһ„бһҖбҹ’бһҡбһ»бһҳбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ</translation>
<translation id="1738346536511908887">{TAB_GROUPS_COUNT,plural, =1{бһӣбҹӮбһ„вҖӢбһўбһ¶бһ…бһ”бҹ’бһҡбһҫвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TAB_GROUPS_COUNT_ONE" /> бһ”бһ¶бһ“вҖӢбһ‘бҹҖбһҸбһ бһҫбһҷ}other{бһӣбҹӮбһ„вҖӢбһўбһ¶бһ…бһ”бҹ’бһҡбһҫвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TAB_GROUPS_COUNT_MANY" /> бһ”бһ¶бһ“вҖӢбһ‘бҹҖбһҸбһ бһҫбһҷ}}</translation>
<translation id="176485176228926164"><ph name="BEGIN_LINK1" />бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ<ph name="END_LINK1" /></translation>
<translation id="1828808367831369073">бһ”бһ¶бһ“бһҠбһ¶бһҖбҹӢ <ph name="TABS_COUNT_ONE" /> бһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҮбһ¶бһҖбҹ’бһҡбһ»бһҳ</translation>
<translation id="1844381456014878100">бһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһ–бһёвҖӢбһўбһҹбһҖбһҳбҹ’бһҳвҖӢбһҡбһҷбҹҲбһ–бҹҒбһӣ 7 бһҗбҹ’бһ„бҹғ</translation>
<translation id="1869137256605757565">{TABS_COUNT,plural, =1{бһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TABS_COUNT_ONE" />}other{бһ•бҹ’бһ‘бһ¶бҹҶбһ„ <ph name="TABS_COUNT_MANY" />}}</translation>
<translation id="1909810060368225529">бһ…бҹҶбһҺбһ¶бҹҶбҹ– бһўбҹ’бһ“бһҖбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһ“бһ¶бһўбһ¶бһ…бһҳбһҫбһӣбһғбһҫбһүбһҖбһ¶бһҡбһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҠбһјбһҡбһ…бҹҶбһ–бҹ„бҹҮбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҠбҹӮбһӣбһ”бһ¶бһ“бһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖбһ“бҹҒбҹҮбҹ” бһўбҹ’бһ“бһҖвҖӢбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһ“бһ¶вҖӢбһўбһ¶бһ…вҖӢбһ’бҹ’бһңбһҫбһҖбһ¶бһҡвҖӢбһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҠбһјбһҡвҖӢбһ…бҹҶбһ–бҹ„бҹҮвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҠбҹӮбһӣбһўбҹ’бһ“бһҖвҖӢбһ”бһ¶бһ“бһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖ</translation>
<translation id="1925363809167540686">{TAB_COUNT,plural, =1{бһҒбҹ’бһ‘бһ¶бһҹбҹӢвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„}other{бһҒбҹ’бһ‘бһ¶бһҹбҹӢвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„}}</translation>
<translation id="1982637982196732906">бһ•бҹ’бһӣбһ¶бһҹбҹӢбһ‘бһёвҖӢбһ‘бҹ…бһҖбһ¶бһ“бҹӢвҖӢбһ•бҹ’бһ“бҹӮбһҖвҖӢбһўбһҹбһҖбһҳбҹ’бһҳ</translation>
<translation id="2050597508048557928">{TABS_COUNT,plural, =1{бһ…бҹҶбһҺбһ¶бҹҶвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹ <ph name="TABS_COUNT_ONE" />}other{бһ…бҹҶбһҺбһ¶бҹҶвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹ <ph name="TABS_COUNT_MANY" />}}</translation>
<translation id="2055057176188061528">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„ бһ¬вҖӢбһ”бһ„бҹ’бһҖбһҫбһҸвҖӢбһҖбҹ’бһҡбһ»бһҳбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҗбҹ’бһҳбһё</translation>
