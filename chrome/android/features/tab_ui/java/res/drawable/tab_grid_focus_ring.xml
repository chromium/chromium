<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_focused="true">
    <inset
      android:insetLeft="@dimen/tab_grid_focus_ring_inset"
      android:insetTop="@dimen/tab_grid_focus_ring_inset"
      android:insetRight="@dimen/tab_grid_focus_ring_inset"
      android:insetBottom="@dimen/tab_grid_focus_ring_inset">
      <shape android:shape="rectangle">
        <corners android:radius="28dp" />
        <stroke android:width="2dp" android:color="?attr/colorPrimary" />
        <solid android:color="@android:color/transparent" />
      </shape>
    </inset>
  </item>
  <item>
    <shape android:shape="rectangle">
      <solid android:color="@android:color/transparent" />
    </shape>
  </item>
</selector>