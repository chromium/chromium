<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/vertical_tab_rail_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@macro/vertical_tabs_rail_bg_color"
    android:orientation="vertical"
    android:paddingStart="@dimen/vertical_tabs_rail_horizontal_margin"
    android:paddingEnd="@dimen/vertical_tabs_rail_horizontal_margin">

    <!-- Header Container: Socket for future search/toolbar buttons -->
    <FrameLayout
        android:id="@+id/vertical_tab_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Tab List Recycler View -->
    <org.chromium.chrome.browser.tasks.tab_management.TabListRecyclerView
        android:id="@+id/tab_list_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- Footer Container: Socket for future action buttons -->
    <FrameLayout
        android:id="@+id/vertical_tab_footer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

    <!-- TODO(crbug.com/518001737): Add background drawable and implement onHover. -->
        <org.chromium.ui.widget.ButtonCompat
            android:id="@+id/new_tab_button"
            android:contentDescription="@string/accessibility_toolbar_btn_new_tab"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</LinearLayout>
