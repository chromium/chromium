<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1383876407941801731">бһҹбҹ’бһңбҹӮбһ„бһҡбһҖ</translation>
<translation id="1717486229951421299">вҖӢбһ”бһүбҹ’бһҮбһёвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ бһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңвҖӢбһ”бҹҶбһ–бҹҒбһүбһҠбҹ„бһҷвҖӢбһҖбһ¶бһҡбһ”бҹүбҹҮбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһҫбһҖбһ–бһ¶бһҖбҹӢбһҖбһҺбҹ’бһҠбһ¶бһӣвҖӢбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбҹ”</translation>
<translation id="207576718733492531">бһ”бһүбҹ’бһҮбһёвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ бһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңвҖӢбһ”бҹҶбһ–бҹҒбһүвҖӢбһҠбҹ„бһҷвҖӢбһҖбһ¶бһҡбһ”бҹүбҹҮвҖӢбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһ·бһ‘бҹ”</translation>
<translation id="2610239185026711824">бһҺбҹӮбһ“бһ¶бҹҶвҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢ</translation>
<translation id="2652129567809778422">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹвҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢ</translation>
<translation id="2903493209154104877">бһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“</translation>
<translation id="3399357656427473483">бһ”бһүбҹ’бһҮбһёвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ бһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңвҖӢбһ”бҹҶбһ–бҹҒбһүвҖӢбһҠбҹ„бһҷбһҖбһ¶бһҡбһ”бҹүбҹҮбҹ”</translation>
<translation id="3688051737190211318">бһ”бҹ’бһҡбһҹбһ·бһ“бһ”бһҫбһўбҹ’бһ“бһҖвҖӢбһҮбһҝбһ‘бһ»бһҖбһ…бһ·бһҸбҹ’бһҸ <ph name="ORIGIN" /> бһўбҹ’бһ“бһҖбһўбһ¶бһ…бһ”бҹ’бһҡбһҫвҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҠбҹӮбһӣбһ”бһ¶бһ“бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖ бһҠбһҫбһҳбҹ’бһ”бһёбһ…бһјбһӣбһӮбһҺбһ“бһё</translation>
<translation id="4631649115723685955">бһ”бһ¶бһ“бһ—бҹ’бһҮбһ¶бһ”бҹӢвҖӢбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣвҖӢбһ”бһ¶бһ“бһ”бҹ’бһҡбһ¶бһҖбҹӢвҖӢбһҳбһҖбһңбһ·бһү</translation>
<translation id="4660011489602794167">бһ”бһ„бҹ’бһ бһ¶бһүбһҖбҹ’бһҸбһ¶бһҡбһ…бһ»бһ…</translation>
<translation id="4694050069269396220">бһ”бҹ’бһҡбһҹбһ·бһ“бһ”бһҫвҖӢбһўбҹ’бһ“бһҖвҖӢбһҮбһҝбһ‘бһ»бһҖбһ…бһ·бһҸбҹ’бһҸ <ph name="ORIGIN" /> бһўбҹ’бһ“бһҖвҖӢбһўбһ¶бһ…вҖӢбһ”бҹ’бһҡбһҫвҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҠбҹӮбһӣбһ”бһ¶бһ“бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖвҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһӮбҹҒбһ бһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ•бҹ’бһҹбҹҒбһ„бһ‘бҹҖбһҸвҖӢбһ”бһ¶бһ“бҹ”</translation>
<translation id="5016175294846053194">бһҖбһ¶бһҡбһҺбҹӮбһ“бһ¶бҹҶвҖӢбһўбҹҶбһ–бһёбһҖбһ¶бһҡбһ”бҹҶбһ–бҹҒбһүбһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҳбһ¶бһ“бһ“бҹ…бһ•бҹ’бһ“бҹӮбһҖбһҒбһ¶бһ„бһӣбһҫвҖӢбһҖбҹ’бһҠбһ¶бһҡбһ…бһ»бһ…вҖӢ</translation>
<translation id="5441504010984421144">бһ”бһүбҹ’бһҮбһёвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ бһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңвҖӢбһ”бҹҶбһ–бҹҒбһүвҖӢбһҠбҹ„бһҷвҖӢбһҖбһ¶бһҡбһ”бҹүбҹҮвҖӢбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“вҖӢбһ”бһҫбһҖвҖӢбһ–бҹҒбһүвҖӢбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбҹ”</translation>
<translation id="6393156038355142111">бһҺбҹӮбһ“бһ¶бҹҶвҖӢбһ–бһ¶бһҖбҹ’бһҷвҖӢбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҒбҹ’бһӣбһ¶бҹҶбһ„</translation>
<translation id="6558703547256592471">бһҹбһјбһҳбһ–бҹ’бһҷбһ¶бһҷбһ¶бһҳвҖӢбһ”бҹ’бһҡбһҫвҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҒбһ»бһҹбһ”бҹ’бһӣбҹӮбһҖбһ–бһёбһӮбҹҒвҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһҡбһ¶бһӣбҹӢвҖӢбһӮбҹҒбһ бһ‘бҹҶбһ–бҹҗбһҡвҖӢбҹ”</translation>
<translation id="7029809446516969842">бһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢ</translation>
<translation id="7594473730623999723">бһўбһјбһҹбһҠбһҫбһҳбҹ’бһ”бһёбһҳбһҫбһӣвҖӢбһҖбһ¶бһҡбһҺбҹӮбһ“бһ¶бҹҶбһ…бҹ’бһҡбһҫбһ“бһ‘бҹҖбһҸ</translation>
<translation id="7992095260806105436">бһ”бҹ’бһҡбһҫбһҖбһ¶бһҡвҖӢбһҺбҹӮбһ“бһ¶бҹҶбһўбҹҶбһ–бһёбһҖбһ¶бһҡбһ”бҹҶбһ–бҹҒбһүбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҡбһ”бһҹбҹӢ Chrome</translation>
<translation id="8507520749471379845">бһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҠбҹӮбһӣбһўбһ¶бһ…бһ”бҹ’бһҡбһҫбһ”бһ¶бһ“</translation>
<translation id="8705308553596171387">бһӮбҹ’бһҳбһ¶бһ“бһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢбһ‘бҹҒ</translation>
<translation id="879180780857354295">бһҳбһ¶бһ“бһҮбһҳбҹ’бһҡбһҫбһҹбһ”бҹҶбһ–бҹҒбһүбһҮбҹҶбһ“бһҪбһҹбһ“бҹ…бһҒбһ¶бһ„бһӣбһҫбһҖбҹ’бһҠбһ¶бһҡбһ…бһ»бһ…</translation>
<translation id="8849262850971482943">бһ”бҹ’бһҡбһҫбһҖбһ¶бһҸбһ“бһ·бһҳбҹ’бһҳбһ·бһҸбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ–бһ”бһ“бҹ’бһҗбҹӮбһҳ</translation>
</translationbundle>