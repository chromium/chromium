{
  "name": "Fetch resource",
  "version": "1",
  "manifest_version": 3,
  "web_accessible_resources": [
    {
      "resources": [
        "content_script.js"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "js": [
        "content_script.js"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "permissions": [
    "tabs"
  ]
}
