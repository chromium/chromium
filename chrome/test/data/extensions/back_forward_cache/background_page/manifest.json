{
  "name": "Background Page Extension",
  "version": "1.0",
  "manifest_version": 3,
  "description": "A minimal extension for testing purposes.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "*://a.com/*",
    "*://b.com/*"
  ]
}
