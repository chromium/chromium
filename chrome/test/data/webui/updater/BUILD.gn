import("../build_webui_tests.gni")

assert(is_mac || is_win || is_linux)

build_webui_tests("build") {
  # Test files go here
  files = [
    "event_history_test.ts",
    "event_list/event_list_item_test.ts",
    "event_list/event_list_test.ts",
    "event_list/filter_bar_test.ts",
    "event_list/filter_dialog/app_dialog_test.ts",
    "event_list/filter_dialog/date_dialog_test.ts",
    "event_list/filter_dialog/event_dialog_test.ts",
    "event_list/filter_dialog/filter_dialog_footer_test.ts",
    "event_list/filter_dialog/filter_dialog_test.ts",
    "event_list/filter_dialog/outcome_dialog_test.ts",
    "event_list/filter_dialog/type_dialog_test.ts",
    "event_list/filter_settings_test.ts",
  ]

  # Path mapping the WebUI host URL to the path where the WebUI's compiled
  # TypeScript files are placed by the TS compiler.
  ts_path_mappings = [
    "chrome://updater/*|" +
        rebase_path("$root_gen_dir/chrome/browser/resources/updater/tsc/*",
                    target_gen_dir),
    "//webui-test/chai.js|" +
        rebase_path("//third_party/node/node_modules/@types/chai/index.d.ts",
                    target_gen_dir),
  ]
  ts_deps = [
    "//chrome/browser/resources/updater:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
