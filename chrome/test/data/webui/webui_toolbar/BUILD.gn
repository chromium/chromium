import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [
    "webui_toolbar_js_browsertest.cc",
    "webui_toolbar_js_interactive_uitest.cc",
  ]

  files = [
    "content_setting_icon_test.ts",
    "location_bar_test.ts",
    "location_bar_focus_test.ts",
    "location_bar_high_contrast_focus_test.ts",
    "location_icon_test.ts",
    "readonly_omnibox_test.ts",
    "readonly_omnibox_focus_test.ts",
    "pinned_toolbar_action_test.ts",
  ]

  ts_deps = [
    "//chrome/browser/resources/webui_toolbar:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  ts_path_mappings =
      [ "chrome://webui-toolbar.top-chrome*|" +
        rebase_path(
            "$root_gen_dir/chrome/browser/resources/webui_toolbar/tsc/*",
            target_gen_dir) ]
}
