import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "web_app_internals_browsertest.cc" ]

  files = [ "utils_test.ts" ]

  ts_path_mappings =
      [ "chrome://web-app-internals/*|" +
        rebase_path(
            "$root_gen_dir/chrome/browser/resources/web_app_internals/tsc/*",
            target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/web_app_internals:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
