import("../build_webui_tests.gni")

assert(is_win || is_mac || is_linux || is_chromeos,
       "This target is only supported on Windows, Mac, Linux, or ChromeOS.")

build_webui_tests("build") {
  cc_test_files = [ "skills_browsertest.cc" ]

  files = [
    "card_test.ts",
    "discover_skills_page_test.ts",
    "skills_dialog_test.ts",
    "skills_test.ts",
    "test_skills_browser_proxy.ts",
    "user_skills_page_test.ts",
  ]

  ts_path_mappings =
      [ "chrome://skills/*|" +
        rebase_path("$root_gen_dir/chrome/browser/resources/skills/tsc/*",
                    target_gen_dir) ]
  ts_deps = [
    "//chrome/browser/resources/skills:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
