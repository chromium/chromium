import("../build_webui_tests.gni")
build_webui_tests("build") {
  cc_test_files = [ "ai_overlay_dialog_browsertest.cc" ]

  is_chrome_untrusted = true
  files = [ "persona_test.ts" ]
  ts_path_mappings =
      [ "chrome-untrusted://ai-overlay-dialog/*|" +
        rebase_path(
            "$root_gen_dir/chrome/browser/resources/ai_overlay_dialog/tsc/*",
            target_gen_dir) ]
  ts_deps = [
    "//chrome/browser/resources/ai_overlay_dialog:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
