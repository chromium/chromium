import("../build_webui_tests.gni")

assert(!is_android)

build_webui_tests("build") {
  cc_test_files = [ "device_log_ui_browsertest.cc" ]

  files = [ "device_log_ui_test.ts" ]

  ts_path_mappings =
      [ "chrome://device-log/*|" +
        rebase_path("$root_gen_dir/chrome/browser/resources/device_log/tsc/*",
                    target_gen_dir) ]
  ts_deps = [
    "//chrome/browser/resources/device_log:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
  ts_definitions = [ "//tools/typescript/definitions/chrome_send.d.ts" ]
}
