import("../build_webui_tests.gni")

assert(is_mac)

build_webui_tests("build") {
  cc_test_files = [ "unexportable_keys_internals_browsertest.cc" ]

  files = [ "app_test.ts" ]

  ts_path_mappings = [ "chrome://unexportable-keys-internals/*|" + rebase_path(
                           "$root_gen_dir/chrome/browser/resources/unexportable_keys_internals/tsc/*",
                           target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/unexportable_keys_internals:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
  ]
}
