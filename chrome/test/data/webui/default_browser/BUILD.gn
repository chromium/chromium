import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "default_browser_browsertest.cc" ]

  resource_path_prefix = "default_browser"

  files = [
    "app_with_illustration_test.ts",
    "app_without_illustration_test.ts",
    "test_browser_proxy.ts",
  ]

  ts_path_mappings = [ "chrome://default-browser-modal/*|" + rebase_path(
                           "$root_gen_dir/chrome/browser/resources/default_browser/default_browser_modal/tsc/*",
                           target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/default_browser/default_browser_modal:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
