import("../build_webui_tests.gni")

assert(!is_android)

build_webui_tests("build") {
  cc_test_files = [ "multistep_filter_internals_browsertest.cc" ]
  files = [ "app_test.ts" ]

  ts_path_mappings = [ "chrome://multistep-filter-internals/*|" + rebase_path(
                           "$root_gen_dir/chrome/browser/resources/multistep_filter_internals/tsc/*",
                           target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/multistep_filter_internals:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
}
