import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "bluetooth_internals_browsertest.cc" ]

  files = [
    "bluetooth_internals_test.ts",
    "test_utils.ts",
  ]

  ts_path_mappings =
      [ "chrome://bluetooth-internals/*|" +
        rebase_path(
            "$root_gen_dir/chrome/browser/resources/bluetooth_internals/tsc/*",
            target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/bluetooth_internals:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
