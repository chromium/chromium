import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "subresource_filter_internals_browsertest.cc" ]

  files = [ "subresource_filter_internals_test.ts" ]

  ts_path_mappings =
      [ "chrome://subresource-filter-internals/*|" +
        rebase_path(
            "$root_gen_dir/chrome/browser/resources/subresource_filter/tsc/*",
            target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/subresource_filter:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
}
