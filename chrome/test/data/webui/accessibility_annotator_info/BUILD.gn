import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "personal_context_notice_browsertest.cc" ]

  files = [
    "personal_context_notice_test.ts",
    "test_personal_context_notice_browser_proxy.ts",
  ]

  ts_path_mappings = [ "chrome://accessibility-annotator-info/*|" + rebase_path(
                           "$root_gen_dir/chrome/browser/resources/accessibility_annotator_info/tsc/*",
                           target_gen_dir) ]
  ts_deps = [
    "//chrome/browser/resources/accessibility_annotator_info:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
