import("../build_webui_tests.gni")

build_webui_tests("build") {
  files = [
    "about_sys_test.ts",
    "key_value_pair_viewer_test.ts",
    "test_about_sys_browser_proxy.ts",
  ]

  ts_path_mappings = [
    "chrome://system/*|" +
        rebase_path("$root_gen_dir/chrome/browser/resources/about_sys/tsc/*",
                    target_gen_dir),
    "chrome://system/shared/key_value_pair_viewer/*|" + rebase_path(
            "$root_gen_dir/chrome/browser/resources/key_value_pair_viewer_shared/tsc/*",
            target_gen_dir),
  ]
  ts_deps = [
    "//chrome/browser/resources/about_sys:build_ts",
    "//chrome/browser/resources/key_value_pair_viewer_shared:build_ts",
    "//third_party/polymer/v3_0:library",
    "//ui/webui/resources/js:build_ts",
  ]
}
