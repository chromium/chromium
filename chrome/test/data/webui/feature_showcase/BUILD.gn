import("../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "feature_showcase_browsertest.cc" ]

  files = [ "app_test.ts" ]

  ts_path_mappings =
      [ "chrome://feature-showcase/*|" +
        rebase_path(
            "$root_gen_dir/chrome/browser/resources/feature_showcase/tsc/*",
            target_gen_dir) ]

  ts_deps = [
    "//chrome/browser/resources/feature_showcase:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
}
