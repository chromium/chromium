import("../../build_webui_tests.gni")

build_webui_tests("build") {
  ts_composite = true
  ts_tsconfig_base = "tsconfig_base.json"
  cc_test_files = [ "../cr_components_chromeos_v3_browsertest.js" ]
  files = [
    "activation_code_page_test.ts",
    "base_page_test.ts",
    "button_bar_test.ts",
    "cellular_setup_test.ts",
    "confirmation_code_page_test.ts",
    "esim_flow_ui_test.ts",
    "fake_barcode_detector.ts",
    "fake_cellular_setup_delegate.ts",
    "fake_cellular_setup_remote.ts",
    "fake_esim_manager_remote.ts",
    "fake_media_devices.ts",
    "final_page_test.ts",
    "mock_metrics_private.ts",
    "profile_discovery_list_page_test.ts",
    "provisioning_page_test.ts",
    "psim_flow_ui_test.ts",
    "setup_loading_page_test.ts",
  ]

  ts_path_mappings = [
    "chrome://os-settings/strings.m.js|" +
        rebase_path("//tools/typescript/definitions/strings.d.ts",
                    target_gen_dir),
    "chrome://webui-test/chromeos/*|" +
        rebase_path("$root_gen_dir/chrome/test/data/webui/chromeos/tsc/*",
                    target_gen_dir),
  ]

  ts_definitions = [
    "//tools/typescript/definitions/metrics_private.d.ts",
    "//tools/typescript/definitions/pending.d.ts",
  ]

  ts_deps = [
    "//ash/webui/common/resources:build_ts",
    "//ash/webui/common/resources/cellular_setup:build_ts",
    "//ash/webui/common/resources/cr_elements:build_ts",
    "//chrome/test/data/webui/chromeos:build_ts",
    "//third_party/polymer/v3_0:library",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
  ts_extra_deps = [ "//ash/webui/common/resources:generate_definitions" ]
}
