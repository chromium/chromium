import("../../build_webui_tests.gni")

build_webui_tests("build") {
  ts_composite = true
  cc_test_files = [ "../cr_components_chromeos_v3_browsertest.js" ]
  files = [
    "apn_list_item_test.ts",
    "apn_list_test.ts",
    "apn_selection_dialog_list_item_test.ts",
    "apn_selection_dialog_test.ts",
    "cr_policy_network_behavior_mojo_tests.js",
    "cr_policy_network_indicator_mojo_tests.js",
    "cr_policy_strings.js",
    "network_apnlist_test.js",
    "network_choose_mobile_test.ts",
    "network_config_element_behavior_test.js",
    "network_config_input_test.ts",
    "network_config_select_test.js",
    "network_config_test.ts",
    "network_config_toggle_test.js",
    "network_config_vpn_test.ts",
    "network_config_wifi_test.ts",
    "network_icon_test.js",
    "network_ip_config_test.ts",
    "network_list_item_test.js",
    "network_list_test.js",
    "network_nameservers_test.ts",
    "network_password_input_test.ts",
    "network_property_list_mojo_test.js",
    "network_proxy_exclusions_test.ts",
    "network_proxy_input_test.ts",
    "network_proxy_test.ts",
    "network_select_test.ts",
    "network_siminfo_test.ts",
    "sim_lock_dialogs_test.ts",
    "test_utils.ts",
  ]

  ts_path_mappings = [
    "chrome://os-settings/strings.m.js|" +
        rebase_path("//tools/typescript/definitions/strings.d.ts",
                    target_gen_dir),
    "chrome://webui-test/chromeos/*|" +
        rebase_path("$root_gen_dir/chrome/test/data/webui/chromeos/tsc/*",
                    target_gen_dir),
  ]

  ts_deps = [
    "//ash/webui/common/resources:build_ts",
    "//ash/webui/common/resources/cr_elements:build_ts",
    "//chrome/test/data/webui/chromeos:build_ts",
    "//third_party/polymer/v3_0:library",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
  ts_extra_deps = [ "//ash/webui/common/resources:generate_definitions" ]
}
