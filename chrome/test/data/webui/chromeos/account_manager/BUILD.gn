import("../../build_webui_tests.gni")

build_webui_tests("build") {
  cc_test_files = [ "account_manager_browsertest.js" ]
  files = [
    "account_migration_welcome_test.js",
    "test_account_manager_browser_proxy.js",
  ]

  ts_path_mappings = [
    "chrome://account-migration-welcome/strings.m.js|" +
        rebase_path("//tools/typescript/definitions/strings.d.ts",
                    target_gen_dir),
    "chrome://webui-test/chromeos/*|" +
        rebase_path("$root_gen_dir/chrome/test/data/webui/chromeos/tsc/*",
                    target_gen_dir),
  ]

  ts_deps = [
    "//ash/webui/common/resources:build_ts",
    "//ash/webui/common/resources/cr_elements:build_ts",
    "//chrome/test/data/webui/chromeos:build_ts",
    "//third_party/polymer/v3_0:library",
    "//ui/webui/resources/js:build_ts",
  ]
  ts_extra_deps = [ "//ash/webui/common/resources:generate_definitions" ]
}
