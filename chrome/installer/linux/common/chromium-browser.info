# This file provides common configuration information for building
# chromium-browser packages for various platforms.

# Base name of the package.
PACKAGE="dappnet-browser"

# Filename of the main executable (for generating launcher scripts, etc.)
PROGNAME=chrome

# Base directory for package installation.
INSTALLDIR=/opt/dappnet/dappnet

# Directory for device policy enrollments.
ENROLLMENTDIR=/etc/dappnet/policies/enrollment

# Display string for desktop menu/icon.
MENUNAME="Dappnet Web Browser"

# Brief package description.
SHORTDESC="The decentralized web browser powered by Dappnet"

# Detailed package description.
FULLDESC="Dappnet is a browser that combines decentralized web technologies with sophisticated design to make the web more open, secure, and user-controlled."

# Package maintainer information.
MAINTNAME="Dappnet Team"
MAINTMAIL="team@dappnet.io"
PRODUCTURL="https://dappnet.io"

PROJECT_LICENSE="BSD-3-Clause and LGPL-2.1+ and Apache-2.0 and IJG and MIT and GPL-2.0+ and ISC and OpenSSL and (MPL-1.1 or GPL-2.0 or LGPL-2.0)"

DEVELOPER_NAME="The Dappnet Team"

BUGTRACKERURL="https://github.com/dappnet/dappnet/issues"

HELPURL="https://docs.dappnet.io"

RDN="io.dappnet.Dappnet"
