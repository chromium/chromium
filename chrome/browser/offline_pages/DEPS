include_rules = [
  # This folder should not depend on specific platform implementations.
  # This restriction helps in moving files here since historically offline_pages
  # were android-only and thus accumulated many unnecessary dependencies on
  # Android. OS-specific subfolders should have their own DEPS enabling specific
  # dependencies.
  "-base/android",
  "-chrome/browser/offline_pages/android",
  "-chrome/browser",
  "+chrome/browser/offline_pages",
  "+chrome/browser/browser_process.h",
  "+chrome/browser/profiles/profile.h",
  "+chrome/browser/profiles/profile_key.h",
  "+chrome/browser/profiles/profile_keyed_service_factory.h",
  "+chrome/browser/ssl/chrome_security_state_tab_helper.h",
  "+chrome/browser/net/net_error_tab_helper.h",
  "+chrome/browser/content_settings/cookie_settings_factory.h",
  "+chrome/browser/preloading/preloading_prefs.h",
  "+chrome/browser/renderer_host/chrome_navigation_ui_data.h",
  "+chrome/browser/image_fetcher/image_decoder_impl.h",
  "+chrome/browser/content_settings/page_specific_content_settings_delegate.h",
  "+chrome/browser/renderer_preferences_util.h",
  "+chrome/browser/download/download_prefs.h",
  "+chrome/browser/download/android/mock_download_controller.h",
]
