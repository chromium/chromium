    "//components/keyed_service/core",
    "//components/memory_pressure",
    "//components/metrics",
    "//components/performance_manager",
    "//components/performance_manager/scenario_api",
    "//components/prefs",
    "//components/search_engines",
    "//content/public/browser",
    "//content/public/common",
    "//extensions/buildflags",
    "//url",
  ]

  if (is_android) {
    public += [
      "policies/discard_page_with_crashed_subframe_policy.h",
      "policies/process_rank_policy_android.h",
    ]
    public_deps += [ "//content/public/browser" ]
  }

  if (!is_android) {
    public += [
      "execution_context_priority/side_panel_loading_voter.h",
      "mechanisms/page_loader.h",
      "metrics/metrics_provider_desktop.h",
      "policies/background_tab_loading_policy.h",
