      "policies/freezing_opt_out_checker.h",
      "policies/memory_saver_mode_policy.h",
      "policies/sustained_memory_pressure_evaluator.h",
      "policies/urgent_page_discarding_policy.h",
      "public/background_tab_loading_policy.h",
      "public/side_panel_loading_policy.h",
      "user_tuning/cpu_health_tracker.h",
    ]
    public_deps += [
      "//chrome/browser/performance_manager/public/user_tuning",
      "//chrome/browser/performance_manager/user_tuning",
      "//components/system_cpu",
    ]
  }

  if (is_chromeos) {
    public += [
      "mechanisms/working_set_trimmer_chromeos.h",
      "policies/oom_score_policy_chromeos.h",
      "policies/report_page_processes_policy.h",
      "policies/working_set_trimmer_policy_arcvm.h",
      "policies/working_set_trimmer_policy_chromeos.h",
    ]
    public_deps += [
      "//chrome/browser/ash/arc/session",
      "//chromeos/ash/experiences/arc",
      "//chromeos/ash/experiences/arc/mojom",
      "//chromeos/ash/experiences/arc/process",
      "//chromeos/ash/experiences/arc/session",
      "//chromeos/ash/experiences/arc/session:connection_holder",
      "//chromeos/dbus/power",
      "//ui/wm/public",
    ]
  }

  if (is_win) {
    public += [
      "policies/priority_boost_helpers.h",
      "public/dll_pre_read_policy_win.h",
    ]
  }

  if (enable_extensions_core) {
    public += [ "extension_watcher.h" ]
    public_deps += [ "//extensions/browser" ]
  }
}

