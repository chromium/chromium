    "user_tuning/profile_discard_opt_out_list_helper.h",
    "user_tuning/profile_force_foreground_priority_list_helper.h",
  ]

  public_deps = [
    "//base",
    "//chrome/browser:chrome_content_browser_client_parts",
    "//chrome/browser:main_extra_parts",
    "//chrome/browser/media/webrtc",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/resource_coordinator:mojo_bindings",
    "//chrome/browser/resource_coordinator:mojo_bindings_shared",
