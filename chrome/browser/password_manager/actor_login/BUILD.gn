import("//chrome/common/features.gni")

source_set("service") {
  public = [ "actor_login_service.h" ]

  public_deps = [
    "//base",
    "//components/password_manager/core/browser/actor_login:common",
    "//components/tabs:public",
  ]
}
source_set("service_impl") {
  public = [
    "actor_login_quality_logger.h",
    "actor_login_service_impl.h",
  ]
  sources = [
    "actor_login_quality_logger.cc",
    "actor_login_service_impl.cc",
  ]

  public_deps = [
    ":service",
    "//components/password_manager/core/browser/actor_login/internal:delegate",
  ]

  deps = [
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/password_manager/actor_login/internal",
    "//chrome/browser/profiles:profile",
    "//components/affiliations/core/browser:affiliations",
    "//components/optimization_guide/core:model_execution",
    "//components/password_manager/content/browser",
    "//components/password_manager/core/browser/actor_login:common",
    "//components/password_manager/core/browser/actor_login/internal:delegate",
    "//components/tabs:public",
    "//components/translate/core/browser",
    "//components/variations/service",
    "//content/public/browser",
  ]
}

source_set("factories") {
  sources = [
    "actor_login_permission_cleaning_service_factory.cc",
    "actor_login_permission_cleaning_service_factory.h",
    "actor_login_permission_service_factory.cc",
    "actor_login_permission_service_factory.h",
  ]

  deps = [
    "//base",
    "//chrome/browser/password_manager/factories",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/signin",
    "//components/password_manager/core/browser/actor_login:common",
    "//components/password_manager/core/browser/actor_login/internal:permission_cleaner",
    "//components/password_manager/core/browser/actor_login/internal:permission_service_impl",
    "//components/signin/public/identity_manager",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "actor_login_quality_logger_unittest.cc",
    "actor_login_service_impl_unittest.cc",
  ]

  deps = [
    ":service_impl",
    "//base/test:test_support",
    "//chrome/browser/password_manager/actor_login/internal",
    "//chrome/browser/password_manager/actor_login/internal:unit_tests",
    "//chrome/test:test_support",
    "//components/language/core/browser",
    "//components/optimization_guide/core:model_execution_test_support",
    "//components/password_manager/core/browser/actor_login:common",
    "//components/password_manager/core/browser/actor_login/internal:delegate",
    "//components/password_manager/core/browser/actor_login/test:test_support",
    "//components/tabs:public",
    "//components/tabs:test_support",
    "//components/translate/core/browser:test_support",
    "//content/public/browser",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
