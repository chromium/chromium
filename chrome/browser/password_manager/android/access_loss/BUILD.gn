import("//build/config/android/rules.gni")

android_library("java") {
  resources_package = "org.chromium.chrome.browser.access_loss"

  sources = [ "java/src/org/chromium/chrome/browser/access_loss/PasswordAccessLossDialogSettingsCoordinator.java" ]

  deps = [
    "//base:base_java",
    "//build/android:build_java",
    "//chrome/browser/password_manager/android:java_resources",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//ui/android:ui_java",
