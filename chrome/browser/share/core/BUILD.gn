import("//chrome/browser/buildflags.gni")

source_set("crow_configuration") {
  sources = [
    "crow_configuration.cc",
    "crow_configuration.h",
  ]
  deps = [
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/share/proto:crow_proto",
  ]
}

source_set("crow_configuration_unittest") {
  testonly = true
  sources = [ "crow_configuration_unittest.cc" ]

  deps = [
    ":crow_configuration",
    "//base",
    "//chrome/browser/share/proto:crow_proto",
    "//testing/gmock",
    "//testing/gtest",
  ]
}

source_set("share_targets") {
  sources = [
    "share_targets.cc",
    "share_targets.h",
    "share_targets_observer.h",
  ]
  deps = [
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser:resources_grit",
    "//chrome/browser/share/core/resources:make_share_targets_protobuf",
    "//chrome/browser/share/proto:proto",
    "//components/country_codes",
    "//components/resources:components_resources",
    "//ui/base:base",
  ]
}

source_set("share_targets_unittest") {
  testonly = true
  sources = [ "share_targets_unittest.cc" ]

  deps = [
    ":share_targets",
    "//base",
    "//build:chromeos_buildflags",
    "//components/country_codes",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
