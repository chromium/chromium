source_set("dictation") {
  public = [
    "dictation_keyed_service.h",
    "dictation_keyed_service_factory.h",
    "features.h",
    "session_controller.h",
    "session_controller_delegate.h",
    "session_ui.h",
    "session_ui_delegate.h",
    "stream_provider.h",
    "target.h",
  ]
  public_deps = [
    "//base",
    "//chrome/browser/profiles:profile",
  ]
}

source_set("impl") {
  sources = [
    "dictation_keyed_service.cc",
    "dictation_keyed_service_factory.cc",
    "features.cc",
    "session_controller.cc",
    "session_ui_impl.cc",
    "session_ui_impl.h",
  ]

  deps = [
    ":dictation",
    "//base",
    "//chrome/browser/ui",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/views/interaction",
    "//content/public/browser",
    "//ui/views",
  ]
}

source_set("test_support") {
  testonly = true
  sources = [
    "test_util.cc",
    "test_util.h",
  ]

  public_deps = [
    ":dictation",
    "//base",
    "//testing/gmock",
    "//testing/gtest",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "dictation_keyed_service_unittest.cc",
    "session_controller_unittest.cc",
  ]

  deps = [
    ":impl",
    ":test_support",
    "//base/test:test_support",
    "//chrome/browser/ui:test_support",
  ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [
    "dictation_keyed_service_browsertest.cc",
    "session_ui_impl_browsertest.cc",
  ]
  deps = [
    ":impl",
    ":test_support",
    "//chrome/browser/profiles:profile",
    "//chrome/test:test_support",
    "//content/test:test_support",
  ]
}
