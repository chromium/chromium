import("//components/on_device_translation/buildflags/features.gni")

assert(enable_on_device_translation)

source_set("on_device_translation") {
  sources = [
    "../component_updater/translate_kit_component_installer.cc",
    "../component_updater/translate_kit_component_installer.h",
    "../component_updater/translate_kit_language_pack_component_installer.cc",
    "../component_updater/translate_kit_language_pack_component_installer.h",
    "installer_impl.cc",
    "installer_impl.h",
    "service_controller_manager_factory.cc",
    "service_controller_manager_factory.h",
    "translation_manager_impl.cc",
    "translation_manager_impl.h",
  ]
  public_deps = [
    "//chrome/browser:browser_public_dependencies",
    "//components/on_device_translation:public",
  ]
  deps = [
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/content_settings",
    "//chrome/browser/content_settings:content_settings_factory",
    "//components/component_updater",
    "//components/content_settings/core/browser",
    "//components/keyed_service/content",
    "//components/on_device_translation",
    "//components/on_device_translation/public/mojom",
    "//components/on_device_translation/service:on_device_translation_service",
    "//components/permissions",
    "//components/prefs",
    "//components/update_client",
    "//content/public/browser",
  ]
  if (is_chromeos) {
    deps += [ "//chromeos/ash/components/dbus/image_loader" ]
  }
  configs += [ "//build/config/compiler:wexit_time_destructors" ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "../component_updater/translate_kit_component_installer_unittest.cc",
    "../component_updater/translate_kit_language_pack_component_installer_unittest.cc",
    "installer_impl_unittest.cc",
  ]
  deps = [
    ":on_device_translation",
    "//base",
    "//base/test:test_support",
    "//chrome/browser",
    "//chrome/test:test_support",
    "//components/component_updater:test_support",
    "//components/crx_file",
    "//components/language/core/browser",
    "//components/on_device_translation",
    "//components/on_device_translation:public",
    "//components/on_device_translation/public/mojom",
    "//components/on_device_translation/service/:test_support",
    "//components/prefs",
    "//components/prefs:test_support",
    "//components/sync_preferences:test_support",
    "//components/update_client",
    "//content/test:test_support",
  ]
  if (is_chromeos) {
    deps += [ "//chromeos/ash/components/dbus/image_loader" ]
  }
}

source_set("test_support") {
  testonly = true
  sources = [
    "test/test_util.cc",
    "test/test_util.h",
  ]
  public_deps = [ "//components/on_device_translation:public" ]
  deps = [
    ":on_device_translation",
    "//base",
    "//base/test:test_support",
    "//chrome/browser",
    "//chrome/browser:browser_process",
    "//chrome/browser/ui",
    "//components/on_device_translation",
    "//components/on_device_translation/service:test_support",
    "//content/test:test_support",
  ]
}
