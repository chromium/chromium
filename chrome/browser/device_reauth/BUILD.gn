source_set("device_reauth") {
  sources = [ "chrome_device_authenticator_factory.h" ]
  deps = [
    "//chrome/browser/profiles:profile",
    "//ui/gfx",
  ]
}

source_set("impl") {
  sources = [ "chrome_device_authenticator_factory.cc" ]

  deps = [
    ":device_reauth",
    "//chrome/browser:browser_process",
    "//chrome/browser/profiles:profile",
    "//components/device_reauth",
    "//components/prefs",
  ]

  if (is_android) {
    sources += [
      "android/device_authenticator_android.cc",
      "android/device_authenticator_android.h",
      "android/device_authenticator_bridge.h",
      "android/device_authenticator_bridge_impl.cc",
      "android/device_authenticator_bridge_impl.h",
      "android/reauthenticator_bridge.cc",
      "android/reauthenticator_bridge.h",
    ]
    deps += [
      "//chrome/browser/device_reauth/android:jni_headers",
      "//components/password_manager/core/browser",
      "//ui/android",
    ]
  }

  if (is_chromeos) {
    sources += [
      "chromeos/authenticator_chromeos.cc",
      "chromeos/authenticator_chromeos.h",
      "chromeos/device_authenticator_chromeos.cc",
      "chromeos/device_authenticator_chromeos.h",
    ]
    deps += [
      "//ash/constants",
      "//ash/public/cpp",
      "//chrome/browser/ash/auth",
      "//chrome/browser/profiles:profile_manager",
      "//chromeos/ash/components/cryptohome",
      "//chromeos/ash/components/dbus/cryptohome",
      "//chromeos/ash/components/dbus/cryptohome:cryptohome_proto",
      "//chromeos/ash/components/dbus/userdataauth",
      "//chromeos/ash/components/dbus/userdataauth:userdataauth_proto",
      "//chromeos/ash/components/osauth/public",
      "//components/user_manager",
    ]
  }

  if (is_mac) {
    sources += [
      "mac/authenticator_mac.h",
      "mac/authenticator_mac.mm",
      "mac/device_authenticator_mac.h",
      "mac/device_authenticator_mac.mm",
    ]
    deps += [
      "//chrome/app:branded_strings",
      "//chrome/browser/password_manager",
      "//components/password_manager/core/browser/features:password_features",
      "//components/password_manager/core/common",
      "//device/fido",
      "//ui/base",
    ]
  }

  if (is_win) {
    sources += [
      "win/authenticator_win.cc",
      "win/authenticator_win.h",
      "win/device_authenticator_win.cc",
      "win/device_authenticator_win.h",
    ]
    deps += [
      "//chrome/browser/password_manager",
      "//components/password_manager/core/common",
      "//ui/aura",
      "//ui/views",
    ]
  }
}

source_set("unit_tests") {
  testonly = true
  sources = [ "chrome_device_authenticator_factory_unittest.cc" ]
  deps = [
    ":device_reauth",
    ":impl",
    "//base/test:test_support",
    "//chrome/browser/prefs",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/profiles:profile_manager",
    "//chrome/test:test_support",
    "//components/device_reauth",
    "//components/prefs:test_support",
    "//content/test:test_support",
    "//testing/gtest",
  ]
  if (is_android) {
    sources += [ "android/device_authenticator_android_unittest.cc" ]
    deps += [ "//ui/android" ]
  }
  if (is_chromeos) {
    sources += [ "chromeos/device_authenticator_chromeos_unittest.cc" ]
  }
  if (is_mac) {
    sources += [ "mac/device_authenticator_mac_unittest.mm" ]
    deps += [ "//device/fido:test_support" ]
  }
  if (is_win) {
    sources += [ "win/device_authenticator_win_unittest.cc" ]
  }
}
