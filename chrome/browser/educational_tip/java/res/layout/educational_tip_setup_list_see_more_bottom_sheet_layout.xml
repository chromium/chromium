<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<!--    TODO(crbug.com/479597724): Implement bottom sheet layout.-->

    <ImageView
        android:id="@+id/setup_list_bottom_sheet_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/setup_list_bottom_sheet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/setup_list_bottom_sheet_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <org.chromium.chrome.browser.educational_tip.two_cell.EducationalTipBottomSheetListContainerView
        android:id="@+id/setup_list_bottom_sheet_container_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
    </org.chromium.chrome.browser.educational_tip.two_cell.EducationalTipBottomSheetListContainerView>
</LinearLayout>
