<org.chromium.chrome.browser.educational_tip.two_cell.EducationalTipBottomSheetListItemView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="UnusedResources"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!--    TODO(crbug.com/479597724): Implement bottom sheet list item view.-->

    <ImageView
        android:id="@+id/list_item_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/list_item_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@+id/list_item_button"
        android:layout_alignEnd="@id/list_item_icon"
        android:layout_alignParentTop="true" />
    <TextView
        android:id="@+id/list_item_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignEnd="@id/list_item_icon"
        android:layout_alignStart="@+id/list_item_button"/>
    <org.chromium.ui.widget.ButtonCompat
        android:id="@+id/list_item_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"/>
</org.chromium.chrome.browser.educational_tip.two_cell.EducationalTipBottomSheetListItemView>
