<org.chromium.chrome.browser.educational_tip.two_cell.EducationalTipSetupListBottomSheetListItemView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_height"
    android:padding="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_padding"
    android:layout_marginBottom="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_margin_bottom"
    android:background="@drawable/educational_tip_setup_list_bottom_sheet_list_item_background"
    android:clickable="true"
    >

    <ImageView
        android:id="@+id/list_item_icon"
        android:layout_width="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_icon_width"
        android:layout_height="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_icon_height"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/list_item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:textAppearance="@style/TextAppearance.TextMediumThick"
        android:layout_marginStart="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_margin"
        app:layout_constraintBottom_toTopOf="@id/list_item_description"
        app:layout_constraintStart_toEndOf="@id/list_item_icon"
        app:layout_constraintEnd_toStartOf="@id/chevron"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/list_item_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:layout_alignParentBottom="true"
        android:textAppearance="@style/TextAppearance.TextSmall"
        android:layout_marginStart="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_margin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/list_item_icon"
        app:layout_constraintEnd_toStartOf="@id/chevron"
        app:layout_constraintTop_toBottomOf="@id/list_item_title" />

    <ImageView
        android:id="@+id/chevron"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/educational_tip_setup_list_see_more_bottom_sheet_list_item_margin"
        android:background="@drawable/chevron_right"
        android:contentDescription="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/list_item_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</org.chromium.chrome.browser.educational_tip.two_cell.EducationalTipSetupListBottomSheetListItemView>
