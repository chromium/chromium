<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 0: the background drawable. -->
    <item android:drawable="@drawable/ntp_theme_promo_logo_background"
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"/>

    <!-- Layer 1: the highlight drawable. -->
    <item android:drawable="@drawable/ntp_theme_promo_logo_background_highlight"
        android:top="12dp"
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp" />

    <!-- Layer 2: the original 28dp icon with 16dp padding applied to all sides. -->
    <item
        android:drawable="@drawable/ntp_theme_promo_logo_icon"
        android:width="48dp"
        android:height="48dp"
        android:gravity="center"
        android:top="16dp"
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp" />

</layer-list>
