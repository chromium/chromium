assert(is_win)

source_set("os_crypt") {
  sources = [
    "app_bound_encryption_metrics_win.cc",
    "app_bound_encryption_metrics_win.h",
    "app_bound_encryption_win.cc",
    "app_bound_encryption_win.h",
  ]

  deps = [
    "//base",
    "//chrome/install_static:install_static_util",
    "//components/prefs:prefs",
    "//content/public/browser",
  ]

  public_deps = [ "//chrome/elevation_service:public_headers" ]
}

source_set("browser_tests") {
  testonly = true
  sources = [ "app_bound_encryption_win_browsertest.cc" ]

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  deps = [
    ":os_crypt",
    "//base",
    "//chrome/install_static/test:test_support",
    "//chrome/installer/util:constants",
    "//chrome/test:test_support",
    "//components/version_info:version_info",
    "//content/test:test_support",
  ]
}
