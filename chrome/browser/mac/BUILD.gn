import("//build/util/process_version.gni")
import("//chrome/updater/branding.gni")
import("//testing/test.gni")

process_version("install") {
  extra_args = [
    "-e",
    "SHEBANGGUARD=\"\"",
    "-e",
    "BROWSER_PRODUCT_NAME=\"$browser_product_name\"",
    "-e",
    "UPDATER_PRODUCT_NAME=\"$updater_product_full_name\"",
    "-e",
    "KEYSTONE_APP_NAME=\"$keystone_app_name\"",
    "-e",
    "UPDATER_COMPANY_SHORT_NAME=\"$updater_company_short_name\"",
  ]
  process_only = true
  executable = true
  template_file = "install.sh.in"
  output = "$target_gen_dir/install.sh"
}

# These tests mutate system state and should not be bundled into unit_tests or
# other commonly-run targets.
test("install_sh_test") {
  testonly = true
  sources = [ "install_test.cc" ]
  deps = [
    "//base",
    "//base/test:test_config",
    "//base/test:test_support",
    "//build:branding_buildflags",
    "//chrome",
    "//testing/gtest",
  ]
}

# key_window_notifier is split out so that
# //chrome/browser:browser_process_platform_part can include
# browser_process_platform_part_mac.h (which transitively includes
# key_window_notifier.h) without depending on the rest of :mac.
source_set("key_window_notifier") {
  public = [ "key_window_notifier.h" ]
  public_deps = [ "//base" ]
}

source_set("mac") {
  public = [
    "auth_session_request.h",
    "chrome_browser_main_extra_parts_mac.h",
    "code_sign_clone_manager.h",
    "dock.h",
    "exception_processor.h",
    "initial_prefs.h",
    "install_from_dmg.h",
    "metrics.h",
    "nsprocessinfo_additions.h",
    "relauncher.h",
  ]
  sources = public
  public_deps = [
    ":key_window_notifier",
    "//base",
    "//chrome/browser:main_extra_parts",
    "//chrome/browser/upgrade_detector",
    "//content/public/browser",
    "//content/public/common",
  ]
}

source_set("impl") {
  sources = [
    "auth_session_request.mm",
    "chrome_browser_main_extra_parts_mac.mm",
    "code_sign_clone_manager.mm",
    "dock.mm",
    "exception_processor.mm",
    "initial_prefs.mm",
    "install_from_dmg.mm",
    "key_window_notifier.cc",
    "metrics.mm",
    "nsprocessinfo_additions.mm",
    "relauncher.mm",
  ]
  deps = [
    ":mac",
    "//base",
    "//chrome/browser/prefs",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui",
    "//chrome/common:channel_info",
    "//chrome/common:constants",
    "//components/policy/core/common",
    "//components/version_info",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "auth_session_request_unittest.mm",
    "code_sign_clone_manager_unittest.mm",
    "exception_processor_unittest.mm",
    "metrics_unittest.mm",
  ]
  deps = [
    ":impl",
    ":mac",
    "//base",
    "//base/test:test_support",
    "//build:branding_buildflags",
    "//chrome/common:non_code_constants",
    "//content/test:test_support",
    "//testing/gtest",
  ]
  configs += [ "//build/config/compiler:no_exit_time_destructors" ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "auth_session_request_browsertest.mm" ]
  deps = [
    ":impl",
    ":mac",
    "//base",
    "//chrome/test:test_support",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
