import("//build/compiled_action.gni")

# Split into a separate target for build graph optimization.
source_set("selected_colors_info") {
  sources = [ "selected_colors_info.h" ]
  public_deps = [
    "//chrome/app:generated_resources",
    "//skia",
  ]
}

source_set("chrome_colors") {
  sources = [
    "chrome_colors_util.cc",
    "chrome_colors_util.h",
  ]
  public_deps = [
    "//skia",
    "//ui/base/mojom",
  ]
  deps = [
    ":generate_chrome_colors_info",
    "//chrome/browser/ui/webui/cr_components/theme_color_picker",
  ]
}

executable("generate_colors_info") {
  sources = [ "generate_colors_info.cc" ]
  deps = [
    ":selected_colors_info",

    # Avoid adding big generic deps as this target is build for host
    # toolchain. For example, see the problem with adding //chrome in
    # crbug.com/1000916.
    "//base",
    "//chrome/app:generated_resources",
    "//chrome/common/themes:autogenerated_theme_util",
    "//skia",
  ]
}

compiled_action("generate_chrome_colors_info") {
  tool = ":generate_colors_info"
  outputs = [ "$target_gen_dir/generated_colors_info.h" ]
  args = rebase_path(outputs, root_build_dir)

  # Restrict visibility to prevent accidental build dependency serialization.
  # See http://crbug.com/477780634.
  visibility = [
    ":chrome_colors",
    "//chrome/browser",
    "//chrome/browser/signin:impl",
    "//chrome/browser/ui",
    "//chrome/browser/ui/profiles:impl",
    "//chrome/browser/ui/profiles:unit_tests",
    "//chrome/browser/ui/webui/cr_components/theme_color_picker",
    "//chrome/browser/ui/webui/signin:profile_impl",
    "//chrome/test:*",
  ]
}
