import("//mojo/public/tools/bindings/mojom.gni")
import("//testing/test.gni")

mojom("notice_mojom") {
  sources = [ "notice.mojom" ]
  webui_module_path = "/"
  generate_legacy_js_bindings = true
  generate_java = true
}

source_set("core") {
  sources = [
    "notice_catalog.cc",
    "notice_features.cc",
    "notice_model.cc",
    "notice_storage.cc",
  ]
  public = [
    "notice_catalog.h",
    "notice_constants.h",
    "notice_features.h",
    "notice_model.h",
    "notice_storage.h",
  ]
  deps = [
    ":notice_mojom",
    "//base",
    "//base/version_info:version_info",
    "//components/pref_registry:pref_registry",
    "//components/prefs",
    "//components/privacy_sandbox:features",
  ]
  public_deps = [ ":notice_mojom" ]
}

source_set("interfaces") {
  public = [ "notice_service_interface.h" ]
  deps = [ ":notice_mojom" ]
}

source_set("notice") {
  sources = [ "notice_service.cc" ]
  deps = [
    ":core",
    ":interfaces",
    "//base",
    "//chrome/browser/profiles:profile",
    "//components/keyed_service/core",
  ]

  if (!is_android) {
    deps += [ ":desktop_view_manager" ]
  }
}

# (Desktop Only)
if (!is_android) {
  source_set("desktop_view_manager") {
    sources = [ "desktop_view_manager.cc" ]
    public = [ "desktop_view_manager.h" ]
    deps = [
      ":core",
      ":interfaces",
      "//base",
    ]
  }
}

test("fuzz_tests") {
  sources = [ "notice_storage_fuzztest.cc" ]
  fuzztests = [
    "PrivacySandboxNoticeStorageFuzzTest.CheckConvertsV1SchemaSuccessfully",
  ]
  deps = [
    ":core",
    "//testing/gmock",
    "//testing/gtest",
    "//third_party/fuzztest:fuzztest_gtest_main",
  ]
}

source_set("test_support") {
  testonly = true
  sources = [
    "mock_notice_service.cc",
    "mock_notice_service.h",
  ]
  deps = [
    ":interfaces",
    ":notice_mojom",
    "//components/keyed_service/core",
    "//content/public/browser",
    "//testing/gmock",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "notice_catalog_unittest.cc",
    "notice_model_unittest.cc",
    "notice_service_unittest.cc",
    "notice_storage_unittest.cc",
  ]
  data = [ "//tools/metrics/histograms/metadata/privacy/histograms.xml" ]
  deps = [
    ":core",
    ":notice",
    "//base/test:test_support",
    "//base/version_info",
    "//chrome/test:test_support",
    "//components/prefs",
    "//components/prefs:test_support",
    "//components/privacy_sandbox:features",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
