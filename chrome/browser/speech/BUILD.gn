import("//build/config/features.gni")
import("//components/soda/buildflags.gni")
import("//extensions/buildflags/buildflags.gni")

source_set("speech") {
  public = [
    "chrome_speech_recognition_manager_delegate.h",
    "on_device_speech_recognition_impl.h",
    "on_device_speech_recognition_util.h",
  ]

  public_deps = [
    "//base",
    "//content/public/browser",
    "//media/mojo/mojom:web_speech_recognition",
    "//mojo/public/cpp/bindings",
  ]

  if (!is_android) {
    public += [
      "chrome_speech_recognition_service.h",
      "speech_recognition_client_browser_interface.h",
      "speech_recognition_client_browser_interface_factory.h",
      "speech_recognition_service.h",
      "speech_recognition_service_factory.h",
    ]

    public_deps += [
      "//chrome/browser/profiles:profile",
      "//components/optimization_guide/core:model_execution",
      "//components/optimization_guide/core:ondevice",
      "//components/soda",
      "//components/soda:constants",
      "//media/mojo/mojom",
      "//media/mojo/mojom:speech_recognition",
    ]
  }

  if (is_chromeos) {
    public += [
      "cros_speech_recognition_service.h",
      "cros_speech_recognition_service_factory.h",
      "network_speech_recognizer.h",
      "speech_recognition_constants.h",
      "speech_recognition_recognizer_client_impl.h",
      "speech_recognizer.h",
      "speech_recognizer_delegate.h",
      "tts_chromeos.h",
      "tts_controller_delegate_impl.h",
    ]

    public_deps += [
      "//chrome/browser/ash/accessibility",
      "//chromeos/services/tts/public/mojom",
    ]
  }

  if (enable_extensions_core) {
    public += [
      "extension_api/tts_engine_extension_api.h",
      "extension_api/tts_extension_api.h",
      "extension_api/tts_extension_api_constants.h",
    ]

    public_deps += [
      "//extensions/browser",
      "//extensions/buildflags",
    ]
  }

  if (is_chromeos && enable_extensions) {
    public += [
      "extension_api/tts_engine_extension_api_chromeos.h",
      "extension_api/tts_engine_extension_observer_chromeos.h",
      "extension_api/tts_engine_extension_observer_chromeos_factory.h",
    ]
  }
}

source_set("impl") {
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]

  sources = [
    "chrome_speech_recognition_manager_delegate.cc",
    "on_device_speech_recognition_impl.cc",
    "on_device_speech_recognition_util.cc",
  ]

  deps = [
    ":speech",
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/component_updater",
    "//chrome/browser/optimization_guide",
    "//chrome/browser/profiles:profile_manager",
    "//chrome/services/speech/buildflags",
    "//components/user_prefs",
    "//content/public/browser",
    "//media/mojo/mojom:speech_recognition",
    "//media/mojo/mojom:web_speech_recognition",
    "//mojo/public/cpp/bindings",
  ]

  if (!is_android) {
    sources += [
      "chrome_speech_recognition_service.cc",
      "speech_recognition_client_browser_interface.cc",
      "speech_recognition_client_browser_interface_factory.cc",
      "speech_recognition_service_factory.cc",
    ]

    deps += [
      "//chrome/browser/accessibility/live_caption",
      "//chrome/browser/content_settings:content_settings_factory",
      "//chrome/browser/profiles:profile",
      "//components/content_settings/core/browser",
      "//components/keyed_service/content",
      "//components/keyed_service/core",
      "//components/live_caption:constants",
      "//components/live_caption:utils",
      "//components/prefs",
      "//components/soda",
      "//components/soda:constants",
      "//components/soda:utils",
    ]
  }

  if (is_chromeos) {
    sources += [
      "cros_speech_recognition_service.cc",
      "cros_speech_recognition_service_factory.cc",
      "network_speech_recognizer.cc",
      "speech_recognition_constants.cc",
      "speech_recognition_recognizer_client_impl.cc",
      "speech_recognizer.cc",
      "tts_chromeos.cc",
      "tts_controller_delegate_impl.cc",
    ]

    deps += [
      "//chrome/services/speech:lib",
      "//chromeos/ash/experiences/arc/session",
      "//components/keyed_service/content",
      "//components/keyed_service/core",
      "//components/language/core/common",
    ]
  }

  if (enable_extensions_core) {
    sources += [
      "extension_api/tts_engine_extension_api.cc",
      "extension_api/tts_extension_api.cc",
    ]

    deps += [
      "//chrome/browser/extensions",
      "//extensions/browser",
      "//extensions/common",
    ]
  }

  if (is_chromeos && enable_extensions) {
    sources += [
      "extension_api/tts_engine_extension_api_chromeos.cc",
      "extension_api/tts_engine_extension_observer_chromeos.cc",
      "extension_api/tts_engine_extension_observer_chromeos_factory.cc",
    ]

    deps += [
      "//chromeos/services/tts/public/mojom",
      "//components/keyed_service/content",
    ]
  }
}

if (!is_android) {
  source_set("test_support") {
    testonly = true
    public = [
      "fake_speech_recognition_service.h",
      "fake_speech_recognizer.h",
    ]
    sources = [
      "fake_speech_recognition_service.cc",
      "fake_speech_recognizer.cc",
    ]
    public_deps = [
      ":speech",
      "//base",
      "//media",
      "//media/mojo/mojom",
      "//mojo/public/cpp/bindings",
    ]
    deps = [
      "//chrome/browser:browser_process",
      "//content/public/browser",
      "//testing/gtest",
    ]

    if (is_chromeos) {
      public += [ "speech_recognition_test_helper.h" ]
      sources += [ "speech_recognition_test_helper.cc" ]
      public_deps += [
        "//base/test:test_support",
        "//content/test:test_support",
      ]
      deps += [
        "//components/soda",
        "//components/soda:constants",
      ]
    }
  }

  source_set("unit_tests") {
    testonly = true
    sources = [ "speech_recognition_service_factory_unittest.cc" ]
    deps = [
      ":speech",
      "//base",
      "//chrome/test:test_support",
      "//content/test:test_support",
      "//testing/gmock",
      "//testing/gtest",
    ]

    if (is_chromeos) {
      sources += [
        "cros_speech_recognition_service_factory_unittest.cc",
        "cros_speech_recognition_service_unittest.cc",
        "tts_chromeos_unittest.cc",
        "tts_controller_delegate_impl_unittest.cc",
      ]
      deps += [
        ":test_support",
        "//chrome/browser:browser_process",
        "//chrome/common:constants",
        "//chrome/services/speech:lib",
        "//components/soda",
        "//components/soda:test_support",
        "//third_party/blink/public/mojom:mojom_platform",
      ]
    }
  }

  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "speech_recognition_browsertest.cc" ]
    deps = [
      ":speech",
      ":test_support",
      "//base",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/ui",
      "//chrome/test:test_support",
      "//content/test:test_support",
      "//media",
      "//media/mojo/mojom",
      "//mojo/public/cpp/bindings",
      "//testing/gmock",
      "//testing/gtest",
    ]

    if (enable_extensions) {
      deps += [
        "//chrome/browser/extensions",
        "//extensions/browser",
      ]
    }

    if (!is_linux || target_cpu != "arm64") {
      # SODA doesn't support Linux on Arm64.
      if (is_win || is_mac || is_linux) {
        sources += [ "on_device_speech_recognition_impl_browsertest.cc" ]
        deps += [
          "//chrome/browser/browsing_data:constants",
          "//components/live_caption:utils",
          "//components/soda",
        ]
      }
    }

    if (enable_soda_integration_tests) {
      sources += [ "speech_recognition_service_browsertest.cc" ]
      deps += [
        "//chrome/browser:browser_process",
        "//chrome/common:constants",
        "//chrome/services/speech:lib",
        "//chrome/services/speech/soda",
        "//components/metrics",
        "//components/prefs",
        "//components/soda",
        "//components/soda:constants",
        "//sandbox/policy",
        "//services/audio/public/cpp",
        "//services/audio/public/cpp:test_support",
      ]
      if (is_mac) {
        data_deps = [ "//third_party/soda-mac64:soda_resources" ]
      } else if (is_win && target_cpu == "x86") {
        data_deps = [ "//third_party/soda-win32:soda_resources" ]
      } else if (is_win && target_cpu == "x64") {
        data_deps = [ "//third_party/soda-win64:soda_resources" ]
      } else {
        data_deps = [ "//third_party/soda:soda_resources" ]
      }
    }

    if (is_chromeos) {
      sources += [
        "network_speech_recognizer_browsertest.cc",
        "speech_recognition_recognizer_client_impl_browsertest.cc",
      ]
      deps += [
        "//chrome/browser/ui",
        "//components/soda:constants",
        "//components/soda:utils",
      ]
      if (enable_extensions_core) {
        deps += [ "//chromeos/services/tts" ]
      }
    }

    if (enable_extensions_core) {
      sources += [ "extension_api/tts_extension_apitest.cc" ]
      deps += [
        "//chrome/browser/extensions:test_support",
        "//extensions:test_support",
        "//extensions/common",
        "//ui/accessibility",
      ]
    }
  }
}
