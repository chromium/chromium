import("//build/config/ui.gni")
import("//components/offline_pages/buildflags/features.gni")

source_set("bookmarks") {
  public = [
    "bookmark_expanded_state_tracker.h",
    "bookmark_expanded_state_tracker_factory.h",
    "bookmark_html_writer.h",
    "bookmark_merged_surface_ordering_storage.h",
    "bookmark_merged_surface_service.h",
    "bookmark_merged_surface_service_factory.h",
    "bookmark_merged_surface_service_observer.h",
    "bookmark_model_factory.h",
    "bookmark_parent_folder.h",
    "bookmark_parent_folder_children.h",
    "chrome_bookmark_client.h",
    "managed_bookmark_service_factory.h",
    "permanent_folder_ordering_tracker.h",
    "url_and_id.h",
  ]

  public_deps = [
    "//base",
    "//chrome/browser/profiles",
    "//components/bookmarks/browser",
    "//components/keyed_service/core",
    "//components/offline_pages/buildflags",
    "//components/power_bookmarks/core",
    "//url",
  ]
}

source_set("impl") {
  sources = [
    "bookmark_expanded_state_tracker.cc",
    "bookmark_expanded_state_tracker_factory.cc",
    "bookmark_html_writer.cc",
    "bookmark_merged_surface_ordering_storage.cc",
    "bookmark_merged_surface_service.cc",
    "bookmark_merged_surface_service_factory.cc",
    "bookmark_model_factory.cc",
    "bookmark_parent_folder.cc",
    "bookmark_parent_folder_children.cc",
    "chrome_bookmark_client.cc",
    "managed_bookmark_service_factory.cc",
    "permanent_folder_ordering_tracker.cc",
  ]

  public_deps = [ "//chrome/browser:browser_public_dependencies" ]

  deps = [
    ":bookmarks",
    "//chrome/browser:browser_process",
    "//chrome/browser/commerce",
    "//chrome/browser/enterprise/browser_management:management_identity",
    "//chrome/browser/favicon",
    "//chrome/browser/history",
    "//chrome/browser/sync",
    "//chrome/browser/undo",
    "//components/bookmarks/common",
    "//components/bookmarks/managed",
    "//components/commerce/core:feature_list",
    "//components/commerce/core:shopping_service",
    "//components/favicon/core",
    "//components/history/core/browser",
    "//components/policy:generated",
    "//components/pref_registry",
    "//components/prefs",
    "//components/signin/public/base",
    "//components/sync/base",
    "//components/sync_bookmarks",
    "//components/undo",
    "//content/public/browser",
    "//ui/gfx",
  ]

  if (enable_offline_pages) {
    deps += [ "//chrome/browser/offline_pages" ]
  }
}

source_set("test_support") {
  testonly = true

  sources = [
    "bookmark_test_helpers.cc",
    "bookmark_test_helpers.h",
    "bookmark_test_utils.cc",
    "bookmark_test_utils.h",
  ]

  public_deps = [
    ":bookmarks",
    "//components/bookmarks/test",
    "//testing/gmock",
  ]

  deps = [
    "//base",
    "//components/bookmarks/common",
    "//components/bookmarks/managed",
    "//components/sync_preferences:test_support",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "managed_bookmark_service_unittest.cc" ]

  if (!is_android) {
    sources += [
      # Bookmark export/import are handled via the BookmarkColumns
      # ContentProvider.
      "bookmark_html_writer_unittest.cc",
      "bookmark_merged_surface_ordering_storage_unittest.cc",
      "bookmark_merged_surface_service_unittest.cc",
      "bookmark_parent_folder_children_unittest.cc",
      "bookmark_parent_folder_unittest.cc",
      "permanent_folder_ordering_tracker_unittest.cc",
    ]
  }

  if (toolkit_views) {
    sources += [ "bookmark_expanded_state_tracker_unittest.cc" ]
  }

  deps = [
    ":bookmarks",
    ":test_support",
    "//base",
    "//base/test:test_support",
    "//chrome/browser",
    "//chrome/test:test_support",
    "//components/bookmarks/browser",
    "//components/bookmarks/common",
    "//components/bookmarks/managed",
    "//components/bookmarks/test",
    "//components/prefs",
    "//components/signin/public/base",
    "//components/strings",
    "//components/sync/base",
    "//components/sync_preferences:test_support",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base",
    "//url",
  ]

  if (!is_android) {
    deps += [
      "//chrome/browser/favicon",
      "//chrome/browser/history",
      "//chrome/common:constants",
      "//components/favicon/core",
      "//components/favicon_base",
      "//components/history/core/browser",
      "//components/user_data_importer/content",
      "//components/user_data_importer/content:test_support",
      "//skia",
      "//ui/gfx/codec",
    ]
  }
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "encrypted_bookmark_browsertest.cc" ]

  deps = [
    ":bookmarks",
    "//base/test:test_support",
    "//chrome/browser:test_support",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/sync",
    "//chrome/test:test_support",
    "//components/bookmarks/browser",
    "//components/bookmarks/test",
    "//components/sync_bookmarks",
    "//content/test:browsertest_support",
    "//content/test:test_support",
    "//testing/gmock",
  ]
}
