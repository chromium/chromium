import("//chrome/common/features.gni")

source_set("back_to_opener") {
  public = [ "back_to_opener_controller.h" ]

  public_deps = [
    "//base",
    "//content/public/browser",
    "//ui/base/unowned_user_data",
    "//url",
  ]

  deps = [
    "//chrome/browser/ui/tabs",
    "//components/tabs:public",
  ]
}

source_set("impl") {
  sources = [ "back_to_opener_controller.cc" ]

  deps = [
    ":back_to_opener",
    "//chrome/browser/favicon",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/tabs:tab_strip",
    "//ui/base",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "back_to_opener_controller_unittest.cc" ]

  deps = [
    ":back_to_opener",
    ":impl",
    "//chrome/browser/ui",
    "//chrome/browser/ui/tabs:features",
    "//chrome/browser/ui/tabs:test_support",
    "//chrome/test:test_support",
    "//components/tabs:test_support",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "back_to_opener_browsertest.cc" ]
  deps = [
    ":back_to_opener",
    ":impl",
    "//chrome/app:command_ids",
    "//chrome/browser/ui",
    "//chrome/browser/ui/tabs:features",
    "//chrome/test:test_support",
    "//components/tabs:public",
    "//content/test:test_support",
    "//net:test_support",
    "//testing/gtest",
  ]
}
