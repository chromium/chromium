source_set("android_tab_model_impl") {
  # TODO(crbug.com/494284032): Remove once impl is usable.
  testonly = true

  sources = [
    "android_browser_adapter_impl.cc",
    "android_browser_adapter_impl.h",
    "android_tab_model_event_bridge.cc",
    "android_tab_model_event_bridge.h",
    "android_tab_strip_api_injector.cc",
    "android_tab_strip_api_injector.h",
    "android_tab_strip_model_adapter.cc",
    "android_tab_strip_model_adapter.h",
    "android_translation_adapter.cc",
    "android_translation_adapter.h",
  ]

  deps = [
    "//base",
    "//chrome/browser/android:tabs_public",
    "//chrome/browser/favicon",
    "//chrome/browser/ui/android/tab_model",
    "//components/browser_apis/tab_strip:mojom",
    "//components/browser_apis/tab_strip/adapters",
    "//components/browser_apis/tab_strip/types",
    "//components/tabs:public",
    "//mojo/public/mojom/base",
    "//skia",
    "//url",
  ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [
    "android_tab_strip_api_browsertest.cc",
    "android_tab_strip_api_events_browsertest.cc",
    "android_translation_adapter_browsertest.cc",
  ]

  deps = [
    ":android_tab_model_impl",
    "testing",
    "//base",
    "//base/test:test_support",
    "//chrome/browser/ui/tabs/tab_strip_api",
    "//chrome/test:test_support",
    "//components/browser_apis/tab_strip:service",
    "//components/browser_apis/tab_strip/adapters",
    "//components/browser_apis/tab_strip/testing",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
