source_set("tree_builder") {
  sources = [ "mojo_tree_builder.h" ]
  public_deps = [
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/tabs/tab_strip_api:mojom",
    "//chrome/browser/ui/tabs/tab_strip_api:types",
  ]
}

source_set("impl") {
  sources = [ "mojo_tree_builder.cc" ]
  deps = [
    ":tree_builder",
    "//chrome/browser/ui/tabs/tab_strip_api/adapters:adapters",
    "//chrome/browser/ui/tabs/tab_strip_api/converters:converters",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "mojo_tree_builder_unittest.cc" ]

  deps = [
    ":impl",
    ":tree_builder",
    "//base",
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/tabs:test_support",
    "//chrome/browser/ui/tabs/tab_strip_api:mojom",
    "//chrome/browser/ui/tabs/tab_strip_api:tab_strip_api",
    "//chrome/browser/ui/tabs/tab_strip_api:types",
    "//chrome/browser/ui/tabs/tab_strip_api/adapters:adapters",
    "//chrome/browser/ui/tabs/tab_strip_api/adapters:impl",
    "//chrome/test:test_support",
    "//components/tabs:public",
    "//content/public/browser",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
