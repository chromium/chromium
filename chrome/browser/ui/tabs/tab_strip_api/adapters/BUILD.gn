source_set("adapters") {
  sources = [
    "browser_adapter.h",
    "tab_strip_model_adapter.h",
  ]

  public_deps = [
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/tabs",
    "//chrome/browser/ui/tabs:tab_strip_model_observer",
    "//components/browser_apis/tab_strip:mojom",
    "//components/tabs:public",
    "//content/public/browser",
  ]
}

source_set("impl") {
  sources = [
    "browser_adapter_impl.cc",
    "browser_adapter_impl.h",
    "tab_strip_model_adapter_impl.cc",
    "tab_strip_model_adapter_impl.h",
  ]

  deps = [
    ":adapters",
    "tree_builder",
    "//chrome/browser/ui",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/tabs:tab_strip_model_observer",
    "//chrome/browser/ui/tabs/tab_strip_api/converters",
    "//content/public/browser",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "tab_strip_model_adapter_impl_unittest.cc" ]

  deps = [
    ":impl",
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/tabs:test_support",
    "//chrome/browser/ui/tabs/tab_strip_api/converters",
    "//chrome/test:test_support",
    "//testing/gtest",
  ]
}
