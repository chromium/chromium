# This package contains the pure interfaces to adapt a model to the
# service. All integration points should be declared and defined in
# this directory. It should not contain model specific concepts.
#
# If a new idea needs to be expressed, add it to the tab_strip_api's
# 'type' package.
source_set("adapters") {
  sources = [
    "browser_adapter.h",
    "context_menu_adapter.h",
    "experimental_platform_adapters_provider.h",
    "platform_adapters_provider.h",
    "tab_strip_model_adapter.h",
    "translation_adapter.h",
  ]

  public_deps = [
    "//chrome/browser/ui/tabs/tab_strip_api/types",
    "//components/browser_apis/tab_strip:mojom",
    "//components/tabs:public",
  ]
}
