source_set("projects") {
  sources = [
    "projects_panel_state_controller.h",
    "projects_prefs.h",
    "projects_utils.h",
  ]

  public_deps = [
    "//base",
    "//ui/base/unowned_user_data",
  ]
}

source_set("impl") {
  sources = [
    "projects_panel_state_controller.cc",
    "projects_prefs.cc",
    "projects_utils.cc",
  ]

  public_deps = [ ":projects" ]

  deps = [
    "//chrome/app:generated_resources",
    "//chrome/app/vector_icons",
    "//chrome/browser:primitives",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui/actions:actions_headers",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/tabs:features",
    "//chrome/common:constants",
    "//components/pref_registry",
    "//components/prefs",
    "//components/saved_tab_groups/public:features",
    "//ui/views",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "projects_panel_state_controller_unittest.cc" ]
  deps = [
    ":impl",
    "//base/test:test_support",
    "//chrome/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base",
  ]
}

source_set("interactive_ui_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "projects_panel_state_controller_interactive_uitest.cc" ]
  deps = [
    ":impl",
    "//chrome/browser/ui",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui/tabs",
    "//chrome/browser/ui/views/tabs/projects",
    "//chrome/test:test_support",
    "//content/test:test_support",
    "//ui/base",
    "//ui/views",
  ]
}
