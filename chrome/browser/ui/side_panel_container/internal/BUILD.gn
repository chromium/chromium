import("//build/config/android/rules.gni")

android_library("java") {
  visibility = [
    ":*",
    "//chrome/android:chrome_all_java",
  ]

  sources = [
    "android/java/src/org/chromium/chrome/browser/ui/side_panel_container/SidePanelContainerCoordinatorFactory.java",
    "android/java/src/org/chromium/chrome/browser/ui/side_panel_container/SidePanelContainerCoordinatorImpl.java",
  ]

  deps = [
    "//build/android:build_java",
    "//chrome/browser/flags:java",
    "//chrome/browser/ui/side_panel_container/public:java",
    "//chrome/browser/ui/side_ui/public:java",
    "//third_party/androidx:androidx_annotation_annotation_java",
  ]
}

robolectric_library("junit") {
  sources = [ "android/java/src/org/chromium/chrome/browser/ui/side_panel_container/SidePanelContainerCoordinatorImplUnitTest.java" ]
  deps = [
    ":java",
    "//base:base_junit_test_support",
    "//chrome/browser/ui/side_ui/public:java",
    "//third_party/junit",
    "//third_party/mockito:mockito_java",
  ]
}
