import("//build/config/android/rules.gni")
import("//third_party/jni_zero/jni_zero.gni")

# Supports native unit tests.
android_library("native_unit_test_support_java") {
  testonly = true
  sources = [
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidNativeUnitTestSupport.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/WindowScopedSidePanelRegistryBridgeNativeUnitTestSupport.java",
  ]
  deps = [
    "//build/android:build_java",
    "//chrome/browser/ui/side_panel/internal/android:java",
    "//chrome/browser/ui/side_panel_container/public:java",
    "//chrome/test/android:chrome_java_test_support_common",
    "//third_party/jni_zero:jni_zero_java",
    "//third_party/mockito:mockito_java",
  ]
  srcjar_deps = [ ":native_unit_test_support_jni" ]
}

# JNI for native unit tests.
generate_jni("native_unit_test_support_jni") {
  testonly = true
  sources = [
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidNativeUnitTestSupport.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/WindowScopedSidePanelRegistryBridgeNativeUnitTestSupport.java",
  ]
}

# Supports native browser tests.
android_library("browser_test_support_java") {
  testonly = true
  sources = [ "java/src/org/chromium/chrome/browser/ui/side_panel/test/SidePanelCoordinatorAndroidBrowserTestSupport.java" ]
  deps = [
    "//build/android:build_java",
    "//third_party/jni_zero:jni_zero_java",
    "//ui/android:ui_no_recycler_view_java",
  ]
}

# JNI for native browser tests.
generate_jni("browser_test_support_jni") {
  testonly = true
  sources = [ "java/src/org/chromium/chrome/browser/ui/side_panel/test/SidePanelCoordinatorAndroidBrowserTestSupport.java" ]
}

source_set("browser_test_support") {
  testonly = true
  sources = [
    "side_panel_android_browser_test_base.cc",
    "side_panel_android_browser_test_base.h",
  ]
  deps = [
    "//base",
    "//chrome/browser/flags:flags_android",
    "//chrome/browser/tab_list",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/browser_window/test:android_browser_test_support",
    "//chrome/browser/ui/side_panel/android",
    "//chrome/browser/ui/side_panel/test/android:browser_test_support_jni",
    "//chrome/test:test_support_ui_android",
    "//components/tabs:public",
    "//testing/gtest",
  ]
}
