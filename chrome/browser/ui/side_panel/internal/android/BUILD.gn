import("//build/config/android/rules.gni")
import("//third_party/jni_zero/jni_zero.gni")

source_set("android") {
  visibility = [
    ":*",
    "//chrome/browser/ui/side_panel:side_panel_ui_provider",
    "//chrome/browser/ui/side_panel/internal:*",
  ]
  sources = [
    "side_panel_coordinator_android.cc",
    "side_panel_coordinator_android.h",
    "side_panel_tab_list_observer_android.cc",
    "side_panel_tab_list_observer_android.h",
    "window_scoped_side_panel_registry_bridge.cc",
    "window_scoped_side_panel_registry_bridge.h",
  ]

  deps = [
    ":jni_headers",
    "//base",
    "//chrome/browser/android:tabs_public",
    "//chrome/browser/tab_list",
    "//chrome/browser/ui/android/tab_model",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/side_panel",
    "//chrome/browser/ui/side_panel:side_panel_views_dependent",
    "//third_party/jni_zero",
    "//ui/base",
    "//ui/base/unowned_user_data",
  ]
}

android_library("java") {
  visibility = [
    ":*",
    "//chrome/android:chrome_all_java",
    "//chrome/browser/ui/side_panel/test/android:*",
  ]
  sources = [
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidFactory.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidImpl.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelRegistryBridgeFactory.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/WindowScopedSidePanelRegistryBridgeImpl.java",
  ]

  deps = [
    "//base:base_java",
    "//build/android:build_java",
    "//chrome/browser/tab:java",
    "//chrome/browser/ui/browser_window/public/android:java",
    "//chrome/browser/ui/side_panel/android:java",
    "//chrome/browser/ui/side_panel_container/public:java",
    "//components/cached_flags:java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//third_party/jni_zero:jni_zero_java",
  ]

  srcjar_deps = [ ":jni_headers" ]
}

generate_jni("jni_headers") {
  sources = [
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidImpl.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/WindowScopedSidePanelRegistryBridgeImpl.java",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "side_panel_coordinator_android_unittest.cc",
    "window_scoped_side_panel_registry_bridge_unittest.cc",
  ]
  deps = [
    ":android",
    "//base",
    "//chrome/browser/tab_list:test_support",
    "//chrome/browser/ui:test_support",
    "//chrome/browser/ui/side_panel:side_panel_ui_provider",
    "//chrome/browser/ui/side_panel:side_panel_views_dependent",
    "//chrome/browser/ui/side_panel/test/android:native_unit_test_support_jni",
    "//components/tabs:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [
    "side_panel_coordinator_android_browsertest.cc",
    "side_panel_registry_android_browsertest.cc",
  ]
  deps = [
    ":android",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/side_panel",
    "//chrome/browser/ui/side_panel:side_panel_ui_provider",
    "//chrome/browser/ui/side_panel:side_panel_views_dependent",
    "//chrome/browser/ui/side_panel/android",
    "//chrome/browser/ui/side_panel/test/android:browser_test_support",
    "//chrome/browser/ui/side_panel/test/android:browser_test_support_jni",
    "//components/tabs:public",
    "//content/test:test_support",
    "//testing/gtest",
    "//ui/android",
    "//ui/base",
  ]
}
