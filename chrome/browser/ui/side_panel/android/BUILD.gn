import("//build/config/android/rules.gni")
import("//chrome/android/features/android_library_factory_tmpl.gni")
import("//third_party/jni_zero/jni_zero.gni")

# Public C++ classes
source_set("android") {
  sources = [
    "android_side_panel_enabled_fn.cc",
    "android_side_panel_enabled_fn.h",
    "side_panel_native_view_android.cc",
    "side_panel_native_view_android.h",
  ]

  deps = [
    ":jni_headers",
    "//base",
    "//third_party/jni_zero",
    "//ui/base",
  ]
}

# Public Java interfaces
android_library("java") {
  sources = [
    "java/src/org/chromium/chrome/browser/ui/side_panel/AndroidSidePanelEnabledFn.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroid.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelUtils.java",
    "java/src/org/chromium/chrome/browser/ui/side_panel/WindowScopedSidePanelRegistryBridge.java",
  ]
  deps = [
    "//base:base_java",
    "//build/android:build_java",
    "//chrome/browser/flags:java",
    "//chrome/browser/ui/browser_window/public/android:java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//third_party/jni_zero:jni_zero_java",
  ]
  srcjar_deps = [
    ":jni_headers",
    ":side_panel_enums_java",
  ]
}

# Public Java factory
android_library_factory("factory_java") {
  sources = [
    "//chrome/browser/ui/side_panel/internal/android/java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidFactory.java",
    "//chrome/browser/ui/side_panel/internal/android/java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelRegistryBridgeFactory.java",
  ]
  deps = [
    ":java",
    "//chrome/browser/tab:java",
    "//chrome/browser/ui/side_panel_container/public:java",
  ]
}

generate_jni("jni_headers") {
  visibility = [ ":*" ]
  sources = [ "java/src/org/chromium/chrome/browser/ui/side_panel/AndroidSidePanelEnabledFn.java" ]
}

java_cpp_enum("side_panel_enums_java") {
  sources = [ "//chrome/browser/ui/side_panel/side_panel_enums.h" ]
}
