import("//build/config/android/rules.gni")
import("//chrome/android/features/android_library_factory_tmpl.gni")

# Public C++ classes
source_set("android") {
  sources = [
    "side_panel_native_view_android.cc",
    "side_panel_native_view_android.h",
  ]

  deps = [
    "//base",
    "//third_party/jni_zero",
    "//ui/base",
  ]
}

# Public Java interfaces
android_library("java") {
  sources = [ "java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroid.java" ]
  deps = [ "//build/android:build_java" ]
}

# Public Java factory
android_library_factory("factory_java") {
  sources = [ "//chrome/browser/ui/side_panel/internal/android/java/src/org/chromium/chrome/browser/ui/side_panel/SidePanelCoordinatorAndroidFactory.java" ]
  deps = [ ":java" ]
}
