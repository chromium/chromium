import("//build/config/android/rules.gni")

android_library("java") {
  visibility = [
    ":*",
    "//chrome/android:chrome_all_java",
  ]

  sources = [
    "android/java/src/org/chromium/chrome/browser/ui/side_ui/SideUiContainerTransition.java",
    "android/java/src/org/chromium/chrome/browser/ui/side_ui/SideUiCoordinatorFactory.java",
    "android/java/src/org/chromium/chrome/browser/ui/side_ui/SideUiCoordinatorImpl.java",
  ]

  deps = [
    "//base:callback_java",
    "//base:supplier_java",
    "//base:tasks_java",
    "//build/android:build_java",
    "//chrome/browser/flags:java",
    "//chrome/browser/ui/side_panel/android:java",
    "//chrome/browser/ui/side_ui/public:java",
    "//components/cached_flags:java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//ui/android:ui_no_recycler_view_java",
  ]
}

robolectric_library("junit") {
  testonly = true
  resources_package = "org.chromium.chrome.browser.ui.side_ui"
  sources = [ "android/java/src/org/chromium/chrome/browser/ui/side_ui/SideUiCoordinatorImplTest.java" ]
  deps = [
    ":java",
    "//base:base_java",
    "//base:base_java_test_support",
    "//base:base_junit_test_support",
    "//chrome/browser/ui/side_ui/public:java",
    "//chrome/browser/ui/side_ui/public:java_resources",
    "//chrome/browser/ui/side_ui/test/android:test_support_java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//third_party/junit",
    "//third_party/mockito:mockito_java",
  ]
}
