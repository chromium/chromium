<translation id="766587987807204883">ОЏОљОЪ ОЎОЋОдОњОЋ ОъОљОъОеОЎОЮ, ОЋОљОцОЕОе ОюОДОеОЋОљ ОљОЋОфОЮ ОњОЮ ОЉОъОдОЉ ОљОЋОаОюОЎОЎОЪ</translation>
<translation id="768232549260819724">РђЈОћ-GIF ОћОЋОбОфОД</translation>
<translation id="7682724950699840886">ОљОцОЕОе ОюОаОАОЋОф ОљОф ОћОўОЎОцОЎОЮ ОћОЉОљОЎОЮ: ОдОеОЎОџ ОюОЋОЋОЊОљ ОЕОЎОЕ ОъОАОцОЎОД ОъОДОЋОЮ ОцОаОЋОЎ ОЉОъОЏОЕОЎОе ОЋОљОќ ОюОаОАОЋОф ОюОЎОЎОдОљ ОЕОЋОЉ.</translation>
<translation id="7686086654630106285">ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОдОбОЋОф ОюОъОЋОЊОбОЋОф ОЉОљОфОеОЎОЮ</translation>
<translation id="768618399695552958">РђЈОЌОюОД ОъОћОЊОцОЎОЮ ОЕОљОюОЎОћОЮ ОбОЋОЉОеОЎОЮ ОаОўОбОаОЎОЮ ОъОеОљОЕ. ОЊОцОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЎОўОбОЪ ОъОеОљОЕ ОЉОљОъОдОбОЋОф ОЕОеОфОЎ Google ОЏОЕОЎОЕ ОљОюОЎОћОЮ ОДОЎОЕОЋОеОЎОЮ ОъОљОфОе ОЕОаОЋОдОе ОЉОљОъОдОбОЋОф Google Sites.</translation>
<translation id="7690596512217303514">РђЈОюОљ ОаОЎОфОЪ ОюОцОфОЋОЌ ОљОф Chrome ОЉОъОЏОЕОЎОе. ОЏОЊОЎ ОюОцОфОЋОе ОљОф ОћОЉОбОЎОћ, ОбОюОЎОџ ОюОћОЋОеОЎОЊ ОљОф ОћОбОЊОЏОЋОЪ ОћОљОЌОеОЋОЪ ОЕОю Chrome ОъОЌОаОЋОф ОћОљОцОюОЎОДОдОЎОЋОф.</translation>
<translation id="7691043218961417207">ОљОцОЕОеОЋОЎОЋОф ОюОфОЋОЏОЪ ОюОъОбОДОЉ</translation>
<translation id="7697383401610880082">ОаОДОЋОЊОф ОљОЌОЎОќОћ ОюОњОеОЎОеОћ</translation>
<translation id="7698359219371678927">ОЎОдОЎОеОф ОћОЋОЊОбОф ОљОЎОъОЎОЎОю ОЉ-<ph name="APP_NAME" /></translation>
<translation id="7702388902581909985">РђЈОъОЌОЎОДОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОюОљ ОъОЋОЉОЎОюОћ ОюОЎОдОЎОљОћ ОъОЌОЕОЉОЋОЪ Google. ОЏОЊОЎ ОюОбОЕОЋОф ОќОљОф, <ph name="BEGIN_LINK1" />ОдОеОЎОџ ОюОдОљОф Оъ-Chrome<ph name="END_LINK1" />.</translation>
<translation id="7707922173985738739">ОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="7709918231054955894">ОћОдОњОф ОЏОю ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="7725024127233776428">ОћОЊОцОЎОЮ ОЕОћОЋОАОцОф ОюОАОЎОъОаОЎОЋОф ОъОЋОцОЎОбОЎОЮ ОЏОљОЪ</translation>
<translation id="7733878270780732638">ОљОЎОЪ ОъОАОцОЎОД ОаОцОЌ ОљОЌОАОЋОЪ ОцОаОЋОЎ ОЉОъОЏОЕОЎОе.</translation>
<translation id="7757787379047923882">ОћОўОДОАОў ОЕОЋОфОБ ОЊОеОџ <ph name="DEVICE_NAME" /></translation>
<translation id="7759809451544302770">ОљОЋОцОдОЎОЋОаОюОЎ</translation>
<translation id="7762668264895820836">РђЈОЏОеОўОЎОА SD <ph name="SD_CARD_NUMBER" /></translation>
<translation id="7764225426217299476">ОћОЋОАОцОф ОЏОфОЋОЉОф</translation>
<translation id="7766587497031415281">ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф ОюОъОЌОЎОДОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ</translation>
<translation id="7772032839648071052">ОљОЎОЕОЋОе ОъОЕОцОў-ОАОЎОАОъОћ</translation>
<translation id="7772375229873196092">ОАОњОЎОеОф <ph name="APP_NAME" /></translation>
<translation id="7774809984919390718">{PAYMENT_METHOD,plural, =1{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОБ}one{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОцОЎОЮ}two{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОцОЎОЮ}other{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОцОЎОЮ}}</translation>
<translation id="777637629667389858">РђЈОљОЌОеОЎ ОЕОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ, ОћОъОбОеОЏОф ОъОњОЎОаОћ ОбОюОЎОџ ОЉОЕОЎОеОЋОфОЎ Google.</translation>
<translation id="7778840695157240389">ОЉОћОъОЕОџ ОЎОћОЎОЋ ОцОћ ОАОЎОцОЋОеОЎОЮ ОЌОЊОЕОЎОЮ</translation>
<translation id="7780645209293383778">РђЈОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОЉОљОцОюОЎОДОдОЎОЋОф ОЕОю Google, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОъОДОЋОЕОеОЎОЮ ОЉОљОЋОцОЪ ОќОъОаОЎ ОюОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОћОћОњОаОћ ОћОќОЋ ОцОбОЎОюОћ ОеОД ОљОЮ ОаОЏОаОАОЎОЮ ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="7791543448312431591">ОћОЋОАОцОћ</translation>
<translation id="7798392620021911922">ОЕОЋОЌОќОеОЋ <ph name="TAB_COUNT" /> ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="780301667611848630">ОюОљ ОфОЋОЊОћ</translation>
<translation id="7808889146555843082">ОъОЌОЎОДОф ОћОАОЎОАОъОћ ОћОќОЋ ОюОљ ОфОњОеОЋОЮ ОюОъОЌОЎОДОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉОљОфОе <ph name="SITE" />. ОЏОЊОЎ ОюОъОаОЋОб ОљОф ОћОЌОЕОЎОцОћ ОЕОю ОћОАОЎОАОъОћ, ОЏОЊОљОЎ ОюОЕОаОЋОф ОљОЋОфОћ ОљОЋ ОюОъОЌОЋОД ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-<ph name="SITE" />.</translation>
<translation id="7810647596859435254">ОцОфОЎОЌОћ ОЉОљОъОдОбОЋОф...</translation>
<translation id="7815484226266492798">ОдОЎОюОЋОЮ ОъОАОџ ОљОеОЋОџ</translation>
<translation id="7822705602465980873">РђЈОљОЌОеОЎ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОъОДОЋОЕОеОЎОЮ ОюОЌОЕОЉОЋОЪ Google ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОЉОЕОЎОеОЋОфОЎ Google. ОюОЊОЋОњОъОћ, ОЉОъОДОеОћ ОЕОю ОљОЎОеОЋОб ОљОЉОўОЌОћ, ОћОћОњОаОћ ОЉ-Gmail ОъОЋОњОЉОеОф.</translation>
<translation id="782705168687182233">РђЈОћОцОбОЎОюОЋОф ОаОЕОъОеОф ОЉ<ph name="BEGIN_LINK" />ОЌОЕОЉОЋОЪ Google<ph name="END_LINK" /> ОЕОюОџ.</translation>
<translation id="78270725016672455">ОћОфОДОЉОюОћ ОъОћОъОЌОЕОЉ ОЉОДОЕОћ ОюОеОЕОЋОЮ ОљОф ОћОъОЏОЕОЎОе ОћОќОћ ОюОдОЋОеОџ ОЏОаОЎОАОћ ОюОљОфОе</translation>
<translation id="7844171778363018843">ОљОЎОЪ ОаОфОЋОаОЎОЮ ОЕОаОЉОЌОеОЋ ОюОАОаОЏОеОЋОЪ</translation>
<translation id="7846296061357476882">РђЈОЕОЎОеОЋОфОЎ Google</translation>
<translation id="784934925303690534">ОўОЋОЋОЌ ОќОъОЪ</translation>
<translation id="7851858861565204677">ОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="7853202427316060426">ОцОбОЎОюОЋОф</translation>
<translation id="7859988229622350291">ОљОЎОЪ ОюОфОеОњОЮ ОљОБ ОцОбОЮ</translation>
<translation id="7864208933699511058">РђЈОЉОъОћОюОџ ОћОњОюОЎОЕОћ, ОЎОЋОдОњОЋ ОъОЋОЊОбОЋОф ОбОЮ ОљОЋ ОЉОюОЎ ОћОфОљОъОћ ОљОЎОЕОЎОф ОЉОћОфОљОЮ ОюОћОњОЊОеОћ ОћОќОЋ, Ою<ph name="BEGIN_LINK_1" />ОћОдОбОЋОф ОюОъОЋОЊОбОЋОф ОъОљОфОеОЎОЮ<ph name="END_LINK_1" />, Ою<ph name="BEGIN_LINK_2" />ОћОњОЊОеОЋОф ОДОЋОЉОдОЎ Оћ-cookie<ph name="END_LINK_2" /> ОЋОюОъОдОЉ ОћОћОфОљОъОћ ОћОљОЎОЕОЎОф ОЕОю ОъОЋОЊОбОЋОф ОЉОљОфОе (ОцОбОЎОюОћ ОљОЋ ОъОЋОЕОЉОфОф).</translation>
<translation id="7866213166286285359">ОфОеОњОЋОЮ ОћОЊОцОЎОЮ ОЕОЏОљОЪ</translation>
<translation id="78707286264420418">Ою-<ph name="PRODUCT_NAME" /> ОаОЊОеОЕОф 'ОћОеОЕОљОф ОъОЏОЕОЎОеОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ' ОЏОЊОЎ ОюОћОфОЌОЉОе ОюОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="7875915731392087153">ОћОЋОЊОбОф ОљОЎОъОЎОЎОю ОЌОЊОЕОћ</translation>
<translation id="7876243839304621966">ОћОАОеОф ОћОЏОЋОю</translation>
<translation id="7886917304091689118">РђЈОцОЋОбОю ОЉ-Chrome</translation>
<translation id="7887174313503389866">ОАОЎОЋОе ОъОЋОЊОеОџ ОЉОљОъОдОбОЎ ОћОЉОДОеОћ ОћОЌОЕОЋОЉОЎОЮ ОЉОЎОЋОфОе ОбОю ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ. ОюОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф, ОЎОЕ ОюОбОЉОЋОе ОюОћОњОЊОеОЋОф ОАОцОдОЎОцОЎОЋОф.</translation>
<translation id="7896724475402191389">ОфОЋОЏОЪ ОюОЎОюОЊОЎОЮ РђЊ ОъОЋОЕОЉОф</translation>
<translation id="7903184275147100332">ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОЏОъОћ ОеОњОбОЎОЮ</translation>
<translation id="7914399737746719723">ОћОљОцОюОЎОДОдОЎОћ ОћОЋОфОДОаОћ</translation>
<translation id="7919123827536834358">ОфОеОњОЋОЮ ОљОЋОўОЋОъОўОЎ ОЕОю ОЕОцОЋОф ОљОюОћ</translation>
<translation id="7926975587469166629">ОЏОЎОаОЋОЎ ОћОЏОеОўОЎОА</translation>
<translation id="7929962904089429003">ОцОфОЎОЌОф ОћОфОцОеОЎОў</translation>
<translation id="7930998711684428189">ОћОдОњОф ОљОќОћОеОћ ОљОЮ ОАОЎОАОъОљОЋОф ОаОЌОЕОцОЋОф ОбОДОЉ ОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб.</translation>
<translation id="7934668619883965330">ОюОљ ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОф ОћОДОЋОЉОЦ. ОцОЋОеОъОў ОћОДОЋОЉОЦ ОюОљ ОаОфОъОџ.</translation>
<translation id="7939485076072265087">ОЎОдОЎОеОф ОЏОеОўОЎОА ОъОбОЋОдОЉ ОбОЮ ОћОЊОњОЕОћ</translation>
<translation id="7942131818088350342"><ph name="PRODUCT_NAME" /> ОљОЎОаОЋ ОъОбОЋОЊОЏОЪ.</translation>
<translation id="7944772052836377867">ОЏОЊОЎ ОюОАОаОЏОеОЪ ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="7947953824732555851">ОДОЉОюОћ ОЋОЏОаОЎОАОћ</translation>
<translation id="7957413488482743710">ОЏОеОўОЎОА ОЋОЎОеОўОЋОљОюОЎ ОъОАОфОЎОе ОљОф ОћОЏОеОўОЎОА ОЕОюОџ ОЉОцОЋОбОю ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОъОцОаОЎ ОфОеОъОЎОЋОф ОцОЋОўОаОдОЎОљОюОЎОЋОф. <ph name="BEGIN_LINK1" />ОЏОљОЪ ОъОцОЋОеОў ОъОЎОЊОб ОаОЋОАОБ ОбОю ОЏОеОўОЎОАОЎОЮ ОЋОЎОеОўОЋОљОюОЎОЎОЮ<ph name="END_LINK1" /></translation>
<translation id="7960972236129063347">ОюОЌОдОЪ 'ОћОДОЋОЊОЮ' ОЉОфОЋОЉОаОЋОф ОюОњОЉОЎ ОћОЊОБ</translation>
<translation id="7961926449547174351">ОћОЕОЉОфОф ОљОф ОћОњОЎОЕОћ ОюОљОЌОАОЋОЪ. ОЏОЊОЎ ОюОћОцОбОЎОю ОљОЋОфОћ, ОЎОЕ ОюОбОЉОЋОе ОюОћОњОЊОеОЋОф.</translation>
<translation id="7963646190083259054">ОАОцОД:</translation>
<translation id="7965838025086216108">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЉОЏОю ОъОЏОЕОЎОе. ОћОЪ ОаОЕОъОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОюОЌОЕОЉОЋОЪ <ph name="ACCOUNT" />.</translation>
<translation id="7968014550143838305">ОаОЋОАОБ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ</translation>
<translation id="7971136598759319605">ОцОбОЎОюОЋОф ОљОЌОеОЋОаОћ: ОюОцОаОЎ ОЎОЋОЮ ОљОЌОЊ</translation>
<translation id="7975379999046275268">ОћОдОњОф ОћОЊОБ ОЉОфОдОЋОњОћ ОъОДОЊОЎОъОћ<ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="7977451675950311423">ОъОДОЉОюОЎОЮ ОљОќОћОеОћ ОљОЮ ОъОЕОфОъОЕОЎОЮ ОЉОАОЎОАОъОћ ОЕОаОЌОЕОцОћ ОЉОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб.</translation>
<translation id="7986497153528221272">ОЏОЊОЎ ОюОћОдОЎОњ ОАОЎОАОъОљОЋОф, ОфОЌОЎОюОћ ОЎОЕ ОюОћОњОЊОЎОе ОаОбОЎОюОф ОъОАОџ ОЉОъОЏОЕОЎОе</translation>
<translation id="7995059495660416932">ОфОЋОЏОЪ ОЎОЋОдОњ ОюОџ ОЉОеОњОб ОЕОЎОћОЎОћ ОќОъОЎОЪ</translation>
<translation id="799576009106109668">ОъОћОЎОеОЋОф ОћОњОюОЎОЕОћ ОфОњОЉОе ОЏОЎ ОћОфОЋОЏОЪ ОЎОЎОўОбОЪ ОЉОљОЋОцОЪ ОЎОќОЋОЮ, ОбОю ОАОъОџ ОћОЉОЎОДОЋОе ОћОаОЋОЏОЌОЎ ОЕОюОџ ОЉОЊОБ ОћОљОЎОаОўОеОаОў</translation>
<translation id="8004582292198964060">ОЊОцОЊОцОЪ</translation>
<translation id="8013372441983637696">РђЈОЎОЕ ОюОаОДОЋОф ОњОЮ ОљОф ОаОфОЋОаОЎ Chrome ОъОћОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="8015452622527143194">ОЏОю ОъОћ ОЕОъОЋОцОЎОб ОЉОЊОБ ОЎОЕОфОаОћ ОюОњОЋОЊОю ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="8026334261755873520">ОаОЎОДОЋОЎ ОаОфОЋОаОЎ ОњОюОЎОЕОћ</translation>
<translation id="8027863900915310177">ОЉОЌОЎОеОф ОћОъОЎОДОЋОЮ ОюОћОЋОеОЊОћ</translation>
<translation id="8030852056903932865">ОљОЎОЕОЋОе</translation>
<translation id="8032569120109842252">ОЉОъОбОДОЉ</translation>
<translation id="8035133914807600019">ОфОЎОДОЎОЎОћ ОЌОЊОЕОћРђд</translation>
<translation id="8037750541064988519">ОаОЋОфОеОЋ <ph name="DAYS" /> ОЎОъОЎОЮ</translation>
<translation id="8037801708772278989">ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОбОЏОЕОЎОЋ</translation>
<translation id="804335162455518893">РђЈОюОљ ОаОъОдОљ ОЏОеОўОЎОА SD</translation>
<translation id="8048533522416101084">{TAB_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />) ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}one{<ph name="TAB_COUNT_NORMAL" /> ОЏОеОўОЎОАОЎОЋОф ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}two{<ph name="TAB_COUNT_NORMAL" /> ОЏОеОўОЎОАОЎОЋОф ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}other{<ph name="TAB_COUNT_NORMAL" /> ОЏОеОўОЎОАОЎОЋОф ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}}</translation>
<translation id="8051695050440594747">РђЈРђј<ph name="MEGABYTES" />MB ОќОъОЎОаОЎОЮ</translation>
<translation id="8058655154417507695">ОЕОаОф ОфОцОЋОњОћ</translation>
<translation id="8058746566562539958">РђЈОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЕОю Chrome</translation>
<translation id="8062594758852531064">ОўОбОЎОаОћ ОъОЋОеОЌОЉОф ОъОеОљОЕ:</translation>
<translation id="8063895661287329888">ОћОЋОАОцОф ОћОАОЎОъОаОЎОЎОћ ОаОЏОЕОюОћ.</translation>
<translation id="8066816452984416180">ОћОЋОАОцОћ ОъОћОЎОеОћ ОЕОю ОћОЊОБ ОћОќОћ ОюОАОЎОъОаОЎОЋОф. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="806745655614357130">ОЕОъОЎОеОф ОћОаОфОЋОаОЎОЮ ОЕОюОЎ ОЉОаОцОеОЊ</translation>
<translation id="8073388330009372546">ОцОфОЎОЌОф ОћОфОъОЋОаОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="8076492880354921740">ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="8078096376109663956">ОЎОЕ ОюОЕОфОБ ОўОДОАОў ОЉОюОЉОЊ</translation>
<translation id="8084114998886531721">ОАОЎОАОъОћ ОЕОъОЋОеОћ</translation>
<translation id="8084285576995584326">РђЈОЕОюОЎОўОћ ОЉОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="808747664143081553">ОћОўОюОцОЋОЪ ОъОЌОЋОЉОе ОюОъОЌОЕОЉ</translation>
<translation id="8088176524274673045">РђЈОЏОЊОЎ ОюОЕОфОБ ОбОЮ ОљОаОЕОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ, ОћОЮ ОдОеОЎОЏОЎОЮ ОюОАОеОЋОД ОљОф ОДОЋОЊ Оћ-QR ОћОќОћ</translation>
<translation id="8090732854597034573">ОљОЮ ОдОеОЎОџ ОбОќОеОћ, ОљОцОЕОе ОюОЉОДОЕ ОбОќОеОћ ОъОћОЋОеОћ</translation>
<translation id="8100969750121413114">РђЈОЏОЊОЎ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chrome, ОбОюОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ</translation>
<translation id="8101414242770404289">ОюОљ ОЎОАОњОеОЋ ОЏОеОўОЎОАОЎОЋОф ОЉОъОАОњОеОф <ph name="TIME_PERIOD" /></translation>
<translation id="8103578431304235997">ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="8105613260829665809">РђЈОюОЌОЎОдОћ ОбОю ОћОъОЕОџ ОфОфОцОеОЕ ОЏОћОАОЏОъОфОџ <ph name="BEGIN_TOS_LINK" />ОюОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф<ph name="END_TOS_LINK" />.\nОЏОЊОЎ ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОћОљОцОюОЎОДОдОЎОћ, Chrome ОЎОЕОюОЌ ОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЋОДОеОЎОАОЋОф ОљОю Google. <ph name="BEGIN_UMA_LINK" />ОаОЎОћОЋОю<ph name="END_UMA_LINK" /></translation>
<translation id="8105893657415066307"><ph name="DESCRIPTION" /> <ph name="SEPARATOR" /> <ph name="FILE_SIZE" /></translation>
<translation id="8107530384992929318">ОАОњОЎОеОћ ОЕОю ОљОцОЕОеОЋОЎОЋОф ОћОъОЎОЋОЪ</translation>
<translation id="8110024788458304985">РђЈОбОќОеОћ ОЉОЕОЎОцОЋОе ОћОфОЏОЋОаОЋОф ОЋОћОЉОЎОдОЋОбОЎОЮ ОЕОю Chrome</translation>
<translation id="8110087112193408731">РђЈОюОћОдОЎОњ ОљОф ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉ-Chrome ОЉ'ОЕОЎОъОЋОЕ ОЌОЏОЮ ОЉОЊОЎОњОЎОўОю'?</translation>
<translation id="8118117428362942925">ОљОЮ ОдОеОЎОџ ОбОќОеОћ, ОљОцОЕОе ОюОЉОДОЕ ОбОќОеОћ ОъОћОЋОеОћ (<ph name="PARENT_NAME" />)</translation>
<translation id="8122623268651408616">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОюОцОЎ ОћОцОеОЎОў ОћОЌОЊОЕ ОЉОЎОЋОфОе</translation>
<translation id="8127542551745560481">ОбОеОЎОЏОф ОЊОБ ОћОЉОЎОф</translation>
<translation id="8130309322784422030">ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОцОеОўОЎОЮ ОЕОаОЕОъОеОЋ ОюОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ ОюОљ ОбОЊОЏОаОЎОЎОЮ</translation>
<translation id="813082847718468539">ОћОдОњОф ОаОфОЋОаОЎ ОљОфОе</translation>
<translation id="8137562778192957619">РђЈОљОЎОЪ ОдОЋОеОџ ОюОќОЏОЋОе ОљОф ОћОАОЎОАОъОћ ОћОќОЋ. ОћОЎОљ ОфОЎОЕОъОе ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google.</translation>
<translation id="8186512483418048923">ОаОЋОфОеОЋ ОбОЋОЊ <ph name="FILES" /> ОДОЉОдОЎОЮ</translation>
<translation id="8190358571722158785">ОаОЋОфОе ОЎОЋОЮ ОљОЌОЊ</translation>
<translation id="8193953846147532858"><ph name="BEGIN_LINK" />ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ<ph name="END_LINK" /> ┬и <ph name="EMAIL" /></translation>
<translation id="8200772114523450471">ОЌОЎОЊОЋОЕ</translation>
<translation id="8209050860603202033">ОцОфОЎОЌОф ОћОфОъОЋОаОћ</translation>
<translation id="8210770465353466621">ОћОЏОеОўОЎОАОЎОЋОф ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="8215740705341534369">ОњОЎОюОЎОЋОЪ ОдОЊ</translation>
<translation id="8218622182176210845">ОаОЎОћОЋОю ОћОЌОЕОЉОЋОЪ</translation>
<translation id="8221401890884589479">РђЈОљОцОЕОе ОюОЌОАОЋОЮ ОљОфОеОЎОЮ ОЕОюОљ ОеОЋОдОЎОЮ ОюОфОф ОюОћОЮ ОћОеОЕОљОћ. ОЉОаОЋОАОБ, ОљОфОеОЎОЮ ОЕОаОЋОАОцОЋ ОюОцОаОЎ ОЎОЋОфОе Оъ-30 ОЎОЋОЮ ОаОъОЌОДОЎОЮ ОъОћОеОЕОЎОъОћ ОЉ-Chrome ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="8223642481677794647">ОфОцОеОЎОў ОЏОеОўОЎОА ОћОцОЎОЊ</translation>
<translation id="8236097722223016103">ОћОЋОАОцОћ ОюОАОЎОъОаОЎОЋОф</translation>
<translation id="8237871086242677046">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОћОфОЋОЉОаОЋОф ОюОњОЉОЎ ОћОЊОБ</translation>
<translation id="8243077599929149377">ОћОЋОАОцОћ ОЕОю ОЕОЮ ОћОъОЕОфОъОЕ</translation>
<translation id="8250920743982581267">ОъОАОъОЏОЎОЮ</translation>
<translation id="8255617931166444521">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ Оћ-cookie ОеОД ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ ОЕОъОфОЉОдОбОф ОЉОћОЮ ОЉОюОЉОЊ, ОЋОюОљ ОЉОљОфОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="8259179246279078674">РђЈОъОцОаОЎ ОЕОћОЊОцОЎОЮ ОЕОаОўОбОаОЎОЮ ОъОеОљОЕ ОъОЋОдОцОаОЎОЮ, Google ОюОљ ОфОДОЉОю ОъОЎОЊОб ОбОю ОфОЋОЏОЪ ОћОЊОБ ОЕОаОўОбОЪ ОъОеОљОЕ. ОЕОеОфОЎ Google ОЎОњОюОЋ ОљОЎОюОЋ ОљОфОеОЎОЮ ОаОўОбОаОЎОЮ ОъОеОљОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ. ОћОъОЎОЊОб ОћОќОћ ОъОЕОъОЕ ОеОД ОюОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОћОЊОцОЎОЮ ОЋОћОЋОљ ОюОљ ОъОДОЋОЕОе ОюОъОЎОЊОб ОљОЌОе ОъОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="8260126382462817229">ОЎОЕ ОюОћОЎОЏОаОА ОЕОЋОЉ</translation>
<translation id="8261506727792406068">ОъОЌОЎОДОћ</translation>
<translation id="82619448491672958">ОћОдОњОф ОЏОеОўОЎОАОЎОЋОф ОљОЌОеОЋОф</translation>
<translation id="8266862848225348053">ОъОЎОДОЋОЮ ОћОћОЋОеОЊОћ</translation>
<translation id="8281886186245836920">ОЊОЎОюОЋОњ</translation>
<translation id="8282297628636750033">ОћОЌОюОф ОбОЎОдОЋОЉ ОЏОћОћ ОбОю ОљОфОеОЎОЮ, ОЏОЕОљОцОЕОе</translation>
<translation id="829672787777123339">ОъОфОЉОдОб ОЌОЎОЉОЋОе ОюОъОЏОЕОЎОеРђд</translation>
<translation id="8310344678080805313">ОЏОеОўОЎОАОЎОЋОф ОеОњОЎОюОЋОф</translation>
<translation id="831192587911042850">ОћОЋОАОцОф ОљОфОе ОћОљОЎОаОўОеОаОў ОЕОцОфОЋОЌ ОЏОеОњОб ОюОеОЕОЎОъОф ОљОфОеОЎ ОћОљОЎОаОўОеОаОў ОЕОЉОъОбОДОЉ.</translation>
<translation id="8333340769932050274">РђЈОаОЎОфОЪ ОюОЌОАОЋОЮ ОаОЋОЕОљОЎОЮ ОЏОЊОЎ ОЕОюОљ ОЎОЕОЋОфОцОЋ ОбОЮ ОљОфОеОЎОЮ. ОЉОаОЋОАОБ, Chrome ОъОЋОЌОД ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОаОЋОЕОљОЎОЮ ОЕОаОЋОАОцОЋ ОюОцОаОЎ ОЎОЋОфОе Оъ-4 ОЕОЉОЋОбОЋОф. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="834313815369870491">ОљОЎОЪ ОюОфОеОњОЮ ОљОф ОћОљОфОеОЎОЮ ОљОБ ОцОбОЮ</translation>
<translation id="8349795646647783032">РђЈ<ph name="BEGIN_BOLD" />ОљОЎОџ ОљОаОЌОаОЋ ОъОЕОфОъОЕОЎОЮ ОЉОаОфОЋОаОЎОЮ ОћОљОюОћ:<ph name="END_BOLD" /> ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЕОъОЋОе ОъОЎОЊОб ОЉ-Chrome ОюОњОЉОЎ ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ. ОюОЊОЋОњОъОћ, ОљОЮ ОЉОЎОДОеОф ОЉОљОфОе ОЏОЊОЎ ОюОДОаОЋОф ОаОбОюОЎОЎОЮ ОюОъОеОфОЋОЪ, ОћОљОфОе ОбОЕОЋОЎ ОюОћОњОЊОЎОе 'ОеОЎОдОф ОъОеОфОЋОЪ' ОЏОфОЌОЋОЮ ОбОаОЎОЎОЪ ОЕОюОџ. ОюОљОЌОе ОъОЏОЪ, ОЉОЉОЎОДОЋОе ОЉОљОфОе ОЕОЋОаОћ, ОюОъОЕОю ОЏОЊОЎ ОюОћОЎОеОЕОЮ ОюОъОеОЋОЦ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОЋОдОњ ОюОџ ОъОЋОЊОбОћ ОюОаОбОюОЎ ОеОЎОдОћ ОбОю ОАОъОџ ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ.</translation>
<translation id="8354977102499939946">ОЌОЎОцОЋОЕ ОъОћОЎОе ОЉОљОъОдОбОЋОф ОћОДОЋОю. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="835847953965672673">ОЕОЋОЌОќОеОЋ <ph name="NUMBER_OF_DOWNLOADS" /> ОћОЋОеОЊОЋОф</translation>
<translation id="8368001212524806591">ОъОбОДОЉ ОљОЌОе ОћОъОЌОЎОе</translation>
<translation id="8383226135083126309">РђЈ<ph name="BEGIN_BOLD" />ОљОЎОџ ОљОаОЌОаОЋ ОъОЕОфОъОЕОЎОЮ ОЉОаОфОЋОаОЎОЮ ОћОљОюОћ:<ph name="END_BOLD" /> Chrome ОЎОЏОЋОю ОюОћОбОеОЎОџ ОъОћОЮ ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ. ОюОљОЌОе ОъОЏОЪ, ОљОфОе ОЕОЉОЋ ОЉОЎОДОеОф ОЎОЏОЋОю ОюОЕОюОЋОЌ ОЉОДОЕОћ Ою-Chrome ОЏОЊОЎ ОюОњОюОЋОф ОъОћОЮ ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ ОЋОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОъОЋОЊОбОЋОф ОЕОъОЋОдОњОЋОф ОюОџ.</translation>
<translation id="8387617938027387193">ОљОЎОъОЋОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="8393700583063109961">ОЕОюОЎОЌОф ОћОЋОЊОбОћ</translation>
<translation id="8394720698884623075">РђЈОћОъОбОеОЏОф ОЉОЋОЊОДОф ОЏОфОЋОЉОЋОф URL ОЉОбОќОеОф ОеОЕОЎОъОћ ОЕОю ОљОфОеОЎОЮ ОюОљ ОЉОўОЋОЌОЎОЮ ОЕОЕОъОЋОеОћ ОЉ-Chrome</translation>
<translation id="8402673309244746971">ОъОбОЉОе ОљОю ОћОцОЎОЊ 'ОЉОъОбОДОЉ'</translation>
<translation id="8413126021676339697">ОюОћОдОњОф ОћОћОЎОАОўОЋОеОЎОћ ОћОъОюОљОћ</translation>
<translation id="8413795581997394485">РђЈОћОњОаОћ ОъОцОаОЎ ОљОфОеОЎОЮ, ОћОЋОеОЊОЋОф ОЋОфОЋОАОцОЎОЮ ОЕОЎОЊОЋОбОЎОЮ ОЏОъОАОЋОЏОаОЎОЮ. ОЏОЕОъОЉОДОеОЎОЮ ОЉОљОфОе ОъОАОЋОЎОЮ, Chrome ОЕОЋОюОЌ Ою-Google ОДОўОб ОДОЋОЊ ОъОбОЋОеОцОю ОъОЏОфОЋОЉОф Оћ-URL ОЊОеОџ ОЕОеОф ОцОеОўОЎОЋОф ОЕОъОАОфОЎОе ОљОф ОЏОфОЋОЉОф Оћ-IP. ОљОЮ ОћОљОфОе ОцОЋОбОю ОЉОљОЋОцОЪ ОЕОъОбОЋОеОе ОЌОЕОЊ, ОаОЕОюОЌОЋОф ОњОЮ ОЏОфОЋОЉОЋОф URL ОъОюОљОЋОф ОЋОДОўОбОЎ ОфОЋОЏОЪ ОъОЊОцОЎОЮ.</translation>
<translation id="8414396119627470038">ОЏОаОЎОАОћ ОљОю <ph name="SITE_ETLD_PLUS_ONE" /> ОЉОљОъОдОбОЋОф <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="8416347857511542594">РђЈОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОћОфОљОъОћ ОћОљОЎОЕОЎОф ОЕОю ОћОъОЋОЊОбОЋОф ОЉ-Chrome</translation>
<translation id="8419244640277402268">ОћОЋОАОцОћ</translation>
<translation id="8422250855136581222">ОљОЎОЪ ОЏОеОўОЎОАОЎОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="8424781820952413435">РђЈОћОЊОБ ОаОЕОюОЌ. ОЏОЊОЎ ОюОеОљОЋОф ОљОЋОфОЋ, ОцОЋОфОЌОЎОЮ ОљОф ОЊОцОЊОцОЪ Chrome ОЉ<ph name="DEVICE_TYPE" /></translation>
<translation id="8427875596167638501">ОЏОеОўОЎОАОЎОЎОф ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОцОфОЋОЌОћ ОЉОЌОдОЎ ОњОЋОЉОћ ОћОъОАОџ</translation>
<translation id="8428213095426709021">ОћОњОЊОеОЋОф</translation>
