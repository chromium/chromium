<translation id="483742037940503070">{TAB_COUNT,plural, =1{ОЕОЌОќОЋОе ОЕОю ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЕОъОЏОЎОюОћ ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />) ОЉОдОЉОб <ph name="COLOR_NAME" /> ОЏОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ ОЉОеОДОб.}one{ОЕОЌОќОЋОе ОЕОю ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЕОъОЏОЎОюОћ <ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф, ОЉОдОЉОб <ph name="COLOR_NAME" />, ОЏОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ ОЉОеОДОб.}two{ОЕОЌОќОЋОе ОЕОю ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЕОъОЏОЎОюОћ <ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф, ОЉОдОЉОб <ph name="COLOR_NAME" />, ОЏОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ ОЉОеОДОб.}other{ОЕОЌОќОЋОе ОЕОю ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЕОъОЏОЎОюОћ <ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф, ОЉОдОЉОб <ph name="COLOR_NAME" />, ОЏОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ ОЉОеОДОб.}}</translation>
