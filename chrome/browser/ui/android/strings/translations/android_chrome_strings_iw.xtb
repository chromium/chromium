<translation id="8489271220582375723">ОцОфОЎОЌОф ОЊОБ ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="8493948351860045254">ОцОЎОаОЋОЎ ОаОцОЌ ОљОЌОАОЋОЪ</translation>
<translation id="8497242791509864205">ОцОфОЎОЌОћ ОЕОю ОљОцОЕОеОЋОЎОЋОф ОћОъОЎОЋОЪ</translation>
<translation id="8497480609928300907">ОћОАОЉОе ОбОю ОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф</translation>
<translation id="8497726226069778601">ОљОЎОЪ ОъОћ ОюОеОљОЋОф ОЏОљОЪРђд ОЉОЎОаОфОЎОЎОЮ</translation>
<translation id="8501423924927196358">ОљОЎОаОЊОЎОДОўОЋОе ОћОўОбОЎОаОћ ОЕОю ОћОфОЋОЉОаОЋОф ОюОњОЉОЎ ОћОЊОБ</translation>
<translation id="8503559462189395349">РђЈОАОЎОАОъОљОЋОф Chrome</translation>
<translation id="8503813439785031346">ОЕОЮ ОъОЕОфОъОЕ</translation>
<translation id="8505766168025405649">ОАОўОўОЋОА ОћОћОЋОеОЊОћ ОъОЋОдОњ ОЉОћОфОеОљОЋОф</translation>
<translation id="8506357771923193001">ОћОћОЋОеОЊОЋОф ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="8514477925623180633">РђЈОЎОЎОдОЋОљ ОАОЎОАОъОљОЋОф ОћОъОљОЋОЌОАОаОЋОф ОЉ-Chrome</translation>
<translation id="8516012719330875537">ОбОЋОеОџ ОфОъОЋОаОЋОф</translation>
<translation id="8516431725144212809">РђЈОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ ОЉОћОфОљОЮ ОюОћОбОеОЏОћ ОЕОю Chrome</translation>
<translation id="8523928698583292556">ОъОЌОЎОДОф ОћОАОЎОАОъОћ ОћОЕОъОЋОеОћ</translation>
<translation id="8526855376374973824">ОфОћОюОЎОџ ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОфОеОљОЋОф</translation>
<translation id="8540136935098276800">РђЈОЎОЕ ОюОћОќОЎОЪ ОЏОфОЋОЉОф URL ОЉОцОЋОеОъОў ОЌОЋОДОЎ</translation>
<translation id="854522910157234410">ОцОфОЎОЌОф ОЊОБ ОќОћ</translation>
<translation id="8551513938758868521">РђЈОЏОеОўОЎОАОЎОЋОф ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ ОЎОЎОаОбОюОЋ ОЏОЕ-Chrome ОЎОЎОАОњОе</translation>
<translation id="8559961053328923750">РђЈОЉ-Chrome ОъОЋОњОЊОеОф ОъОњОЉОюОћ ОбОю ОЏОъОЋОф ОћОаОфОЋОаОЎОЮ ОћОЏОЋОюОюОф ОЕОљОфОеОЎОЮ ОеОЕОљОЎОЮ ОюОЕОфОБ ОЊОеОџ ОћОЊОцОЊОцОЪ ОЏОЊОЎ ОюОъОЊОЋОЊ ОљОф ОЉОЎОдОЋОбОЎ ОћОъОЋОЊОбОЋОф</translation>
<translation id="8559990750235505898">ОћОдОбОћ ОюОфОеОњОЮ ОЊОцОЎОЮ ОЉОЕОцОЋОф ОљОЌОеОЋОф</translation>
<translation id="8560602726703398413">ОаОЎОфОЪ ОюОъОдОЋОљ ОљОф ОеОЕОЎОъОф ОћОДОеОЎОљОћ ОЉОДОўОб 'ОАОЎОъОаОЎОЋОф'</translation>
<translation id="8562452229998620586">ОћОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЎОЋОцОЎОбОЋ ОЏОљОЪ.</translation>
<translation id="856481929701340285">ОЉОДОЕ ОљОфОе ОюОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ</translation>
<translation id="8570677896027847510">ОюОљ ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОф ОћОДОЋОЉОЦ ОЉОљОЋОцОЪ ОъОљОЋОЉОўОЌ</translation>
<translation id="8571213806525832805">ОъОљОеОЉОбОф ОћОЕОЉОЋОбОЋОф ОћОљОЌОеОЋОаОЎОЮ</translation>
<translation id="8580884231102452214">РђЈОћОбОфОДОћ ОЕОю Оћ-GIF</translation>
<translation id="8583805026567836021">ОаОфОЋОаОЎ ОћОЌОЕОЉОЋОЪ ОаОъОЌОДОЎОЮ</translation>
<translation id="859046281437143747">ОљОцОЕОе ОюОбОДОЋОЉ ОљОЌОе ОћОъОЌОЎОе ОЉОљОъОдОбОЋОф ОюОЌОдОЪ ОћОљОцОЕОеОЋОЎОЋОф ОћОаОЋОАОцОЋОф</translation>
<translation id="860043288473659153">ОЕОЮ ОЉОбОю ОћОЏОеОўОЎОА</translation>
<translation id="8602358303461588329">РђЈОЏОаОЎОАОћ Ою-Chrome, ОАОњОЋОе.</translation>
<translation id="860282621117673749">ОћОфОеОљОЋОф ОбОю ОћОаОЌОЋОф</translation>
<translation id="8616006591992756292">РђЈОЎОЎОфОЏОЪ ОЕОюОЌОЕОЉОЋОЪ Google ОЕОюОџ ОЎОћОЎОЋ ОдОЋОеОЋОф ОљОЌОеОЋОф ОЕОю ОћОЎОАОўОЋОеОЎОЎОф ОњОюОЎОЕОћ ОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK" />myactivity.google.com<ph name="END_LINK" />.</translation>
<translation id="8617240290563765734">ОћОљОЮ ОюОбОЉОЋОе ОљОю ОЏОфОЋОЉОф ОћОљОфОе ОЕОдОЋОЎОаОћ ОЏОћОдОбОћ ОЉОфОЋОЏОЪ ОЕОћОЋОеОЊОф?</translation>
<translation id="8621068256433641644">ОўОюОцОЋОЪ</translation>
<translation id="8636825310635137004">ОЏОЊОЎ ОюОДОЉОю ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОъОћОъОЏОЕОЎОеОЎОЮ ОћОљОЌОеОЎОЮ ОЕОюОџ, ОЎОЕ ОюОћОцОбОЎОю ОљОф ОћОАОаОЏОеОЋОЪ.</translation>
<translation id="864544049772947936">ОаОЎОћОЋОю ОћОЌОюОЋОаОЋОф (<ph name="INSTANCE_COUNTS" />)</translation>
<translation id="8645920082661222035">ОћОъОбОеОЏОф ОЌОЋОќОћ ОљОЎОеОЋОбОЎОЮ ОъОАОЋОЏОаОЎОЮ ОЋОъОќОћОЎОеОћ ОљОЋОфОџ ОюОњОЉОЎОћОЮ ОюОцОаОЎ ОЕОћОЮ ОъОфОеОЌОЕОЎОЮ</translation>
<translation id="8655129584991699539">РђЈОљОцОЕОе ОюОаОДОЋОф ОљОф ОћОаОфОЋОаОЎОЮ ОЊОеОџ ОћОњОЊОеОЋОф Chrome.</translation>
<translation id="8664215986015753476">РђЈОЕОЎОъОЋОЕ ОъОЋОфОљОЮ ОљОЎОЕОЎОф ОЉ-Chrome</translation>
<translation id="8664979001105139458">ОЕОЮ ОћОДОЋОЉОЦ ОЏОЉОе ОДОЎОЎОЮ</translation>
<translation id="8676276370198826499">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЎОеОЕОЮ ОюОљОфОе <ph name="SITE_ETLD_PLUS_ONE" /> ОбОЮ ОћОЌОЕОЉОЋОЪ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="8676789164135894283">ОЕОЎОъОЋОЕ ОЉОъОЏОЕОЎОе ОюОљОЎОъОЋОф ОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ</translation>
<translation id="8683039184091909753">ОфОъОЋОаОћ</translation>
<translation id="869891660844655955">ОфОљОеОЎОџ ОфОцОЋОњОћ</translation>
<translation id="8699120352855309748">ОљОЎОЪ ОюОћОдОЎОњ ОљОф ОћОћОдОбОћ ОюОфОеОњОЮ ОљОф ОћОЕОцОЋОф ОћОљОюОћ</translation>
<translation id="8712637175834984815">ОћОЉОаОфОЎ</translation>
<translation id="8723453889042591629">ОфОеОњОЋОЮ ОъОћОЎОе ОЕОю ОћОЊОБ ОћОќОћ. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="8725066075913043281">ОаОЎОАОЎОЋОЪ ОЌОЋОќОе</translation>
<translation id="8731268612289859741">ОДОЋОЊ ОћОљОЉОўОЌОћ</translation>
<translation id="8746155870861185046">ОЕОЎОфОЋОБ ОЕОю ОћОўОДОАОў ОћОъОЋОЊОњОЕ</translation>
<translation id="874726034427945498">ОљОЌОеОЎ ОАОаОЏОеОЋОЪ ОћОЏОеОўОЎОАОЎОЋОф ОЋОћОћОЎОАОўОЋОеОЎОћ ОЎОфОДОЉОюОЋ ОћОдОбОЋОф ОўОЋОЉОЋОф ОЎОЋОфОе ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф</translation>
<translation id="8748850008226585750">ОћОфОЋОЏОЪ ОъОЋОАОфОе</translation>
<translation id="8754448020583829686">ОћОбОфОДОћ ОЉОюОЎ ОћОДОЎОЕОЋОе</translation>
<translation id="8756969031206844760">ОюОбОЊОЏОЪ ОљОф ОћОАОЎОАОъОћ?</translation>
<translation id="8765470054473112089">РђЈОЏОЕОъОДОюОЎОЊОЎОЮ ОўОДОАОў ОЉОАОеОњОю ОћОЏОфОЋОЉОЋОф ОљОЋ ОЉОфОЎОЉОф ОћОЌОЎОцОЋОЕ, Chrome ОЕОЋОюОЌ ОљОф ОћОўОДОАОў ОћОќОћ ОюОъОаОЋОб ОћОЌОЎОцОЋОЕ ОЕОъОЋОњОЊОе ОЏОЉОеОЎОеОф ОъОЌОЊОю ОЏОЊОЎ ОюОДОЉОю ОћОдОбОЋОф ОўОЋОЉОЋОф ОЎОЋОфОе. ОћОљОцОЕОеОЋОф ОћОќОЋ ОъОЋОЕОЉОфОф ОЉОъОдОЉ ОћОцОеОўОЎ.</translation>
<translation id="8766529642647037772">ОеОЋОдОћ ОюОЎОдОЋОе ОДОЎОЕОЋОе ОъОЋОЊОњОЕ ОЏОъОЋ ОќОћ ОЕОъОЋОцОЎОб ОЏОљОЪ?</translation>
<translation id="8773160212632396039">ОбОЎОЉОЋОЊ ОћОЉОДОЕОћ ОъОфОЉОдОб</translation>
<translation id="8788265440806329501">ОћОЎОАОўОЋОеОЎОЎОф ОћОаОЎОЋОЋОў ОАОњОЋОеОћ</translation>
<translation id="8788968922598763114">ОцОфОЎОЌОћ ОъОЌОЊОЕ ОЕОю ОћОЏОеОўОЎОАОЎОЎОћ ОћОљОЌОеОЋОаОћ ОЕОаОАОњОеОћ</translation>
<translation id="879027982257117598">ОюОЊОЋОњОъОћ, ОљОЮ ОЉОЎОДОеОф ОЉОљОфОе ОюОъОЏОЎОеОф ОаОбОюОЎ ОеОЎОдОћ ОюОъОеОЌОДОЎОЮ ОљОеОЋОЏОЎОЮ, ОћОљОфОе ОбОЕОЋОЎ ОюОћОбОеОЎОџ ОЕОеОЎОдОЋОф ОъОеОфОЋОЪ ОъОбОаОЎОЎОаОЋОф ОљОЋОфОџ. ОюОљОЌОе ОъОЏОЪ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЉОЉОЎОДОЋОе ОЉОљОфОе ОЕОЋОаОћ ОфОЋОдОњ ОъОЋОЊОбОћ ОюОаОбОюОЎ ОеОЎОдОћ ОюОцОЎ ОћОдОбОћ ОъОћОљОфОе ОћОеОљОЕОЋОЪ.</translation>
<translation id="8798449543960971550">ОаОДОеОљОЋ</translation>
<translation id="8803526663383843427">ОЉОъОдОЉ ОъОЋОцОбОю</translation>
<translation id="8812260976093120287">ОЉОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОаОЎОфОЪ ОюОЕОюОЮ ОЊОеОџ ОћОъОЏОЕОЎОе ОЉОљОъОдОбОЋОф ОљОцОюОЎОДОдОЎОЋОф ОћОфОЕОюОЋОЮ ОћОаОфОъОЏОЋОф ОЕОъОЋОцОЎОбОЋОф ОюОъОбОюОћ.</translation>
<translation id="8816556050903368450">ОћОДОЎОЕОЋОе ОћОъОЏОЎОю: <ph name="ORIGIN" /></translation>
<translation id="881688628773363275">ОюОљ ОаОЎОфОЪ ОюОдОцОЋОф ОЉОфОЋОЏОЪ ОЕОю ОЏОеОўОЎОАОЎОЎОф 'ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ'.</translation>
<translation id="8820817407110198400">ОАОЎОъОаОЎОЋОф</translation>
<translation id="8835786707922974220">ОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОфОъОЎОЊ ОфОћОЎОћ ОюОџ ОњОЎОЕОћ ОюОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЕОюОџ</translation>
<translation id="883806473910249246">ОљОЎОеОбОћ ОЕОњОЎОљОћ ОЉОќОъОЪ ОћОЋОеОЊОф ОћОфОЋОЏОЪ.</translation>
<translation id="8840953339110955557">ОЎОЎОфОЏОЪ ОЕОћОЊОБ ОћОќОћ ОЕОЋОаОћ ОъОћОњОеОАОћ ОЉОљОЎОаОўОеОаОў.</translation>
<translation id="8847988622838149491">USB</translation>
<translation id="8849001918648564819">ОъОЋОАОфОе</translation>
<translation id="8853345339104747198"><ph name="TAB_TITLE" />, ОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="8854223127042600341">ОћОдОњОф ОћОДОЉОдОЎОЮ ОЕОќОъОЎОаОЎОЮ ОюОюОљ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў.</translation>
<translation id="885480114717186641">ОаОЎОфОЪ ОюОЉОДОЕ ОљОф ОћОљОфОе ОЕОъОЋОфОљОЮ ОюОъОЌОЕОЉ ОЕОю <ph name="HOST_NAME" /></translation>
<translation id="8856607253650333758">ОюОЎОдОЎОеОф ОфОЎОљОЋОеОЎОЮ</translation>
<translation id="8856931513242997049">ОфОћОюОЎОџ ОћОћОеОЕОљОћ ОюОЕОюОЎОЌОф ОћОфОеОљОЋОф ОаОАОњОе</translation>
<translation id="8884023684057697730"><ph name="BEGIN_BOLD" />ОљОЎОџ ОюОаОћОю ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ:<ph name="END_BOLD" /> ОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОцОеОўОЎОЋОф ОЕОюОџ, ОћОљОфОеОЎОЮ ОЕОаОЋОАОцОЋ ОюОеОЕОЎОъОћ ОюОцОаОЎ ОЎОЋОфОе Оъ-4 ОЕОЉОЋОбОЋОф ОаОъОЌОДОЎОЮ ОъОъОаОћ ОљОЋОўОЋОъОўОЎОф. ОљОфОе ОЕОЉОЎОДОеОф ОЉОЋ ОЕОЋОЉ ОбОЕОЋОЎ ОюОЌОќОЋОе ОЋОюОћОЋОцОЎОб ОЉОеОЕОЎОъОћ. ОљОцОЕОе ОњОЮ ОюОћОАОЎОе ОљОфОе ОљОЮ ОюОљ ОеОЋОдОЎОЮ ОЕОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЎОЋОњОЊОеОЋ ОюОцОЎ ОћОЉОЎОДОЋОе ОЉОЋ.</translation>
<translation id="8898822736010347272">РђЈОЕОЋОюОЌ Ою-Google ОЏОфОЋОЉОЋОф URL ОЕОю ОЌОюОД ОъОћОЊОцОЎОЮ ОЕОљОюОЎОћОЮ ОаОЏОаОАОф, ОцОеОўОЎОЮ ОъОЋОњОЉОюОЎОЮ ОюОњОЉОЎ ОћОъОбОеОЏОф ОЋОЌОюОД ОъОфОЋОЏОЪ ОћОЊОцОЎОЮ. ОцОбОЋОюОћ ОќОЋ ОбОЋОќОеОф ОюОќОћОЋОф ОљОЎОЋОъОЎОЮ ОЌОЊОЕОЎОЮ ОЋОюОћОњОЪ ОбОю ОЏОю ОћОъОЕОфОъОЕОЎОЮ ОЉОљОЎОаОўОеОаОў.</translation>
<translation id="8909135823018751308">ОЕОЎОфОЋОБРђд</translation>
<translation id="8912362522468806198">РђЈОЌОЕОЉОЋОЪ Google</translation>
<translation id="8921980840204105660">ОљОцОЕОе ОюОЉОдОб ОАОаОЏОеОЋОЪ ОЏОЊОЎ ОюОћОЋОАОЎОБ ОљОф ОћОАОЎОъОаОЎОЋОф ОъОћОъОЏОЕОЎОеОЎОЮ ОћОљОЌОеОЎОЮ ОЕОюОџ</translation>
<translation id="8922289737868596582">ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОЊОцОЎОЮ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ, ОљОцОЕОе ОюОћОЋОеОЎОЊ ОљОЋОфОЮ ОЊОеОџ ОћОюОЌОдОЪ 'ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф'</translation>
<translation id="8924575305646776101"><ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="892496902842311796"><ph name="LANG" /> ОъОЋОЏОаОћ ОюОЕОЎОъОЋОЕ</translation>
<translation id="8937772741022875483">РђЈОћОљОЮ ОюОћОАОЎОе ОљОф ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉ-Chrome Оъ'ОЕОЎОъОЋОЕ ОЌОЏОЮ ОЉОЊОЎОњОЎОўОю'?</translation>
<translation id="8942627711005830162">ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ ОћОљОЌОе</translation>
<translation id="8945143127965743188"><ph name="LANG" /> - ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОЋОеОЎОЊ ОљОф ОћОЕОцОћ ОћОќОЋ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="8955719471735800169">ОЌОќОеОћ ОюОъОбОюОћ</translation>
<translation id="8964479563882643397">ОЏОЊОЎ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЎОћ ОцОеОўОЎОф ОЌОЊОЕОћ, ОцОЋОфОЌОЎОЮ ОљОф ОћОфОцОеОЎОў</translation>
<translation id="8965591936373831584">ОЉОћОъОфОаОћ</translation>
<translation id="8968085728801125376">{TAB_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОљОЌОф (<ph name="INCOGNITO_TAB_COUNT" />) ОЋОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />) ОаОЋОАОцОф ОЎОЎОАОњОеОЋ}one{ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОљОЌОф (<ph name="INCOGNITO_TAB_COUNT" />) ОЋ-<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОаОЋОАОцОЋОф ОЎОЎОАОњОеОЋ}two{ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОљОЌОф (<ph name="INCOGNITO_TAB_COUNT" />) ОЋ-<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОаОЋОАОцОЋОф ОЎОЎОАОњОеОЋ}other{ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОљОЌОф (<ph name="INCOGNITO_TAB_COUNT" />) ОЋ-<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОаОЋОАОцОЋОф ОЎОЎОАОњОеОЋ}}</translation>
<translation id="8970887620466824814">ОъОЕОћОЋ ОћОЕОфОЉОЕ.</translation>
<translation id="8972098258593396643">ОћОљОЮ ОюОћОЋОеОЎОЊ ОюОфОЎОДОЎОЎОф ОЉОеОЎОеОф ОћОъОЌОЊОю?</translation>
<translation id="8987736167266086032">ОћОъОЕОџ ОъОћОаОДОЋОЊОћ ОЕОЉОћ ОћОцОАОДОф</translation>
<translation id="8993760627012879038">ОцОфОЎОЌОф ОЌОюОЋОЪ ОЌОЊОЕ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="8996847606757455498">ОЉОЌОЎОеОф ОАОцОД ОљОЌОе</translation>
<translation id="8998289560386111590">ОюОљ ОќОъОЎОЪ ОЉОъОЏОЕОЎОе ОЕОюОџ</translation>
<translation id="8998729206196772491">РђЈОЉОЌОеОф ОюОћОЎОЏОаОА ОбОЮ ОЌОЕОЉОЋОЪ ОћОъОаОЋОћОю ОбОю-ОЎОЊОЎ <ph name="MANAGED_DOMAIN" /> ОЋОюОћОбОаОЎОД ОюОъОаОћОю ОЕОюОЋ ОЕОюОЎОўОћ ОбОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉ-Chrome. ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЎОЕОЋОЎОЏОЋ ОюОдОъОЎОфОЋОф ОљОю ОћОЌОЕОЉОЋОЪ ОћОќОћ. ОЎОдОЎОљОћ Оъ-Chrome ОфОъОЌОД ОљОф ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОъОћОъОЏОЕОЎОе ОћОќОћ, ОљОЉОю ОћОЮ ОЎОЎОЕОљОеОЋ ОЉОЌОЕОЉОЋОЪ Google.</translation>
<translation id="9012585441087414258">РђЈОћОњОаОћ ОъОцОаОЎ ОљОфОеОЎОЮ, ОћОЋОеОЊОЋОф ОЋОфОЋОАОцОЎОЮ ОЕОЎОЊОЋОбОЎОЮ ОЏОъОАОЋОЏОаОЎОЮ. ОљОЮ ОЉОЊОБ ОЏОюОЕОћОЋ ОъОфОЉОдОбОф ОцОбОЋОюОћ ОЌОЕОЋОЊОћ, ОЏОфОЋОЉОЋОф URL ОЋОДОўОбОЎОЮ ОъОћОфОЋОЏОЪ ОЉОЊОБ ОаОЕОюОЌОЎОЮ ОљОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОЕОю Google.</translation>
<translation id="9019199799064251516">ОюОћОъОЕОЎОџ ОЉОюОЎ ОаОбОЎОюОф ОцОеОЋОцОЎОю ОЉОъОЏОЋОаОЎОф?</translation>
<translation id="9022774213089566801">ОљОфОеОЎОЮ ОбОЮ ОЉОЎОДОЋОеОЎОЮ ОфОЏОЋОцОЎОЮ</translation>
<translation id="9022871169049522985">ОљОфОеОЎОЮ ОЋОъОцОеОАОъОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОъОЊОЋОЊ ОљОф ОЉОЎОдОЋОбОЎ ОћОъОЋОЊОбОЋОф ОЕОюОћОЮ</translation>
<translation id="9035378196785279980">РђЈОћОбОЉОеОћ ОљОю\u2026</translation>
<translation id="9041669420854607037">{FILE_COUNT,plural, =1{ОАОеОўОЋОЪ ОљОЌОЊ (#)}one{# ОАОеОўОЋОаОЎОЮ}two{# ОАОеОўОЋОаОЎОЮ}other{# ОАОеОўОЋОаОЎОЮ}}</translation>
<translation id="9042893549633094279">ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ</translation>
<translation id="9050666287014529139">ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="9055497320631373736">ОћОљОфОе ОћОЋОЌОќОе ОюОљОфОеОЎОЮ ОцОЋОўОаОдОЎОљОюОЎОЎОЮ</translation>
<translation id="9063523880881406963">ОЏОЎОЉОЋОЎ ОЕОю 'ОЉОДОЕОф ОљОфОе ОбОЉОЋОе ОъОЌОЕОЉ ОЕОЋОюОЌОаОЎ'</translation>
<translation id="9065203028668620118">ОбОеОЎОЏОћ</translation>
<translation id="9065383040763568503">РђЈОаОфОЋОаОЎОЮ ОъОљОЋОЌОАОаОЎОЮ ОЕОюОљ ОъОЋОњОЊОеОЎОЮ ОЏОЌОЕОЋОЉОЎОЮ ОЉ-Chrome (ОюОъОЕОю: ОљОфОеОЎОЮ ОюОюОљ ОћОњОЊОеОЋОф ОЕОъОЋОеОЋОф ОљОЋ ОЏОљОюОћ ОЕОфОЊОЎОеОЋОф ОћОЉОЎОДОЋОе ОЉОћОЮ ОаОъОЋОЏОћ)</translation>
<translation id="9067341854474068781">ОљОЎОЪ ОњОЎОюОЎОЋОЪ ОЕОю ОъОцОфОЌОЋОф ОњОЎОЕОћ ОЕОаОцОфОЌ ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="906781307897697745">ОъОЎОДОЋОЮ ОћОАОЎОъОаОЎОЎОћ: <ph name="PRODUCT_NAME" /></translation>
<translation id="9069999660519089861">ОљОЎОЪ ОЊОцОЎОЮ ОЕОюОљ ОаОДОеОљОЋ</translation>
<translation id="9070377983101773829">ОЉОЎОдОЋОб ОЌОЎОцОЋОЕ ОДОЋОюОЎ</translation>
<translation id="9074739597929991885">Bluetooth</translation>
<translation id="9081543426177426948">ОљОфОеОЎОЮ ОЕОаОЏОаОАОЎОЮ ОљОюОЎОћОЮ ОюОљ ОаОЕОъОеОЎОЮ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="9084103763810123431">ОљОЌОеОЎ ОАОаОЏОеОЋОЪ ОћОЏОеОўОЎОАОЎОЋОф ОЋОћОћОЎОАОўОЋОеОЎОћ ОљОцОЕОе ОЎОћОЎОћ ОюОћОъОЕОЎОџ ОЉОњОюОЎОЕОћ ОЉОъОЏОЕОЎОе ОљОЌОе</translation>
<translation id="9086302186042011942">ОћОАОаОЏОеОЋОЪ ОъОфОЉОдОб</translation>
<translation id="9086455579313502267">ОљОЎОЪ ОљОцОЕОеОЋОф ОюОњОЕОф ОюОеОЕОф</translation>
<translation id="9099220545925418560">ОбОю ОАОъОџ ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЕОюОџ. ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф.</translation>
<translation id="9100610230175265781">ОЎОЕ ОюОћОќОЎОЪ ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="9101137867221042551">ОаОЎОћОЋОю</translation>
<translation id="9102803872260866941">ОЏОеОўОЎОАОЎОЎОф ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОаОцОфОЌОћ</translation>
<translation id="9102864637938129124">ОћОљОфОеОЎОЮ ОЋОћОъОцОеОАОъОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЉОЎОЪ ОљОф ОеОъОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОћОъОЋОЊОбОЋОф. ОћОћОњОЊОеОћ ОћОќОЋ ОцОЋОбОюОф.</translation>
<translation id="9104217018994036254">ОеОЕОЎОъОф ОћОъОЏОЕОЎОеОЎОЮ ОЕОљОцОЕОе ОюОЕОфОБ ОљОЎОфОЮ ОЏОеОўОЎОАОЎОЎОћ.</translation>
<translation id="9106148373857059373">ОфОћОюОЎОџ ОЕОъОЎОеОф ОћОАОЎОъОаОЎОЎОћ ОаОАОњОе</translation>
<translation id="9108312223223904744">ОфОъОЎОЏОћ ОЉОўОюОцОЋОЪ ОЏОъОцОфОЌ ОљОЉОўОЌОћ</translation>
<translation id="9108808586816295166">РђЈОћ-DNS ОћОъОљОЋОЉОўОЌ ОюОљ ОЎОћОЎОћ ОЉОћОЏОеОЌ ОќОъОЎОЪ ОфОъОЎОЊ</translation>
<translation id="9128984223251192329">ОћОћОЋОЊОбОћ ОюОњОЉОЎ ОљОеОњОќ ОћОЌОЋОю ОюОцОеОўОЎОЋОф ОаОцОфОЌОћ ОЉОЌОдОЎ ОћОњОЋОЉОћ</translation>
<translation id="9131209053278896908">ОЏОљОЪ ОЎОЋОцОЎОбОЋ ОљОфОеОЎОЮ ОЌОАОЋОъОЎОЮ</translation>
<translation id="9133397713400217035">ОћОдОбОЋОф ОюОфОЋОЏОЪ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="9148126808321036104">ОЏОаОЎОАОћ ОЌОЋОќОеОф</translation>
<translation id="9158770349521403363">ОЕОЎОфОЋОБ ОћОфОЋОЏОЪ ОЉОюОЉОЊ</translation>
<translation id="9159716826369098114">ОЕОЌОќОЋОе ОЕОю ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЕОъОЏОЎОюОћ <ph name="TAB_COUNT" /> ОЏОеОўОЎОАОЎОЋОф ОЏОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ ОЉОеОДОб.</translation>
<translation id="9169507124922466868">ОћОЎОАОўОЋОеОЎОЎОф ОћОаОЎОЋОЋОў ОцОфОЋОЌОћ ОюОъОЌОдОћ</translation>
<translation id="918419812064856259">РђЈChrome ОЉОўОљ</translation>
<translation id="9190276265094487094">ОћОћОЎОАОўОЋОеОЎОћ ОфОЋОцОЎОб ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ ОЕОюОџ, ОЏОџ ОЕОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОћОъОЕОЎОџ ОъОћОъОДОЋОЮ ОЕОЉОЋ ОћОцОАОДОф.</translation>
<translation id="9199368092038462496">{NUM_MINS,plural, =1{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ ОЊОДОћ ОљОЌОф}one{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЊОДОЋОф}two{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЊОДОЋОф}other{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЊОДОЋОф}}</translation>
<translation id="9204021776105550328">ОъОфОЉОдОбОф ОъОЌОЎОДОћ</translation>
<translation id="9204836675896933765">ОаОЋОфОе ОДОЋОЉОЦ ОљОЌОЊ</translation>
<translation id="9205933215779845960">ОюОљ ОаОЎОфОЪ ОюОъОдОЋОљ ОљОф ОћОЊОБ ОћОќОћ. ОдОеОЎОџ ОюОЋОЋОЊОљ ОЕОћОљОЎОЋОф ОаОЏОЋОЪ ОљОЋ ОюОаОАОЋОф ОюОЌОцОЕ ОЉ-<ph name="SEARCH_ENGINE" />.</translation>
<translation id="9206873250291191720">Ољ</translation>
<translation id="9209888181064652401">ОюОљ ОаОЎОфОЪ ОюОЉОдОб ОЕОЎОЌОЋОф</translation>
<translation id="9212845824145208577">ОљОЎ ОљОцОЕОе ОюОќОЋОќ ОюОъОўОћ ОЎОЋОфОе. ОЎОЕ ОюОаОАОЋОф ОюОћОфОЌОЎОю ОъОЌОюОД ОаОъОЋОџ ОЎОЋОфОе ОЉОЊОБ.</translation>
<translation id="9219103736887031265">ОфОъОЋОаОЋОф</translation>
<translation id="9219582468404818260">ОеОЋОдОћ ОюОбОќОЋОе ОюОаОЋ ОюОЕОцОе ОљОф ОћОљОЎОаОўОеОаОў?</translation>
<translation id="92381315203627188">РђЈОЏОЕОљОфОе ОъОЉОДОЕ ОюОўОбОЋОЪ ОъОеОљОЕ ОДОЎОЕОЋОеОЎОЮ ОЉОЊОБ ОЕОюОЋ ОЉОљОЋОцОЪ ОцОеОўОЎ, ОъОбОеОЏОф Chrome ОъОдОцОЎОаОћ ОЋОўОЋОбОаОф ОъОеОљОЕ ОљОф ОћОЊОцОЎОЮ ОЉОљОъОдОбОЋОф ОЕОеОфОЎОЮ ОЕОю Google ОюОюОљ ОДОЋОЉОдОЎ cookie. ОЏОџ ОъОЋОАОфОеОф ОћОќОћОЋОф ОЕОюОџ ОъОћОљОфОе ОЕОаОўОбОЪ ОъОеОљОЕ.</translation>
<translation id="926205370408745186">РђЈОћОАОеОф ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉ-Chrome Оъ'ОЕОЎОъОЋОЕ ОЌОЏОЮ ОЉОЊОЎОњОЎОўОю'.</translation>
<translation id="927968626442779827">РђЈОЏОЊОљОЎ ОюОћОЕОфОъОЕ ОЉОъОдОЉ ОћОўОбОЎОаОћ ОћОъОћОЎОеОћ ОЉ-Google Chrome</translation>
<translation id="928550791203542716">ОћОљОфОе <ph name="SITE_NAME" /> ОаОъОдОљ ОЉОъОбОДОЉ</translation>
<translation id="93533588269984624">ОфОфОЉОдОб ОћОЋОеОЊОћ ОЕОю ОЏОю ОћОАОЎОАОъОљОЋОф ОЕОЉОъОЏОЕОЎОе ОЋОћОЪ ОЎОЋОАОеОЋ Оъ-<ph name="CHROME_CHANNEL" /></translation>
<translation id="938850635132480979">ОЕОњОЎОљОћ: <ph name="ERROR_CODE" /></translation>
<translation id="939598580284253335">ОћОќОаОф ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="952301137339791907">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОћОфОЋОЉОаОЋОф ОюОњОЉОЎ ОћОЊОБ ОцОфОЋОЌ</translation>
<translation id="95817756606698420">РђЈОЊОцОЊОцОЪ Chrome ОЎОЏОЋОю ОюОћОЕОфОъОЕ ОЉ-<ph name="BEGIN_BOLD" />SogouРђЈ<ph name="END_BOLD" /> ОЏОЊОЎ ОюОЉОдОб ОЌОЎОцОЋОЕ ОъОАОЎОЪ. ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОћОћОбОЊОцОћ ОћОќОљОф ОЉ<ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф<ph name="END_LINK" />.</translation>
<translation id="962979164594783469">ОћОфОДОаОф ОћОљОцОюОЎОДОдОЎОћ</translation>
<translation id="96681097142096641">ОюОћОдОЎОњ ОЊОБ ОцОЕОЋОў?</translation>
<translation id="968900484120156207">ОћОЊОцОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф ОъОЋОцОЎОбОЎОЮ ОЏОљОЪ</translation>
<translation id="970715775301869095">ОаОЋОфОеОЋ <ph name="MINUTES" /> ОЊОДОЋОф</translation>
<translation id="981121421437150478">ОюОљ ОъОДОЋОЋОЪ</translation>
<translation id="983192555821071799">ОАОњОЎОеОф ОЏОю ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="987264212798334818">ОЏОюОюОЎ</translation>
<translation id="992745192656291733"><ph name="TAB_COUNT" /> ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="993520549480398880">ОаОЎОфОЪ ОюОаОДОЋОф ОњОЮ ОљОф ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОъОЏОЋОаОЎОф ОћОќОЋ</translation>
<translation id="996149300115483134">ОфОцОеОЎОў ОЏОеОўОЎОА ОћОцОЎОЊ ОАОњОЋОе</translation>
</translationbundle>