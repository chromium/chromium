<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1009406586654360474">РђЈОцОЋОфОЌОЎОЮ ОљОф ОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОЋОбОЋОЉОеОЎОЮ ОюОћОњОЊОеОЋОф. ОЉОЋОЌОеОЎОЮ ОЉОљОцОЕОеОЋОф 'ОЎОЎОЉОЋОљ' ОЋОъОЋОАОЎОцОЎОЮ ОљОф ОДОЋОЉОЦ Оћ-CSV ОЕОъОЏОЎОю ОљОф ОћОАОЎОАОъОљОЋОф ОЕОЎОЋОдОљОЋ.</translation>
<translation id="1010283278930414892">ОљОЎОЪ ОЉОъОЏОЕОЎОе ОћОќОћ ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="1011749477052068769">ОћОбОЉОеОћ ОюОЏОљОЪ</translation>
<translation id="1014147525163127655">ОљОЎОЪ ОъОцОфОЌОЋОф ОњОЎОЕОћ ОбОЉОЋОе <ph name="ORIGIN" /> ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="1016498331642356377">ОЌОЎОцОЋОЕ ОъОћОЎОе ОЉОљОъОдОбОЋОф ОћОДОЋОю. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="1024113959924243553">РђЈChrome ОцОЎОфОЋОЌ</translation>
<translation id="1028699632127661925">ОћОЏОеОўОЎОАОЎОЎОћ ОаОЕОюОЌОф ОљОю <ph name="DEVICE_NAME" />...</translation>
<translation id="103269572468856066">ОюОъОЌОЋОД ОаОфОЋОаОЎОЮ ОњОЮ ОъОћОљОфОеОЎОЮ ОЋОъОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОћ?</translation>
<translation id="1034259925032978114">ОћОЌОюОЋОЪ ОцОфОЋОЌ</translation>
<translation id="1036348656032585052">ОЏОЎОЉОЋОЎ</translation>
<translation id="1045899828449635435">ОюОъОЌОЋОД ОаОфОЋОаОЎОЮ ОњОЮ ОъОћОљОфОеОЎОЮ ОћОљОюОћ?</translation>
<translation id="1049743911850919806">ОњОюОЎОЕОћ ОцОеОўОЎОф</translation>
<translation id="1052842760770519282">ОЌОюОД ОъОћОАОЎОАОъОљОЋОф ОЕОюОџ ОюОљ ОќОъОЎОаОЋОф</translation>
<translation id="1058669287135776095">ОљОЎОЪ ОюОџ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў. ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="10614374240317010">ОцОеОЎОўОЎОЮ ОЕОљОБ ОцОбОЮ ОюОљ ОЎОЎОЕОъОеОЋ</translation>
<translation id="1070689840697074178">РђЈОљОцОЕОе ОюОћОЋОеОЎОЊ ОДОЋОЉОдОЎ PDF ОЏОљОЪ</translation>
<translation id="107147699690128016">ОЕОЎОаОЋОЎ ОЕОю ОАОЎОЋОъОф ОћОДОЋОЉОЦ ОбОЕОЋОЎ ОюОњОеОЋОЮ ОюОЏОџ ОЕОћОДОЋОЉОЦ ОЎОЎОцОфОЌ ОЉОљОцОюОЎОДОдОЎОћ ОљОЌОеОф. ОъОдОЉ ОќОћ ОбОюОЋОю ОюОАОЏОЪ ОљОф ОћОъОЏОЕОЎОе.</translation>
<translation id="1080365971383768617">ОАОЎОАОъОљОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="1087176310396019910">ОАОцОљОЮ ОљОцОЕОеОЎ</translation>
<translation id="1087799850623149508">ОљОцОЕОе ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОЏОЊОЎ ОюОћОбОЉОЎОе ОљОф ОАОеОњОю ОћОЏОфОЋОЉОЋОф ОюОфОЌОфОЎОф</translation>
<translation id="1089606299949659462">ОћОЉОЊОЎОДОћ ОћОЋОЕОюОъОћ!</translation>
<translation id="1094555143448724771">ОЏОЊОЎ ОюОеОљОЋОф ОЏОеОўОЎОАОЎОЋОф ОъОћОъОЏОЕОЎОеОЎОЮ ОћОљОЌОеОЎОЮ ОЕОюОџ, ОдОеОЎОџ ОюОАОаОЏОеОЪ ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЋОљОф ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="1095761715416917775">ОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОаОЎОфОЪ ОюОњОЕОф ОюОаОфОЋОаОЎОЮ ОћОъОАОЋОаОЏОеОаОЎОЮ ОЉОЏОю ОеОњОб</translation>
<translation id="1100066534610197918">ОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЉОДОЉОЋОдОћ</translation>
<translation id="1103142993930332957">РђЈОеОЋОдОћ ОюОбОќОЋОе ОюОаОЋ ОюОЕОцОе ОљОф Chrome?</translation>
<translation id="1105960400813249514">ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="1108214977745280468">ОћОдОњОф ОћОфОЋОЉОаОЋОф ОюОњОЉОЎ ОћОЊОБ</translation>
<translation id="1108938384783527433">ОАОаОЏОеОЋОЪ ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="1111673857033749125">ОАОЎОъОаОЎОЋОф ОЕОаОЕОъОеОЋ ОЉОъОЏОЕОЎОеОЎОЮ ОћОљОЌОеОЎОЮ ОЕОюОџ ОЎОЋОцОЎОбОЋ ОЏОљОЪ.</translation>
<translation id="1126696498560056882">ОаОЎОћОЋОю ОћОЌОЕОЉОЋОаОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="1129510026454351943">ОцОеОўОЎОЮ: <ph name="ERROR_DESCRIPTION" /></translation>
<translation id="1135018701024399762">'ОъОдОЉ ОцОеОўОЎ' ОъОљОцОЕОе ОюОџ ОюОњОюОЋОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ ОЕОюОљ ОЎОћОЎОћ ОњОюОЋОЎ ОюОъОЕОфОъОЕОЎОЮ ОљОЌОеОЎОЮ ОЉОъОЏОЕОЎОе</translation>
<translation id="1138458427267715730">ОДОЉОюОф ОћОфОеОљОЋОф ОЏОЕОЎОЕ ОћОаОЌОЋОф ОЉОљОфОеОЎОЮ ОЉОљОЎОаОўОеОаОў</translation>
<translation id="1140317858355046628">ОљОЮ ОћОДОЉОЋОдОћ ОфОЎОъОЌОД, ОЏОЋОюОЮ ОЎОљОЉОЊОЋ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ ОљОф ОћОњОЎОЕОћ ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф '<ph name="GROUP_NAME" />', ОЋОћОЎОљ ОфОЎОъОЌОД ОъОЏОю ОћОъОЏОЕОЎОеОЎОЮ.</translation>
<translation id="1142732900304639782">ОљОЎОЪ ОюОћОдОЎОњ ОљОф ОћОћОдОбОћ ОюОфОеОњОЮ ОљОф ОћОљОфОеОЎОЮ ОћОљОюОћ</translation>
<translation id="1145536944570833626">ОъОЌОЎОДОф ОаОфОЋОаОЎОЮ ОДОЎОЎОъОЎОЮ.</translation>
<translation id="1150263420752757504">РђЈОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОфОЎОцОфОЌ ОЉ-Chrome. ОћОъОЕОџ ОћОцОбОЋОюОћ ОъОЉОўОљ ОћОАОЏОъОћ <ph name="BEGIN_LINK1" />ОюОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф ОЕОю Google<ph name="END_LINK1" /> ОЋ<ph name="BEGIN_LINK2" />ОюОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф ОћОаОЋОАОцОЎОЮ ОЕОю Google Chrome ОЋ-ChromeOS<ph name="END_LINK2" />.</translation>
<translation id="1154555449933432029">РђЈОљОЎОЪ ОюОџ ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google.</translation>
<translation id="115483310321669804">ОЕОЎОъОЋОЕ ОЉОАОЎОАОъОћ <ph name="PASSWORD" /></translation>
<translation id="1173894706177603556">ОЕОЎОаОЋОЎ ОЕОЮ</translation>
<translation id="1174479719160874822">РђЈОљОЮ ОћОъОАОџ ОдОе, Chrome ОЎОЉОДОЕ ОљОф ОћОљОфОе ОюОаОЎОЎОЊ</translation>
<translation id="1175241315203286684">РђЈОюОљОЊОъОЎОЪ ОЎОЕ ОљОцОЕОеОЋОф ОюОЉОдОб ОъОеОЌОЋОД ОЕОЎОаОЋОЎОЎОЮ ОЉОцОеОЋОцОЎОю ОЋОЉОЊОцОЊОцОЪ, ОюОаОфОЌ ОъОЎОЊОб ОбОю ОћОЊОцОЊОцОЪ ОЉОљОъОдОбОЋОф ОЊОЋОЌОЋОф ОЋОюОЉОдОб ОъОЕОЎОъОЋОф ОЌОЕОЋОЉОЋОф ОљОЌОеОЋОф. ОљОцОЕОе ОюОаОћОю ОљОф ОћОцОбОЎОюОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ ОњОЮ ОъОЌОЋОЦ Ою-Chrome.</translation>
<translation id="1177863135347784049">ОъОЋОфОљОЮ ОљОЎОЕОЎОф</translation>
<translation id="1181037720776840403">ОћОАОеОћ</translation>
<translation id="1183189057400844278">РђЈОЏОЊОЎ ОЕОфОъОЎОЊ ОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ, ОбОюОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="1187810343066461819">ОаОЎОфОЪ ОюОъОЌОЋОД ОњОЮ ОљОф ОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОеОЏОЉ ОћОќОћ</translation>
<translation id="1193729455103054076">ОеОЋОдОћ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОћ ОћОЌОќОДОћ?</translation>
<translation id="11947597112837849">ОЏОфОЋОЉОф ОљОЎОъОЎОЎОю</translation>
<translation id="1197267115302279827">ОћОбОЉОеОф ОАОЎОъОаОЎОЋОф</translation>
<translation id="1197761954713363183">ОњОЎОюОЎОЋОЪ ОћОљОЎОЕОЋОе ОЕОю ОъОцОфОЌ ОћОњОЎОЕОћ ОАОњОЋОе</translation>
<translation id="1201402288615127009">ОћОЉОљ</translation>
<translation id="1202892408424955784">ОъОЋОдОеОЎОЮ ОЉОъОбОДОЉ</translation>
<translation id="1204037785786432551">ОћОЋОеОЊОф ОДОЎОЕОЋОе</translation>
<translation id="1206892813135768548">ОћОбОфОДОф ОўОДОАОў ОДОЎОЕОЋОе</translation>
<translation id="1209206284964581585">ОюОћОАОфОЎОе ОЉОЎОаОфОЎОЎОЮ</translation>
<translation id="1227058898775614466">ОћОЎОАОўОЋОеОЎОЎОф ОаОЎОЋОЋОў</translation>
<translation id="123724288017357924">ОўОбОЎОаОћ ОъОЌОЊОЕ ОЕОю ОћОЊОБ ОћОаОЋОЏОЌОЎ, ОфОЋОџ ОћОфОбОюОъОЋОф ОъОфОЋОЏОЪ ОЕОъОљОЋОЌОАОЪ ОЉОДОЋОЉОЦ ОћОЕОъОЋОе</translation>
<translation id="1239792311949352652">ОЕОЎОфОЋОБ ОћОЊОБ ОћОќОћ ОЉОъОћОЎОеОЋОф. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="1240288207750131269"><ph name="LANG" /> ОЉОўОбОЎОаОћ</translation>
<translation id="124116460088058876">ОЕОцОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="124678866338384709">ОАОњОЎОеОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОаОЋОЏОЌОЎОф</translation>
<translation id="1246905108078336582">ОюОћОАОЎОе ОљОф ОћОћОдОбОћ ОъОћОюОЋОЌ?</translation>
<translation id="1258753120186372309">РђЈОЊОЋОЊОю ОЕОю GoogleРђЈ: <ph name="DOODLE_DESCRIPTION" /></translation>
<translation id="1263063910731171689">РђЈОъОбОЏОЕОЎОЋ ОЎОЋОдОњ ОюОџ ОфОЋОЏОЪ ОъОљОфОе <ph name="SITE_NAME" />, ОЋОфОЋОЏОЪ ОюОњОЉОЎОЋ, ОЉОДОўОб 'ОЉОъОбОДОЉ'. ОћОљОфОеОЎОЮ ОЋОћОЌОЎОцОЋОЕОЎОЮ ОЕОЉОъОбОДОЉ ОаОЕОъОеОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОЉОЏОю ОЕОюОЉ ОљОцОЕОе ОюОаОћОю ОљОф ОћОцОеОЎОўОЎОЮ ОЕОЉОъОбОДОЉ ОЉОћОњОЊОеОЋОф.</translation>
<translation id="1263231323834454256">ОеОЕОЎОъОф ОДОеОЎОљОћ</translation>
<translation id="1269129608791067105">ОћОћОЎОАОўОЋОеОЎОћ ОфОЋОцОЎОб ОЏОљОЪ</translation>
<translation id="1273937721055267968">ОЌОАОЎОъОћ ОЕОю <ph name="DOMAIN" /></translation>
<translation id="1283039547216852943">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОеОЌОЎОЉ</translation>
<translation id="1289129165308566697">ОеОЋОдОћ ОюОеОљОЋОф ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОЕОюОџ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ?</translation>
<translation id="129553762522093515">ОаОАОњОеОЋ ОюОљОЌОеОЋОаОћ</translation>
<translation id="1298077576058087471">ОДОеОљОф ОЌОЊОЕОЋОф ОћОЎОЋОЮ? ОљОцОЕОе ОюОЌОАОЋОџ ОбОЊ 60% ОЉОаОЎОдОЋОю ОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="1303339473099049190">ОюОљ ОаОЎОфОЪ ОюОъОдОЋОљ ОљОф ОћОАОЎОАОъОћ. ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОљОЎОЋОф ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="1303507811548703290"><ph name="DOMAIN" /> Рђћ ОаОЕОюОЌОћ Оъ-<ph name="DEVICE_NAME" /></translation>
<translation id="130959219150156180">ОъОбОЉОе ОюОЊОБ ОћОЉОљ ОЉ"ОћОЎОАОўОЋОеОЎОћ"</translation>
<translation id="1318262688555255786">ОЕОЎОфОЋОБ ОћОДОЎОЕОЋОе ОюОЊОБ ОћОљОЎОаОўОеОаОў <ph name="PAGE_TITLE" />. ОъОДОЋОе: <ph name="PAGE_URL" /></translation>
<translation id="1320912611264252795">ОфОћОюОЎОџ ОЕОъОЎОеОф ОфОЎОДОЎОЋОф ОћОАОЎОъОаОЎОЋОф ОЕОцОфОЋОЌОЋОф ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="1327257854815634930">ОћОЎОАОўОЋОеОЎОЎОф ОћОаОЎОЋОЋОў ОцОфОЋОЌОћ</translation>
<translation id="1331212799747679585">РђЈОюОљ ОаОЎОфОЪ ОюОбОЊОЏОЪ ОљОф Chrome. ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="1332501820983677155">РђЈОъОДОЕОЎ ОДОЎОдОЋОе ОюОфОЏОЋОаОЋОф ОЕОю Google ChromeРђЈ</translation>
<translation id="1333491156693005331">ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОљОЌОеОЋОаОћ</translation>
<translation id="1336996151357442890">ОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ ОюОљОфОе <ph name="SITE_NAME" />. ОфОЋОдОњ ОЕОљОюОћ ОаОЋОАОцОф ОЉОЉОЎОДОЋОе ОћОЉОљ ОЕОюОџ.</translation>
<translation id="1340839264183302272">ОЎОдОЎОљОћ ОъОћОДОЉОЋОдОћ</translation>
<translation id="1342886103232377846">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ, ОдОеОЎОџ ОюОбОЉОЋОе ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="1344653310988386453">ОбОюОЎОџ ОюОЏОюОЋОю ОДОЎОЕОЋОе ОюОўОДОАОў ОћОъОЋОЊОњОЕ</translation>
<translation id="1347468774581902829">ОаОЎОћОЋОю ОцОбОЎОюОЋОф</translation>
<translation id="1355088659320425659">ОћОЎОАОўОЋОеОЎОћ ОЋОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="1360432990279830238">ОюОдОљОф ОЋОюОћОЕОЉОЎОф ОљОф ОћОАОаОЏОеОЋОЪ?</translation>
<translation id="1363028406613469049">ОеОдОЋОбОћ</translation>
<translation id="1366525380420346469">ОЉОъОдОЉ ОъОЋОцОбОю</translation>
<translation id="1373696734384179344">ОљОЎОЪ ОъОАОцОЎОД ОќОЎОЏОеОЋОЪ ОюОћОЋОеОЊОф ОћОфОЋОЏОЪ ОћОаОЉОЌОе.</translation>
<translation id="1376578503827013741">ОъОЌОЕОЉ...</translation>
<translation id="1381838868249179644">ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ, ОћОЋОАОеОЋ ОћОеОЕОљОЋОф ОъОЏОъОћ ОљОфОеОЎОЮ</translation>
<translation id="1383876407941801731">ОЌОЎОцОЋОЕ</translation>
<translation id="1384704387250346179">РђЈОфОеОњОЋОЮ ОфОъОЋОаОћ ОЉОљОъОдОбОЋОф Google LensРђЈ <ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="1386674309198842382">ОцОбОЎОюОЋОф ОљОЌОеОЋОаОћ: ОюОцОаОЎ <ph name="LAST_UPDATED" /> ОЎОъОЎОЮ</translation>
<translation id="1390418506739274310">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОЋОдОњ ОћОЎОАОўОЋОеОЎОћ ОъОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф ОЕОцОЋОфОЌОЋОф ОДОЎОЕОЋОеОЎОЮ ОЉ-Chrome. ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google ОбОЕОЋОЎОЎОЮ ОюОћОЋОцОЎОб ОАОЋОњОЎОЮ ОљОЌОеОЎОЮ ОЕОю ОћОЎОАОўОЋОеОЎОЎОф ОњОюОЎОЕОћ ОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK" />myactivity.google.com<ph name="END_LINK" />.</translation>
<translation id="139752016751285248">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОъОЊОЊОЎ ОћОъОЌОЎОеОЎОЮ ОаОцОфОЌ ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="1397811292916898096">ОЌОЎОцОЋОЕ ОЉОљОъОдОбОЋОф <ph name="PRODUCT_NAME" /></translation>
<translation id="1398057416966591719">РђЈОљОцОЕОе <ph name="BEGIN_LINK1" />ОюОДОЉОЋОб ОљОЎОюОЋ ОаОфОЋОаОЎОЮ Оъ-Chrome ОЎОЎОЕОъОеОЋ<ph name="END_LINK1" /> ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google.

ОЏОЊОЎ ОюОеОљОЋОф ОљОЎОюОЋ ОћОњОЊОеОЋОф ОаОЋОАОцОЋОф ОъОфОЉОАОАОЋОф ОбОю ОаОфОЋОаОЎОЮ ОюОдОЋОеОџ ОЕОЎОцОЋОе ОЌОЋОЋОЎОЎОф ОћОЕОЎОъОЋОЕ ОЉ-Chrome, ОаОЎОфОЪ ОюОбОЉОЋОе ОљОю <ph name="BEGIN_LINK2" />ОЕОЎОеОЋОфОЎ Google<ph name="END_LINK2" />.</translation>
<translation id="1407069428457324124">ОбОЎОдОЋОЉ ОЏОћОћ</translation>
<translation id="1407135791313364759">ОцОфОЎОЌОф ОЏОю ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="1409879593029778104">ОћОЋОеОЊОф <ph name="FILE_NAME" /> ОаОъОаОбОћ ОъОЏОЎОЋОЋОЪ ОЕОћОДОЋОЉОЦ ОЏОЉОе ОДОЎОЎОЮ.</translation>
<translation id="1413446866325418126">РђЈОЕОъОЎОеОф ОаОфОЋОаОЎОЮ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google</translation>
<translation id="1416550906796893042">ОњОеОАОф ОљОцОюОЎОДОдОЎОћ</translation>
<translation id="1419753403124156396">РђЈОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chrome?</translation>
<translation id="1428770807407000502">ОюОЏОЉОЋОф ОљОф ОћОАОаОЏОеОЋОЪ?</translation>
<translation id="1430915738399379752">ОћОЊОцОАОћ</translation>
<translation id="1435593198351412143">РђЈОцОфОЎОЌОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОДОЋОЉОдОЎ PDF</translation>
<translation id="1437543266176261764">ОћОцОбОЎОюОЋОф ОъОфОЉОдОбОф ОЉ-<ph name="APP_NAME" /></translation>
<translation id="1448440926884431741">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОљОеОњОЪ ОљОф ОћОъОЋОдОеОЎОЮ ОЕОЉОъОбОДОЉ ОЉ-Bookmarks</translation>
<translation id="1460751212339734034">ОЌОЋОАОЏОЎОЮ ОќОъОЪ, ОъОДОюОЎОЊОЎОЮ ОцОЌОЋОф</translation>
<translation id="1466383950273130737">РђЈОЉОЌОЎОеОф ОћОЕОцОћ ОЉ-Chrome</translation>
<translation id="1477626028522505441">ОћОЋОеОЊОф <ph name="FILE_NAME" /> ОаОЏОЕОюОћ ОбОДОЉ ОЉОбОЎОЋОф ОЉОЕОеОф.</translation>
<translation id="147982357559798527">ОћОЕОфОаОфОћ</translation>
<translation id="1480287803138246127">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЌОюОД ОъОћОћОЎОАОўОЋОеОЎОћ ОЕОюОџ ОюОљ ОфОЋОдОњ ОЏОљОЪ. ОдОеОЎОџ ОюОцОфОЋОЌ ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОћОъОюОљОћ ОЉ-Chrome ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОЏОЋОюОћ.</translation>
<translation id="1492417797159476138">ОЕОЮ ОћОъОЕОфОъОЕ ОћОќОћ ОЏОЉОе ОаОЕОъОе ОюОљОфОе ОќОћ</translation>
<translation id="1493287004536771723">ОЉОЌОеОф ОюОбОДОЋОЉ ОљОЌОе <ph name="SITE_NAME" /></translation>
<translation id="1496514951988037011">ОЕОЮ ОъОЕОфОъОЕ</translation>
<translation id="1501480321619201731">ОъОЌОЎОДОф ОДОЉОЋОдОћ</translation>
<translation id="1502010315804028179">РђЈОЏОЊОЎ ОюОаОћОю ОљОф ОћОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Google Play Services</translation>
<translation id="1506061864768559482">ОъОаОЋОб ОЌОЎОцОЋОЕ</translation>
<translation id="1513352483775369820">ОАОЎОъОаОЎОЋОф ОЋОћОЎОАОўОЋОеОЎОЎОф ОљОфОеОЎОЮ</translation>
<translation id="1513858653616922153">ОъОЌОЎОДОф ОАОЎОАОъОћ</translation>
<translation id="1515901671075971249">ОъОДОЕОЎ ОДОЎОдОЋОе ОюОаОЎОЋОЋОў ОЉОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="1521774566618522728">ОАОаОЏОеОЋОЪ ОљОЌОеОЋОЪ: ОћОЎОЋОЮ</translation>
<translation id="153446405401665083">РђЈОЎОЕ ОњОеОАОћ ОЌОЊОЕОћ ОЕОю Chrome</translation>
<translation id="1540012742443808215">ОАОеОњОю ОћОЏОфОЋОЉОЋОф ОаОъОдОљ ОЏОеОњОб ОЉОЌОюОД ОћОбОюОЎОЋОЪ</translation>
<translation id="1543379346429265919">{BOOKMARKS_COUNT,plural, =1{РђЈОАОЎОъОаОЎОЎОћ ОљОЌОф ОЕОъОЋОеОћ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОбОюОЎОџ ОюОЕОъОЋОе ОљОЋОфОћ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}one{РђЈРђФ# ОАОЎОъОаОЎОЋОф ОЕОъОЋОеОЋОф ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}two{РђЈРђФ# ОАОЎОъОаОЎОЋОф ОЕОъОЋОеОЋОф ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}other{РђЈРђФ# ОАОЎОъОаОЎОЋОф ОЕОъОЋОеОЋОф ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}}</translation>
<translation id="1544084554881119930">РђЈОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЋОЏОфОЋОЉОЋОф ОюОљ ОЎОЋОдОцОаОЋ. ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЉ-Chrome ОюОљ ОфОАОЋОаОЏОеОЪ.
ОеОД ОъОЎ ОЕОЎОЋОЊОб ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЎОЏОЋОю ОюОДОеОЋОљ ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОЋОдОцОаОЎОЮ. ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОюОљ ОаОЕОюОЌ ОљОю Google ОЋОюОљ ОъОљОЋОЌОАОЪ ОЉ-Google. ОљОЮ ОЕОЏОЌОф ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОЕОЉОеОдОЋОаОџ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, <ph name="BEGIN_LINK" />ОбОюОЎОџ ОюОаОДОЋОф ОљОф ОаОфОЋОаОЎ Chrome ОЉОЌОЕОЉОЋОЪ<ph name="END_LINK" />.</translation>
<translation id="1544826120773021464">РђЈОЏОЊОЎ ОюОаОћОю ОљОф ОЌОЕОЉОЋОЪ Google, ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОћОЏОцОфОЋОе "ОаОЎОћОЋОю ОћОЌОЕОЉОЋОЪ"</translation>
<translation id="1549000191223877751">ОћОбОЉОеОћ ОюОЌОюОЋОЪ ОћОљОЌОе</translation>
<translation id="1553358976309200471">РђЈОЏОЊОљОЎ ОюОбОЊОЏОЪ ОљОф Chrome</translation>
<translation id="1554532453982918912">РђЈОћОъОЊОЊОЎОЮ ОЕОЎОЕОЋОфОцОЋ ОЎОбОќОеОЋ ОЉОЕОЎОцОЋОе Chrome ОЉОЕОЉОЎОю ОљОаОЕОЎОЮ ОЕОъОЕОфОъОЕОЎОЮ ОЉОЋ ОЉОдОЋОеОћ ОЊОЋОъОћ ОюОЕОюОџ</translation>
<translation id="1568636008098739136">ОћОљОќОаОћ ОюОЊОБ ОћОќОћ. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="1571041387761170095">ОљОЎОЪ ОАОЎОАОъОљОЋОф ОЌОюОЕОЋОф ОљОЋ ОАОЎОАОъОљОЋОф ОЉОЕОЎОъОЋОЕ ОЌОЋОќОе</translation>
<translation id="1571304935088121812">ОћОбОфОДОф ОЕОЮ ОъОЕОфОъОЕ</translation>
<translation id="1578591621182011812">{NUM_PASSWORDS,plural, =1{ОЎОЕ ОЉОъОЏОЕОЎОе ОћОќОћ ОАОЎОАОъОћ ОљОЌОф ОЕОаОЌОЕОцОћ}one{ОЎОЕ ОЉОъОЏОЕОЎОе ОћОќОћ # ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}two{ОЎОЕ ОЉОъОЏОЕОЎОе ОћОќОћ # ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}other{ОЎОЕ ОЉОъОЏОЕОЎОе ОћОќОћ # ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ}}</translation>
<translation id="1594635596540195766">ОЉОеОЕОЎОъОћ ОЕОЉОћОъОЕОџ ОЎОЕ <ph name="SUGGESTIONS_COUNT" /> ОћОдОбОЋОф ОюОцОеОЎОўОЎОЮ.</translation>
<translation id="1598163867407640634">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОљОфОе <ph name="SITE_ETLD_PLUS_ONE" /> ОбОЮ ОћОЌОЕОЉОЋОЪ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="160275202205869636">РђЈОЏОЕОћОћОњОЊОеОћ ОъОЋОцОбОюОф, ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОаОфОЋОаОЎОЮ ОЋОћОЮ ОаОЕОъОеОЎОЮ ОЉОЌОЕОЉОЋОЪ Google. ОЏОЕОћОћОњОЊОеОћ ОъОЋОЕОЉОфОф, ОћОаОфОЋОаОЎОЮ ОаОЕОъОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="1628019612362412531">{NUM_SELECTED,plural, =1{ОћОАОеОф ОцОеОЎОў ОљОЌОЊ ОЕОаОЉОЌОе}one{ОћОАОеОф # ОцОеОЎОўОЎОЮ ОЕОаОЉОЌОеОЋ}two{ОћОАОеОф # ОцОеОЎОўОЎОЮ ОЕОаОЉОЌОеОЋ}other{ОћОАОеОф # ОцОеОЎОўОЎОЮ ОЕОаОЉОЌОеОЋ}}</translation>
<translation id="163206315857427258">{BOOKMARKS_COUNT,plural, =1{РђЈОАОЎОъОаОЎОЎОћ ОљОЌОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}one{РђЈРђФ# ОАОЎОъОаОЎОЋОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}two{РђЈРђФ# ОАОЎОъОаОЎОЋОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}other{РђЈРђФ# ОАОЎОъОаОЎОЋОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}}</translation>
<translation id="1639239467298939599">ОЉОўОбОЎОаОћ</translation>
<translation id="1641113438599504367">ОњОюОЎОЕОћ ОЉОўОЋОЌОћ</translation>
<translation id="164269334534774161">ОќОћОЋ ОбОЋОфОД ОљОЋОцОюОЎОЎОЪ ОЕОю ОћОЊОБ ОћОќОћ Оъ-<ph name="CREATION_TIME" /></translation>
<translation id="1644574205037202324">ОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="1645262572857218659">ОЏОаОЎОАОћ ОЊОеОџ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="1671236975893690980">ОћОћОЋОеОЊОћ ОфОЎОЏОБ ОфОфОЌОЎОюРђд</translation>
<translation id="1672586136351118594">ОљОЎОЪ ОюОћОдОЎОњ ОЕОЋОЉ</translation>
<translation id="1680919990519905526">РђЈОДОаОЎОЎОф ОъОЋОдОе ОбОЮ Google Lens <ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="1687482373098770139">РђЈОЉОДОеОЋОЉ ОЎОЋОдОњ ОюОџ ОфОЋОЏОЪ ОъОљОфОе <ph name="SITE_NAME" />, ОЋОфОЋОЏОЪ ОюОњОЉОЎОЋ, ОЉОДОўОб 'ОЉОъОбОДОЉ'. ОћОљОфОеОЎОЮ ОЋОћОЌОЎОцОЋОЕОЎОЮ ОЕОЉОъОбОДОЉ ОаОЕОъОеОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОЉОЏОю ОЕОюОЉ ОљОцОЕОе ОюОаОћОю ОљОф ОћОцОеОЎОўОЎОЮ ОЕОЉОъОбОДОЉ ОЉОћОњОЊОеОЋОф.</translation>
<translation id="1689333818294560261">ОЏОЎОаОЋОЎ</translation>
<translation id="1696555181932908973">ОљОцОЕОе ОюОаОАОЋОф ОюОћОъОЕОЎОџ ОЉОЊОеОЏОЎОЮ ОљОЌОеОЋОф ОЉ-<ph name="SITE_ETLD_PLUS_ONE" />.</translation>
<translation id="1702543251015153180">ОеОЋОдОћ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОЋОф ОЕОю ОћОбОЎОдОЋОЉ ОћОЏОћОћ?</translation>
<translation id="1702907158640575240">ОЊОцОЊОцОЪ ОъОаОЋОћОю</translation>
<translation id="1718835860248848330">ОъОћОЕОбОћ ОћОљОЌОеОЋОаОћ</translation>
<translation id="1724977129262658800">ОЎОЕ ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЏОЊОЎ ОюОбОеОЋОџ ОљОф ОћОАОЎОАОъОћ</translation>
<translation id="1726477445370128854">РђЈОљОцОЕОе ОюОњОюОЋОЕ ОЋОюОЌОцОЕ ОъОћОе ОЎОЋОфОе ОЏОЕОъОбОеОЏОф Chrome ОъОЉОдОбОф ОћОбОеОЏОћ ОюОњОЉОЎ ОЊОцОЎОЮ ОЕОћОъОЕОфОъОЕ ОЎОбОЉОЋОе ОљОюОЎОћОЮ ОЋОўОЋОбОаОф ОљОЋОфОЮ ОъОеОљОЕ</translation>
<translation id="1728803206919861584">ОюОЕОъОЋОе ОљОф ОъОцОфОЌ ОћОњОЎОЕОћ ОъОЌОЋОЦ ОюОъОдОЉ ОћОцОеОўОЎ?</translation>
<translation id="1732514748744806741">ОљОЮ ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОЎОЎОЌОЕОцОЋ ОюОљОЌОеОЎОЮ, ОљОаОЌОаОЋ ОаОЋОЊОЎОб ОюОџ</translation>
<translation id="1747593111377567311">{NUM_SITES,plural, =1{ОљОфОе ОљОЌОЊ ОЕОюОЌ ОюОљОЌОеОЋОаОћ ОћОеОЉОћ ОћОфОеОљОЋОф}one{РђФ# ОљОфОеОЎОЮ ОЕОюОЌОЋ ОћОеОЉОћ ОћОфОеОљОЋОф ОюОљОЌОеОЋОаОћ}two{РђФ# ОљОфОеОЎОЮ ОЕОюОЌОЋ ОћОеОЉОћ ОћОфОеОљОЋОф ОюОљОЌОеОЋОаОћ}other{РђФ# ОљОфОеОЎОЮ ОЕОюОЌОЋ ОћОеОЉОћ ОћОфОеОљОЋОф ОюОљОЌОеОЋОаОћ}}</translation>
<translation id="1749561566933687563">ОАОаОЏОеОЋОЪ ОћОАОЎОъОаОЎОЋОф ОЕОюОџ</translation>
<translation id="1750238553597293878">РђЈОћОъОЕОџ ОћОЕОЎОъОЋОЕ ОЉОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="17513872634828108">ОЏОеОўОЎОАОЎОЋОф ОцОфОЋОЌОЋОф</translation>
<translation id="1755203724116202818">ОЏОЊОЎ ОюОъОЊОЋОЊ ОљОф ОЉОЎОдОЋОбОЎ ОћОъОЋОЊОбОЋОф, ОеОД ОАОЋОњОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЕОю ОаОфОЋОаОЎОЮ ОЎОЕОЋОфОцОЋ ОЉОЎОЪ ОљОфОеОЎОЮ. ОюОъОЕОю, ОљОЮ ОЉОЎОдОбОф ОеОЏОЎОЕОћ ОљОЌОеОЎ ОЉОЎОДОЋОе ОЉОљОфОе.</translation>
<translation id="1757620656501361327">РђЈОбОЊОЏОЋОЪ ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="1760873718737761808">{FILE_COUNT,plural, =1{ОЊОцОЎОЮ, ОЊОБ ОљОЌОЊ ОЉОеОЕОЎОъОћ}one{ОЊОцОЎОЮ, # ОЊОцОЎОЮ ОЉОеОЕОЎОъОћ}two{ОЊОцОЎОЮ, # ОЊОцОЎОЮ ОЉОеОЕОЎОъОћ}other{ОЊОцОЎОЮ, # ОЊОцОЎОЮ ОЉОеОЕОЎОъОћ}}</translation>
<translation id="1771929606532798550">РђЈОъОЎОЊОб ОбОю ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЕОюОџ ОЉ-Chrome ОаОЕОюОЌ ОљОю Google, ОљОЉОю ОћОЋОљ ОюОљ ОъОЕОЋОЎОџ ОљОюОЎОџ\n\nОљОЮ Chrome ОДОЋОеОА, ОћОцОеОўОЎОЮ ОЉОаОЋОњОб ОюОДОеОЎОАОћ ОбОЕОЋОЎОЎОЮ ОюОћОЏОЎОю ОњОЮ ОцОеОўОЎОЮ ОљОЎОЕОЎОЎОЮ\n\nОљОЮ ОћОћОЎОАОўОЋОеОЎОћ ОъОАОЋОаОЏОеОаОф ОбОЮ ОЌОЕОЉОЋОЪ Google, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОъОЊОЊОЎОЮ ОЎОЏОюОюОЋ ОњОЮ ОъОЎОЊОб ОбОю ОЏОфОЋОЉОЋОф Оћ-URL ОЕОЉОЎОДОеОф ОЉОћОЪ</translation>
<translation id="1778457539567749232">ОАОЎОъОЋОЪ ОЏОЏОеОўОЎОАОЎОЎОћ ОЕОюОљ ОаОДОеОљОћ</translation>
<translation id="1779766957982586368">ОАОњОЎОеОф ОЌОюОЋОЪ</translation>
<translation id="1780023393214832643">ОћОАОЎОАОъОљОЋОф ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ <ph name="USERNAME" /></translation>
<translation id="1791662854739702043">ОъОЋОфОДОЪ</translation>
<translation id="1792959175193046959">ОљОцОЕОе ОфОъОЎОЊ ОюОЕОаОЋОф ОљОф ОъОЎОДОЋОЮ ОћОћОЋОеОЊОЋОф</translation>
<translation id="1796666869097395659">ОъОќОбОЋОе ОћОЏОеОўОЎОАОЎОЎОћ ОЏОЊОЎ ОюОЌОќОЋОе ОљОюОЎОћ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="1807246157184219062">ОЉОћОЎОе</translation>
<translation id="1807709131360304325">ОцОфОЎОЌОф ОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="1810845389119482123">ОћОћОњОЊОеОћ ОћОеОљОЕОЋОаОЎОф ОЕОю ОћОАОаОЏОеОЋОЪ ОюОљ ОћОЋОЕОюОъОћ</translation>
<translation id="1812027881030482584">Ою-<ph name="SITE_ETLD_PLUS_ONE" /> ОљОЎОЪ ОљОцОЕОеОЋОф ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉ-<ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="1820408774134375111">ОњОЎОюОЎОЋОЪ ОфОЌОфОЋОЪ ОЕОю ОЏОаОЎОАОћ</translation>
<translation id="1825772852827001597">РђЈОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЋОЏОфОЋОЉОЋОф ОЕОаОЕОъОеОЋ ОЉ-Google Pay ОюОљ ОЎОЋОдОцОаОЋ. ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЉ-Chrome ОюОљ ОфОАОЋОаОЏОеОЪ.
ОеОД ОъОЎ ОЕОЎОЋОЊОб ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЎОЏОЋОю ОюОДОеОЋОљ ОљОф ОћОаОфОЋОаОЎОЮ ОћОъОЋОдОцОаОЎОЮ. ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОюОљ ОаОЕОюОЌ ОљОю Google ОЋОюОљ ОъОљОЋОЌОАОЪ ОЉ-Google. ОљОЮ ОЕОЏОЌОф ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОЕОЉОеОдОЋОаОџ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, <ph name="BEGIN_LINK" />ОбОюОЎОџ ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ Chrome ОЉОЌОЕОЉОЋОЪ<ph name="END_LINK" />.</translation>
<translation id="1829244130665387512">ОЌОЎОцОЋОЕ ОЉОЊОБ</translation>
<translation id="1832459821645506983">ОЏОЪ, ОљОаОЎ ОеОЋОдОћ</translation>
<translation id="1845958458910716240">РђЈОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОаОфОЋОаОЎОЮ ОЕОюОџ, ОЏОЊОљОЎ ОюОљОцОЕОе Ою-Chrome ОюОћОАОЎОе ОћОеОЕОљОЋОф ОъОљОфОеОЎОЮ ОЕОюОљ ОаОЏОаОАОф ОљОюОЎОћОЮ ОюОљОЌОеОЋОаОћ</translation>
<translation id="1871098866036088250">РђЈОцОфОЎОЌОћ ОЉОЊОцОЊОцОЪ Chrome</translation>
<translation id="1877026089748256423">РђЈChrome ОљОЎОаОЋ ОъОбОЋОЊОЏОЪ</translation>
<translation id="1877073879466606884">ОћОцОеОЋОцОЎОю ОЕОљОюОЎОЋ ОаОЏОаОАОф ОћОЋОљ ОцОеОЋОцОЎОю ОъОаОЋОћОю. ОюОљОЊОъОЎОЪ ОЎОЕ ОљОцОЕОеОЋОф ОюОЕОаОЋОф ОъОеОЌОЋОД ОљОф ОћОњОЊОеОЋОф ОћОцОеОЋОцОЎОю, ОюОаОфОЌ ОъОЎОЊОб ОбОю ОћОЊОцОЊОцОЪ ОЉОљОъОдОбОЋОф ОЊОЋОЌОЋОф ОЋОюОЉОдОб ОъОЕОЎОъОЋОф ОЌОЕОЋОЉОЋОф ОљОЌОеОЋОф.</translation>
<translation id="1879904908408734349">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОћОЏОаОЎОАОћ ОАОњОЋОе</translation>
<translation id="1883903952484604915">ОћОДОЉОдОЎОЮ ОЕОюОЎ</translation>
<translation id="189358972401248634">ОЕОцОЋОф ОљОЌОеОЋОф</translation>
<translation id="1899175549411605574">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОъОЊОЊОЎ ОћОъОЌОЎОеОЎОЮ</translation>
<translation id="1900260903084164610">ОюОЌОЎОдОћ ОбОю ОћОъОЕОџ ОфОфОцОеОЕ ОЏОћОАОЏОъОћ Ою<ph name="BEGIN_TOS_LINK" />ОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф<ph name="END_TOS_LINK" /></translation>
<translation id="1904580727789512086">РђЈОЏОфОЋОЉОЋОф Оћ-URL ОЕОаОЏОаОАОф ОљОюОЎОћОЪ ОаОЕОъОеОЋОф ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="1910950723001426294">ОеОЕОЎОъОф ОљОцОЕОеОЋОЎОЋОф ОћОЕОЎОфОЋОБ ОАОњОЋОеОћ.</translation>
<translation id="191726024256261717">ОЉОЊОЎОДОф ОћОћОеОЕОљОЋОф</translation>
<translation id="1917766536967060661">РђЈОћОњОЎОЕОћ ОЕОюОџ ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф '<ph name="GROUP_NAME" />', ОЋОњОЮ ОћОљОцОЕОеОЋОф ОЕОю <ph name="BLOCKED_MEMBER_FULL_NAME" /> РђЈ(<ph name="BLOCKED_MEMBER_EMAIL" />) ОюОЎОдОЋОе ОљОЎОфОџ ОљОЎОаОўОеОљОДОдОЎОћ ОЉОЕОЎОеОЋОфОЎ Google, ОЎОљОЉОЊОЋ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ.</translation>
<translation id="1919130412786645364">РђЈОћОфОеОф ОЏОаОЎОАОћ ОљОю Chrome</translation>
<translation id="1922362554271624559">ОЕОцОЋОф ОъОЋОдОбОЋОф</translation>
<translation id="1924255092154549435">ОћОЏОеОўОЎОАОЎОЎОћ ОъОЋОеОЌОЉОф</translation>
<translation id="1925021887439448749">ОЎОЕ ОюОћОќОЎОЪ ОЏОфОЋОЉОф ОљОЎОаОўОеОаОў ОъОЋОфОљОъОф ОљОЎОЕОЎОф</translation>
<translation id="1928618076168182477">ОъОЋОдОњОф ОфОдОЋОњОћ ОъОЋОеОЌОЉОф</translation>
<translation id="1928696683969751773">ОбОЊОЏОЋОаОЎОЮ</translation>
<translation id="1939549834451474504">РђЈОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОДОеОЋОЉ ОЏОЎ ОЌОЉОЎОюОф Google Play Services ОюОљ ОќОъОЎОаОћ. ОљОцОЕОе ОюОЎОдОЋОе ОбОЋОфОД ОЕОю ОћОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОюОцОаОЎ ОЕОћОЪ ОЎОцОАОЎОДОЋ ОюОцОбОЋОю. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="1943398124995840148">РђЈОћОЏОеОўОЎОАОЎОЋОф ОћОцОфОЋОЌОЋОф ОЕОюОџ ОќОЏОЋ ОюОъОеОљОћ ОъОбОЋОЊОЏОЪ ОЉ-XR</translation>
<translation id="1943432128510653496">ОЕОъОЎОеОф ОАОЎОАОъОљОЋОф</translation>
<translation id="1944535645109964458">ОљОЎОЪ ОъОцОфОЌОЋОф ОњОЎОЕОћ ОќОъОЎОаОЎОЮ</translation>
<translation id="1957557050935255529">РђЈОДОЋОЉОЦ Оћ-PDF ОЉОўОбОЎОаОћРђд</translation>
<translation id="1959679933317802873">ОЉОћОъОфОаОћ ОюОфОЋОЏОЪ</translation>
<translation id="1960290143419248813">РђЈОбОЊОЏОЋОаОЎ Chrome ОюОљ ОаОфОъОЏОЎОЮ ОЎОЋОфОе ОЉОњОеОАОћ ОћОќОЋ ОЕОю Android</translation>
<translation id="1963056249988316027">ОЉОЊОЎОДОф ОћОќОћОЋОф ОъОЋОцОбОюОф ОЋОюОљ ОаОЎОфОЪ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="1963976881984600709">ОћОњОаОћ ОеОњОЎОюОћ</translation>
<translation id="1966710179511230534">ОЎОЕ ОюОбОЊОЏОЪ ОљОф ОцОеОўОЎ ОћОЏОаОЎОАОћ ОЕОюОџ.</translation>
<translation id="1969037871259811890">РђЈОъОЌОЎОДОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОюОљ ОъОЋОЉОЎОюОћ ОюОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google. ОЏОЊОЎ ОюОбОЕОЋОф ОљОф ОќОћ, <ph name="BEGIN_LINK1" />ОдОеОЎОџ ОюОдОљОф ОъОћОЌОЕОЉОЋОЪ ОЉ-Chrome<ph name="END_LINK1" />.</translation>
<translation id="197288927597451399">ОЕОъОЎОеОћ</translation>
<translation id="1973912524893600642">ОЕОъОЎОеОф ОћОаОфОЋОаОЎОЮ</translation>
<translation id="1974060860693918893">ОъОфОДОЊОЮ</translation>
<translation id="1984087999855033707">ОъОАОцОе ОўОюОцОЋОЪ</translation>
<translation id="1984417487208496350">ОюОюОљ ОћОњОаОћ (ОюОљ ОъОЋОъОюОЦ)</translation>
<translation id="1986685561493779662">ОћОЕОЮ ОЏОЉОе ОДОЎОЎОЮ</translation>
<translation id="200114059308480249">РђЈОюОЏОюОЋОю ОљОф ОћОўОДОАОў ОЕОъОАОЉОЎОЉ ОЉОЌОЎОцОЋОЕОЎОЮ ОЉ-Google?</translation>
<translation id="2021896219286479412">ОцОДОЊОЎ ОљОфОе ОЉОъОАОџ ОъОюОљ</translation>
<translation id="2038563949887743358">ОћОцОбОюОћ ОЕОю 'ОЉОДОЕОф ОљОфОе ОбОЉОЋОе ОъОЌОЕОЉ ОЕОЋОюОЌОаОЎ'</translation>
<translation id="204321170514947529">РђЈОю-<ph name="APP_NAME" /> ОЎОЕ ОаОфОЋОаОЎОЮ ОњОЮ ОЉ-Chrome</translation>
<translation id="2047378580182589770">ОЏОЊОЎ ОюОдОљОф ОъОћОъОдОЉ ОћОцОеОўОЎ, ОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОљОеОЋОЏОћ</translation>
<translation id="2049574241039454490"><ph name="FILE_SIZE_OF_TOTAL" /> <ph name="SEPARATOR" /> <ph name="DESCRIPTION" /></translation>
<translation id="2051669996101374349">РђЈОЎОЕ ОюОћОЕОфОъОЕ ОЉ-HTTPS ОЏОЕОљОцОЕОе, ОЋОюОДОЉОю ОљОќОћОеОћ ОюОцОаОЎ ОЕОўОЋОбОаОЎОЮ ОљОфОеОЎОЮ ОЕОюОљ ОфОЋОъОЏОЎОЮ ОЉ-HTTPS. ОюОљ ОаОЎОфОЪ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЏОЎ ОћОћОњОаОћ ОћОъОфОДОЊОъОф ОъОЋОцОбОюОф.</translation>
<translation id="2056878612599315956">ОћОљОфОе ОъОЋОЕОћОћ</translation>
<translation id="2063047797624276601">ОћОљОеОњОЋОЪ ОЕОюОџ ОћОцОбОЎОю ОљОф ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ</translation>
<translation id="2065944887543506430">{FILE_COUNT,plural, =1{ОћОЋОеОЊОћ ОљОЌОф ОаОЏОЕОюОћ}one{# ОћОЋОеОЊОЋОф ОаОЏОЕОюОЋ}two{# ОћОЋОеОЊОЋОф ОаОЏОЕОюОЋ}other{# ОћОЋОеОЊОЋОф ОаОЏОЕОюОЋ}}</translation>
<translation id="2067805253194386918">ОўОДОАОў</translation>
<translation id="2079545284768500474">ОЉОЎОўОЋОю ОћОцОбОЋОюОћ</translation>
<translation id="2082238445998314030">ОфОЋОдОљОћ <ph name="RESULT_NUMBER" /> ОъОфОЋОџ <ph name="TOTAL_RESULTS" /></translation>
<translation id="2088833076121753253">РђЈОЏОЊОЎ ОюОАОЎОЎОЮ ОљОф ОћОћОњОЊОеОћ ОЕОю ОћОъОЎОюОЋОЎ ОћОљОЋОўОЋОъОўОЎ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chrome ОбОЏОЕОЎОЋ. ОћОЏОеОўОЎОАОЎОЋОф ОЎОЎОцОфОЌОЋ ОъОЌОЊОЕ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ.</translation>
<translation id="2091863218454846791">ОъОЋОдОњОф ОфОдОЋОњОћ ОДОЋОъОцОДОўОЎОф</translation>
<translation id="2093731487903423814">15 ОћОЊОДОЋОф ОћОљОЌОеОЋОаОЋОф</translation>
<translation id="2100273922101894616">ОЏОаОЎОАОћ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="2109384632594340939">ОфОъОЋОаОф ОцОеОЋОцОЎОю</translation>
<translation id="2111511281910874386">ОъОбОЉОе ОюОЊОБ</translation>
<translation id="2119609734654412418">ОћОАОЎОъОаОЎОЋОф ОќОъОЎОаОЋОф ОЏОљОЪ</translation>
<translation id="2122601567107267586">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОцОфОЋОЌ ОљОф ОћОЎОЎОЕОЋОЮ</translation>
<translation id="213279576345780926">ОћОЏОеОўОЎОАОЎОЎОћ "<ph name="TAB_TITLE" />" ОаОАОњОеОћ</translation>
<translation id="2141396931810938595">ОбОю ОАОъОџ ОћОЕОЎОъОЋОЕ ОЕОюОџ</translation>
<translation id="2145315049852051678">РђЈРђФChrome ОъОЋОЋОЊОљ ОЉОДОЉОЎОбОЋОф ОЕОюОЊОцОЊОцОЪ ОЕОюОџ ОЎОЕ ОљОф ОћОћОњОЊОеОЋОф ОћОЉОўОЋОЌОЋОф ОЉОЎОЋОфОе. ОаОЋОЊОЎОб ОюОџ ОљОЮ ОдОеОЎОџ ОюОЉОЊОЋОД ОъОЕОћОЋ.</translation>
<translation id="2149973817440762519">ОбОеОЎОЏОф ОАОЎОъОаОЎОЋОф</translation>
<translation id="2158408438301413340">РђЈChrome ОюОљ ОћОдОюОЎОЌ ОюОЉОЊОЋОД ОљОф ОЏОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="2163089732491971196">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chrome ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google, ОбОюОЎОџ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОЕОюОџ</translation>
<translation id="2166228530126694506">ОњОеОАОћ <ph name="VERSION_NUMBER" /></translation>
<translation id="2172688499998841696">ОћОфОЏОЋОаОћ 'ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф' ОъОЋОЕОЉОфОф</translation>
<translation id="2172905120685242547">ОюОАОњОЋОе ОљОф ОћОЌОюОЋОЪ?</translation>
<translation id="2173302385160625112">ОЎОЕ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў</translation>
<translation id="2175927920773552910">РђЈОДОЋОЊ QR</translation>
<translation id="2181097965834437145">ОћОдОњОћ ОљОЋ ОћОАОфОеОћ ОЕОю ОАОеОњОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="2184272387334793084">ОЏОЊОљОЎ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЏОЊОЎ ОЕОћОАОЎОАОъОљОЋОф ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЎОЋОцОЎОбОЋ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="218608176142494674">ОЕОЎОфОЋОБ</translation>
<translation id="219283042927675668">ОЏОеОўОЎОАОЎОЋОф ОЉОДОЉОЋОдОћ</translation>
<translation id="2194856509914051091">ОъОћ ОЏОЊОљОЎ ОюОДОЌОф ОЉОЌОЕОЉОЋОЪ</translation>
<translation id="22091350895006575">ОћОЋОАОцОћ ОЕОю ОЕОЮ ОћОъОЕОфОъОЕ</translation>
<translation id="221494669172414749">РђЈОцОфОЎОЌОф Chrome ОЉОюОЎ ОаОбОЎОюОф ОцОеОЋОцОЎОю ОфОњОеОЋОЮ ОюОћОАОеОф ОћОАОЎОАОъОљОЋОф ОЋОљОъОдОбОЎ ОћОфОЕОюОЋОЮ ОћОЕОъОЋОеОЎОЮ ОъОћОъОЏОЋОаОЎОф. ОЕОЎОъОЋОЕ ОЉОаОбОЎОюОф ОцОеОЋОцОЎОю ОбОЋОќОе ОюОЕОъОЋОе ОбОю ОљОЉОўОЌОф ОћОаОфОЋОаОЎОЮ ОћОљОюОћ.</translation>
<translation id="2227444325776770048">ОћОъОЕОџ ОЉОЕОЮ <ph name="USER_FULL_NAME" /></translation>
<translation id="2230777942707397948">ОЌОюОЋОЪ ОеОЎОД</translation>
<translation id="223356358902285214">ОцОбОЎОюОЋОф ОЉОљОЎОаОўОеОаОў ОЋОЉОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="2234827758954819389">ОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф</translation>
<translation id="2239812875700136898">РђЈОЉОбОќОеОф ОћОЏОцОфОЋОе 'ОљОцОЕОеОЋОЎОЋОф ОЕОю Discover' ОаОЎОфОЪ ОюОДОЉОЋОб ОљОЎОюОЋ ОъОљОъОеОЎОЮ ОЎОЋОдОњОЋ</translation>
<translation id="2247789808226901522">ОфОЋОДОБ ОћОЏОеОўОЎОА ОцОњ</translation>
<translation id="2248941474044011069">РђЈОћОАОЎОАОъОљОЋОф ОЕОюОџ ОъОЋОдОцОаОЋОф ОЉОъОЏОЕОЎОе ОюОцОаОЎ ОЕОћОЪ ОаОЕОъОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="2249635629516220541">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОъОЎОЊОб ОЕОъОЕОъОЕ ОљОфОеОЎОЮ ОюОћОдОњОф ОъОЋОЊОбОЋОф</translation>
<translation id="2253927598983295051">ОЉОЌОЎОеОф ОћОъОЎОЊОб ОЕОЎОЕОЋОфОБ ОбОЮ <ph name="APP_NAME" /></translation>
<translation id="2259659629660284697">ОЎОЎОдОЋОљ ОАОЎОАОъОљОЋОфРђд</translation>
<translation id="2276696007612801991">РђЈОЎОЕ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ Google ОЏОЊОЎ ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ</translation>
<translation id="2278052315791335171">ОъОЌОЎОДОф ОћОАОЎОАОъОћ ОћОќОЋ ОюОљ ОфОњОеОЋОЮ ОюОъОЌОЎОДОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉОљОфОе <ph name="SITE" />.</translation>
<translation id="2281243904606300427">РђФ<ph name="TAB_TITLE" />, ОћОЏОеОўОЎОАОЎОЎОћ ОћОцОеОўОЎОф ОЕОаОЉОЌОеОћ</translation>
<translation id="2286841657746966508">ОЏОфОЋОЉОф ОюОЌОЎОЋОЉ</translation>
<translation id="228704530595896923">ОеОЕОЎОъОф ОљОцОЕОеОЋОЎОЋОф ОћОЕОЎОфОЋОБ.</translation>
<translation id="2287421207599770907">{NUMBER_OF_TABS,plural, =1{ОћОдОњОф ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TABS_COUNT_ONE" />)}one{ОћОдОњОф <ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}two{ОћОдОњОф <ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}other{ОћОдОњОф <ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="2297822946037605517">ОЕОфОБ ОЊОБ ОќОћ</translation>
<translation id="230115972905494466">ОюОљ ОаОъОдОљОЋ ОъОЏОЕОЎОеОЎОЮ ОфОЋОљОъОЎОЮ</translation>
<translation id="2318045970523081853">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОфОДОЕОе</translation>
<translation id="2321086116217818302">ОћОъОбОеОЏОф ОъОЏОЎОаОћ ОљОф ОћОАОЎОАОъОљОЋОфРђд</translation>
<translation id="2323763861024343754">ОаОфОЋОаОЎ ОљОфОе ОъОљОЋОЌОАОаОЎОЮ</translation>
<translation id="2328474416100889417">ОЏОЋОюОЮ ОЎОљОЉОЊОЋ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ ОљОф ОћОњОЎОЕОћ ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф '<ph name="GROUP_NAME" />' ОЋОЏОю ОћОДОЎОЕОЋОеОЎОЮ ОюОћОќОъОаОћ ОЎОЋОЕОЉОфОЋ</translation>
<translation id="2332515770639153015">ОћОњОеОАОћ ОћОъОЕОЋОцОеОф ОЕОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОъОЋОцОбОюОф</translation>
<translation id="233375395665273385">ОъОЌОЎОДОћ ОЋОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ</translation>
<translation id="2341410551640223969">ОюОљ ОћОдОюОЌОаОЋ ОюОћОфОДОЎОЪ ОљОф <ph name="WEBAPK_NAME" />.</translation>
<translation id="2349710944427398404">РђЈОАОџ ОЏОю ОћОаОфОЋОаОЎОЮ ОЕОЉОћОЮ ОъОЕОфОъОЕ Chrome, ОЏОЋОюОю ОЌОЕОЉОЋОаОЋОф, ОАОЎОъОаОЎОЋОф ОЋОћОњОЊОеОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="2349954856814571872">ОАОъОю ОЕОю ОЏОцОфОЋОе ОАОеОњОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="235789365079050412">РђЈОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф ОЕОю Google</translation>
<translation id="2359808026110333948">ОћОъОЕОџ</translation>
<translation id="2362083820973145409">ОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ ОЉОфОЋОе <ph name="USER_NAME" />. <ph name="USER_EMAIL" />. ОћОћОњОЊОеОЋОф ОЎОЎОцОфОЌОЋ.</translation>
<translation id="2363734411417672757">РђЈОЎОЋОфОе ОЊОцОЎОЮ ОаОўОбОаОЎОЮ ОъОеОљОЕ. ОћОЕОеОфОЎОЮ ОЕОю Google ОЎОЏОЋОюОЎОЮ ОюОўОбОЋОЪ ОЊОцОЎОЮ ОъОеОљОЕ ОюОцОЎ ОЉОДОЕОћ ОЕОю ОљОфОеОЎОЮ ОљОЌОеОЎОЮ ОљОЋ ОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф.</translation>
<translation id="2366554533468315977">ОћОЎОАОўОЋОеОЎОЎОф ОћОъОЌОЎОеОЎОЮ ОЕОю ОћОљОцОЕОеОЋОф ОћОќОЋ ОЉОљОЎОаОўОеОаОў</translation>
<translation id="2367818124433749493">ОДОЎОдОЋОеОЎ ОЊОеОџ ОюОъОцОфОЌОЎОЮ</translation>
<translation id="2385605401818128172">ОљОцОЕОе ОюОЉОЊОЋОД ОљОфОеОЎОЮ ОЕОЕОЋОюОЌОЎОЮ ОћОеОЉОћ ОћОфОеОљОЋОф ОЋОюОъОаОЋОб ОъОћОЮ ОюОЕОюОЋОЌ ОбОЋОЊ ОћОфОеОљОЋОф ОЉОбОфОЎОЊ</translation>
<translation id="2386938421315164605">ОћОАОфОеОћ ОЋОЉОЎОўОЋОю ОћОАОфОеОћ ОЕОю ОаОЋОЕОљОЎОЮ</translation>
<translation id="2390510615457643724">ОеОЋОдОћ ОюОћОЋОеОЎОЊ ОЕОЋОЉ ОљОф <ph name="FILE_NAME" /> (<ph name="FILE_SIZE" />)?</translation>
<translation id="2410754283952462441">ОЉОЌОЎОеОф ОЌОЕОЉОЋОЪ</translation>
<translation id="2413014528833954543">ОюОљ ОаОЎОфОЪ ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="2414886740292270097">ОЏОћОћ</translation>
<translation id="2421705177906985956">ОљОЎОЪ ОЏОеОњОб ОљОфОеОЎОЮ ОЕОљОцОЕОе ОюОћОдОЎОњ</translation>
<translation id="2426805022920575512">ОЉОЌОЎОеОф ОЌОЕОЉОЋОЪ ОљОЌОе</translation>
<translation id="2427025860753516072">{FILE_COUNT,plural, =1{ОАОеОўОЋОаОЎОЮ, ОАОеОўОЋОЪ ОљОЌОЊ ОЉОеОЕОЎОъОћ}one{ОАОеОўОЋОаОЎОЮ, # ОАОеОўОЋОаОЎОЮ ОЉОеОЕОЎОъОћ}two{ОАОеОўОЋОаОЎОЮ, # ОАОеОўОЋОаОЎОЮ ОЉОеОЕОЎОъОћ}other{ОАОеОўОЋОаОЎОЮ, # ОАОеОўОЋОаОЎОЮ ОЉОеОЕОЎОъОћ}}</translation>
<translation id="2433507940547922241">ОъОеОљОћ</translation>
<translation id="2435457462613246316">ОћОдОњОф ОАОЎОАОъОћ</translation>
<translation id="2439153523196674349">ОфОдОЋОњОћ ОъОДОЊОЎОъОћ ОЕОю <ph name="SITE_NAME" /></translation>
<translation id="2449931042095204989">РђЈОЏОЕОљОфОе ОљОЋ ОљОцОюОЎОДОдОЎОћ ОЕОю Google ОъОЉОДОЕОЎОЮ ОюОўОбОЋОЪ ОъОеОљОЕ ОДОЎОЕОЋОеОЎОЮ ОЕОъОЋОцОЎОбОЎОЮ ОЉОЊОБ ОЕОюОћОЮ ОЉОљОЋОцОЪ ОцОеОўОЎ, ОЊОцОЊОцОЪ Chrome ОъОдОцОЎОЪ ОЋОўОЋОбОЪ ОъОеОљОЕ ОљОф ОћОЊОцОЎОЮ ОЉОљОъОдОбОЋОф ОћОЕОеОфОЎОЮ ОЕОю Google ОюОюОљ ОДОЋОЉОдОЎ Cookie. ОЏОџ ОъОЋОАОфОеОф ОћОќОћОЋОф ОЕОюОџ ОъОћОљОфОе ОЕОаОўОбОЪ ОъОеОљОЕ.</translation>
<translation id="2450083983707403292">ОюОћОфОЌОЎОю ОЕОЋОЉ ОљОф ОћОћОЋОеОЊОћ ОЕОю <ph name="FILE_NAME" />?</translation>
<translation id="2451607499823206582">ОЉОъОбОДОЉ</translation>
<translation id="2453860139492968684">ОАОЎОЋОЮ</translation>
<translation id="2461378706168271257">ОЌОЎОцОЋОЕ ОЉОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="2461822463642141190">ОЏОеОњОб</translation>
<translation id="2463770278804271243">ОЊОБ</translation>
<translation id="2468444275314013497">ОаОеОљОћ ОЕОћОЏОЋОю ОЉОАОЊОе ОЉОЊОцОЊОцОЪ ОЕОюОџ</translation>
<translation id="2472163211318554013">РђЈОЏОЊОЎ ОюОћОцОЎОД ОљОф ОћОъОеОЉ Оъ-Chrome, ОбОюОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ</translation>
<translation id="247737702124049222">ОћОфОЏОЋОаОћ 'ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф' ОъОЋОцОбОюОф</translation>
<translation id="2479148705183875116">ОюОъОбОЉОе ОљОю ОћОћОњОЊОеОЋОф</translation>
<translation id="2482878487686419369">ОћОфОеОљОЋОф</translation>
<translation id="2496180316473517155">ОћОЎОАОўОЋОеОЎОЎОф ОњОюОЎОЕОћ</translation>
<translation id="2497852260688568942">ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ ОћОЕОЉОЎОф ОљОф ОћОАОаОЏОеОЋОЪ</translation>
<translation id="250020030759455918">РђЈОЉ-Chrome ОЎОЋОдОњОЋ ОАОўОўОЋОА ОћОЏОаОЎОАОћ ОЕОюОџ Ою-<ph name="SITE_NAME" />, ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЋОаОфОЋОаОЎ ОћОљОфОе</translation>
<translation id="2510106555128151389">ОъОфОЉОдОбОф ОћОфОДОаОћ ОЕОю <ph name="WEBAPK_NAME" />...</translation>
<translation id="2512234228327349533">ОЌОЎОцОЋОЕ ОљОцОЕОеОЋОЎОЋОф ОДОаОЎОЎОћ</translation>
<translation id="2513403576141822879">РђЈОљОцОЕОе ОюОъОдОЋОљ ОћОњОЊОеОЋОф ОаОЋОАОцОЋОф ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф, ОљОЉОўОЌОћ ОЋОљОЎОАОЋОБ ОаОфОЋОаОЎОЮ ОЉОЊОБ <ph name="BEGIN_LINK" />ОАОаОЏОеОЋОЪ ОЋОЕОЎОеОЋОфОЎ Google<ph name="END_LINK" /></translation>
<translation id="2515921719039583189">РђЈОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ Оъ-Chrome ОъОћОъОЏОЕОЎОе ОћОќОћ?</translation>
<translation id="2517113738956581680">ОњОЎОюОЎОЋОЪ ОЉОњОЋОЊОю ОъОюОљ</translation>
<translation id="2523184218357549926">РђЈОЕОюОЎОЌОф ОЏОфОЋОЉОЋОф ОљОфОеОЎОЮ ОЕОю ОЊОцОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф Ою-Google</translation>
<translation id="2524132927880411790">РђЈОъОбОЉОе ОюОЌОЎОцОЋОЕ ОћОДОЋОюОЎ ОЕОю ОљОцОюОЎОДОдОЎОЎОф Google</translation>
<translation id="2527209463677295330">ОеОЋОдОћ ОюОеОљОЋОф ОфОЋОдОљОЋОф ОўОЋОЉОЋОф ОЎОЋОфОе? ОЏОЊОљОЎ ОюОЏОюОЋОю ОЏОъОћ ОЕОЎОЋОфОе ОўОДОАОў ОъОћОЊОБ</translation>
<translation id="2527779675047087889">ОћОАОфОеОф ОћОфОЋОЏОЪ ОЕОЉОюОЋОЌ</translation>
<translation id="2532336938189706096">ОфОдОЋОњОф ОљОЎОаОўОеОаОў</translation>
<translation id="253498598929009420">ОћОљОфОе ОЎОЋОЏОю ОюОеОљОЋОф ОљОф ОфОЋОЏОЪ ОћОъОАОџ ОЕОюОџ</translation>
<translation id="2535807170289627159">ОЏОю ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="2536728043171574184">ОъОЋОдОњ ОћОбОфОД ОюОљ ОъОДОЋОЋОЪ ОЕОю ОбОъОЋОЊ ОќОћ</translation>
<translation id="2542548955756682219">РђФ<ph name="TAB_TITLE" />, ОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="2546283357679194313">РђЈОДОЋОЉОдОЎ Cookie ОЋОаОфОЋОаОЎОЮ ОъОљОфОеОЎОЮ</translation>
<translation id="2547843573592965873">РђЈОаОбОЎОюОф ОћОцОеОЋОцОЎОю ОъОљОЉОўОЌОф ОљОф ОћОъОЎОЊОб ОЕОюОџ ОЉОеОЏОЉ, ОЏОЋОюОю ОАОЎОАОъОљОЋОф, ОфОЕОюОЋОъОЎОЮ ОЋОбОЋОЊ ОъОЎОЊОб ОЕОЕОъОЋОе ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google.</translation>
<translation id="254973855621628293">ОћОАОЎОАОъОљОЋОф ОаОЕОъОеОЋ ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="2567385386134582609">ОфОъОЋОаОћ</translation>
<translation id="2569733278091928697">ОЉОљОъОдОбОЋОф ОћОћОфОеОљОЋОф, ОДОю ОЎОЋОфОе ОюОаОћОю ОљОф ОЉОДОеОЎ ОћОъОЊОЎОћ, ОћОАОЕОаОЎОЮ ОћОцОеОўОЎОЎОЮ, ОћОћОЋОеОЊОЋОф ОЋОбОЋОЊ</translation>
<translation id="2571711316400087311">РђЈОћОдОбОћ ОюОЕОюОЋОЌ ОЊОцОЎОЮ ОЉОЕОцОЋОф ОљОЌОеОЋОф Ою-Google Translate</translation>
<translation id="2571834852878229351">ОЎОдОЎОеОф ОАОЎОАОъОћ ОъОЕОюОЎ</translation>
<translation id="2574249610672786438">РђЈОЏОЊОЎ ОюОеОљОЋОф ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОЕОюОџ ОъОЏОю ОъОДОЋОЮ ОЕОЉОЋ ОцОфОЌОф ОљОф Chrome ОЎОЕ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="2577981599306533385">РђЈОћОњОЎОЕОћ ОЕОю <ph name="MEMBER_FULL_NAME" /> РђЈ(<ph name="EMAIL" />) ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф "<ph name="GROUP_NAME" />", ОЋОњОЮ ОћОљОцОЕОеОЋОф ОюОЎОдОЋОе ОљОЎОфОџ ОљОЎОаОўОеОљОДОдОЎОћ ОЉОЕОЎОеОЋОфОЎ Google, ОЎОљОЉОЊОЋ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ.</translation>
<translation id="2579297619530305344">ОћОАОЎОАОъОљОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОаОцОфОЌОЋ ОЉОъОАОџ ОъОюОљ</translation>
<translation id="2581165646603367611">РђЈОцОбОЋОюОћ ОќОЋ ОфОъОЌОД ОљОф ОДОЋОЉОдОЎ Оћ-Cookie, ОљОф ОћОъОўОъОЋОЪ ОЋОаОфОЋОаОЎОЮ ОљОЌОеОЎОЮ ОЕОю ОљОфОеОЎОЮ ОЕ-Chrome ОюОљ ОъОЌОЕОЎОЉ ОЏОЌОЕОЋОЉОЎОЮ.</translation>
<translation id="2587052924345400782">ОЎОЕ ОњОеОАОћ ОЌОЊОЕОћ ОЎОЋОфОе</translation>
<translation id="2593272815202181319">ОеОЋОЌОЉ ОљОЌОЎОЊ</translation>
<translation id="260403163289591229">ОЉОъОбОДОЉ</translation>
<translation id="2604446170045642109">ОЉОћОњОЊОеОЋОф, ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЏОЉОЋОф ОљОф ОћОбОЎОдОЋОЉ ОћОЏОћОћ ОЉОљОфОеОЎОЮ.</translation>
<translation id="2607441479295509868">ОћОЌОЕОЉОЋОЪ ОюОљ ОъОЌОЋОЉОе. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОАОЎОъОаОЎОЋОф, ОЉОАОЎОАОъОљОЋОф ОЋОЉОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ, ОбОюОЎОџ ОюОћОЎОЏОаОА ОЕОЋОЉ ОюОЌОЕОЉОЋОЪ.</translation>
<translation id="2612676031748830579">ОъОАОцОе ОћОЏОеОўОЎОА</translation>
<translation id="2620314865574742210">ОћОЋОќОъОаОф ОбОю ОЎОЊОЎ <ph name="NAME" /> ОюОњОЕОф ОюОцОеОЎОў ОъОЕОЋОфОБ.</translation>
<translation id="2625189173221582860">ОћОАОЎОАОъОћ ОћОЋОбОфОДОћ</translation>
<translation id="2630630219780173487">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОцОАОЎОД ОљОф ОЕОюОЎОЌОф ОћОћОфОеОљОЋОф ОћОбОфОЎОЊОЎОЋОф ОъОћОљОфОеОЎОЮ ОћОљОюОћ</translation>
<translation id="2634393460268044753">РђЈОЏОфОЋОЉОЋОф Оћ-URL ОЕОю ОћОљОфОеОЎОЮ ОЕОЉОћОЪ ОЉОЎОДОеОф ОЋОЊОњОЎОъОћ ОДОўОаОћ ОЕОю ОфОЋОЏОЪ ОъОћОЊОцОЎОЮ, ОћОЋОеОЊОЋОф, ОцОбОЎОюОЋОф ОЕОю ОфОЋОАОцОЎОЮ ОЋОцОеОўОЎ ОъОбОеОЏОф ОаОЕОюОЌОЎОЮ ОљОю ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОЕОю Google ОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОћОЮ ОъОќОЎОДОЎОЮ.</translation>
<translation id="2643064289437760082">ОфОъОЎОЊ ОљОцОЕОе ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ ОћОъОЊОЎОЊОћ ОЕОю ОЉОЎОдОЋОбОЎ ОћОъОЋОЊОбОЋОф ОбОю ОЎОЊОЎ ОъОЌОЎОДОћ ОЕОю ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ</translation>
<translation id="2647434099613338025">ОюОћОЋОАОцОф ОЕОцОћ</translation>
<translation id="2650077116157640844">ОбОЋОЊ ОЉОъОЏОЕОЎОеОЎОЮ ОъОАОЋОаОЏОеОаОЎОЮ</translation>
<translation id="2650348088770008516">ОћОћОАОЉОе ОбОю ОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф ОаОАОњОе</translation>
<translation id="2650751991977523696">ОћОљОЮ ОюОћОЋОеОЎОЊ ОљОф ОћОДОЋОЉОЦ ОЕОЋОЉ?</translation>
<translation id="265156376773362237">ОўОбОЎОаОћ ОеОњОЎОюОћ ОъОеОљОЕ</translation>
<translation id="2656405586795711023">ОљОцОюОЎОДОдОЎОЋОф ОљОЎОаОўОеОаОў</translation>
<translation id="2664252182805397291">ОћОдОњОф ОљОфОеОЎОЮ</translation>
<translation id="2666092431469916601">ОюОъОбОюОћ</translation>
<translation id="2669454659051515572">ОЏОю ОъОЎ ОЕОъОЕОфОъОЕ ОЉОъОЏОЕОЎОе ОћОќОћ ОЎОЏОЋОю ОюОеОљОЋОф ОљОф ОћОДОЉОдОЎОЮ ОЕОћОЋОеОЊОЋ</translation>
<translation id="2677748264148917807">ОЎОдОЎОљОћ</translation>
<translation id="2687009626279857299">ОћОЕОЎОеОЋОф ОћОцОАОЎОД ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="2702516483241149200">ОЌОЊОЕ: ОаОЎОфОЪ ОюОЕОфОБ ОДОЎОЕОЋОе ОЕОњОЋОюОю ОюОўОДОАОў ОћОќОћ</translation>
<translation id="2708226184420201102">ОцОфОЎОЌОћ ОЉОЊОцОЊОцОЪ <ph name="PRODUCT_NAME" /></translation>
<translation id="271033894570825754">ОЌОЊОЕ</translation>
<translation id="2718352093833049315">РђЈОеОД ОЉ-Wi-Fi</translation>
<translation id="2718846868787000099">ОЏОЊОЎ ОЕОаОЋОЏОю ОюОћОдОЎОњ ОфОЋОЏОЪ ОЉОЕОцОЋОф ОћОъОЋОбОЊОцОЋОф ОбОюОЎОџ, ОћОћОбОЊОцОЋОф ОЕОюОџ ОњОюОЋОЎОЋОф ОюОљОфОеОЎОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ</translation>
<translation id="2723001399770238859">ОљОЋОЊОЎОЋ</translation>
<translation id="2734335652257251631">ОћОдОњОф ОъОдОЉ ОћОДОеОЎОљОћ</translation>
<translation id="2739887572830526131">ОљОцОЕОе ОюОЕОъОЋОе ОљОф ОћОДОЉОЋОдОћ ОћОќОЋ ОЏОЊОЎ ОюОћОЋОАОЎОБ ОЏОеОўОЎОАОЎОЋОф ОъОљОЋОЌОе ОЎОЋОфОе, ОљОЋ ОюОъОЌОЋОД ОљОЋОфОћ ОљОЮ ОљОЎОЪ ОюОџ ОЎОЋОфОе ОдОЋОеОџ ОЉОћ.</translation>
<translation id="2742373789128106053">ОљОЎОЪ ОњОЎОЕОћ ОљОю <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /> ОЏОеОњОб.</translation>
<translation id="2760805590727089264">MM/YY</translation>
<translation id="2760989362628427051">ОбОЎОдОЋОЉ ОЏОћОћ ОъОЋОцОбОю ОЏОЕОЉОъОЏОЕОЎОе ОцОЋОбОюОф ОћОљОцОЕОеОЋОф 'ОбОЎОдОЋОЉ ОЏОћОћ' ОљОЋ 'ОЌОЎОАОЏОЋОЪ ОЉОАОЋОюОюОћ'</translation>
<translation id="2762000892062317888">ОЉОеОњОб ОќОћ</translation>
<translation id="276969039800130567">ОъОЌОЋОЉОе ОЉОљОъОдОбОЋОф ОЌОЕОЉОЋОЪ <ph name="USER_EMAIL_ADDRESS" />.</translation>
<translation id="2777555524387840389">ОаОЋОфОеОЋ <ph name="SECONDS" /> ОЕОаОЎОЋОф</translation>
<translation id="2779651927720337254">ОаОЏОЕОю</translation>
<translation id="2781151931089541271">ОаОЋОфОеОћ ОЕОаОЎОЎОћ ОљОЌОф</translation>
<translation id="2789486458103222910">ОљОЎОЕОЋОе</translation>
<translation id="2791129728587938169">{NUM_PASSWORDS,plural, =1{РђЈРђФChrome ОќОЎОћОћ ОАОЎОАОъОћ ОЉОЕОЎОъОЋОЕ ОЌОЋОќОе ОЕОљОцОЕОе ОюОЕОцОе}one{РђЈРђФChrome ОќОЎОћОћ # ОАОЎОАОъОљОЋОф ОЉОЕОЎОъОЋОЕ ОЌОЋОќОе ОЕОљОцОЕОе ОюОЕОцОе}two{РђЈРђФChrome ОќОЎОћОћ # ОАОЎОАОъОљОЋОф ОЉОЕОЎОъОЋОЕ ОЌОЋОќОе ОЕОљОцОЕОе ОюОЕОцОе}other{РђЈРђФChrome ОќОЎОћОћ # ОАОЎОАОъОљОЋОф ОЉОЕОЎОъОЋОЕ ОЌОЋОќОе ОЕОљОцОЕОе ОюОЕОцОе}}</translation>
<translation id="2800066122460699237">ОћОЏОеОўОЎОАОЎОЎОћ <ph name="TAB_TITLE" /> ОфОЎОАОњОе</translation>
<translation id="2805756323405976993">ОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="281504910091592009">РђЈОћОдОњОћ ОЋОаОЎОћОЋОю ОЕОю ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОЉ<ph name="BEGIN_LINK" />ОЌОЕОЉОЋОЪ Google<ph name="END_LINK" /></translation>
<translation id="2819849308549746319">ОЉОЎОўОЋОю ОћОћОеОЕОъОћ ОюОЏОЋОюОЮ</translation>
<translation id="2826576843404243001">ОъОДОЉОюОЎОЮ ОљОќОћОеОћ ОюОцОаОЎ ОЕОъОЉОДОеОЎОЮ ОЉОљОфОеОЎОЮ ОЕОюОљ ОфОЋОъОЏОЎОЮ ОЉОЌОЎОЉОЋОеОЎОЮ ОъОљОЋОЉОўОЌОЎОЮ. ОюОљ ОаОЎОфОЪ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОЏОЎ ОћОћОњОаОћ ОћОъОфОДОЊОъОф ОъОЋОцОбОюОф.</translation>
<translation id="2827278682606527653">ОфОцОеОЎОў ОЏОеОўОЎОА ОћОцОЎОЊ ОаОцОфОЌ ОЉОЌОдОЎ ОъОњОЋОЉОћ ОћОъОАОџ</translation>
<translation id="2830783625999891985">ОћОфОЋОЏОЪ ОЕОЉОюОЋОЌ ОъОЋОАОфОе</translation>
<translation id="2834884592945939112">РђЈОћОњОЊОеОЋОф, ОЕОњОЎОљОћ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="2838367486340230368">ОћОћОАОЉОе ОбОю ОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф ОаОцОфОЌ ОЉОЌОдОЎ ОћОњОЋОЉОћ</translation>
<translation id="2839327205551510876">ОЉОЋОўОю ОћОъОбОДОЉ ОљОЌОе <ph name="SITE_NAME" /></translation>
<translation id="2840810876587895427">{TAB_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОљОЌОф (<ph name="TAB_COUNT_ONE" />) ОфОЎОАОњОе}one{<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОЎОЎОАОњОеОЋ}two{<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОЎОЎОАОњОеОЋ}other{<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОЎОЎОАОњОеОЋ}}</translation>
<translation id="2841216154655874070">{NUM_DAYS,plural, =1{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ ОЎОЋОЮ ОљОЌОЊ}one{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЎОъОЎОЮ}two{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ ОЎОЋОъОЎОЎОЮ}other{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЎОъОЎОЮ}}</translation>
<translation id="2842985007712546952">ОфОЎОДОЎОЎОф ОљОЉ</translation>
<translation id="2854916915045135148">ОЏОЊОЎ ОюОбОЉОЋОе ОюОъОдОЉ ОцОеОўОЎ, ОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОљОеОЋОЏОћ</translation>
<translation id="2860954141821109167">ОЎОЕ ОюОЋОЋОЊОљ ОЕОъОЋОцОбОюОф ОЉОъОЏОЕОЎОе ОћОќОћ ОљОцОюОЎОДОдОЎОЎОф ОўОюОцОЋОЪ</translation>
<translation id="2861923151411510142">РђЈОЌОюОД ОъОћОфОЏОЋОаОЋОф ОЕОю Chrome ОюОљ ОЎОћОЎОЋ ОќОъОЎОаОЋОф ОЎОЋОфОе</translation>
<translation id="2869430948265924908">ОЏОЊОЎ ОюОћОњОЪ ОбОю ОфОЋОЏОЪ ОеОњОЎОЕ ОЉОеОЏОЉ, ОбОюОЎОџ ОюОЎОдОЋОе ОаОбОЎОюОф ОцОеОЋОцОЎОю ОЉОеОЏОЉ.  ОљОцОЕОе ОюОбОЕОЋОф ОќОљОф ОЉОљОъОдОбОЋОф ОДОЋОЊ ОљОЎОъОЋОф, ОДОЋОЊ ОљОЋ ОАОЎОАОъОћ.</translation>
<translation id="2870560284913253234">ОљОфОе</translation>
<translation id="2871733351037274014">ОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОЊОцОЎОЮ</translation>
<translation id="2876136027428473467">ОаОЕОюОЌОћ Оъ<ph name="CHILD_NAME" /> ОЉОДОЕОћ ОюОљОЎОЕОЋОе ОЏОЊОЎ ОюОЉОДОе ОЉОљОфОе ОћОЉОљ:</translation>
<translation id="2876628302275096482">РђЈ<ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОюОњОЉОЎ ОћОЕОъОЎОеОћ ОбОю ОцОеОўОЎОЋОф ОћОаОфОЋОаОЎОЮ ОЉ-Chrome<ph name="END_LINK" /></translation>
<translation id="2883644600102358131">РђЈОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ ОЉОДОеОЋОЉ. ОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Google Play Services.</translation>
<translation id="2888126860611144412">РђЈОъОЎОЊОб ОЏОюОюОЎ ОбОю Chrome</translation>
<translation id="2891154217021530873">ОћОцОАОДОф ОўОбОЎОаОф ОћОЊОБ</translation>
<translation id="2894821468041866720">ОћОћОњОаОћ ОћОъОЕОЋОцОеОф ОюОљ ОъОљОўОћ ОЉОъОЎОЊОћ ОъОЕОъОбОЋОфОЎОф ОљОф ОћОЊОцОЊОцОЪ ОљОЋ ОћОъОЏОЕОЎОе.</translation>
<translation id="2895521649038438824">ОЎОЕ ОљОцОЕОеОЋОф ОюОћОљОќОЎОЪ ОюОЊОБ ОћОќОћ</translation>
<translation id="2899252057552912621">РђЈОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОДОеОЋОЉ ОЏОЎ ОЌОЉОЎОюОф Google Play Services ОюОљ ОќОъОЎОаОћ. ОљОцОЕОе ОюОЎОдОЋОе ОбОЋОфОД ОЕОю ОћОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОюОцОаОЎ ОЕОћОЪ ОЎОцОАОЎОДОЋ ОюОцОбОЋОю.</translation>
<translation id="2900528713135656174">ОЎОдОЎОеОф ОљОЎОеОЋОб</translation>
<translation id="2901411048554510387">ОъОЋОдОњОЋОф ОћОдОбОЋОф ОћОДОЕОЋОеОЋОф ОюОЊОБ <ph name="WEBSITE_TITLE" /></translation>
<translation id="2904300462646366554">РђЈОДОЋОЉОдОЎ PDF ОЎОЎОцОфОЌОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОљОЌОеОЎ ОћОћОЋОеОЊОћ ОЉОљОъОдОбОЋОф ОљОЌОф ОъОћОфОЋОЏОаОЋОф ОюОћОдОњОф ОДОЉОдОЎОЮ ОЏОљОюОћ ОЉОъОЏОЕОЎОе</translation>
<translation id="2904414404539560095">ОеОЕОЎОъОф ОћОъОЏОЕОЎОеОЎОЮ ОЕОљОцОЕОе ОюОЕОфОБ ОљОЎОфОЮ ОЏОеОўОЎОАОЎОЎОћ ОаОцОфОЌОћ ОЉОњОЋОЉОћ ОћОъОюОљ ОЕОю ОћОъОАОџ.</translation>
<translation id="2908243544703713905">ОћОАОЎОцОЋОеОЎОЮ ОЕОюОљ ОаОДОеОљОЋ ОъОЋОЏОаОЎОЮ</translation>
<translation id="2909615210195135082">РђЈОцОюОўОцОЋОеОъОф ОћОћОфОеОљОЋОф ОЕОю Google</translation>
<translation id="2912345083818861431">ОЕОЎОъОЋОЕ ОЉОаОбОЎОюОф ОћОъОАОџ ОЏОЊОЎ ОюОеОљОЋОф ОЏОеОўОЎОАОЎОЋОф ОцОфОЋОЌОЋОф ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="2923908459366352541">ОћОЕОЮ ОюОљ ОЌОЋОДОЎ</translation>
<translation id="2932150158123903946">РђЈОаОцОЌ ОљОЌОАОЋОЪ ОЕОю <ph name="APP_NAME" />РђЈ Google</translation>
<translation id="2932222164150889403">ОюОљ ОЎОћОЎОћ ОЕОЎОаОЋОЎ ОЉОъОДОюОЊОф</translation>
<translation id="2936980480904111527">РђЈОћОћОфОеОљОЋОф ОЕОю Chrome: ОДОю ОЎОЋОфОе, ОцОЕОЋОў ОЎОЋОфОе</translation>
<translation id="2940075786175545812">ОљОцОЕОеОЋОф ОюОљОЕОе ОљОЋ ОюОљ ОюОљОЕОе ОљОфОе</translation>
<translation id="2942036813789421260">ОЏОеОўОЎОАОЎОЎОф ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОАОњОЋОеОћ</translation>
<translation id="2951071800649516099">ОъОЋОАОЎОцОЎОЮ ОЊОцОЎОЮ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ ОюОЕОюОЉ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="2954586176076923855">ОћОбОЉОеОф ОАОеОњОю ОћОЏОфОЋОЉОЋОф ОюОъОбОюОћ</translation>
<translation id="2961208450284224863">{READING_LIST_UNREAD_PAGE_COUNT,plural, =1{ОЊОБ ОљОЌОЊ (<ph name="READING_LIST_UNREAD_PAGE_COUNT_ONE" />) ОЕОюОљ ОаОДОеОљ}one{<ph name="READING_LIST_UNREAD_PAGE_COUNT_MANY" /> ОЊОцОЎОЮ ОЕОюОљ ОаОДОеОљОЋ}two{<ph name="READING_LIST_UNREAD_PAGE_COUNT_MANY" /> ОЊОцОЎОЮ ОЕОюОљ ОаОДОеОљОЋ}other{<ph name="READING_LIST_UNREAD_PAGE_COUNT_MANY" /> ОЊОцОЎОЮ ОЕОюОљ ОаОДОеОљОЋ}}</translation>
<translation id="2972109037780336501">ОћОАОеОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОћОеОЕОљОЋОф</translation>
<translation id="2976550651269220761">РђЈОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОЉ-Chrome ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-GoogleРђЈ.\nОЏОЊОљОЎ ОюОћОъОфОЎОЪ ОЏОъОћ ОЊОДОЋОф ОюОцОаОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ. ОљОЮ ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОЎОЎОъОЌОДОЋ.</translation>
<translation id="2977350910003566746">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОюОцОЎ ОъОЋОбОЊ ОћОцОфОЎОЌОћ ОћОљОЌОеОЋОаОћ</translation>
<translation id="297771753501244313">ОъОЎОЋОЪ ОюОцОЎ ОаОцОфОЌОЋ ОюОљОЌОеОЋОаОћ</translation>
<translation id="2979639724566107830">ОцОфОЎОЌОћ ОЉОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="2981364137500752533">ОаОЎОфОЪ ОюОцОфОЋОЌ ОбОЊ 5 ОЌОюОЋОаОЋОф.</translation>
<translation id="2983102365694924129">ОбОю ОАОъОџ ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉОљОфОе ОъОАОЋОЎОЮ. ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф.</translation>
<translation id="2983398917942897288">ОЉОъОдОЉ ОюОљ ОцОбОЎОю (<ph name="ITEM_COUNT" />)</translation>
<translation id="2984978667043170458">РђЈОћОЏОюОюОф ОћОўОДОАОў ОЕОъОАОЉОЎОЉ ОЉОЌОЎОцОЋОЕОЎОЮ ОЉ-Google</translation>
<translation id="2988638966064514052">ОЌОЎОќОЋОД ОћОАОЎОАОъОљОЋОф</translation>
<translation id="2989523299700148168">ОъОаОЋОбОЎ ОЌОЎОцОЋОЕ ОЕОћОЕОфОъОЕОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ</translation>
<translation id="2992473221983447149">ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф</translation>
<translation id="2996291259634659425">ОЎОдОЎОеОф ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="2996809686854298943">ОЊОеОЋОЕОћ ОЏОфОЋОЉОф ОљОфОе</translation>
<translation id="3026955690410463085">ОћОЏОюОюОф ОћОДОЎОЕОЋОе</translation>
<translation id="3027644380269727216">ОбОю ОАОъОџ ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉОљОфОе ОъОАОЋОЎОЮ. ОћОћОњОЊОеОћ ОћОќОЋ ОцОЋОбОюОф.</translation>
<translation id="3027950907978057636">ОћОъОДОЋОе: <ph name="APP_LABEL" /></translation>
<translation id="3029276696788198026">ОюОюОљ ОўОбОЎОаОћ ОъОеОљОЕ</translation>
<translation id="3029704984691124060">ОЉОЎОўОЋОЎОЎ ОћОАОЎОАОъОћ ОљОЎОаОЮ ОфОЋОљОъОЎОЮ</translation>
<translation id="3036750288708366620"><ph name="BEGIN_LINK" />ОДОЉОюОф ОбОќОеОћ<ph name="END_LINK" /></translation>
<translation id="3037177537145227281">ОћОъОЌОЎОе ОЉОъОбОДОЉ</translation>
<translation id="3037517125981011456">РђЈОЎОЋОдОњОЋ ОћОЋОЊОбОЋОф ОюОдОЋОеОџ ОЏОаОЎОАОћ ОљОю Chrome</translation>
<translation id="3038272154009688107">ОћОдОњОф ОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="3060635849835183725">{BOOKMARKS_COUNT,plural, =1{ОАОЎОъОаОЎОЎОћ ОљОЌОф (<ph name="BOOKMARKS_COUNT_ONE" />)}one{<ph name="BOOKMARKS_COUNT_MANY" /> ОАОЎОъОаОЎОЋОф}two{<ph name="BOOKMARKS_COUNT_MANY" /> ОАОЎОъОаОЎОЋОф}other{<ph name="BOOKMARKS_COUNT_MANY" /> ОАОЎОъОаОЎОЋОф}}</translation>
<translation id="3062802207422175757">РђЈОЉ-Chrome ОъОЌОЏОЎОЮ ОюОџ ОъОљОъОеОЎОЮ ОЉОаОЋОЕОљОЎОЮ ОЕОъОбОаОЎОЎОаОЎОЮ ОљОЋОфОџ</translation>
<translation id="3066573403916685335">ОеОЊ ОюОъОўОћ</translation>
<translation id="3067505415088964188">ОћОъОЌОЎОе ОаОъОЋОџ</translation>
<translation id="3070005020161560471">ОЎОЕ ОюОфОеОњОЮ ОљОЋОўОЋОъОўОЎОф</translation>
<translation id="3072980200212375806">РђЈОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОфОЎОцОфОЌ ОЉ-Chrome. ОћОъОЕОџ ОћОцОбОЋОюОћ ОъОЉОўОљ ОћОАОЏОъОћ <ph name="BEGIN_LINK1" />ОюОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф ОЕОю Google<ph name="END_LINK1" /> ОЋ<ph name="BEGIN_LINK2" />ОюОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф ОћОаОЋОАОцОЎОЮ ОЕОю Google Chrome ОЋ-ChromeOS<ph name="END_LINK2" />. ОњОЮ <ph name="BEGIN_LINK3" />ОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф<ph name="END_LINK3" /> ОЌОюОћ.</translation>
<translation id="3080525922482950719">ОаОЎОфОЪ ОюОЕОъОЋОе ОЊОцОЎОЮ ОюОДОеОЎОљОћ ОЉОъОЋОбОЊ ОъОљОЋОЌОе ОЎОЋОфОе ОљОЋ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="3087734570205094154">ОфОЌОфОЎОф</translation>
<translation id="3091010850649238832">ОћОдОњОф ОћОфОЋОЏОЪ ОЕОЉОюОЋОЌ</translation>
<translation id="3098745985164956033">РђЈОЌОюОД ОъОћОфОъОЋОаОЋОф ОаОЕОюОЌОЋОф ОљОю Google ОЏОЊОЎ ОюОЕОцОе ОбОЉОЋОеОџ ОљОф ОћОфОЎОљОЋОеОЎОЮ</translation>
<translation id="3114507951000454849">ОДОеОљОф ОЌОЊОЕОЋОф ОћОЎОЋОЮ? <ph name="NEWS_ICON" /></translation>
<translation id="3122883569442693641">ОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ</translation>
<translation id="3123734510202723619">ОћОЋОЊОбОЋОф</translation>
<translation id="3148237711805373460">ОДОЌОЋ ОљОЋОфОЎ ОюОЕОЮ</translation>
<translation id="314939179385989105">РђЈОЊОБ ОћОЉОЎОф ОЕОю Chrome</translation>
<translation id="3158667104057012316">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОюОцОЎ ОАОЊОе ОЎОЊОаОЎ</translation>
<translation id="3159335509547415276">ОъОЎОЊОб ОбОю ОЌОЕОЉОЋОаОЋОф ОЌОАОЋОъОЎОЮ</translation>
<translation id="3161699713309727585">РђФ<ph name="BUTTON_TEXT" />, ОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="3166827708714933426">ОъОДОЕОЎ ОДОЎОдОЋОе ОюОЏОеОўОЎОАОЎОЋОф ОЋОюОЌОюОЋОаОЋОф</translation>
<translation id="316694332262407393">РђЈChrome ОЏОЉОе ОцОЋОбОю ОЏОљОЪ.</translation>
<translation id="3167258285411721858">ОаОЎОфОЪ ОюОЉОДОЕ ОљОф ОћОљОфОе ОюОаОЎОЎОЊ ОЕОю <ph name="HOST_NAME" /></translation>
<translation id="3169472444629675720">Discover</translation>
<translation id="3172472771272043251">{PASSWORDS_COUNT,plural, =1{РђЈОАОЎОАОъОћ ОљОЌОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}one{РђЈРђФ# ОАОЎОАОъОљОЋОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}two{РђЈРђФ# ОАОЎОАОъОљОЋОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}other{РђЈРђФ# ОАОЎОАОъОљОЋОф ОЋОцОеОЎОўОЎОЮ ОаОЋОАОцОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}}</translation>
<translation id="3187472288455401631">ОъОЊОЎОЊОф ОћОъОЋОЊОбОЋОф</translation>
<translation id="3189635831478931757">ОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф "<ph name="GROUP_TITLE" />"</translation>
<translation id="3207960819495026254">ОъОАОЋОъОЪ ОЉОАОЎОъОаОЎОЎОћ</translation>
<translation id="3208584281581115441">ОюОЉОЊОЎОДОћ</translation>
<translation id="3211426585530211793">ОъОЋОбОЊ ОћОъОЌОЎОДОћ: <ph name="ITEM_TITLE" /></translation>
<translation id="3220943972464248773">ОЏОЊОЎ ОюОАОаОЏОеОЪ ОљОф ОћОАОЎОАОъОљОЋОф ОбОюОЎОџ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="323213525320714789">ОъОцоиОфОЌ</translation>
<translation id="3232293466644486101">ОъОЌОЎОДОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОъОфОЉОдОбОфРђд</translation>
<translation id="3232754137068452469">ОљОцОюОЎОДОдОЎОЎОф ОљОЎОаОўОеОаОў</translation>
<translation id="3236059992281584593">ОаОЋОфОеОћ ОЊОДОћ ОљОЌОф</translation>
<translation id="3237087289225714896">ОўОбОЎОаОћ ОеОњОЎОюОћ ОъОеОљОЕ:</translation>
<translation id="3244271242291266297">MM</translation>
<translation id="3245429137663807393">РђЈОљОЮ ОЉОаОЋОАОБ ОЎОЕОЋОфОцОЋ ОЊОЋОЌОЋОф ОЕОЎОъОЋОЕ ОЉ-Chrome, ОћОЊОЋОЌОЋОф ОћОљОюОћ ОЎОЏОюОюОЋ ОљОф ОЏОфОЋОЉОЋОф Оћ-URL ОЕОЉОћОЪ ОЉОЎОДОеОф</translation>
<translation id="3250563604907490871">РђЈОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф ОЎОЋОцОЎОбОЋ ОЏОЕОЎОћОЎОћ ОЌОЎОЉОЋОе Ою-Wi-Fi</translation>
<translation id="3254409185687681395">ОћОЋОАОцОф ОћОЊОБ ОюОАОЎОъОаОЎОЋОф</translation>
<translation id="3259831549858767975">ОћОДОўОаОф ОЏОю ОъОћ ОЕОъОЋОцОЎОб ОЉОЊОБ</translation>
<translation id="3265093782546847662">ОЏОю ОћОЊОцОЎОЮ ОЕОю <ph name="DOMAIN" /></translation>
<translation id="3269093882174072735">ОўОбОЎОаОф ОфОъОЋОаОћ</translation>
<translation id="327204079441056603">ОЕОЎОаОЎОаОЋ ОљОф ОћОљОЋОцОЪ ОЕОЉОЋ ОАОЎОАОъОљОЋОф ОаОЕОъОеОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="3280562213547448728">ОЌОЎОцОЋОЕ ОДОЋОюОЎ</translation>
<translation id="3282568296779691940">РђЈОЏОаОЎОАОћ Ою-Chrome</translation>
<translation id="3285065882678541460">{TAB_COUNT,plural, =1{РђФ<ph name="TAB_GROUPS_PART" />, ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />)}one{РђФ<ph name="TAB_GROUPS_PART" />, <ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}two{РђФ<ph name="TAB_GROUPS_PART" />, <ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}other{РђФ<ph name="TAB_GROUPS_PART" />, <ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="3293181007446299124">ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОаОЕОъОеОф ОЉОљОЋОцОЪ ОцОеОўОЎ ОЉОъОЏОЕОЎОе, ОЋОћОЊОЋОЌОЋОф ОаОЕОюОЌОЎОЮ ОюОљОЌОе ОћОЕОћОЎОћ ОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОцОеОўОЎОЋОф ОЕОюОџ.</translation>
<translation id="3301936297336370235">ОљОЎОЕОЋОе ОЕОю ОћОћОдОбОћ ОюОАОЎОАОъОћ</translation>
<translation id="3302615849591357577">ОЕОЌОќОЋОе ОЕОю ОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф <ph name="TITLE_OF_GROUP" />, ОЉОдОЉОб <ph name="COLOR_NAME" />, ОЏОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОћ ОЉОеОДОб.</translation>
<translation id="3303414029551471755">ОћОљОЮ ОюОћОЋОеОЎОЊ ОљОф ОћОфОЋОЏОЪ?</translation>
<translation id="3303855915957856445">ОюОљ ОаОъОдОљОЋ ОфОЋОдОљОЋОф ОЌОЎОцОЋОЕ</translation>
<translation id="3305130791745726624">ОЕОюОЎОЌОћ ОюОъОЏОЕОЎОе</translation>
<translation id="3305795716056605962">ОфОеОњОЋОЮ ОћОЊОцОЎОЮ ОЉОљОъОдОбОЋОф ОћОЏОцОфОЋОе 'ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф'</translation>
<translation id="331080746368555063">ОљОфОеОЎОЮ ОцОеОўОЎОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЏОюОЋОю ОЊОЉОеОЎОЮ ОЏОъОЋ ОћОљОЎОаОўОеОљОаОў ОЕОю ОћОЌОЉОеОћ</translation>
<translation id="3311330810461485557">ОљОцОЕОе ОюОЌОцОЕ ОюОцОЎ ОљОцОюОЎОДОдОЎОћ, ОфОљОеОЎОџ ОЋОбОЋОЊ.</translation>
<translation id="3334729583274622784">ОюОЕОаОЋОф ОљОф ОАОЎОЋОъОф ОћОДОЋОЉОЦ?</translation>
<translation id="333863344734218290">ОъОДОЉОюОЎОЮ ОљОќОћОеОћ ОюОњОЉОЎ ОљОфОеОЎОЮ ОдОЎОЉОЋОеОЎОЎОЮ ОЋОцОеОўОЎОЎОЮ ОюОљ ОъОљОЋОЉОўОЌОЎОЮ</translation>
<translation id="3341262203274374114">ОюОљ ОаОЎОфОЪ ОюОЉОўОю ОљОф ОћОъОбОДОЉ. ОъОЕОћОЋ ОћОЕОфОЉОЕ.</translation>
<translation id="3351165113450806415">ОЊОеОџ ОЌОЊОЕОћ ОюОћОЌОюОЎОД</translation>
<translation id="3359667936385849800">ОЕОЎОъОЋОЕ ОЉОАОцОД ОћОЕОЎОеОЋОф ОћОаОЋОЏОЌОЎ</translation>
<translation id="3373701465337594448">ОЏОЕОћОћОњОЊОеОћ ОъОЋОцОбОюОф, ОъОЋОдОњОф ОЏОљОЪ ОеОЕОЎОъОћ ОЕОю ОљОфОеОЎОЮ ОЕОЎОЏОЋОюОЎОЮ ОюОћОбОеОЎОџ ОљОф ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ</translation>
<translation id="3374023511497244703">РђЈОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ, ОћОАОЎОАОъОљОЋОф ОЋОаОфОЋОаОЎОЮ ОљОЌОеОЎОЮ ОЉ-Chrome ОЏОЉОе ОюОљ ОЎОАОЋОаОЏОеОаОЋ ОбОЮ ОЌОЕОЉОЋОЪ Google</translation>
<translation id="3384347053049321195">ОЕОЎОфОЋОБ ОфОъОЋОаОћ</translation>
<translation id="3387650086002190359">ОћОЋОеОЊОф <ph name="FILE_NAME" /> ОаОЏОЕОюОћ ОбОДОЉ ОЕОњОЎОљОЋОф ОЉОъОбОеОЏОф ОћОДОЉОдОЎОЮ.</translation>
<translation id="3398320232533725830">ОцОфОЎОЌОф ОъОаОћОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="3414952576877147120">ОњОЋОЊОю:</translation>
<translation id="3421726884497337397">РђЈОљОцОЕОе ОюОДОЉОЋОб ОъОфОЎ ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОЎОЎОЌОАОъОЋ</translation>
<translation id="3430670036890315772">ОћОЕОЉОфОћ ОЕОю ОаОбОЎОюОф ОћОцОеОЋОцОЎОю ОфОњОеОЋОЮ ОюОћОАОеОф ОћОъОЎОЊОб ОћОЕОъОЋОе</translation>
<translation id="3435465986463792564">ОцОфОЋОЌОЎОЮ ОљОдОюОџ ОћОеОЉОћ ОЌОюОЋОаОЋОф? ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОаОћОю ОљОф ОЏОЋОюОЮ ОъОЏОљОЪ.</translation>
<translation id="3435575784518354875">РђЈОЏОЊОЎ ОюОЕОъОЋОе ОбОю ОћОњОЎОЕОћ ОюОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОЎОЎОдОљ ОљОЋОфОЪ ОбОЏОЕОЎОЋ, ОюОбОЊОЏОЪ ОљОф Google Play Services ОЋОљОќ ОюОЎОЎОЉОљ ОљОЋОфОЪ ОЌОќОеОћ ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google. <ph name="BEGIN_LINK" />ОюОдОцОЎОЎОћ ОЉОћОЋОеОљОЋОф ОћОъОюОљОЋОф<ph name="END_LINK" />.</translation>
<translation id="3435738964857648380">ОљОЉОўОЌОћ</translation>
<translation id="3435914367318771664">ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЎОћ ОюОДОЉОЋОдОћ ОЌОЊОЕОћ</translation>
<translation id="3439276997620616816">ОћОЏОеОўОЎОАОЎОЋОф ОћОљОЌОеОЋОаОЋОф ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="3443221991560634068">ОўОбОЎОаОћ ОъОЌОЊОЕ ОЕОю ОћОЊОБ ОћОаОЋОЏОЌОЎ</translation>
<translation id="3444179773590444986">ОеОЋОдОћ ОюОЕОфОБ ОъОЕОЋОЉ ОюОњОЉОЎ ОбОЎОдОЋОЉ ОЏОћОћ ОЕОю ОљОфОеОЎОЮ?</translation>
<translation id="3448874648066942074">РђЈОАОЎОЏОЋОЮ ОћОЊОБ ОЉОљОъОдОбОЋОф AI</translation>
<translation id="3452832259067974318">РђЈОЏОЊОЎ ОюОћОњОЪ ОбОю ОћОцОеОўОЎОЋОф ОЕОюОџ, ОюОљ ОъОфОЉОдОб ОЉ-Chrome ОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЕОю ОћОАОЎОАОъОћ ОЕОюОџ ОЉОЕОЊОћ ОћОќОћ.</translation>
<translation id="3467081767799433066">ОЉОъОАОњОеОф ОъОЊОЎОЊОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОћОъОЋОЊОбОЋОф, ОеОД ОАОЋОњОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЕОю ОаОфОЋОаОЎОЮ ОЎОЕОЋОфОцОЋ ОЉОЎОЪ ОљОфОеОЎОЮ ОЏОЊОЎ ОюОъОЊОЋОЊ ОљОф ОЉОЎОдОЋОбОЎ ОћОъОЋОЊОбОЋОф ОЕОюОћОЮ. ОюОъОЕОю, ОљОЮ ОЉОЎОдОбОф ОеОЏОЎОЕОћ ОљОЌОеОЎ ОЉОЎОДОЋОе ОЉОљОфОе.</translation>
<translation id="3474624961160222204">ОћОъОЕОџ ОЏ-<ph name="NAME" /></translation>
<translation id="3478363558367712427">ОљОцОЕОе ОюОЉОЌОЋОе ОљОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ</translation>
<translation id="3479552764303398839">ОюОљ ОбОЏОЕОЎОЋ</translation>
<translation id="3482805106082349287">ОЌОЎОцОЋОЕ ОЉОћОДОюОЊОћ, ОЉОДОЋОю, ОЉОъОдОЉ ОцОеОўОЎ ОљОЋ ОЉОбОќОеОф ОћОъОдОюОъОћ</translation>
<translation id="3487903178221457900">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОљОаОЕОЎОЮ ОљОЌОеОЎОЮ ОЎОЋОЏОюОЋ ОюОњОЕОф ОюОДОЋОЉОЦ ОћОъОЎОЋОЉОљ, ОЏОЋОюОю ОљОцОюОЎОДОдОЎОЋОф. ОюОљОЌОе ОћОЎОЎОдОЋОљ, ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОЎОЎОъОЌОДОЋ Оъ-Chrome.</translation>
<translation id="3488199663160411179">ОЕОЮ</translation>
<translation id="3493531032208478708"><ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /> ОбОю ОћОдОбОЋОф ОюОфОЋОЏОЪ</translation>
<translation id="3499246418971111862">chrome_qrcode_<ph name="CURRENT_TIMESTAMP_MS" /></translation>
<translation id="350276055892098337">ОъОЎОЋОЪ ОюОцОЎ ОћОЎОЕОЪ ОЉОЎОЋОфОе</translation>
<translation id="3507132249039706973">ОъОЋОцОбОюОф ОћОњОаОћ ОеОњОЎОюОћ</translation>
<translation id="3509330069915219067">РђЈОљОЎОЪ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў. ОъОбОеОЏОф Chrome ОюОљ ОЎОЏОЋОюОћ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОбОЊОЏОЋОаОЎОЮ.</translation>
<translation id="3513019849832307207">ОћОдОўОеОцОЋОф ОЋОцОфОЎОЌОћ</translation>
<translation id="3513704683820682405">ОъОдОЎОљОЋОф ОеОЉОЋОЊОћ</translation>
<translation id="3516053221628030540">РђЈОъОбОЉОе ОљОю Google Play</translation>
<translation id="351672147489633468">{NUM_REVOKED_PERMISSIONS,plural, =1{ОћОАОеОаОЋ ОћОеОЕОљОЋОф ОюОЕОюОЎОЌОф ОћОфОеОљОЋОф ОъОљОфОе ОљОЌОЊ ОЕОюОљ ОЉОЎОДОеОф ОЉОЋ ОюОљОЌОеОЋОаОћ}one{ОћОАОеОаОЋ ОћОеОЕОљОЋОф ОюОЕОюОЎОЌОф ОћОфОеОљОЋОф Оъ-# ОљОфОеОЎОЮ ОЕОюОљ ОЉОЎОДОеОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ}two{ОћОАОеОаОЋ ОћОеОЕОљОЋОф ОюОЕОюОЎОЌОф ОћОфОеОљОЋОф Оъ-# ОљОфОеОЎОЮ ОЕОюОљ ОЉОЎОДОеОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ}other{ОћОАОеОаОЋ ОћОеОЕОљОЋОф ОюОЕОюОЎОЌОф ОћОфОеОљОЋОф Оъ-# ОљОфОеОЎОЮ ОЕОюОљ ОЉОЎОДОеОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ}}</translation>
<translation id="3518985090088779359">ОЉОАОЊОе, ОъОДОЋОЉОю ОбОюОЎОЎ</translation>
<translation id="3519014757432845220">РђЈОЏОЊОЎ ОюОбОќОЋОе ОюОаОЋ ОюОЕОцОе ОљОф ОћОћОњОаОћ ОъОцОаОЎ ОАОцОљОЮ, ОљОцОЕОе ОюОЕОфОБ ОбОЮ Google ОљОф ОфОЋОЏОЪ ОћОћОЋОЊОбОћ ОЋОљОф ОЏОфОЋОЉОф Оћ-URL ОЕОю ОћОљОфОе. ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЉОЋОЊОДОЎОЮ ОљОаОЋОЕОЎОЎОЮ ОЎОЉОЊОДОЋ ОљОф ОћОфОЋОЏОЪ.</translation>
<translation id="3521388823983121502">ОюОљ ОаОЎОфОЪ ОюОћОъОЕОЎОџ ОбОЮ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="3522247891732774234">ОЎОЕ ОбОЊОЏОЋОЪ ОќОъОЎОЪ. ОбОЋОЊ ОљОцОЕОеОЋОЎОЋОф</translation>
<translation id="3523789730715594198">РђЈОљОцОЕОе ОюОбОЊОЏОЪ ОљОф ОћОћОњОЊОеОЋОф, ОЉОЏОю ОеОњОб, ОЏОЊОЎ ОюОћОцОАОЎОД ОљОф ОћОАОаОЏОеОЋОЪ. Google ОбОЕОЋОЎОћ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОЌОЎОцОЋОЕ ОЋОЕОЎОеОЋОфОЎОЮ ОаОЋОАОцОЎОЮ ОбОю ОАОъОџ ОћОћОЎОАОўОЋОеОЎОћ ОЕОюОџ.</translation>
<translation id="3524138585025253783">ОъОъОЕОД ОъОЕОфОъОЕ ОюОъОцОфОЌОЎОЮ</translation>
<translation id="3524334353996115845">ОаОЎОфОЪ ОЎОћОЎОћ ОюОљОъОф ОљОф ОќОћОЋОфОџ ОЉОљОъОдОбОЋОф <ph name="ORIGIN" /></translation>
<translation id="3527085408025491307">ОфОЎОДОЎОЎОћ</translation>
<translation id="3542235761944717775">РђЈРђј<ph name="KILOBYTES" />KB ОќОъОЎОаОЎОЮ</translation>
<translation id="3549537543136628349">РђЈОћОЊОцОЎОЮ ОЕОаОўОбОаОЎОЮ ОъОеОљОЕ ОъОЋОдОцОаОЎОЮ, ОЋОћОљОфОе ОљОЋ ОћОљОцОюОЎОДОдОЎОћ ОЕОъОДОЕОеОЎОЮ ОюОЊОцОЎОЮ ОћОљОюОћ ОћОЮ ОљОфОе ОљОЋ ОљОцОюОЎОДОдОЎОћ ОЕОю Google, ОюОЏОЪ ОћОЕОеОфОЎОЮ ОЕОю Google ОюОљ ОъОДОЉОюОЎОЮ ОъОЎОЊОб ОЌОЊОЕ ОЏОЕОъОфОЉОдОбОф ОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОћОЊОцОЎОЮ ОћОљОюОћ ОЉОљОЋОцОЪ ОцОеОўОЎ.</translation>
<translation id="3549657413697417275">ОЌОЎОцОЋОЕ ОЉОћОЎОАОўОЋОеОЎОћ ОЕОюОџ</translation>
<translation id="3557336313807607643">ОћОЋОАОцОћ ОюОљОаОЕОЎ ОћОДОЕОе</translation>
<translation id="3563767357928833671">ОъОЋОдОњ ОћОфОЋОЏОЪ ОЕОЉОюОЋОЌ</translation>
<translation id="3566639033325271639">ОбОЊОЏОЋОЪ ОћОћОњОЊОеОЋОф</translation>
<translation id="3568945271227339929">ОљОЎОЪ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ</translation>
<translation id="3575464060651642446">ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ ОаОЉОЊОДОЋОфРђд</translation>
<translation id="3577473026931028326">ОъОЕОћОЋ ОћОЕОфОЉОЕ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3577558748185201054">ОљОцОЕОе ОюОаОћОю ОљОф ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЋОћОћОбОЊОцОЋОф</translation>
<translation id="3587482841069643663">ОћОЏОЋОю</translation>
<translation id="3602290021589620013">ОфОдОЋОњОћ ОъОДОЊОЎОъОћ</translation>
<translation id="3614126103057878858">ОъОЊОЊОЎ ОъОЌОЎОеОЎОЮ</translation>
<translation id="3616113530831147358">ОљОЋОЊОЎОЋ</translation>
<translation id="3619255692378312441">ОаОЎОћОЋОю ОћОеОЕОљОЋОф ОћОњОЎОЕОћ</translation>
<translation id="3622349720008044802">ОаОЎОћОЋОю ОћОЌОюОЋОаОЋОф</translation>
<translation id="3623240789707551553">{DOMAIN_COUNT,plural, =1{ОЋОбОЋОЊ ОљОфОе ОљОЌОЊ}one{ОЋОбОЋОЊ # ОљОфОеОЎОЮ}two{ОЋОбОЋОЊ # ОљОфОеОЎОЮ}other{ОЋОбОЋОЊ # ОљОфОеОЎОЮ}}</translation>
<translation id="3627893290277153986">ОцОфОЎОЌОф ОљОцОЕОеОЋОЎОЋОф ОюОЕОъОЎОеОф ОћОЊОБ</translation>
<translation id="3631987586758005671">ОћОЕОЎОфОЋОБ ОбОЮ <ph name="DEVICE_NAME" /> ОъОфОЉОдОб</translation>
<translation id="363484704507524488">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОаОћОю ОљОф ОЉОЊОЎОДОф ОћОќОћОЋОф ОЉОћОњОЊОеОЋОф ОЕОю ОљОъОдОбОЎ ОћОћОњОаОћ ОюОъОДОеОћ ОњОаОЎОЉОћ. <ph name="BEGIN_LINK" />ОъОбОЉОе ОюОћОњОЊОеОЋОф<ph name="END_LINK" /></translation>
<translation id="3635073343384702370">РђЈОю-Chrome ОЎОЕ ОљОцОЕОеОЋОф ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ ОеОД ОљОЮ ОЕОъОеОф ОљОЋОфОЪ</translation>
<translation id="363596933471559332">ОЏОаОЎОАОћ ОљОЋОўОЋОъОўОЎОф ОюОљОфОеОЎОЮ ОЉОљОъОдОбОЋОф ОцОеОўОЎ ОЏОаОЎОАОћ ОъОљОЋОЌОАОаОЎОЮ. ОЏОЕОфОЏОЋОаОћ ОќОЋ ОЏОЉОЋОЎОћ, ОЎОћОЎОћ ОбОюОЎОџ ОюОЉОдОб ОљОЎОъОЋОф ОюОцОаОЎ ОЏОю ОЏОаОЎОАОћ ОюОљОфОе.</translation>
<translation id="3636940436873918441">ОћОЕОцОЋОф ОћОъОЋОбОЊОцОЋОф</translation>
<translation id="3637744895182738742">РђЈОљОЮ ОЕОЏОЌОф ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ ОљОЋ ОЕОЉОеОдОЋОаОџ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, <ph name="BEGIN_LINK" />ОбОюОЎОџ ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ Chrome ОЉОЌОЕОЉОЋОЪ<ph name="END_LINK" />.</translation>
<translation id="3653111872753786013"><ph name="WEBSITE_TITLE" />: <ph name="WEBSITE_URL" /></translation>
<translation id="3674208116086565128">РђЈОъОбОЉОе ОюОЊОБ ОћОЉОЎОф ОЕОю ОљОцОюОЎОДОдОЎОЎОф Google</translation>
<translation id="368329460027487650">ОћОЌОЕОЉОЋОЪ ОюОљ ОъОЌОЋОЉОе. ОЎОЎОцОфОЌОЋ ОљОцОЕОеОЋОЎОЋОф ОћОЏОаОЎОАОћ.</translation>
<translation id="3684540848053703310">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОъОЊОЊОЎ ОћОъОЌОЎОеОЎОЮ ОАОњОЋОе</translation>
<translation id="3687645719033307815">ОъОЋОдОњОф ОюОџ ОфОдОЋОњОћ ОъОДОЊОЎОъОћ ОЕОю ОћОЊОБ ОћОќОћ</translation>
<translation id="3692944402865947621">ОћОћОЋОеОЊОћ ОЕОю <ph name="FILE_NAME" /> ОаОЏОЕОюОћ ОЏОЎ ОъОЎОДОЋОЮ ОћОљОЌОАОЋОЪ ОюОљ ОаОњОЎОЕ.</translation>
<translation id="3697705478071004188">ОъОЎОЋОЪ ОюОцОЎ ОљОфОе</translation>
<translation id="3699022356773522638">ОюОћОЋОеОЎОЊ ОљОф ОћОДОЋОЉОЦ?</translation>
<translation id="3701167022068948696">ОюОцОфОеОЋОЪ ОћОЉОбОЎОћ</translation>
<translation id="3701515417135397388">ОћОдОњОф ОљОќОћОеОћ ОљОЮ ОАОЎОАОъОћ ОаОЌОЕОцОћ ОЉОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб</translation>
<translation id="3703166520839776970">ОљОЮ ОћОЉОбОЎОћ ОюОљ ОаОцОфОеОћ, ОаОЎОфОЪ ОюОЉОЌОЋОе ОЉОљОцОЕОеОЋОф 'ОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ' ОюОъОўОћ ОЏОЊОЎ ОюОбОЎОЎОЪ ОЉОъОЎОЊОб ОаОЋОАОБ Оъ-<ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" />.</translation>
<translation id="3708100450779900829">ОЏОЕОћОъОЏОЕОЎОе ОъОДОЋОцОю, ОљОцОЕОе ОюОЉОЌОЋОе ОъОћОљОцОЕОеОЋОЎОЋОф ОюОъОўОћ ОљОЋ ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю ОАОеОњОю ОћОЏОфОЋОЉОЋОф ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОъОЎОДОЋОЮ ОЕОюОЋ</translation>
<translation id="3710501561113687889">ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОћОцОеОўОЎОЮ '<ph name="FIELDS_STRING" />' ОЎОЕОЋОфОцОЋ ОбОю ОЎОЊОЎ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /> ОбОЮ ОћОљОфОе ОћОќОћ.</translation>
<translation id="3710560693796335511">ОЕОЎОфОЋОБ ОцОбОЋОюОћ</translation>
<translation id="3714981814255182093">ОцОфОЎОЌОф ОАОеОњОю ОћОЌОЎОцОЋОЕ</translation>
<translation id="3718765429352682176">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОЋОдОњ ОћОЎОАОўОЋОеОЎОћ ОъОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф ОЕОцОЋОфОЌОЋОф ОДОЎОЕОЋОеОЎОЮ ОЉ-Chrome.</translation>
<translation id="3721119614952978349">РђЈОћОћОњОЊОеОЋОф ОЕОюОџ ОЉ-Google</translation>
<translation id="3737319253362202215">ОћОњОЊОеОЋОф ОћОфОеОњОЋОЮ</translation>
<translation id="3738139272394829648">ОЌОЎОцОЋОЕ ОЉОаОњОЎОбОћ</translation>
<translation id="3739455665973395693">РђЈОљОЎОЪ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google</translation>
<translation id="3739899004075612870">ОаОЋОАОБ ОюОАОЎОъОаОЎОЋОф ОЉ-<ph name="PRODUCT_NAME" /></translation>
<translation id="3740525748616366977">ОЌОЎОцОЋОЕ ОДОЋОюОЎ ОюОљ ОќОъОЎОЪ ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="376561056759077985">ОЌОюОД ОъОћОаОфОЋОаОЎОЮ ОбОЊОЎОЎОЪ ОюОљ ОаОЕОъОеОЋ</translation>
<translation id="3771033907050503522">ОЏОеОўОЎОАОЎОЋОф ОљОаОЋОаОЎОъОЎОЋОф</translation>
<translation id="3771290962915251154">ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф ОъОљОЌОе ОЕОЉОДОеОф ОћОћОЋОеОЎОЮ ОъОЋОцОбОюОф</translation>
<translation id="3771694256347217732">РђЈОфОаОљОЎОЮ ОЋОћОњОЉОюОЋОф ОЕОю Google</translation>
<translation id="3775705724665058594">ОЕОюОЎОЌОћ ОљОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="3777796259512476958">ОфОфОЉОдОб ОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ ОЉОеОЋОЉ ОћОљОфОеОЎОЮ</translation>
<translation id="379035798868314833">РђЈОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОЎОцОАОЎОД ОюОцОбОЋОю ОЉОъОЏОЕОЎОе</translation>
<translation id="3791957072666773229">{TAB_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}one{# ОЏОеОўОЎОАОЎОЋОф}two{# ОЏОеОўОЎОАОЎОЋОф}other{# ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="3795154175078851242">ОћОбОфОДОф ОћОфОъОЋОаОћ ОбОЮ ОћОДОЎОЕОЋОе</translation>
<translation id="3810973564298564668">ОаОЎОћОЋОю</translation>
<translation id="3819178904835489326"><ph name="NUMBER_OF_DOWNLOADS" /> ОћОЋОеОЊОЋОф ОаОъОЌОДОЋ</translation>
<translation id="3819183753496523827">ОљОЎОЪ ОюОџ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў. ОдОеОЎОџ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="3823019343150397277">IBAN</translation>
<translation id="38243391581572867">РђЈРђФLens ОюОљ ОќОъОЎОЪ ОЉОЌОЕОЉОЋОЪ ОћОќОћ.</translation>
<translation id="38258275871320156">ОћОљОцОЕОеОЋОф ОќОъОЎОаОћ ОеОД ОюОЌОюОЋОаОЋОф ОДОўОаОЎОЮ</translation>
<translation id="3830886834687455630">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф, ОЎОЕ ОюОбОЊОЏОЪ ОљОф Google Play Services</translation>
<translation id="3843603704176567761">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ ОЉОДОеОЋОЉ. ОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Google Play Services.</translation>
<translation id="3845098929839618392">ОюОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="3847319713229060696">ОАОЎОЋОб ОюОЕОЎОцОЋОе ОћОљОЉОўОЌОћ ОЉОљОЎОаОўОеОаОў ОюОўОЋОЉОф ОЏОЋОюОЮ</translation>
<translation id="385051799172605136">ОЌОќОеОћ</translation>
<translation id="3856096718352044181">ОЎОЕ ОюОљОъОф ОЕОћОАОцОД ОћОќОћ ОЌОЋОДОЎ ОљОЋ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="3858860766373142691">ОЕОЮ</translation>
<translation id="3863527519275151528">ОћОЋОЊОбОћ ОбОю ОбОЎОЉОЋОЊ</translation>
<translation id="3866863539038222107">ОЉОЊОЋОД</translation>
<translation id="3870908470613821006">ОЏОЋОюОЮ ОЎОљОЉОЊОЋ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ ОљОф ОћОњОЎОЕОћ ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф '<ph name="GROUP_NAME" />', ОЋОћОЎОљ ОфОЎОъОЌОД ОъОЏОю ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="3873174561423636563">ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОцОеОўОЎОЮ ОъОАОЋОЎОъОЎОЮ (<ph name="FIELDS_STRING" />) ОЎОЕОЋОфОцОЋ ОбОю ОЎОЊОЎ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /> ОбОЮ ОћОљОфОе ОћОќОћ. <ph name="BEGIN_LINK1" />ОЏОљОЪ ОъОцОЋОеОўОЎОЮ ОћОфОаОљОЎОЮ ОЋОћОћОњОЉОюОЋОф<ph name="END_LINK1" /> ОЕОю ОћОљОфОе ОћОќОћ.</translation>
<translation id="3892148308691398805">ОћОбОфОДОф ОћОўОДОАОў</translation>
<translation id="3898498281932368596">ОЌОАОЎОъОћ ОЋОЎОдОЎОљОћ</translation>
<translation id="3899682235662194879">ОАОњОЎОеОћ ОЕОю ОЏОю ОЏОеОўОЎОАОЎОЋОф ОћОъОдОЉ ОћОљОаОЋОаОЎОъОЎ</translation>
<translation id="3900966090527141178">ОЎОЎОдОЋОљ ОАОЎОАОъОљОЋОф</translation>
<translation id="3902562446536395999">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОЉОАОЊОе ОљОюОцОЉОЎОфОЎ ОбОЋОюОћ</translation>
<translation id="3908308510347173149">ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="PRODUCT_NAME" /></translation>
<translation id="3911609878849982353">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОЉОАОЊОе ОљОюОцОЉОЎОфОЎ ОЎОЋОеОЊ</translation>
<translation id="3924911262913579434"><ph name="SAFE_BROWSING_MODE" /> ОцОбОЎОюОћ</translation>
<translation id="3927692899758076493">Sans Serif</translation>
<translation id="3928666092801078803">ОЕОЎОюОЋОЉ ОћОаОфОЋОаОЎОЮ ОЕОюОЎ</translation>
<translation id="3931947361983910192">ОъОљОеОЉОбОф ОћОЕОЉОЋОбОЋОф ОћОљОЌОеОЋОаОЎОЮ</translation>
<translation id="393697183122708255">ОЌОЎОцОЋОЕ ОДОЋОюОЎ ОъОЋОцОбОю ОюОљ ОќОъОЎОЪ</translation>
<translation id="3950820424414687140">ОЏОаОЎОАОћ</translation>
<translation id="395377504920307820">ОЕОЎОъОЋОЕ ОюОюОљ ОЌОЕОЉОЋОЪ</translation>
<translation id="3955219620682768253">ОъОбОЉОе ОюОЊОБ ОћОДОЋОЊОЮ ОЉ"ОћОЎОАОўОЋОеОЎОћ"</translation>
<translation id="396192773038029076">{NUM_IN_PROGRESS,plural, =1{РђЈChrome ОЎОўОбОЪ ОљОф ОћОЊОБ ОЏОЕОЎОћОЎОћ ОъОЋОЏОЪ}one{РђЈChrome ОЎОўОбОЪ ОљОф ОћОЊОцОЎОЮ ОЏОЕОЎОћОЎОЋ ОъОЋОЏОаОЎОЮ}two{РђЈChrome ОЎОўОбОЪ ОљОф ОћОЊОцОЎОЮ ОЏОЕОЎОћОЎОЋ ОъОЋОЏОаОЎОЮ}other{РђЈChrome ОЎОўОбОЪ ОљОф ОћОЊОцОЎОЮ ОЏОЕОЎОћОЎОЋ ОъОЋОЏОаОЎОЮ}}</translation>
<translation id="3969142555815019568">РђЈОю-Chrome ОљОЎОЪ ОљОцОЕОеОЋОф ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ</translation>
<translation id="3969863827134279083">ОбОюОћ ОюОъОбОюОћ</translation>
<translation id="397105322502079400">ОъОфОЉОдОб ОЌОЎОЕОЋОЉ...</translation>
<translation id="397583555483684758">ОћОАОаОЏОеОЋОЪ ОћОцОАОЎОД ОюОцОбОЋОю</translation>
<translation id="3976396876660209797">ОћОАОеОћ ОЋОЎОдОЎОеОћ ОъОЌОЊОЕ ОЕОю ОъОДОЕ ОћОДОЎОдОЋОе ОћОќОћ</translation>
<translation id="3985022125189960801">ОаОЎОфОЪ ОюОћОЋОАОЎОБ ОљОфОе ОЉОЌОќОеОћ ОЏОЊОЎ ОЕОЎОЎОЏОюОю ОЉОъОљОњОе ОћОљОфОеОЎОЮ ОЕОЎОЏОЋОюОЎОЮ ОюОћОбОеОЎОџ ОъОћ ОъОбОаОЎОЎОЪ ОљОЋОфОџ</translation>
<translation id="3985215325736559418">ОћОљОЮ ОюОћОЋОеОЎОЊ ОЕОЋОЉ ОљОф <ph name="FILE_NAME" />?</translation>
