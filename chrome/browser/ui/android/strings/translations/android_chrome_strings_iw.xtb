<translation id="4197828496439691735">{NUM_TABS,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф ОЉОъОЏОЕОЎОе ОћОќОћ}one{# ОЏОеОўОЎОАОЎОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ}two{# ОЏОеОўОЎОАОЎОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ}other{# ОЏОеОўОЎОАОЎОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ}}</translation>
<translation id="4198423547019359126">ОљОЎОЪ ОъОЎОДОЋОъОЎОЮ ОќОъОЎОаОЎОЮ ОюОћОЋОеОЊОћ</translation>
<translation id="4209029522667123437">РђФ<ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /> Рђб ОћОЌОЕОЉОЋОЪ ОЕОћОЕОфОъОЕОф ОЉОЋ ОЉОљОфОе ОћОќОћ</translation>
<translation id="4214315110991671325">РђЈОљОЮ ОъОљОцОЕОеОЎОЮ ОЕОЎОъОЋОЕ ОЉОДОЋОЉОдОЎ Cookie, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОъОбОеОЏОф Chrome ОфОЕОфОъОЕ ОЉОћОЮ ОЉОўОбОЎОаОћ ОъОеОљОЕ.</translation>
