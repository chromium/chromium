<translation id="5040262127954254034">ОцОеОўОЎОЋОф</translation>
<translation id="504456571576643789">ОъОћ ОЏОЊОљОЎ ОюОДОЌОф ОЉОЌОЕОЉОЋОЪ?</translation>
<translation id="506254248375231072">ОљОЎОЪ ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="5062960805900435602">ОћОбОЊОЏОЋОЪ ОбОю ОъОЎОќОЋОњ ОћОАОЎОАОъОљОЋОф ОаОАОњОе</translation>
<translation id="5075939510584558547">ОЕОъОЎОеОћ ОюОюОљ ОћОдОцОаОћ</translation>
<translation id="5085038751173179818">РђЈОдОеОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЉОљОфОе ОћОќОћ ОЋОЉ-Chrome ОЏОЊОЎ ОЕОћОАОЎОъОаОЎОЋОф ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЎОЋОцОЎОбОЋ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="5091199029769593641">РђЈОЉОДОеОЋОЉ ОЎОЋОдОњОЋ ОАОўОЋОеОЎОќ ОъОћОљОфОе <ph name="SITE_NAME" /> ОЉОцОфОЎОЌОф ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ. ОљОфОеОЎОЮ ОЕОаОъОдОљОЎОЮ ОЉОъОбОДОЉ ОаОЕОъОеОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОаОћОю ОљОЋОфОЮ ОЉОћОњОЊОеОЋОф ОЕОю Discover.</translation>
<translation id="509429900233858213">ОљОЎОеОбОћ ОЕОњОЎОљОћ.</translation>
<translation id="5096775069898886423">ОъОДОЉОюОЎОЮ ОљОќОћОеОћ ОюОцОаОЎ ОЕОъОЉОДОеОЎОЮ ОЉОљОфОеОЎОЮ ОЕОюОљ ОфОЋОъОЏОЎОЮ ОЉОЌОЎОЉОЋОеОЎОЮ ОъОљОЋОЉОўОЌОЎОЮ</translation>
<translation id="5097349930204431044">ОљОфОеОЎОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ ОЎОЏОЋОюОЎОЮ ОюОќОћОЋОф ОъОћ ОъОбОаОЎОЎОЪ ОљОЋОфОџ ОЋОљОќ ОюОћОдОЎОб ОъОЋОЊОбОЋОф ОЉОъОћОюОџ ОћОњОюОЎОЕОћ</translation>
<translation id="510275257476243843">ОаОЋОфОеОћ ОЕОбОћ ОљОЌОф</translation>
<translation id="5114895953710637392">ОњОЎОюОЎОЋОЪ ОћОАОЎОаОЋОЪ ОюОцОЎ ОљОцОюОЎОДОдОЎОЋОф ОАОњОЋОе.</translation>
<translation id="5115811374190515607">ОљОю <ph name="PRODUCT_NAME" /></translation>
<translation id="5116239826668864748">РђЈОљОцОЕОе ОюОћОЕОфОъОЕ ОЉ-Chrome ОЉОЏОю ОцОбОЮ ОЕОюОЋОЌОдОЎОЮ ОбОю ОДОЎОЕОЋОеОЎОЮ ОЉОћОЋОЊОбОЋОф, ОЉОъОАОъОЏОЎОЮ ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОљОЌОеОЋОф.</translation>
<translation id="5118713593561876160">ОфОЌОЋОъОЎ ОбОаОЎОЎОЪ</translation>
<translation id="5122378528687922675">ОљОЮ ОдОеОЎОџ ОбОќОеОћ, ОљОцОЕОе ОюОЉОДОЕ ОбОќОеОћ ОъОћОЋОеОћ (<ph name="PARENT_NAME_1" /> ОљОЋ <ph name="PARENT_NAME_2" />)</translation>
<translation id="5123685120097942451">ОЏОеОўОЎОАОЎОЎОћ ОљОаОЋОаОЎОъОЎОф</translation>
<translation id="5139940364318403933">РђЈОљОЎОџ ОъОЕОфОъОЕОЎОЮ ОЉ-Google Drive</translation>
<translation id="5142281402488957685">ОюОЏОфОЉОЋОф ОЌОЊОЕОЋОф, ОЎОЕ ОюОъОЕОЋОџ ОюОъОўОћ ОЏОЊОЎ ОюОеОбОаОЪ</translation>
<translation id="5144385790872094440">РђЈОЌОюОД ОъОћОЊОцОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОаОўОбОаОЎОЮ ОъОеОљОЕ. ОћОЕОеОфОЎОЮ ОЕОю Google ОЎОЏОЋОюОЎОЮ ОюОўОбОЋОЪ ОъОеОљОЕ ОЊОцОЎОЮ ОЕОЎОЕ ОљОюОЎОћОЮ ОДОЎОЕОЋОеОЎОЮ ОъОљОфОеОЎОЮ ОљОЋ ОљОцОюОЎОДОдОЎОЋОф ОЕОю Google.</translation>
<translation id="5152843274749979095">ОюОљ ОъОЋОфОДОаОЋОф ОљОцОюОЎОДОдОЎОЋОф ОаОфОъОЏОЋОф</translation>
<translation id="5161254044473106830">ОЎОЕ ОюОћОќОЎОЪ ОЏОЋОфОеОф</translation>
<translation id="5161262286013276579">ОњОЎОюОЎОЋОЪ ОћОљОЎОЕОЋОе ОЕОю ОъОцОфОЌ ОћОњОЎОЕОћ ОцОфОЋОЌ</translation>
<translation id="5163361352003913350">ОћОЌОЕОЉОЋОЪ ОћОаОЋОЏОЌОЎ: <ph name="NAME" />. ОбОюОЎОџ ОюОЉОЌОЋОе ОЌОЕОЉОЋОЪ.</translation>
<translation id="5167637873777016814">ОЏОЊОЎ ОюОдОљОф ОъОћОъОдОЉ ОћОцОеОўОЎ, ОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОЏОцОЋОюОћ ОЋОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОљОеОЋОЏОћ</translation>
<translation id="5169102789680486565">ОЎОЕ ОцОбОЎОюОЋОф ОЌОЊОЕОћ ОЉОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф "<ph name="TAB_GROUP_TITLE" />"</translation>
<translation id="5170568018924773124">ОћОдОњОћ ОЉОфОЎОДОЎОЎОћ</translation>
<translation id="5171045022955879922">ОўОДОАОў ОљОЋ ОЏОфОЋОЉОф ОљОфОе ОюОЌОЎОцОЋОЕ</translation>
<translation id="5174700554036517242">ОћОЏОеОўОЎОАОЎОЎОћ ОЌОќОеОћ ОюОњОЋОЉОћ ОћОћОфОЌОюОфОЎ</translation>
<translation id="5180063720319462041">ОћОЊОБ ОфОЋОеОњОЮ Ою<ph name="TARGET_LANGUAGE" /></translation>
<translation id="5191251636205085390">РђЈОъОЎОЊОб ОбОю ОўОЏОаОЋОюОЋОњОЎОЋОф ОЌОЊОЕОЋОф ОЕОъОЎОЋОбОЊОЋОф ОюОћОЌОюОЎОБ ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОЋОћОЋОеОљОЋОф ОюОЕОюОЎОўОћ ОЉОћОЪ.</translation>
<translation id="5197649123261764478">ОњОЎОЕОћ ОаОЋОЌОћ ОюОАОЎОъОаОЎОЋОф</translation>
<translation id="5204967432542742771">ОћОќОаОф ОАОЎОАОъОћ</translation>
<translation id="5206168361184759344">{FILE_COUNT,plural, =1{ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю ОДОЋОЉОЦРђд}one{ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю # ОДОЉОдОЎОЮРђд}two{ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю # ОДОЉОдОЎОЮРђд}other{ОъОфОЉОдОбОф ОћОЋОеОЊОћ ОЕОю # ОДОЉОдОЎОЮРђд}}</translation>
<translation id="5210286577605176222">ОЌОќОеОћ ОюОЏОеОўОЎОАОЎОЎОћ ОћОДОЋОЊОъОф</translation>
<translation id="5210365745912300556">ОАОњОЎОеОф ОћОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="5215957675041756913">ОЕОюОЎОўОћ ОЉОаОфОЋОаОЎОЮ ОЋОЉОЌОЕОЉОЋОЪ</translation>
<translation id="5221437554987713282">РђЈРђФ<ph name="PERMISSION_1" />, <ph name="PERMISSION_2" /> ОЋОбОЋОЊ <ph name="SEPARATOR" /> Chrome ОћОАОЎОе ОљОф ОћОћОеОЕОљОЋОф ОћОљОюОћ ОЏОЎ ОюОљ ОаОЏОаОАОф ОюОљОЌОеОЋОаОћ</translation>
<translation id="5222676887888702881">ОЎОдОЎОљОћ</translation>
<translation id="5226378907213531272">ОЎОћОЎОћ ОдОЋОеОџ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОАОџ ОЉОЏОю ОцОбОЮ ОЕОъОЕОфОъОЕОЎОЮ ОЉОеОЏОЉ</translation>
<translation id="5227554086496586518">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОдОЎОњ ОљОф ОфОЋОдОљОЋОф ОћОЌОЎОцОЋОЕ</translation>
<translation id="5233638681132016545">ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="5235196193381275927">ОъОЕОћОЋ ОћОЕОфОЉОЕ ОЉОъОћОюОџ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ</translation>
<translation id="5246093389635966745">ОбОеОЎОЏОф ОДОЎОдОЋОе ОћОЊОеОџ ОЉОАОеОњОю ОћОЏОюОЎОЮ</translation>
<translation id="5252768492075585080">РђЈОћОњОЊОеОЋОф ОЕОю ОДОЋОЉОдОЎ Cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ</translation>
<translation id="5264813352784073502">24 ОћОЕОбОЋОф ОћОљОЌОеОЋОаОЋОф</translation>
<translation id="5267572070504076962">ОЏОЊОљОЎ ОюОћОцОбОЎОю ОљОф ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОЋОюОДОЉОю ОћОњОаОћ ОъОцОаОЎ ОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ</translation>
<translation id="5271967389191913893">ОћОъОЏОЕОЎОе ОюОљ ОъОдОюОЎОЌ ОюОцОфОЋОЌ ОљОф ОћОфОЋОЏОЪ ОюОћОЋОеОЊОћ.</translation>
<translation id="5273031377282080577">ОћОћОњОЊОеОћ ОћОќОЋ ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОћОљОЊОъОЎОЪ.</translation>
<translation id="5292796745632149097">ОЕОюОЎОЌОћ ОљОю</translation>
<translation id="5301876394151419436">РђЈОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ ОЉОфОЋОе <ph name="EMAIL" />. ОљОцОЕОе ОюОбОЊОЏОЪ ОљОф ОћОћОњОЊОеОЋОф, ОЉОЏОю ОеОњОб, ОЏОЊОЎ ОюОћОцОАОЎОД ОљОф ОћОАОаОЏОеОЋОЪ. РђФGoogle ОбОЕОЋОЎОћ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОЌОЎОцОЋОЕ ОЋОЕОЎОеОЋОфОЎОЮ ОаОЋОАОцОЎОЮ ОбОю ОАОъОџ ОћОћОЎОАОўОЋОеОЎОћ ОЕОюОџ.</translation>
<translation id="5304593522240415983">ОЕОЊОћ ОќОћ ОюОљ ОЎОЏОЋОю ОюОћОЎОЋОф ОеОЎОД</translation>
<translation id="5306014156308790439">ОћОюОЌОдОЪ 'ОћОЋОАОцОћ ОюОљОЋОАОБ' ОъОЋОЕОЉОф</translation>
<translation id="5308380583665731573">ОћОфОЌОЉОеОЋОф</translation>
<translation id="5316947901395241499">ОћОљОцОЕОеОЋОф ОюОЕОъОЋОе ОАОЎОАОъОљОЋОф ОћОЋОЕОЉОфОћ ОбОю ОЎОЊОЎ ОћОљОЊОъОЎОЪ</translation>
<translation id="5317780077021120954">ОЕОъОЎОеОћ</translation>
<translation id="5319359161174645648">РђЈGoogle ОъОъОюОЎОдОћ ОбОю Chrome</translation>
<translation id="5326246328175179736">ОљОЎ ОљОцОЕОе ОюОћОЎОЏОаОА ОЉОљОъОдОбОЋОф ОћОЌОЕОЉОЋОЪ ОћОќОћ</translation>
<translation id="5327248766486351172">ОЕОЮ</translation>
<translation id="5328542107300944283">ОЕОЎОъОЋОЕ ОбОЮ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="5342314432463739672">ОЉОДОЕОЋОф ОћОеОЕОљОћ</translation>
<translation id="534580735623577507">ОљОЎОЪ ОЉОЎОДОЋОеОЎОЮ ОЉОљОфОеОЎОЮ ОъОљОќ <ph name="TIME_PERIOD" /></translation>
<translation id="5354716139000094027">РђЈОАОЎОЏОЋОЮ ОЉОбОќОеОф AI</translation>
<translation id="5355191726083956201">ОъОЋОцОбОюОф ОћОњОаОћ ОъОЕОЋОцОеОф</translation>
<translation id="5375374982898812658">ОћОњОЎОЕОћ ОЕОюОџ ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф '<ph name="GROUP_NAME" />' ОфОљОЉОЊ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ, ОЋОћОЎОљ ОфОЎОъОЌОД ОъОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="5375577065097716013">РђЈОЌОЎОцОЋОЕ ОфОъОЋОаОћ ОЉОбОќОеОф Google Lens <ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="5390367025924544771">ОћОљОфОе <ph name="WEBSITE_ORIGIN" /> ОеОЋОдОћ ОюОћОЕОфОъОЕ ОЉОцОеОўОЎОЮ ОћОљОЎОЕОЎОЎОЮ ОъОћОљОеОаОД ОћОЊОЎОњОЎОўОюОЎ ОЕОюОџ. ОъОЋОъОюОЦ ОюОћОъОЕОЎОџ ОеОД ОљОЮ ОћОљОфОе ОъОћОЎОъОЪ. ОЎОЕ ОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ ОЕОбОЕОЋОЎОЎОЮ ОюОћОўОбОЋОф ОљОЋОфОџ ОЏОЊОЎ ОюОњОеОЋОЮ ОюОџ ОюОЌОЕОЋОБ ОцОеОўОЎОЮ ОЏОъОЋ ОћОЕОЮ ОћОЌОЋОДОЎ ОљОЋ ОъОАОцОе ОфОбОЋОЊОф ОћОќОћОЋОф ОЕОюОџ.</translation>
<translation id="5394331612381306435">ОЎОдОЎОљОћ ОъОъОдОЉ ОцОеОўОЎ</translation>
<translation id="5395376160638294582">РђЈОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОфОъОЎОЊ ОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chrome ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="539881862970320163">ОъОЋОдОњОф ОћОдОбОћ ОюОАОЎОАОъОћ ОЌОќОДОћ. ОћОъОДОюОЊОф ОъОЋОАОфОеОф.</translation>
<translation id="5409881200985013443">ОюОЕОюОЋОЌ ОљОф <ph name="ONE_TIME_CODE" /> ОЉОљОъОдОбОЋОф <ph name="CLIENT_NAME" />?</translation>
<translation id="5410300144953132176">РђФ<ph name="OWNER_FULL_NAME" />РђЈ (<ph name="OWNER_EMAIL" />) ОеОЋОдОћ ОюОдОеОБ ОљОЋОфОџ ОюОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф. ОюОцОаОЎ ОЕОъОдОўОеОцОЎОЮ, ОЌОЕОЋОЉ ОюОЊОбОф ОЕОЏОю ОъОЎ ОЕОЎОЕ ОюОЋ ОљОф ОћОДОЎОЕОЋОе ОЎОЏОЋОю ОюОбОеОЋОџ ОљОф ОЏОю ОћОЏОеОўОЎОАОЎОЋОф. ОфОЋОДОБ ОћОДОЎОЕОЋОе ОЎОцОЋОњ ОЉОбОЋОЊ 48 ОЕОбОЋОф.</translation>
<translation id="5412388166586147626">РђЈОюОљ ОћОдОюОЌОаОЋ ОюОцОфОЋОЌ ОљОф ОћОбОЋОќОе ОћОљОЎОЕОЎ ОъОЉОЋОАОА Оћ-AI. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="5414836363063783498">ОЉОфОћОюОЎОџ ОљОЎОъОЋОфРђд</translation>
<translation id="5415871492522952905">ОћОћОЎОАОўОЋОеОЎОћ ОЋОћОЏОеОўОЎОАОЎОЋОф ОЎОЋОцОЎОбОЋ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ, ОЏОџ ОЕОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОћОъОЕОЎОџ ОъОћОъОДОЋОЮ ОЕОЉОЋ ОћОцОАОДОф.</translation>
<translation id="542073632571549028">ОћОњОЎОЕОћ ОЕОю <ph name="MEMBER_FULL_NAME" /> РђЈ(<ph name="EMAIL" />) ОюОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф ОЉОЕОЮ '<ph name="GROUP_NAME" />' ОфОљОЉОЊ ОЉОљОЋОцОЪ ОъОЎОЎОЊОЎ</translation>
<translation id="5423934151118863508">ОћОЊОцОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф ОЉОфОЊОЎОеОЋОф ОћОњОЉОЋОћОћ ОЉОЎОЋОфОе ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="5424588387303617268">РђЈРђј<ph name="GIGABYTES" /> GB ОќОъОЎОаОЎОЮ</translation>
<translation id="543338862236136125">ОбОеОЎОЏОф ОАОЎОАОъОћ</translation>
<translation id="5433691172869980887">ОЕОЮ ОћОъОЕОфОъОЕ ОћОЋОбОфОД</translation>
<translation id="5436928407363358055">ОЏОЊОЎ ОюОћОъОЕОЎОџ ОЉОДОюОЋОф ОъОћОаОДОЋОЊОћ ОЕОЉОћ ОћОцОАОДОф, ОдОеОЎОџ ОюОАОаОЏОеОЪ ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОЋОљОф ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="5438292632479953702">ОюОћОЋОеОЊОћ ОъОЌОЊОЕ</translation>
<translation id="5439191312780166229">РђЈОъОДОЉОюОЎОЮ ОљОќОћОеОЋОф ОюОњОЉОЎ ОљОфОеОЎОЮ ОъОАОЋОЏОаОЎОЮ, ОњОЮ ОЏОљОюОћ ОЕОюОљ ОћОЎОЋ ОЎОЊОЋОбОЎОЮ Ою-Google ОюОцОаОЎ ОЏОЪ, ОЉОбОќОеОф ОаОЎОфОЋОЌ ОЕОю ОЎОЋОфОе ОаОфОЋОаОЎОЮ ОъОљОфОеОЎОЮ ОЉОћОЕОЋОЋОљОћ ОюОћОњОаОћ ОћОеОњОЎОюОћ. ОљОцОЕОе ОюОЊОюОњ ОбОю ОћОљОќОћОеОЋОф Оъ-Chrome.</translation>
<translation id="5441137934526263133">РђЈОћОљОфОе ОюОљ ОцОЋОбОю? ОДОЋОЉОдОЎ cookie ОЕОю ОдОЊ ОЕОюОЎОЕОЎ ОЌОАОЋОъОЎОЮ</translation>
<translation id="5441466871879044658">ОфОеОњОЋОЮ ОюОЕОцОћ ОћОќОЋ</translation>
<translation id="5441522332038954058">ОъОбОЉОе ОюОЕОЋОеОф ОЏОфОЋОЉОф ОћОљОфОе</translation>
<translation id="5444999712122199445">ОЌОќОеОћ ОюОљОфОе</translation>
<translation id="544776284582297024">ОЏОЊОЎ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЋОф ОЋОюОћОЎОЏОаОА ОюОЊОцОЎОЮ ОЕОЋОаОЎОЮ ОЉОЋ-ОќОъОаОЎОф, ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОЏОцОфОЋОе ОћОЏОеОўОЎОАОЎОЋОф ОћОцОфОЋОЌОЋОф</translation>
<translation id="5454166040603940656">ОбОЮ <ph name="PROVIDER" /></translation>
<translation id="5456381639095306749">ОћОЋОеОЊОф ОЊОБ ОќОћ</translation>
<translation id="5458366071038729214">ОЏОљОЪ ОЎОЋОдОњОЋ ОћОљОфОеОЎОЮ ОЕОЎОфОЋОЋОАОцОЋ ОюОъОбОДОЉ</translation>
<translation id="5468068603361015296">ОеОЋОдОћ ОюОћОЋОеОЎОЊ ОљОф <ph name="FILE_NAME" /> ОЉОЏОю ОќОљОф?</translation>
<translation id="5471273988133666918">ОюОљ ОаОЎОфОЪ ОюОћОбОЉОЎОе ОљОф ОћОЏОеОўОЎОАОЎОЎОћ <ph name="TAB_TITLE" /></translation>
<translation id="548278423535722844">ОцОфОЎОЌОћ ОЉОљОцОюОЎОДОдОЎОЎОф ОъОцОЋОф</translation>
<translation id="5492637351392383067">ОћОдОцОаОћ ОЉОъОЏОЕОЎОе</translation>
<translation id="549660026907543296">ОћОдОўОеОцОЋОф ОЉОфОЋОе <ph name="MEMBER_FULL_NAME" /></translation>
<translation id="5503125329065007089">ОћОАОЎОАОъОљОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОаОцОфОЌОЋ ОЉОЌОдОЎ ОъОњОЋОЉОћ ОћОъОАОџ</translation>
<translation id="5515439363601853141">ОЉОЎОўОЋОю ОћОаОбОЎОюОћ ОЎОдОЎОњ ОљОф ОћОАОЎОАОъОћ</translation>
<translation id="5517095782334947753">ОЎОЕ ОюОџ ОАОЎОъОаОЎОЋОф, ОћОЎОАОўОЋОеОЎОћ, ОАОЎОАОъОљОЋОф ОЋОћОњОЊОеОЋОф ОаОЋОАОцОЋОф Оъ-<ph name="FROM_ACCOUNT" />.</translation>
<translation id="5517326820028369152">ОњОЎОюОЎОЋОЪ ОфОЌОфОЋОЪ ОЕОю ОцОбОЎОюОЋОф ОЕОЉОЎОдОбОф ОюОљОЌОеОЋОаОћ</translation>
<translation id="5526281268548144413">ОљОЎ ОљОцОЕОе ОюОАОњОЋОе ОЉОЏОъОћ ОЌОюОЋОаОЋОф</translation>
<translation id="5548606607480005320">ОЉОЊОЎОДОф ОљОЉОўОЌОћ</translation>
<translation id="5554520618550346933">РђЈОљОЮ ОъОЕОфОъОЕОЎОЮ ОЉОАОЎОАОъОћ ОЋОћОЎОљ ОцОЋОеОАОъОћ ОЉОљОЎОаОўОеОаОў, ОъОЋОдОњОф ОљОќОћОеОћ ОЉ-Chrome. ОЏОЕОћОЉОЊОЎОДОћ ОћОќОЋ ОъОфОЉОдОбОф, ОћОАОЎОАОъОљОЋОф ОЋОЕОъОЋОф ОћОъОЕОфОъОЕОЎОЮ ОъОЋОдОцОаОЎОЮ, ОЏОџ ОЕОљОЎОЕ ОюОљ ОЎОЏОЋОю ОюОДОеОЋОљ ОљОЋОфОЮ, ОЏОЋОюОю Google.</translation>
<translation id="5555525474779371165">ОЉОЌОЎОеОф ОАОЋОњ ОћОћОњОаОћ ОЉОъОАОњОеОф 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ'</translation>
<translation id="5556459405103347317">ОўОбОЎОаОћ ОъОЌОЊОЕ</translation>
<translation id="555671485580955310">ОћОЎОАОўОЋОеОЎОЎОф ОћОАОаОЏОеОЋОЪ ОЋОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="555816257274242153">ОћОъОбОДОЉ ОљОЌОе ОъОЌОЎОеОЎОЮ ОћОЋОцОАОД</translation>
<translation id="5561445479436807659">РђЈОЉОљ ОюОџ ОюОЕОЌОД ОЉ-Dino?</translation>
<translation id="5561549206367097665">ОЉОћОъОфОаОћ ОюОеОЕОфРђд</translation>
<translation id="5568069709869097550">ОљОЎ ОљОцОЕОе ОюОћОЎОЏОаОА</translation>
<translation id="557018954714092179">ОЎОдОЎОеОф ОфОЎОДОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="5578795271662203820">ОЌОЎОцОЋОЕ ОћОфОъОЋОаОћ ОћОќОЋ ОЉ-<ph name="SEARCH_ENGINE" /></translation>
<translation id="5596627076506792578">ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="5599455543593328020">ОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="5601180634394228718">РђЈОЏОЊОЎ ОюОеОљОЋОф ОљОЎОюОЋ ОћОњОЊОеОЋОф ОаОЋОАОцОЋОф ОъОфОЉОАОАОЋОф ОбОю ОаОфОЋОаОЎОЮ ОюОдОЋОеОџ ОЕОЎОцОЋОе ОЌОЋОЋОЎОЎОф ОћОЕОЎОъОЋОЕ ОЉ-Chrome, ОљОцОЕОе ОюОбОЉОЋОе ОљОю <ph name="BEGIN_LINK" />ОЕОЎОеОЋОфОЎ Google<ph name="END_LINK" />.</translation>
<translation id="5611398002774823980">ОЕОъОЎОеОћ ОЉОЌОЕОЉОЋОЪ</translation>
<translation id="5614625640221885312">ОюОљОЌОе ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОћОАОЎОъОаОЎОЋОф, ОћОАОЎОАОъОљОЋОф ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЎОЋОцОЎОбОЋ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="5619633276517849615">ОћОљОеОњОЋОЪ ОЕОюОџ ОћОцОбОЎОю ОљОф ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ</translation>
<translation id="5620163320393916465">ОљОЎОЪ ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="5620928963363755975">ОљОЎОфОЋОе ОћОДОЉОдОЎОЮ ОЋОћОЊОцОЎОЮ ОЕОюОџ ОЉ'ОћОЋОеОЊОЋОф' ОЊОеОџ ОћОЏОцОфОЋОе 'ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф'</translation>
<translation id="5626134646977739690">ОЕОЮ:</translation>
<translation id="5628604359369369630">ОюОљ ОаОДОеОљОЋ РђЊ ОќОъОЎОаОЎОЮ ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="5631483240431073854">ОаОЎОћОЋОю ОћОЏОеОўОЎОАОЎОЋОф ОћОцОфОЋОЌОЋОф</translation>
<translation id="564121214411935612">РђЈОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ ОЉОфОЋОе <ph name="USER_NAME" />. ОЕОњОЎОљОћ ОЉОЌОЕОЉОЋОЪ Google. ОћОћОњОЊОеОЋОф ОЎОЎОцОфОЌОЋ.</translation>
<translation id="5641456720590409793">РђЈ<ph name="BEGIN_LINK1" />ОћОЎОАОўОЋОеОЎОЎОф ОћОЌОЎОцОЋОЕОЎОЮ<ph name="END_LINK1" /> ОЋ<ph name="BEGIN_LINK2" />ОАОЋОњОЎ ОцОбОЎОюОЋОф ОљОЌОеОЎОЮ<ph name="END_LINK2" /> ОбОЕОЋОЎОЎОЮ ОюОћОЎОЕОъОе ОЉОЌОЕОЉОЋОЪ Google.</translation>
<translation id="5648166631817621825">ОъОћОЕОЉОЋОб ОћОљОЌОеОЋОЪ</translation>
<translation id="5655963694829536461">ОЌОЎОцОЋОЕ ОћОћОЋОеОЊОЋОф ОЕОюОџ</translation>
<translation id="5657871969392618475">ОћОъОЎОЊОб ОЕОюОџ ОъОљОЋОЉОўОЌ ОЉОљОъОдОбОЋОф ОаОбОЎОюОф ОцОеОЋОцОЎОю</translation>
<translation id="5659593005791499971">ОљОЎОъОЎОЎОю</translation>
<translation id="5665379678064389456">ОЎОдОЎОеОф ОљОЎОеОЋОб ОЉ-<ph name="APP_NAME" /></translation>
<translation id="5683547024293500885">РђЈОъОбОеОЏОф Chrome ОюОљ ОЎОЏОЋОюОћ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОбОЊОЏОЋОаОЎОЮ</translation>
<translation id="5683916195767086779">ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="5686790454216892815">ОЕОЮ ОћОДОЋОЉОЦ ОљОеОЋОџ ОъОЊОЎ</translation>
<translation id="5687606994963670306">РђЈОљОфОеОЎОЮ ОЕОаОЋОАОцОЋ ОюОцОаОЎ ОЎОЋОфОе Оъ-30 ОЎОЋОЮ ОаОъОЌОДОЎОЮ Оъ-Chrome ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ. ОљОфОе ОЕОъОЉОДОеОЎОЮ ОЉОЋ ОцОбОЮ ОаОЋОАОцОф ОбОЕОЋОЎ ОюОћОЋОцОЎОб ОЕОЋОЉ ОЉОеОЕОЎОъОћ. ОљОцОЕОе ОњОЮ ОюОЌОАОЋОЮ ОљОф ОћОљОцОЕОеОЋОф ОЕОю ОљОфОеОЎОЮ ОюОћОдОЎОб ОъОЋОЊОбОЋОф. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ ОбОю ОаОЎОћОЋОю ОћОцОеОўОЎОЋОф ОЉОцОеОАОЋОЮ ОЉ-Chrome<ph name="END_LINK" /></translation>
<translation id="569536719314091526">ОЊОеОџ ОЏОцОфОЋОе ОћОљОцОЕОеОЋОЎОЋОф ОћОаОЋОАОцОЋОф ОљОцОЕОе ОюОфОеОњОЮ ОљОф ОћОЊОБ ОћОќОћ ОюОЕОцОћ ОЏОюОЕОћОЎ</translation>
<translation id="5696597120588531049">РђЈChrome ОЎОЏОЋОю ОюОћОњОЪ ОбОюОЎОџ ОъОцОаОЎ ОцОеОдОЋОф ОЉОљОЉОўОЌОф ОъОЎОЊОб, ОљОфОеОЎОЮ ОюОљ ОЉОўОЋОЌОЎОЮ ОЋОАОЏОаОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="5698878456427040674">ОбОюОЎОџ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОфОъОЎОЏОћ ОЉОЌОЕОЉОЋОЪ ОЕОаОЉОЌОе.</translation>
<translation id="570347048394355941">ОъОбОЉОе ОюОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="5709213329446699338">ОћОљОфОе <ph name="SITE" /> ОъОЉОДОЕ ОюОћОфОЌОЉОе ОљОю ОЎОдОЎОљОћ ОўОЋОеОЎОф</translation>
<translation id="5715150588940290235">ОюОъОЌОЋОД ОљОф ОДОЋОЊОЎ ОћОљОЉОўОЌОћ ОЕОаОЕОъОеОЋ?</translation>
<translation id="571930967925877633">РђЈОћОАОЎОъОаОЎОЋОф, ОћОћОЎОАОўОЋОеОЎОћ ОЋОаОфОЋОаОЎОЮ ОљОЌОеОЎОЮ ОЉ-Chrome ОЏОЉОе ОюОљ ОЎОАОЋОаОЏОеОаОЋ ОбОЮ ОЌОЕОЉОЋОЪ Google</translation>
<translation id="572328651809341494">ОЏОеОўОЎОАОЎОЋОф ОљОЌОеОЋОаОЋОф</translation>
<translation id="5726692708398506830">ОћОњОЊОюОф ОЏОю ОъОћ ОЕОъОЋОцОЎОб ОЉОЊОБ</translation>
<translation id="5728072125198221967">РђЈОЕОЎОеОЋОфОЎ Google ОъОДОЋОЕОеОЎОЮ</translation>
<translation id="5744751019568455640">ОљОюОћ ОћОДОЋОюОЋОф ОЕОљОцОЕОе ОюОЉОЌОЋОе ОюОћОДОеОљОћ ОЕОю ОЊОцОЎ ОћОљОЎОаОўОеОаОў. ОљОЮ ОћОДОЋОю ОћОќОћ ОъОЋОдОљ ОЌОЪ ОЉОбОЎОаОЎОџ ОЋОЉОеОдОЋОаОџ ОЕОљОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОЋ, ОцОЕОЋОў ОдОеОЎОџ ОюОюОЌОЋОЦ ОбОю ОЕОЮ ОћОДОЋОю.</translation>
<translation id="574845902699630049">ОЕОЎОфОЋОБ ОЉОфОЋОе <ph name="OWNER_FULL_NAME" /></translation>
<translation id="5749068826913805084">РђЈОюОдОЋОеОџ ОћОЋОеОЊОф ОДОЉОдОЎОЮ, Chrome ОќОДОЋОД ОюОњОЎОЕОћ ОюОљОЌОАОЋОЪ.</translation>
<translation id="5749237766298580851">ОЏОЉОЋОЎОћ <ph name="SEPARATOR" /> ОюОљ ОъОЋОъОюОЦ</translation>
<translation id="5752232708629533680">РђЈОЕОЎОфОЋОБ ОДОЋОЉОЦ GIF ОЉОюОЉОЊ</translation>
<translation id="5754350196967618083">РђЈОюОљ ОаОЎОфОЪ ОюОеОбОаОЪ ОљОф Discover</translation>
<translation id="5763382633136178763">ОЏОеОўОЎОАОЎОЋОф ОљОаОЋОаОЎОъОЎОЋОф</translation>
<translation id="5763514718066511291">ОюОЌОЎОдОћ ОъОбОфОЎОДОћ ОљОф ОЏОфОЋОЉОф ОћОљОфОе ОЕОю ОћОљОцОюОЎОДОдОЎОћ ОћОќОЋ</translation>
<translation id="5765517223145864268">ОаОЕОъОЌ ОюОЕОъОЋОб ОбОю ОћОЌОЋОЋОЎОћ ОЕОюОџ. ОљОцОЕОе ОњОЮ <ph name="BEGIN_LINK" />ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОЋОф<ph name="END_LINK" />.</translation>
<translation id="5765780083710877561">ОфОЎОљОЋОе:</translation>
<translation id="5776970333778123608">ОаОфОЋОаОЎОЮ ОюОљ ОЌОЕОЋОЉОЎОЮ</translation>
<translation id="5780792035410621042">ОЏОЊОЎ ОюОћОбОфОЎОД ОАОЎОАОъОљОЋОф, ОфОЌОЎОюОћ ОЎОЕ ОюОћОњОЊОЎОе ОаОбОЎОюОф ОъОАОџ ОЉОъОЏОЕОЎОе</translation>
<translation id="5793665092639000975"><ph name="SPACE_USED" /> ОъОфОЋОџ <ph name="SPACE_AVAILABLE" /> ОаОъОдОљОЎОЮ ОЉОЕОЎОъОЋОЕ</translation>
<translation id="5795872532621730126">ОЌОЎОцОЋОЕ ОЋОњОюОЎОЕОћ</translation>
<translation id="5797949256525811424">ОћОаОЋОЕОљ ОЌОАОЋОЮ</translation>
<translation id="580893287573699959">ОаОЎОћОЋОю ОћОаОЋОЕОљОЎОЮ ОЋОћОљОфОеОЎОЮ ОЕОъОбОаОЎОЎОаОЎОЮ ОљОЋОфОџ</translation>
<translation id="5809361687334836369">{HOURS,plural, =1{ОюОцОаОЎ ОЕОбОћ}one{ОюОцОаОЎ # ОЕОбОЋОф}two{ОюОцОаОЎ ОЕОбОфОЎОЎОЮ}other{ОюОцОаОЎ # ОЕОбОЋОф}}</translation>
<translation id="5810288467834065221">РђЈCopyright <ph name="YEAR" /> Google LLC.Рђј ОЏОю ОћОќОЏОЋОЎОЋОф ОЕОъОЋОеОЋОф.</translation>
<translation id="5814749351757353073">ОбОЋОДОЉОЎОЮ ОљОЌОе ОљОфОеОЎОЮ ОЕОљОЋОћОЉОЎОЮ</translation>
<translation id="5828921839638612740">РђЈОљОцОЕОе ОюОъОЌОЋОД ОљОф ОћОаОфОЋОаОЎОЮ ОЊОеОџ ОћОћОњОЊОеОЋОф ОЕОю Chrome</translation>
<translation id="5829586821381540080">ОЉОЋОдОбОћ ОЕОъОЎОеОћ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDER_NAME" /></translation>
<translation id="583281660410589416">ОюОљ ОЎОЊОЋОб</translation>
<translation id="5833984609253377421">ОЕОЎОфОЋОБ ОДОЎОЕОЋОе</translation>
<translation id="5839058148541733625">Chrome Dino</translation>
<translation id="5848257610304005265">РђЈОюОцОфОЋОЌ ОљОф ОДОЋОЉОЦ Оћ-PDF ОЉОљОъОдОбОЋОф <ph name="APP_NAME" />?</translation>
<translation id="5849288995120328556">ОюОћОцОАОЎОД ОљОф ОћОЕОЎОфОЋОБ?</translation>
<translation id="5853623416121554550">ОћОћОЋОеОЊОћ ОЉОћОЕОћОЎОћ</translation>
<translation id="5855546874025048181">ОдОъОдОЋОЮ: <ph name="REFINE_TEXT" /></translation>
<translation id="5857447844686706637">ОъОЕОћОЋ ОћОЕОфОЉОЕ. ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОбОЊОЏОЪ ОљОф ОћОъОЌОЎОе ОЕОЉОъОбОДОЉ.</translation>
<translation id="5859968346865909126">ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОцОбОЎОю ОљОЋ ОюОћОЕОЉОЎОф ОљОЋОфОЋ ОЉОћОњОЊОеОЋОф</translation>
<translation id="5860033963881614850">ОЏОЉОЋОЎ</translation>
<translation id="5860491529813859533">ОћОцОбОюОћ</translation>
<translation id="5864419784173784555">ОЉОћОъОфОаОћ ОюОћОЋОеОЊОћ ОаОЋОАОцОфРђд</translation>
<translation id="5865733239029070421">РђЈОЕОюОЎОЌОф ОЊОЋОЌОЋОф ОДОеОЎОАОћ ОЋОАОўОўОЎОАОўОЎОДОф ОЕОЎОъОЋОЕ ОљОю Google ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="5869522115854928033">ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф</translation>
<translation id="587735546353481577">РђЈОЏОЊОЎ ОюОбОДОЋОЉ ОљОЌОе ОљОфОе ОЏОюОЕОћОЋ, ОбОЋОЉОеОЎОЮ ОљОюОЎОЋ, ОцОЋОфОЌОЎОЮ ОљОф ОфОцОеОЎОў Chrome ОЋОюОЋОЌОдОЎОЮ ОбОю 'ОъОбОДОЉ'.</translation>
<translation id="5883855034004058011">ОћОљОЎОъОЋОф ОћОЉОЎОЋОъОўОеОЎ ОаОЏОЕОю ОЎОЋОфОе ОъОЊОЎ ОцОбОъОЎОЮ. ОдОеОЎОџ ОюОаОбОЋОю ОљОф ОћОъОЏОЕОЎОе ОЋОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОюОЋ ОЏОЊОЎ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="5885378508678660271">РђЈОћОфОеОљОЋОф <ph name="SEPARATOR" /> Chrome ОћОАОЎОе ОљОф ОћОћОеОЕОљОЋОф ОћОљОюОћ ОЏОЎ ОћОљОфОе ОћОќОћ ОъОАОЋОЏОЪ</translation>
<translation id="5895834791314695851">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ ОЉОДОеОЋОЉ. ОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Google Play Services. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="5899667542927581604">ОљОЎОЪ ОњОЎОюОЎОЋОЪ ОЕОю ОъОцОфОЌОЋОф ОњОЎОЕОћ ОЕОаОАОњОе</translation>
<translation id="5907542076239273525">ОћОАОЎОъОаОЎОЎОћ ОаОЕОъОеОћ ОЉОфОЎОДОЎОЎОћ <ph name="FOLDER_NAME" /></translation>
<translation id="5916664084637901428">ОцОЋОбОю</translation>
<translation id="5919204609460789179">ОЎОЕ ОюОбОЊОЏОЪ ОљОф <ph name="PRODUCT_NAME" /> ОЏОЊОЎ ОюОћОфОЌОЎОю ОАОаОЏОеОЋОЪ</translation>
<translation id="5932881020239635062">ОАОЎОЊОЋОеОЎ</translation>
<translation id="5938820472109305350">ОћОЋОАОцОћ ОЕОю ОфОЌОЋОЮ ОћОбОаОЎОЎОЪ '<ph name="INTEREST" />'</translation>
<translation id="5942872142862698679">РђЈОЕОЎОъОЋОЕ ОЉ-Google ОюОЌОЎОцОЋОЕ</translation>
<translation id="5945035219773565305">ОћОъОюОдОћ ОаОЋОЏОЌОЎОф:  <ph name="RECOMMENDATION" /></translation>
<translation id="5951119116059277034">ОъОЋОдОњ ОЊОБ ОцОбОЎОю</translation>
<translation id="5956665950594638604">РђЈОцОфОЎОЌОф ОъОеОЏОќ ОћОбОќОеОћ ОЕОю Chrome ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="59577092665511740">ОЉОЌОЎОеОф ОЌОЕОЉОЋОЪ.</translation>
<translation id="5958275228015807058">ОћОДОЉОдОЎОЮ ОЋОћОЊОцОЎОЮ ОЕОюОџ ОаОъОдОљОЎОЮ ОЉ'ОћОЋОеОЊОЋОф'</translation>
<translation id="5958994127112619898">ОЊОБ ОцОЕОЋОў ОЎОЋОфОе</translation>
<translation id="5962718611393537961">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОЏОЋОЋОЦ</translation>
<translation id="5964869237734432770">ОћОцОАОДОћ ОЕОю ОфОЎОљОЋОеОЎ ОћОфОъОЋОаОЋОф</translation>
<translation id="5977976211062815271">ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="5978661847409534366">{ITEMS_COUNT,plural, =1{ОЊОБ ОљОЌОЊ ОЉОеОЕОЎОъОф ОћОДОеОЎОљОћ}one{РђФ# ОЊОцОЎОЮ ОЉОеОЕОЎОъОф ОћОДОеОЎОљОћ}two{РђФ# ОЊОцОЎОЮ ОЉОеОЕОЎОъОф ОћОДОеОЎОљОћ}other{РђФ# ОЊОцОЎОЮ ОЉОеОЕОЎОъОф ОћОДОеОЎОљОћ}}</translation>
<translation id="5979084224081478209">ОЉОЊОЎОДОф ОћОАОЎОАОъОљОЋОф</translation>
<translation id="5992182727984874868">РђЈРђФ<ph name="PERMISSION_1" />, <ph name="PERMISSION_2" /> <ph name="SEPARATOR" /> Chrome ОћОАОЎОе ОљОф ОћОћОеОЕОљОЋОф ОћОљОюОћ ОЏОЎ ОюОљ ОаОЏОаОАОф ОюОљОЌОеОЋОаОћ</translation>
<translation id="5995726099713306770">ОюОћОЋОеОЎОЊ ОЕОЋОЉ ОљОф ОћОЊОБ?</translation>
<translation id="6000066717592683814">РђЈОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉ-Google</translation>
<translation id="6000203700195075278">ОъОбОДОЉ ОъОЌОЋОЊОЕ</translation>
<translation id="6011308810877101166">ОЕОЎОцОЋОе ОЕОю ОћОћОдОбОЋОф ОюОЌОЎОцОЋОЕ</translation>
<translation id="6013305291643746595">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОюОцОЎ ОћОцОеОЎОў ОћОЎОЕОЪ ОЉОЎОЋОфОе</translation>
<translation id="6022659036123304283">РђЈОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф Chrome ОЉОЊОеОџ ОЕОаОЋОЌОћ ОюОџ</translation>
<translation id="6026538407078977628">ОћОеОЌОЉОћ ОюОъОАОџ ОъОюОљ</translation>
<translation id="6030719887161080597">ОаОЎОћОЋОю ОћОъОЎОЊОб ОЕОъОЕОъОЕ ОљОфОеОЎОЮ ОюОъОЊОЎОЊОф ОЉОЎОдОЋОбОЎ ОъОЋОЊОбОЋОф</translation>
<translation id="6039379616847168523">ОъОбОЉОе ОюОЏОеОўОЎОАОЎОЎОћ ОћОЉОљОћ</translation>
<translation id="604124094241169006">ОљОЋОўОЋОъОўОЎ</translation>
<translation id="6042308850641462728">ОбОЋОЊ</translation>
<translation id="604996488070107836">ОћОЋОеОЊОф <ph name="FILE_NAME" /> ОаОЏОЕОюОћ ОбОДОЉ ОЕОњОЎОљОћ ОюОљ ОЎОЊОЋОбОћ.</translation>
<translation id="605721222689873409">YY</translation>
<translation id="6059830886158432458">ОЏОљОЪ ОљОцОЕОе ОюОаОћОю ОљОф ОћОАОўОЋОеОЎОќ ОЋОћОцОбОЎОюОЋОф ОЕОюОџ</translation>
<translation id="6071995715087444295">РђЈОЏОЊОЎ ОюОЉОЊОЋОД ОљОЮ ОЎОЕ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ, ОдОеОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ Google</translation>
<translation id="6078323886959318429">ОћОЋОАОцОф ОДОЎОдОЋОе ОЊОеОџ</translation>
<translation id="6085886413119427067">ОДОЉОЎОбОф ОљОЋОцОЪ ОћОћОфОЌОЉОеОЋОф ОюОљОфОеОЎОЮ ОЉОљОъОдОбОЋОф ОДОЎОЕОЋОе ОъОљОЋОЉОўОЌ</translation>
<translation id="6087286598828478206">ОюОЌОАОЋОЮ ОљОф ОћОДОЉОЋОдОћ ОЋОюОдОљОф ОъОъОаОћ?</translation>
<translation id="60923314841986378">ОаОЋОфОеОЋ <ph name="HOURS" /> ОЕОбОЋОф</translation>
<translation id="6095578583683628124">РђЈОљОЮ Google ОћОЋОљ ОњОЮ ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОћОъОЋОњОЊОе ОљОдОюОџ ОЏОЉОеОЎОеОф ОъОЌОЊОю, ОЎОЋОдОњОЋ ОюОџ ОћОдОбОЋОф ОъОЕОЋОцОеОЋОф ОЋОеОюОЋОЋОаОўОЎОЋОф ОъОЉОЌОЎОаОф ОћОДОЕОе.</translation>
<translation id="6104768972315313991">РђЈОДОЋОЊ QR ОЕОаОЋОдОе</translation>
<translation id="610630277578876674">ОцОфОЎОЌОф ОДОЎОЕОЋОеОЎОЮ ОЉОћОЋОЊОбОЋОф ОЉОъОћОЎОеОЋОф ОЋОбОЋОЊ</translation>
<translation id="6108923351542677676">ОћОћОњОЊОеОћ ОъОфОЉОдОбОфРђд</translation>
<translation id="6112702117600201073">ОеОбОаОЋОЪ ОћОЊОБ ОъОфОЉОдОб</translation>
<translation id="6122831415929794347">ОюОћОЕОЉОЎОф ОљОф 'ОњОюОЎОЕОћ ОЉОўОЋОЌОћ'?</translation>
<translation id="6124936178263837501">ОЊОЎОЋОЋОЌ ОЏОћОЋОЊОбОћ ОЕОћОЎОљ ОюОљ ОАОцОљОЮ</translation>
<translation id="6125202119952209826">ОћОдОўОеОцОЋОф ОюОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОбОЮ <ph name="OWNER_FIRST_NAME" /></translation>
<translation id="6125864963080902918"><ph name="BEGIN_LINK" />ОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ<ph name="END_LINK" /></translation>
<translation id="6127379762771434464">ОћОцОеОЎОў ОћОЋОАОе</translation>
<translation id="6130303040046284160">ОъОќОбОЋОе ОћОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="6135608400322377268">{TAB_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />)}one{РђФ<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}two{РђФ<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}other{РђФ<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="6137022273846704445">ОћОЕОцОћ ОЉ-<ph name="APP_NAME" /></translation>
<translation id="6138832295072039549">ОЏОљОЪ ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОћОњОЊОеОЋОф ОћОљОфОе ОЕОюОџ</translation>
<translation id="6140912465461743537">ОъОЊОЎОаОћ/ОљОќОЋОе</translation>
<translation id="6142183503755612900">ОфОъОЎОЊ ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОЉОеОЎОеОф ОћОъОЌОЊОю ОЉОћОњОЊОеОЋОф</translation>
<translation id="6143892791267458416">РђЈ\u0020ОЋОаОАОњОеОЋОф ОљОЌОеОЎ <ph name="DAYS_ARCHIVED" /> ОЎОъОЎОЮ</translation>
<translation id="6146563240635539929">ОАОеОўОЋОаОЎОЮ</translation>
<translation id="614890671148262506">ОюОљОфОе ОћОќОћ ОфОъОЎОЊ ОфОћОЎОћ ОћОеОЕОљОћ ОюОЕОюОЋОЌ ОћОфОеОљОЋОф</translation>
<translation id="6150320133806434356">ОћОАОЎОъОаОЎОЎОћ ОаОЕОъОеОћ</translation>
<translation id="6150706324143004339">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОаОфОЋОаОЎ Chrome ОЋОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google, ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Chrome</translation>
<translation id="6154478581116148741">ОЎОЕ ОюОћОцОбОЎОю ОаОбОЎОюОф ОъОАОџ ОЉ'ОћОњОЊОеОЋОф' ОЏОЊОЎ ОюОЎОЎОдОљ ОљОф ОћОАОЎОАОъОљОЋОф ОъОћОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="6156323911414505561">ОћОдОњОф ОАОеОњОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="6162892189396105610">РђЈОъОбОеОЏОф Chrome ОўОЋОбОаОф ОъОеОљОЕ ОЊОцОЎОЮ ОЕОАОЉОЎОе ОЕОћОъОЕОфОъОЕ ОЎОбОЉОЋОе ОљОюОЎОћОЮ.</translation>
<translation id="6170675927290506430">ОюОЊОБ ОћОњОЊОеОф ОћОћОфОеОљОЋОф</translation>
<translation id="6186394685773237175">ОюОљ ОаОъОдОљОЋ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ</translation>
<translation id="6192907950379606605">ОюОЎОдОЎОеОф ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф</translation>
<translation id="6193448654517602979">ОЉОЌОЎОеОф ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="6196315980958524839">РђЈОАОЎОАОъОљОЋОф ОаОЕОъОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="6202812185118613467">ОбОюОЎОџ ОюОћОЎОЏОаОА ОЕОЋОЉ ОЏОЊОЎ ОюОћОфОЌОЎОю ОљОф ОћОАОаОЏОеОЋОЪ</translation>
<translation id="6204781143409202534">РђЈРђФChrome ОќОЎОћОћ ОъОЕОћОЋ ОЕОаОеОљОћ ОЏОъОЋ ОАОцОљОЮ ОъОћОЏОфОЋОЉОф <ph name="DOMAIN" />.</translation>
<translation id="6205314730813004066">ОцОеОўОЎОЋОф ОЉОцОеОАОЋОЮ</translation>
<translation id="6210748933810148297">ОљОЎОаОџ <ph name="EMAIL" />?</translation>
<translation id="6211386937064921208">ОъОЋОдОњОф ОфОдОЋОњОћ ОъОДОЊОЎОъОћ ОЕОю ОћОЊОБ</translation>
<translation id="6212567362666004597">ОћОЋОАОцОф ОћОЏОеОўОЎОАОЎОЎОћ ОюОДОЉОЋОдОћ</translation>
<translation id="6221633008163990886">ОЎОЕ ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЏОЊОЎ ОюОЎОЎОдОљ ОАОЎОАОъОљОЋОф</translation>
<translation id="6225572914528673855">ОАОеОњОю ОћОЏОфОЋОЉОЋОф</translation>
<translation id="6232535412751077445">РђЈОљОЮ ОфОЋОцОбОю ОћОфОЏОЋОаОћ 'ОюОљ ОюОбОДОЋОЉ (DNT), ОЉОДОЕОћ ОќОЋ ОфОЎОЏОюОю ОЉОфОаОЋОбОф ОћОњОюОЎОЕОћ ОЕОюОџ. ОћОЕОцОбОф ОћОЉОДОЕОћ ОфОюОЋОЎОћ ОЉОљОЋОцОЪ ОћОцОбОЋОюОћ ОЕОю ОЏОю ОљОфОе РђЊ ОљОЮ ОћОЋОљ ОъОњОЎОЉ ОюОЉОДОЕОћ ОљОЋ ОюОљ, ОЋОЏОЎОдОЊ ОћОЋОљ ОъОцОеОЕ ОљОЋОфОћ.

ОюОЊОЋОњОъОћ, ОЎОЎОфОЏОЪ ОЕОЉОфОњОЋОЉОћ ОюОЉОДОЕОћ, ОљОфОеОЎОЮ ОъОАОЋОЎОъОЎОЮ ОЎОдОЎОњОЋ ОъОЋОЊОбОЋОф ОЕОљОЎОаОЪ ОъОЉОЋОАОАОЋОф ОбОю ОљОфОеОЎОЮ ОљОЌОеОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф. ОљОфОеОЎОЮ ОеОЉОЎОЮ ОЎОъОЕОЎОЏОЋ ОюОљОАОЋОБ ОљОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОЕОюОџ ОЋОюОћОЕОфОъОЕ ОЉОћОЮ, ОюОъОЕОю ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОљОЉОўОЌОћ, ОЏОЊОЎ ОюОАОцОД ОфОЋОЏОЪ, ОъОЋОЊОбОЋОф ОЋОћОъОюОдОЋОф ОЋОЏОЊОЎ ОюОЎОдОЋОе ОаОфОЋОаОЎОЮ ОАОўОўОЎОАОўОЎОЎОЮ ОюОЊОЎОЋОЋОЌ.</translation>
<translation id="6247557882553405851">РђЈОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="6251449557817521191">РђЈОюОдОцОЎОЎОћ ОЉОћОЎОАОўОЋОеОЎОћ ОЉ-Chrome</translation>
<translation id="6253680439349691381">{ITEMS_COUNT,plural, =1{РђЈОцОеОЎОў ОљОЌОЊ ОЕОъОЋОе ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОЋ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОбОюОЎОџ ОюОЕОъОЋОе ОљОЋОфОЋ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}one{РђЈРђФ# ОцОеОЎОўОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}two{РђЈРђФ# ОцОеОЎОўОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}other{РђЈРђФ# ОцОеОЎОўОЎОЮ ОЕОъОЋОеОЎОЮ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЮ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЮ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}}</translation>
<translation id="6254139308321626268">РђЈОъОЋОдОњ ОюОџ ОДОЋОЉОЦ PDF</translation>
<translation id="6255809143828972562">РђЈОЉОбОќОеОф ОћОЏОюОЎОЮ ОЕОю Chrome ОљОцОЕОе ОюОњОюОЋОЕ ОЉОЉОўОЌОћ ОЋОЉОЕОюОЎОўОћ</translation>
<translation id="6264376385120300461">ОюОћОЋОеОЎОЊ ОЉОЏОю ОќОљОф</translation>
<translation id="6264485186158353794">ОЌОќОеОћ ОюОЌОЋОБ ОъОЉОўОЌОЎОЮ</translation>
<translation id="6277522088822131679">ОљОЎОеОбОћ ОЉОбОЎОћ ОЉОбОф ОћОЊОцОАОф ОћОЊОБ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="6278428485366576908">ОбОЎОдОЋОЉ</translation>
<translation id="6284472661216707937">ОњОЎОюОЎОЋОаОЋОф ОћОАОЎОАОъОљОЋОф ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОаОАОњОеОЋ</translation>
<translation id="6291294824436685757">ОъОЌОЎОДОф ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ, ОЉОЌОЎОеОф ОаОфОЋОаОЎОЮ ОюОъОЌОЎОДОћ</translation>
<translation id="6295158916970320988">ОЏОю ОћОљОфОеОЎОЮ</translation>
<translation id="6296366034485697675">ОЎОЎОдОЋОљ ОЋОъОЌОЎОДОћ</translation>
<translation id="629730747756840877">ОЌОЕОЉОЋОЪ</translation>
<translation id="6301526076346731664">ОцОфОЎОЌОф "ОЏОюОЎОЮ ОюОъОцОфОЌОЎОЮ"</translation>
<translation id="6303969859164067831">ОЎОдОЎОљОћ ОЋОЏОЎОЉОЋОЎ ОћОАОаОЏОеОЋОЪ</translation>
<translation id="6307241780749477694">ОЏОЊОЎ ОюОДОЉОю ОљОф ОЏОю ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ, ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="6312687380483398334">ОљОцОюОЎОДОдОЎОЋОф ОљОЎОаОўОеОаОў (ОЕОДОў)</translation>
<translation id="6315386555979018699">ОъОЌОЎОДОћ ОЋОћОъОЕОџ</translation>
<translation id="6316139424528454185">РђЈОљОЎОЪ ОфОъОЎОЏОћ ОЉОњОеОАОф Android</translation>
<translation id="6324916366299863871">ОбОеОЎОЏОф ОДОЎОдОЋОе ОЊОеОџ</translation>
<translation id="6324977638108296054">ОљОЎ ОљОцОЕОе ОюОЎОдОЋОе ОДОЎОЕОЋОе ОюОўОДОАОў ОћОъОЋОЊОњОЕ</translation>
<translation id="6333140779060797560">ОЕОЎОфОЋОБ ОЉОљОъОдОбОЋОф <ph name="APPLICATION" /></translation>
<translation id="6335454563754888572">РђЈОбОеОЎОЏОф ОЏОфОЋОЉОф Оћ-URL ОЕОъОдОЉОЎОбОћ ОбОю ОћОЊОБ ОЉОЏОфОЋОЉОф: <ph name="PAGE_URL" /></translation>
<translation id="6337234675334993532">ОћОдОцОаОћ</translation>
<translation id="6340526405444716530">ОћОфОљОъОћ ОљОЎОЕОЎОф</translation>
<translation id="6341580099087024258">ОюОЕОљОЋОю ОљОЎОцОћ ОюОЕОъОЋОе ОДОЉОдОЎОЮ</translation>
<translation id="6342069812937806050">ОќОћ ОбОфОћ</translation>
<translation id="6343495912647200061">{SHIPPING_ADDRESS,plural, =1{РђЈ<ph name="SHIPPING_ADDRESS_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_ADDRESSES" /> ОаОЋОАОцОф}one{РђЈ<ph name="SHIPPING_ADDRESS_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_ADDRESSES" /> ОаОЋОАОцОЋОф}two{РђЈ<ph name="SHIPPING_ADDRESS_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_ADDRESSES" /> ОаОЋОАОцОЋОф}other{РђЈ<ph name="SHIPPING_ADDRESS_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_ADDRESSES" /> ОаОЋОАОцОЋОф}}</translation>
<translation id="6345878117466430440">ОАОЎОъОЋОЪ ОЏОцОеОЎОў ОЕОаОДОеОљ</translation>
<translation id="6347010704471250799">ОћОдОњОф ОћОфОеОљОћ</translation>
<translation id="6356893102071098867">ОбОюОЎОџ ОюОЋОЋОЊОљ ОЕОЉОЌОеОф ОЉОЌОЕОЉОЋОЪ ОћОаОЏОЋОЪ</translation>
<translation id="6363990818884053551">ОЏОЊОЎ ОюОћОфОЌОЎОю ОЉОАОаОЏОеОЋОЪ ОбОюОЎОџ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="6364438453358674297">ОћОљОЮ ОюОћОАОЎОе ОљОф ОћОћОдОбОћ ОъОћОћОЎОАОўОЋОеОЎОћ?</translation>
<translation id="6380100320871303656">РђЈОъОбОеОЏОф Chrome ОўОЋОбОаОф ОъОеОљОЕ ОЉОфОЊОЎОеОЋОф ОњОЉОЋОћОћ ОЎОЋОфОе ОЊОцОЎОЮ ОЕОАОЉОЎОе ОЕОћОъОЕОфОъОЕ ОЎОбОЉОЋОе ОљОюОЎОћОЮ. ОћОћОњОЊОеОћ ОћОќОЋ ОЎОЏОЋОюОћ ОюОњОеОЋОЮ ОюОЕОЎОъОЋОЕ ОъОЋОњОЉОе ОЉОаОфОЋОаОЎОЮ.</translation>
<translation id="6382848304055775421">ОъОфОЉОдОб ОЎОЎОдОЋОљ</translation>
<translation id="6388152137132427505">ОЌОЕОЋОЉ ОюОЕОЎОЮ ОюОЉ ОбОЮ ОъОЎ ОъОЕОфОцОЎОЮ. ОфОЋОДОБ ОћОДОЎОЕОЋОеОЎОЮ ОцОњ ОљОЌОеОЎ 48 ОЕОбОЋОф.</translation>
<translation id="6394791151443660613">ОЌОЎОцОЋОЕ: <ph name="SEARCH_QUERY" /></translation>
<translation id="6395288395575013217">ОДОЎОЕОЋОе</translation>
<translation id="6397616442223433927">ОЌОќОеОћ ОюОъОдОЉ ОљОЋОаОюОЎОЎОЪ</translation>
<translation id="6399363707848566877">ОбОЏОЕОЎОЋ ОљОцОЕОе ОюОћОЋОАОЎОБ ОЉОДОюОЋОф ОЏОеОўОЎОАОЎОЋОф ОюОДОЉОЋОдОЋОф ОЏОљОЪ</translation>
<translation id="6401458660421980302">РђЈОЏОЊОЎ ОюОЕОюОЋОЌ ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОюОъОЏОЕОЎОе ОљОЌОе, ОдОеОЎОџ ОюОћОЎОЏОаОА Ою-Chrome ОЉОъОЏОЕОЎОе ОћОљОЌОе</translation>
<translation id="6404511346730675251">ОбОеОЎОЏОф ОАОЎОъОаОЎОЎОћ</translation>
<translation id="6406506848690869874">ОАОаОЏОеОЋОЪ</translation>
<translation id="6410883413783534063">ОаОЎОфОЪ ОюОцОфОЋОЌ ОЏОеОўОЎОАОЎОЋОф ОЏОЊОЎ ОюОћОЎОЏОаОА ОљОю ОЊОцОЎОЮ ОЕОЋОаОЎОЮ ОЉОЋ-ОќОъОаОЎОф</translation>
<translation id="6411219469806822692">ОљОЎ ОљОцОЕОе ОюОќОЋОќ ОюОъОбОюОћ ОЎОЋОфОе. ОЎОЕ ОюОаОАОЋОф ОюОћОфОЌОЎОю ОъОЌОюОД ОњОЉОЋОћ ОЎОЋОфОе ОЉОЊОБ.</translation>
<translation id="641643625718530986">ОћОЊОцОАОћРђд</translation>
<translation id="6433501201775827830">ОЉОЌОЎОеОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ</translation>
<translation id="6434309073475700221">ОъОЌОЎОДОћ</translation>
<translation id="6437162790453527153">ОюОљОЌОе ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОћОАОЎОъОаОЎОЋОф ОЋОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЎОЋОцОЎОбОЋ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="6437478888915024427">ОцОеОўОЎ ОЊОБ</translation>
<translation id="6440291723980579689">ОЊОцОЎОЮ ОаОўОбОаОЎОЮ ОеОД ОљОЌОеОЎ ОЕОцОЋОфОЌОЎОЮ ОљОЋОфОЮ</translation>
<translation id="6441734959916820584">ОћОЕОЮ ОљОеОЋОџ ОъОЊОЎ</translation>
<translation id="6444291413624515012">ОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф <ph name="TAB_GROUP_TITLE" /> ОаОАОњОеОћ</translation>
<translation id="6452534462676960500">ОцОбОЎОюОЋОф ОЌОЊОЕОћ</translation>
<translation id="6459045781120991510">ОАОДОеОЎОЮ</translation>
<translation id="6461962085415701688">ОюОљ ОаОЎОфОЪ ОюОцОфОЋОЌ ОљОф ОћОДОЋОЉОЦ</translation>
<translation id="6464977750820128603">РђЈОљОцОЕОе ОюОеОљОЋОф ОљОфОеОЎОЮ ОЕОъОЉОДОеОЎОЮ ОЉОћОЮ ОЉ-Chrome ОЋОюОћОњОЊОЎОе ОўОЎОЎОъОеОЎОЮ ОЉОЕОЉОЎОюОЮ.\n\nРђЈGoogle ОъОДОЉОюОф ОъОЎОЊОб ОбОю ОћОљОфОеОЎОЮ ОЕОъОЋОњОЊОеОЎОЮ ОЉОЕОЉОЎОюОЮ ОўОЎОЎОъОеОЎОЮ ОЋОъОЕОџ ОћОЕОћОЎОЎОћ ОЕОюОџ ОЉОљОфОеОЎОЮ ОћОљОюОћ. ОћОъОЎОЊОб ОбОЋОќОе ОюОЕОцОе ОљОф 'ОЕОЎОъОЋОЕ ОЌОЏОЮ ОЉОЊОЎОњОЎОўОю'.</translation>
<translation id="6468703991511753953">ОАОеОњОю ОћОЏОфОЋОЉОЋОф ОаОъОдОљ ОЏОеОњОб ОЉОЌОюОД ОћОфОЌОфОЋОЪ</translation>
<translation id="6470181189905173055">РђЈОћОЊОцОЎОЮ ОЕОцОфОЌОф ОЉ-Chrome ОЉОќОъОЪ ОћОЕОЎОъОЋОЕ ОЉ-<ph name="APP_LABEL" /> ОЎОЋОцОЎОбОЋ ОЏОљОЪ.</translation>
<translation id="6473086018775716761">ОеОЕОЎОъОф ОљОцОЕОеОЋОЎОЋОф ОћОЕОЎОфОЋОБ ОаОцОфОЌОћ ОЉОЌОдОЎ ОћОњОЋОЉОћ.</translation>
<translation id="6475951671322991020">ОћОЋОеОЊОф ОАОеОўОЋОЪ</translation>
<translation id="6477928892249167417">ОаОеОљОћ ОЕОћОљОфОеОЎОЮ ОћОљОюОћ ОЌОЕОЋОЉОЎОЮ ОюОџ:</translation>
<translation id="6481963882741794338">РђЈОљОцОЕОе ОюОДОЕОе ОљОф Chrome ОюОЕОЎОеОЋОфОЎ Google ОљОЌОеОЎОЮ ОюОдОЋОеОџ ОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОюОъОўОеОЋОф ОљОЌОеОЋОф</translation>
<translation id="6482749332252372425">ОћОЋОеОЊОф <ph name="FILE_NAME" /> ОаОЏОЕОюОћ ОъОљОЌОе ОЕОЌОАОе ОаОцОЌ ОљОЌОАОЋОЪ.</translation>
<translation id="6486420406192123355">РђЈОДОЋОЉОЦ Оћ-PDF ОћОќОћ ОъОњОЎОб ОъОљОфОе ОЕОъОЕОфОъОЕ ОЉОЌОЎОЉОЋОе ОюОљ ОъОљОЋОЉОўОЌ</translation>
<translation id="650224091954855786">{FILE_COUNT,plural, =1{ОДОЋОЉОЦ ОљОЌОЊ ОћОЋОеОЊ}one{# ОћОЋОеОЊОЋОф ОћОЋОЕОюОъОЋ}two{# ОћОЋОеОЊОЋОф ОћОЋОЕОюОъОЋ}other{# ОћОЋОеОЊОЋОф ОћОЋОЕОюОъОЋ}}</translation>
<translation id="6508722015517270189">РђЈОћОцОбОюОћ ОъОЌОЊОЕ ОЕОю Chrome</translation>
<translation id="6513924416597632811">ОћОбОфОДОф ОћОДОЎОЕОЋОе ОюОЊОБ ОфОЋОдОљОЋОф ОћОЌОЎОцОЋОЕ ОЕОю: <ph name="SEARCH_QUERY" />. ОъОДОЋОе: <ph name="PAGE_URL" /></translation>
<translation id="6518133107902771759">ОљОЎОъОЋОф</translation>
<translation id="6527303717912515753">ОЕОЎОфОЋОБ</translation>
<translation id="652948702951888897">РђЈОћОЎОАОўОЋОеОЎОћ ОЕОю Chrome</translation>
<translation id="6532866250404780454">РђЈОљОфОеОЎОЮ ОЕОаОЏОаОАОЎОЮ ОљОюОЎОћОЮ ОЉ-Chrome ОюОљ ОЎОЋОцОЎОбОЋ. ОЏОю ОћОўОЎОЎОъОеОЎОЮ ОЕОю ОћОљОфОеОЎОЮ ОЎОЎОъОЌОДОЋ.</translation>
<translation id="6539092367496845964">ОъОЕОћОЋ ОћОЕОфОЉОЕ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="6541983376925655882">{NUM_HOURS,plural, =1{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ ОЕОбОћ ОљОЌОф}one{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЕОбОЋОф}two{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ ОЕОбОфОЎОЎОЮ}other{ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОюОцОаОЎ # ОЕОбОЋОф}}</translation>
<translation id="6545017243486555795">ОаОЎОДОЋОЎ ОЏОю ОћОаОфОЋОаОЎОЮ</translation>
<translation id="6546511553472444032">ОћОДОЋОЉОЦ ОбОюОЋОю ОюОћОќОЎОД</translation>
<translation id="6550891580932862748">РђЈОЉОъОдОЉ ОћОќОћ ОћОъОбОеОЏОф ОюОљ ОъОњОЎОаОћ ОбОюОЎОџ ОъОцОаОЎ ОљОфОеОЎОЮ, ОћОЋОеОЊОЋОф ОЋОфОЋОАОцОЎОЮ ОъОАОЋОЏОаОЎОЮ. ОћОћОњОЊОеОЋОф ОЕОДОЉОбОф ОюОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ ОЉОъОЋОдОеОЎОЮ ОљОЌОеОЎОЮ ОЕОю Google ОюОљ ОЎОЋОЕОцОбОЋ.</translation>
<translation id="6556542240154580383">{TAB_COUNT,plural, =1{ОћОЏОеОўОЎОАОЎОЎОћ <ph name="TAB_TITLE" /> ОЋОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />) ОаОЋОАОцОф ОЎОЎОАОњОеОЋ}one{ОћОЏОеОўОЎОАОЎОЎОћ <ph name="TAB_TITLE" /> ОЋ-<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОаОЋОАОцОЋОф ОЎОЎОАОњОеОЋ}two{ОћОЏОеОўОЎОАОЎОЎОћ <ph name="TAB_TITLE" /> ОЋ-<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОаОЋОАОцОЋОф ОЎОЎОАОњОеОЋ}other{ОћОЏОеОўОЎОАОЎОЎОћ <ph name="TAB_TITLE" /> ОЋ-<ph name="TAB_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОаОЋОАОцОЋОф ОЎОЎОАОњОеОЋ}}</translation>
<translation id="6560414384669816528">РђЈОЕОЎОъОЋОЕ ОЉ-Sogou ОюОЌОЎОцОЋОЕ</translation>
<translation id="656065428026159829">ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="6564820424018738527">РђЈОЉОъОЏОЕОЎОе Android ОъОЋОцОЎОбОћ ОћОњОЊОеОћ ОЊОЋОъОћ. ОљОЮ ОћОљОцОЕОеОЋОф "ОъОЊОЎОЊОф ОЉОЎОдОЋОбОЎОЮ ОЕОю ОъОЋОЊОбОЋОф" ОъОЋОцОбОюОф ОЉ-Chrome ОЋОЉОъОЏОЕОЎОе Android, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОфОћОЎОћ ОюОЌОЉОеОћ ОъОАОЋОЎОъОф ОћОеОЕОљОћ ОюОъОЊОЋОЊ ОљОф ОеОъОф ОћОљОцОДОўОЎОЉОЎОЋОф ОЕОю ОъОЋОЊОбОћ ОЏОюОЕОћОЎ ОЉОљОфОеОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОЕОЉОћОЪ ОъОЕОфОъОЕОЎОЮ.</translation>
<translation id="6565959834589222080">РђЈОћОъОЏОЕОЎОе ОЎОфОЌОЉОе ОюОеОЕОф Wi-Fi ОЏОљОЕОе ОфОћОЎОћ ОќОъОЎОаОћ</translation>
<translation id="6569373978618239158">РђЈОЉОцОфОЎОЌОф ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ, ОЎОЋОдОњОЋ ОюОџ ОАОўОЋОеОЎОќ ОъОћОљОфОе <ph name="SITE_NAME" />. ОљОфОеОЎОЮ ОЕОаОъОдОљОЎОЮ ОЉОъОбОДОЉ ОаОЕОъОеОЎОЮ ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОаОћОю ОљОЋОфОЮ ОЉОћОњОЊОеОЋОф ОЕОю Discover.</translation>
<translation id="657177046675873214">ОЏОЊОЎ ОЕОћОАОЎОъОаОЎОЋОф ОЎОЋОцОЎОбОЋ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ, ОдОеОЎОџ ОюОћОцОбОЎОю ОљОф ОћОљОцОЕОеОЋОф "ОАОЎОъОаОЎОЋОф" ОЉОћОњОЊОеОЋОф</translation>
<translation id="6573096386450695060">ОљОаОЎ ОеОЋОдОћ ОюОљОцОЕОе ОфОъОЎОЊ</translation>
<translation id="6573431926118603307">РђЈОЏОеОўОЎОАОЎОЋОф ОЕОцОфОЌОф ОЉ-Chrome ОЉОъОЏОЕОЎОеОЎОЮ ОћОљОЌОеОЎОЮ ОЕОюОџ ОЎОЋОцОЎОбОЋ ОЏОљОЪ.</translation>
<translation id="6583199322650523874">ОАОЎОъОЋОЪ ОћОЊОБ ОћОаОЋОЏОЌОЎ ОЉОАОЎОъОаОЎОЎОћ</translation>
<translation id="6588043302623806746">РђЈОЕОЎОъОЋОЕ ОЉ-DNS ОъОљОЋОЉОўОЌ</translation>
<translation id="6590471736817333463">ОЌОЎОАОЏОЋОЪ ОЕОю ОбОЊ 60% ОЉОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="6590680911007613645">ОЎОЕ ОюОЋОЋОЊОљ ОЕОћОАОЎОАОъОћ ОЕОаОЕОъОеОф ОќОћОћ ОюОАОЎОАОъОћ ОЕОюОџ ОбОЉОЋОе <ph name="SITE" /></translation>
<translation id="6593061639179217415">ОљОфОе ОЕОъОЋОфОљОЮ ОюОъОЌОЕОЉ</translation>
<translation id="6594347733515723558">ОљОцОЕОеОЋОЎОЋОф ОюОъОЎОЋОЪ ОЋОюОћОдОњОћ</translation>
<translation id="6595046016124923392">РђЈОћОфОъОЋОаОЋОф ОаОЕОюОЌОЋОф ОљОю Google ОЏОЊОЎ ОюОЕОцОе ОљОф ОћОфОЎОљОЋОеОЎОЮ ОюОаОЋОЌОЎОЋОфОџ.</translation>
<translation id="6604931690954120417">РђЈОљОЌОеОЎ ОЕОаОЏОаОАОЎОЮ ОюОЌОЕОЉОЋОЪ ОЉ-Chrome, ОћОАОЎОАОъОљОЋОф ОЕОаОЕОъОеОЋОф ОъОљОЋОЌОАОаОЋОф ОЉОЌОЕОЉОЋОЪ Google. ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф ОћОљОцОЕОеОЋОф ОћОќОЋ <ph name="BEGIN_LINK" />ОЉОћОњОЊОеОЋОф<ph name="END_LINK" />.</translation>
<translation id="661266467055912436">ОеОъОф ОљОЉОўОЌОћ ОъОЕОЋОцОеОф ОбОЉОЋОеОџ ОЋОбОЉОЋОе ОЏОю ОъОЎ ОЕОъОфОЌОЉОе ОюОљОЎОаОўОеОаОў.</translation>
<translation id="6621391692573306628">РђЈОЏОЊОЎ ОюОЕОюОЋОЌ ОљОф ОћОЏОеОўОЎОАОЎОЎОћ ОћОќОЋ ОюОъОЏОЕОЎОе ОљОЌОе, ОдОеОЎОџ ОюОћОЎОЏОаОА Ою-Chrome ОЉОЕОаОЎ ОћОъОЏОЕОЎОеОЎОЮ</translation>
<translation id="6627583120233659107">ОбОеОЎОЏОф ОћОфОЎОДОЎОЎОћ</translation>
<translation id="6633067410344541938">ОЉОЎОўОЋОю ОћОаОбОЎОюОћ ОЕОю ОћОъОдОЉ ОћОцОеОўОЎ</translation>
<translation id="6636623428211296678">ОљОцОЕОе ОюОбОЎОЎОЪ ОюОъОўОћ ОЉОћОњОЊОеОЋОф ОаОЋОАОцОЋОф ОљОЋ ОюОАОЎОЎОЮ ОбОЏОЕОЎОЋ.</translation>
<translation id="6637100877383020115">РђЈОЏОЊОЎ ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОћОљОцОюОЎОДОдОЎОћ, Chrome ОЎОЕОюОЌ ОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЋОДОеОЎОАОЋОф ОљОю Google. <ph name="BEGIN_UMA_LINK" />ОаОЎОћОЋОю<ph name="END_UMA_LINK" /></translation>
<translation id="6640207029842583248">ОЌОАОЎОъОћ ОЏОю ОћОќОъОЪ</translation>
<translation id="6641780377503683465">ОћОАОеОћ ОЕОю ОфОЌОЋОЮ ОћОбОаОЎОЎОЪ '<ph name="INTEREST" />'</translation>
<translation id="6647441008198474441">РђЈОЏОфОЋОЉОЋОф URL ОЕОЉОћОЪ ОЉОЎОДОеОф ОЎОЎОЕОюОЌОЋ ОљОю Google ОЏОЊОЎ ОюОЌОќОЋОф ОљОф ОћОљОфОеОЎОЮ ОћОЉОљОЎОЮ ОЕОљОюОЎОћОЮ ОфОфОЉОдОб ОЏОаОЎОАОћ ОбОю ОЎОЊОџ</translation>
<translation id="6648977384226967773">{CONTACT,plural, =1{РђЈ<ph name="CONTACT_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_CONTACTS" /> ОаОЋОАОБ}one{РђЈ<ph name="CONTACT_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_CONTACTS" /> ОаОЋОАОцОЎОЮ}two{РђЈ<ph name="CONTACT_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_CONTACTS" /> ОаОЋОАОцОЎОЮ}other{РђЈ<ph name="CONTACT_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_CONTACTS" /> ОаОЋОАОцОЎОЮ}}</translation>
<translation id="6649642165559792194">ОћОдОњОф ОћОфОъОЋОаОћ ОЉОфОдОЋОњОћ ОъОДОЊОЎОъОћ <ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="6657585470893396449">ОАОЎОАОъОћ</translation>
<translation id="666731172850799929">ОцОфОЎОЌОћ ОЉ-<ph name="APP_NAME" /></translation>
<translation id="6671495933530132209">ОћОбОфОДОф ОћОфОъОЋОаОћ</translation>
<translation id="6672697278890207089">ОћОќОЪ ОљОф ОъОЕОцОў ОћОАОЎОАОъОћ</translation>
<translation id="6672917148207387131">ОћОЋОАОцОћ ОЕОю <ph name="DOMAIN" /></translation>
<translation id="6674571176963658787">ОЏОЊОЎ ОюОћОфОЌОЎОю ОюОАОаОЏОеОЪ ОдОеОЎОџ ОюОћОќОЎОЪ ОљОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ</translation>
<translation id="6676927815633975364">РђЈОЏОаОЎОАОћ ОюОљОфОе ОћОќОћ ОЋОю-Chrome</translation>
<translation id="6684809838922667136">РђЈОъОЕОцОеОЎОЮ ОљОф Chrome</translation>
<translation id="6700279777779583398">ОћОЉОЌОЎОеОЋОф ОаОЕОъОеОЋ</translation>
<translation id="6704048624334633734">ОЎОЎОдОЋОљ ОЋОъОЌОЎОДОћ ОЕОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="670498945988402717">ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОљОфОъОЋОю</translation>
<translation id="6710213216561001401">ОћОДОЋОЊОЮ</translation>
<translation id="671481426037969117">ОќОъОЪ ОћОЕОЎОъОЋОЕ ОЉОљОцОюОЎОДОдОЎОћ <ph name="FQDN" /> ОћОАОфОЎОЎОЮ. ОћОўОЎОЎОъОе ОЎОЋОцОбОю ОъОЌОЊОЕ ОъОЌОе ОЋОљОќ ОљОцОЕОе ОЎОћОЎОћ ОюОћОЕОфОъОЕ ОЕОЋОЉ ОЉОљОцОюОЎОДОдОЎОћ.</translation>
<translation id="6715020873764921614">ОеОЋОдОћ ОюОћОЋОеОЎОЊ ОљОф <ph name="FILE_NAME" /> (<ph name="FILE_SIZE" />) ОЉОЏОю ОќОљОф?</translation>
<translation id="671928215901716392">ОъОАОџ ОаОбОЎОюОћ</translation>
<translation id="6723740634201835758">РђЈОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="6734310707649923383">ОЉОЊОБ ОћОћОЎОАОўОЋОеОЎОћ ОљОцОЕОе ОюОеОљОЋОф ОљОЋ ОюОъОЌОЋОД ОљОф ОћОЊОцОЎОЮ ОЕОаОЏОаОАОф ОљОюОЎОћОЮ</translation>
<translation id="6738867403308150051">ОћОћОЋОеОЊОћ ОъОфОЉОдОбОф...</translation>
<translation id="674388916582496364">РђЈОЉОћОеОЉОћ ОљОфОеОЎОЮ ОаОћОЋОњ ОюОЕОъОЋОе ОљОф ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОю ОћОъОЉОДОеОЎОЮ ОЏОЊОЎ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОЌОЋОЋОЎОЎОф ОћОњОюОЎОЕОћ. ОЉОаОЋОАОБ, ОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОЕОъОЋОе ОъОЎОЊОб ОЉ-Chrome ОюОњОЉОЎ ОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОћОљОюОћ.</translation>
<translation id="6746338529702829275">ОЉОЊОЎОДОћ ОЕОю ОаОфОЋОаОЎ ОћОЌОЕОЉОЋОЪ</translation>
<translation id="6751521182688001123">ОцОфОЎОЌОф ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЉОъОћОЎОеОЋОф. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="6756507620369789050">ОЕОЎОфОЋОБ ОъОЕОЋОЉ</translation>
<translation id="6762511428368667596"><ph name="NAME" />,РђЈ <ph name="EMAIL" />.</translation>
<translation id="676305334223455055">ОдОеОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЏОЊОЎ ОюОДОЉОю ОфОЋОЏОЪ ОЕОъОЋОфОљОЮ ОюОфОЌОЋОъОЎ ОћОбОаОЎОЎОЪ ОЕОюОџ</translation>
<translation id="6764137532716892442">ОцОбОЎОюОЋОф ОЌОЊОЕОћ ОЉОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф ОћОъОЕОЋОфОцОф "<ph name="GROUP_TITLE" />"</translation>
<translation id="6767294960381293877">ОеОЕОЎОъОф ОћОъОЏОЕОЎОеОЎОЮ ОЕОљОцОЕОе ОюОЕОфОБ ОљОЎОфОЮ ОЏОеОўОЎОАОЎОЎОћ ОаОцОфОЌОћ ОЉОЌОдОЎ ОњОЋОЉОћ ОћОъОАОџ.</translation>
<translation id="6785476624617658922">РђЈОфОаОљОЎОЮ ОЋОћОњОЉОюОЋОф ОаОЋОАОцОЎОЮ ОЕОю Chrome ОЋОЕОю ChromeOS</translation>
<translation id="6795633245022906657">ОцОфОЎОЌОф ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЉОъОћОЎОеОЋОф. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="679588508577699489">РђЈОћОњОЊОеОф Chrome ОЏОЊОцОЊОцОЪ ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="679956319013005046">РђЈОЏОЊОЎ ОюОћОњОЊОЎОе ОљОф ОћОЕОЎОеОЋОф ОћОъОЋОбОЊОБ ОюОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ, ОдОеОЎОџ ОДОЋОЊОЮ ОюОћОЋОАОЎОБ ОљОф ОћОЕОЎОеОЋОф ОЉ<ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф Android<ph name="END_LINK" />.</translation>
<translation id="6802555630140434547">ОћОЌОюОЋОЪ ОћОќОћ ОЎОЎОАОњОе</translation>
<translation id="6803791793483522764">ОЉОЊОЎОДОф ОћОћОфОеОљОЋОф</translation>
<translation id="6811034713472274749">ОћОЊОБ ОъОЋОЏОЪ ОюОћОдОњОћ</translation>
<translation id="6813359536773993594">{FILE_COUNT,plural, =1{ОфОъОЋОаОЋОф, ОфОъОЋОаОћ ОљОЌОф ОЉОеОЕОЎОъОћ}one{ОфОъОЋОаОЋОф, # ОфОъОЋОаОЋОф ОЉОеОЕОЎОъОћ}two{ОфОъОЋОаОЋОф, # ОфОъОЋОаОЋОф ОЉОеОЕОЎОъОћ}other{ОфОъОЋОаОЋОф, # ОфОъОЋОаОЋОф ОЉОеОЕОЎОъОћ}}</translation>
<translation id="6813446258015311409">РђЈОЏОаОЎОАОћ Ою-Chrome, ОцОфОЋОЌ.</translation>
<translation id="6817747507826986771">ОЕОЎОфОЋОБ ОћОЊОБ ОћОќОћ ОЉОъОћОЎОеОЋОф. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="6820686453637990663">CVC</translation>
<translation id="6820942662346226299">РђЈОћОбОЊОЏОЋОЪ ОЕОю ОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОаОАОњОе</translation>
<translation id="6824933543577433709">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОћОцОбОЎОюОЋОф ОћОљОЌОеОЋОаОћ ОАОњОЋОе</translation>
<translation id="6828070228333235514">ОћОцОАОДОф ОћОъОбОДОЉ ОљОЌОе ОъОЌОЎОеОЎОЮ</translation>
<translation id="6830728435402077660">ОюОљ ОъОљОЋОЉОўОЌ</translation>
<translation id="6831043979455480757">ОфОеОњОЋОЮ</translation>
<translation id="6846298663435243399">ОћОўОбОЎОаОћ ОъОфОЉОдОбОф...</translation>
<translation id="6850409657436465440">ОћОћОЋОеОЊОћ ОбОЊОЎОЎОЪ ОъОфОЉОдОбОф</translation>
<translation id="6850830437481525139"><ph name="TAB_COUNT" /> ОЏОеОўОЎОАОЎОЋОф ОаОАОњОеОЋ</translation>
<translation id="685340923442249391">{FILE_COUNT,plural, =1{ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ, ОДОЋОЉОЦ ОљОЋОЊОЎОЋ ОљОЌОЊ ОЉОеОЕОЎОъОћ}one{ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ, # ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ ОЉОеОЕОЎОъОћ}two{ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ, # ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ ОЉОеОЕОЎОъОћ}other{ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ, # ОДОЋОЉОдОЎ ОљОЋОЊОЎОЋ ОЉОеОЕОЎОъОћ}}</translation>
<translation id="685850645784703949">РђЈDiscover by Google РђЊ ОъОЋОЕОЉОф</translation>
<translation id="6861722405755529743">ОЏОцОфОЋОе ОюОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф ОЉОАОеОњОю ОћОАОЎОъОаОЎОЋОф</translation>
<translation id="686366188661646310">ОюОъОЌОЋОД ОљОф ОћОАОЎОАОъОћ?</translation>
<translation id="6864459304226931083">ОћОЋОеОЊОф ОфОъОЋОаОћ</translation>
<translation id="686490460830618322">ОњОЎОюОЎОЋОЪ ОћОАОЎОаОЋОЪ ОюОцОЎ ОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="6865313869410766144">ОаОфОЋОаОЎ ОўОцОАОЎОЮ ОюОъОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="6867400383614725881">ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОЌОЊОЕОћ</translation>
<translation id="686899695320434745">РђЈОћОЏОфОЋОЉОЋОф ОюОљ ОъОЋОдОцОаОЋОф ОЉОљОъОдОбОЋОф ОЉОЎОўОЋОЎ ОћОАОЎОАОъОћ. ОцОбОЋОюОћ ОќОЋ ОъОљОцОЕОеОф ОюОџ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОЕОЎОеОЋОфОЎ Google ОљОЌОеОЎОЮ.</translation>
<translation id="687838958001010630">ОЏОю ОъОЎ ОЕОЎОЕ ОюОЋ ОљОф ОћОДОЎОЕОЋОе ОЎОЏОЋОю ОюОбОеОЋОџ ОљОф ОЏОю ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="6880903702195291049">ОаОеОљОћ ОЕОћОЏОЋОю ОЉОАОЊОе ОЉОћОеОЕОљОЋОф</translation>
<translation id="6883204995689174413">ОЕОЎОфОЋОБ</translation>
<translation id="6883606786470492001">ОљОцОЕОе ОюОаОћОю ОљОф ОаОЋОЕОљОЎ ОћОъОЋОЊОбОЋОф ОЋОћОњОЊОеОЋОф ОљОЌОеОЋОф ОЏОЊОЎ ОюОћОњОЉОЎОю ОљОф ОћОъОЎОЊОб ОЕОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОДОЉОю ОбОюОЎОџ ОЏОЊОЎ ОюОћОдОЎОњ ОюОџ ОъОЋОЊОбОЋОф ОЉОћОфОљОъОћ ОљОЎОЕОЎОф</translation>
<translation id="6883906387682976294">ОЉОЎОўОЋОю ОћОћОеОЕОъОћ ОюОДОЉОюОф ОћОфОеОљОЋОф ОъОћОљОфОе ОћОќОћ</translation>
<translation id="688398477366397178">ОЎОЕ ОљОцОЕОеОЋОф ОюОћОњОЊОЎОе ОљОф ОћОЕОцОЋОф ОЕОЊОЋОЉОеОЎОЮ ОЏОџ ОЕОћОЪ ОЎОћОЎОЋ ОЎОЊОЋОбОЋОф ОюОљОфОеОЎОЮ. ОЎОЋОдОњ ОЉОћОЮ ОфОЋОЏОЪ ОЉОЕОцОЋОф ОћОљОюОћ, ОЏОЕОћОЊОЉОе ОЎОфОљОцОЕОе.</translation>
<translation id="6885933993535178919">{NUM_SITES,plural, =1{ОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ ОюОљОфОе ОљОЌОЊ}one{ОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ Ою-# ОљОфОеОЎОЮ}two{ОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ Ою-# ОљОфОеОЎОЮ}other{ОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ Ою-# ОљОфОеОЎОЮ}}</translation>
<translation id="6886500155621657325">{ITEMS_COUNT,plural, =1{ОАОЎОАОъОћ ОљОЌОф}one{РђФ# ОАОЎОАОъОљОЋОф}two{РђФ# ОАОЎОАОъОљОЋОф}other{РђФ# ОАОЎОАОъОљОЋОф}}</translation>
<translation id="688730033107341407">РђЈОљОЌОеОЎ ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ, ОћОАОЎОъОаОЎОЋОф, ОћОАОЎОАОъОљОЋОф ОЋОцОеОўОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-Google ОЎОЋОАОеОЋ ОъОћОъОЏОЕОЎОе ОћОќОћ.</translation>
<translation id="688738109438487280">ОћОЋОАОцОф ОаОфОЋОаОЎОЮ ОДОЎОЎОъОЎОЮ ОљОю <ph name="TO_ACCOUNT" />.</translation>
<translation id="6891726759199484455">ОЉОЎОўОЋОю ОћОаОбОЎОюОћ ОЎОљОцОЕОе ОюОћОбОфОЎОД ОљОф ОћОАОЎОАОъОћ</translation>
<translation id="6896758677409633944">ОћОбОфОДОћ</translation>
<translation id="6898797562238201317">РђЈОЕОЎОъОЋОЕ ОЉОЉОЎОўОЋОЎ ОАОЎОАОъОћ ОъОЕОюОџ ОЏОЊОЎ ОюОћОдОцОЎОЪ ОљОф ОЏОю ОаОфОЋОаОЎ Chrome ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="6900532703269623216">ОћОњОаОћ ОъОЕОЋОцОеОф</translation>
<translation id="6903907808598579934">ОћОцОбОюОф ОћОАОаОЏОеОЋОЪ</translation>
<translation id="6906448540340261898">РђЈОЏОЊОљОЎ ОюОЋОЋОЊОљ ОЕОфОъОЎОЊ ОфОћОЎОћ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ</translation>
<translation id="6908230663105268638">ОюОљОфОе <ph name="SITE_NAME" /> ОЎОЕ ОћОеОЕОљОћ ОюОЕОюОЋОЌ ОћОфОеОљОЋОф</translation>
<translation id="6908998565271542516">ОљОцОЕОеОЋОф ОюОљОЕОе ОљОЋ ОюОљ ОюОљОЕОе ОљОфОе ОЕОъОЋОдОњОф ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="6909589135458168665">ОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОЊОцОЎОЮ</translation>
<translation id="6910211073230771657">ОаОъОЌОД</translation>
<translation id="6918398787259831832">ОљОЮ ОћОЉОбОЎОћ ОаОъОЕОЏОф, <ph name="BEGIN_LINK" />ОаОЎОфОЪ ОюОбОЎОЎОЪ ОЉОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /> ОЉ-<ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" />.</translation>
<translation id="6922812712751566567">РђЈРђФ<ph name="PERMISSION" /> <ph name="SEPARATOR" /> Chrome ОћОАОЎОе ОљОф ОћОћОеОЕОљОЋОф ОћОљОюОћ ОЏОЎ ОюОљ ОаОЏОаОАОф ОюОљОЌОеОЋОаОћ</translation>
<translation id="6927821422725196292">{TABS_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф}one{РђФ<ph name="NUMBER_OF_TABS" /> ОЏОеОўОЎОАОЎОЋОф}two{РђФ<ph name="NUMBER_OF_TABS" /> ОЏОеОўОЎОАОЎОЋОф}other{РђФ<ph name="NUMBER_OF_TABS" /> ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="6929224077895306814">РђЈОЏОю ОДОЋОЊОЎ ОћОљОЉОўОЌОћ ОЕОаОЕОъОеОЋ ОЉОъОЏОЕОЎОе ОЋОЉОЌОЕОЉОЋОЪ Google ОЕОюОџ ОЎОЎОъОЌОДОЋ</translation>
<translation id="6937524809504266803">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЋОДОЎОЕОЋОе</translation>
<translation id="6937876069006524083">ОЏОЎОаОЋОЎ (ОљОЋОцОдОЎОЋОаОюОЎ)</translation>
<translation id="6942665639005891494">ОаОЎОфОЪ ОфОъОЎОЊ ОюОЕОаОЋОф ОљОф ОъОЎОДОЋОЮ ОЉОеОЎОеОф ОћОъОЌОЊОю ОюОћОЋОеОЊОЋОф ОЊОеОџ ОћОљОцОЕОеОЋОф 'ОћОњОЊОеОЋОф' ОЉОфОцОеОЎОў</translation>
<translation id="694267552845942083">ОъОфОЉОдОбОф ОбОЏОЕОЎОЋ ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОњОЊОеОЋОф ОћОАОаОЏОеОЋОЪ. ОЏОЊОЎ ОюОћОЕОюОЎОЮ ОљОф ОћОцОбОюОф ОћОАОаОЏОеОЋОЪ ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОћОЏОцОфОЋОе 'ОљОЎОЕОЋОе', ОДОеОЋОЉ ОюОфОЌОфОЎОф ОћОъОАОџ. ОаОЎОЋОЋОў ОюОъОбОюОћ</translation>
<translation id="6945221475159498467">ОЉОЌОЎОеОћ</translation>
<translation id="6955535239952325894">ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф ОЉОЊОцОЊОцОаОЎОЮ ОъОаОЋОћОюОЎОЮ</translation>
<translation id="6963766334940102469">ОъОЌОЎОДОф ОАОЎОъОаОЎОЋОф</translation>
<translation id="6964300328304469089">ОћОЌОЕОЉОЋОЪ ОћОаОЋОЏОЌОЎ: <ph name="NAME" />, <ph name="EMAIL" />. ОбОюОЎОџ ОюОЉОЌОЋОе ОЌОЕОЉОЋОЪ.</translation>
<translation id="696447261358045621">ОюОдОљОф ОъОћОъОдОЉ ОћОљОаОЋОаОЎОъОЎ?</translation>
<translation id="6965382102122355670">ОљОЎОЕОЋОе</translation>
<translation id="6968350777423863208">{NUMBER_OF_TABS,plural, =1{ОћОдОњОф ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TABS_COUNT_ONE" />) ОбОЮ ОцОбОЎОюОЋОф ОЌОЊОЕОћ ОЉОДОЉОЋОдОЋОф ОћОъОЕОЋОфОцОЋОф ОЕОю ОћОЏОеОўОЎОАОЎОЋОф}one{ОћОдОњОф <ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОбОЮ ОцОбОЎОюОЋОф ОЌОЊОЕОћ ОЉОДОЉОЋОдОЋОф ОћОъОЕОЋОфОцОЋОф ОЕОю ОћОЏОеОўОЎОАОЎОЋОф}two{ОћОдОњОф <ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОбОЮ ОцОбОЎОюОЋОф ОЌОЊОЕОћ ОЉОДОЉОЋОдОЋОф ОћОъОЕОЋОфОцОЋОф ОЕОю ОћОЏОеОўОЎОАОЎОЋОф}other{ОћОдОњОф <ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОбОЮ ОцОбОЎОюОЋОф ОЌОЊОЕОћ ОЉОДОЉОЋОдОЋОф ОћОъОЕОЋОфОцОЋОф ОЕОю ОћОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="6971862865055170158">ОюОљ ОюОљОЕОе</translation>
<translation id="6976223255612495095">РђФ<ph name="TAB_TITLE" />, ОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОљОЋ ОЏОеОўОЎОАОЎОЎОћ ОЕОбОЋОЊОЏОаОћ</translation>
<translation id="6976811588313110624">ОћОЋОАОцОф ОъОДОЕ ОДОЎОдОЋОе ОЌОЊОЕ.</translation>
<translation id="6978717888677691380">ОљОфОеОЎОЮ ОЕОЌОАОъОф</translation>
<translation id="6979737339423435258">ОъОЕОЌОе ОћОћОЎОАОўОЋОеОЎОћ</translation>
<translation id="6983306615164277634">ОљОцОЕОе ОњОЮ ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю ОАОеОњОю ОћОЏОфОЋОЉОЋОф ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОъОЎОДОЋОЮ.</translation>
<translation id="6987047470128880212">ОъОдОЉ ОљОаОЋОаОЎОъОЎ ОюОљ ОќОъОЎОЪ ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="6991701761229081516">РђЈОћОъОбОеОЏОф ОфОЋОеОЎОЊ ОљОф ОћОАОЎОАОъОљОЋОф ОЏОДОЋОЉОЦ CSV. ОћОЪ ОЎОћОЎОЋ ОњОюОЋОЎОЋОф ОюОЏОю ОъОЎ ОЕОЎОЕ ОюОЋ ОњОЎОЕОћ ОюОДОЋОЉОЦ, ОЏОЋОюОю ОљОцОюОЎОДОдОЎОЋОф. ОћОАОЎОАОъОљОЋОф ОЕОЎОЋОдОљОЋ ОЎОЎОъОЌОДОЋ Оъ-Chrome.</translation>
<translation id="6996145122199359148">ОћОЋОеОЊОф ОћОЊОБ ОћОќОћ</translation>
<translation id="7013762323294215682">ОъОцОфОЌ ОћОњОЎОЕОћ ОћОќОћ ОЎОЎОЕОъОе ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф. ОЏОю ОъОЎ ОЕОЎОЕ ОюОЋ ОњОЎОЕОћ ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЎОЋОЏОю ОюОћОЕОфОъОЕ ОЉОЋ.</translation>
<translation id="7020741890149022655">ОћОЋОАОцОћ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ <ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="7022756207310403729">ОцОфОЎОЌОћ ОЉОЊОцОЊОцОЪ</translation>
<translation id="7029809446516969842">ОАОЎОАОъОљОЋОф</translation>
<translation id="7053256416619638731">ОЌОЎОќОЋОД ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="7053983685419859001">ОЌОАОЎОъОћ</translation>
<translation id="7054588988317389591">ОеОЋОдОћ ОюОДОЉОю ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф?</translation>
<translation id="7057969023583258980">РђЈОцОфОЎОЌОф ОћОћОЎОАОўОЋОеОЎОћ ОћОъОюОљОћ ОЉ-Chrome</translation>
<translation id="7063006564040364415">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОЌОЉОе ОљОю ОЕОеОф ОћОАОаОЏОеОЋОЪ.</translation>
<translation id="7071521146534760487">ОаОЎОћОЋОю ОЌОЕОЉОЋОЪ</translation>
<translation id="707155805709242880">ОЎОЕ ОюОЉОЌОЋОе ОюОъОўОћ ОъОћ ОюОАОаОЏОеОЪ</translation>
<translation id="7077143737582773186">РђЈОЏОеОўОЎОА SD</translation>
<translation id="7078916049958741685">РђЈОдОеОЎОџ ОюОъОЌОЋОД ОњОЮ ОљОф ОаОфОЋОаОЎ Chrome ОъОћОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="7085332316435785646">РђЈОЉОЋОЌОеОЎОЮ ОљОЮ ОюОЏОюОЋОю ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОЉ-Chrome ОюОћОфОљОъОћ ОљОЎОЕОЎОф ОъОЊОЋОЎОДОф ОЎОЋОфОе ОЉОЕОЎОеОЋОфОЎ Google</translation>
<translation id="7088681679121566888">РђЈChrome ОъОбОЋОЊОЏОЪ</translation>
<translation id="7106762743910369165">ОћОЊОцОЊОцОЪ ОъОаОЋОћОю ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="7111394291981742152">РђЈОЉ-Chrome ОЎОЕ ОюОџ ОЎОЋОфОе ОЕОюОЎОўОћ ОЉОъОЋОЊОбОЋОф ОЕОъОЋОдОњОЋОф ОюОџ, ОЋОЌОюОЋОф ОћОњОЉОюОЋОф ОбОю ОћОъОЎОЊОб ОбОюОЎОџ ОЕОћОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОДОЉОю ОЉОћОдОњОф ОъОЋОЊОбОЋОф ОЉОћОфОљОъОћ ОљОЎОЕОЎОф.</translation>
<translation id="7117485132243600300">ОаОЎОћОЋОю ОћОфОЋОЏОЪ ОЕОЉОъОбОДОЉ ОЕОюОџ ОЋОћОъОюОдОЋОф ОюОаОЋОЕОљОЎОЮ ОЋОюОЌОЎОцОЋОЕОЎОЮ</translation>
<translation id="7136902389402789299">{NUM_SITES,plural, =1{ОаОЉОЊОДОЋ ОћОеОЕОљОЋОф ОЕОю ОљОфОе ОљОЌОЊ}one{ОаОЉОЊОДОЋ ОћОћОеОЕОљОЋОф ОЕОю # ОљОфОеОЎОЮ}two{ОаОЉОЊОДОЋ ОћОћОеОЕОљОЋОф ОЕОю # ОљОфОеОЎОЮ}other{ОаОЉОЊОДОЋ ОћОћОеОЕОљОЋОф ОЕОю # ОљОфОеОЎОЮ}}</translation>
<translation id="7138678301420049075">ОљОЌОе</translation>
<translation id="7140829094791862589">ОъОЎОЋОЪ ОюОцОЎ ОАОЊОе ОЎОЊОаОЎ</translation>
<translation id="7146622961999026732">ОаОеОљОћ ОЕОћОљОфОеОЎОЮ ОЋОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОћ ОЌОЕОЋОЉОЎОЮ ОюОџ:</translation>
<translation id="7148400116894863598"><ph name="BEGIN_LINK" />ОаОЎОфОЪ ОюОбОЎОЎОЪ ОЉОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /> Оъ-<ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" />.</translation>
<translation id="7149893636342594995">ОъОћОЎОЋОЮ ОћОљОЌОеОЋОЪ</translation>
<translation id="71503698506017927">РђЈОћОдОцОаОћ ОЕОю ОЉОЎОўОЋОЎ ОАОЎОАОъОћ ОюОљ ОЏОЋОюОюОф ОљОъОдОбОЎ ОфОЕОюОЋОЮ ОЋОЏОфОЋОЉОЋОф Оъ-Google Pay.

ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ, ОбОюОЎОџ <ph name="BEGIN_LINK" />ОюОъОЌОЋОД ОљОф ОаОфОЋОаОЎ Chrome ОЉОЌОЕОЉОЋОЪ<ph name="END_LINK" />.</translation>
<translation id="7168323970702333693">ОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ ОЉОфОЋОе <ph name="USER_NAME" />. ОћОћОњОЊОеОЋОф ОЎОЎОцОфОЌОЋ.</translation>
<translation id="7173114856073700355">ОцОфОЎОЌОф ОћОћОњОЊОеОЋОф</translation>
<translation id="7173338713290252554">ОћОЎОАОўОЋОеОЎОЎОф ОћОъОЌОЎОеОЎОЮ ОЉОљОЎОаОўОеОаОў</translation>
<translation id="7177466738963138057">ОљОцОЕОе ОюОЕОаОЋОф ОљОф ОћОћОњОЊОеОћ ОћОќОЋ ОъОљОЋОЌОе ОЎОЋОфОе ОЉ'ОћОњОЊОеОЋОф'</translation>
<translation id="7177873915659574692">РђЈОюОљ ОаОЎОфОЪ ОюОЎОдОЋОе ОДОЋОЊ QR. ОЏОфОЋОЉОф Оћ-URL ОъОЏОЎОюОћ ОЎОЋОфОе Оъ-<ph name="CHARACTER_LIMIT" /> ОфОЋОЋОЎОЮ.</translation>
<translation id="7180611975245234373">ОеОбОаОЋОЪ</translation>
<translation id="7182051712900867547">ОЕОЎОъОЋОЕ ОЉОЌОЕОЉОЋОЪ ОљОЌОе</translation>
<translation id="7183517696921903380">ОњОЎОюОЎОЋОЪ ОћОАОЎОаОЋОЪ ОюОцОЎ ОљОцОюОЎОДОдОЎОЋОф ОцОфОЋОЌ.</translation>
<translation id="7186568385131859684">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЕОюОЋОў ОЉОЊОеОЏОЎОЮ ОЕОЉОћОЪ ОаОЕОфОъОЕ ОЉОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЉОЎОЌОЊ ОбОЮ ОЕОљОе ОћОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОЕОЎОеОЋОфОЎ Google</translation>
<translation id="7190921792980745354">ОюОЌОАОЋОЮ ОљОф <ph name="MEMBER_FULL_NAME" />?</translation>
<translation id="7191430249889272776">ОћОЏОеОўОЎОАОЎОЎОћ ОаОцОфОЌОћ ОЉОеОДОб.</translation>
<translation id="7192397795254933433">{NUM_PASSWORDS,plural, =1{ОдОеОЎОџ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОћ ОћОќОЋ ОбОЏОЕОЎОЋ}one{ОдОеОЎОџ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОљОЋОф ОћОљОюОћ ОбОЏОЕОЎОЋ}two{ОдОеОЎОџ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОљОЋОф ОћОљОюОћ ОбОЏОЕОЎОЋ}other{ОдОеОЎОџ ОюОЕОаОЋОф ОљОф ОћОАОЎОАОъОљОЋОф ОћОљОюОћ ОбОЏОЕОЎОЋ}}</translation>
<translation id="7196215469483532480">ОћОћОАОЉОе ОбОю ОћОъОЊОеОЎОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф ОаОцОфОЌ ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="7207760545532569765">ОЕОЌОќОЋОе ОЕОю <ph name="TAB_COUNT" /> ОЏОеОўОЎОАОЎОЋОф ОЏОЏОеОўОЎОАОЎОЋОф ОЌОЊОЕОЋОф ОЉОеОДОб.</translation>
<translation id="7217781228893594884">РђЈОЏОеОўОЎОАОЎОЋОф ОцОеОўОЎОЋОф ОаОаОбОюОЋОф ОЏОЕОАОЋОњОеОЎОЮ ОљОф Chrome</translation>
<translation id="7221869452894271364">ОеОбОаОЋОЪ ОћОЊОБ</translation>
<translation id="7224097611345298931">РђЈОЏОю ОћОАОЎОАОъОљОЋОф ОЕОаОЕОъОеОЋ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ ОбОЉОЋОе Chrome ОЋ-<ph name="CHROME_CHANNEL" /> ОъОЋОќОњОЋ. ОљОцОЕОе ОюОъОюОљ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОљОф ОЏОю ОћОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЉОЕОфОЎ ОћОљОцОюОЎОДОдОЎОЋОф ОћОљОюОЋ.</translation>
<translation id="7227218174981371415">{FILE_COUNT,plural, =1{ОћОЋОеОЊОћ ОљОЌОф ОЉОћОъОфОаОћ}one{# ОћОЋОеОЊОЋОф ОЉОћОъОфОаОћ}two{# ОћОЋОеОЊОЋОф ОЉОћОъОфОаОћ}other{# ОћОЋОеОЊОЋОф ОЉОћОъОфОаОћ}}</translation>
<translation id="7230064152164845085">ОъОбОЉОе ОюОъОдОЉ ОцОеОўОЎ</translation>
<translation id="7236515828900885295">ОъОбОЉОе ОюОЌОЎОцОЋОЕ</translation>
<translation id="7237724030342645845">РђЈОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОћОцОАОЎОД ОюОцОбОЋОю</translation>
<translation id="72415438529550637">ОћОћОдОбОћ ОюОАОЎОАОъОћ ОаОАОњОеОћ.</translation>
<translation id="7248671827512403053">ОЎОЎОЕОЋОЮ</translation>
<translation id="7260367682327802201">РђЈОЉОъОЏОЕОЎОе Android ОбОЕОЋОЎОћ ОюОћОЋОцОЎОб ОћОњОЊОеОћ ОЊОЋОъОћ. ОљОЮ ОъОЊОЎОЊОф ОћОъОЋОЊОбОЋОф ОъОЋОцОбОюОф ОЉ-Chrome ОЋОЉОъОЏОЕОЎОе Android, ОюОЌОЉОеОћ ОъОАОЋОЎОъОф ОбОЕОЋОЎОћ ОюОћОЎОЋОф ОћОеОЕОљОћ ОюОъОЊОЋОЊ ОљОф ОеОъОф ОћОљОцОДОўОЎОЉОЎОЋОф ОЕОю ОъОЋОЊОбОћ ОЏОюОЕОћОЎ ОЉОљОфОеОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОЕОЉОћОЪ ОъОЕОфОъОЕОЎОЮ.</translation>
<translation id="727288900855680735">ОюОЕОюОЋОЌ ОљОф <ph name="ONE_TIME_CODE" /> ОљОю <ph name="ORIGIN" />?</translation>
<translation id="7274013316676448362">ОљОфОе ОЌОАОЋОЮ</translation>
<translation id="7276868533747677875">РђЈОљОЮ ОЎОЎОдОљОф ОЉОбОЉОе ОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОЌОцОЕ ОљОф ОДОЋОЉОЦ Оћ-CSV ОбОЮ ОћОАОЎОАОъОљОЋОф ОЉОъОЏОЕОЎОе ОЕОюОџ ОЋОюОЎОЎОЉОљ ОљОЋОфОЋ ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф ОћОеОюОЋОЋОаОўОЎ.</translation>
<translation id="7289049772085228972">РђЈОЉОъОЏОЕОЎОе ОЕОюОџ ОцОЋОбОюОЎОЮ ОљОъОдОбОЎ ОћОљОЉОўОЌОћ ОћОЏОЎ ОЌОќОДОЎОЮ ОЕОю Chrome</translation>
<translation id="7289303553784750393">ОљОЮ ОЎОЕ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў ОљОЉОю ОћОЉОбОЎОћ ОаОъОЕОЏОф, ОљОцОЕОе ОюОаОАОЋОф ОюОћОъОЕОЎОџ ОЉОЊОеОЏОЎОЮ ОљОЌОеОЋОф ОЉ-<ph name="SITE_ETLD_PLUS_ONE" />.</translation>
<translation id="7290209999329137901">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОаОф ОљОф ОћОЕОЮ ОъОцОаОЎ ОЕОћОцОеОЎОў ОюОљ ОќОъОЎОЪ</translation>
<translation id="7291910923717764901">ОаОЋОАОцОЋ ОфОЎОљОЋОеОЎ ОфОъОЋОаОЋОф ОЉОЊОБ ОќОћ</translation>
<translation id="7293429513719260019">ОЉОЌОЎОеОф ОЕОцОћ</translation>
<translation id="729975465115245577">ОљОЎОЪ ОЉОъОЏОЕОЎОе ОљОцОюОЎОДОдОЎОћ ОюОљОЌОАОЋОЪ ОДОЋОЉОЦ ОћОАОЎОАОъОљОЋОф.</translation>
<translation id="7304072650267745798">РђЈОЉОъОЏОЕОЎОе Android ОбОЕОЋОЎОћ ОюОћОЋОцОЎОб ОћОњОЊОеОћ ОЊОЋОъОћ. ОљОЮ ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОцОбОюОф ОЉ-Chrome ОЋОЉОъОЏОЕОЎОе Android, ОЌОЉОеОЋОф ОбОЕОЋОЎОЋОф ОюОДОЉОю ОћОеОЕОљОЋОф ОюОъОЊОЋОЊ ОљОф ОеОъОф ОћОљОцОДОўОЎОЉОЎОЋОф ОЕОю ОћОъОЋОЊОбОЋОф ОЕОюОћОЪ ОЉОљОфОеОЎОЮ ОЕОЉОћОЮ ОъОЉОДОеОЎОЮ ОЋОЉОљОцОюОЎОДОдОЎОЋОф ОЕОЉОћОЪ ОъОЕОфОъОЕОЎОЮ.</translation>
<translation id="7304806746406660416">{PASSWORDS_COUNT,plural, =1{РђЈОАОЎОАОъОћ ОљОЌОф ОЕОъОЋОеОћ ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОбОюОЎОџ ОюОЕОъОЋОе ОљОЋОфОћ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}one{РђЈРђФ# ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}two{РђЈРђФ# ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}other{РђЈРђФ# ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОеОД ОЉОъОЏОЕОЎОе ОћОќОћ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОћОЪ ОЉОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ, ОдОеОЎОџ ОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google ОбОЮ ОћОЏОфОЋОЉОф <ph name="ACCOUNT_EMAIL" />.}}</translation>
<translation id="7304873321153398381">РђЈОљОЎОЪ ОЌОЎОЉОЋОе ОюОљОЎОаОўОеОаОў. Ою-Chrome ОљОЎОЪ ОљОцОЕОеОЋОф ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф ОЕОюОџ.</translation>
<translation id="7313188324932846546">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОњОЊОЎОе ОАОаОЏОеОЋОЪ</translation>
<translation id="7314734791127433392">ОюОљ ОаОЎОфОЪ ОюОЉОЊОЋОД ОљОф ОћОАОЎОАОъОљОЋОф</translation>
<translation id="7324354302972299151">РђЈОЕОюОЎОЌОћ ОЕОю ОЉОДОЕОф Do Not Track</translation>
<translation id="7333041109965360609">ОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ ОюОДОЉОюОф ОћОфОеОљОЋОф</translation>
<translation id="7336259382292148213">ОаОеОљОћ ОЕОћОЏОЋОю ОЉОАОЊОе ОЉОћОфОеОљОЋОф</translation>
<translation id="7339898014177206373">ОЌОюОЋОЪ ОЌОЊОЕ</translation>
<translation id="7340958967809483333">РђЈОљОцОЕОеОЋОЎОЋОф ОЕОю Discover</translation>
<translation id="7352339641508007922">ОЎОЕ ОюОњОеОЋОе ОЏОЊОЎ ОюОЎОдОЋОе ОдОЎОюОЋОЮ ОъОАОџ ОљОеОЋОџ</translation>
<translation id="7352651011704765696">ОъОЕОћОЋ ОћОЕОфОЉОЕ</translation>
<translation id="7352939065658542140">ОАОеОўОЋОЪ</translation>
<translation id="7353894246028566792">{NUM_SELECTED,plural, =1{ОЕОЎОфОЋОБ ОцОеОЎОў ОљОЌОЊ ОЕОаОЉОЌОе}one{ОЕОЎОфОЋОБ # ОцОеОЎОўОЎОЮ ОЕОаОЉОЌОеОЋ}two{ОЕОЎОфОЋОБ # ОцОеОЎОўОЎОЮ ОЕОаОЉОЌОеОЋ}other{ОЕОЎОфОЋОБ # ОцОеОЎОўОЎОЮ ОЕОаОЉОЌОеОЋ}}</translation>
<translation id="7359002509206457351">ОњОЎОЕОћ ОюОљОъОдОбОЎ ОфОЕОюОЋОЮ</translation>
<translation id="7363349185727752629">ОъОЊОеОЎОџ ОюОЉОЌОЎОеОЋОф ОЕОюОџ ОЉОаОЋОЕОљ ОцОеОўОЎОЋОф</translation>
<translation id="7364103838544876661">ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф ОюОъОЌОЎОДОћ ОЕОю ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ</translation>
<translation id="7365073365123878797">РђЈОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Google Play Services ОЏОЊОЎ ОюОћОфОЌОЎОю ОюОЕОъОЋОе ОАОЎОАОъОљОЋОф ОЋОюОћОЕОфОъОЕ ОЉОћОЪ ОбОЮ ОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="7375125077091615385">ОАОЋОњ:</translation>
<translation id="7376560087009844242">ОљОЮ ОЏОЋОюОюОЎОЮ ОЏОъОћ ОЕОЎОЋОфОе ОъОћОўОДОАОў ОЕОъОЋОцОЎОб ОЉОЊОБ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЎОфОДОЉОюОЋ ОфОЋОдОљОЋОф ОўОЋОЉОЋОф ОЎОЋОфОе ОЏОЕОъОЕОфОъОЕОЎОЮ ОЉОЌОЎОцОЋОЕ ОЉОћОДОЕОћ. ОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОЕОаОЋОф ОќОљОф ОЉОЏОю ОЕОюОЉ ОЉ<ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф<ph name="END_LINK" />.</translation>
<translation id="7379900596734708416">ОћОбОЎОдОЋОЉ ОћОЏОћОћ ОќОъОЎОЪ ОюОљОфОеОЎОЮ</translation>
<translation id="7388615499319468910">ОћОљОфОеОЎОЮ ОЋОћОъОцОеОАОъОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЉОЎОЪ ОљОф ОеОъОф ОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОћОъОЋОЊОбОЋОф. ОћОћОњОЊОеОћ ОћОќОЋ ОъОЋОЕОЉОфОф.</translation>
<translation id="7400003506822844357">{FILE_COUNT,plural, =1{ОАОЋОњ ОљОЌОе, ОДОЋОЉОЦ ОљОЌОЊ ОЉОеОЕОЎОъОћ}one{ОАОЋОњ ОљОЌОе, # ОДОЉОдОЎОЮ ОЉОеОЕОЎОъОћ}two{ОАОЋОњ ОљОЌОе, # ОДОЉОдОЎОЮ ОЉОеОЕОЎОъОћ}other{ОАОЋОњ ОљОЌОе, # ОДОЉОдОЎОЮ ОЉОеОЕОЎОъОћ}}</translation>
<translation id="7400418766976504921">ОЏОфОЋОЉОф ОљОфОе</translation>
<translation id="7403691278183511381">РђЈОЌОЋОЋОЎОЎОф ОћОћОцОбОюОћ ОћОеОљОЕОЋОаОћ ОЕОю Chrome</translation>
<translation id="7411224099004328643">РђЈОъОЕОфОъОЕ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="7419565702166471774">ОюОћОЕОфОъОЕ ОфОъОЎОЊ ОЉОЌОЎОЉОЋОеОЎОЮ ОъОљОЋОЉОўОЌОЎОЮ</translation>
<translation id="7421293530411019405">ОюОдОљОф ОъОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф?</translation>
<translation id="7431991332293347422">ОДОЉОЎОбОф ОљОЋОцОЪ ОћОЕОЎОъОЋОЕ ОЉОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОюОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОЌОЎОцОЋОЕ ОЋОбОЋОЊ</translation>
<translation id="7435356471928173109">ОъОаОћОю ОћОъОбОеОЏОф ОЏОЎОЉОћ ОљОф ОћОфОЏОЋОаОћ ОћОќОЋ</translation>
<translation id="7437998757836447326">РђЈОЎОдОЎОљОћ Оъ-Chrome</translation>
<translation id="7453810262525006706">ОЏОЎОЋОЋОЦ ОюОЌОюОЋОаОЎОф ОдОЊОЊОЎОф</translation>
<translation id="7454641608352164238">ОљОЎОЪ ОъОАОцОЎОД ОъОДОЋОЮ</translation>
<translation id="7454744349230173024">ОЕОъОЎОеОф ОћОАОЎОАОъОљОЋОф ОћОЋОЕОЉОфОћ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="7455988709578031708">ОбОю ОАОъОџ ОћОЎОАОўОЋОеОЎОЎОф ОћОњОюОЎОЕОћ ОЕОюОџ. ОћОћОњОЊОеОћ ОћОќОЋ ОцОЋОбОюОф.</translation>
<translation id="7456774706094330779">ОўОбОЎОаОћ ОъОЋОеОЌОЉОф ОъОеОљОЕ</translation>
<translation id="7466328545712777810">ОфОЎОЕОюОЌ ОљОюОЎОџ ОћОфОеОљОћ ОљОЮ ОфОћОЎОћ ОЎОеОЎОЊОћ ОЉОъОЌОЎОе ОЉОљОфОе ОЏОюОЕОћОЋ</translation>
<translation id="7466431077154602932">ОфОдОЋОњОћ ОДОЋОъОцОДОўОЎОф</translation>
<translation id="7474822150871987353">ОюОЋОъОЊОЎОЮ ОбОю ОаОЋОЕОљОЎОЮ ОЕОъОЋОцОЎОбОЎОЮ ОЉОљОфОеОЎОЮ ОЉОюОЎ ОюОдОљОф ОъОћОЊОБ. ОЉОЋОЌОеОЎОЮ ОъОЎОюОћ ОљОЌОф ОљОЋ ОЎОЋОфОе ОЉОЊОБ ОЏОЊОЎ ОюОЉОдОб ОЌОЎОцОЋОЕ.</translation>
<translation id="7475192538862203634">ОљОЮ ОќОћ ОДОЋОеОћ ОћОеОЉОћ, ОЏОЊОљОЎ ОюОаОАОЋОф <ph name="BEGIN_LINK" />ОћОћОдОбОЋОф<ph name="END_LINK" /> ОћОљОюОћ.</translation>
<translation id="7475688122056506577">РђЈОюОљ ОаОъОдОљ ОЏОеОўОЎОА SD. ОЎОЎОфОЏОЪ ОЕОЌОюОД ОъОћОДОЉОдОЎОЮ ОЕОюОџ ОЌОАОеОЎОЮ.</translation>
<translation id="7479104141328977413">ОаОЎОћОЋОю ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="7481312909269577407">ОДОЊОЎОъОћ</translation>
<translation id="7482656565088326534">ОЏОеОўОЎОАОЎОЎОф ОфОдОЋОњОћ ОъОДОЊОЎОъОћ</translation>
<translation id="7484997419527351112">РђЈDiscover РђЊ ОЏОЉОЋОЎ</translation>
<translation id="7485033510383818941">ОЏОЊОЎ ОюОеОбОаОЪ ОљОф ОћОфОЋОЏОЪ ОЉОцОЎОЊ, ОъОЋОЕОЏОЎОЮ ОљОф ОћОЊОБ ОЏОюОцОЎ ОъОўОћ</translation>
<translation id="749294055653435199">РђЈGoogle Lens ОюОљ ОќОъОЎОЪ ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="7493994139787901920"><ph name="VERSION" /> (ОбОЋОЊОЏОЪ <ph name="TIME_SINCE_UPDATE" />)</translation>
<translation id="7498271377022651285">ОаОљ ОюОћОъОфОЎОЪРђд</translation>
<translation id="750228856503700085">ОљОЎОЪ ОбОЊОЏОЋОаОЎОЮ ОќОъОЎОаОЎОЮ</translation>
<translation id="7507207699631365376">ОћОдОњОф <ph name="BEGIN_LINK" />ОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф<ph name="END_LINK" /> ОЕОю ОћОАОцОД ОћОќОћ</translation>
<translation id="750886945254958667">ОљОцОЕОе ОюОЕОъОЋОе ОљОф ОћОДОЉОЋОдОћ ОћОќОЋ ОЏОЊОЎ ОюОћОЋОАОЎОБ ОЏОеОўОЎОАОЎОЋОф ОъОљОЋОЌОе ОЎОЋОфОе, ОљОЋ ОюОбОќОЋОЉ ОљОЋОфОћ ОљОЮ ОљОЎОЪ ОюОџ ОЎОЋОфОе ОдОЋОеОџ ОЉОћ</translation>
<translation id="7514365320538308">ОћОЋОеОЊОћ</translation>
<translation id="7517292544534877198">РђЈОЕОЎОъОЋОЕ ОЉОЉОеОЎОеОф ОћОъОЌОЊОю ОЕОю Google ОюОћОдОцОаОф ОћОАОЎОАОъОљОЋОф ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="7518079994230200553">ОћОљОцОЕОеОЋОф ОћОќОЋ ОюОљ ОќОъОЎОаОћ ОЏОеОњОб.</translation>
<translation id="751961395872307827">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОфОе</translation>
<translation id="7523960634226602883">РђЈОЌОЎОцОЋОЕ ОбОЮ ОћОъОдОюОъОћ ОЉОљОъОдОбОЋОф Google Lens</translation>
<translation id="7525248386620136756">РђФ<ph name="TAB_GROUPS_AND_TABS_PART" /> ОаОАОњОеОЋ ОЋОаОЕОъОеОЋ</translation>
<translation id="752731652852882757">ОЌОАОЎОъОћ ОЉОъОћОюОџ ОњОюОЎОЕОћ ОЉОъОдОЉ ОцОеОўОЎ</translation>
<translation id="7545347190366646170">ОљОаОЕОЎОЮ ОЕОЎОЕ ОюОћОЮ ОњОЎОЕОћ</translation>
<translation id="7554643625247105821">РђЈОюОљ ОаОЎОфОЪ ОюОЉОЊОЋОД ОљОф ОћОњОеОАОћ ОЕОю Chrome</translation>
<translation id="7557508262441527045">ОћОЌОЕОЉОЋОЪ ОюОљ ОъОЌОЋОЉОе</translation>
<translation id="7561260660702735877">ОъОЎОЊОб ОаОЋОАОБ ОбОю ОДОЎОЕОЋОе ОъОћОљОфОе</translation>
<translation id="7573665567024262965">ОЉОЌОЎОеОф ОћОљОцОюОЎОДОдОЎОЋОф ОЕОЎОЋОњОЊОеОЋ ОЏОЉОеОЎОеОЋОф ОћОъОЌОЊОю</translation>
<translation id="7577900504646297215">ОаОЎОћОЋОю ОфОЌОЋОъОЎ ОбОаОЎОЎОЪ</translation>
<translation id="757855969265046257">{FILES,plural, =1{ОћОЋОеОЊОф ОДОЋОЉОЦ ОљОЌОЊ (<ph name="FILES_DOWNLOADED_ONE" />)}one{ОћОЋОеОЊОф <ph name="FILES_DOWNLOADED_MANY" /> ОДОЉОдОЎОЮ}two{ОћОЋОеОЊОф <ph name="FILES_DOWNLOADED_MANY" /> ОДОЉОдОЎОЮ}other{ОћОЋОеОЊОф <ph name="FILES_DOWNLOADED_MANY" /> ОДОЉОдОЎОЮ}}</translation>
<translation id="7581273696622423628">ОћОЕОфОфОБ ОЉОАОДОе</translation>
<translation id="7583262514280211622">ОеОЕОЎОъОф ОћОДОеОЎОљОћ ОќОъОЎОаОћ ОЏОљОЪ</translation>
<translation id="758603037873046260">ОдОеОЎОџ ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЏОЊОЎ ОюОЕОъОЋОе ОљОф ОћОЊОБ ОћОќОћ</translation>
<translation id="7588219262685291874">ОбОЎОдОЋОЉ ОЏОћОћ ОъОЋОцОбОю ОЏОЕОћОъОЏОЕОЎОе ОбОЋОЉОе ОюОЌОЎОАОЏОЋОЪ ОЉОАОЋОюОюОћ</translation>
<translation id="7592322927044331376">РђЈОДОЋОЊОЮ ОЏОЋОю, ОдОеОЎОџ ОюОЎОЎОдОљ ОљОф ОћОАОЎОАОъОљОЋОф Оъ-Chrome ОЋОюОъОЌОЋОД ОљОЋОфОЪ</translation>
<translation id="7594687499944811403">ОдОеОЎОџ ОюОљОцОЕОе Ою-<ph name="EMBEDDED_ORIGIN" /> ОюОљОъОф ОљОф ОќОћОЋОфОџ ОбОЉОЋОе <ph name="TOP_ORIGIN" /></translation>
<translation id="7596558890252710462">ОъОбОеОЏОф ОћОцОбОюОћ</translation>
<translation id="7597601275223325603">{NUMBER_OF_TABS,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОеОњОЎОюОћ ОљОЌОф (<ph name="TABS_COUNT_ONE" />)}one{РђФ<ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОеОњОЎОюОЋОф}two{РђФ<ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОеОњОЎОюОЋОф}other{РђФ<ph name="TABS_COUNT_MANY" /> ОЏОеОўОЎОАОЎОЋОф ОеОњОЎОюОЋОф}}</translation>
<translation id="7603168929588204083">ОћОфОљОеОЎОџ ОюОљ ОфОДОЎОЪ</translation>
<translation id="7605594153474022051">ОћОАОаОЏОеОЋОЪ ОюОљ ОбОЋОЉОЊ</translation>
<translation id="7612619742409846846">РђЈОћОфОЌОЉОеОф Ою-Google ОЉОЕОЮ</translation>
<translation id="7612989789287281429">ОъОфОЉОдОбОф ОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪРђд</translation>
<translation id="7619072057915878432">ОћОЋОеОЊОф <ph name="FILE_NAME" /> ОаОЏОЕОюОћ ОбОДОЉ ОЏОЕОюОЎОЮ ОЉОеОЕОф.</translation>
<translation id="762537095495606755">ОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="7626032353295482388">РђЈОЉОеОЋОџ ОЉОЋОљОџ ОљОю Chrome</translation>
<translation id="7628417132421583481">ОъОбОЉОе ОюОъОаОћОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="7630202231528827509">РђЈОЏОфОЋОЉОф Оћ-URL ОЕОю ОћОАОцОД</translation>
<translation id="7638584964844754484">ОЉОЎОўОЋОЎ ОАОЎОАОъОћ ОЕОњОЋОЎ</translation>
<translation id="7646499124171960488">ОъОДОЉОюОЎОЮ ОљОќОћОеОћ ОюОњОЉОЎ ОљОфОеОЎОЮ ОдОЎОЉОЋОеОЎОЎОЮ ОюОљ ОъОљОЋОЉОўОЌОЎОЮ</translation>
<translation id="7646772052135772216">ОАОаОЏОеОЋОЪ ОћОАОЎОАОъОљОЋОф ОюОљ ОцОЋОбОю</translation>
<translation id="7655240423373329753">7 ОћОЎОъОЎОЮ ОћОљОЌОеОЋОаОЎОЮ</translation>
<translation id="7656721520530864426">ОљОЎОЪ ОљОфОеОЎОЮ</translation>
<translation id="7656862631699126784">ОћОцОбОюОћ ОЕОю ОаОбОЎОюОф ОћОЏОеОўОЎОАОЎОЋОф ОћОцОеОўОЎОЋОф</translation>
<translation id="7658239707568436148">ОЉОЎОўОЋОю</translation>
<translation id="7663320421139257046">ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОцОеОўОЎОЮ ОъОАОЋОЎОъОЎОЮ (<ph name="FIELDS_STRING" />) ОЎОЕОЋОфОцОЋ ОбОю ОЎОЊОЎ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /> ОбОЮ ОћОљОфОе ОћОќОћ. <ph name="BEGIN_LINK1" />ОЏОљОЪ ОъОцОЋОеОўОф ОъОЊОЎОаОЎОЋОф ОћОцОеОўОЎОЋОф<ph name="END_LINK1" /> ОЕОю ОћОљОфОе ОћОќОћ.</translation>
<translation id="766587987807204883">ОЏОљОЪ ОЎОЋОдОњОЋ ОъОљОъОеОЎОЮ, ОЋОљОцОЕОе ОюОДОеОЋОљ ОљОЋОфОЮ ОњОЮ ОЉОъОдОЉ ОљОЋОаОюОЎОЎОЪ</translation>
<translation id="7666185984446444960">РђФ<ph name="TAB_GROUPS_AND_TABS_PART" /> ОаОАОњОеОЋ</translation>
<translation id="7682724950699840886">ОљОцОЕОе ОюОаОАОЋОф ОљОф ОћОўОЎОцОЎОЮ ОћОЉОљОЎОЮ: ОдОеОЎОџ ОюОЋОЋОЊОљ ОЕОЎОЕ ОъОАОцОЎОД ОъОДОЋОЮ ОцОаОЋОЎ ОЉОъОЏОЕОЎОе ОЋОљОќ ОюОаОАОЋОф ОюОЎОЎОдОљ ОЕОЋОЉ.</translation>
<translation id="7686086654630106285">ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОдОбОЋОф ОюОъОЋОЊОбОЋОф ОЉОљОфОеОЎОЮ</translation>
<translation id="7690596512217303514">РђЈОюОљ ОаОЎОфОЪ ОюОцОфОЋОЌ ОљОф Chrome ОЉОъОЏОЕОЎОе. ОЏОЊОЎ ОюОцОфОЋОе ОљОф ОћОЉОбОЎОћ, ОбОюОЎОџ ОюОћОЋОеОЎОЊ ОљОф ОћОбОЊОЏОЋОЪ ОћОљОЌОеОЋОЪ ОЕОю Chrome ОъОЌОаОЋОф ОћОљОцОюОЎОДОдОЎОЋОф.</translation>
<translation id="7691043218961417207">ОљОцОЕОеОЋОЎОЋОф ОюОфОЋОЏОЪ ОюОъОбОДОЉ</translation>
<translation id="7692761875510935111">ОцОфОЎОЌОћ ОъОћОЎОеОћ ОЉОЊОцОЊОцОЪ. ОЏОЊОЎ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ, ОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="7697383401610880082">ОаОДОЋОЊОф ОљОЌОЎОќОћ ОюОњОеОЎОеОћ</translation>
<translation id="7698359219371678927">ОЎОдОЎОеОф ОћОЋОЊОбОф ОљОЎОъОЎОЎОю ОЉ-<ph name="APP_NAME" /></translation>
<translation id="7702420606070050505">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОћОцОбОЎОюОЋОф ОћОљОЌОеОЋОаОћ ОаОцОфОЌ ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="7707922173985738739">ОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="7708994397325774423">ОДОЉОюОф ОЏОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="7733878270780732638">ОљОЎОЪ ОъОАОцОЎОД ОаОцОЌ ОљОЌОАОЋОЪ ОцОаОЋОЎ ОЉОъОЏОЕОЎОе.</translation>
<translation id="7746817319925672889">РђЈОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОЎОцОАОЎОД ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ ОЉОДОеОЋОЉ</translation>
<translation id="774876555279732384">РђЈОљОцОЕОе ОюОаОћОю ОљОф ОЕОЎОеОЋОфОЎ ОћОъОЎОюОЋОЎ ОћОљОЋОўОЋОъОўОЎ ОњОЮ ОЉ<ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф Android<ph name="END_LINK" />.</translation>
<translation id="7759809451544302770">ОљОЋОцОдОЎОЋОаОюОЎ</translation>
<translation id="7762668264895820836">РђЈОЏОеОўОЎОА SD <ph name="SD_CARD_NUMBER" /></translation>
<translation id="7764225426217299476">ОћОЋОАОцОф ОЏОфОЋОЉОф</translation>
<translation id="7772032839648071052">ОљОЎОЕОЋОе ОъОЕОцОў-ОАОЎОАОъОћ</translation>
<translation id="7772375229873196092">ОАОњОЎОеОф <ph name="APP_NAME" /></translation>
<translation id="7774125747223422443">ОЉОћОфОљОЮ ОюОЌОЋОД ОЉОљОќОЋОе ОЕОюОџ, ОдОеОЎОџ ОюОЉОЌОЋОе ОљОф ОћОЊОцОЊОцОЪ ОЋОљОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ</translation>
<translation id="7774809984919390718">{PAYMENT_METHOD,plural, =1{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОБ}one{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОцОЎОЮ}two{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОцОЎОЮ}other{РђЈ<ph name="PAYMENT_METHOD_PREVIEW" />Рђј\u2026Рђј ОЋ-<ph name="NUMBER_OF_ADDITIONAL_PAYMENT_METHODS" /> ОаОЋОАОцОЎОЮ}}</translation>
<translation id="777637629667389858">РђЈОљОЌОеОЎ ОЕОаОЏОаОАОф ОюОЌОЕОЉОЋОЪ, ОћОъОбОеОЏОф ОъОњОЎОаОћ ОбОюОЎОџ ОЉОЕОЎОеОЋОфОЎ Google.</translation>
<translation id="7778840695157240389">ОЉОћОъОЕОџ ОЎОћОЎОЋ ОцОћ ОАОЎОцОЋОеОЎОЮ ОЌОЊОЕОЎОЮ</translation>
<translation id="7791543448312431591">ОћОЋОАОцОћ</translation>
<translation id="7792388396321542707">ОћОцОАОДОф ОЕОЎОфОЋОБ</translation>
<translation id="780287761701992588">ОљОцОЕОе ОюОДОЉОю ОњОЎОЕОћ ОюОАОЎОъОаОЎОЋОф, ОюОАОЎОАОъОљОЋОф ОЋОюОаОфОЋОаОЎОЮ ОаОЋОАОцОЎОЮ ОЉОЏОю ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ</translation>
<translation id="780301667611848630">ОюОљ ОфОЋОЊОћ</translation>
<translation id="7808889146555843082">ОъОЌОЎОДОф ОћОАОЎОАОъОћ ОћОќОЋ ОюОљ ОфОњОеОЋОЮ ОюОъОЌОЎОДОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉОљОфОе <ph name="SITE" />. ОЏОЊОЎ ОюОъОаОЋОб ОљОф ОћОЌОЕОЎОцОћ ОЕОю ОћОАОЎОАОъОћ, ОЏОЊОљОЎ ОюОЕОаОЋОф ОљОЋОфОћ ОљОЋ ОюОъОЌОЋОД ОљОф ОћОЌОЕОЉОЋОЪ ОЕОюОџ ОЉ-<ph name="SITE" />.</translation>
<translation id="7810647596859435254">ОцОфОЎОЌОћ ОЉОљОъОдОбОЋОф...</translation>
<translation id="7814066895362068701">{FILE_COUNT,plural, =1{ОЏОю ОћОДОЉОдОЎОЮ, ОДОЋОЉОЦ ОљОЌОЊ ОЉОеОЕОЎОъОћ}one{ОЏОю ОћОДОЉОдОЎОЮ, # ОДОЉОдОЎОЮ ОЉОеОЕОЎОъОћ}two{ОЏОю ОћОДОЉОдОЎОЮ, # ОДОЉОдОЎОЮ ОЉОеОЕОЎОъОћ}other{ОЏОю ОћОДОЉОдОЎОЮ, # ОДОЉОдОЎОЮ ОЉОеОЕОЎОъОћ}}</translation>
<translation id="7815484226266492798">ОдОЎОюОЋОЮ ОъОАОџ ОљОеОЋОџ</translation>
<translation id="7815680994978050279">ОћОЋОеОЊОћ ОъОАОЋОЏОаОф ОаОЌОАОъОћ</translation>
<translation id="7819605256207059717">ОаОЌОАОЮ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ</translation>
<translation id="7821130663268546430">ОЏОю ОћОЏОеОўОЎОАОЎОЋОф ОћОцОфОЋОЌОЋОф ОъОЋОцОЎОбОЋОф ОЉОЏОюОЎ ОюОъОбОЉОе ОЉОЎОЪ ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="7822705602465980873">РђЈОљОЌОеОЎ ОћОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ, ОћОаОфОЋОаОЎОЮ ОћОљОюОћ ОъОДОЋОЕОеОЎОЮ ОюОЌОЕОЉОЋОЪ Google ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОЉОЕОЎОеОЋОфОЎ Google. ОюОЊОЋОњОъОћ, ОЉОъОДОеОћ ОЕОю ОљОЎОеОЋОб ОљОЉОўОЌОћ, ОћОћОњОаОћ ОЉ-Gmail ОъОЋОњОЉОеОф.</translation>
<translation id="7824665136384946951">ОћОљОеОњОЋОЪ ОЕОюОџ ОћОЕОЉОЎОф ОљОф ОћОњОюОЎОЕОћ ОћОЉОўОЋОЌОћ</translation>
<translation id="7844171778363018843">ОљОЎОЪ ОаОфОЋОаОЎОЮ ОЕОаОЉОЌОеОЋ ОюОАОаОЏОеОЋОЪ</translation>
<translation id="7846161022626028328">ОљОЎОеОбОћ ОЕОњОЎОљОћ. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7846296061357476882">РђЈОЕОЎОеОЋОфОЎ Google</translation>
<translation id="784934925303690534">ОўОЋОЋОЌ ОќОъОЪ</translation>
<translation id="7851858861565204677">ОъОЏОЕОЎОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="7853202427316060426">ОцОбОЎОюОЋОф</translation>
<translation id="7859988229622350291">ОљОЎОЪ ОюОфОеОњОЮ ОљОБ ОцОбОЮ</translation>
<translation id="7866213166286285359">ОфОеОњОЋОЮ ОћОЊОцОЎОЮ ОЕОЏОљОЪ</translation>
<translation id="7875915731392087153">ОћОЋОЊОбОф ОљОЎОъОЎОЎОю ОЌОЊОЕОћ</translation>
<translation id="7876243839304621966">ОћОАОеОф ОћОЏОЋОю</translation>
<translation id="7886917304091689118">РђЈОцОЋОбОю ОЉ-Chrome</translation>
<translation id="7887174313503389866">ОАОЎОЋОе ОъОЋОЊОеОџ ОЉОљОъОдОбОЎ ОћОЉОДОеОћ ОћОЌОЕОЋОЉОЎОЮ ОЉОЎОЋОфОе ОбОю ОцОеОўОЎОЋОф ОЋОљОЉОўОЌОћ. ОюОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф, ОЎОЕ ОюОбОЉОЋОе ОюОћОњОЊОеОЋОф ОАОцОдОЎОцОЎОЋОф.</translation>
<translation id="7907478394153853634">Lorem Ipsum</translation>
<translation id="7913993612870913335">{FILE_COUNT,plural, =1{ОћОЋОеОЊОћ ОљОЌОф ОаОЌОАОъОћ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ}one{РђФ# ОћОЋОеОЊОЋОф ОаОЌОАОъОЋ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ}two{РђФ# ОћОЋОеОЊОЋОф ОаОЌОАОъОЋ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ}other{РђФ# ОћОЋОеОЊОЋОф ОаОЌОАОъОЋ ОбОю ОЎОЊОЎ ОћОљОеОњОЋОЪ ОЕОюОџ}}</translation>
<translation id="7914399737746719723">ОћОљОцОюОЎОДОдОЎОћ ОћОЋОфОДОаОћ</translation>
<translation id="7917574899775263813">ОъОбОЉОе ОюОЏОеОўОЎОАОЎОЎОћ ОћОљОЌОеОЋОаОћ</translation>
<translation id="7919123827536834358">ОфОеОњОЋОЮ ОљОЋОўОЋОъОўОЎ ОЕОю ОћОЕОцОЋОф ОћОљОюОћ</translation>
<translation id="7921782882718083488">ОАОЎОЏОЋОЮ ОћОЊОБ ОћОќОћ</translation>
<translation id="7926975587469166629">ОЏОЎОаОЋОЎ ОћОЏОеОўОЎОА</translation>
<translation id="7929587383660661825">РђЈРђФChrome ОъОАОЎОе ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОћОеОЕОљОЋОф ОъОљОфОеОЎОЮ ОЕОъОЕОфОъОЕОЎОЮ ОюОеОбОћ ОЉОћОфОеОљОЋОф ОљОЋ ОЕОюОљ ОЉОЎОДОеОф ОЉОћОЮ ОюОљОЌОеОЋОаОћ</translation>
<translation id="7929962904089429003">ОцОфОЎОЌОф ОћОфОцОеОЎОў</translation>
<translation id="7934668619883965330">ОюОљ ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОф ОћОДОЋОЉОЦ. ОцОЋОеОъОў ОћОДОЋОЉОЦ ОюОљ ОаОфОъОџ.</translation>
<translation id="7942131818088350342"><ph name="PRODUCT_NAME" /> ОљОЎОаОЋ ОъОбОЋОЊОЏОЪ.</translation>
<translation id="7944772052836377867">ОЏОЊОЎ ОюОАОаОЏОеОЪ ОдОеОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="7951102827450076904">РђЈОДОЋОЉОдОЎ PDF ОфОъОЎОЊ ОЎОЎОцОфОЌОЋ ОљОЌОеОЎ ОћОћОЋОеОЊОћ</translation>
<translation id="7957413488482743710">ОЏОеОўОЎОА ОЋОЎОеОўОЋОљОюОЎ ОъОАОфОЎОе ОљОф ОћОЏОеОўОЎОА ОЕОюОџ ОЉОцОЋОбОю ОЏОЊОЎ ОюОћОњОЪ ОбОюОЎОџ ОъОцОаОЎ ОфОеОъОЎОЋОф ОцОЋОўОаОдОЎОљОюОЎОЋОф. <ph name="BEGIN_LINK1" />ОЏОљОЪ ОъОцОЋОеОў ОъОЎОЊОб ОаОЋОАОБ ОбОю ОЏОеОўОЎОАОЎОЮ ОЋОЎОеОўОЋОљОюОЎОЎОЮ<ph name="END_LINK1" /></translation>
<translation id="7959485987650214982">ОћОЏОеОўОЎОАОЎОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="7961926449547174351">ОћОЕОЉОфОф ОљОф ОћОњОЎОЕОћ ОюОљОЌОАОЋОЪ. ОЏОЊОЎ ОюОћОцОбОЎОю ОљОЋОфОћ, ОЎОЕ ОюОбОЉОЋОе ОюОћОњОЊОеОЋОф.</translation>
<translation id="7963646190083259054">ОАОцОД:</translation>
<translation id="7965838025086216108">РђЈОЎОЕ ОюОџ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОћОЕОъОЋОеОЋОф ОЉОЏОю ОъОЏОЕОЎОе. ОћОЪ ОаОЕОъОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google ОюОЌОЕОЉОЋОЪ <ph name="ACCOUNT" />.</translation>
<translation id="7968014550143838305">ОаОЋОАОБ ОюОеОЕОЎОъОф ОћОДОеОЎОљОћ</translation>
<translation id="7968982339740310781">ОћОдОњОф ОцОеОўОЎОЮ</translation>
<translation id="7971136598759319605">ОцОбОЎОюОЋОф ОљОЌОеОЋОаОћ: ОюОцОаОЎ ОЎОЋОЮ ОљОЌОЊ</translation>
<translation id="7975379999046275268">ОћОдОњОф ОћОЊОБ ОЉОфОдОЋОњОћ ОъОДОЊОЎОъОћ<ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="7977451675950311423">ОъОДОЉОюОЎОЮ ОљОќОћОеОћ ОљОЮ ОъОЕОфОъОЕОЎОЮ ОЉОАОЎОАОъОћ ОЕОаОЌОЕОцОћ ОЉОцОеОдОћ ОЉОљОЉОўОЌОф ОъОЎОЊОб.</translation>
<translation id="7986497153528221272">ОЏОЊОЎ ОюОћОдОЎОњ ОАОЎОАОъОљОЋОф, ОфОЌОЎОюОћ ОЎОЕ ОюОћОњОЊОЎОе ОаОбОЎОюОф ОъОАОџ ОЉОъОЏОЕОЎОе</translation>
<translation id="7987499071758862048">РђЈРђФ<ph name="PERMISSION_1" />, <ph name="PERMISSION_2" />, <ph name="PERMISSION_3" /> <ph name="SEPARATOR" /> Chrome ОћОАОЎОе ОљОф ОћОћОеОЕОљОЋОф ОћОљОюОћ ОЏОЎ ОюОљ ОаОЏОаОАОф ОюОљОЌОеОЋОаОћ</translation>
<translation id="7995059495660416932">ОфОЋОЏОЪ ОЎОЋОдОњ ОюОџ ОЉОеОњОб ОЕОЎОћОЎОћ ОќОъОЎОЪ</translation>
<translation id="799576009106109668">ОъОћОЎОеОЋОф ОћОњОюОЎОЕОћ ОфОњОЉОе ОЏОЎ ОћОфОЋОЏОЪ ОЎОЎОўОбОЪ ОЉОљОЋОцОЪ ОЎОќОЋОЮ, ОбОю ОАОъОџ ОћОЉОЎОДОЋОе ОћОаОЋОЏОЌОЎ ОЕОюОџ ОЉОЊОБ ОћОљОЎОаОўОеОаОў</translation>
<translation id="8001245658307297681">ОъОЋОдОњ ОюОџ ОДОЋОЉОЦ ОъОДОЋОъОЎ</translation>
<translation id="8004582292198964060">ОЊОцОЊОцОЪ</translation>
<translation id="8014210850410408071">ОЉОЕОюОЉ ОћОЉОљ, ОЎОЕ ОюОЎОЎОЉОљ ОљОф ОћОАОЎОАОъОљОЋОф</translation>
<translation id="8015452622527143194">ОЏОю ОъОћ ОЕОъОЋОцОЎОб ОЉОЊОБ ОЎОЕОфОаОћ ОюОњОЋОЊОю ОЉОеОЎОеОф ОћОъОЌОЊОю</translation>
<translation id="8025972204417227828">ОћОЋОАОцОф ОъОДОЕ ОДОЎОдОЋОе ОЌОЊОЕ</translation>
<translation id="8027395186860110042">ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОДОеОЋОЉ</translation>
<translation id="8027863900915310177">ОЉОЌОЎОеОф ОћОъОЎОДОЋОЮ ОюОћОЋОеОЊОћ</translation>
<translation id="8030852056903932865">ОљОЎОЕОЋОе</translation>
<translation id="8032569120109842252">ОЉОъОбОДОЉ</translation>
<translation id="8037750541064988519">ОаОЋОфОеОЋ <ph name="DAYS" /> ОЎОъОЎОЮ</translation>
<translation id="8037801708772278989">ОћОфОЉОдОбОћ ОЉОЊОЎОДОћ ОбОЏОЕОЎОЋ</translation>
<translation id="804335162455518893">РђЈОюОљ ОаОъОдОљ ОЏОеОўОЎОА SD</translation>
<translation id="8048533522416101084">{TAB_COUNT,plural, =1{ОЏОеОўОЎОАОЎОЎОћ ОљОЌОф (<ph name="TAB_COUNT_ONE" />) ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}one{<ph name="TAB_COUNT_NORMAL" /> ОЏОеОўОЎОАОЎОЋОф ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}two{<ph name="TAB_COUNT_NORMAL" /> ОЏОеОўОЎОАОЎОЋОф ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}other{<ph name="TAB_COUNT_NORMAL" /> ОЏОеОўОЎОАОЎОЋОф ОЕОю ОъОдОЉ ОљОаОЋОаОЎОъОЎ}}</translation>
<translation id="8051695050440594747">РђЈРђј<ph name="MEGABYTES" />MB ОќОъОЎОаОЎОЮ</translation>
<translation id="8058746566562539958">РђЈОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ ОЕОю Chrome</translation>
<translation id="8062594758852531064">ОўОбОЎОаОћ ОъОЋОеОЌОЉОф ОъОеОљОЕ:</translation>
<translation id="8063895661287329888">ОћОЋОАОцОф ОћОАОЎОъОаОЎОЎОћ ОаОЏОЕОюОћ.</translation>
<translation id="8066816452984416180">ОћОЋОАОцОћ ОъОћОЎОеОћ ОЕОю ОћОЊОБ ОћОќОћ ОюОАОЎОъОаОЎОЋОф. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉОюОЌОЎОдОћ ОљОеОЋОЏОћ.</translation>
<translation id="806745655614357130">ОЕОъОЎОеОф ОћОаОфОЋОаОЎОЮ ОЕОюОЎ ОЉОаОцОеОЊ</translation>
<translation id="8073388330009372546">ОцОфОЎОЌОф ОћОфОъОЋОаОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="8076492880354921740">ОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="8078096376109663956">ОЎОЕ ОюОЕОфОБ ОўОДОАОў ОЉОюОЉОЊ</translation>
<translation id="8078348702936632821">ОћОдОъОЊОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ</translation>
<translation id="8084114998886531721">ОАОЎОАОъОћ ОЕОъОЋОеОћ</translation>
<translation id="8084285576995584326">РђЈОЕОюОЎОўОћ ОЉОаОфОЋОаОЎОЮ ОЕОюОџ ОЉОЌОЕОЉОЋОЪ Google</translation>
<translation id="8084864785646838999">РђЈОЎОЏОЋОю ОюОћОЎОЋОф ОЕОЌОюОД ОъОћОћОЎОАОўОЋОеОЎОћ ОЕОюОџ ОюОљ ОфОЋОцОЎОб ОЏОљОЪ. ОдОеОЎОџ ОюОцОфОЋОЌ ОљОф ОћОћОЎОАОўОЋОеОЎОћ ОћОъОюОљОћ ОЉ-Chrome ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОЏОЋОюОћ. ОЏОъОЋ ОЏОЪ, ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОљОцОЕОе ОЎОћОЎОћ ОюОњОЕОф ОюОАОЋОњОЎОЮ ОљОЌОеОЎОЮ ОЕОю ОћОЎОАОўОЋОеОЎОЎОф ОњОюОЎОЕОћ ОЉОЌОЕОЉОЋОЪ Google ОЉОЏОфОЋОЉОф <ph name="BEGIN_LINK" />myactivity.google.com<ph name="END_LINK" />.</translation>
<translation id="8088176524274673045">РђЈОЏОЊОЎ ОюОЕОфОБ ОбОЮ ОљОаОЕОЎОЮ ОЉОДОеОЉОф ОъОДОЋОЮ, ОћОЮ ОдОеОЎОЏОЎОЮ ОюОАОеОЋОД ОљОф ОДОЋОЊ Оћ-QR ОћОќОћ</translation>
<translation id="8090732854597034573">ОљОЮ ОдОеОЎОџ ОбОќОеОћ, ОљОцОЕОе ОюОЉОДОЕ ОбОќОеОћ ОъОћОЋОеОћ</translation>
<translation id="8101414242770404289">ОюОљ ОЎОАОњОеОЋ ОЏОеОўОЎОАОЎОЋОф ОЉОъОАОњОеОф <ph name="TIME_PERIOD" /></translation>
<translation id="8103578431304235997">ОЏОеОўОЎОАОЎОЎОф ОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="8105613260829665809">РђЈОюОЌОЎОдОћ ОбОю ОћОъОЕОџ ОфОфОцОеОЕ ОЏОћОАОЏОъОфОџ <ph name="BEGIN_TOS_LINK" />ОюОфОаОљОЎОЮ ОЋОюОћОњОЉОюОЋОф<ph name="END_TOS_LINK" />.\nОЏОЊОЎ ОюОбОќОЋОе ОЉОЕОЎОцОЋОе ОћОљОцОюОЎОДОдОЎОћ, Chrome ОЎОЕОюОЌ ОаОфОЋОаОЎ ОЕОЎОъОЋОЕ ОЋОДОеОЎОАОЋОф ОљОю Google. <ph name="BEGIN_UMA_LINK" />ОаОЎОћОЋОю<ph name="END_UMA_LINK" /></translation>
<translation id="8105893657415066307"><ph name="DESCRIPTION" /> <ph name="SEPARATOR" /> <ph name="FILE_SIZE" /></translation>
<translation id="8107530384992929318">ОАОњОЎОеОћ ОЕОю ОљОцОЕОеОЋОЎОЋОф ОћОъОЎОЋОЪ</translation>
<translation id="8110024788458304985">РђЈОбОќОеОћ ОЉОЕОЎОцОЋОе ОћОфОЏОЋОаОЋОф ОЋОћОЉОЎОдОЋОбОЎОЮ ОЕОю Chrome</translation>
<translation id="8110087112193408731">РђЈОюОћОдОЎОњ ОљОф ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉ-Chrome ОЉ'ОЕОЎОъОЋОЕ ОЌОЏОЮ ОЉОЊОЎОњОЎОўОю'?</translation>
<translation id="8118117428362942925">ОљОЮ ОдОеОЎОџ ОбОќОеОћ, ОљОцОЕОе ОюОЉОДОЕ ОбОќОеОћ ОъОћОЋОеОћ (<ph name="PARENT_NAME" />)</translation>
<translation id="8120286190326371840">ОљОЎОЪ ОЉОъОЏОЕОЎОе ОћОќОћ ОАОЎОАОъОљОЋОф ОЕОаОЌОЕОцОЋ</translation>
<translation id="8122623268651408616">ОЉОфОћОюОЎОџ ОъОЎОЋОЪ ОюОцОЎ ОћОцОеОЎОў ОћОЌОЊОЕ ОЉОЎОЋОфОе</translation>
<translation id="8127542551745560481">ОбОеОЎОЏОф ОЊОБ ОћОЉОЎОф</translation>
<translation id="8130309322784422030">ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОцОеОўОЎОЮ ОЕОаОЕОъОеОЋ ОюОЏОаОЎОАОћ ОюОЌОЕОЉОЋОЪ ОюОљ ОбОЊОЏОаОЎОЎОЮ</translation>
<translation id="813082847718468539">ОћОдОњОф ОаОфОЋОаОЎ ОљОфОе</translation>
<translation id="8135406045838672858">РђЈОДОЋОЉОдОЎ PDF ОЎОЎОцОфОЌОЋ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОљОъОдОбОЋОф <ph name="APP_NAME" /> ОљОЌОеОЎ ОћОћОЋОеОЊОћ</translation>
<translation id="8137562778192957619">РђЈОљОЎОЪ ОдОЋОеОџ ОюОќОЏОЋОе ОљОф ОћОАОЎОАОъОћ ОћОќОЋ. ОћОЎОљ ОфОЎОЕОъОе ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google.</translation>
<translation id="8152331954420209374">РђЈОъОбОЉОе ОљОю Lens</translation>
<translation id="8163820386638255770">РђЈОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф ОЋОюОЕОъОЋОе ОљОЋОфОЪ ОЉОЌОЕОЉОЋОЪ Google, ОбОюОЎОџ ОюОљОъОф ОљОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="8179976553408161302">Enter</translation>
<translation id="8186512483418048923">ОаОЋОфОеОЋ ОбОЋОЊ <ph name="FILES" /> ОДОЉОдОЎОЮ</translation>
<translation id="8190358571722158785">ОаОЋОфОе ОЎОЋОЮ ОљОЌОЊ</translation>
<translation id="8192765420340770300">ОћОњОЎОюОЎОЋОЪ ОћОфОЌОфОЋОЪ ОЕОю ОћОЏОаОЎОАОћ ОаОцОфОЌ ОЉОњОЋОЉОћ ОъОюОљ</translation>
<translation id="8193953846147532858"><ph name="BEGIN_LINK" />ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ<ph name="END_LINK" /> ┬и <ph name="EMAIL" /></translation>
<translation id="820568752112382238">ОћОљОфОеОЎОЮ ОЕОљОюОЎОћОЮ ОаОЏОаОАОф ОЉОфОЊОЎОеОЋОф ОћОњОЉОЋОћОћ ОЉОЎОЋОфОе</translation>
<translation id="8207867836430106322">{NUM_OTHER_MEMBERS,plural, =1{ОћОдОўОеОцОЋОф ОюОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОбОЮ <ph name="OWNER_FIRST_NAME" /> ОЋОбОЋОЊ ОъОЕОфОъОЕ ОљОЌОЊ (<ph name="NUMBER_OF_OTHER_MEMBERS" />)}one{ОћОдОўОеОцОЋОф ОюОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОбОЮ <ph name="OWNER_FIRST_NAME" /> ОЋОбОЋОЊ <ph name="NUMBER_OF_OTHER_MEMBERS" /> ОъОЕОфОъОЕОЎОЮ}two{ОћОдОўОеОцОЋОф ОюОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОбОЮ <ph name="OWNER_FIRST_NAME" /> ОЋОбОЋОЊ <ph name="NUMBER_OF_OTHER_MEMBERS" /> ОъОЕОфОъОЕОЎОЮ}other{ОћОдОўОеОцОЋОф ОюОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОбОЮ <ph name="OWNER_FIRST_NAME" /> ОЋОбОЋОЊ <ph name="NUMBER_OF_OTHER_MEMBERS" /> ОъОЕОфОъОЕОЎОЮ}}</translation>
<translation id="8209050860603202033">ОцОфОЎОЌОф ОћОфОъОЋОаОћ</translation>
<translation id="8210770465353466621">ОћОЏОеОўОЎОАОЎОЋОф ОЎОЋОцОЎОбОЋ ОЏОљОЪ</translation>
<translation id="8211101263765532799">ОЌОюОД ОъОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОДОеОЋОЉ</translation>
<translation id="8215740705341534369">ОњОЎОюОЎОЋОЪ ОдОЊ</translation>
<translation id="8218622182176210845">ОаОЎОћОЋОю ОћОЌОЕОЉОЋОЪ</translation>
<translation id="8221401890884589479">РђЈОљОцОЕОе ОюОЌОАОЋОЮ ОљОфОеОЎОЮ ОЕОюОљ ОеОЋОдОЎОЮ ОюОфОф ОюОћОЮ ОћОеОЕОљОћ. ОЉОаОЋОАОБ, ОљОфОеОЎОЮ ОЕОаОЋОАОцОЋ ОюОцОаОЎ ОЎОЋОфОе Оъ-30 ОЎОЋОЮ ОаОъОЌОДОЎОЮ ОъОћОеОЕОЎОъОћ ОЉ-Chrome ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="8221985041778490865">ОаОфОЋОаОЎ ОћОњОюОЎОЕОћ ОаОъОЌОДОЎОЮ</translation>
<translation id="8223642481677794647">ОфОцОеОЎОў ОЏОеОўОЎОА ОћОцОЎОЊ</translation>
<translation id="82296173028782770">ОбОеОЎОЏОф ОЕОљОЎОюОфОф ОћОЌОЎОцОЋОЕ: <ph name="SEARCH_QUERY" /></translation>
<translation id="8236063039629122676">ОъОбОЏОЕОЎОЋ, ОћОЌОюОДОћ ОЎОъОЎОаОћ ОфОЌОќОЎОе ОљОЋОфОџ ОљОЌОЋОеОћ ОюОЊОцОЎОЮ ОДОЋОЊОъОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф, ОЋОћОЌОюОДОћ ОЕОъОљОюОћ ОфОбОЉОЎОе ОљОЋОфОџ ОДОЊОЎОъОћ</translation>
<translation id="8236097722223016103">ОћОЋОАОцОћ ОюОАОЎОъОаОЎОЋОф</translation>
<translation id="8243077599929149377">ОћОЋОАОцОћ ОЕОю ОЕОЮ ОћОъОЕОфОъОЕ</translation>
<translation id="8244387390464017490">ОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОЊОБ ОћОЏОеОўОЎОАОЎОЎОћ ОћОЌОЊОЕОћ</translation>
<translation id="8250920743982581267">ОъОАОъОЏОЎОЮ</translation>
<translation id="8255617931166444521">РђЈОљОфОеОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОЕОфОъОЕ ОЉОДОЋОЉОдОЎ Оћ-cookie ОеОД ОЏОЊОЎ ОюОеОљОЋОф ОљОф ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ ОЕОъОфОЉОдОбОф ОЉОћОЮ ОЉОюОЉОЊ, ОЋОюОљ ОЉОљОфОеОЎОЮ ОљОЌОеОЎОЮ</translation>
<translation id="8256087213273124136">РђЈОЉОЎОўОюОф ОљОф ОћОћОеОЕОъОћ ОюОДОЉОюОф ОћОфОеОљОЋОф ОЉ-Chrome</translation>
<translation id="8258999165172757081">ОаОЋОАОБ</translation>
<translation id="8259179246279078674">РђЈОъОцОаОЎ ОЕОћОЊОцОЎОЮ ОЕОаОўОбОаОЎОЮ ОъОеОљОЕ ОъОЋОдОцОаОЎОЮ, Google ОюОљ ОфОДОЉОю ОъОЎОЊОб ОбОю ОфОЋОЏОЪ ОћОЊОБ ОЕОаОўОбОЪ ОъОеОљОЕ. ОЕОеОфОЎ Google ОЎОњОюОЋ ОљОЎОюОЋ ОљОфОеОЎОЮ ОаОўОбОаОЎОЮ ОъОеОљОЕ ОЉОљОЋОцОЪ ОцОеОўОЎ. ОћОъОЎОЊОб ОћОќОћ ОъОЕОъОЕ ОеОД ОюОўОбОЎОаОћ ОъОеОљОЕ ОЕОю ОћОЊОцОЎОЮ ОЋОћОЋОљ ОюОљ ОъОДОЋОЕОе ОюОъОЎОЊОб ОљОЌОе ОъОЌОЕОЉОЋОЪ Google ОЕОюОџ.</translation>
<translation id="8260126382462817229">ОЎОЕ ОюОћОЎОЏОаОА ОЕОЋОЉ</translation>
<translation id="8261506727792406068">ОъОЌОЎОДОћ</translation>
<translation id="82619448491672958">ОћОдОњОф ОЏОеОўОЎОАОЎОЋОф ОљОЌОеОЋОф</translation>
<translation id="8266753737658117282">ОћОъОЕОџ ОбОЮ <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="8266862848225348053">ОъОЎОДОЋОЮ ОћОћОЋОеОЊОћ</translation>
<translation id="8271267069224406035">ОЊОЎОЋОЋОЌ ОбОю ОАОцОљОЮ</translation>
<translation id="8279945625179116733">ОъОљОЋОЉОўОЌ ОбОю ОЎОЊОЎ <ph name="APP_NAME" /></translation>
<translation id="8281886186245836920">ОЊОЎОюОЋОњ</translation>
<translation id="8282297628636750033">ОћОЌОюОф ОбОЎОдОЋОЉ ОЏОћОћ ОбОю ОљОфОеОЎОЮ, ОЏОЕОљОцОЕОе</translation>
<translation id="8282950411412455249">ОљОю ОћОњОЊОеОЋОф ОћОљОЉОўОЌОћ</translation>
<translation id="8306751933352925837">РђЈОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОъОЏОЕОЎОе ОћОќОћ ОЉОДОеОЋОЉ. ОЏОЊОЎ ОюОћОъОЕОЎОџ ОюОћОЕОфОъОЕ ОЉОАОЎОАОъОљОЋОф, ОдОеОЎОџ ОюОбОЊОЏОЪ ОљОф Google Play Services. <ph name="BEGIN_LINK" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="8310451567823644042">ОћОАОЎОАОъОљОЋОф ОЎОцОАОЎОДОЋ ОюОцОбОЋОю ОЉОДОеОЋОЉ</translation>
<translation id="831192587911042850">ОћОЋОАОцОф ОљОфОе ОћОљОЎОаОўОеОаОў ОЕОцОфОЋОЌ ОЏОеОњОб ОюОеОЕОЎОъОф ОљОфОеОЎ ОћОљОЎОаОўОеОаОў ОЕОЉОъОбОДОЉ.</translation>
<translation id="8320212361750431956">ОцОбОЎОюОЋОф ОљОЌОеОЋОаОћ</translation>
<translation id="832514020744584629">РђФ<ph name="PREF_TITLE" />  <ph name="BEGIN_NEW" />ОЌОЊОЕ<ph name="END_NEW" /></translation>
<translation id="8342727528718219152">РђЈРђФChrome ОЎОЋОЊОЎОб ОюОџ ОбОю ОљОфОеОЎОЮ ОЕОбОюОЋОюОЎОЮ ОюОЕОюОЋОЌ ОЎОЋОфОе ОъОЊОЎ ОћОфОеОљОЋОф</translation>
<translation id="834313815369870491">ОљОЎОЪ ОюОфОеОњОЮ ОљОф ОћОљОфОеОЎОЮ ОљОБ ОцОбОЮ</translation>
<translation id="8348430946834215779">РђЈОЎОЕ ОюОћОЕОфОъОЕ ОЉ-HTTPS ОЏОЕОљОцОЕОе, ОЋОюОДОЉОю ОљОќОћОеОћ ОюОцОаОЎ ОЕОўОЋОбОаОЎОЮ ОљОфОеОЎОЮ ОЕОюОљ ОфОЋОъОЏОЎОЮ ОЉ-HTTPS</translation>
<translation id="8354977102499939946">ОЌОЎОцОЋОЕ ОъОћОЎОе ОЉОљОъОдОбОЋОф ОћОДОЋОю. ОаОЎОфОЪ ОюОбОеОЋОџ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОќОћ ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="8361737703487394103">ОъОбОЉОе ОюОЏОеОўОЎОАОЎОЎОћ ОАОцОдОЎОцОЎОф (1-8)</translation>
<translation id="8368001212524806591">ОъОбОДОЉ ОљОЌОе ОћОъОЌОЎОе</translation>
<translation id="8368772330826888223">{TAB_GROUP_COUNT,plural, =1{ОДОЉОЋОдОф ОЏОеОўОЎОАОЎОЋОф ОљОЌОф (<ph name="TAB_GROUPS_ONE" />)}one{РђФ<ph name="TAB_GROUPS_MANY" /> ОДОЉОЋОдОЋОф ОЕОю ОЏОеОўОЎОАОЎОЋОф}two{РђФ<ph name="TAB_GROUPS_MANY" /> ОДОЉОЋОдОЋОф ОЕОю ОЏОеОўОЎОАОЎОЋОф}other{РђФ<ph name="TAB_GROUPS_MANY" /> ОДОЉОЋОдОЋОф ОЕОю ОЏОеОўОЎОАОЎОЋОф}}</translation>
<translation id="8378850197701296741">ОЎОЕ ОюОџ ОАОЎОъОаОЎОЋОф, ОћОЎОАОўОЋОеОЎОћ ОЋОћОњОЊОеОЋОф ОљОЌОеОЋОф ОъОћОЌОЕОЉОЋОЪ <ph name="FROM_ACCOUNT" />.</translation>
<translation id="8387617938027387193">ОљОЎОъОЋОф ОћОќОћОЋОф ОЕОюОџ</translation>
<translation id="8393700583063109961">ОЕОюОЎОЌОф ОћОЋОЊОбОћ</translation>
<translation id="8396098434728053815">ОЕОЎОфОЋОБ ОњОЮ ОЕОю ОћОљОЋОЊОЎОЋ ОъОћОЏОеОўОЎОАОЎОЎОћ</translation>
<translation id="8398389123831319859">ОЏОЊОЎ ОюОбОЉОЋОе ОюОъОдОЉ ОцОеОўОЎ, ОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОЏОцОЋОюОћ ОЋОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОљОеОЋОЏОћ</translation>
<translation id="8402673309244746971">ОъОбОЉОе ОљОю ОћОцОЎОЊ 'ОЉОъОбОДОЉ'</translation>
<translation id="8413126021676339697">ОюОћОдОњОф ОћОћОЎОАОўОЋОеОЎОћ ОћОъОюОљОћ</translation>
<translation id="8413795581997394485">РђЈОћОњОаОћ ОъОцОаОЎ ОљОфОеОЎОЮ, ОћОЋОеОЊОЋОф ОЋОфОЋОАОцОЎОЮ ОЕОЎОЊОЋОбОЎОЮ ОЏОъОАОЋОЏОаОЎОЮ. ОЏОЕОъОЉОДОеОЎОЮ ОЉОљОфОе ОъОАОЋОЎОЮ, Chrome ОЕОЋОюОЌ Ою-Google ОДОўОб ОДОЋОЊ ОъОбОЋОеОцОю ОъОЏОфОЋОЉОф Оћ-URL ОЊОеОџ ОЕОеОф ОцОеОўОЎОЋОф ОЕОъОАОфОЎОе ОљОф ОЏОфОЋОЉОф Оћ-IP. ОљОЮ ОћОљОфОе ОцОЋОбОю ОЉОљОЋОцОЪ ОЕОъОбОЋОеОе ОЌОЕОЊ, ОаОЕОюОЌОЋОф ОњОЮ ОЏОфОЋОЉОЋОф URL ОъОюОљОЋОф ОЋОДОўОбОЎ ОфОЋОЏОЪ ОъОЊОцОЎОЮ.</translation>
<translation id="8414396119627470038">ОЏОаОЎОАОћ ОљОю <ph name="SITE_ETLD_PLUS_ONE" /> ОЉОљОъОдОбОЋОф <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE" /></translation>
<translation id="8419144699778179708">ОћОћОЎОАОўОЋОеОЎОћ ОфОЎОъОЌОД, ОЏОЋОюОю ОћОћОЎОАОўОЋОеОЎОћ ОЉОфОЎОЉОф ОћОЌОЎОцОЋОЕ</translation>
<translation id="8419244640277402268">ОћОЋОАОцОћ</translation>
<translation id="8422250855136581222">ОљОЎОЪ ОЏОеОўОЎОАОЎОЋОф ОЉОъОЏОЕОЎОе ОћОќОћ</translation>
<translation id="842386925677997438">РђЈОћОЏОюОЎОЮ ОюОЉОўОЎОЌОЋОф ОЕОю Chrome</translation>
<translation id="8427875596167638501">ОЏОеОўОЎОАОЎОЎОф ОћОфОдОЋОњОћ ОћОъОДОЊОЎОъОћ ОцОфОЋОЌОћ ОЉОЌОдОЎ ОњОЋОЉОћ ОћОъОАОџ</translation>
<translation id="8428213095426709021">ОћОњОЊОеОЋОф</translation>
<translation id="8430824733382774043">ОЕОЎОфОЋОБ ОдОЎОюОЋОЮ ОћОъОАОџ ОЉОюОЉОЊ</translation>
<translation id="8434837876193928924">ОцОеОўОЎ ОДОЉОЋОдОф ОћОЏОеОўОЎОАОЎОЋОф</translation>
<translation id="8438566539970814960">ОЕОЎОцОЋОе ОћОЌОЎОцОЋОЕОЎОЮ ОЋОћОњОюОЎОЕОћ</translation>
<translation id="8439974325294139057"><ph name="LANG" /> - ОћОЕОцОћ ОъОЋОЏОаОћ, ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф <ph name="APP_NAME" />.</translation>
<translation id="8442258441309440798">ОљОЎОЪ ОАОЎОцОЋОеОЎОЮ ОќОъОЎОаОЎОЮ</translation>
<translation id="8443209985646068659">РђЈОљОЎ ОљОцОЕОе ОюОбОЊОЏОЪ ОљОф Chrome</translation>
<translation id="8445448999790540984">ОљОЎ ОљОцОЕОе ОюОЎОЎОдОљ ОАОЎОАОъОљОЋОф</translation>
<translation id="8446884382197647889">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
