<translation id="963246339335003378">ಟಾಸ್ಕ್‌ ಮ್ಯಾನೇಜರ್‌ ಅನ್ನು ತೆರೆಯಿರಿ</translation>
<translation id="966131775676567255">ಖಾತೆಯ ಡೇಟಾವನ್ನು ಅಳಿಸಲಾಗುತ್ತಿದೆ</translation>
<translation id="970715775301869095"><ph name="MINUTES" /> ನಿಮಿಷಗಳು ಉಳಿದಿವೆ</translation>
