import("//build/config/android/config.gni")
import("//build/config/android/rules.gni")

if (enable_chrome_android_internal) {
  android_aar_prebuilt("play_review_aar_internal_java") {
    aar_path = "//third_party/android_deps/autorolled/cipd/libs/com_google_android_play_review/review.aar"
    info_path = "//third_party/android_deps/autorolled/committed/libs/com_google_android_play_review/com_google_android_play_review.info"

    # Skip core_common_java to avoid resource collisions with clank's internal playcore.
    deps = [
      "$google_play_services_package:google_play_services_basement_java",
      "$google_play_services_package:google_play_services_tasks_java",
    ]
  }

  java_group("play_review_aar_for_clank_java") {
    deps = [ ":play_review_aar_internal_java" ]
  }
}

android_library("java") {
  sources = [
    "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingManager.java",
    "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingManagerFactory.java",
    "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingPromoController.java",
    "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingPromoMetrics.java",
  ]
  deps = [
    "//base:base_java",
    "//base:service_loader_java",
    "//build/android:build_java",
    "//chrome/browser/feature_engagement:java",
    "//chrome/browser/flags:java",
    "//chrome/browser/preferences:java",
    "//chrome/browser/profiles/android:java",
    "//chrome/browser/segmentation_platform:factory_java",
    "//components/feature_engagement/public:public_java",
    "//components/prefs/android:java",
    "//components/segmentation_platform/public:public_java",
    "//components/user_prefs/android:java",
    "//content/public/android:content_full_java",
    "//third_party/androidx:androidx_annotation_annotation_java",
  ]
}

android_library("impl_java") {
  sources = [ "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingManagerImpl.java" ]
  proguard_configs = [ "proguard.flags" ]
  deps = [
    ":java",
    "$google_play_services_package:google_play_services_tasks_java",
    "//base:base_java",
    "//build/android:build_java",
    "//third_party/androidx:androidx_annotation_annotation_java",
  ]
  if (enable_chrome_android_internal) {
    deps += [ ":play_review_aar_for_clank_java" ]
  } else {
    deps += [ "//third_party/android_deps:com_google_android_play_review_java" ]
  }
}

robolectric_library("junit") {
  sources = [
    "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingManagerTest.java",
    "java/src/org/chromium/chrome/browser/ui/app_rating/AppRatingPromoControllerTest.java",
  ]
  deps = [
    ":impl_java",
    ":java",
    "//base:base_java_test_support",
    "//base:base_junit_test_support",
    "//base:callback_java",
    "//chrome/browser/feature_engagement:java",
    "//chrome/browser/flags:java",
    "//chrome/browser/preferences:java",
    "//chrome/browser/profiles/android:java",
    "//chrome/browser/segmentation_platform:factory_java",
    "//components/feature_engagement/public:public_java",
    "//components/prefs/android:java",
    "//components/segmentation_platform/public:public_java",
    "//components/user_prefs/android:java",
    "//content/public/android:content_full_java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//third_party/androidx:androidx_test_core_java",
    "//third_party/androidx:androidx_test_runner_java",
    "//third_party/hamcrest:hamcrest_java",
    "//third_party/junit",
    "//third_party/mockito:mockito_java",
  ]
  if (enable_chrome_android_internal) {
    deps += [ ":play_review_aar_for_clank_java" ]
  } else {
    deps += [ "//third_party/android_deps:com_google_android_play_review_java" ]
  }
}
