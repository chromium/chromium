<org.chromium.chrome.browser.omnibox.fusebox.FuseboxScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fusebox_scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:accessibilityPaneTitle="@string/accessibility_omnibox_context_popup_title">

    <LinearLayout
        android:id="@+id/fusebox_view_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <ViewStub
            android:id="@+id/fusebox_attachments_stub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <View
            style="@style/Fusebox.PopupMenu.Divider"
            android:id="@+id/fusebox_tools_divider"/>

        <TextView
            style="@style/Fusebox.PopupMenu.Header"
            android:id="@+id/fusebox_tools_header"/>

        <View
            style="@style/Fusebox.PopupMenu.Divider"
            android:id="@+id/fusebox_models_divider"/>

        <TextView
            style="@style/Fusebox.PopupMenu.Header"
            android:id="@+id/fusebox_models_header"/>

    </LinearLayout>

</org.chromium.chrome.browser.omnibox.fusebox.FuseboxScrollView>
