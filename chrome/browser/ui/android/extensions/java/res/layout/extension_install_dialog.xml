<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

  <LinearLayout
    android:id="@+id/webstore_info_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingStart="24dp"
      android:paddingTop="16dp"
      android:visibility="gone" >
      <RatingBar
        android:id="@+id/webstore_rating_bar"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.1"
        android:isIndicator="true"
        android:visibility="gone" />
      <TextView
        android:id="@+id/webstore_user_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:textAppearance="@style/TextAppearance.TextSmall"
        android:visibility="gone" />
    </LinearLayout>

    <TextView
      android:id="@+id/webstore_real_user_count"
      android:layout_width="match_parent"
      android:paddingTop="16dp"
      android:layout_height="wrap_content"
      android:textAppearance="@style/TextAppearance.TextSmall"
      android:visibility="gone"
      android:paddingStart="24dp" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/scroll_view_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/permissions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/modal_dialog_control_vertical_padding_filled"
        android:visibility="gone">
        <TextView
          android:id="@+id/permissions_heading"
          android:textAppearance="@style/TextAppearance.TextMedium.Primary"
          style="@style/AlertDialogContent" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/justification_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingTop="@dimen/modal_dialog_control_vertical_padding_filled"
      android:visibility="gone">
      <TextView
        android:id="@+id/justification_heading"
        android:textAppearance="@style/TextAppearance.TextMedium.Primary"
        style="@style/AlertDialogContent" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/justification_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/dialog_padding_sides"
        app:counterEnabled="true"
        app:counterMaxLength="@integer/extension_install_dialog_justification_max_input">
          <com.google.android.material.textfield.TextInputEditText
              android:id="@+id/justification_input_text"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"/>
      </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
  </LinearLayout>
  <TextView
    android:id="@+id/store_link"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:textAppearance="@style/TextAppearance.TextMedium.Link"
    android:visibility="gone"
    android:paddingTop="@dimen/modal_dialog_control_vertical_padding_filled"
    android:paddingStart="24dp" />

</LinearLayout>
