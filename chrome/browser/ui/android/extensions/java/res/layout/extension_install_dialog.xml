<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

  <LinearLayout
    android:id="@+id/webstore_info_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">
    <!-- TODO(crbug.com/424010795): Add webstore information -->
  </LinearLayout>


  <LinearLayout
    android:id="@+id/permissions_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <org.chromium.ui.widget.TextViewWithLeading
      android:id="@+id/permissions_heading"
      android:textAppearance="@style/TextAppearance.TextMedium.Primary"
      app:leading="@dimen/text_size_medium_leading"
      style="@style/AlertDialogContent" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/justification_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">
    <!-- TODO(crbug.com/424010795): Add justification textfield -->
  </LinearLayout>

</LinearLayout>
