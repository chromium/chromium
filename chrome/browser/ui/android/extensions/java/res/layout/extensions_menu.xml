<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:minWidth="320dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:clipToOutline="true"
        android:background="@drawable/default_popup_menu_bg"
        android:elevation="@dimen/app_menu_elevation">

        <include
            android:id="@+id/extensions_menu_header"
            layout="@layout/extensions_menu_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <org.chromium.components.browser_ui.widget.MaterialSwitchWithText
            android:id="@+id/extensions_menu_site_settings_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:layout_constraintTop_toBottomOf="@+id/extensions_menu_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <View
            android:id="@+id/extensions_menu_header_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_constraintTop_toBottomOf="@+id/extensions_menu_site_settings_toggle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/extensions_menu_reload_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/extensions_menu_header_divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/extensions_menu_reload_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/extensions_menu_message_section_reload_container_description_text"
                android:textAppearance="@style/TextAppearance.TextMedium.Secondary" />

            <org.chromium.ui.widget.ButtonCompat
                android:id="@+id/extensions_menu_reload_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/extensions_menu_message_section_reload_container_button_text"
                android:contentDescription="@string/extensions_menu_message_section_reload_container_button_tooltip" />
        </LinearLayout>

        <!-- Wrap RecyclerView and zero state in a FrameLayout to easily toggle and anchor them together -->
        <FrameLayout
            android:id="@+id/extensions_menu_items_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/extensions_menu_reload_section"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/extensions_menu_footer_divider"
            app:layout_constrainedHeight="true"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintVertical_bias="0">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/extensions_menu_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minWidth="320dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Restored original zero state UI from CL 7632587 -->
            <LinearLayout
                android:id="@+id/extensions_menu_zero_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minWidth="320dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="94dp"
                    app:srcCompat="@drawable/extensions_zero_state"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/extensions_menu_zero_state_header"
                    android:textAppearance="@style/TextAppearance.Headline2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/extensions_menu_zero_state_desc"
                    android:textAppearance="@style/TextAppearance.TextMedium.Primary" />

                <org.chromium.ui.widget.ButtonCompat
                    android:id="@+id/btn_open_store"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/open_web_store_button_text"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="20dp" />
            </LinearLayout>
        </FrameLayout>

        <View
            android:id="@+id/extensions_menu_footer_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_constraintTop_toBottomOf="@+id/extensions_menu_items_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/extensions_menu_footer"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="8dp" />

        <include
            android:id="@+id/extensions_menu_footer"
            layout="@layout/extensions_menu_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/extensions_menu_footer_divider"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            android:paddingBottom="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
