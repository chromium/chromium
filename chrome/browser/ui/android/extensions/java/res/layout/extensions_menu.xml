<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:minWidth="320dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:clipToOutline="true"
        android:background="@drawable/default_popup_menu_bg"
        android:elevation="@dimen/app_menu_elevation">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/extensions_menu_main_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <include
                android:id="@+id/extensions_menu_header"
                layout="@layout/extensions_menu_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/extensions_menu_site_settings_toggle_container"
                style="@style/ExtensionsMenuControlRow"
                app:layout_constraintTop_toBottomOf="@+id/extensions_menu_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/extensions_menu_site_settings_toggle_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/extensions_menu_site_settings_info_icon"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    style="@style/ExtensionsMenuAllowAccessText" />

                <ImageView
                    android:id="@+id/extensions_menu_site_settings_info_icon"
                    android:layout_width="@dimen/extensions_menu_extension_icon_size"
                    android:layout_height="@dimen/extensions_menu_extension_icon_size"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_info_24dp"
                    android:visibility="gone"
                    app:layout_constraintStart_toEndOf="@+id/extensions_menu_site_settings_toggle_text"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/extensions_menu_site_settings_toggle"
                    android:contentDescription="@string/extensions_menu_message_section_enterprise_tooltip_icon_text" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/extensions_menu_site_settings_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:focusable="false"
                    android:clickable="false"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/extensions_menu_header_divider"
                style="@style/ExtensionsMenuDivider"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@+id/extensions_menu_site_settings_toggle_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- State Container: Wraps both Active and Zero states to mutually exclude them -->
            <FrameLayout
                android:id="@+id/extensions_menu_state_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/extensions_menu_header_divider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/extensions_menu_footer_divider"
                app:layout_constrainedHeight="true"
                app:layout_constraintVertical_chainStyle="packed"
                app:layout_constraintVertical_bias="0">

                <!-- Active State: Contains Reload, Access Requests, and Menu Items -->
                <LinearLayout
                    android:id="@+id/extensions_menu_active_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="2dp">

                    <LinearLayout
                        android:id="@+id/extensions_menu_reload_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/extensions_menu_horizontal_padding"
                        android:paddingEnd="@dimen/extensions_menu_horizontal_padding"
                        android:paddingVertical="@dimen/extensions_menu_toggle_vertical_padding"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/extensions_menu_reload_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/extensions_menu_message_section_reload_container_description_text"
                            android:textAppearance="@style/TextAppearance.TextMedium.Secondary" />

                        <org.chromium.ui.widget.ButtonCompat
                            android:id="@+id/extensions_menu_reload_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_gravity="center_horizontal"
                            android:text="@string/extensions_menu_message_section_reload_container_button_text"
                            android:contentDescription="@string/extensions_menu_message_section_reload_container_button_tooltip" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/extensions_request_access_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_margin="@dimen/extensions_menu_horizontal_padding"
                            android:background="@drawable/extensions_request_access_bg">

                            <TextView
                                android:id="@+id/extensions_request_access_section_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="@dimen/extensions_menu_request_access_padding"
                                android:paddingEnd="@dimen/extensions_menu_request_access_padding"
                                android:paddingTop="@dimen/extensions_menu_request_access_padding"
                                android:text="@string/extensions_menu_requests_access_section_title"
                                android:textAppearance="@style/TextAppearance.TextMediumThick.Secondary" />

                            <LinearLayout
                                android:id="@+id/extensions_request_access_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="@dimen/extensions_menu_request_access_padding"
                                android:paddingEnd="@dimen/extensions_menu_request_access_padding"
                                android:paddingBottom="4dp"
                                android:orientation="vertical" />
                        </LinearLayout>

                        <View style="@style/ExtensionsMenuDivider" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/extensions_menu_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minWidth="320dp" />
                </LinearLayout>

                <!-- Zero State: Mutually exclusive with the active state -->
                <LinearLayout
                    android:id="@+id/extensions_menu_zero_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minWidth="320dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/extensions_menu_horizontal_padding"
                    android:paddingVertical="@dimen/extensions_menu_toggle_vertical_padding"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="200dp"
                        android:layout_height="94dp"
                        app:srcCompat="@drawable/extensions_zero_state"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/extensions_menu_zero_state_header"
                        android:textAppearance="@style/TextAppearance.Headline2.Primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/extensions_menu_zero_state_desc"
                        android:textAppearance="@style/TextAppearance.TextMedium.Primary" />

                    <org.chromium.ui.widget.ButtonCompat
                        android:id="@+id/btn_open_store"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/open_web_store_button_text"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </FrameLayout>

            <View
                android:id="@+id/extensions_menu_footer_divider"
                style="@style/ExtensionsMenuDivider"
                android:layout_marginBottom="4dp"
                app:layout_constraintTop_toBottomOf="@+id/extensions_menu_state_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/extensions_menu_footer" />

            <include
                android:id="@+id/extensions_menu_footer"
                layout="@layout/extensions_menu_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/extensions_menu_footer_divider"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingBottom="8dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            android:id="@+id/extensions_menu_site_permissions_page"
            layout="@layout/extensions_menu_site_permissions_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
