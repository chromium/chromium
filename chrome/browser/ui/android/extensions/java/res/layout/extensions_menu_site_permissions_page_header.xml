<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="@dimen/extensions_menu_horizontal_padding"
    android:paddingVertical="@dimen/extensions_menu_header_vertical_padding"
    tools:ignore="UnusedResources">

    <ImageButton
        android:id="@+id/extensions_menu_back_button"
        android:layout_width="@dimen/extensions_menu_header_button_size"
        android:layout_height="@dimen/extensions_menu_header_button_size"
        android:src="@drawable/ic_arrow_back_24dp"
        android:background="@drawable/default_icon_background_selector"
        android:contentDescription="@string/back"
        android:scaleType="center"/>

    <ImageView
        android:id="@+id/extensions_menu_extension_icon"
        android:layout_width="@dimen/extensions_menu_header_icon_size"
        android:layout_height="@dimen/extensions_menu_header_icon_size"
        android:layout_marginStart="4dp"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/extensions_menu_extension_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/extensions_menu_header_spacing"
        android:layout_marginEnd="@dimen/extensions_menu_header_spacing"
        android:textAppearance="@style/TextAppearance.Headline2.Primary" />

    <ImageButton
        android:id="@+id/extensions_menu_site_permissions_close_button"
        android:layout_width="@dimen/extensions_menu_header_button_size"
        android:layout_height="@dimen/extensions_menu_header_button_size"
        android:src="@drawable/ic_close"
        android:background="@drawable/default_icon_background_selector"
        android:contentDescription="@string/close"
        android:scaleType="center"
        android:layout_gravity="top"/>

</LinearLayout>
