<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Styles for the extensions menu -->
    <style name="ExtensionsMenuControlRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">@dimen/extensions_menu_footer_min_height</item>
        <item name="android:paddingStart">@dimen/extensions_menu_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/extensions_menu_horizontal_padding</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:baselineAligned">false</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="ExtensionsMenuControlIcon">
        <item name="android:layout_width">@dimen/extensions_menu_footer_icon_size</item>
        <item name="android:layout_height">@dimen/extensions_menu_footer_icon_size</item>
        <item name="tint">?android:attr/textColorPrimary</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

    <style name="ExtensionsMenuAllowAccessText" parent="ExtensionsMenuControlText">
        <item name="android:textAppearance">@style/TextAppearance.TextMedium.Primary</item>
    </style>

    <style name="ExtensionsMenuControlText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">@dimen/extensions_menu_horizontal_padding</item>
        <item name="android:textAppearance">@style/TextAppearance.TextLarge.Primary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="ExtensionsMenuDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/divider_height</item>
        <item name="android:background">?android:attr/listDivider</item>
        <item name="android:layout_marginTop">@dimen/extensions_menu_divider_vertical_margin</item>
        <item name="android:layout_marginBottom">@dimen/extensions_menu_divider_vertical_margin</item>
    </style>

    <style name="TextAppearance.ExtensionsRequestAccessButton" parent="TextAppearance.TextAccentLarge">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/default_text_color_list</item>
    </style>
</resources>
