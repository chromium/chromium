<org.chromium.components.browser_ui.widget.MaterialCardViewNoShadow
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/discover_info_view_wrapper"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/MaterialCardStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="30dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/discover_info_card_title"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_gravity="top"
                android:includeFontPadding="false"
                android:textAppearance="@style/TextAppearance.Headline.Primary"
                android:translationY="-0.23sp"
                android:text="@string/supervised_user_discover_info_card_title"
                android:paddingStart="24dp"/>

            <TextView
                android:id="@+id/discover_info_card_description"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:gravity="top"
                android:includeFontPadding="false"
                android:textAppearance="@style/TextAppearance.TextSmall.Secondary"
                android:text="@string/supervised_user_discover_info_card_description"
                android:paddingStart="24dp"
                android:paddingTop="10dp"
                android:paddingBottom="5dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/discover_info_card_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:importantForAccessibility="no"
            android:scaleType="centerInside"
            android:src="@drawable/supervised_user_info_card_illustration" />

    </LinearLayout>

    <org.chromium.ui.widget.ChromeImageButton
        android:id="@+id/discover_info_card_close_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:background="?attr/selectableItemBackground"
        android:contentDescription="@string/close"
        android:scaleType="center"
        android:src="@drawable/btn_close"
        app:tint="@macro/default_icon_color" />

</org.chromium.components.browser_ui.widget.MaterialCardViewNoShadow>
