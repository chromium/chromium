<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="lo">
<translation id="1275718070701477396">​ເລືອກແລ້ວ</translation>
<translation id="248973266728004341">ເພີ່ມບັດເຄຣດິດບັດໃໝ່</translation>
<translation id="385051799172605136">ກັບ​ຄືນ​</translation>
<translation id="4401440167302712543">ການຕື່ມຂໍ້ມູນການສົ່ງ ແລະ ການຈ່າຍເງິນໂດຍອັດຕະໂນມັດໃນເວລາທີ່ທ່ານຈ່າຍເງິນ</translation>
<translation id="4526274353008646337">ເພີ່ມທີ່ຢູ່ໃໝ່</translation>
<translation id="567079066552447069">ລາຍການທີ່ຢູ່ ແລະ ຕົວເລືອກການຈ່າຍເງິນທີ່ຕ້ອງຕື່ມໃນລະຫວ່າງຂັ້ນຕອນການຈ່າຍເງິນແມ່ນຖືກປິດແລ້ວ.</translation>
<translation id="5747552184818312860">ໝົດອາຍຸ</translation>
<translation id="6476284679642588870">ຈັດການວິທີການຈ່າຍເງິນ</translation>
<translation id="7974390230414479278">ລາຍ​ການ​ເມ​ນູ</translation>
<translation id="884264119367021077">ທີ່​ຢູ່​ຈັດສົ່ງ</translation>
<translation id="8873105120914375071">ຈ່າຍເງິນໃຫ້ໄວຂຶ້ນບໍ?</translation>
<translation id="9032876013752408138">ຕື່ມຂໍ້ມູນຂອງຂ້ອຍໂດຍອັດຕະໂນມັດ</translation>
<translation id="984275831282074731">ວິທີການຈ່າຍເງິນ</translation>
</translationbundle>