<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1275718070701477396">бһ”бһ¶бһ“бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹ</translation>
<translation id="248973266728004341">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһҖбһ¶бһҸбһҘбһҺбһ‘бһ¶бһ“вҖӢбһҗбҹ’бһҳбһё</translation>
<translation id="385051799172605136">бһҗбһҷбһҖбҹ’бһҡбҹ„бһҷ</translation>
<translation id="4401440167302712543">бһ”бҹҶбһ–бҹҒбһүвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһўбҹҶбһ–бһёбһҖбһ¶бһҡбһ‘бһјбһ‘бһ¶бһҸбҹӢ бһ“бһ·бһ„вҖӢбһҖбһ¶бһҡбһҠбһ№бһҖбһҮбһүбҹ’бһ…бһјбһ“вҖӢбһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·вҖӢбһ“бҹ…бһ–бҹҒбһӣвҖӢбһўбҹ’бһ“бһҖвҖӢбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢбһ…бҹҒбһү</translation>
<translation id="4526274353008646337">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“вҖӢбһҗбҹ’бһҳбһё</translation>
<translation id="567079066552447069">бһ”бһүбҹ’бһҮбһёвҖӢбһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“ бһ“бһ·бһ„вҖӢбһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһ”бһ„бҹӢвҖӢбһ”бҹ’бһҡбһ¶бһҖбҹӢвҖӢвҖӢвҖӢбһҠбҹӮбһӣвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бҹҶбһ–бҹҒбһүвҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢбһўбҹҶбһЎбһ»бһ„вҖӢвҖӢбһӣбҹҶбһ бһјбһҡвҖӢбһ“бҹғвҖӢбһҖбһ¶бһҡбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢбһ…бҹҒбһү бһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“бһ”бһ·бһ‘бҹ”</translation>
<translation id="5747552184818312860">бһ•бһ»бһҸбһҖбҹҶбһҺбһҸбҹӢ</translation>
<translation id="6476284679642588870">бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„вҖӢбһңбһ·бһ’бһёбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢ</translation>
<translation id="7974390230414479278">бһ’бһ¶бһҸбһ»бһҳбҹүбһәбһ“бһ»бһҷ</translation>
<translation id="884264119367021077">бһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“бһҠбһ№бһҖбһҮбһүбҹ’бһҮбһјбһ“бһ‘бҹ…</translation>
<translation id="8873105120914375071">бһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢбһ…бҹҒбһүвҖӢбһӣбһҝбһ“бһҮбһ¶бһ„бһҳбһ»бһ“вҖӢбһ¬?</translation>
<translation id="9032876013752408138">бһ”бҹҶбһ–бҹҒбһүвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһҡбһ”бһҹбҹӢбһҒбҹ’бһүбһ»бҹҶвҖӢбһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·</translation>
<translation id="984275831282074731">бһңбһ·бһ’бһёвҖӢбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢ</translation>
</translationbundle>