import("//build/config/ui.gni")

assert(is_win || is_mac || is_linux || is_chromeos)

source_set("personal_context") {
  sources = [
    "personal_context_notice_dialog.cc",
    "personal_context_notice_dialog.h",
    "personal_context_notice_dialog_controller.cc",
    "personal_context_notice_dialog_controller.h",
  ]

  deps = [
    "//base",
    "//chrome/browser:primitives",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/views/bubble",
    "//chrome/browser/ui/webui/personal_context",
    "//chrome/browser/ui/webui/top_chrome",
    "//components/constrained_window",
    "//components/web_modal",
    "//content/public/browser",
    "//ui/base",
    "//ui/views",
    "//ui/views/controls/webview",
  ]
}

source_set("browser_tests") {
  testonly = true

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "personal_context_notice_dialog_browsertest.cc" ]

  deps = [
    ":personal_context",
    "//base",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui",
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/webui/personal_context",
    "//chrome/test:test_support",
    "//components/personal_context/first_run",
    "//content/public/browser",
    "//content/test:test_support",
    "//ui/events:test_support",
    "//ui/views",
  ]
}
