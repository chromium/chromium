import("//build/config/features.gni")

source_set("status_icons") {
  sources = []
  public_deps = []
  deps = []

  if (is_linux) {
    sources += [
      "status_icon_button_linux.cc",
      "status_icon_button_linux.h",
      "status_icon_linux_wrapper.cc",
      "status_icon_linux_wrapper.h",
      "status_tray_linux.cc",
      "status_tray_linux.h",
    ]
    public_deps += [
      "//build/config/linux/dbus:buildflags",
      "//chrome/browser/status_icons",
      "//ui/base/mojom:ui_base_types",
      "//ui/linux:linux_ui",
      "//ui/views",
    ]
    deps += [
      "//chrome/browser:shell_integration_linux",
      "//chrome/browser/ui:ui_features",
      "//ui/aura",
      "//ui/base:wm_role_names",
      "//ui/message_center/public/cpp",
      "//ui/ozone",
    ]

    if (use_dbus) {
      sources += [
        "concat_menu_model.cc",
        "concat_menu_model.h",
        "status_icon_linux_dbus.cc",
        "status_icon_linux_dbus.h",
      ]
      public_deps += [ "//components/dbus" ]
      deps += [ "//content/public/browser" ]
    }
  }

  if (is_chromeos) {
    sources += [
      "status_icon_chromeos.cc",
      "status_icon_chromeos.h",
      "status_tray_chromeos.cc",
      "status_tray_chromeos.h",
    ]
    public_deps += [
      "//chrome/browser/status_icons",
      "//ui/display",
      "//ui/gfx",
    ]
    deps += [
      "//ash",
      "//ash/constants",
      "//base",
    ]
  }

  if (is_win) {
    sources = [
      "status_icon_win.cc",
      "status_icon_win.h",
      "status_tray_state_changer_win.cc",
      "status_tray_state_changer_win.h",
      "status_tray_win.cc",
      "status_tray_win.h",
    ]
    public_deps += [
      "//base",
      "//chrome/browser/status_icons",
    ]
    deps += [
      "//chrome/browser/lifetime",
      "//chrome/common:non_code_constants",
      "//skia",
      "//ui/display",
      "//ui/gfx",
      "//ui/message_center/public/cpp",
      "//ui/views",
    ]
  }
}

if (is_win) {
  source_set("unit_tests") {
    testonly = true
    sources = [ "status_tray_win_unittest.cc" ]
    deps = [
      ":status_icons",
      "//chrome/browser/status_icons",
      "//chrome/test:test_support",
      "//ui/gfx",
      "//ui/views:test_support",
    ]
  }

  source_set("interactive_ui_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "status_tray_state_changer_interactive_uitest_win.cc" ]
    deps = [
      ":status_icons",
      "//base",
      "//chrome/browser/status_icons",
      "//skia",
      "//testing/gtest",
      "//ui/gfx",
    ]
  }
}
