source_set("page_action_test_support") {
  testonly = true

  sources = [
    "test_support/page_action_test_support.cc",
    "test_support/page_action_test_support.h",
  ]

  public_deps = [
    ":page_action",
    "//ui/actions:actions_headers",
  ]

  deps = [
    "//base",
    "//chrome/browser/ui:ui_features",
    "//chrome/browser/ui/page_action",
  ]
}

source_set("test_support") {
  testonly = true

  sources = [
    "test_support/mock_anchored_message_delegate.cc",
    "test_support/mock_anchored_message_delegate.h",
  ]

  public_deps = [
