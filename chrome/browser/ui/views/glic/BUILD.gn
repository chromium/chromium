import("//chrome/common/features.gni")

assert(enable_glic)

source_set("glic") {
  sources = []

  if (!is_android) {
    sources += [
      "glic_button.h",
      "glic_button_interface.h",
    ]
    deps = [
      "//base",
      "//chrome/browser/glic",
      "//chrome/browser/ui:layout_constants",
      "//chrome/browser/ui/views",
      "//ui/base/metadata",
      "//ui/gfx/geometry",
      "//ui/views",
    ]
  }
}
