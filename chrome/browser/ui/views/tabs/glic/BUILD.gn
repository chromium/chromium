import("//chrome/common/features.gni")

source_set("glic") {
  sources = [ "glic_actor_constants.h" ]

  if (!is_android) {
    sources += [
      "glic_and_actor_buttons_container.h",
      "tab_strip_glic_actor_task_icon.h",
      "tab_strip_glic_button.h",
    ]
    deps = [
      "//base",
      "//chrome/browser/glic",
      "//chrome/browser/ui:layout_constants",
      "//chrome/browser/ui/tabs",
      "//chrome/browser/ui/tabs:tab_strip",
      "//chrome/browser/ui/views",
      "//chrome/browser/ui/views/glic",
      "//chrome/browser/ui/views/tabs/dragging:tab_drag_target",
      "//components/tabs",
      "//ui/base/metadata",
      "//ui/gfx/geometry",
      "//ui/views",
    ]
  }
}

if (!is_android) {
  source_set("impl") {
    sources = [
      "glic_and_actor_buttons_container.cc",
      "tab_strip_glic_actor_task_icon.cc",
      "tab_strip_glic_button.cc",
    ]
    deps = [
      ":glic",
      "//base",
      "//chrome/app:command_ids",
      "//chrome/app:generated_resources_grit",
      "//chrome/app/vector_icons",
      "//chrome/browser:browser_public_dependencies",
      "//chrome/browser/actor/resources:grit",
      "//chrome/browser/background/glic",
      "//chrome/browser/glic",
      "//chrome/browser/glic:enum",
      "//chrome/browser/glic/fre",
      "//chrome/browser/ui:browser_element_identifiers",
      "//chrome/browser/ui/browser_window",
      "//chrome/browser/ui/color:color_headers",
      "//chrome/browser/ui/tabs",
      "//chrome/browser/ui/user_education",
      "//chrome/browser/ui/views/glic",
      "//chrome/browser/ui/views/interaction",
      "//chrome/common:chrome_features",
      "//ui/base",
      "//ui/base/metadata",
      "//ui/gfx",
      "//ui/gfx/geometry",
      "//ui/views",
    ]
  }
}
