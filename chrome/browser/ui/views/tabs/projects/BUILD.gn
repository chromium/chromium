source_set("projects") {
  sources = [
    "projects_panel_controller.cc",
    "projects_panel_controller.h",
    "projects_panel_controls_view.cc",
    "projects_panel_controls_view.h",
    "projects_panel_tab_groups_view.cc",
    "projects_panel_tab_groups_view.h",
    "projects_panel_view.cc",
    "projects_panel_view.h",
  ]

  deps = [
    "//base",
    "//chrome/app:generated_resources",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui:layout_constants",
    "//chrome/browser/ui/actions:actions_headers",
    "//chrome/browser/ui/color:color_headers",
    "//chrome/browser/ui/tabs/projects",
    "//chrome/browser/ui/views/tabs/vertical",
    "//components/saved_tab_groups/public",
    "//ui/actions",
    "//ui/base",
    "//ui/views",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "projects_panel_controller_unittest.cc" ]
  deps = [
    ":projects",
    "//base/test:test_support",
    "//components/saved_tab_groups/public",
    "//components/saved_tab_groups/test_support",
  ]

  # TODO(crbug.com/40031409): Fix code that adds exit-time destructors and
  # enable the diagnostic by removing this line.
  configs += [ "//build/config/compiler:no_exit_time_destructors" ]
}
