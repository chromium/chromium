source_set("shared") {
  sources = [
    "drop_arrow.h",
    "tab_strip_combo_button.h",
    "tab_strip_flat_edge_button.h",
  ]

  deps = [
    "//chrome/browser/ui/views",
    "//chrome/browser/ui/views/frame",
    "//components/prefs",
    "//ui/base/metadata",
    "//ui/menus",
    "//ui/views",
  ]
}

source_set("impl") {
  sources = [
    "drop_arrow.cc",
    "tab_strip_combo_button.cc",
    "tab_strip_flat_edge_button.cc",
  ]

  deps = [
    ":shared",
    "//base:i18n",
    "//chrome/app:command_ids",
    "//chrome/app:generated_resources_grit",
    "//chrome/app/vector_icons",
    "//chrome/browser:primitives",
    "//chrome/browser/ui:layout_constants",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/color:color_headers",
    "//chrome/browser/ui/tabs",
    "//chrome/browser/ui/tabs/saved_tab_groups",
    "//chrome/browser/ui/toolbar/pinned_toolbar",
    "//chrome/browser/ui/views/frame",
    "//chrome/browser/ui/views/toolbar",
    "//components/prefs",
    "//ui/actions",
    "//ui/menus",
    "//ui/views",
  ]
}

source_set("interactive_ui_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "tab_strip_combo_button_interactive_uitest.cc" ]
  deps = [
    ":impl",
    "//base",
    "//chrome/browser/ui",
    "//chrome/browser/ui/views/tabs/shared",
    "//chrome/test:test_support",
    "//chrome/test:test_support_ui",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/views",
  ]
}
