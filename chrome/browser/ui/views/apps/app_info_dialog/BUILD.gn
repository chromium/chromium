import("//build/config/ui.gni")

assert(toolkit_views)

source_set("app_info_dialog") {
  public = [
    "app_info_dialog_container.h",
    "app_info_dialog_views.h",
    "app_info_footer_panel.h",
    "app_info_header_panel.h",
    "app_info_label.h",
    "app_info_panel.h",
    "app_info_permissions_panel.h",
    "app_info_summary_panel.h",
  ]
  public_deps = [
    "//base",
    "//chrome/browser/extensions",
    "//ui/base",
    "//ui/views",
  ]

  if (is_chromeos) {
    public += [ "arc_app_info_links_panel.h" ]
    public_deps += [ "//chrome/browser/ash/app_list/arc" ]
  }
}

source_set("impl") {
  sources = [
    "app_info_dialog_container.cc",
    "app_info_dialog_views.cc",
    "app_info_footer_panel.cc",
    "app_info_header_panel.cc",
    "app_info_label.cc",
    "app_info_panel.cc",
    "app_info_permissions_panel.cc",
    "app_info_summary_panel.cc",
  ]
  deps = [
    ":app_info_dialog",
    "//apps",
    "//chrome/browser/apps/platform_apps",
    "//chrome/browser/ui/dialogs:browser_dialogs",
    "//chrome/browser/web_applications",
    "//components/app_constants",
  ]

  if (is_chromeos) {
    sources += [ "arc_app_info_links_panel.cc" ]
    deps += [
      "//ash/strings",
      "//chrome/browser/ash/arc:arc_util",
      "//chrome/browser/ui/ash/shelf",
      "//chromeos/ash/experiences/arc:arc_app_constants",
      "//chromeos/ash/experiences/arc/intent_helper:arc_intent_helper_constants",
    ]
  }
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "app_info_dialog_views_unittest.cc",
    "app_info_permissions_panel_unittest.cc",
  ]
  deps = [
    ":app_info_dialog",
    "//apps",
    "//base",
    "//chrome/app:generated_resources",
    "//chrome/browser/extensions",
    "//chrome/browser/extensions:test_support",
    "//chrome/test:test_support",
    "//components/app_constants",
  ]
  if (is_chromeos) {
    deps += [
      "//chrome/browser/ash/app_list/arc:test_support",
      "//chrome/browser/ash/browser_delegate:impl",
      "//chrome/browser/ui/ash/shelf",
      "//chromeos/ash/experiences/arc:arc_app_constants",
    ]
  }
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "app_info_dialog_views_browsertest.cc" ]
    deps = [
      ":app_info_dialog",
      "//base",
      "//base/test:test_support",
      "//chrome/browser/ui",
      "//chrome/browser/ui/tabs:tab_strip",
      "//chrome/browser/ui/test:dialog",
      "//chrome/test:test_support",
    ]
  }
}
