    "//components/services/app_service/public/cpp:app_types",
    "//ui/base",
    "//ui/views",
  ]
}

source_set("impl") {
  sources = [
    "app_block_dialog_view.cc",
    "app_dialog_view.cc",
    "app_local_block_dialog_view.cc",
    "app_pause_dialog_view.cc",
    "app_uninstall_dialog_view.cc",
  ]
  deps = [
    ":app_dialog",
    "//chrome/browser/ash/app_list/arc",
    "//chrome/browser/ash/borealis",
