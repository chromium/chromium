import("//build/config/ui.gni")

assert(toolkit_views)

source_set("digital_credentials") {
  sources = [
    "digital_identity_bluetooth_manual_dialog_controller.h",
    "digital_identity_multi_step_dialog.h",
    "digital_identity_safety_interstitial_controller_desktop.h",
  ]
  public_deps = [
    "//base",
    "//chrome/browser/digital_credentials",
    "//components/web_modal",
    "//content/public/browser",
    "//ui/views",
  ]
}

source_set("impl") {
  sources = [
    "digital_identity_bluetooth_manual_dialog_controller.cc",
    "digital_identity_multi_step_dialog.cc",
    "digital_identity_safety_interstitial_controller_desktop.cc",
  ]
  deps = [
    ":digital_credentials",
    "//chrome/app:generated_resources",
    "//chrome/app:generated_resources__strings_grit",
    "//chrome/app/vector_icons",
    "//chrome/browser/ui/views/accessibility",
    "//components/constrained_window",
    "//components/url_formatter",
    "//ui/base",
  ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [
      "digital_identity_integration_test.cc",
      "digital_identity_multi_step_dialog_browsertest.cc",
    ]
    deps = [
      ":digital_credentials",
      "//base",
      "//base/test:test_support",
      "//chrome/browser:chrome_content_browser_client",
      "//chrome/browser/digital_credentials",
      "//chrome/test:test_support",
      "//ui/events:test_support",
    ]
  }
}
