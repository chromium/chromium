import("//mojo/public/tools/bindings/mojom.gni")

assert(!is_android)

mojom("mojo_bindings") {
  sources = [ "drive_picker_result_handler.mojom" ]
  public_deps = [ "//url/mojom:url_mojom_gurl" ]
  webui_module_path = "/"
}

source_set("drive_picker_host") {
  sources = [
    "drive_picker_host_controller.cc",
    "drive_picker_host_controller.h",
    "drive_picker_host_view.cc",
    "drive_picker_host_view.h",
    "drive_picker_sanitizer.cc",
    "drive_picker_sanitizer.h",
  ]

  public_deps = [
    ":mojo_bindings",
    "//ui/views",
  ]
  deps = [
    "//chrome/browser:browser_public_dependencies",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/webui/drive_picker_host",
    "//chrome/browser/ui/webui/drive_picker_host:mojo_bindings",
    "//chrome/common",
    "//components/constrained_window",
    "//content/public/browser",
    "//net",
    "//skia",
    "//ui/base",
    "//ui/base/metadata",
    "//ui/gfx",
    "//ui/views/controls/webview",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "drive_picker_host_controller_unittest.cc",
    "drive_picker_host_view_unittest.cc",
    "drive_picker_sanitizer_unittest.cc",
  ]
  deps = [
    ":drive_picker_host",
    "//chrome/browser/ui",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/browser_window/test:test_support",
    "//chrome/browser/ui/views:test_support",
    "//chrome/browser/ui/webui/drive_picker_host",
    "//chrome/common",
    "//chrome/test:test_support",
    "//content/test:test_support",
    "//testing/gtest",
    "//ui/views:test_support",
  ]
}
