import("//build/config/chromeos/ui_mode.gni")

assert(is_win)

source_set("search_promotion") {
  public = [
    "search_promotion_manager.h",
    "search_promotion_manager_factory.h",
    "search_promotion_navigation_observer.h",
  ]

  sources = [
    "search_promotion_manager.cc",
    "search_promotion_manager_factory.cc",
    "search_promotion_navigation_observer.cc",
  ]

  public_deps = [
    "//base",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui/tabs",
    "//components/keyed_service/core",
    "//content/public/browser",
    "//url",
  ]

  deps = [
    "//chrome/browser/feature_engagement",
    "//components/feature_engagement/public",
    "//components/google/core/common",
    "//components/tabs:public",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "search_promotion_manager_unittest.cc" ]
  deps = [
    ":search_promotion",
    "//chrome/test:test_support",
    "//components/feature_engagement/public",
    "//components/feature_engagement/test:test_support",
    "//components/tabs:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
