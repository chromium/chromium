assert(is_win || is_mac || is_linux || is_chromeos)

source_set("animation") {
  public = [
    "browser_animation_controller.h",
    "browser_animation_provider.h",
    "browser_animation_provider_internal.h",
    "browser_animation_types.h",
  ]

  sources = [
    "browser_animation_controller.cc",
    "browser_animation_provider.cc",
    "browser_animation_provider_internal.cc",
  ]

  public_deps = [
    "//base",
    "//ui/base/identifier",
    "//ui/base/unowned_user_data",
    "//ui/gfx/animation",
  ]

  deps = [
    "//chrome/browser/ui/browser_window",
    "//ui/views",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "browser_animation_controller_unittest.cc" ]

  deps = [
    ":animation",
    "//base/test:test_support",
    "//chrome/browser/ui:test_support",
    "//chrome/browser/ui/browser_window",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base/interaction:test_support",
    "//ui/gfx:test_support",
  ]
}

source_set("browser_tests") {
  testonly = true

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "browser_animation_controller_browsertest.cc" ]

  deps = [
    ":animation",
    "//base/test:test_support",
    "//chrome/browser/ui:test_support",
    "//chrome/browser/ui/browser_window",
    "//chrome/test:test_support_ui",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base/interaction:test_support",
    "//ui/gfx:test_support",
  ]
}
