import("//build/config/ui.gni")

assert(!is_android)

source_set("focus") {
  public = [
    "browser_focus_controller.h",
    "browser_focus_controller_delegate_views.h",
  ]

  public_deps = [
    "//base",
    "//chrome/browser/ui:browser_element_identifiers",
    "//ui/base/unowned_user_data",
  ]
}

source_set("impl") {
  sources = [
    "browser_focus_controller.cc",
    "browser_focus_controller_delegate_views.cc",
  ]

  public_deps = [
    ":focus",
    "//chrome/browser:browser_public_dependencies",
  ]

  deps = [
    "//base",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/interaction",
    "//chrome/browser/ui/views/frame:toolbar_button_provider",
    "//chrome/browser/ui/views/infobars",
    "//chrome/browser/ui/views/location_bar",
    "//chrome/browser/ui/views/toolbar",
    "//chrome/browser/user_education",
    "//components/feature_engagement/public",
    "//components/user_education/common",
    "//components/user_education/views",
    "//ui/views",
  ]
}
