import("//mojo/public/tools/bindings/mojom.gni")

assert(!is_android)

mojom("mojo_bindings") {
  sources = [ "downloads.mojom" ]
  webui_module_path = "/"

  public_deps = [
    "//mojo/public/mojom/base",
    "//url/mojom:url_mojom_gurl",
  ]
}

source_set("downloads") {
  sources = [
    "downloads_dom_handler.cc",
    "downloads_list_tracker.cc",
    "downloads_ui.cc",
  ]
  public = [
    "downloads_dom_handler.h",
    "downloads_list_tracker.h",
    "downloads_ui.h",
  ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
  deps = [
    ":mojo_bindings",
    "//base",
    "//chrome/browser:defaults",
    "//chrome/browser:primitives",
    "//chrome/browser/download",
    "//chrome/browser/download:impl",
    "//chrome/browser/enterprise",
  ]

  if (!is_chromeos) {
    deps += [ "//chrome/browser/download/bubble" ]
  }

  deps += [
    "//chrome/app:branded_strings",
    "//chrome/app:generated_resources",
    "//chrome/app/theme:theme_resources",
    "//chrome/browser/extensions",
    "//chrome/browser/feature_engagement",
    "//chrome/browser/lifetime",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/resources/downloads:resources",
    "//chrome/browser/safe_browsing",
    "//chrome/browser/safe_browsing:advanced_protection",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui:ui_features",
    "//chrome/browser/ui/webui",
    "//chrome/browser/ui/webui:webui_load_timer",
    "//chrome/common",
    "//components/download/content/public",
    "//components/download/public/common:public",
    "//components/feature_engagement/public",
    "//components/google/core/common",
    "//components/history/core/common",
    "//components/prefs",
    "//components/profile_metrics",
    "//components/safe_browsing:buildflags",
    "//components/strings:components_strings",
    "//content/public/browser",
    "//mojo/public/cpp/bindings",
    "//ui/base",
    "//ui/webui",
    "//url",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "downloads_dom_handler_unittest.cc",
    "downloads_list_tracker_unittest.cc",
    "mock_downloads_page.cc",
    "mock_downloads_page.h",
  ]
  deps = [
    ":downloads",
    "//base",
    "//base/test:test_support",
    "//chrome/browser",
    "//chrome/browser/download",
    "//chrome/browser/download:impl",
    "//chrome/browser/ui/hats:test_support",
    "//chrome/test:test_support",
    "//components/download/public/common:public",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
