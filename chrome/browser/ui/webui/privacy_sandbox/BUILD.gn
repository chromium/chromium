import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojo_bindings") {
  disable_variants = true
  public_deps = [
    "//components/content_settings/core/common:mojo_bindings",
    "//mojo/public/mojom/base",
  ]

  deps = [ "//components/content_settings/core/common:content_settings_types" ]

  sources = [
    "base_dialog.mojom",
    "privacy_sandbox_internals.mojom",
  ]
  webui_module_path = "/"
}

if (!is_android) {
  source_set("privacy_sandbox") {
    public = [
      "base_dialog_handler.h",
      "base_dialog_ui.h",
    ]

    sources = [
      "base_dialog_handler.cc",
      "base_dialog_ui.cc",
    ]

    public_deps = [ ":mojo_bindings" ]

    deps = [
      "//base",
      "//chrome/app:generated_resources",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/resources/privacy_sandbox:resources",
      "//chrome/browser/ui/views/privacy_sandbox",
      "//chrome/common",
      "//components/privacy_sandbox:features",
      "//content/public/browser",
      "//ui/base",
      "//ui/webui",
    ]
  }

  source_set("unit_tests") {
    testonly = true
    sources = [ "base_dialog_handler_unittest.cc" ]

    deps = [
      ":mojo_bindings",
      ":privacy_sandbox",
      "//base/test:test_support",
      "//testing/gmock",
      "//testing/gtest",
    ]
  }

  source_set("browser_tests") {
    testonly = true

    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "base_dialog_browsertest.cc" ]

    deps = [
      ":privacy_sandbox",
      "//chrome/browser/ui:ui",
      "//chrome/browser/ui/tabs:tab_strip",
      "//chrome/browser/ui/views/privacy_sandbox",
      "//chrome/test:test_support_ui",
      "//content/test:test_support",
      "//testing/gmock",
      "//testing/gtest",
      "//ui/views",
    ]
  }
}
