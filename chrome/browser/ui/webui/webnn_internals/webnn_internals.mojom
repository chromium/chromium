module webnn_internals.mojom;

import "mojo/public/mojom/base/big_buffer.mojom";
import "services/webnn/public/mojom/webnn_service_introspection.mojom";

// Interface for the WebUI page to communicate with the browser.
interface PageHandler {
  // Sets whether to enable recording of WebNN graphs.
  [EnableIf=webnn_enable_graph_dump]
  SetGraphRecordEnabled(bool enabled);

  // Returns whether recording of WebNN graphs is currently enabled.
  [EnableIf=webnn_enable_graph_dump]
  IsGraphRecording() => (bool enabled);

  // Requests the details of existing contexts from the WebNN service.
  RequestExistingContextsDetails()
      => (array<webnn.mojom.WebNNContextIntrospectionDetails> contexts_info);

  // Requests the details of available execution providers on the device.
  RequestAvailableExecutionProvidersDetails()
      => (array<webnn.mojom.WebNNExecutionProviderDetails>
            available_execution_providers);

  // Force the creation of the ONNX Runtime environment for introspection.
  // This will create the ORT environment if it hasn't been created yet, force
  // installation of execution providers if applicable so WebNN Internals
  // can show them.
  [EnableIf=is_win]
  ForceOrtEnvironmentCreationForIntrospection()
    => (array<webnn.mojom.WebNNExecutionProviderDetails>
            available_execution_providers);
};

// Interface for the browser to communicate with the WebUI page.
interface Page {
  // Called when a graph is recorded. `json_data` contains the serialized graph
  // information.
  [EnableIf=webnn_enable_graph_dump]
  ExportGraphRecorded(mojo_base.mojom.BigBuffer json_data);

  // Called when the graph recording state changes.
  [EnableIf=webnn_enable_graph_dump]
  OnGraphRecordEnabledChanged(bool is_enabled);

  // Called when the WebNN contexts list is updated.
  OnUpdateExistingContextDetails(
      array<webnn.mojom.WebNNContextIntrospectionDetails> contexts_info);

  // Called when the available execution providers list from the platform is
  // updated.
  OnUpdateAvailableExecutionProvidersDetails(
      array<webnn.mojom.WebNNExecutionProviderDetails>
          available_execution_providers);
};

// Factory interface to create the handler.
interface PageHandlerFactory {
  // Creates the handler and connects the page.
  CreatePageHandler(pending_remote<Page> page,
                              pending_receiver<PageHandler> handler);
};
