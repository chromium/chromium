      "webapks_handler.h",
      "webapks_ui.h",
    ]
    public_deps = [
      "//chrome/common",
      "//content/public/browser",
    ]
    deps = [
      "//base",
      "//chrome/browser/android:shortcut_helper",
      "//chrome/browser/android/webapk:webapk_sources",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/resources/webapks:resources",
      "//third_party/blink/public/common",
      "//ui/android",
      "//ui/gfx",
      "//ui/webui",
    ]
