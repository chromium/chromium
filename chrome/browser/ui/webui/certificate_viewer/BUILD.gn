import("//chrome/common/features.gni")

if (enable_webui_certificate_viewer) {
  source_set("certificate_viewer") {
    sources = [
      "certificate_viewer_ui.cc",
      "certificate_viewer_ui.h",
      "certificate_viewer_webui.cc",
      "certificate_viewer_webui.h",
    ]

    public_deps = [ "//chrome/browser:browser_public_dependencies" ]

    deps = [
      "//base",
      "//chrome/browser:certificate_viewer",
      "//chrome/browser:primitives",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/resources/certificate_viewer:resources",
      "//chrome/browser/ui/webui",
      "//chrome/common",
      "//chrome/common/net",
      "//components/server_certificate_database",
      "//components/strings",
      "//content/public/browser",
      "//crypto",
      "//net",
      "//third_party/boringssl",
      "//ui/base",
      "//ui/gfx/geometry",
      "//ui/web_dialogs",
      "//ui/webui",
    ]
    if (use_nss_certs) {
      configs += [ "//build/config/linux/nss" ]
    }
  }
}
