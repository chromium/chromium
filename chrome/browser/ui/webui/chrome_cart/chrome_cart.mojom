module chrome_cart.mojom;

// Information needed to show cart for one site in Chrome Cart.
struct ChromeCartDataItem {
  // Merchant that this cart comes from.
  string merchant;
  // URL that directs to the cart page.
  string cart_url;
  // List of URLs for product image to show in the cart.
  array<string> image_urls;
};

// Browser-side handler for requests from JS.
interface ChromeCartHandler {
  // Returns the data for cart items in Chrome Cart.
  GetData() => (array<ChromeCartDataItem> data);
  // Returns whether Chrome Cart module should be showing.
  ShouldShowModule() => (bool shouldShow);
};
