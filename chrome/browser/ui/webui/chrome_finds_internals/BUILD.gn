import("//mojo/public/tools/bindings/mojom.gni")

static_library("chrome_finds_internals") {
  sources = [
    "chrome_finds_internals_ui.cc",
    "chrome_finds_internals_ui.h",
  ]

  public_deps = [
    ":mojo_bindings",
    "//base",
    "//chrome/browser/finds/core",
    "//chrome/browser/history",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/resources/chrome_finds_internals:resources",
    "//content/public/browser",
    "//ui/webui",
  ]

  deps = [
    "//chrome/browser/finds",
    "//chrome/browser/finds/core",
    "//chrome/browser/optimization_guide",
    "//chrome/common",
    "//chrome/common:constants",
    "//components/history/core/browser",
    "//components/keyed_service/core",
    "//mojo/public/cpp/bindings",
  ]
}

mojom("mojo_bindings") {
  sources = [ "chrome_finds_internals.mojom" ]
  webui_module_path = "/"
}
