import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojo_bindings") {
  sources = [ "logs.mojom" ]

  webui_module_path = "/"

  public_deps = [ "//mojo/public/mojom/base" ]
}

static_library("logging") {
  sources = [
    "logs_page_handler.cc",
    "logs_page_handler.h",
  ]

  deps = [
    ":mojo_bindings",
    "//base",
    "//components/omnibox/common",
    "//content/public/browser",
    "//mojo/public/cpp/bindings",
  ]
}
