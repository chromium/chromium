module omnibox.logging.mojom;

import "mojo/public/mojom/base/time.mojom";

// Lives in the browser process. A renderer uses this to link itself with
// a page handler.
interface PageHandlerFactory {
  // Create a page handler and link it to the UI.
  CreatePageHandler(
      pending_remote<Page> page,
      pending_receiver<PageHandler> handler);
};

// PageHandler for omnibox logs internals page.
interface PageHandler {
};

// Renderer-side handler for internals WebUI page to process the updates from
// the service.
interface Page {
  // Notifies the page of an omnibox log event.
  OnLogMessageAdded(mojo_base.mojom.Time event_time,
                    string tag,
                    string source_file,
                    uint32 source_line,
                    string message);
};
