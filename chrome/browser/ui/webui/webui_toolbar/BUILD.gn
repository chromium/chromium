assert(!is_android)

import("//build/config/chromeos/ui_mode.gni")
import("//mojo/public/tools/bindings/mojom.gni")
import("//ui/webui/resources/tools/build_webui.gni")

source_set("webui_toolbar") {
  sources = [
    "browser_controls_service.h",
    "toolbar_ui_service.h",
    "webui_toolbar_ui.h",
  ]
  public_deps = [
    "//chrome/browser/ui/webui/metrics_reporter",
    "//chrome/browser/ui/webui/top_chrome",
    "//chrome/common:constants",
    "//components/browser_apis/browser_controls:mojom",
    "//components/browser_apis/browser_controls:mojom_data_model",
    "//components/browser_apis/ui_controllers/toolbar:mojom",
    "//content/public/browser",
    "//ui/webui/resources/js/tracked_element:mojo_bindings",
    "//ui/webui/tracked_element",
  ]
  deps = [
    "adapters",
    "//chrome/browser:primitives",
    "//chrome/browser/ui/tabs:tab_model",
    "//ui/views",
  ]
}

source_set("impl") {
  sources = [
    "browser_controls_service.cc",
    "toolbar_ui_service.cc",
    "webui_toolbar_layout_css_helper.cc",
    "webui_toolbar_layout_css_helper.h",
    "webui_toolbar_ui.cc",
  ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
  deps = [
    ":webui_toolbar",
    "adapters",
    "adapters:impl",
    "utils",
    "//chrome/browser/resources/webui_toolbar:resources_grit",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui:layout_constants",
    "//chrome/browser/ui:ui_features",
    "//chrome/browser/ui/interaction",
    "//chrome/browser/ui/webui:webui_util",
  ]
}

source_set("test_support") {
  testonly = true
  sources = [
    "webui_toolbar_test_utils.cc",
    "webui_toolbar_test_utils.h",
  ]
  deps = [
    ":webui_toolbar",
    "//chrome/browser:primitives",
    "//testing/gmock",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "browser_controls_service_unittest.cc",
    "toolbar_ui_service_unittest.cc",
    "webui_toolbar_layout_css_helper_unittest.cc",
    "webui_toolbar_ui_unittest.cc",
  ]

  deps = [
    ":impl",
    ":test_support",
    ":webui_toolbar",
    "adapters",
    "adapters:impl",
    "testing",
    "//base",
    "//base/test:test_support",
    "//chrome/browser",
    "//chrome/browser/ui/webui:webui_util",
    "//chrome/browser/ui/webui/metrics_reporter:test_support",
    "//chrome/test:test_support",
    "//components/browser_apis/browser_controls:mojom",
    "//components/browser_apis/browser_controls:mojom_data_model",
    "//components/browser_apis/ui_controllers/toolbar:mojom",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/views",
    "//url",
  ]
}

source_set("browser_tests") {
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  testonly = true
  sources = [ "webui_toolbar_ui_browsertest.cc" ]
  deps = [
    ":test_support",
    ":webui_toolbar",
    "adapters",
    "adapters:impl",
    "//base",
    "//base/test:test_support",
    "//chrome/browser/ui",
    "//chrome/browser/ui/webui:webui_util",
    "//chrome/test:test_support",
    "//testing/gtest",
  ]
}
