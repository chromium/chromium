module intro.mojom;

// Used by the WebUI page to bootstrap communication for the top level intro
// page.
interface IntroPageHandlerFactory {
  // Passes the IntroPage remote to the browser.
  CreateIntroPageHandler(pending_remote<IntroPage> page);
};

// WebUI-side handler for requests from the browser.
interface IntroPage {
  // Toggles animations on the WebUI side.
  ToggleAnimations(bool active);
};
