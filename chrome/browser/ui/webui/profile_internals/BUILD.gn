assert(!is_android)

source_set("profile_internals") {
  sources = [
    "profile_internals_handler.cc",
    "profile_internals_handler.h",
    "profile_internals_ui.cc",
    "profile_internals_ui.h",
  ]
  public_deps = [
    "//chrome/common",
    "//content/public/browser",
  ]
  deps = [
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/profiles:profile_manager",
    "//chrome/browser/profiles:profile_util",
    "//chrome/browser/profiles/keep_alive",
    "//chrome/browser/regional_capabilities",
    "//chrome/browser/resources/profile_internals:resources",
    "//chrome/browser/search_engines",
    "//chrome/browser/ui/profiles",
    "//components/country_codes",
    "//components/regional_capabilities",
    "//components/regional_capabilities:country_access_reason",
    "//components/search_engines",
    "//components/signin/public/identity_manager",
    "//components/variations/service",
    "//google_apis",
    "//skia",
    "//ui/webui",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "profile_internals_handler_unittest.cc" ]
  deps = [
    ":profile_internals",
    "//base/test:test_support",
    "//chrome/browser/search_engines",
    "//chrome/test:test_support",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
