import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojo_bindings") {
  sources = [ "report_unsafe_site.mojom" ]

  webui_module_path = "/"

  public_deps = [ "//mojo/public/mojom/base" ]
}

static_library("report_unsafe_site") {
  sources = [
    "report_unsafe_site_handler.cc",
    "report_unsafe_site_handler.h",
  ]

  deps = [
    ":mojo_bindings",
    "//chrome/browser/ui/webui/top_chrome",
    "//chrome/common",
    "//mojo/public/cpp/bindings",
  ]
}
