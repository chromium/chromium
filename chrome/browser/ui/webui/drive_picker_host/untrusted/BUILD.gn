import("//mojo/public/tools/bindings/mojom.gni")

assert(!is_android)

mojom("mojo_bindings") {
  sources = [ "drive_picker_host_untrusted.mojom" ]
  webui_module_path = "/"
}

source_set("untrusted") {
  sources = [
    "drive_picker_host_untrusted_ui.cc",
    "drive_picker_host_untrusted_ui.h",
  ]

  public_deps = [
    ":mojo_bindings",
    "//content/public/browser",
    "//ui/webui",
  ]

  deps = [
    "//chrome/browser/profiles:profile",
    "//chrome/browser/resources/drive_picker_host/untrusted:resources",
    "//chrome/common",
    "//components/omnibox/common",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "drive_picker_host_untrusted_ui_unittest.cc" ]

  deps = [
    ":untrusted",
    "//base/test:test_support",
    "//chrome/test:test_support",
    "//components/omnibox/common",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
