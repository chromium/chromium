import("//build/config/ui.gni")

assert(!is_android)

source_set("window_feature_controller") {
  public = [ "window_feature_controller.h" ]
  sources = [ "window_feature_controller.cc" ]

  public_deps = [
    "//base",
    "//chrome/browser/ui/browser_window",
    "//ui/base/unowned_user_data",
  ]

  deps = [
    "//chrome/browser/ui/fullscreen",
    "//chrome/browser/ui/web_applications",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "window_feature_controller_unittest.cc" ]
  deps = [
    ":window_feature_controller",
    "//base",
    "//base/test:test_support",
    "//chrome/browser/ui:test_support",
    "//chrome/browser/ui/fullscreen",
    "//chrome/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base/unowned_user_data",
  ]
}
