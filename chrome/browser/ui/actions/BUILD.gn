import("//ui/base/ui_features.gni")

assert(!is_ios, "Chromium/iOS shouldn't use anything in //chrome")

source_set("actions_headers") {
  sources = [ "chrome_action_id.h" ]

  public_deps = [
    "//chrome/app:command_ids",
    "//ui/actions:actions_headers",
  ]
}

source_set("actions") {
  sources = [
    "chrome_actions.cc",
    "chrome_actions.h",
  ]

  deps = [
    ":actions_headers",
    "//ui/actions",
  ]
}

source_set("actions_util") {
  public = [ "actions_util.h" ]
  sources = [ "actions_util.cc" ]

  public_deps = [ "//base" ]

  deps = [ "//ui/gfx" ]
}

if (!is_android) {
  executable("dump_actions") {
    testonly = true

    sources = [ "tools/dump_actions.cc" ]

    deps = [
      ":actions_headers",
      "//ui/actions:actions_headers",
    ]
  }
}

source_set("unit_tests") {
  testonly = true

  sources = [ "chrome_actions_unittest.cc" ]

  deps = [
    ":actions",
    ":actions_headers",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
