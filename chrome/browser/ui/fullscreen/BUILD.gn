import("//build/config/ui.gni")

assert(!is_android)

source_set("fullscreen") {
  public = [ "browser_window_fullscreen_controller.h" ]

  public_deps = [
    "//base",
    "//ui/base/unowned_user_data",
  ]
}

source_set("impl") {
  sources = [ "browser_window_fullscreen_controller.cc" ]

  public_deps = [
    ":fullscreen",
    "//chrome/browser:browser_public_dependencies",
  ]

  deps = [
    "//base",
    "//chrome/browser/ui:browser_element_identifiers",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/interaction",
    "//chrome/browser/ui/views/frame:immersive_mode_controller",
    "//ui/views",
  ]
}
