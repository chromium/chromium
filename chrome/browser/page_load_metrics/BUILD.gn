import("//build/config/android/rules.gni")

android_library("java") {
  sources = [ "java/src/org/chromium/chrome/browser/page_load_metrics/PageLoadMetrics.java" ]

  deps = [
    "//base:base_java",
    "//base:jni_java",
    "//content/public/android:content_java",
