    "//url",
  ]

  deps = [
    ":impl",
    "//chrome/browser",
    "//testing/gtest",
    "//ui/base",
  ]

  if (!is_android) {
    public += [
      "render_view_context_menu_browsertest_util.h",
      "render_view_context_menu_test_util.h",
    ]
    sources += [
      "render_view_context_menu_browsertest_util.cc",
