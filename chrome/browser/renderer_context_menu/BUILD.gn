source_set("renderer_context_menu") {
  if (!is_android) {
    # TODO(crbug.com/353332589): Remove this circular dependency when
    # chrome/browser/ui gets componentized further.
    allow_circular_includes_from = [ "//chrome/browser/ui" ]

    if (is_mac) {
      allow_circular_includes_from += [ "//chrome/browser/ui/cocoa" ]
    }

    public = [
      "accessibility_labels_bubble_model.h",
      "render_view_context_menu.h",
      "spelling_bubble_model.h",
    ]

    public_deps = [
      "//base",
      "//chrome/app:command_ids",
      "//chrome/browser/ui",
      "//chrome/browser/ui/autofill",
      "//chrome/common:mojo_bindings",
      "//components/compose:buildflags",
      "//components/custom_handlers",
      "//components/lens:buildflags",
      "//components/renderer_context_menu",
      "//components/supervised_user/core/browser",
      "//content/public/browser",
      "//content/public/common:buildflags",
      "//extensions/buildflags",
      "//mojo/public/cpp/bindings",
      "//printing/buildflags",
      "//ui/base",
      "//ui/base/interaction",
      "//ui/gfx",
      "//ui/menus",
      "//url",
    ]

    if (is_mac) {
      public_deps += [ "//chrome/browser/ui/cocoa" ]
    }

    if (is_chromeos) {
      public_deps += [ "//chromeos/ui/clipboard_history" ]
    }

    if (enable_extensions) {
      public_deps += [ "//chrome/browser/extensions" ]
    }
  }
}

