<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    tools:ignore="UseCompoundDrawables">

    <ImageView
        android:layout_width="@dimen/tab_bottom_sheet_resizing_view_icon_size"
        android:layout_height="@dimen/tab_bottom_sheet_resizing_view_icon_size"
        android:src="@drawable/ic_spark_24dp"
        android:tint="@macro/default_icon_color"
        android:importantForAccessibility="no" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/tab_bottom_sheet_resizing_view_text_margin_top"
        android:gravity="center"
        android:text="@string/tab_bottom_sheet_resizing_view_text"
        android:textAppearance="@style/TextAppearance.TextMedium.Secondary" />
</LinearLayout>