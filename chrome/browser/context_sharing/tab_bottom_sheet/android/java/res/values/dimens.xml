<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tab Bottom Sheet -->
    <dimen name="tab_bottom_sheet_resizing_view_icon_size">32dp</dimen>
    <dimen name="tab_bottom_sheet_resizing_view_text_margin_top">20dp</dimen>
    <dimen name="tab_bottom_sheet_placeholder_padding">24dp</dimen>
    <dimen name="tab_bottom_sheet_placeholder_drawable_padding">16dp</dimen>

    <!-- The total visible height requested by TabBottomSheet at peek state, counting the
         contents of the peek view plus the space consumed by the drag handle bar frame.
         (12dp handle area + 48dp control min size + 4dp bottom padding) -->
    <dimen name="tab_bottom_sheet_peek_height_total">64dp</dimen>
    <dimen name="tab_bottom_sheet_handle_margin">8dp</dimen>
    <dimen name="tab_bottom_sheet_web_ui_top_margin">18dp</dimen>
    <!-- Cumulative top overlay padding required to avoid clipping visual headers beneath
         the floating drag handle. 8dp top margin + 4dp intrinsic handle) -->
    <dimen name="tab_bottom_sheet_handle_area_height">12dp</dimen>
    <dimen name="tab_bottom_sheet_peek_container_bottom_padding">4dp</dimen>
    <dimen name="tab_bottom_sheet_peek_corner_radius">@dimen/bottom_sheet_corner_radius</dimen>

    <!-- Tab Bottom Sheet Peek View Dimensions -->
    <dimen name="tab_bottom_sheet_peek_button_margin_end">4dp</dimen>
    <dimen name="tab_bottom_sheet_peek_padding_start">12dp</dimen>
    <dimen name="tab_bottom_sheet_peek_padding_end">3dp</dimen>
    <dimen name="tab_bottom_sheet_peek_padding_top">3dp</dimen>
    <dimen name="tab_bottom_sheet_peek_icon_size">24dp</dimen>
    <dimen name="tab_bottom_sheet_peek_icon_margin_start">6dp</dimen>
    <dimen name="tab_bottom_sheet_peek_icon_margin_end">12dp</dimen>
    <dimen name="tab_bottom_sheet_peek_text_container_margin_end">8dp</dimen>
    <dimen name="tab_bottom_sheet_peek_description_margin_top">-2dp</dimen>
</resources>
