<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tab Bottom Sheet -->
    <dimen name="tab_bottom_sheet_resizing_view_icon_size">32dp</dimen>
    <dimen name="tab_bottom_sheet_resizing_view_text_margin_top">20dp</dimen>


    <!-- The total visible height requested by TabBottomSheet at peek state, counting the
         contents of the peek view plus the space consumed by the drag handle bar frame.
         (12dp handle area + 48dp control min size + 4dp bottom padding) -->
    <dimen name="tab_bottom_sheet_peek_height_total">64dp</dimen>
    <dimen name="tab_bottom_sheet_handle_margin">8dp</dimen>
    <dimen name="tab_bottom_sheet_web_ui_top_margin">18dp</dimen>
    <!-- Cumulative top overlay padding required to avoid clipping visual headers beneath
         the floating drag handle. 8dp top margin + 4dp intrinsic handle) -->
    <dimen name="tab_bottom_sheet_handle_area_height">12dp</dimen>
    <dimen name="tab_bottom_sheet_peek_container_bottom_padding">4dp</dimen>
</resources>
