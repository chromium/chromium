import("//rlz/buildflags/buildflags.gni")

assert(enable_rlz)

source_set("rlz") {
  public = [
    "chrome_rlz_tracker_delegate.h",
    "chrome_rlz_tracker_web_contents_observer.h",
  ]

  sources = [
    "chrome_rlz_tracker_delegate.cc",
    "chrome_rlz_tracker_web_contents_observer.cc",
  ]

  public_deps = [
    "//base",
    "//components/omnibox/browser",
    "//components/rlz",
    "//content/public/browser",
  ]

  deps = [
    "//chrome/browser:browser_process",
    "//chrome/browser/google",
    "//chrome/browser/prefs:util",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/search_engines",
    "//chrome/browser/ui/startup",
    "//chrome/common:constants",
    "//chrome/common:non_code_constants",
    "//components/google/core/common",
    "//components/pref_registry",
    "//components/prefs",
    "//components/search_engines",
    "//content/public/common",
    "//services/network/public/cpp",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "chrome_rlz_tracker_delegate_unittest.cc",
    "chrome_rlz_tracker_web_contents_observer_unittest.cc",
  ]

  deps = [
    ":rlz",
    "//base/test:test_support",
    "//chrome/test:test_support",
    "//components/rlz:test_support",
    "//rlz:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
