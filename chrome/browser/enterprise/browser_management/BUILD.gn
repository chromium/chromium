import("//build/config/chromeos/ui_mode.gni")

source_set("management_identity") {
  public = [ "management_identity.h" ]
  public_deps = [ "//chrome/browser/profiles" ]
}

source_set("management_identity_impl") {
  sources = [ "management_identity.cc" ]

  public_deps = [ "//chrome/browser:browser_public_dependencies" ]

  deps = [
    ":management_identity",
    "//chrome/browser:browser_process",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/profiles:profile_util",
    "//chrome/browser/ui:ui_features",
    "//chrome/common:constants",
    "//components/policy/core/browser",
    "//components/policy/core/common",
    "//components/policy/core/common:common_constants",
    "//components/prefs",
    "//components/signin/public/identity_manager",
  ]

  if (is_chromeos_ash) {
    deps += [ "//chrome/browser/ash/policy/core" ]
  }
}
