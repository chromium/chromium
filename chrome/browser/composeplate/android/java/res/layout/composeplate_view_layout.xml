<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/composeplate_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/voice_search_button"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="@dimen/composeplate_view_height"
        android:paddingTop="@dimen/composeplate_view_padding_top"
        android:paddingBottom="@dimen/composeplate_view_padding_top"
        android:layout_marginEnd="@dimen/composeplate_view_button_margin_end"
        android:src="@drawable/ic_mic_white_24dp"
        android:background="@drawable/home_surface_ui_background"
        android:contentDescription="@string/accessibility_toolbar_btn_mic" />

    <ImageView
        android:id="@+id/lens_camera_button"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="@dimen/composeplate_view_height"
        android:paddingTop="@dimen/composeplate_view_padding_top"
        android:paddingBottom="@dimen/composeplate_view_padding_top"
        android:layout_marginEnd="@dimen/composeplate_view_button_margin_end"
        android:src="@drawable/lens_camera_icon"
        android:background="@drawable/home_surface_ui_background"
        android:contentDescription="@string/accessibility_btn_lens_camera" />

    <ImageView
        android:id="@+id/incognito_button"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="@dimen/composeplate_view_height"
        android:paddingTop="@dimen/composeplate_view_padding_top"
        android:paddingBottom="@dimen/composeplate_view_padding_top"
        android:src="@drawable/incognito_24"
        android:background="@drawable/home_surface_ui_background"
        android:contentDescription="@string/new_incognito_tab_title" />

</LinearLayout>