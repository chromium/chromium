import("//chrome/common/features.gni")
import("//mojo/public/tools/bindings/mojom.gni")

if (is_android) {
  import("//build/config/android/rules.gni")

  # Target to generate Java enums from C++ headers
  java_cpp_enum("enums_java") {
    sources = [
      "states/handoff_button_state.h",
      "states/tab_indicator_state.h",
    ]
  }
}

source_set("states") {
  public = [
    "states/actor_overlay_state.h",
    "states/actor_task_nudge_state.h",
    "states/handoff_button_state.h",
    "states/tab_indicator_state.h",
  ]

  public_deps = [ "//chrome/browser/actor:types" ]
}

source_set("dom_node_geometry_types") {
  sources = [ "dom_node_geometry_types.h" ]
}

source_set("metrics") {
  sources = [
    "actor_ui_metrics.cc",
    "actor_ui_metrics.h",
    "actor_ui_metrics_types.h",
  ]

  public_deps = [
    ":dom_node_geometry_types",
    ":states",
    "//base",
  ]
}

source_set("dom_node_geometry") {
  sources = [
    "dom_node_geometry.cc",
    "dom_node_geometry.h",
  ]
  deps = [
    ":dom_node_geometry_types",
    ":metrics",
    "//chrome/browser/actor:types",
    "//chrome/common:chrome_features",
    "//components/optimization_guide/proto:optimization_guide_proto",
  ]
}

mojom("mojo_bindings") {
  disable_variants = true
  public_deps = [ "//mojo/public/mojom/base" ]

  deps = [
    "//skia/public/mojom",
    "//ui/gfx/geometry/mojom",
  ]

  sources = [ "actor_overlay.mojom" ]
  webui_module_path = "/"
}

if (!is_android) {
  source_set("actor_overlay_web_view") {
    sources = [
      "actor_overlay_web_view.cc",
      "actor_overlay_web_view.h",
    ]
    deps = [
      ":actor_overlay",
      "//base",
      "//chrome/browser/profiles",
      "//chrome/browser/ui/browser_window",
      "//chrome/browser/ui/webui",
      "//chrome/browser/ui/webui:webui_util",
      "//chrome/common:chrome_features",
      "//components/tabs:public",
      "//content/public/browser",
      "//ui/views",
      "//ui/views/controls/webview",
    ]
  }
}

source_set("actor_overlay") {
  sources = [
    "actor_overlay_handler.cc",
    "actor_overlay_handler.h",
    "actor_overlay_ui.cc",
    "actor_overlay_ui.h",
  ]
  deps = [
    ":mojo_bindings",
    ":ui",
    "//base",
    "//chrome/browser/actor/resources:grit_grit",
    "//chrome/browser/profiles",
    "//chrome/browser/resources/actor_overlay:resources",
    "//chrome/browser/ui/color:color_headers",
    "//chrome/browser/ui/tabs:tabs_public",
    "//chrome/browser/ui/webui",
    "//chrome/browser/ui/webui:webui_util",
    "//chrome/common",
    "//components/tabs:public",
    "//content/public/browser",
    "//mojo/public/cpp/bindings",
    "//skia",
    "//ui/color",
    "//ui/native_theme",
    "//ui/webui",
  ]

  if (!is_android) {
    deps += [ "//chrome/browser/themes" ]
  }
}

if (!skip_android_unmigrated_actor_files) {
  source_set("window_controller_impl") {
    sources = [ "actor_ui_window_controller.cc" ]
    deps = [
      ":actor_overlay",
      ":actor_overlay_web_view",
      ":metrics",
      ":ui",
      "//chrome/browser/actor",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/ui",
      "//chrome/browser/ui/browser_window",
      "//chrome/browser/ui/tabs:tab_strip",
      "//chrome/common",
      "//ui/views",
      "//ui/views/controls/webview",
    ]
  }

  source_set("actor_ui_interactive_base") {
    sources = [
      "actor_ui_interactive_browser_test.cc",
      "actor_ui_interactive_browser_test.h",
    ]
    testonly = true
    deps = [
      "//base/test:test_support",
      "//chrome/browser/actor",
      "//chrome/browser/actor:test_support",
      "//chrome/browser/actor:types",
      "//chrome/test:test_support_ui",
    ]
  }
}

source_set("test_support") {
  sources = [
    "test_support/fake_actor_overlay_page.cc",
    "test_support/fake_actor_overlay_page.h",
    "test_support/mock_actor_ui_state_manager.cc",
    "test_support/mock_actor_ui_state_manager.h",
    "test_support/mock_actor_ui_tab_controller.cc",
    "test_support/mock_actor_ui_tab_controller.h",
    "test_support/mock_event_dispatcher.cc",
    "test_support/mock_event_dispatcher.h",
    "test_support/mock_handoff_button_controller.cc",
    "test_support/mock_handoff_button_controller.h",
  ]
  testonly = true
  public_deps = [
    "//base",
    "//chrome/browser/ui:test_support",
    "//components/tabs:test_support",
    "//testing/gmock",
  ]
  deps = [
    ":event_dispatcher",
    ":ui",
    "//chrome/browser/actor",
  ]

  # TODO(crbug.com/40031409): Fix code that adds exit-time destructors and
  # enable the diagnostic by removing this line.
  configs += [ "//build/config/compiler:no_exit_time_destructors" ]
}

