<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/actor_ui_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/tab_thumbnail"
        app:layout_constraintBottom_toBottomOf="@id/tab_thumbnail"
        app:layout_constraintStart_toStartOf="@id/tab_thumbnail"
        app:layout_constraintEnd_toEndOf="@id/tab_thumbnail">

       <ImageView
            android:id="@+id/actor_thumbnail_overlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            android:background="@drawable/actor_thumbnail_overlay_outline"
            android:clipToOutline="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:importantForAccessibility="no" />
        <FrameLayout
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/actor_gts_tab_indicator_background"
            android:elevation="2dp"
            android:clipToOutline="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_spark_blue_16dp"
                android:importantForAccessibility="no" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>