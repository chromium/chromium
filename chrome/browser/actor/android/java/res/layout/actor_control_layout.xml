<org.chromium.chrome.browser.actor.ui.ActorControlView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/actor_control_padding_start"
    android:paddingEnd="@dimen/actor_control_padding_end"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/actor_icon"
        android:layout_width="@dimen/actor_control_icon_size"
        android:layout_height="@dimen/actor_control_icon_size"
        android:layout_marginStart="@dimen/actor_control_icon_margin_start"
        android:layout_marginEnd="@dimen/actor_control_icon_margin_end"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_spark_24dp"
        app:tint="@color/default_icon_color_tint_list"
        android:scaleType="centerInside"
        android:importantForAccessibility="no"/>

    <org.chromium.ui.widget.ChromeImageButton
        android:id="@+id/actor_control_close_button"
        android:layout_width="?attr/minInteractTargetSize"
        android:layout_height="?attr/minInteractTargetSize"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/material_ic_close_24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/close"
        app:tint="@color/default_icon_color_tint_list" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actor_control_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="?attr/minInteractTargetSize"
        android:minWidth="?attr/minInteractTargetSize"
        android:gravity="center"
        android:layout_toStartOf="@id/actor_control_close_button"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/actor_control_button_margin_end"
        android:textAppearance="@style/TextAppearance.TextSmall.Secondary.Baseline.Light"
        android:visibility="gone"
        app:tint="@color/default_icon_color_tint_list"
        app:iconPadding="0dp"
        app:iconGravity="textStart"
        app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.IconButton.Small"
        style="?attr/materialIconButtonFilledStyle" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toEndOf="@id/actor_icon"
        android:layout_toStartOf="@id/actor_control_button"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/actor_control_text_margin_end">

        <TextView
            android:id="@+id/actor_control_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TextMediumThick.Primary"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/actor_control_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/actor_control_description_margin_top"
            android:textAppearance="@style/TextAppearance.TextSmall.Secondary"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>
</org.chromium.chrome.browser.actor.ui.ActorControlView>
