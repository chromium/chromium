<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. TOP GLOW (Fades Top -> Bottom) -->
    <item android:height="24dp" android:gravity="top">
        <shape android:shape="rectangle">
            <!-- Angle 270 is Top-to-Bottom -->
            <gradient
                android:angle="270"
                android:startColor="@color/baseline_primary_60"
                android:centerColor="@android:color/transparent"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- 2. BOTTOM GLOW (Fades Bottom -> Top) -->
    <item android:height="24dp" android:gravity="bottom">
        <shape android:shape="rectangle">
            <!-- Angle 90 is Bottom-to-Top -->
            <gradient
                android:angle="90"
                android:startColor="@color/baseline_primary_60"
                android:centerColor="@android:color/transparent"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- 3. LEFT GLOW (Fades Left -> Right) -->
    <item android:width="24dp" android:gravity="left">
        <shape android:shape="rectangle">
            <!-- Angle 0 is Left-to-Right -->
            <gradient
                android:angle="0"
                android:startColor="@color/baseline_primary_60"
                android:centerColor="@android:color/transparent"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- 4. RIGHT GLOW (Fades Right -> Left) -->
    <item android:width="24dp" android:gravity="right">
        <shape android:shape="rectangle">
            <!-- Angle 180 is Right-to-Left -->
            <gradient
                android:angle="180"
                android:startColor="@color/baseline_primary_60"
                android:centerColor="@android:color/transparent"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
