source_set("glic_experimental_triggering") {
  public = [ "glic_experimental_triggering_message_handler.h" ]

  public_deps = [
    "//base",
    "//chrome/browser/glic:mojo_bindings",
    "//components/sharing_message",
    "//components/sharing_message/proto",
    "//mojo/public/cpp/bindings",
  ]
}

source_set("impl") {
  sources = [ "glic_experimental_triggering_message_handler.cc" ]

  deps = [
    ":glic_experimental_triggering",
    "//chrome/browser/actor",
    "//chrome/browser/glic",
    "//chrome/browser/glic:impl",
    "//chrome/browser/profiles:profile",
    "//chrome/common:chrome_features",
  ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "glic_experimental_triggering_message_handler_browsertest.cc" ]
  deps = [
    ":glic_experimental_triggering",
    ":impl",
    "//base/test:test_support",
    "//chrome/browser/glic",
    "//chrome/browser/glic/test_support",
    "//chrome/test:test_support",
    "//components/sharing_message:test_support",
    "//components/sharing_message/proto",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
