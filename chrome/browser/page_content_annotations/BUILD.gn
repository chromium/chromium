    deps += [ "//chrome/browser/ash/profiles" ]
  }
}

source_set("extraction_service") {
  public = [ "page_content_extraction_service_factory.h" ]
  sources = [ "page_content_extraction_service_factory.cc" ]
  public_deps = [
    "//base",
