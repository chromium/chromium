    "//chrome/browser/app_mode",
    "//chrome/browser/feature_engagement",
    "//chrome/browser/profiles:profile_manager",
    "//chrome/browser/profiles:profile_util",
    "//components/page_content_annotations/content",
  ]
  if (is_android) {
    sources += [
      "android/page_content_extraction_service_android.cc",
      "android/page_content_extraction_service_android.h",
      "android/page_content_extraction_service_factory_android.cc",
      "android/page_content_extraction_tab_model_observer_android.cc",
      "android/page_content_extraction_tab_model_observer_android.h",
