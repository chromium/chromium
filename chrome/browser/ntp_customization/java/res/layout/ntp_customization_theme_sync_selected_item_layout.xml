<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="UnusedResources"
    android:layout_width="@dimen/ntp_customization_chrome_colors_selector_size"
    android:layout_height="@dimen/ntp_customization_chrome_colors_selector_size"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_view"
    android:background="@drawable/chrome_color_icon_list_selector"
    android:layout_margin="@dimen/ntp_customization_edit_icon_padding">

    <!-- The Main Large Circle -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/background_view"
        android:layout_width="@dimen/ntp_customization_theme_collections_icon_size"
        android:layout_height="@dimen/ntp_customization_theme_collections_icon_size"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ThemeSyncBadgeImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- The Floating Small Circle (Badge) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/platform_badge"
        android:layout_width="@dimen/ntp_customization_theme_sync_badge_icon_size"
        android:layout_height="@dimen/ntp_customization_theme_sync_badge_icon_size"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ThemeSyncBadgeImage"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>