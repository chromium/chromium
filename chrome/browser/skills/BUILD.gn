    ":ui",
    "//chrome/browser/glic",
    "//chrome/browser/glic/test_support",
    "//chrome/browser/ui",
    "//chrome/test:test_support",
    "//components/skills:features",
    "//components/skills/public",
    "//components/skills/public:mojo_bindings",
