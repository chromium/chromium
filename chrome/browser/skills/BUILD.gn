    "//components/skills/public",
    "//components/skills/public:mojo_bindings",
    "//services/service_manager/public/cpp",
    "//ui/base/unowned_user_data",
  ]
  if (!is_android) {
    deps += [
      "//chrome/browser/ui/browser_window",
