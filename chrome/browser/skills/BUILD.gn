    sources += [ "skills_ui_window_controller.h" ]
    deps += [
      "//chrome/browser/ui/toasts",
      "//chrome/browser/ui/toasts/api:toasts",
    ]
  }
}

source_set("ui") {
  sources = [
    "skills_dialog_launcher.cc",
    "skills_update_observer.cc",
    "skills_update_observer.h",
  ]
  if (!is_android) {
    sources += [
      "skills_ui_tab_controller.cc",
