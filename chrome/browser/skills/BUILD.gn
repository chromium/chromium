assert(is_win || is_mac || is_linux || is_chromeos)

source_set("skills") {
  sources = [
    "skills_service_factory.cc",
    "skills_service_factory.h",
    "skills_ui_controller.cc",
    "skills_ui_controller.h",
  ]

  public_deps = [
    "//base",
    "//components/keyed_service/content",
  ]

  deps = [
    "//chrome/browser/profiles:profile",
    "//chrome/browser/sync:factories",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/toasts",
    "//chrome/browser/ui/toasts/api:toasts",
    "//chrome/common:channel_info",
    "//components/keyed_service/core",
    "//components/skills:features",
    "//components/skills/internal",
    "//components/skills/public",
    "//components/sync/model",
    "//ui/base/unowned_user_data",
  ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [ "skills_ui_controller_browsertest.cc" ]
  deps = [
    ":skills",
    "//chrome/browser/ui",
    "//chrome/browser/ui/toasts",
    "//chrome/browser/ui/toasts/api:toasts",
    "//chrome/test:test_support",
  ]
}
