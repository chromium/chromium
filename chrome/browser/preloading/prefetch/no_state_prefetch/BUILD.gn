import("//extensions/buildflags/buildflags.gni")

assert(is_win || is_mac || is_linux || is_chromeos || is_android)

source_set("no_state_prefetch") {
  sources = [
    "chrome_no_state_prefetch_contents_delegate.h",
    "chrome_no_state_prefetch_manager_delegate.h",
    "chrome_no_state_prefetch_processor_impl_delegate.h",
    "no_state_prefetch_link_manager_factory.h",
    "no_state_prefetch_manager_factory.h",
    "no_state_prefetch_tab_helper.h",
  ]
  public_deps = [
    "//base",
    "//chrome/browser/profiles:profile",
    "//components/no_state_prefetch/browser",
    "//components/no_state_prefetch/common",
    "//content/public/browser",
    "//third_party/blink/public/common:headers",
  ]
}

source_set("impl") {
  sources = [
    "chrome_no_state_prefetch_contents_delegate.cc",
    "chrome_no_state_prefetch_manager_delegate.cc",
    "chrome_no_state_prefetch_processor_impl_delegate.cc",
    "no_state_prefetch_link_manager_factory.cc",
    "no_state_prefetch_manager_factory.cc",
    "no_state_prefetch_tab_helper.cc",
  ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
  deps = [
    ":no_state_prefetch",
    "//base",
    "//chrome/browser/content_settings:content_settings_factory",
    "//chrome/browser/history",
    "//chrome/browser/predictors",
    "//chrome/browser/preloading:prefs",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/sync:factories",
    "//chrome/browser/task_manager",
    "//chrome/browser/ui",
    "//chrome/common",
    "//components/content_settings/core/browser:cookie_settings",
    "//components/no_state_prefetch/browser",
    "//content/public/browser",
    "//extensions/buildflags",
  ]
  if (enable_extensions) {
    deps += [ "//extensions/browser" ]
  }
}

if (!is_android) {
  source_set("test_support") {
    testonly = true
    sources = [
      "no_state_prefetch_test_utils.cc",
      "no_state_prefetch_test_utils.h",
    ]
    public_deps = [
      ":no_state_prefetch",
      "//chrome/browser/safe_browsing:test_support",
      "//chrome/test:test_support_ui",
      "//components/no_state_prefetch/browser",
      "//components/safe_browsing/core/browser/db:test_database_manager",

      # TODO(crbug.com/353332589): Revisit this when external_protocol_handler.h
      # gets modularized.
      "//chrome/browser",
    ]
    deps = [
      "//base",
      "//chrome/browser/ui",
      "//chrome/common",
      "//net:test_support",
      "//testing/gtest",
    ]
  }
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "no_state_prefetch_unit_test_utils.cc",
    "no_state_prefetch_unit_test_utils.h",
    "no_state_prefetch_unittest.cc",
  ]
  deps = [
    ":no_state_prefetch",
    "//base",
    "//base/test:test_support",
    "//chrome/browser/preloading:prefs",
    "//chrome/common",
    "//chrome/test:test_support",
    "//components/content_settings/core/browser:cookie_settings",
    "//components/content_settings/core/common",
    "//components/no_state_prefetch/browser",
    "//components/no_state_prefetch/common",
    "//mojo/public/cpp/bindings",
    "//net",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/gfx/geometry",
    "//url",
  ]
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "prerender_nostate_prefetch_browsertest.cc" ]
    deps = [
      ":test_support",
      "//base/test:test_support",
      "//chrome/browser/browsing_data:constants",
      "//chrome/browser/content_settings:content_settings_factory",
      "//chrome/browser/devtools",
      "//chrome/browser/devtools:test_support",
      "//chrome/browser/history",
      "//chrome/browser/preloading",
      "//chrome/browser/preloading:prefs",
      "//chrome/browser/preloading:test_support",
      "//chrome/browser/preloading/prefetch/no_state_prefetch",
      "//chrome/test:test_support",
      "//components/embedder_support",
      "//components/no_state_prefetch/browser",
      "//components/privacy_sandbox:features",
      "//components/security_state/content",
      "//components/ukm:test_support",

      # TODO(crbug.com/408146612): Revisit this when preloading_features.h
      # moves into this file.
      "//chrome/browser",
    ]

    # TODO(crbug.com/40031409): Fix code that adds exit-time destructors and
    # enable the diagnostic by removing this line.
    configs += [ "//build/config/compiler:no_exit_time_destructors" ]
  }
}
