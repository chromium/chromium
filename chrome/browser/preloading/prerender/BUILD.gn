source_set("test_support") {
  testonly = true

  sources = [
    "search_prewarm_progress_test_utils.cc",
    "search_prewarm_progress_test_utils.h",
  ]

  deps = [
    "//base",
    "//chrome/browser",
    "//chrome/browser/preloading",
  ]
}

source_set("browser_tests") {
  testonly = true

  sources = [
    "dse_prewarm_navigation_throttle_browsertest.cc",
    "omnibox_prerender_browsertest.cc",
    "prerender_browsertest.cc",
  ]

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  deps = [
    ":test_support",
    "//base/test:test_support",
    "//chrome/browser/preloading",
    "//chrome/browser/preloading:prefs",
    "//chrome/browser/preloading:test_support",
    "//chrome/browser/preloading/prefetch/search_prefetch:field_trial_settings",
    "//chrome/browser/search_engines",
    "//chrome/test:test_support",
    "//components/page_load_metrics/browser",
    "//third_party/blink/public/common:preloading_headers",
  ]

  data = [ "//chrome/test/data/" ]
}

source_set("unit_tests") {
  testonly = true

  sources = [
    "prerender_manager_unittest.cc",
    "search_prewarm_progress_service_unittest.cc",
  ]

  deps = [
    ":test_support",
    "//chrome/browser/preloading",
    "//chrome/browser/preloading:test_support",
    "//chrome/test:test_support",
    "//content/test:test_support",
  ]
}
