source_set("site_cookie_provider") {
  sources = [
    "site_cookie_provider_service_factory.cc",
    "site_cookie_provider_service_factory.h",
  ]

  public_deps = [
    "//base",
    "//chrome/browser/profiles:profile",
  ]

  deps = [
    "//chrome/browser/signin",
    "//components/keyed_service/content",
