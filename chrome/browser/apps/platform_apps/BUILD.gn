import("//extensions/buildflags/buildflags.gni")
import("//printing/buildflags/buildflags.gni")

assert(enable_extensions)

source_set("platform_apps") {
  sources = [
    "app_load_service.cc",
    "app_load_service.h",
    "app_load_service_factory.cc",
    "app_load_service_factory.h",
    "app_termination_observer.cc",
    "app_termination_observer.h",
    "app_termination_observer_factory.cc",
    "app_termination_observer_factory.h",
    "app_window_registry_util.cc",
    "app_window_registry_util.h",
    "audio_focus_web_contents_observer.cc",
    "audio_focus_web_contents_observer.h",
    "browser_context_keyed_service_factories.cc",
    "browser_context_keyed_service_factories.h",
    "chrome_apps_browser_api_provider.cc",
    "chrome_apps_browser_api_provider.h",
    "install_chrome_app.cc",
    "install_chrome_app.h",
    "platform_app_launch.cc",
    "platform_app_launch.h",
    "platform_app_navigation_redirector.cc",
    "platform_app_navigation_redirector.h",
    "shortcut_manager.cc",
    "shortcut_manager.h",
    "shortcut_manager_factory.cc",
    "shortcut_manager_factory.h",
  ]

  if (is_mac) {
    sources += [
      "extension_app_shim_manager_delegate_mac.cc",
      "extension_app_shim_manager_delegate_mac.h",
    ]
  }

  configs += [ "//build/config/compiler:wexit_time_destructors" ]

  public_deps = [
    "//apps",
    "//chrome/browser:browser_public_dependencies",
    "//chrome/browser/apps/platform_apps/api:api_registration",
    "//chrome/browser/profiles:profile_util",
    "//chrome/common/apps/platform_apps/api",
  ]

  deps = [
    "//chrome/app:command_ids",
    "//chrome/browser:browser_process",
    "//chrome/browser:shell_integration",
    "//chrome/browser/apps/app_service",
    "//chrome/browser/extensions",
    "//chrome/browser/lifetime:termination_notification",
    "//chrome/browser/media/router/discovery",
    "//chrome/browser/preloading/prefetch/no_state_prefetch",
    "//chrome/browser/profiles",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/profiles:profile_manager",
    "//chrome/browser/ui/extensions",
    "//chrome/browser/web_applications",
    "//chrome/browser/web_applications/extensions",
    "//chrome/common",
    "//components/crx_file",
    "//components/keyed_service/content",
    "//components/navigation_interception",
    "//components/no_state_prefetch/browser",
    "//components/pref_registry",
    "//components/services/app_service",
    "//components/sharing_message/proto",
    "//content/public/browser",
    "//content/public/common",
    "//extensions/browser",
    "//extensions/browser:webstore_installer",
    "//extensions/common",
    "//extensions/common/api",
    "//net",
    "//services/preferences/public/cpp",
    "//ui/gfx",
  ]

  allow_circular_includes_from = [ "//chrome/browser/extensions" ]

  if (is_mac) {
    deps += [
      "//chrome/browser/apps/app_shim",
      "//chrome/browser/profiles",
      "//chrome/browser/ui/extensions:extension_enable_flow_delegate",
    ]
  }

  if (is_chromeos) {
    deps += [
      "//chrome/browser/ash/login/demo_mode",
      "//chrome/browser/ash/remote_apps",
      "//chrome/browser/ui/ash/keyboard",
    ]

    allow_circular_includes_from += [
      "//chrome/browser/ash/login/demo_mode",
      "//chrome/browser/ui/ash/keyboard",
    ]
  }
}

source_set("browser_test_support") {
  testonly = true

  sources = [
    "app_browsertest_util.cc",
    "app_browsertest_util.h",
    "app_window_interactive_uitest_base.cc",
    "app_window_interactive_uitest_base.h",
  ]

  public_deps = [
    ":platform_apps",
    "//chrome/browser/extensions:test_support",
    "//chrome/test:test_support",
    "//content/test:test_support",
  ]

  deps = [
    "//chrome/browser/apps/app_service",
    "//chrome/browser/ui/apps",
    "//chrome/browser/ui/extensions",
    "//chrome/browser/web_applications",
    "//components/media_router/browser",
    "//components/media_router/browser:test_support",
    "//components/services/app_service",
    "//extensions/browser:test_support",
  ]

  if (is_chromeos) {
    deps += [ "//chrome/browser/ui/ash/cast_config" ]
  }
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [
    "api/sync_file_system/sync_file_system_apitest.cc",
    "api/sync_file_system/sync_file_system_browsertest.cc",
    "app_browsertest.cc",
    "app_speech_recognition_browsertest.cc",
    "app_window_apitest.cc",
    "app_window_browsertest.cc",
    "app_window_frame_browsertest.cc",
    "audio_focus_web_contents_observer_browsertest.cc",
    "event_page_browsertest.cc",
    "service_worker_browsertest.cc",
  ]
  deps = [
    ":browser_test_support",
    ":platform_apps",
    "//chrome/browser/apps/app_service",
    "//chrome/browser/devtools",
    "//chrome/browser/devtools:test_support",
    "//chrome/browser/extensions:test_support",
    "//chrome/browser/sync_file_system",
    "//chrome/browser/ui/apps",
    "//chrome/browser/ui/extensions",
    "//chrome/test:test_support",
    "//chrome/test:test_support_ui",
    "//components/drive:test_support",
    "//components/media_router/browser",
    "//content/test:test_support",
    "//extensions/browser:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
  if (is_chromeos) {
    sources += [
      "api/arc_apps_private/arc_apps_private_apitest.cc",
      "api/browser/browser_apitest.cc",
      "api/enterprise_remote_apps/enterprise_remote_apps_apitest.cc",
      "api/media_galleries/media_galleries_apitest.cc",
      "api/media_galleries/media_galleries_watch_apitest.cc",
      "platform_app_navigation_redirector_browsertest.cc",
    ]
    deps += [
      "//ash/app_list",
      "//ash/app_list/model:app_list_model",
      "//chrome/browser/ash/app_list",
      "//chrome/browser/ash/app_list/arc:test_support",
      "//chrome/browser/ash/arc:arc_util",
      "//chrome/browser/ash/policy/core:test_support",
      "//chrome/browser/ash/policy/test_support",
      "//chrome/browser/ash/remote_apps",
      "//chrome/browser/ash/test:test_support",
      "//chrome/browser/media_galleries",
      "//chrome/browser/ui/ash/cast_config",
      "//chrome/browser/ui/ash/shelf",
      "//chromeos/ash/components/system",
      "//chromeos/ash/experiences/arc:arc_test_support",
      "//chromeos/ash/experiences/arc:notification_test_support",
      "//components/embedder_support",
      "//media:test_support",
    ]
  }
  if (enable_print_preview) {
    deps += [ "//chrome/browser/printing:test_support" ]
  }
}

source_set("interactive_ui_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
  sources = [
    "app_pointer_lock_interactive_uitest.cc",
    "app_window_interactive_uitest.cc",
  ]
  deps = [
    ":browser_test_support",
    ":platform_apps",
    "//chrome/browser/extensions:test_support",
    "//chrome/browser/ui/extensions",
    "//chrome/test:test_support",
    "//chrome/test:test_support_ui",
    "//content/test:test_support",
    "//extensions/browser:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
