# app_shim_listener and mach_bootstrap_acceptor are split out so that
# //chrome/browser:browser_process_platform_part can include
# browser_process_platform_part_mac.h (which transitively includes
# app_shim_listener.h) without depending on the rest of :app_shim.
source_set("app_shim_listener") {
  public = [
    "app_shim_listener.h",
    "mach_bootstrap_acceptor.h",
  ]
  public_deps = [
    "//base",
    "//content/public/browser",
    "//mojo/public/cpp/platform",
  ]
}

# This is the part of the Chrome browser process responsible for launching and
# communicating with app_shim processes on Mac.
source_set("app_shim") {
  sources = [
    "app_shim_host_bootstrap_mac.cc",
    "app_shim_host_bootstrap_mac.h",
    "app_shim_host_mac.cc",
    "app_shim_host_mac.h",
    "app_shim_listener.mm",
    "app_shim_manager_mac.cc",
    "app_shim_manager_mac.h",
    "app_shim_termination_manager.cc",
    "app_shim_termination_manager.h",
    "code_signature_mac.cc",
    "code_signature_mac.h",
    "mach_bootstrap_acceptor.cc",
    "web_app_shim_manager_delegate_mac.cc",
    "web_app_shim_manager_delegate_mac.h",
  ]

  configs += [ "//build/config/compiler:wexit_time_destructors" ]

  public_deps = [
    ":app_shim_listener",
    "//chrome/browser:browser_public_dependencies",
  ]

  deps = [
    "//apps",
    "//chrome/browser:browser_process",
    "//chrome/browser:browser_process_platform_part",
    "//chrome/browser/apps/app_service",
    "//chrome/browser/badging",
    "//chrome/browser/lifetime",
    "//chrome/browser/notifications",
    "//chrome/browser/profiles",
    "//chrome/browser/profiles:misc",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/profiles:profile_manager",
    "//chrome/browser/profiles:profile_util",
    "//chrome/browser/ui:ui_features",
    "//chrome/browser/ui/profiles",
    "//chrome/browser/ui/web_applications",
    "//chrome/browser/web_applications",
    "//chrome/browser/web_applications/extensions",
    "//chrome/common",
    "//chrome/common:app_mode_app_support",
    "//chrome/common:constants",
    "//chrome/common:mojo_bindings",
    "//chrome/common:non_code_constants",
    "//components/crx_file",
    "//components/metrics:content",
    "//components/remote_cocoa/browser",
    "//components/services/app_service",
    "//components/version_info",
    "//components/webapps/common",
    "//content/public/browser",
    "//content/public/common",
    "//services/preferences/public/cpp",
    "//ui/views",
  ]
}
