include_rules = [
  # Minimize dependencies on internal code, but allow service construction.
  "+components/contextual_tasks/internal/composite_context_decorator.h",
  "+components/contextual_tasks/internal/contextual_tasks_service_impl.h",
  "+components/url_deduplication/url_deduplication_helper.h",
  "+components/visited_url_ranking/public/url_visit_util.h",

  "+chrome/browser/signin/identity_manager_factory.h",
  "+chrome/browser/sync/data_type_store_service_factory.h",

   # No files in this directory can use TabStripModel. This ensures
   # platform-agnosticism for Android support.
   "-chrome/browser/ui/tabs/tab_strip_model.h",
]

specific_include_rules = {
   # Allowlist: Exceptions for legacy files that haven't been refactored yet.
   # TODO(crbug.com/475222385): Refactor these and remove them from this
   # allowlist.
  r"(contextual_tasks_ui_service"
  r"|search_ai_mode_promo_tab_helper_browsertest"
  r"|contextual_tasks_side_panel_coordinator_unittest"
  r").*\.(cc|h)": [
     "+chrome/browser/ui/tabs/tab_strip_model.h",
  ],
}
