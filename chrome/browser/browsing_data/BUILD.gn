  deps = [
    ":browsing_data",
    ":impl",
    "//base/test:test_support",
    "//chrome/browser/commerce",
    "//chrome/test:test_support",
    "//components/browsing_data/content:test_support",
    "//components/commerce/core:account_checker_test_support",
