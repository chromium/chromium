import("//build/config/android/rules.gni")

android_library("java") {
  sources = [
    "java/src/org/chromium/chrome/browser/open_in_app/CustomTabOpenInAppEntryPoint.java",
    "java/src/org/chromium/chrome/browser/open_in_app/OpenInAppDelegate.java",
    "java/src/org/chromium/chrome/browser/open_in_app/OpenInAppEntryPoint.java",
    "java/src/org/chromium/chrome/browser/open_in_app/OpenInAppMenuItemProvider.java",
    "java/src/org/chromium/chrome/browser/open_in_app/OpenInAppUtils.java",
    "java/src/org/chromium/chrome/browser/open_in_app/TabbedOpenInAppEntryPoint.java",
  ]

  deps = [
    "//base:base_java",
    "//chrome/browser/flags:java",
    "//chrome/browser/tab:java",
    "//chrome/browser/ui/android/omnibox:java",
    "//chrome/browser/ui/android/strings:ui_strings_grd",
    "//components/browser_ui/styles/android:java_resources",
    "//components/cached_flags:java",
    "//components/embedder_support/android:util_java",
    "//components/external_intents/android:java",
    "//content/public/android:content_full_java",
    "//third_party/androidx:androidx_annotation_annotation_java",
    "//url:url_java",
  ]

  resources_package = "org.chromium.chrome.browser.open_in_app"
}

robolectric_library("junit") {
  sources = [
    "java/src/org/chromium/chrome/browser/open_in_app/CustomTabOpenInAppEntryPointUnitTest.java",
    "java/src/org/chromium/chrome/browser/open_in_app/TabbedOpenInAppEntryPointUnitTest.java",
  ]

  deps = [
    ":java",
    "//base:base_java",
    "//base:base_java_test_support",
    "//base:base_junit_test_support",
    "//chrome/android/javatests:common_unit_test_deps_java",
    "//chrome/browser/tab:java",
    "//chrome/browser/ui/android/omnibox:java",
    "//chrome/test/android:chrome_java_unit_test_support",
    "//components/browser_ui/styles/android:java_resources",
    "//content/public/android:content_java",
    "//third_party/androidx:androidx_test_core_java",
    "//third_party/junit",
    "//third_party/mockito:mockito_java",
    "//url:url_java",
  ]
}
