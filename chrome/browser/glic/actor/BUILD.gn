source_set("actor") {
  sources = [
    "glic_actor_policy_checker.cc",
    "glic_actor_policy_checker.h",
    "glic_actor_task_manager.cc",
    "glic_actor_task_manager.h",
  ]

  deps = [
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/actor",
    "//chrome/browser/actor/ui",
    "//chrome/browser/glic",
    "//chrome/browser/glic:mojo_bindings",
    "//chrome/browser/signin",
    "//chrome/common:actor_webui_mojom",
    "//components/tabs:public",
    "//components/variations/service",
    "//mojo/public/mojom/base:protobuf_support",
  ]

  public_deps = [ "//chrome/browser/profiles:profile" ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  if (!is_android) {
    sources = [
      "glic_actor_action_execution_browsertest.cc",
      "glic_actor_context_fetch_browsertest.cc",
      "glic_actor_functional_browsertest.cc",
      "glic_actor_functional_browsertest.h",
      "glic_actor_metrics_functional_browsertest.cc",
      "glic_actor_tab_functional_browsertest.cc",
      "glic_actor_task_lifecycle_browsertest.cc",
    ]

    deps = [
      ":actor",
      "//chrome/browser/actor",
      "//chrome/browser/actor:test_support",
      "//chrome/browser/glic/test_support",
      "//chrome/common:actor_webui_mojom",
      "//chrome/test:test_support",
    ]
  }
}
