module glic.mojom;

// Page handler for the glic experimental opt-in dialog.
interface ExperimentalOptInPageHandler {
  // Accepts the experimental opt-in.
  Accept();

  // Rejects the experimental opt-in.
  Reject();

  // Sync necessary cookies to the webview partition. Returns true if cookies
  // were synced successfully, false otherwise. When false is returned, it's not
  // appropriate to show the webview.
  SyncCookies() => (bool success);
};
