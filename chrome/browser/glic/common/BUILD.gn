source_set("common") {
  sources = [
    "future_browser_features.h",
    "glic_tab_observer.cc",
    "glic_tab_observer.h",
  ]

  deps = [
    "//base",
    "//chrome/browser/ui",
    "//chrome/browser/ui:browser_navigator_params_headers",
    "//components/tabs:public",
  ]

  if (is_android) {
    sources += [
      "glic_tab_observer_android.cc",
      "glic_tab_observer_android.h",
    ]
    deps += [
      "//chrome/browser/tab",
      "//chrome/browser/ui/android/tab_model",
      "//chrome/browser/ui/browser_window/public/android:java_enum_srcjar",
      "//chrome/browser/ui/tabs:tabs_public",
      "//content/public/browser",
    ]
  } else {
    sources += [
      "glic_tab_observer_impl.cc",
      "glic_tab_observer_impl.h",
    ]
    deps += [
      "//chrome/browser/ui/browser_window",
      "//chrome/browser/ui/tabs",
      "//chrome/browser/ui/tabs:tab_strip",
      "//content/public/browser",
      "//ui/base",
    ]
  }
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "glic_tab_observer_browsertest.cc" ]
    deps = [
      ":common",
      "//base",
      "//chrome/browser",
      "//chrome/browser/ui",
      "//chrome/test:test_support",
      "//components/tabs:public",
      "//content/test:test_support",
    ]
  }
}
