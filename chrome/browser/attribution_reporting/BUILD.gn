source_set("browser_tests") {
  testonly = true

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "chrome_attribution_browsertest.cc" ]

  deps = [
    "//base",
    "//base/test:test_support",
    "//chrome/browser",
    "//chrome/browser/privacy_sandbox",
    "//chrome/browser/ui",
    "//chrome/test:test_support",
    "//components/page_load_metrics/browser:test_support",
    "//components/privacy_sandbox",
    "//components/privacy_sandbox/privacy_sandbox_attestations",
    "//content/public/browser",
    "//content/public/common",
    "//content/test:test_support",
    "//net",
    "//net:test_support",
    "//testing/gtest",
    "//url",
  ]
}
