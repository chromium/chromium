<!DOCTYPE translationbundle>
<translationbundle lang="si">
<translation id="1178581264944972037">විරාමය</translation>
<translation id="385051799172605136">ආපසු</translation>
<translation id="4431240646217225907">පෙළ ඉස්මතු කර ස්වයං අනුචලනය කරන්න</translation>
<translation id="4654641641922242357">“මෙම පිටුවට සවන් දෙන්න” වාදකය.</translation>
<translation id="5234971936051226002">“මෙම පිටුවට සවන් දෙන්න” වාදකය අවම කෙරිණි.</translation>
<translation id="5596627076506792578">තවත් විකල්ප</translation>
<translation id="6315170314923504164">හඬ</translation>
<translation id="6550675742724504774">අභිප්‍රේත</translation>
<translation id="6790428901817661496">වාදනය කරන්න</translation>
<translation id="6831043979455480757">පරිවර්තනය කරන්න</translation>
<translation id="6846298663435243399">පූර්ණය වෙමින්...</translation>
<translation id="7587250070160020374">Chrome දැන් වාදනය කරයි</translation>
<translation id="8136852699834914183">මෙම පිටුව සඳහා පසුධාවනය නොමැත.</translation>
<translation id="8953618380150219653">“මෙම පිටුවට සවන් දෙන්න” වාදකය සම්පූර්ණ උසින් විවෘත විය.</translation>
</translationbundle>