<translation id="1178581264944972037">ለአፍታ አቁም</translation>
<translation id="385051799172605136">ተመለስ</translation>
<translation id="4431240646217225907">ጽሁፍን አድምቅ እና በራስ-ሠር ሸብልል</translation>
<translation id="4654641641922242357">«ይህን ገፅ አዳምጥ» አጫዋች።</translation>
<translation id="5234971936051226002">«ይህን ገፅ አዳምጥ» አጫዋች እንዲያንስ ተደርጓል።</translation>
<translation id="5596627076506792578">ተጨማሪ አማራጮች</translation>
<translation id="6315170314923504164">ድምፅ</translation>
<translation id="6550675742724504774">አማራጮች</translation>
<translation id="6790428901817661496">አጫውት</translation>
<translation id="6831043979455480757">መተርጎም</translation>
<translation id="6846298663435243399">በመጫን ላይ…</translation>
<translation id="7587250070160020374">Chrome አሁን በመጫወት ላይ</translation>
<translation id="8136852699834914183">ለዚህ ገፅ መልሶ ማጫወት አይገኝም።</translation>
<translation id="8953618380150219653">«ይህን ገፅ አዳምጥ» አጫዋች በሙሉ ቀመት ተከፍቷል።</translation>
