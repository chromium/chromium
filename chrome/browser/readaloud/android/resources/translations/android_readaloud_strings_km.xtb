<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1178581264944972037">бһ•бҹ’бһўбһ¶бһҖ</translation>
<translation id="1921351128855867012">бһҒбһ¶вҖӢбһ‘бҹ…бһҳбһ»бһҒ <ph name="NUMBER_OF_SECONDS" /> бһңбһ·бһ“бһ¶бһ‘бһё</translation>
<translation id="1984328900355667246">бһҳбһ·бһ“бһўбһ¶бһ…вҖӢбһ…бһ¶бһҖбҹӢбһңбһёбһҠбҹҒбһўбһјвҖӢбһ”бһ¶бһ“бһ‘бҹҒ</translation>
<translation id="3023502830214299618">бһӮбһҪбһҡбһұбҹ’бһҷвҖӢбһҹбҹ„бһҖбһҹбҹ’бһҠбһ¶бһҷ бһҳбһ·бһ“бһўбһ¶бһ…вҖӢбһ…бһ¶бһҖбҹӢбһңбһёбһҠбҹҒбһўбһјвҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ‘бҹҶбһ–бҹҗбһҡбһ“бҹҒбҹҮвҖӢбһ“бҹ…бһ–бҹҒбһӣбһ“бҹҒбҹҮбһ”бһ¶бһ“бһ‘бҹҒбҹ” бһҹбһјбһҳбһ–бҹ’бһҷбһ¶бһҷбһ¶бһҳвҖӢбһҳбҹ’бһҠбһ„бһ‘бҹҖбһҸвҖӢбһ“бҹ…бһ–бҹҒбһӣбһҖбҹ’бһҡбҹ„бһҷбҹ”</translation>
<translation id="3807208219231826020">бһҡбҹҶбһҖбһ·бһӣбһҖбһ¶бһҡбһ…бһ¶бһҖбҹӢбһңбһёбһҠбҹҒбһўбһј</translation>
<translation id="385051799172605136">бһҗбһҷбһҖбҹ’бһҡбҹ„бһҷ</translation>
<translation id="4020327272915390518">бһҳбҹүбһәбһ“бһ»бһҷбһҮбһҳбҹ’бһҡбһҫбһҹ</translation>
<translation id="4431240646217225907">бһҡбҹҶбһӣбҹҒбһ…бһўбһҖбҹ’бһҹбһҡ бһ“бһ·бһ„бһҡбҹҶбһҖбһ·бһӣбһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·</translation>
<translation id="4872475766448853257">бһҒбһ¶вҖӢбһҗбһҷвҖӢбһҖбҹ’бһҡбҹ„бһҷ <ph name="NUMBER_OF_SECONDS" /> бһңбһ·бһ“бһ¶бһ‘бһё</translation>
<translation id="5234971936051226002">бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһ…бһ¶бһҖбҹӢ вҖңбһҹбҹ’бһҠбһ¶бһ”бҹӢвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ“бҹҒбҹҮвҖқ бһ”бһ¶бһ“бһ”бһ„бҹ’бһҡбһҪбһҳбһҮбһ¶вҖӢбһўбһ”бҹ’бһ”бһ”бһҡбһҳбһ¶бҹ”</translation>
<translation id="5596627076506792578">бһҮбһҳбҹ’бһҡбһҫбһҹбһ…бҹ’бһҡбһҫбһ“бһ‘бҹҖбһҸ</translation>
<translation id="6315170314923504164">бһҹбһҳбҹ’бһӣбҹҒбһ„</translation>
<translation id="6550675742724504774">бһҮбһҳбҹ’бһҡбһҫбһҹ</translation>
<translation id="6790428901817661496">бһӣбҹҒбһ„</translation>
<translation id="6831043979455480757">бһ”бһҖбһ”бҹ’бһҡбҹӮ</translation>
<translation id="6846298663435243399">бһҖбҹҶбһ–бһ»бһ„бһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡ...</translation>
<translation id="7587250070160020374">Chrome бһҘбһЎбһјбһңвҖӢбһҖбҹҶбһ–бһ»бһ„вҖӢбһ…бһ¶бһҖбҹӢ</translation>
<translation id="8136852699834914183">бһҳбһ·бһ“бһўбһ¶бһ…бһ…бһ¶бһҖбҹӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ‘бҹҶбһ–бҹҗбһҡбһ“бҹҒбҹҮбһ”бһ¶бһ“бһ‘бҹҒбҹ”</translation>
<translation id="8264989794233974275">бһ”бһ„бҹ’бһҖбһҫбһ“/бһ”бһ“бҹ’бһҗбһҷбһӣбҹ’бһ”бһҝбһ“ <ph name="PLAYBACK_SPEED" />xбҹ”</translation>
<translation id="8407011429883244666">бһ”бһ·бһ‘вҖӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһ…бһ¶бһҖбҹӢбҹ”</translation>
<translation id="8953618380150219653">бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһ…бһ¶бһҖбҹӢ вҖңбһҹбҹ’бһҠбһ¶бһ”бҹӢвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ“бҹҒбҹҮвҖқ бһ”бһ¶бһ“бһ”бһҫбһҖвҖӢбһ–бҹҒбһүвҖӢбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбҹ”</translation>
</translationbundle>