<!DOCTYPE translationbundle>
<translationbundle lang="pa">
<translation id="1178581264944972037">ਰੋਕੋ</translation>
<translation id="385051799172605136">ਪਿੱਛੇ</translation>
<translation id="4431240646217225907">ਲਿਖਤ ਨੂੰ ਉਜਾਗਰ ਕਰੋ ਅਤੇ ਸਵੈਚਲਿਤ ਸਕ੍ਰੋਲ ਕਰੋ</translation>
<translation id="4654641641922242357">“ਇਸ ਪੰਨੇ ਨੂੰ ਸੁਣੋ” ਪਲੇਅਰ।</translation>
<translation id="5234971936051226002">“ਇਸ ਪੰਨੇ ਨੂੰ ਸੁਣੋ” ਪਲੇਅਰ ਨੂੰ ਛੋਟਾ ਕੀਤਾ ਗਿਆ।</translation>
<translation id="5596627076506792578">ਹੋਰ ਚੋਣਾਂ</translation>
<translation id="6315170314923504164">ਅਵਾਜ਼</translation>
<translation id="6550675742724504774">ਚੋਣਾਂ</translation>
<translation id="6790428901817661496">ਪਲੇ ਕਰੋ</translation>
<translation id="6831043979455480757">ਅਨੁਵਾਦ ਕਰੋ</translation>
<translation id="6846298663435243399">ਲੋਡ ਹੋ ਰਿਹਾ ਹੈ...</translation>
<translation id="7587250070160020374">Chrome ਹੁਣ ਚੱਲ ਰਿਹਾ ਹੈ</translation>
<translation id="8136852699834914183">ਇਸ ਪੰਨੇ ਲਈ ਪਲੇਬੈਕ ਉਪਲਬਧ ਨਹੀਂ ਹੈ।</translation>
<translation id="8953618380150219653">“ਇਸ ਪੰਨੇ ਨੂੰ ਸੁਣੋ” ਪਲੇਅਰ ਪੂਰੀ ਉਚਾਈ ਤੱਕ ਖੁੱਲ੍ਹਾਂ ਹੈ।</translation>
</translationbundle>