<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="te">
<translation id="1178581264944972037">పాజ్ చేయి</translation>
<translation id="385051799172605136">వెనుకకు</translation>
<translation id="4431240646217225907">టెక్స్ట్‌ను హైలైట్ చేయండి, ఆటోమెటిక్ స్క్రోల్ చేయండి</translation>
<translation id="4654641641922242357">"ఈ పేజీలో ఉన్న కంటెంట్‌ను వినండి" ప్లేయర్.</translation>
<translation id="5234971936051226002">“ఈ పేజీలో ఉన్న కంటెంట్‌ను వినండి” ప్లేయర్ మినిమైజ్ చేయబడింది.</translation>
<translation id="5596627076506792578">మరిన్ని ఆప్షన్‌లు</translation>
<translation id="6315170314923504164">Voice</translation>
<translation id="6550675742724504774">ఎంపికలు</translation>
<translation id="6790428901817661496">ప్లే చేయి</translation>
<translation id="6831043979455480757">అనువదించు</translation>
<translation id="6846298663435243399">లోడ్ చేస్తున్నాము…</translation>
<translation id="7587250070160020374">Chrome ఇప్పుడు ప్లే అవుతోంది</translation>
<translation id="8136852699834914183">ఈ పేజీకి ప్లేబ్యాక్ అందుబాటులో లేదు.</translation>
<translation id="8953618380150219653">"ఈ పేజీలో ఉన్న కంటెంట్‌ను వినండి" ప్లేయర్ పూర్తి ఎత్తులో తెరవబడింది.</translation>
</translationbundle>