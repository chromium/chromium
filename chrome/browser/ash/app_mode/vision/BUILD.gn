import("//testing/test.gni")

assert(is_chromeos_ash)

source_set("vision") {
  sources = [
    "kiosk_vision.cc",
    "kiosk_vision.h",
  ]
  public_deps = [ ":vision_prefs" ]
  deps = [
    ":internal",
    "//base",
    "//chrome/browser:browser_process",
    "//chromeos/ash/components/dbus/dlcservice",
    "//components/prefs:prefs",
  ]
}

source_set("vision_prefs") {
  sources = [ "pref_names.h" ]
}

source_set("internal") {
  visibility = [ ":*" ]
  sources = [
    "internal/pref_observer.cc",
    "internal/pref_observer.h",
  ]
  deps = [
    ":vision_prefs",
    "//base",
    "//components/prefs:prefs",
  ]
}

source_set("unit_test_sources") {
  testonly = true
  sources = [ "kiosk_vision_unittest.cc" ]
  deps = [
    ":vision",
    "//base",
    "//chrome/test:test_support",
    "//chromeos/ash/components/dbus/dlcservice",
    "//testing/gtest",
  ]
}

test("kiosk_vision_unit_tests") {
  testonly = true
  deps = [
    ":unit_test_sources",
    ":vision",
    "//chrome/test:test_support_unit",
    "//testing/gtest",
  ]
}
