import("//chrome/common/features.gni")

assert(is_win || is_mac || is_linux || is_chromeos || is_android)

source_set("reduce_accept_language") {
  sources = [ "reduce_accept_language_factory.h" ]

  public_deps = [
    "//base",
    "//chrome/browser/profiles:profile",
    "//components/keyed_service/core",
    "//components/reduce_accept_language/browser",
    "//content/public/browser",
  ]
}

source_set("impl") {
  sources = [ "reduce_accept_language_factory.cc" ]

  public_deps = [
    ":reduce_accept_language",
    "//chrome/browser:browser_public_dependencies",
  ]

  deps = [
    "//chrome/browser/content_settings:content_settings_factory",
    "//chrome/browser/profiles:profile",
    "//components/prefs",
    "//components/reduce_accept_language/browser",
    "//content/public/browser",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "reduce_accept_language_service_unittest.cc" ]

  deps = [
    ":reduce_accept_language",
    "//chrome/browser/content_settings:content_settings_factory",
    "//chrome/test:test_support",
    "//components/language/core/browser",
    "//components/prefs",
    "//components/reduce_accept_language/browser",
    "//components/reduce_accept_language/browser:test_support",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//url",
  ]
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "reduce_accept_language_browsertest.cc" ]

    deps = [
      "//chrome/browser/content_settings:content_settings_factory",
      "//chrome/browser/policy:test_support",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/ui",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//components/content_settings/core/browser",
      "//components/content_settings/core/common",
      "//components/embedder_support",
      "//components/language/core/browser",
      "//components/language/core/common",
      "//components/metrics:content",
      "//components/policy:policy_code_generate",
      "//components/prefs",
      "//content/public/browser",
      "//content/public/common",
      "//content/test:test_support",
      "//services/network/public/cpp",
      "//third_party/blink/public/common",
      "//ui/base",
      "//url",
    ]
  }
}
