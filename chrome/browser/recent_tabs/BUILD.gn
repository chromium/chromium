import("//build/config/android/rules.gni")
import("//chrome/android/features/android_library_factory_tmpl.gni")

android_library("java") {
  sources = [ "android/java/src/org/chromium/chrome/browser/recent_tabs/RestoreTabsFeatureHelper.java" ]

  deps = [
    "//base:base_java",
    "//chrome/browser/profiles/android:java",
  ]
  resources_package = "org.chromium.chrome.recent_tabs"
}

android_library_factory("factory_java") {
  sources = [ "internal/android/java/src/org/chromium/chrome/browser/recent_tabs/RestoreTabsControllerFactory.java" ]

  deps = [
    ":java",
    "//chrome/browser/recent_tabs/internal:java",
  ]
}
