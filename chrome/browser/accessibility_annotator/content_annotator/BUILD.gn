source_set("content_annotator") {
  sources = [
    "content_annotator_service_factory.cc",
    "content_annotator_service_factory.h",
  ]

  deps = [
    "//base",
    "//chrome/browser/profiles:profile",
    "//components/accessibility_annotator/content/content_annotator",
    "//components/accessibility_annotator/core/public:features",
    "//components/keyed_service/core",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "content_annotator_service_factory_unittest.cc" ]
  deps = [
    ":content_annotator",
    "//base/test:test_support",
    "//chrome/test:test_support",
    "//components/accessibility_annotator/core/public:features",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
