import("//build/config/features.gni")

source_set("accessibility_annotator") {
  sources = [
    "accessibility_annotator_features.cc",
    "accessibility_annotator_features.h",
    "accessibility_annotator_service.cc",
    "accessibility_annotator_service.h",
    "accessibility_annotator_service_factory.cc",
    "accessibility_annotator_service_factory.h",
  ]

  deps = [
    "//base",
    "//chrome/browser/profiles:profile",
    "//components/keyed_service/core",
    "//content/public/browser",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "accessibility_annotator_service_factory_unittest.cc" ]
  deps = [
    ":accessibility_annotator",
    "//base/test:test_support",
    "//chrome/test:test_support",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
