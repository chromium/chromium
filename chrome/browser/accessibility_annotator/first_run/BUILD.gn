if (is_android) {
  import("//build/config/android/rules.gni")
}

source_set("first_run") {
  sources = [
    "accessibility_annotator_first_run_service_factory.cc",
    "accessibility_annotator_first_run_service_factory.h",
    "chrome_accessibility_annotator_first_run_client.cc",
    "chrome_accessibility_annotator_first_run_client.h",
  ]

  if (is_android) {
    sources += [
      "android/accessibility_annotator_first_run_bottom_sheet_bridge.cc",
      "android/accessibility_annotator_first_run_bottom_sheet_bridge.h",
    ]
  }

  deps = [
    "//base",
    "//chrome/browser/accessibility_annotator",
    "//chrome/browser/personal_context",
    "//chrome/browser/profiles:profile",
    "//components/accessibility_annotator/core",
    "//components/accessibility_annotator/core:features",
    "//components/accessibility_annotator/first_run",
    "//components/keyed_service/content",
    "//content/public/browser",
  ]

  if (is_android) {
    deps += [
      "//chrome/android:jni_headers",
      "//ui/android",
    ]
  } else {
    deps += [ "//chrome/browser/ui/views/accessibility_annotator" ]
  }
}

source_set("unit_tests") {
  testonly = true
  sources = []

  if (is_android) {
    sources += [ "android/accessibility_annotator_first_run_bottom_sheet_bridge_unittest.cc" ]
  }

  deps = [
    ":first_run",
    "//base",
    "//base/test:test_support",
    "//components/accessibility_annotator/first_run",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
