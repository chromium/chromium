import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

if (is_chrome_branded) {
  # For a branded build, forward the "resources" target to the implementation
  # in the internal/ directory.
  group("resources") {
    public_deps = [ "internal:resources" ]
  }
} else {
  # For a non-branded (Chromium) build, define the build here directly.
  build_webui("build") {
    grd_prefix = "webui_browser"

    static_files = [ "webui_browser.html" ]

    ts_files = [
      "app.ts",
      "app.html.ts",
      "browser_proxy.ts",
      "webui_browser.ts",
      "webview.ts",
    ]
    css_files = [
      "app.css",
      "webview.css",
    ]

    mojo_files = [
      "$root_gen_dir/chrome/browser/ui/webui_browser/browser.mojom-webui.ts",
    ]

    mojo_files_deps = [
      "//chrome/browser/ui/webui_browser:browser_mojo_bindings_ts__generator",
    ]

    webui_context_type = "trusted"

    ts_definitions = [ "chrome_browser.d.ts" ]

    ts_deps = [
      "//third_party/lit/v3_0:build_ts",
      "//ui/webui/resources/cr_components/searchbox:build_ts",
      "//ui/webui/resources/cr_elements:build_ts",
      "//ui/webui/resources/js:build_ts",
      "//ui/webui/resources/mojo:build_ts",
    ]
  }
}
