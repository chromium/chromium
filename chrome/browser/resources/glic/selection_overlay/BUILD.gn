import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "glic_untrusted"

  static_files = [ "selection_overlay.html" ]

  ts_files = [
    "browser_proxy.ts",
    "selection_overlay_app.html.ts",
    "selection_overlay_app.ts",
  ]

  css_files = [ "selection_overlay_app.css" ]

  mojo_files_deps =
      [ "//chrome/browser/glic/selection:mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/glic/selection/selection_overlay.mojom-webui.ts" ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  webui_context_type = "untrusted"
}
