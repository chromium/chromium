import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "glic_experimental_opt_in"

  static_files = [ "experimental_opt_in.html" ]
  ts_files = [ "experimental_opt_in.ts" ]
  ts_deps = [
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
  mojo_files_deps = [ "//chrome/browser/glic:mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/glic/experimental_opt_in/glic_experimental_opt_in.mojom-webui.ts" ]
  ts_definitions = [
    "//tools/typescript/definitions/chrome_event.d.ts",
    "//tools/typescript/definitions/webview_tag.d.ts",
  ]
}
