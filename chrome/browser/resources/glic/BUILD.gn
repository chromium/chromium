import("//ui/webui/resources/tools/build_webui.gni")

assert(enable_glic)

build_webui("build") {
  grd_prefix = "glic"

  static_files = [
    "glic.html",
    "glic.css",
  ]

  non_web_component_files = [
    "browser_proxy.ts",
    "main.ts",
    "glic_api_host.ts",
  ]

  webui_context_type = "trusted"
  ts_deps = [
    "glic_api_host:post_message_transport",
    "glic_api_host:request_types",
    "//chrome/browser/resources/glic:glic_api",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  extra_grdp_deps = [
    "//chrome/browser/resources/glic/glic_api_host:glic_api_grdp",
    "//chrome/browser/resources/glic/glic_api_host:glic_api_shared_grdp",
  ]
  extra_grdp_files = [
    "$root_gen_dir/chrome/browser/resources/glic/glic_generated.grdp",
    "$root_gen_dir/chrome/browser/resources/glic/glic_api_shared.grdp",
  ]

  mojo_files_deps =
      [ "//chrome/browser/ui/webui/glic:mojo_bindings_ts__generator" ]
  mojo_files =
      [ "$root_gen_dir/chrome/browser/ui/webui/glic/glic.mojom-webui.ts" ]
  ts_path_mappings = [
    "//glic/glic_api_host/*|" + rebase_path(
            "$root_gen_dir/chrome/browser/resources/glic/glic_api_host/*",
            target_gen_dir),
    "//glic/glic_api/*|" +
        rebase_path("$root_gen_dir/chrome/browser/resources/glic/*",
                    target_gen_dir),
  ]

  ts_definitions = [
    # These files are necessary for chrome.webviewTag:
    "//tools/typescript/definitions/webview_tag.d.ts",
    "//tools/typescript/definitions/tabs.d.ts",
    "//tools/typescript/definitions/extension_types.d.ts",
    "//tools/typescript/definitions/context_menus.d.ts",
    "//tools/typescript/definitions/web_request.d.ts",
    "//tools/typescript/definitions/chrome_event.d.ts",
  ]
}

ts_library("glic_api") {
  root_dir = "glic_api"
  in_files = [ "glic_api.ts" ]
  composite = true
}
