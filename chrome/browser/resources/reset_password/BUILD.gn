import("//components/safe_browsing/buildflags.gni")
import("//ui/webui/resources/tools/build_webui.gni")

assert(safe_browsing_mode == 1)

build_webui("build") {
  grd_prefix = "reset_password"

  static_files = [ "reset_password.html" ]

  ts_files = [ "reset_password.ts" ]

  mojo_files_deps =
      [ "//chrome/browser/ui/webui/reset_password:mojo_bindings_ts__generator" ]

  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/reset_password/reset_password.mojom-webui.ts" ]

  ts_deps = [
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  webui_context_type = "trusted"
}
