import("//chrome/common/features.gni")
import("//tools/grit/grit_rule.gni")

grit("resources") {
  source = "resources.grd"
  outputs = [
    "grit/dappnet_settings_resources.h",
    "grit/dappnet_settings_resources_map.cc",
    "grit/dappnet_settings_resources_map.h",
    "dappnet_settings_resources.pak",
  ]
  output_dir = "$root_gen_dir/chrome"
}