import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "multistep_filter_internals"

  static_files = [ "multisteps_filter_internals.html" ]

  ts_files = [
    "app.ts",
    "app.html.ts",
    "browser_proxy.ts",
  ]

  css_files = [ "app.css" ]

  mojo_files_deps = [ "//chrome/browser/ui/webui/multistep_filter_internals:mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/multistep_filter_internals/multistep_filter_internals.mojom-webui.ts" ]

  ts_composite = true
  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  webui_context_type = "trusted"
}
