import("//chrome/common/features.gni")
import("//tools/grit/grit_rule.gni")
import("//tools/grit/preprocess_if_expr.gni")
import("//tools/polymer/html_to_js.gni")
import("//tools/typescript/ts_library.gni")
import("//ui/webui/resources/tools/generate_grd.gni")

preprocess_folder = "preprocessed"

ts_library("build") {
  root_dir = "$target_gen_dir/$preprocess_folder"
  out_dir = "$target_gen_dir/tsc"
  tsconfig_base = "tsconfig_base.json"
  in_files = [
    "app.js",
    "browser_proxy.js",
    "cluster.js",
    "history_clusters.js",
    "page_favicon.js",
    "router.js",
    "search_query.js",
    "shared_style.js",
    "shared_vars.js",
    "top_visit.js",
    "utils.js",
    "visit_row.js",
  ]
  deps = [
    "//third_party/polymer/v3_0:library",
    "//ui/webui/resources:library",
  ]
  extra_deps = [
    ":preprocess",
    ":preprocess_generated",
  ]
}

html_to_js("web_components_local") {
  js_files = [
    "app.js",
    "cluster.js",
    "page_favicon.js",
    "router.js",
    "search_query.js",
    "shared_style.js",
    "shared_vars.js",
    "top_visit.js",
    "visit_row.js",
  ]
}

group("web_components") {
  public_deps = [ ":web_components_local" ]
}

preprocess_if_expr("preprocess") {
  defines = chrome_grit_defines + [ "is_official_build=$is_official_build" ]
  in_folder = "./"
  out_folder = "$target_gen_dir/$preprocess_folder"
  in_files = [
    "browser_proxy.js",
    "history_clusters.js",
    "utils.js",
  ]
}

preprocess_if_expr("preprocess_generated") {
  defines = chrome_grit_defines + [ "is_official_build=$is_official_build" ]
  in_folder = target_gen_dir
  out_folder = "$target_gen_dir/$preprocess_folder"
  in_files = [
    "app.js",
    "cluster.js",
    "page_favicon.js",
    "router.js",
    "search_query.js",
    "shared_style.js",
    "shared_vars.js",
    "top_visit.js",
    "visit_row.js",
  ]
  deps = [ ":web_components" ]
}

grd_prefix = "history_clusters"

generate_grd("build_history_clusters_api_mojo_grdp") {
  grd_prefix = "${grd_prefix}_API"
  out_grd = "$target_gen_dir/clusters_api_mojo_resources.grdp"
  input_files = [ "history_clusters.mojom-webui.js" ]
  resource_path_rewrites = [ "history_clusters.mojom-webui.js|chrome/browser/ui/webui/history_clusters/history_clusters.mojom-webui.js" ]
  input_files_base_dir =
      rebase_path(
          "$root_gen_dir/mojom-webui/chrome/browser/ui/webui/history_clusters",
          root_build_dir)
}

generate_grd("build_history_clusters_definition_mojo_grdp") {
  grd_prefix = "${grd_prefix}_DEFINITION"
  out_grd = "$target_gen_dir/clusters_definition_mojo_resources.grdp"
  input_files = [ "history_clusters.mojom-webui.js" ]
  resource_path_rewrites = [ "history_clusters.mojom-webui.js|components/history_clusters/core/history_clusters.mojom-webui.js" ]
  input_files_base_dir =
      rebase_path("$root_gen_dir/mojom-webui/components/history_clusters/core",
                  root_build_dir)
}

generate_grd("build_grd") {
  grd_prefix = "$grd_prefix"
  out_grd = "$target_gen_dir/resources.grd"
  input_files = [ "history_clusters.html" ]
  input_files_base_dir = rebase_path(".", "//")
  grdp_files = [
    "$target_gen_dir/clusters_api_mojo_resources.grdp",
    "$target_gen_dir/clusters_definition_mojo_resources.grdp",
  ]
  deps = [
    ":build",
    ":build_history_clusters_api_mojo_grdp",
    ":build_history_clusters_definition_mojo_grdp",
  ]
  manifest_files = [ "$target_gen_dir/tsconfig.manifest" ]
}

grit("resources") {
  defines = chrome_grit_defines + [ "is_official_build=$is_official_build" ]
  enable_input_discovery_for_gn_analyze = false
  source = "$target_gen_dir/resources.grd"
  deps = [
    ":build_grd",
    "//chrome/browser/ui/webui/history_clusters:mojo_bindings_webui_js",
    "//components/history_clusters/core:mojo_bindings_webui_js",
  ]
  outputs = [
    "grit/history_clusters_resources.h",
    "grit/history_clusters_resources_map.cc",
    "grit/history_clusters_resources_map.h",
    "history_clusters_resources.pak",
  ]
  output_dir = "$root_gen_dir/chrome"
}
