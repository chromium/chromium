import("//ui/webui/resources/tools/build_webui.gni")

assert(is_win || is_mac || is_linux || is_chromeos)

action("generate_tool_definitions") {
  script = "tools/generate_tool_definitions.py"
  sources = [ "//chrome/browser/ui/webui/ai_overlay_dialog/tools/tools.mojom" ]
  outputs = [ "$target_gen_dir/generated_tool_definitions.ts" ]
  args = [
    "--in-files",
    rebase_path(sources[0], root_build_dir),
    "--out-file",
    rebase_path(outputs[0], root_build_dir),
  ]
}

build_webui("build") {
  grd_prefix = "ai_overlay_dialog_untrusted"

  static_files = [ "ai_overlay_dialog.html" ]

  css_files = [ "app.css" ]

  web_component_files = [ "app.ts" ]

  ts_files = [
    "api_session.ts",
    "audio_capturer.ts",
    "audio_player.ts",
    "audio_processor.ts",
    "audio_utils.ts",
    "conversation.ts",
    "journal.ts",
    "logging.ts",
    "page_context_manager.ts",
    "persona.ts",
    "tools/tool_executor.ts",
  ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  mojo_files_deps = [
    ":generate_tool_definitions",
    "//chrome/browser/ui/webui/ai_overlay_dialog:mojo_bindings_ts__generator",
  ]
  mojo_files = [
    "$root_gen_dir/chrome/browser/ui/webui/ai_overlay_dialog/ai_overlay_dialog.mojom-webui.ts",
    "$root_gen_dir/chrome/browser/ui/webui/ai_overlay_dialog/tools/tools.mojom-webui.ts",
    "$target_gen_dir/generated_tool_definitions.ts",
  ]

  ts_composite = true

  webui_context_type = "untrusted"
}
