import("//third_party/closure_compiler/compile_js.gni")
import("../../os_settings.gni")

js_type_check("closure_compile_module") {
  is_polymer3 = true
  closure_flags = os_settings_closure_flags
  deps = [
    ":actions",
    ":api_listener",
    ":browser_proxy",
    ":fake_page_handler",
    ":reducers",
    ":store",
    ":store_client",
  ]
}

js_library("types") {
  deps = [
    "//ui/webui/resources/cr_components/app_management:mojo_bindings_webui_js",
  ]
}

js_library("actions") {
  deps = [
    "//ash/webui/common/resources/store:store",
    "//ui/webui/resources/cr_components/app_management:mojo_bindings_webui_js",
    "//ui/webui/resources/js:cr.m",
  ]
}

js_library("api_listener") {
  deps = [
    ":actions",
    ":store",
    "//ash/webui/common/resources/store:store",
    "//ui/webui/resources/js:cr.m",
  ]
}

js_library("browser_proxy") {
  deps = [
    ":fake_page_handler",
    "//ui/webui/resources/cr_components/app_management:mojo_bindings_webui_js",
  ]
}

js_library("fake_page_handler") {
  deps = [
    "//ash/webui/common/resources:promise_resolver",
    "//ui/webui/resources/cr_components/app_management:mojo_bindings_webui_js",
  ]
}

js_library("reducers") {
  deps = [
    ":types",
    "//ui/webui/resources/js:cr.m",
  ]
}

js_library("store") {
  deps = [
    "//ash/webui/common/resources/store:store",
    "//ui/webui/resources/js:cr.m",
  ]
}

js_library("store_client") {
  deps = [
    ":store",
    ":types",
    "//ash/webui/common/resources/store:store",
    "//ash/webui/common/resources/store:store_client",
    "//ui/webui/resources/cr_components/app_management:mojo_bindings_webui_js",
    "//ui/webui/resources/js:cr.m",
  ]
}
