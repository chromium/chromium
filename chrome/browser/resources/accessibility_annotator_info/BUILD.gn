import("//build/config/chrome_build.gni")
import("//ui/webui/resources/tools/build_webui.gni")
import("//ui/webui/resources/tools/generate_grd.gni")

if (is_chrome_branded) {
  generate_grd("build_google_g_grdp") {
    grd_prefix = "accessibility_annotator_info"
    out_grd = "$target_gen_dir/google_g_cr23.grdp"
    input_files = [ "google_g_cr23.svg" ]
    input_files_base_dir =
        rebase_path("//chrome/app/theme/google_chrome/realbox", "//")
  }
}

build_webui("resources") {
  grd_prefix = "accessibility_annotator_info"

  static_files = [
    "accessibility_annotator_info.html",
    "keyboard.svg",
  ]

  css_files = [ "accessibility_annotator_info.css" ]

  ts_files = [
    "accessibility_annotator_info.ts",
    "accessibility_annotator_info.html.ts",
    "browser_proxy.ts",
  ]

  mojo_files_deps = [ "//chrome/browser/ui/webui/accessibility_annotator:mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/accessibility_annotator/accessibility_annotator_info.mojom-webui.ts" ]

  ts_composite = true
  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  webui_context_type = "trusted"

  if (is_chrome_branded) {
    extra_grdp_deps = [ ":build_google_g_grdp" ]
    extra_grdp_files = [ "$target_gen_dir/google_g_cr23.grdp" ]
  }
}
