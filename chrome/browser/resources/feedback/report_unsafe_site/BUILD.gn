import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "feedback_report_unsafe_site"
  generate_grdp = true

  static_files = [ "report_unsafe_site.html" ]

  ts_files = [
    "report_unsafe_site_app.ts",
    "report_unsafe_site_app.html.ts",
  ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
  webui_context_type = "trusted"
}
