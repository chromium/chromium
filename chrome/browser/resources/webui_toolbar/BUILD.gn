import("//ui/webui/resources/tools/build_webui.gni")
import("//ui/webui/webui_features.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "webui_toolbar"

  static_files = [
    "browser_controls_icons/home_20.svg",
    "browser_controls_icons/home_24.svg",
    "rhs_icons/location_off_chrome_refresh.svg",
    "rhs_icons/location_on_chrome_refresh.svg",
    "rhs_icons/mic_chrome_refresh.svg",
    "rhs_icons/mic_off_chrome_refresh.svg",
    "rhs_icons/notifications_chrome_refresh.svg",
    "rhs_icons/notifications_off_chrome_refresh.svg",
    "rhs_icons/password_manager.svg",
    "rhs_icons/videocam_chrome_refresh.svg",
    "rhs_icons/videocam_off_chrome_refresh.svg",
    "lhs_icons/business_chrome_refresh.svg",
    "lhs_icons/dangerous_chrome_refresh.svg",
    "lhs_icons/http_chrome_refresh.svg",
    "lhs_icons/no_encryption.svg",
    "lhs_icons/not_secure_warning_chrome_refresh_16.svg",
    "lhs_icons/not_secure_warning_chrome_refresh_20.svg",
    "lhs_icons/secure_page_info_chrome_refresh.svg",
    "webui_toolbar.html",
    "webui_toolbar.css",
  ]

  ts_files = [
    "app.html.ts",
    "app.ts",
    "avatar_button.html.ts",
    "avatar_button.ts",
    "back_forward_button.html.ts",
    "back_forward_button.ts",
    "browser_proxy.ts",
    "home_button.html.ts",
    "home_button.ts",
    "location_bar.ts",
    "location_bar.html.ts",
    "location_icon.ts",
    "location_icon.html.ts",
    "metrics_recorder.ts",
    "permission_chip.html.ts",
    "permission_chip.ts",
    "permission_dashboard.html.ts",
    "permission_dashboard.ts",
    "pinned_toolbar_action.html.ts",
    "pinned_toolbar_action.ts",
    "pinned_toolbar_action_icons.html.ts",
    "pinned_toolbar_actions.html.ts",
    "pinned_toolbar_actions.ts",
    "readonly_omnibox.ts",
    "readonly_omnibox.html.ts",
    "reload_button.html.ts",
    "reload_button.ts",
    "split_tabs_button.html.ts",
    "split_tabs_button.ts",
    "split_tabs_button_icons.html.ts",
    "timer_helper.ts",
    "toolbar_button.ts",
    "toolbar_divider.html.ts",
    "toolbar_divider.ts",
  ]
  css_files = [
    "app.css",
    "avatar_button.css",
    "back_forward_button.css",
    "home_button.css",
    "location_bar.css",
    "location_icon.css",
    "permission_chip.css",
    "permission_dashboard.css",
    "pinned_toolbar_action.css",
    "pinned_toolbar_actions.css",
    "readonly_omnibox.css",
    "reload_button.css",
    "split_tabs_button.css",
    "toolbar_button.css",
    "toolbar_divider.css",
  ]

  # ts_composite is needed for JS tests to depend on this.
  ts_composite = true
  webui_context_type = "trusted"
  optimize = optimize_webui
  generate_code_cache = enable_webui_generate_code_cache
  if (optimize) {
    optimize_webui_host = "webui-toolbar.top-chrome"
    optimize_webui_in_files = [
      "app.js",
      "reload_button.js",
    ]
    optimize_webui_external_paths =
        [ "chrome://webui-toolbar.top-chrome|" +
          rebase_path(
              "$root_gen_dir/chrome/browser/resources/webui_toolbar/tsc",
              root_build_dir) ]
  }

  ts_definitions = [
    "//tools/typescript/definitions/chrome_histograms.d.ts",
    "//tools/typescript/definitions/chrome_send.d.ts",
    "//tools/typescript/definitions/chrome_timeticks.d.ts",
    "//tools/typescript/definitions/metrics_private.d.ts",
    "//tools/typescript/definitions/pending.d.ts",
  ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_components/color_change_listener:build_ts",
    "//ui/webui/resources/cr_components/help_bubble:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  mojo_files_deps = [
    "//components/browser_apis/browser_controls:mojom_data_model_ts__generator",
    "//components/browser_apis/browser_controls:mojom_ts__generator",
    "//components/browser_apis/ui_controllers/toolbar:mojom_data_model_ts__generator",
    "//components/browser_apis/ui_controllers/toolbar:mojom_ts__generator",
    "//components/content_settings/core/common:content_settings_types_ts__generator",
  ]

  mojo_files = [
    "$root_gen_dir/components/browser_apis/browser_controls/browser_controls_api.mojom-webui.ts",
    "$root_gen_dir/components/browser_apis/browser_controls/browser_controls_api_data_model.mojom-webui.ts",
    "$root_gen_dir/components/browser_apis/ui_controllers/toolbar/toolbar_ui_api.mojom-webui.ts",
    "$root_gen_dir/components/browser_apis/ui_controllers/toolbar/toolbar_ui_api_data_model.mojom-webui.ts",
    "$root_gen_dir/components/content_settings/core/common/content_settings_types.mojom-webui.ts",
  ]
}
