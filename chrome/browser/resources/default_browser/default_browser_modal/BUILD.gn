import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "default_browser_modal"

  static_files = [
    "default_browser_modal.css",
    "default_browser_modal.html",
    "header_background.svg",
    "header_background_dark.svg",
    "settings_illustration.svg",
  ]

  ts_files = [
    "app.ts",
    "app.html.ts",
    "browser_proxy.ts",
  ]

  css_files = [ "app.css" ]

  ts_composite = true

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  mojo_files_deps = [ "//chrome/browser/ui/webui/default_browser:modal_mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/default_browser/default_browser_modal.mojom-webui.ts" ]

  webui_context_type = "trusted"
}
