import("//ui/webui/resources/tools/build_webui.gni")

assert(is_mac || is_win || is_linux)

build_webui("build") {
  grd_prefix = "updater"

  static_files = [
    "updater.html",
    "updater.css",
  ]

  ts_files = [
    "app.html.ts",
    "app.ts",
    "event_history.ts",
    "event_list/filter_bar.html.ts",
    "event_list/filter_bar.ts",
    "event_list/filter_dialog/app_dialog.html.ts",
    "event_list/filter_dialog/app_dialog.ts",
    "event_list/filter_dialog/date_dialog.html.ts",
    "event_list/filter_dialog/date_dialog.ts",
    "event_list/filter_dialog/event_dialog.html.ts",
    "event_list/filter_dialog/event_dialog.ts",
    "event_list/filter_dialog/filter_dialog.html.ts",
    "event_list/filter_dialog/filter_dialog.ts",
    "event_list/filter_dialog/filter_dialog_footer.html.ts",
    "event_list/filter_dialog/filter_dialog_footer.ts",
    "event_list/filter_dialog/outcome_dialog.html.ts",
    "event_list/filter_dialog/outcome_dialog.ts",
    "event_list/filter_dialog/type_dialog.html.ts",
    "event_list/filter_dialog/type_dialog.ts",
    "event_list/raw_event_details.html.ts",
    "event_list/raw_event_details.ts",
    "icons.html.ts",
    "known_apps.ts",
  ]
  css_files = [
    "app.css",
    "event_list/filter_bar.css",
    "event_list/filter_dialog/app_dialog.css",
    "event_list/filter_dialog/date_dialog.css",
    "event_list/filter_dialog/event_dialog.css",
    "event_list/filter_dialog/filter_dialog.css",
    "event_list/filter_dialog/filter_dialog_footer.css",
    "event_list/filter_dialog/filter_dialog_shared.css",
    "event_list/filter_dialog/outcome_dialog.css",
    "event_list/filter_dialog/type_dialog.css",
    "event_list/raw_event_details.css",
  ]

  webui_context_type = "trusted"

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
  ts_composite = true
}
