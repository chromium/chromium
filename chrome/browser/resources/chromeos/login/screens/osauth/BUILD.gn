    "../../components/behaviors:multi_step_behavior",
    "../../components/behaviors:oobe_i18n_behavior",
    "../../components/dialogs:oobe_adaptive_dialog",
    "../../components/dialogs:oobe_loading_dialog",
  ]
  extra_deps = [ ":web_components" ]
}

