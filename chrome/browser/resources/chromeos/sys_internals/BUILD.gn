import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "sys_internals"

  static_files = [
    "index.html",
    "index.css",
    "images/cpu.svg",
    "images/info.svg",
    "images/memory.svg",
    "images/menu.svg",
    "images/zram.svg",
    "line_chart/line_chart.css",
  ]

  ts_files = [
    "constants.js",
    "index.js",
    "main.js",
    "types.js",
    "line_chart/constants.js",
    "line_chart/data_series.js",
    "line_chart/line_chart.js",
    "line_chart/menu.js",
    "line_chart/scrollbar.js",
    "line_chart/sub_chart.js",
    "line_chart/unit_label.js",
  ]
}
