import("//ui/webui/resources/tools/build_webui.gni")

assert(is_chromeos)

build_webui("build") {
  grd_prefix = "slow"

  static_files = [
    "slow.css",
    "slow.html",
  ]

  ts_files = [ "slow.js" ]

  ts_deps = [
    "//ash/webui/common/resources:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]

  webui_context_type = "trusted"
}
