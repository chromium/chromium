import("//components/signin/features.gni")
import("//ui/webui/resources/tools/build_webui.gni")

assert(enable_dice_support)

build_webui("build") {
  grd_prefix = "intro"

  static_files = [
    "animations/signin_benefits_dark_bottom.json",
    "animations/signin_benefits_dark_left.json",
    "animations/signin_benefits_dark_right.json",
    "animations/signin_benefits_light_bottom.json",
    "animations/signin_benefits_light_left.json",
    "animations/signin_benefits_light_right.json",
    "finish_or_continue/finish_or_continue.html",
    "sign_in_celebration/sign_in_celebration.html",
    "default_browser/default_browser.html",
    "default_browser/default_browser_refresh.html",
    "images/default_browser_bg_bottom_dark.svg",
    "images/default_browser_bg_bottom_light.svg",
    "images/default_browser_bg_right_dark.svg",
    "images/default_browser_bg_right_light.svg",
    "images/default_browser_frame.svg",
    "images/default_browser_frame_dark.svg",
    "images/refresh_showcase_illustration_chromium.png",
    "intro.html",
    "intro_refresh.html",
  ]

  ts_files = [
    "browser_proxy.ts",
    "intro_browser_proxy.ts",
    "default_browser/browser_proxy.ts",
  ]

  if (enable_dice_support) {
    static_files += [
      "images/cloud_upload.svg",
      "images/devices.svg",
    ]

    if (!is_chrome_branded) {
      static_files += [ "images/security.svg" ]
    }

    ts_files += [
      "finish_or_continue/app.html.ts",
      "finish_or_continue/app.ts",
      "sign_in_celebration/app.html.ts",
      "sign_in_celebration/app.ts",
      "sign_in_celebration/sign_in_celebration_browser_proxy.ts",
      "default_browser/app.html.ts",
      "default_browser/app.ts",
      "default_browser/app_refresh.html.ts",
      "default_browser/app_refresh.ts",
      "intro_app.html.ts",
      "intro_app.ts",
      "sign_in_promo.html.ts",
      "sign_in_promo.ts",
      "sign_in_promo_refresh.html.ts",
      "sign_in_promo_refresh.ts",
    ]

    css_files = [
      "default_browser/app.css",
      "default_browser/app_refresh.css",
      "finish_or_continue/app.css",
      "intro_app.css",
      "sign_in_celebration/app.css",
      "sign_in_promo.css",
      "sign_in_promo_refresh.css",
    ]
  }

  ts_definitions = [ "//tools/typescript/definitions/chrome_send.d.ts" ]
  ts_composite = true
  ts_deps = [
    "//chrome/browser/resources/signin:build_ts",
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  mojo_files_deps =
      [ "//chrome/browser/ui/webui/intro:mojo_bindings_ts__generator" ]
  mojo_files = [
    "$root_gen_dir/chrome/browser/ui/webui/intro/intro.mojom-webui.ts",
    "$root_gen_dir/chrome/browser/ui/webui/intro/sign_in_celebration.mojom-webui.ts",
  ]

  ts_path_mappings = [ "chrome://intro/tangible_sync_style_shared.css.js|" + rebase_path(
                           "$root_gen_dir/chrome/browser/resources/signin/tsc/tangible_sync_style_shared.css.d.ts",
                           target_gen_dir) ]

  webui_context_type = "trusted"
}
