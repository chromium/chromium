import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "support_tool"

  static_files = [
    "support_tool_container.html",
    "url_generator_container.html",
  ]

  ts_files = [
    "browser_proxy.ts",
    "data_collectors.html.ts",
    "data_collectors.ts",
    "data_export_done.html.ts",
    "data_export_done.ts",
    "issue_details.html.ts",
    "issue_details.ts",
    "pii_selection.html.ts",
    "pii_selection.ts",
    "spinner_page.html.ts",
    "spinner_page.ts",
    "support_tool.html.ts",
    "support_tool.ts",
    "support_tool_page_mixin_lit.ts",
    "url_generator.html.ts",
    "url_generator.ts",
  ]

  css_files = [
    "data_collectors.css",
    "data_export_done.css",
    "issue_details.css",
    "pii_selection.css",
    "spinner_page.css",
    "support_tool_shared_lit.css",
    "url_generator.css",
    "support_tool.css",
  ]

  icons_html_files = [ "icons.html" ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]

  ts_definitions = [ "//tools/typescript/definitions/chrome_send.d.ts" ]
  ts_composite = true
  webui_context_type = "trusted"
}
