import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "private_state_tokens"

  static_files = [ "app.html" ]

  non_web_component_files = [ "app.ts" ]
  generate_grdp = true
  grd_resource_path_prefix = "private_state_tokens"
}
