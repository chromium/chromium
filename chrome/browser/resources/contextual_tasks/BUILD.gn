import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "contextual_tasks"

  static_files = [ "contextual_tasks.html" ]

  ts_files = [
    "app.ts",
    "app.html.ts",
  ]

  ts_deps = [ "//third_party/lit/v3_0:build_ts" ]

  webui_context_type = "trusted"
}
