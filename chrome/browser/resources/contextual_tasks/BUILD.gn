import("//ui/webui/resources/tools/build_webui.gni")

if (is_chrome_branded) {
  generate_grd("build_icons_grdp") {
    grd_prefix = "lens_untrusted_icons"
    out_grd = "$target_gen_dir/icon_resources.grdp"
    input_files = [ "encrypted.svg" ]
    input_files_base_dir =
        rebase_path("//chrome/app/theme/google_chrome/lens/", "//")
  }
}

build_webui("build") {
  grd_prefix = "contextual_tasks"

  static_files = [
    "contextual_tasks.html",
    "internals/contextual_tasks_internals.html",
  ]

  if (is_chrome_branded) {
    extra_grdp_deps = [ ":build_icons_grdp" ]
    extra_grdp_files = [ "$target_gen_dir/icon_resources.grdp" ]
  }

  ts_files = [
    "app.html.ts",
    "app.ts",
    "constants.ts",
    "contextual_tasks_browser_proxy.ts",
    "error_dialog.html.ts",
    "error_dialog.ts",
    "error_page.html.ts",
    "error_page.ts",
    "favicon_group.html.ts",
    "favicon_group.ts",
    "ghost_loader.ts",
    "ghost_loader.html.ts",
    "icons.html.ts",
    "internals/app.html.ts",
    "internals/app.ts",
    "internals/browser_proxy.ts",
    "onboarding_tooltip.html.ts",
    "onboarding_tooltip.ts",
    "post_message_handler.ts",
    "sources_menu.html.ts",
    "sources_menu.ts",
    "top_toolbar.html.ts",
    "top_toolbar.ts",
    "utils/clip_path.ts",
  ]

  if (!is_android) {
    ts_files += [
      "composebox.html.ts",
      "composebox.ts",
    ]
  }

  css_files = [
    "app.css",
    "error_dialog.css",
    "error_page.css",
    "favicon_group.css",
    "ghost_loader.css",
    "internals/app.css",
    "onboarding_tooltip.css",
    "sources_menu.css",
    "top_toolbar.css",
  ]

  if (!is_android) {
    css_files += [ "composebox.css" ]
  }

  mojo_files_deps =
      [ "//chrome/browser/contextual_tasks:mojo_bindings_ts__generator" ]
  mojo_files = [
    "$root_gen_dir/chrome/browser/contextual_tasks/contextual_tasks.mojom-webui.ts",
    "$root_gen_dir/chrome/browser/contextual_tasks/contextual_tasks_internals.mojom-webui.ts",
    "$root_gen_dir/chrome/browser/contextual_tasks/contextual_tasks_types.mojom-webui.ts",
  ]
  if (!is_android) {
    mojo_files += [ "$root_gen_dir/ui/webui/resources/cr_components/composebox/composebox.mojom-webui.ts" ]
    mojo_files_deps += [ "//ui/webui/resources/cr_components/composebox:mojo_bindings_ts__generator" ]
  }

  # Needed for browser_tests
  ts_composite = true

  ts_definitions = [
    "//tools/typescript/definitions/chrome_event.d.ts",
    "//tools/typescript/definitions/metrics_private.d.ts",
    "//tools/typescript/definitions/web_request.d.ts",
    "//tools/typescript/definitions/webview_tag.d.ts",
  ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
  if (!is_android) {
    ts_deps += [
      "//ui/webui/resources/cr_components/composebox:build_ts",
      "//ui/webui/resources/cr_components/localized_link:build_ts",
      "//ui/webui/resources/cr_components/search:build_ts",
    ]
  }

  webui_context_type = "trusted"
}
