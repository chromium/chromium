import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "context_hub"

  static_files = [ "context_hub.html" ]

  ts_files = [
    "app.ts",
    "app.html.ts",
    "browser_proxy.ts",
    "memory_banks/memory_banks.html.ts",
    "memory_banks/memory_banks.ts",
    "taskbox/ai_taskbox.html.ts",
    "taskbox/ai_taskbox.ts",
    "taskbox/todo_item.html.ts",
    "taskbox/todo_item.ts",
  ]

  css_files = [
    "app.css",
    "taskbox/ai_taskbox.css",
    "taskbox/todo_item.css",
  ]

  mojo_files_deps =
      [ "//chrome/browser/ui/webui/context_hub:mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/context_hub/context_hub.mojom-webui.ts" ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  webui_context_type = "trusted"
}
