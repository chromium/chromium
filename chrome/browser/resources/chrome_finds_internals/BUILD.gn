import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "chrome_finds_internals"

  static_files = [
    "index.html",
    "index.css",
  ]

  ts_files = [
    "app.ts",
    "app.html.ts",
    "constants.ts",
  ]

  css_files = [ "app.css" ]

  mojo_files_deps = [ "//chrome/browser/ui/webui/chrome_finds_internals:mojo_bindings_ts__generator" ]
  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/chrome_finds_internals/chrome_finds_internals.mojom-webui.ts" ]

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]
}
