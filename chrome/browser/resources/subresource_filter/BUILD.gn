import("//ui/webui/resources/tools/build_webui.gni")

build_webui("build") {
  grd_prefix = "subresource_filter_internals"

  static_files = [ "index.html" ]

  css_files = [ "app.css" ]

  ts_files = [
    "app.html.ts",
    "app.ts",
    "browser_proxy.ts",
  ]

  ts_definitions = [ "//tools/typescript/definitions/pending.d.ts" ]

  ts_composite = true

  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  mojo_files_deps = [
    "//chrome/browser/ui/webui/subresource_filter:mojo_bindings_ts__generator",
  ]
  mojo_files = [ "$root_gen_dir/chrome/browser/ui/webui/subresource_filter/subresource_filter_internals.mojom-webui.ts" ]

  webui_context_type = "trusted"
}
