import("//ui/webui/resources/tools/build_webui.gni")

assert(is_win || is_mac || is_linux)

out_dir = "$root_out_dir/resources/tts_engine"

copy("copy_tts_engine_files") {
  sources = [ "//third_party/wasm_tts_engine/src/bindings_main.js" ]
  outputs = [ "$out_dir/bindings_main.js" ]
}

build_webui("build") {
  grd_prefix = "tts_engine"
  non_web_component_files = [ "background.ts" ]
  ts_out_dir = "$out_dir"
  ts_extra_deps = [ ":copy_tts_engine_files" ]
}
