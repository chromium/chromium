import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android)

build_webui("build") {
  grd_prefix = "indigo"
  grd_resource_path_prefix = "indigo"
  webui_context_type = "trusted_only"

  static_files = [
    "index.html",
    "manifest.json",
  ]

  css_files = [
    "app.css",
    "motion_overlay.css",
  ]

  ts_files = [
    "app.html.ts",
    "app.ts",
    "motion_overlay.html.ts",
    "motion_overlay.ts",
  ]

  ts_deps = [ "//third_party/lit/v3_0:build_ts" ]
}
