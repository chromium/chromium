{
  "key": "",
  "manifest_version": 3,
  "name": "Indigo",
  "version": "1.0",
  "description": "Indigo Component Extension",
  "incognito": "not_allowed",
  "content_security_policy": {
    "extension_pages": "script-src 'self' chrome://resources; object-src 'self';"
  },
  "host_permissions": [
    "chrome://resources/"
  ]
}
