source_set("webapps") {
  sources = [
    "chrome_webapps_client.h",
    "web_app_offline.h",
  ]

  public_deps = [
    "//components/webapps/browser",
    "//content/public/browser",
    "//content/public/common",
    "//url",
  ]
}

source_set("impl") {
  sources = [
    "chrome_webapps_client.cc",
    "web_app_offline.cc",
  ]

  deps = [
    ":webapps",
    "//base",
    "//components/infobars/content",
    "//components/security_state/content",
    "//components/strings",
    "//components/webapps/browser",
    "//ui/base",
  ]

  if (is_android) {
    deps += [ "//chrome/browser:browser_public_dependencies" ]
  } else {
    deps += [
      "//chrome/browser/profiles:profile",
      "//chrome/browser/web_applications",
      "//chrome/browser/web_applications/proto",
    ]
  }

  if (is_mac || is_win || is_linux || is_chromeos) {
    deps += [ "//components/webapps/isolated_web_apps:scheme" ]
  }
}

if (is_android) {
  source_set("android") {
    sources = [
      "installable/installed_webapp_bridge.cc",
      "installable/installed_webapp_bridge.h",
      "installable/installed_webapp_geolocation_bridge.cc",
      "installable/installed_webapp_geolocation_bridge.h",
      "installable/installed_webapp_geolocation_context.cc",
      "installable/installed_webapp_geolocation_context.h",
      "installable/installed_webapp_provider.cc",
      "installable/installed_webapp_provider.h",
      "web_app_offline_android.cc",
      "webapps_client_android.cc",
      "webapps_client_android.h",
    ]

    deps = [
      ":impl",
      ":webapps",
      "//base",
      "//chrome/android:jni_headers",
      "//chrome/browser:browser_public_dependencies",
      "//chrome/browser/android:tabs_public",
      "//chrome/browser/feature_engagement",
      "//chrome/browser/notifications",
      "//chrome/common",
      "//components/content_settings/core/browser",
      "//components/content_settings/core/common",
      "//components/feature_engagement/public",
      "//components/infobars/content",
      "//components/permissions",
      "//components/security_state/content",
      "//components/webapps/browser",
      "//components/webapps/common",
      "//content/public/browser",
      "//mojo/public/cpp/bindings",
      "//services/device/public/cpp/geolocation",
      "//services/device/public/mojom",
      "//url",
    ]
  }
} else {
  source_set("desktop") {
    sources = [
      "webapps_client_desktop.cc",
      "webapps_client_desktop.h",
    ]

    deps = [
      ":impl",
      ":webapps",
      "//base",
      "//chrome/browser/banners",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/segmentation_platform",
      "//chrome/browser/user_education",
      "//chrome/browser/web_applications",
      "//chrome/common",
      "//components/infobars/content",
      "//components/security_state/content",
      "//components/webapps/browser",
      "//content/public/browser",
    ]
  }
}

source_set("installable_manager_browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "installable/installable_manager_browsertest.cc" ]

  deps = [
    "//base",
    "//base/test:test_support",
    "//chrome/browser/profiles:profile",
    "//chrome/test:test_support",
    "//components/webapps/browser",
    "//content/test:test_support",
    "//net:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//third_party/blink/public/common",
  ]

  if (!is_android) {
    deps += [
      "//chrome/browser/ui",
      "//chrome/test:test_support_ui",
    ]
  }
}

source_set("web_app_url_loader_browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "web_contents/web_app_url_loader_browsertest.cc" ]

  deps = [
    "//base",
    "//base/test:test_support",
    "//chrome/test:test_support",
    "//components/webapps/browser",
    "//content/public/browser",
    "//net:test_support",
    "//testing/gtest",
  ]

  if (!is_android) {
    deps += [ "//chrome/test:test_support_ui" ]
  }
}

group("browser_tests") {
  testonly = true

  deps = [
    ":installable_manager_browser_tests",
    ":web_app_url_loader_browser_tests",
  ]

  if (!is_android) {
    deps += [ ":ml_promotion_browser_tests" ]
  }
}

if (!is_android) {
  source_set("ml_promotion_browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [
      "installable/ml_promotion_browsertest.cc",
      "installable/ml_promotion_browsertest_base.cc",
      "installable/ml_promotion_browsertest_base.h",
    ]

    deps = [
      ":desktop",
      "//base",
      "//base/test:test_support",
      "//chrome/app:command_ids",
      "//chrome/browser",
      "//chrome/browser/banners:test_support",
      "//chrome/browser/ui",
      "//chrome/browser/user_education",
      "//chrome/browser/web_applications",
      "//chrome/browser/web_applications:web_applications_test_support",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//components/segmentation_platform/public",
      "//components/segmentation_platform/public:test_support",
      "//components/ukm:test_support",
      "//components/user_education/common",
      "//components/webapps/browser",
      "//components/webapps/browser:test_support",
      "//content/public/browser",
      "//net:test_support",
      "//services/metrics/public/cpp:ukm_builders",
      "//testing/gmock",
      "//testing/gtest",
      "//third_party/blink/public/common",
      "//ui/views:test_support",
    ]
  }

  source_set("interactive_ui_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "web_app_offline_interactive_uitest.cc" ]

    deps = [
      ":desktop",
      "//base",
      "//base/test:test_support",
      "//chrome/browser",
      "//chrome/browser/ui",
      "//chrome/browser/web_applications",
      "//chrome/browser/web_applications:web_applications_test_support",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//components/metrics:content",
      "//components/webapps/browser",
      "//components/webapps/browser:test_support",
      "//content/test:test_support",
      "//net:test_support",
      "//testing/gmock",
      "//testing/gtest",
      "//ui/base",
      "//ui/gfx",
      "//ui/native_theme",
    ]

    if (is_chromeos) {
      deps += [ "//ash/public/cpp" ]
    }
  }

  source_set("unit_tests") {
    testonly = true
    sources = [ "installable/installable_utils_unittest.cc" ]

    deps = [
      "//base/test:test_support",
      "//chrome/browser/web_applications:web_app_test",
      "//chrome/browser/web_applications:web_applications_test_support",
      "//chrome/browser/webapps/installable",
      "//chrome/browser/webapps/installable:impl",
      "//testing/gmock",
      "//testing/gtest",
    ]
  }
}
