import("//chrome/common/features.gni")
import("//extensions/buildflags/buildflags.gni")

assert(enable_extensions)
assert(is_chromeos)

source_set("enterprise_platform_keys_private") {
  sources = [
    "enterprise_platform_keys_private_api.cc",
    "enterprise_platform_keys_private_api.h",
  ]

  configs += [ "//build/config/compiler:wexit_time_destructors" ]

  public_deps = [
    "//chrome/browser/ash/attestation",
    "//chromeos/ash/components/dbus/attestation:attestation_proto",
    "//chromeos/ash/components/dbus/constants",
    "//extensions/browser",
    "//extensions/common",
  ]

  deps = [
    "//base",
    "//chrome/browser/ash/profiles",
    "//chrome/browser/extensions",
    "//chrome/browser/profiles:profile",
    "//chrome/common:constants",
    "//chrome/common/extensions/api",
    "//components/pref_registry",
    "//components/prefs",
    "//content/public/browser",
  ]
}

source_set("browser_tests") {
  testonly = true

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "enterprise_platform_keys_private_api_browsertest.cc" ]

  deps = [
    ":enterprise_platform_keys_private",
    "//base",
    "//chrome/browser/ash/attestation:test_support",
    "//chrome/browser/extensions",
    "//chrome/common/extensions/api",
    "//chrome/test:test_support",
    "//content/test:test_support",
    "//extensions/browser",
    "//extensions/common",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
