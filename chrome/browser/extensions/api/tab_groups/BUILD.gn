import("//extensions/buildflags/buildflags.gni")

assert(enable_extensions_core)

source_set("tab_groups") {
  sources = [
    "tab_groups_api.cc",
    "tab_groups_api.h",
    "tab_groups_event_router.cc",
    "tab_groups_event_router.h",
    "tab_groups_event_router_factory.cc",
    "tab_groups_event_router_factory.h",
  ]

  configs += [ "//build/config/compiler:wexit_time_destructors" ]

  public_deps = [
    "//extensions/browser",
    "//extensions/buildflags",
  ]

  deps = [
    "//base",
    "//chrome/browser/extensions",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/tab_group_sync:factories",
    "//chrome/browser/tab_list",
    "//chrome/browser/ui",
    "//chrome/browser/ui:ui_features",
    "//chrome/browser/ui/browser_window",
    "//chrome/common/extensions",
    "//chrome/common/extensions/api",
    "//components/tab_groups",
    "//components/tabs:public",
    "//content/public/browser",
    "//extensions/common",
    "//ui/gfx/range",
  ]

  if (is_android) {
    deps += [ "//chrome/browser/ui/android/tab_model" ]
  } else {
    deps += [
      "//chrome/browser/ui:browser_tab_strip",
      "//chrome/browser/ui/tabs:tab_group",
      "//chrome/browser/ui/tabs:tab_model",
      "//chrome/browser/ui/tabs:tab_strip",
      "//chrome/browser/ui/tabs:tab_strip_model_observer",
      "//chrome/browser/ui/tabs/saved_tab_groups",
    ]
  }

  if (is_mac || is_win || is_linux || is_chromeos) {
    deps += [ "//components/webapps/isolated_web_apps:scheme" ]
  }
}
