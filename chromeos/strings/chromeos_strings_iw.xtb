<translation id="6740695858234317715">ОДОеОЮ ОЋОЏОфОЋОЮ</translation>
<translation id="6741823073189174383">ОАОЎОеОћ</translation>
<translation id="6744441848304920043">Оњ'ОЋОаОњОю</translation>
<translation id="6747035363363040417">ОаОЎОЎОўОеОюОЎ</translation>
<translation id="6747215703636344499">ОћОцОАОЎОДОћ РђЊ ОъОњОЕ ОћОцОюОў ОъОюОљ</translation>
<translation id="6749473226660745022">ОфОъОЋОаОЋОф</translation>
<translation id="6752960629591143793">ОдОеОЎОџ ОюОЉОЌОЋОе ОљОф ОЕОцОф ОћОфОъОюОЎОю ОЋОюОћОЋОеОЎОЊ ОЉОћОњОЊОеОЋОф ОљОЋ ОЉОфОцОеОЎОў <ph name="THREE_DOTS_MENU_ICON" /></translation>
<translation id="6753452347192452143">ОћОъОЏОЕОЎОе ОћОЋОљ ОъОЌОЕОЉ.</translation>
<translation id="6756731097889387912">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЉОўОю ОљОф ОћОАОеОЎОДОћ</translation>
<translation id="6760706756348334449">ОћОЌОюОЕОф ОбОЋОдОъОф ОћОДОЋОю</translation>
<translation id="6761537227090937007">ОћОъОбОеОЏОф ОЎОЋОдОеОф ОфОъОЋОаОћ ОЉОеОќОЋОюОЋОдОЎОћ ОњОЉОЋОћОћРђд</translation>
<translation id="6766275201586212568">РђЈОЉОДОЕОЋОф ОюОќОЎОћОЋОЎ DNS ОЕОаОЏОЕОюОЋ</translation>
<translation id="6768237774506518020">РђЈОЕОЎОбОЋОе ОЏОЎОЕОюОЋОЪ ОњОЉОЋОћ ОюОаОАОЎОЋОаОЋОф ОќОЎОћОЋОЎ DNS</translation>
<translation id="6786747875388722282">ОфОЋОАОцОЎОЮ</translation>
<translation id="6791471867139427246">ОдОЉОб ОћОфОљОЋОеОћ ОЕОю ОћОъОДОюОЊОф</translation>
<translation id="6796229976413584781">ОъОДОЕ ОћОДОЎОдОЋОе ОаОъОЌОД</translation>
<translation id="6798678288485555829">ОаОЎОЋОЋОў ОЉОўОДОАОў</translation>
<translation id="680983167891198932">ОъОДОЕ</translation>
<translation id="6816797338148849397">ОЎОЕ ОъОЎОЊОб ОЉОДОЕОе ОюОЉОЌОЎОеОћ ОЕОюОџ. ОЏОЊОЎ ОюОњОЕОф ОљОюОЎОЋ, ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОбОюОћ.</translation>
<translation id="6831043979455480757">ОфОеОњОЋОЮ</translation>
<translation id="6846843854964504403">ОљОЎОцОЋОА ОћОњОЊОеОЋОф ОћОљОЉОўОЌОћ</translation>
<translation id="6853312040151791195">ОЕОЎОбОЋОе ОћОцОеОЎОДОћ</translation>
<translation id="6862228900689076919">ОћОфОЏОЋОаОћ ОћОќОЋ ОъОаОЋОћОюОф ОбОю-ОЎОЊОЎ ОћОљОЊОъОЎОЪ</translation>
<translation id="6862416241246624313">ОћОъОЕОЋОЉ ОаОЕОюОЌ</translation>
<translation id="6866732840889595464">ОЌОЎОаОаОЎОф</translation>
<translation id="6871256179359663621">ОЉОдОЉОб ОАОњОЋОю ОЉОћОЎОе</translation>
<translation id="6887967050249348172">ОћОфОЋОАОцОЎОЮ ОъОЋОЕОЉОфОЎОЮ ОЏОЊОЎ ОюОъОаОЋОб ОЕОЎОаОЋОЎОЎОЮ ОЉОћОњОЊОеОЋОф. ОЌОЕОЋОЉ ОюОћОцОбОЎОю ОеОД ОфОЋОАОцОЎОЮ ОъОћОЎОъОаОЎОЮ.</translation>
<translation id="6889786074662672253">ОЉОъОћОюОџ ОћОћОцОбОюОћ ОъОЌОЊОЕ ОљОЎОЪ ОюОаОфОД ОљОф ОћОъОЏОЕОЎОе ОћОЌОЎОдОЋОаОЎ ОћОќОћ ОљОЋ ОюОЏОЉОЋОф ОљОф ОћОъОЌОЕОЉ. ОљОцОЕОе ОюОъОќОбОе ОљОф ОћОЌОюОЋОЪ ОћОќОћ. ОћОцОбОЋОюОћ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОЏОъОћ ОЊОДОЋОф ОЋОЎОЏОЋОю ОюОћОЎОЋОф ОЕОћОъОЏОЕОЎОе ОћОЌОЎОдОЋОаОЎ ОюОљ ОЎОцОбОю ОЉОќОъОЪ ОћОќОћ.</translation>
<translation id="6899460405678814458">ОћОдОњОф ОћОАОЎОЏОЋОЮ</translation>
<translation id="6900701049656042631">ОљОЎОЪ ОфОъОЋОаОЋОф ОЉОљОюОЉОЋОЮ ОћОќОћ. ОЏОЊОЎ ОюОћОЋОАОЎОБ ОфОъОЋОаОћ, ОдОеОЎОџ ОюОбОЉОЋОе ОљОю <ph name="LINK" /></translation>
<translation id="6902359863093437070">РђЈОЎОдОЎОеОф ОеОДОб ОЉОљОъОдОбОЋОф AI</translation>
<translation id="6905163627763043954">ОаОАОћ ОќОљОф</translation>
<translation id="6905724422583748843">ОЌОќОеОћ ОљОю <ph name="PAGE_NAME" /></translation>
<translation id="6910312834584889076">ОћОъОЏОАОћ ОЕОю ОћОАОЋОеОД ОцОфОЋОЌ. ОЎОЕ ОюОАОњОЋОе ОљОЋОфОЋ ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="6910845598686542904">ОюОЌОЕОЉ ОъОЋОЊОюОЎОЮ ОЕОю ОћОДОЋОюОЋОф ОЕОќОЋОћОЋ ОЉОћОДОюОўОћ</translation>
<translation id="6911383237894364323">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОЕОеОфОЎ ОъОЊОЎОћ</translation>
<translation id="6930242544192836755">ОъОЕОџ ОћОЌОЎОЉОЋОе</translation>
<translation id="6930597342185648547">ОъОЎОЊОб ОбОю ОћОеОДОб ОЕОаОЉОЌОе</translation>
<translation id="6939766318048400022">ОЉОЎОф ОДОцОћ</translation>
<translation id="6942253772720771875">ОаОЕОъОЌ ОюОДОЉОю ОъОъОџ ОъОЕОЋОЉ ОљОЋ ОфОЎОљОЋОе ОЕОю ОћОЉОбОЎОћ</translation>
<translation id="6943893908656559156">ОќОћОЋОф ОъОеОЌОЋОД (ОљОЋОцОдОЎОЋОаОюОЎ)</translation>
<translation id="6953137545147683679">ОќОћОЉ</translation>
<translation id="6957231940976260713">ОЕОЮ ОЕОЎОеОЋОф</translation>
<translation id="695776212669661671">ОЌОЦ ОЎОъОЎОаОћ</translation>
<translation id="6957792699151067488">ОцОеОЌ</translation>
<translation id="6961170852793647506">ОЏОЊОЎ ОюОћОфОЌОЎОю, ОъОаОЎОЌОЎОЮ ОљОф ОћОъОАОъОџ ОбОю ОћОАОЋОеОД</translation>
<translation id="6965382102122355670">ОљОЎОЕОЋОе</translation>
<translation id="6965978654500191972">ОъОЏОЕОЎОе</translation>
<translation id="6972754398087986839">ОфОЌОЎОюОф ОћОбОЉОЋОЊОћ</translation>
<translation id="6975620886940770104"><ph name="GLOWSCAPES_LANDSCAPE" /> ОбОЮ <ph name="GLOWSCAPES_FEATURE" /> ОЉОњОЋОЋОаОЎОЮ ОќОЋОћОеОЎОЮ</translation>
<translation id="6975981640379148271">ОДОЋОљОюОЋОф</translation>
<translation id="6977381486153291903">ОЕОЏОфОЋОЉ ОДОЋОЕОЌОћ</translation>
<translation id="6978396562261420054">РђЈОфОъОЋОаОћ ОЕОаОЋОдОеОћ ОЉОљОъОдОбОЋОф AI</translation>
<translation id="6981982820502123353">ОаОњОЎОЕОЋОф</translation>
<translation id="6982462588253070448">ОЊОЎОЋОаОЋОф ОЌОЋОю</translation>
<translation id="7005833343836210400">ОћОъОЏОЕОЎОе ОЉОъОдОЉ ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="7028979494427204405">ОћОаОЎОћОЋОю ОЕОю ОћОъОЏОЕОЎОе ОћОќОћ ОъОфОЉОдОб ОъОћОЊОЋОъОЎОЎОЪ <ph name="MANAGER" /> ОЋОљОцОЕОе ОюОњОЕОф ОъОъОаОЋ ОљОю ОЏОю ОћОъОЎОЊОб ОбОю ОћОцОбОЎОюОЋОф ОЕОю ОћОъОЕОфОъОЕОЎОЮ, ОЏОЋОюОю ОЊОцОЎ ОљОЎОаОўОеОаОў ОЕОаОЏОаОАОф ОљОюОЎОћОЮ, ОАОЎОАОъОљОЋОф ОЋОљОЎОъОЎОЎОю.</translation>
<translation id="7035168792582749309">ОфОцОЋОЌОЎ ОљОЊОъОћ</translation>
<translation id="7040230719604914234">ОАОцОД</translation>
<translation id="7040729769968826896">ОћОцОбОюОф ОќОЎОћОЋОЎ ОћОЊОЋОЉОе</translation>
<translation id="7041549558901442110">ОћОъОЏОЕОЎОе ОюОљ ОъОЌОЋОЉОе.</translation>
<translation id="704183341263526038">ОЏОЋОЏОЉ ОдОЊОД</translation>
<translation id="7046522406494308071">ОюОљОцОА ОљОф ОЏОю ОДОЎОдОЋОеОЎ ОћОЊОеОџ ОюОЉОеОЎОеОЋОф ОћОъОЌОЊОю?</translation>
<translation id="7049916119678019302">ОљОцОЕОе ОюОћОЋОеОЎОЊ ОљОф ОъОЋОЊОю ОћОфОъОюОЋОю ОЉОћОњОЊОеОЋОф</translation>
<translation id="7058278511608979688">ОАОЎОЋОЮ ОЋОЕОъОЎОеОћ</translation>
<translation id="7059230779847288458">ОЉОўОбОЎОаОћ, <ph name="TIME_VALUE" /> ОбОЊ ОюОўОбОЎОаОћ ОъОюОљОћ</translation>
<translation id="7064209589142995848">ОћОбОЉОеОф ОфОЋОЏОЪ</translation>
<translation id="7065336548231472971">ОЉОЌОеОф <ph name="LANGUAGE_NAME" /></translation>
<translation id="7066538517128343186">ОъОДОЕ <ph name="KEY" /></translation>
<translation id="7068619307603204412">ОћОЏОаОф ОћОъОЏОЕОЎОе</translation>
<translation id="7076851914315147928">ОЉОЌОЎОеОф ОўОцОў</translation>
<translation id="708426984172631313">ОћОЋОцОАОДОћ</translation>
<translation id="7086168019478250425">ОЌОЋОБ ОбОЮ ОљОЋо╣ОеОЋо╝Оф ОЉОЎОЋОюОЋОњОЎОф</translation>
<translation id="7086440545492620869"><ph name="VALUE" /> <ph name="DISPLAY_NAME" /></translation>
<translation id="7097908713073775559">ОдОЉОбОЋОаОЎ</translation>
<translation id="710028965487274708">ОаОЏОЕОю РђЊ ОћОћОеОЕОљОћ ОаОЏОЕОюОћ</translation>
<translation id="7101959270679078188">ОЏОЊОЎ ОюОћОъОЕОЎОџ ОЉОфОћОюОЎОџ ОћОбОЊОЏОЋОЪ, ОдОеОЎОџ ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю <ph name="DEVICE_NAME" /></translation>
<translation id="7103252855940681301">ОъОЏОЕОЎОе <ph name="INDEX" /> ОъОфОЋОџ <ph name="COUNT" /> ОЉОЕОЮ <ph name="NAME" />.</translation>
<translation id="7103793063702494489">ОћОЕОцОћ ОЕОЉОЌОеОф</translation>
<translation id="7107255225945990211">ОЉОЌОЎОеОф ОЎОдОЎОеОЋОф ОљОЋОъОаОЋОф ОЉОюОбОЊОЎОЋОф ОЉ-<ph name="PRODUCT_NAME" /></translation>
<translation id="7108668606237948702">ОћОќОаОф ОъОцОфОЌ</translation>
<translation id="7117228822971127758">ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="7118522231018231199">РђЈОЌОЕОЋОЉ ОюОЉОЌОЋОе ОаОДОЋОЊОЋОф APN ОЕОАОЋОцОДОЋ ОбОю ОЎОЊОЎ ОАОцОД ОћОАОюОЋОюОе ОљОЋ ОћОљОЊОъОЎОЪ. ОЉОЌОЎОеОф Оћ-APN ОфОЕОЉОЎОф ОљОф ОЏОю ОаОДОЋОЊОЋОф Оћ-APN ОЉОћОфОљОъОћ ОљОЎОЕОЎОф. ОаОДОЋОЊОЋОф APN ОюОљ ОфОДОЎОаОЋОф ОбОюОЋОюОЋОф ОюОЕОЉОЕ ОљОф ОћОЌОЎОЉОЋОе ОюОеОЕОф ОћОАОюОЋОюОеОЎОф.</translation>
<translation id="7119389851461848805">ОћОцОбОюОћ</translation>
<translation id="7129287270910503851">ОаОфОЋОаОЎ ОћОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ ОЎОљОЋОцОАОЋ ОъОЊОЎ ОЌОЋОЊОЕ ОЉОЎОЋОЮ ОћОќОћ</translation>
<translation id="7130438335435247835">РђЈОЕОЮ ОаОДОЋОЊОф ОћОњОЎОЕОћ (APN)</translation>
<translation id="7134436342991564651">{0,plural, =1{ОЕОеОф ОЕОъОЋОф}one{ОЕОеОфОЎ ОЕОъОЋОф}two{ОЕОеОфОЎ ОЕОъОЋОф}other{ОЕОеОфОЎ ОЕОъОЋОф}}</translation>
<translation id="7135814714616751706">ОЌОЎОцОЋОЕ ОъОДОЕОЎ ОДОЎОдОЋОе</translation>
<translation id="7138614237884624401">ОўОДОАОў ОцОЕОЋОў</translation>
<translation id="7138668887584231801">ОЎОЕ ОъОбОў ОъОЊОЎ ОъОЎОюОЎОЮ ОЏОЊОЎ ОюОЎОдОЋОе ОАОЎОЏОЋОЮ</translation>
<translation id="7143207342074048698">ОъОфОЉОдОб ОЌОЎОЉОЋОе</translation>
<translation id="7144878232160441200">ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="7144954474087165241">ОцОњОЋОЊОћ</translation>
<translation id="7147557737960578492">ОљОцОЕОе ОюОћОДОдОЋОф ОъОЌОЊОЕ ОЉОљОъОдОбОЋОф ОЉОЌОЎОеОћ ОЕОю ОъОДОЕ ОЌОЊОЕ</translation>
<translation id="714876143603641390">РђЈОДОЎОЕОЋОеОЎОЋОф LAN</translation>
<translation id="7154020516215182599">ОаОЕОъОЌ ОюОДОЉОю ОъОъОџ ОъОЕОЋОЉ ОљОЋ ОфОЎОљОЋОе ОЕОю ОћОЉОбОЎОћ. ОљОЮ ОљОцОЕОе, ОЎОЕ ОюОЏОюОЋОю ОљОф ОћОЕОюОЉОЎОЮ ОюОЕОЌОќОЋОе ОћОЉОбОЎОћ.</translation>
<translation id="7155171745945906037">ОфОъОЋОаОћ ОДОЎОЎОъОф ОъОъОдОюОъОћ ОљОЋ ОъОДОЋОЉОЦ</translation>
<translation id="7162487448488904999">ОњОюОеОЎОћ</translation>
<translation id="7170236477717446850">ОфОъОЋОаОф ОцОеОЋОцОЎОю</translation>
<translation id="7171919371520438592">ОДОЎОЉОЋОб ОћОЌОюОЋОЪ ОЉОЌОюОД ОћОДОўОЪ ОЎОЋОфОе ОЉОдОЊ <ph name="DIRECTION" /> ОЕОю ОћОъОАОџ</translation>
<translation id="7172721935181587524">ОфОъОЋОаОћ ОљОЌОф</translation>
<translation id="7177485034254901881">ОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОќОћ ОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="MANAGER" />. ОъОаОћОюОЎ ОъОбОеОЏОф ОбОЕОЋОЎОЎОЮ ОюОћОњОЊОЎОе ОљОф ОћОъОЏОЕОЎОе ОћОќОћ ОъОеОЌОЋОД.</translation>
<translation id="7180611975245234373">ОеОбОаОЋОЪ</translation>
<translation id="7180865173735832675">ОћОфОљОъОћ ОљОЎОЕОЎОф</translation>
<translation id="7182063559013288142">ОаОДОЋОЊОф ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎОф</translation>
<translation id="7184043045742675738">ОЏОЊОЎ ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОљОф ОћОЏОцОфОЋОе, ОюОЋОЌОдОЎОЮ ОбОю ОъОДОЕ ОЏОюОЕОћОЋ. ОъОЕОаОЎОЮ ОљОф ОъОЎОДОЋОЮ ОћОъОДОЕ ОЉОљОъОдОбОЋОф ОћОбОЏОЉОе ОљОЋ ОъОДОЕОЎ ОћОЌОЎОдОЎОЮ.</translation>
<translation id="7187669805838282391">ОЉОЎОЋОЮ ОеОЉОЎОбОЎ</translation>
<translation id="7205318498545665455">ОЉОЌОЎОеОф ОћОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="7206979415662233817">ОфОаОљОЎОЮ ОЋОћОњОЉОюОЋОф</translation>
<translation id="7210635925306941239">ОдОЎОљОЪ</translation>
<translation id="7212547870105584639">РђЈОаОЎОћОЋОю ОћОњОЊОеОЋОф APN ОЕОю ОћОеОЕОф. ОаОДОЋОЊОЋОф APN ОЎОЋОдОеОЋОф ОЌОЎОЉОЋОе ОЉОЎОЪ ОеОЕОф ОАОюОЋОюОеОЎОф ОюОЉОЎОЪ ОћОљОЎОаОўОеОаОў. <ph name="BEGIN_LINK_LEARN_MORE" />ОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK_LEARN_MORE" /></translation>
<translation id="7212734716605298123">ОбОЊОЏОЋОаОЎ ОДОЋОЕОЌОћ ОюОъОЏОЕОЎОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ</translation>
<translation id="7216409898977639127">ОАОцОД ОЕОЎОеОЋОф ОАОюОЋОюОеОЎ</translation>
<translation id="7223952304612664117">ОћОљОЎОЕОЋОе ОъОљОцОЕОе ОюОЕОЎОеОЋОфОЎ ОћОъОбОеОЏОф ОюОћОЕОфОъОЕ ОЉОћОњОЊОеОћ 'ОДОЉОЎОбОф ОъОЎОДОЋОЮ ОЎОЋОфОе ОъОЊОЋОЎОДОф' ОЏОЊОЎ ОюОДОЉОЋОб ОљОф ОћОъОЎОДОЋОЮ ОЕОюОџ. ОћОћОњОЊОеОћ 'ОДОЉОЎОбОф ОъОЎОДОЋОЮ ОЎОЋОфОе ОъОЊОЋОЎОДОф' ОъОЕОфОъОЕОф ОЉОъОЎОЊОб ОбОю ОљОЋОфОЋОф ОљОюОЌОЋОўОЎОЎОЮ ОЋОЌОЎОЎОЕОаОЎОЮ ОЏОЊОЎ ОюОДОЉОЋОб ОљОф ОћОъОЎОДОЋОЮ ОЕОю ОћОъОЏОЕОЎОе.</translation>
<translation id="7233782086689993269">ОъОДОЕ ОћОДОЎОдОЋОе ОЕОЋОЌОќОе</translation>
<translation id="725133483556299729">ОЉОЌОЎОеОф ОљОЎОъОЎОЎОю</translation>
<translation id="7255187042098209569">ОЋОеОЋОЊ ОЋОАОњОЋОю</translation>
<translation id="7267918995585557751">ОдОеОЎОџ ОюОљОцОА ОљОф ОћОћОњОЊОеОЋОф ОЏОЊОЎ ОюОЋОЋОЊОљ ОЕОЊОБ ОћОцОфОЎОЌОћ ОЕОъОЋОњОЊОе ОЏОЉОеОЎОеОф ОъОЌОЊОю ОћОЋОљ ОюОљ ОљОфОе ОцОЎОЕОЎОаОњ. ОъОЋОъОюОЦ ОюОћОЕОфОъОЕ ОеОД ОЉОљОфОеОЎОЮ ОъОћОЎОъОаОЎОЮ.</translation>
<translation id="7271000785316964275">ОДОюОљОАОЎОдОЎОАОўОЎ</translation>
<translation id="7271040990581020067">ОћОАОЋОеОД ОаОъОдОљ ОЉОЕОЎОъОЋОЕ ОЏОеОњОб. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="7271932918253517778">ОъОДОЕ ОДОЎОдОЋОе ОбОЮ ОъОДОЕОЎОЮ ОЉОЕОЋОеОћ ОћОбОюОЎОЋОаОћ ОдОеОЎОџ ОюОЏОюОЋОю ОљОф ОћОъОДОЕ '<ph name="META_KEY" />'.</translation>
<translation id="7274587244503383581"><ph name="PRINTED_PAGES_NUMBER" />/<ph name="TOTAL_PAGES_NUMBER" /></translation>
<translation id="7281657306185710294">ОљОЋОЋОЎОе ОюОаОЕОЎОъОћ</translation>
<translation id="7287310195820267359">ОљОЋОАОцОЎОЮ ОЕОю ОўОцОўОЎОЮ</translation>
<translation id="7293429513719260019">ОЉОЌОЎОеОф ОЕОцОћ</translation>
<translation id="7297226631177386107">РђЈОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОбОЮ ОЌОЋОъОф ОљОЕ ОюОљОфОеОЎ HTTPS</translation>
