<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1003363546227723021">ОЏОЕОћОъОАОџ ОюОљ ОцОбОЎОю, ОЎОЋОдОњОЋ ОЉОЋ ОфОъОЋОаОЋОф, ОћОЕОбОћ ОћОаОЋОЏОЌОЎОф, ОаОфОЋОаОЎ ОъОќОњ ОћОљОЋОЋОЎОе ОЋОцОеОўОЎ ОъОЊОЎОћ ОаОЋОАОцОЎОЮ</translation>
<translation id="1014750484722996375">ОЕОЋОюОЌОаОЋОф ОбОЉОЋОЊОћ ОЋОЎОеОўОЋОљОюОЎОЎОЮ</translation>
<translation id="1018219910092211213">РђЈОюОљ ОаОЎОфОЪ ОюОЎОдОЋОе ОеОќОЋОюОЋОдОЎОЎОф DNS</translation>
<translation id="1018656279737460067">ОЉОЋОўОю</translation>
<translation id="1020274983236703756">ОаОЋОАОцОЋ ОаОЏОАОЎОЮ ОЉОюОбОЊОЎОЎОЮ Ою-<ph name="PRODUCT_NAME" /></translation>
<translation id="1022628058306505708">ОќОеОЎОъОћ ОЉОЏОЊОЋОе ОћОљОеОЦ</translation>
<translation id="102432830749687801">РђЈОдОеОЎОџ ОюОћОбОЉОЎОе ОљОф ОћОаОфОЋОаОЎОЮ ОъОћОЌОЕОЉОЋОЪ ОћОЉОЎОф ОАОцОеОЎ ОюОЌОЕОЉОЋОЪ ОћОљОЎОЕОЎ ОбОЮ ОљОцОюОЎОДОдОЎОЎОф "ОћОбОЉОеОф ОфОЋОЏОЪ" ОЕОю Google ОюОцОаОЎ ОЕОћОњОЎОЕОћ ОљОюОЎОћОЮ ОфОљОЉОЊ.</translation>
<translation id="1026212596705997935">ОъОДОЕ ОћОДОЎОдОЋОе ОћОќОћ ОъОЕОъОЕ ОюОЉОЎОдОЋОб ОћОцОбОЋОюОћ '<ph name="CONFLICT_ACCEL_NAME" />'. ОбОюОЎОџ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОДОЎОдОЋОе ОљОЌОе. ОЏОЊОЎ ОюОћОЌОюОЎОБ ОљОф ОДОЎОдОЋОе ОћОЊОеОџ ОћОДОЎОЎОЮ, ОдОеОЎОџ ОюОћОДОЎОЕ ОЕОЋОЉ ОбОю ОъОДОЕ ОћОДОЎОдОЋОе ОћОќОћ.</translation>
<translation id="1030856839388844477">ОљОЎОцОЋОА ОћОЕОЎОъОЋОЕ ОЉОЌОЉОЎОюОф ОћОњОюОЎОЕОћ</translation>
<translation id="1047458377670401304">РђЈ<ph name="CPU_NAME" /> (<ph name="THREAD_COUNT" /> ОЕОеОЕОЋОеОЎОЮ, GHzРђЈ <ph name="CPU_MAX_CLOCK_SPEED" />)</translation>
<translation id="1047773237499189053">ОЎОЕ ОфОЏОЋОаОћ ОЌОЊОЕОћ. ОюОъОЎОЊОб ОаОЋОАОБ ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОбОюОћ.</translation>
<translation id="1049663189809099096">ОЉОдОЉОб ОдОћОЋОЉ ОцОАОўОю</translation>
<translation id="1053371972724535586">ОћОћОДОюОўОЋОф ОЕОюОЎ</translation>
<translation id="1056898198331236512">ОљОќОћОеОћ</translation>
<translation id="1059913517121127803">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОћОфОЌОЎОю ОљОф ОћОАОеОЎОДОћ</translation>
<translation id="1061864016440983342">ОЕОЎОъОЋОЕ ОюОюОљ ОъОЎОДОЋОЮ</translation>
<translation id="1062823486781306604"><ph name="INDEX" /> ОъОфОЋОџ <ph name="COUNT" />, <ph name="NAME" />.</translation>
<translation id="1069150558259542054">ОЏОЕОъОЋОАОЎОцОЎОЮ ОъОДОЕОЎ ОДОЎОдОЋОе ОъОЋОфОљОъОЎОЮ ОљОЎОЕОЎОф, ОљОЎ ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОъОДОЕ 'ОћОЋОАОцОћ ОъОћОЎОеОћ'.</translation>
<translation id="1070066693520972135">WEP</translation>
<translation id="1071587090247825784">ОќОЋОћОфОћ ОЌОЋОъОф ОљОЕ</translation>
<translation id="1075811647922107217">ОњОЋОЊОю ОћОЊОБ</translation>
<translation id="1082009148392559545">ОЕОЋОъОе ОћОъОАОџ ОЉОћОЋОеОЊОћ</translation>
<translation id="1094693127011229778">РђЈОЏОфОЋОЉОф Оћ-IP ОюОљ ОќОъОЎОаОћ</translation>
<translation id="1100902271996134409">ОћОфОъОЋОаОЋОф ОаОЋОдОеОЋОфРђд</translation>
<translation id="1116694919640316211">ОъОЎОЊОб ОЏОюОюОЎ</translation>
<translation id="1118572504348554005">ОЎОЏОЋОю ОюОћОЎОЋОф ОЕОаОЕОфОБ ОъОЕОЋОЉ ОЕОаОЕОюОЌ ОЉОљОъОдОбОЋОф ОћОўОЋОцОА ОћОќОћ ОбОЮ ОћОЕОЋОфОцОЎОЮ ОЕОюОаОЋ ОЏОЊОЎ ОюОфОДОЪ ОЉОљОњОЎОЮ ОЋОюОцОфОЋОе ОЉОбОЎОЋОф ОљОЌОеОЋОф ОЕОЊОЋОЋОЌОЋ. ОљОЎОЪ ОюОћОќОЎОЪ ОъОЎОЊОб ОеОњОЎОЕ ОЏОъОЋ ОАОЎОАОъОљОЋОф.</translation>
<translation id="1119403468619527527">ОЎОЕ ОъОбОў ОъОЊОЎ ОъОЎОюОЎОЮ ОЏОЊОЎ ОюОцОЕОў</translation>
<translation id="1119447706177454957">ОЕОњОЎОљОћ ОцОаОЎОъОЎОф</translation>
<translation id="1124772482545689468">ОъОЕОфОъОЕ</translation>
<translation id="1128128132059598906">EAP-TTLS</translation>
<translation id="1135805404083530719">ОЌОюОЋОаОЎОф ОћОеОЏОЎОЉОЎОЮ ОћОљОЎОаОўОеОљОДОўОЎОЉОЎОЎОЮ</translation>
<translation id="1145018782460575098">ОћОЌОюОЋОЪ ОЕОю ОбОЊОЏОЋОЪ ОћОДОЋОЕОЌОћ ОюОъОЏОЕОЎОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ ОцОфОЋОЌ. ОЎОЕ <ph name="NUM_UPDATES" /> ОбОЊОЏОЋОаОЎОЮ ОќОъОЎОаОЎОЮ.</translation>
<translation id="1145516343487477149">РђЈОЌОЎОцОЋОЕ ОЕОю ОъОљОъОеОЎ ОбОќОеОћ ОЋОфОЕОЋОЉОЋОф ОюОЕОљОюОЋОф ОаОцОЋОдОЋОф ОЉОаОЋОЕОљ Chromebook</translation>
<translation id="1154390310959620237">ОљОцОЕОе ОюОћОфОљОЎОЮ ОљОЎОЕОЎОф ОеОД 5 ОДОЎОдОЋОеОЎ ОЊОеОџ. ОбОюОЎОџ ОюОъОЌОЋОД ОДОЎОдОЋОе ОЊОеОџ ОЏОЊОЎ ОюОћОЋОАОЎОБ ОДОЎОдОЋОе ОЊОеОџ ОЌОЊОЕ.</translation>
<translation id="1155154308031262006">ОЏОљОЪ ОъОДОюОЎОЊОЎОЮ ОћОаОЌОЎОћ</translation>
<translation id="115705039208660697">ОљОаОаОАОЎОЮ</translation>
<translation id="1164939766849482256">ОЕОЋОъОе ОћОъОАОџ: ОъОбОюОЋОф ОћОЕОЌОе ОбОЊ ОюОеОЊОф ОћОЌОЋОЕОџ</translation>
<translation id="1167755866710282443">ОцОфОЎОЌОф ОћОфОцОеОЎОў ОюОћОфОљОъОћ ОљОЎОЕОЎОф ОЕОю ОћОъОцОфОЌОЋОф. ОЎОЕ ОюОњОеОЋОе ОљОф ОћОфОцОеОЎОў ОЏОЊОЎ ОюОћОќОЎОќ ОљОЋОфОЋ.</translation>
<translation id="1171349345463658120">ОюОњОЋОаОћ ОЌОЋОюОЎОф</translation>
<translation id="1174073918202301297">ОДОЎОдОЋОе ОћОЊОеОџ ОаОЋОАОБ</translation>
<translation id="11743817593307477">РђЈОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОъОДОЕОЎ ОћОЌОЎОдОЎОЮ ОЏОЊОЎ ОюОћОбОЉОЎОе ОљОф ОћОеОЏОЎОЉ ОћОљОЎОаОўОеОљОДОўОЎОЉОЎ ОћОќОћ ОюОцОбОЋОюОф ОћОъОЕОЌОД ОћОеОдОЋОЎОћ. ОъОдОЎОЉОЎОЮ ОљОф ОћОеОЏОЎОЉ ОЉОљОъОдОбОЋОф ОъОДОЕ Enter. ОЏОЊОЎ ОюОЉОўОю, ОљОцОЕОе ОюОћОЕОфОъОЕ ОЉОъОДОЕ Escape.</translation>
<translation id="1175697296044146566"><ph name="DEVICE_TYPE" /> ОќОћ ОъОаОЋОћОю ОбОю-ОЎОЊОЎ <ph name="MANAGER" />.</translation>
<translation id="1175951029573070619">ОъОъОЋОдОб (<ph name="SIGNAL_STRENGTH" />)</translation>
<translation id="1178581264944972037">ОћОЕОћОЎОћ</translation>
<translation id="1180621378971766337">ОЌОъОЎОЮ</translation>
<translation id="1181037720776840403">ОћОАОеОћ</translation>
<translation id="1191518099344003522">РђЈОћ-APN ОъОЋОцОбОю.</translation>
<translation id="1195447618553298278">ОЕОњОЎОљОћ ОюОљ ОЎОЊОЋОбОћ.</translation>
<translation id="1196264380943975940">ОюОљ ОаОЎОфОЪ ОюОАОЏОЮ. ОдОеОЎОџ ОюОаОАОЋОф ОфОъОюОЎОю ОљОеОЋОџ ОЎОЋОфОе.</translation>
