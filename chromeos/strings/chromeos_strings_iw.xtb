<translation id="4921665434385737356">ОћОфОЉОдОбОћ ОўОбОЎОаОћ ОЕОю <ph name="RATE" /> ОЉ-<ph name="NUM_SECONDS" /> ОЕОаОЎОЋОф.</translation>
<translation id="4930320165497208503">ОЏОЊОЎ ОюОћОњОЊОЎОе ОљОЋ ОюОбОЊОЏОЪ ОЌОЎОЉОЋОе, ОдОеОЎОџ ОюОбОЉОЋОе Ою<ph name="BEGIN_LINK" />ОћОњОЊОеОЋОф<ph name="END_LINK" />.</translation>
<translation id="4932733599132424254">ОфОљОеОЎОџ</translation>
<translation id="494102685638938793">РђФ<ph name="LINK_TEXT" />, ОцОфОЎОЌОћ ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ</translation>
