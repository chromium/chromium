<translation id="4861758251032006121">{ATTEMPTS_LEFT,plural, =1{<ph name="ERROR_MESSAGE" />. ОаОЋОфОе ОаОЎОАОЎОЋОЪ ОљОЌОЊ ({0})}one{<ph name="ERROR_MESSAGE" />. ОаОЋОфОеОЋ {0} ОаОЎОАОЎОЋОаОЋОф}two{<ph name="ERROR_MESSAGE" />. ОаОЋОфОеОЋ {0} ОаОЎОАОЎОЋОаОЋОф}other{<ph name="ERROR_MESSAGE" />. ОаОЋОфОеОЋ {0} ОаОЎОАОЎОЋОаОЋОф}}</translation>
