<translation id="5037240652947866174">ОћОЎОЋОЮ</translation>
<translation id="5038292761217083259">ОЏОЋОЋОаОЋОЪ ОћОдОЉОбОЎОЮ ОЉОъОДОюОЊОф</translation>
<translation id="5039804452771397117">ОќОћ ОЉОАОЊОе</translation>
<translation id="5049856988445523908">РђЈОЏОеОўОЎОА Оћ-SIM ОаОбОЋОю (<ph name="LOCK_TYPE" />)</translation>
<translation id="5050042263972837708">ОЕОЮ ОћОДОЉОЋОдОћ</translation>
<translation id="5051044138948155788">ОќОћОЋ ОћОЊОБ ОћОЎОЌОЎОЊ. ОцОбОЋОюОћ ОќОЋ ОфОбОЉОЎОе ОљОЋОфОџ ОљОю ОъОАОџ ОћОћОфОЌОюОћ ОЕОю ОћОАОеОЎОДОћ.</translation>
<translation id="5053233795640754917">ОћОЕОћОЎОћ</translation>
<translation id="5056587122125565772">ОЎОдОЎОеОф ОфОъОЋОаОћ</translation>
<translation id="5078711626843651677">ОфОЉОаОЎОЋОф ОћОДОЋОю ОаОЕОъОеОЋОф ОЉОљОЋОцОЪ ОќОъОаОЎ ОЉОъОЏОЕОЎОе ОбОЊ ОюОћОЕОюОъОф ОћОћОЋОАОцОћ ОЕОю ОћОфОЋОЋОЎОЋОф ОюОќОЎОћОЋОЎ ОћОЊОЋОЉОеОЎОЮ. ОљОцОЕОе ОюОћОЕОЉОЎОф ОљОф ОќОћ ОЉ'ОћОњОЊОеОЋОф' ОЉОЏОю ОЕОюОЉ.</translation>
<translation id="5078983345702708852">ОбОфОЎОЊОаОЎ</translation>
<translation id="5087864757604726239">ОћОДОЋОЊОЮ</translation>
<translation id="5088172560898466307">ОЕОЮ ОъОљОеОЌ ОЕОю ОЕОеОф</translation>
<translation id="5089810972385038852">ОъОЊОЎОаОћ</translation>
<translation id="5090362543162270857">IPsec (IKEv2)</translation>
<translation id="5095761549884461003">РђЈОЏОЊОЎ ОюОћОъОЕОЎОџ ОЉОфОћОюОЎОџ ОћОбОЊОЏОЋОЪ, ОдОеОЎОџ ОюОаОфОД ОљОф ОЏОЉОю Оћ-USB ОЕОю <ph name="DEVICE_NAME" /> ОЋОюОћОЏОаОЎОА ОљОЋОфОЋ ОЕОЋОЉ</translation>
<translation id="5099354524039520280">ОюОъОбОюОћ</translation>
<translation id="5107243100836678918">ОъОДОЕОЎ ОДОЎОдОЋОе ОЉОюОЎ ОћОъОДОЕ <ph name="META_KEY" /> ОбОюОЋОюОЎОЮ ОюОћОЎОЋОф ОЌОЋОцОцОЎОЮ ОюОъОДОЕОЎ ОћОДОЎОдОЋОе ОЉОљОцОюОЎОДОдОЎОћ ОЏОюОЕОћОЎ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОъОДОЕОЎ ОћОДОЎОдОЋОе ОћОљОюОћ ОЉОЏОю ОќОљОф, ОдОеОЎОџ ОюОћОДОЎОЕ ОбОюОЎОћОЮ ОЕОЋОЉ. ОљОЌОеОф, ОдОеОЎОџ ОюОћОДОЎОЕ ОбОю ОъОДОЕОЎ ОДОЎОдОЋОе ОЌОЊОЕОЎОЮ ОЕОЏОЋОюОюОЎОЮ ОљОф ОћОъОДОЕ <ph name="KEY" />. <ph name="LINK_BEGIN" />ОъОЎОЊОб ОаОЋОАОБ<ph name="LINK_END" /></translation>
<translation id="5107402373921342399">РђЈОљОЎ ОљОцОЕОе ОюОћОЋОеОЎОЊ ОљОф ОъОЋОЊОю ОћОфОъОюОЋОю ОЉ<ph name="LANGUAGE_NAME" />. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ ОљОЋ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Chromebook</translation>
<translation id="5108781503443873320">ОаОеОЊОцОЋОф:</translation>
<translation id="5121677070210013200">РђЈОюОљ ОаОЎОфОЪ ОюОћОЋОеОЎОЊ ОљОф ОъОЋОЊОю ОћОфОъОюОЋОю. ОдОеОЎОџ ОюОаОАОЋОф ОЕОЋОЉ ОљОЋ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Оћ-Chromebook.</translation>
