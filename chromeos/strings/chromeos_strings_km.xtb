<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1018656279737460067">бһ”бһ¶бһ“бһ”бҹ„бҹҮбһ”бһ„бҹӢ</translation>
<translation id="1059913517121127803">бһҳбһ·бһ“бһўбһ¶бһ…вҖӢбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҠбһҫбһҳвҖӢбһҹбҹ’бһҖбҹҒбһ“бһ”бһ¶бһ“бһ‘бҹҒ</translation>
<translation id="1071587090247825784">бһ”бһ¶бһ“бһҡбһҖбһғбһҫбһүвҖӢбһҮбһүбҹ’бһҮбһ¶бҹҶбһ„бһ—бҹ’бһӣбһҫбһ„</translation>
<translation id="1075811647922107217">бһ‘бҹҶбһ бҹҶвҖӢбһ‘бҹҶбһ–бҹҗбһҡ</translation>
<translation id="1124772482545689468">бһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫ</translation>
<translation id="1175697296044146566"><ph name="DEVICE_TYPE" /> бһ“бҹҒбҹҮбһҹбҹ’бһҗбһ·бһҸбһҖбҹ’бһҡбҹ„бһҳвҖӢбһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҡбһ”бһҹбҹӢ <ph name="MANAGER" />бҹ”</translation>
<translation id="1195447618553298278">бһҖбҹҶбһ бһ»бһҹбһҶбҹ’бһӮбһ„бһҳбһ·бһ“бһҹбҹ’бһӮбһ¶бһӣбҹӢбҹ”</translation>
<translation id="1204296502688602597">бһҖбһ¶бһҡбһ–бһ“бҹ’бһҷбһ¶бһҡ DNS</translation>
<translation id="1238612778414822719">бһҖбһ¶бһҡбһ–бһ“бҹ’бһҷбһ¶бһҡ HTTPS</translation>
<translation id="1290331692326790741">бһҹбҹҒбһңбһ¶бһҒбҹ’бһҹбҹ„бһҷ</translation>
<translation id="1330426557709298164">JPG</translation>
<translation id="1337912285145772892">бһ”бҹүбһ»бһ“вҖӢбһҖбһ“бҹ’бһӣбҹӮбһ„вҖӢбһҹбҹ’бһҖбҹҒбһ“</translation>
<translation id="1397738625398125236">бһўбһ¶бһ…бһ’бҹ’бһңбһҫбһҸбҹҒбһҹбҹ’бһҠбһ—бһёбһ„бһӣбһҫбһ…бҹ’бһҡбһҖбһ”бһ¶бһ“</translation>
<translation id="1398634363027580500">бһҖбһ¶бһҡбһ–бһ“бҹ’бһҷбһ¶бһҡ HTTPS бһҒбҹ’бһ–бһҹбҹӢбһҒбҹ’бһӣбһ¶бҹҶбһ„</translation>
<translation id="1413240736185167732">бһҳбһ·бһ“бһ”бһ¶бһ“бһҹбһҳбҹ’бһҡбҹҒбһ… - вҖӢбһҸбһҳбҹ’бһҡбһ„бһҳбһ¶бһ“бһ”бһүбҹ’бһ бһ¶</translation>
<translation id="1468664791493211953">бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҮбһјбһ“</translation>
<translation id="1476467821656042872"><ph name="MANAGER" /> бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„вҖӢбһ§бһ”бһҖбһҡбһҺбҹҚбһ“бҹҒбҹҮ бһ бһҫбһҷвҖӢбһ”бҹ’бһҡбһ бҹӮбһӣбһҮбһ¶бһўбһ¶бһ…вҖӢбһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–вҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ”бһ¶бһ“бҹ”</translation>
<translation id="1478594628797167447">бһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҹбҹ’бһҖбҹҒбһ“</translation>
<translation id="1499900233129743732"><ph name="MANAGER" /> бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„вҖӢбһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһ“бҹҒбҹҮ бһ“бһ·бһ„вҖӢбһўбһ¶бһ…бһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–бһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢ бһ“бһ·бһ„вҖӢбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„вҖӢбһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһ–бһёбһ…бһҳбҹ’бһ„бһ¶бһҷбһ”бһ¶бһ“бҹ”</translation>
<translation id="150962533380566081">PUK бһҳбһ·бһ“бһҸбҹ’бһҡбһ№бһҳбһҸбҹ’бһҡбһјбһңбҹ”</translation>
<translation id="1510238584712386396">бһЎбһ¶бһ“бҹӢбһҶбҹҗбһҡ</translation>
