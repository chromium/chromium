import("//build/config/chromeos/ui_mode.gni")

assert(is_chromeos_ash,
       "Non-Chrome-OS builds must not depend on //chromeos/ash")

static_library("babelorca") {
  sources = [
    "oauth_token_fetcher.cc",
    "oauth_token_fetcher.h",
    "token_data_wrapper.h",
    "token_fetcher.h",
    "token_manager.cc",
    "token_manager.h",
  ]

  deps = [
    "//base",
    "//components/signin/public/base",
    "//components/signin/public/identity_manager",
    "//google_apis",
  ]
}

source_set("test_support") {
  testonly = true

  sources = [
    "fake_token_fetcher.cc",
    "fake_token_fetcher.h",
  ]

  deps = [
    ":babelorca",
    "//base",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [
    "oauth_token_fetcher_unittest.cc",
    "token_manager_unittest.cc",
  ]

  deps = [
    ":babelorca",
    ":test_support",
    "//base",
    "//base/test:test_support",
    "//components/signin/public/base",
    "//components/signin/public/identity_manager:test_support",
    "//google_apis",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
