assert(is_chromeos)

static_library("receiver") {
  sources = [
    "boca_device_auth_token_service.cc",
    "boca_device_auth_token_service.h",
  ]

  deps = [
    "//base",
    "//google_apis",
    "//google_apis/common",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "boca_device_auth_token_service_unittest.cc" ]

  deps = [
    ":receiver",
    "//base",
    "//base/test:test_support",
    "//google_apis",
    "//google_apis/common",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
