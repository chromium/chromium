assert(is_chromeos, "Non-ChromeOS builds cannot depend on //chromeos")

component("usb") {
  defines = [ "IS_CHROMEOS_DBUS_IMPL" ]
  deps = [
    "//base",
    "//dbus",
  ]

  sources = [
    "fake_usbguard_client.cc",
    "fake_usbguard_client.h",
    "usbguard_client.cc",
    "usbguard_client.h",
    "usbguard_observer.h",
  ]
}
