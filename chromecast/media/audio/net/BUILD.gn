import("//chromecast/chromecast.gni")

cast_source_set("audio_socket_service") {
  sources = [
    "audio_socket_service.cc",
    "audio_socket_service.h",
  ]

  if (use_unix_sockets) {
    sources += [ "audio_socket_service_uds.cc" ]
  } else {
    sources += [ "audio_socket_service_tcp.cc" ]
  }

  deps = [
    "//base",
    "//net",
  ]
}
