<translation id="8457767749626250697">РђЈОЏОеОўОЎОА Оћ-SIM ОЕОюОџ ОаОбОЋОю</translation>
<translation id="8459404855768962328">ОюОљОЌОе ОћОбОфОДОф ОћОцОеОЎОў ОћОќОћ, ОћОЋОљ ОЎОЕОЋОфОБ ОбОЮ ОЏОю ОъОЎ ОЕОЎОЏОЋОю ОюОеОљОЋОф ОљОф ОћОфОЎОДОЎОЎОћ ОћОъОЕОЋОфОцОф '<ph name="DESTINATION_NAME" />'.</translation>
<translation id="8461467696380332069">ОЏОЊОЎ ОюОњОЕОф ОЉОъОћОЎОеОЋОф ОюОДОЉОдОЎОЮ ОЕОЉОъОЊОБ, ОЎОЕ ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОЎОъОаОЎОф ОбОю ОћОДОЋОЉОЦ ОЋОюОЉОЌОЋОе ОЉОљОцОЕОеОЋОф "ОћОдОъОЊОћ ОюОъОЊОБ".</translation>
<translation id="8461914792118322307">РђЈОЕОеОф proxy</translation>
<translation id="8463494891489624050">РђЈОъОДОюОЊОф ОЋОЎОЎОўОаОљОъОЎОф VIQR</translation>
<translation id="8475647382427415476">РђЈОю-Google Drive ОљОЎОЪ ОЏОеОњОб ОљОцОЕОеОЋОф ОюОАОаОЏОеОЪ ОљОф "<ph name="FILENAME" />". ОъОбОеОЏОф Google Drive ОфОаОАОћ ОќОљОф ОЕОЋОЉ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="8477649328507734757">ОАОЎОЉОЋОЉ</translation>
<translation id="8484284835977497781">ОљОцОЕОе ОюОЉОЌОЋОе ОцОеОЎОўОЎОЮ ОъОфОЋОџ ОћОфОъОЋОаОЋОф ОћОљОЌОеОЋОаОЋОф.</translation>
<translation id="8487700953926739672">ОќОъОЎОЪ ОљОЋОцОюОЎОЎОЪ</translation>
<translation id="8492972329130824181">ОћОеОЕОф ОћОЉОЎОфОЎОф ОљОЎОаОћ ОќОъОЎОаОћ. ОЎОЕ ОюОћОцОбОЎОю ОаОЊОЎОЊОћ ОЉОЌОЉОЎОюОф ОњОюОЎОЕОћ ОЏОЊОЎ ОюОћОфОЌОЉОе.</translation>
<translation id="8499098729323186194">ОъОфОЉОдОб ОЌОЎОюОЋОЦ ОЕОю <ph name="NUMBER_OF_ITEMS" /> ОцОеОЎОўОЎОЮРђд</translation>
<translation id="8521441079177373948">ОЉОеОЎОўОаОЎОћ</translation>
<translation id="853494022971700746">ОдОеОцОфОЎОф (ОдОеОцОф)</translation>
<translation id="8540608333167683902">РђЈОеОЕОф <ph name="NETWORK_INDEX" /> ОъОфОЋОџ <ph name="NETWORK_COUNT" />,РђЈ <ph name="NETWORK_NAME" />,РђЈ <ph name="CONNECTION_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: Рђј<ph name="SIGNAL_STRENGTH" />%Рђј, ОцОеОўОЎОЮ</translation>
<translation id="8545476925160229291">ОљОаОњОюОЎОф (ОљОеОћ"ОЉ)</translation>
<translation id="854655314928502177">РђЈОЏОфОЋОЉОф ОћОљОфОе ОюОњОЎОюОЋОЎ ОљОЋОўОЋОъОўОЎ ОЕОю ОЕОеОф proxy ОЉОљОЎОаОўОеОаОў:</translation>
<translation id="8549186985808798022">ОљОЎОўОюОДОЎОф</translation>
<translation id="8551494947769799688">ОюОўОЉОЎОф</translation>
<translation id="8560515948038859357">ОДОаОўОЋОаОќОЎОф</translation>
<translation id="8561206103590473338">ОцОЎОю</translation>
<translation id="8566466896628108558">ОеОЕОф <ph name="NETWORK_INDEX" /> ОъОфОЋОџ <ph name="NETWORK_COUNT" />,РђЈ <ph name="NETWORK_NAME" />,РђЈ <ph name="SECURITY_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф <ph name="SIGNAL_STRENGTH" />%, ОаОЌОАОъОћ ОбОю ОЎОЊОЎ ОћОљОЊОъОЎОЪ, ОцОеОўОЎОЮ</translation>
<translation id="8569764466147087991">ОЎОЕ ОюОЉОЌОЋОе ОДОЋОЉОЦ ОюОцОфОЎОЌОћ</translation>
<translation id="8577897833047451336">ОДОеОЋОљОўОЎОф</translation>
<translation id="8578308463707544055">ОљОЎОаОЊОЋОаОќОЎОф</translation>
<translation id="8579285237314169903">ОъОфОЉОдОб ОАОаОЏОеОЋОЪ Ою-<ph name="NUMBER_OF_FILES" /> ОцОеОЎОўОЎОЮ...</translation>
<translation id="8600173386174225982">ОеОЕОЎОъОф ОћОДОЉОдОЎОЮ ОъОЋОдОњОф ОбОЏОЕОЎОЋ ОЉОфОдОЋОњОф ОфОъОЋОаОЋОф ОъОъОЋОќОбОеОЋОф.</translation>
<translation id="8601932370724196034">РђЈОДОЋОЉОЦ ОфОъОЋОаОћ Crostini</translation>
<translation id="8609695766746872526">ОљОЎОАОюОаОЊОЎОф</translation>
<translation id="863903787380594467">ОДОЋОЊ ОћОљОЎОъОЋОф ОЕОњОЋОЎ. ОаОЋОфОеОЋ ОюОџ ОбОЋОЊ <ph name="RETRIES" /> ОаОЎОАОЎОЋОаОЋОф.</translation>
<translation id="8639391553632924850"><ph name="INPUT_LABEL" /> РђЊ ОЎОдОЎОљОћ</translation>
<translation id="8656768832129462377">ОюОљ ОюОЉОЊОЋОД</translation>
<translation id="8688591111840995413">ОАОЎОАОъОћ ОЕОњОЋОЎОћ</translation>
<translation id="8698464937041809063">РђЈОљОЎОЋОе ОЕОю Google</translation>
<translation id="8712637175834984815">ОћОЉОаОфОЎ</translation>
<translation id="8713112442029511308">ОъОюОўОќОЎОф</translation>
<translation id="8714406895390098252">ОљОЋОцОаОЎОЎОЮ</translation>
<translation id="8719721339511222681">ОЉОЌОеОф ОљОф <ph name="ENTRY_NAME" />.</translation>
<translation id="872537912056138402">ОДОеОЋОљОўОЎОф</translation>
<translation id="8743164338060742337">РђЈОеОЕОф <ph name="NETWORK_INDEX" /> ОъОфОЋОџ <ph name="NETWORK_COUNT" />,РђЈ <ph name="NETWORK_NAME" />,РђЈ ОбОЋОдОъОф ОћОљОЋОф ОЕОю Рђј<ph name="NETWORK_PROVIDER_NAME" />Рђј%<ph name="SIGNAL_STRENGTH" />, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ, ОћОфОЌОЉОеОЋОф</translation>
<translation id="8750438273876807512">ОЏОЊ ОюОњОЕОф ОЉОъОћОЎОеОЋОф ОюОДОЉОдОЎОЮ ОЕОЉОъОЊОБ, ОЎОЕ ОюОюОЌОЋОЦ ОюОЌОЎОдОћ ОљОеОЋОЏОћ ОбОю ОћОДОЋОЉОЦ, ОюОћОДОЎОЕ ОбОю <ph name="ICON" /> ОЋОюОЉОЌОЋОе ОЉОљОцОЕОеОЋОф "ОћОдОъОЊОћ ОюОъОЊОБ"</translation>
<translation id="8787254343425541995">РђЈОљОцОЕОе ОЕОеОфОЎ proxy ОбОЉОЋОе ОеОЕОфОЋОф ОъОЕОЋОфОцОЋОф</translation>
<translation id="8790981080411996443">ОљОЊОЮ ОъОЕОДОћ ОбОдОЎОдОЎОЮ</translation>
<translation id="8798099450830957504">ОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="8802459921616481935">ОћОбОЉОеОћ ОюОљОЕОцОћ</translation>
<translation id="8808686172382650546">ОЌОфОЋОю</translation>
<translation id="8810671769985673465">ОћОЏОЎОЋОЋОЦ ОаОЏОЕОю, ОћОцОеОЎОў ОДОЎОЎОЮ: "<ph name="FILE_NAME" />"</translation>
<translation id="8813284582615685103">ОАОцОеОЊОЎОф (ОАОцОеОЊ)</translation>
<translation id="8834164572807951958">ОЌОЉОеОЎОЮ ОЉОљОЌОАОЋОЪ ОћОЕОЎОфОЋОцОЎ '<ph name="DESTINATION_NAME" />' ОЎОДОЉОюОЋ ОњОЎОЕОћ ОЋОЎОЋОЏОюОЋ ОюОћОбОфОЎОД ОљОф ОћОцОеОЎОўОЎОЮ ОћОљОюОћ.</translation>
<translation id="8857149712089373752">ОаОцОљОюОЎОф ОбОЮ ОъОДОюОЊОф ОцОЋОаОўОЎОф</translation>
<translation id="8860454412039442620">РђЈОњОЎОюОЎОЋОЪ ОљОюОДОўОеОЋОаОЎ ОЕОю Excel</translation>
<translation id="8866284467018526531">ОфОбОфОЎОД ОбОеОЉОЎОф</translation>
<translation id="8874184842967597500">ОюОљ ОъОЌОЋОЉОе</translation>
<translation id="8900820606136623064">ОћОЋОаОњОеОЎОф</translation>
<translation id="8903931173357132290">ОЉОЋОњОе/Оф ОљОЋОаОЎОЉОеОАОЎОўОћ</translation>
<translation id="8912078710089354287">ОЏОюОЉ ОъОДОЕОДОЕ ОЉОќОаОЉ</translation>
<translation id="8919081441417203123">ОЊОаОЎОф</translation>
<translation id="8965697826696209160">ОљОЎОЪ ОъОАОцОЎОД ОЕОўОЌ.</translation>
<translation id="8997962250644902079">РђЈОАОЎОаОЎОф (ОъОАОЋОеОфОЎОф) Pinyin</translation>
<translation id="8998871447376656508">РђЈОљОЎОЪ ОъОАОцОЎОД ОъОДОЋОЮ ОцОаОЋОЎ ОЉ-Google Drive ОЏОЊОЎ ОюОћОЕОюОЎОЮ ОљОф ОћОћОбОюОљОћ.</translation>
<translation id="9003940392834790328">РђЈОеОЕОф <ph name="NETWORK_INDEX" /> ОъОфОЋОџ <ph name="NETWORK_COUNT" />,РђЈ <ph name="NETWORK_NAME" />,РђЈ <ph name="CONNECTION_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: Рђј<ph name="SIGNAL_STRENGTH" />%Рђј, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ, ОцОеОўОЎОЮ</translation>
<translation id="9017798300203431059">ОеОЋОАОЎОф ОцОЋОаОўОЎОф</translation>
<translation id="9034924485347205037">РђЈОДОЋОЉОдОЎ Linux</translation>
<translation id="9035012421917565900">ОюОљ ОаОЎОфОЪ ОюОћОЌОќОЎОе ОљОф ОћОцОеОЎОўОЎОЮ ОљОю '<ph name="DESTINATION_NAME" />', ОЋОюОљ ОаОЎОфОЪ ОюОЉОўОю ОљОф ОћОцОбОЋОюОћ.</translation>
<translation id="9035689366572880647">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОаОЋОЏОЌОЎ</translation>
<translation id="9038620279323455325">ОћОДОЋОЉОЦ ОЕОаОДОеОљ "<ph name="FILE_NAME" />" ОЏОЉОе ОДОЎОЎОЮ. ОЎОЕ ОюОЉОЌОЋОе ОЕОЮ ОљОЌОе.</translation>
<translation id="9046895021617826162">ОћОЌОЎОЉОЋОе ОаОЏОЕОю</translation>
<translation id="9065512565307033593">ОљОЮ ОћОљОЎОъОЋОф ОЎОЎОЏОЕОю, ОћОњОЎОЕОћ ОЕОюОџ ОюОеОЕОф ОфОЋОЕОЉОф.</translation>
<translation id="908378762078012445">РђЈОеОЋОАОЎОф ОбОЮ ОъОДОюОЊОф ОцОЋОаОўОЎОф AATSEEL</translation>
<translation id="9099674669267916096">ОъОАОцОе ОбОъОЋОЊОЎОЮ</translation>
<translation id="9100610230175265781">ОЎОЕ ОюОћОќОЎОЪ ОЉОЎОўОЋОЎ ОАОЎОАОъОћ</translation>
<translation id="9110990317705400362">РђЈОљОаОЌОаОЋ ОъОЌОцОЕОЎОЮ ОЏОю ОћОќОъОЪ ОЊОеОЏОЎОЮ ОюОњОюОЎОЕОћ ОЉОўОЋОЌОћ ОЎОЋОфОе. ОЉОбОЉОе, ОЏОю ОљОфОе ОЎОЏОЋОю ОћОЎОћ ОюОћОдОЎОб ОюОџ ОюОћОЋОАОЎОБ ОфОЋОАОБ ОюОЊОцОЊОцОЪ. ОЉОњОеОАОљОЋОф ОћОљОЌОеОЋОаОЋОф ОЕОю Google Chrome, ОбОюОЎОџ ОюОдОЎОЎОЪ ОЉОљОЋОцОЪ ОъОцОЋОеОЕ Ою-Chrome ОЕОЉОеОдОЋОаОџ ОюОћОфОДОЎОЪ ОфОЋОАОцОЎОЮ ОљОюОћ ОбОю-ОЎОЊОЎ ОћОЋОАОцОфОЮ ОЊОеОџ ОћОЊОБ 'ОфОЋОАОцОЎОЮ'. <ph name="BEGIN_LINK" />ОюОъОЎОЊОб ОаОЋОАОБ<ph name="END_LINK" /></translation>
<translation id="9111102763498581341">ОЉОЎОўОЋОю ОаОбОЎОюОћ</translation>
<translation id="912419004897138677">Codec</translation>
<translation id="9130775360844693113">ОЌОЉОеОЎОЮ ОЉОљОЌОАОЋОЪ ОћОЕОЎОфОЋОцОЎ '<ph name="DESTINATION_NAME" />' ОЎОДОЉОюОЋ ОњОЎОЕОћ ОюОцОеОЎОўОЎОЮ ОћОљОюОћ.</translation>
<translation id="9131598836763251128">ОЎОЕ ОюОЉОЌОЋОе ОДОЋОЉОЦ ОљОЌОЊ ОљОЋ ОЎОЋОфОе</translation>
<translation id="9133055936679483811">ОћОЏОЎОЋОЋОЦ ОаОЏОЕОю. <ph name="ERROR_MESSAGE" /></translation>
<translation id="9144340019284012223">ОДОўОюОљОаОЎОф</translation>
<translation id="914873105831852105">ОДОЋОЊ ОћОљОЎОъОЋОф ОюОљ ОЌОЋОДОЎ. ОаОЋОфОе ОюОџ ОбОЋОЊ ОаОЎОАОЎОЋОЪ ОљОЌОЊ.</translation>
<translation id="9153934054460603056">ОЕОъОЎОеОф ОќОћОЋОф ОЋОАОЎОАОъОћ</translation>
<translation id="9171921933192916600">ОфОЋОюОбОф ОАОцОеОЎОЮ</translation>
<translation id="9172592259078059678">ОфОбОфОЎОД ОњОЋОњ'ОеОљОўОЎОф</translation>
<translation id="9173120999827300720">ОъОДОюОЊОф ОЉОЎОаОюОљОЋОъОЎОф ОЉОљОаОњОюОЎОф (ОљОеОћ"ОЉ)</translation>
<translation id="9174050671906956834">ОцОеОЎОўОЎОЮ ОЕОЉОљОЕОцОћ ОЎОЎОъОЌОДОЋ ОЉОљОЋОцОЪ ОАОЋОцОЎ ОюОљОЌОе 30 ОЎОЋОЮ.</translation>
<translation id="9183302530794969518">Google Docs</translation>
<translation id="9189836632794948435">ОДОќОЌОЎОф</translation>
<translation id="9200427192836333033">ОЌОЋОюОдОЋ <ph name="NUMBER_OF_ITEMS" /> ОцОеОЎОўОЎОЮ.</translation>
<translation id="9213073329713032541">ОћОћОфОДОаОћ ОћОфОЌОЎОюОћ ОЉОћОдОюОЌОћ.</translation>
<translation id="9219103736887031265">ОфОъОЋОаОЋОф</translation>
<translation id="9219908252191632183">ОаОЋОБ ОЎОеОЌ</translation>
<translation id="938470336146445890">ОЎОЕ ОюОћОфОДОЎОЪ ОљОЎОЕОЋОе ОъОЕОфОъОЕ.</translation>
<translation id="939736085109172342">ОфОЎОДОЎОЎОћ ОЌОЊОЕОћ</translation>
<translation id="943972244133411984">ОЕОЋОаОћ ОбОю ОЎОЊОЎ</translation>
<translation id="945522503751344254"> ОЕОюОЎОЌОф ОъОЕОЋОЉ</translation>
<translation id="947144732524271678">ОЉОЌОеОф ОўОЋОЋОЌ ОЕОю <ph name="ENTRY_COUNT" /> ОцОеОЎОўОЎОЮ, Оъ-<ph name="FROM_ENTRY_NAME" /> ОбОЊ <ph name="TO_ENTRY_NAME" />.</translation>
<translation id="965477715979482472">ОљОаОњОюОЎОф (ОЊОеОЋОЮ ОљОцОеОЎОДОћ)</translation>
<translation id="981121421437150478">ОюОљ ОъОДОЋОЋОЪ</translation>
<translation id="988685240266037636">ОЏОЉОе ОДОЎОЎОЮ ОДОЋОЉОЦ ОЉОЕОЮ "<ph name="FILE_NAME" />". ОеОЋОдОћ ОюОћОЌОюОЎОБ ОљОЋОфОЋ?</translation>
<translation id="992401651319295351">ОаОЋОфОеОЋ ОюОџ ОбОЋОЊ <ph name="RETRIES" /> ОаОЎОАОЎОЋОаОЋОф. ОюОљ ОфОћОЎОћ ОљОцОЕОеОЋОф ОюОћОЕОфОъОЕ ОЉОеОЕОф ОћОќОЋ ОбОЊ ОЕОЎОЋОњОЊОе ОДОЋОЊ ОљОЎОъОЋОф ОЌОЊОЕ.</translation>
<translation id="996903396648773764">Рђј<ph name="NUMBER_OF_MB" /> MB</translation>
</translationbundle>