<translation id="22085916256174561">ОДОЋОеОЎОљОаОЎОф</translation>
<translation id="2208919847696382164">РђЈОћОфОДОаОћ ОбОЮ Linux</translation>
<translation id="2225536596944493418"><ph name="NUMBER_OF_ITEMS" /> ОцОеОЎОўОЎОЮ ОЎОЎОъОЌОДОЋ. ОюОћОъОЕОЎОџ?</translation>
<translation id="2230062665678605299">ОюОљ ОаОЎОфОЪ ОюОЎОдОЋОе ОљОф ОћОфОЎОДОЎОЎОћ "<ph name="FOLDER_NAME" />". <ph name="ERROR_MESSAGE" /></translation>
