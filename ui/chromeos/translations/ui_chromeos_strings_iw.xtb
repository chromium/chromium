    ОДОЉОдОЎОЮ ОЉ-Google Drive ОъОбОЋОЊОЏОаОЎОЮ ОЋОќОъОЎОаОЎОЮ ОЉОЏОю ОъОЏОЕОЎОе.<ph name="MARKUP_3" />
    <ph name="MARKUP_4" /> ОЕОъОЎОеОф ОћОДОЉОдОЎОЮ ОЕОюОџ ОЉОъОДОЋОЮ ОЉОўОЋОЌ.<ph name="MARKUP_5" />
    ОњОЮ ОљОЮ ОЎОДОеОћ ОъОЕОћОЋ ОюОъОЏОЕОЎОе ОЕОюОџ, ОћОДОЉОдОЎОЮ ОЕОюОџ ОЕОъОЋОеОЎОЮ ОЉОЉОўОЌОћ 
ОЉ-Google DriveРђЈ.<ph name="MARKUP_6" />
    <ph name="MARKUP_7" />ОЕОфОБ, ОЎОдОЎОеОћ ОЋОбОЉОЋОЊОћ ОЉОъОЕОЋОфОБ<ph name="MARKUP_8" />
    ОбОю ОДОЉОдОЎОЮ ОбОЮ ОљОаОЕОЎОЮ ОаОЋОАОцОЎОЮ - ОћОЏОЋОю ОЉОъОДОЋОЮ ОљОЌОЊ.<ph name="MARKUP_9" /></translation>
