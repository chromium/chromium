import("//components/vector_icons/vector_icons.gni")

aggregate_vector_icons("window_control_vector_icons") {
  icon_directory = "."

  sources = [
    "chrome_maximize.icon",
    "chrome_minimize.icon",
    "chrome_restore.icon",
    "window_control_close_old.icon",
    "window_control_maximize_old.icon",
    "window_control_minimize_old.icon",
    "window_control_restore_old.icon",
  ]
}

source_set("vector_icons") {
  sources = get_target_outputs(":window_control_vector_icons")

  deps = [
    ":window_control_vector_icons",
    "//base",
    "//skia",
    "//ui/gfx",
  ]
}
