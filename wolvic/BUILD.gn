generate_build_config_srcjar("build_config_gen") {
  use_final_fields = true
}

jinja_template("content_manifest") {
  input = "AndroidManifest.xml.jinja2"
  output = "$root_gen_dir/wolvic/AndroidManifest.xml"
}

