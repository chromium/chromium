dist_aar("content_aar") {
  deps = [
    ":content_manifest",
    ":libcontent_native",
    ":wolvic_java",
    "//base",
    "//base:base_java",
    "//components/browser_ui/media/android:java",
    "//components/embedder_support/android:view_java",
    "//components/externalauth/android:google_delegate_public_impl_java",
    "//components/metrics:metrics_java",
    "//components/signin/public/android:java",
    "//components/viz/service:service_java",
    "//components/webauthn/android:java",
    "//content/public/android:content_full_java",
    "//device/vr:vr",
    "//device/vr/android:vr_android",
    "//media/base/android:media_java",
    "//services/data_decoder/public/cpp/android:safe_json_java",
    "//services/device/public/java:nfc_java",
    "//third_party/android_deps:chromium_play_services_availability_java",
    "//third_party/jni_zero:jni_zero_java",
    "//ui/android:ui_full_java",
  ]
  native_libraries = [
    "$root_build_dir/libcontent_native.so",
    # TODO: Replace with shared library
    # "$root_build_dir/obj/device/vr/libdevice_vr.a",
  ]
  shared_libraries = [ ":libcontent_native" ]
  jar_included_patterns = [
    "J/N.class",
    "org/chromium/base/*.class",
    "org/chromium/blink/mojom/*.class",
    "org/chromium/build/*.class",
    "org/chromium/components/browser_ui/media/*.class",
    "org/chromium/components/download/*.class",
    "org/chromium/components/embedder_support/*.class",
    "org/chromium/components/externalauth/*.class",
    "org/chromium/components/webauthn/cred_man/*.class",
    "org/chromium/components/metrics/*.class",
    "org/chromium/components/signin/*.class",
    "org/chromium/components/signin/identitymanager/*.class",
    "org/chromium/components/url_formatter/*.class",
    "org/chromium/components/variations/*.class",
    "org/chromium/components/viz/service/frame_sinks/*.class",
    "org/chromium/content_public/*.class",
    "org/chromium/content/*.class",
    "org/chromium/device/*",
    "org/chromium/gms/*.class",
    "org/chromium/media/*.class",
    "org/chromium/media_session/mojom/*.class",
    "org/chromium/mojo_base/mojom/*.class",
    "org/chromium/mojo/bindings/*.class",
    "org/chromium/mojo/system/*.class",
    "org/chromium/net/*.class",
    "org/chromium/service_manager/mojom/*.class",
    "org/chromium/services/*.class",
    "org/chromium/ui/touch_selection/*.class",
    "org/chromium/url/*.class",
    "org/chromium/wolvic/*.class",
    "org/jni_zero/*.class",
  ]
  resource_included_patterns = [ "*/content/public/*" ]
  jar_excluded_patterns = [
    "android/*.class",
    "androidx/*.class",
    "kotlin/*.class",
    "org/intellij/*.class",
    "org/jetbrains/*.class",
  ]
  srcjar_deps = [ ":build_config_gen" ]
  proguard_configs = [ "//wolvic/java/proguard-rules.pro" ]

  generate_final_jni = true
  android_manifest = "$root_gen_dir/wolvic/AndroidManifest.xml"
  output = "$root_build_dir/Content.aar"
}

dist_aar("ui_aar") {
  deps = [
    "//ui/accessibility:ax_base_java",
    "//ui/android:ui_full_java",
  ]
  native_libraries = []
  jar_included_patterns = [ "org/chromium/ui/*.class" ]
  resource_included_patterns = [ "*/ui/android/*" ]
  jar_excluded_patterns = [
    "android/*.class",
    "androidx/*.class",
    "kotlin/*.class",
    "org/intellij/*.class",
    "org/jetbrains/*.class",
  ]

  android_manifest = "UiAndroidManifest.xml"
  output = "$root_build_dir/ChromiumUi.aar"
}
