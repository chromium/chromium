<translation id="1000127192436081677">ເປີດ/ປິດການແຊຣ໌ດ່ວນ. ການແຊຣ໌ດ່ວນ <ph name="QUICK_SHARE_STATE" /></translation>
<translation id="1012876632442809908">ອຸ​ປະ​ກອນ USB-C (ຜອດດ້ານໜ້າ)</translation>
<translation id="1013923882670373915">ອຸປະກອນ Bluetooth "<ph name="DEVICE_NAME" />" ຢາກຂໍອະນຸຍາດຈັບຄູ່. ກະລຸນາປ້ອນລະຫັດ PIN ນີ້ເຂົ້າໄປໃນອຸປະກອນນັ້ນ: <ph name="PINCODE" /></translation>
<translation id="1014722676793506285">ການດຳເນີນການນີ້ຈະອະນຸຍາດໃຫ້ <ph name="APP_NAME" /> ພ້ອມທັງແອັບ ແລະ ເວັບໄຊທັງໝົດທີ່ມີການອະນຸຍາດເຂົ້າເຖິງສະຖານທີ່ ແລະ ChromeOS ສາມາດໃຊ້ສະຖານທີ່ Wi-Fi ແລະ ເຄືອຂ່າຍມືຖືໄດ້.</translation>
<translation id="1017556409696559990">ຫຍໍ້ໜ້າຈໍເທິງສຸດເມື່ອບໍ່ມີປະຫວັດຄືນຫຼັງໃນ Chrome</translation>
<translation id="101823271612280837">ຢຸດການບັນທຶກແລ້ວ. ບໍ່ສາມາດໃຊ້ແຜງໜ້າປັດເກມໃນໂໝດແທັບເລັດໄດ້.</translation>
<translation id="1024364763893396229">ບັນທຶກ <ph name="NAME" /> ຂອງທ່ານ</translation>
<translation id="103279545524624934">ຂະຫຍາຍພື້ນທີ່ດິສກ໌ເພື່ອເປີດໃຊ້ແອັບ Android.</translation>
<translation id="1032891413405719768">ແບັດເຕີຣີປາຍປາກກາເຫຼືອໜ້ອຍ</translation>
<translation id="1036348656032585052">ປິດ</translation>
<translation id="1037492556044956303">ເພີ່ມ <ph name="DEVICE_NAME" /> ແລ້ວ</translation>
<translation id="1038106730571050514">ສະແດງການແນະນຳ</translation>
<translation id="1047017786576569492">ບາງສ່ວນ</translation>
<translation id="104710386808485638">ຣິສະຕາດ Linux ບໍ?</translation>
<translation id="1052916631016577720">ສະແກນລາຍການ</translation>
<translation id="1056775291175587022">ບໍ່ມີເຄືອຂ່າຍ</translation>
<translation id="1056898198331236512">ຄໍາເຕືອນ</translation>
<translation id="1058009965971887428">ລາຍງານຄຳຕິຊົມ</translation>
<translation id="1059120031266247284">ແບ່ງປັນກັບທ່ານ</translation>
<translation id="1060847216467038176"><ph name="ITEM_LABEL" /> ພ້ອມປຸ່ມລຶບອອກ</translation>
<translation id="1062407476771304334">​ປ່ຽນ​ແທນ​</translation>
<translation id="1065931689816135472"><ph name="BEGIN_PARAGRAPH1" />ສຳຮອງຂໍ້ມູນໄວ້ໃນ Google Drive ກູ້ຄືນຂໍ້ມູນຂອງທ່ານ ຫຼື ປ່ຽນອຸປະກອນໄດ້ຢ່າງງ່າຍດາຍທຸກເວລາ. ຂໍ້ມູນສຳຮອງຂອງທ່ານຈະມີຂໍ້ມູນແອັບຢູ່ນຳ.<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />ຂໍ້ມູນສຳຮອງຂອງທ່ານຈະຖືກອັບໂຫຼດລົງໃນ Google ແລະ ເຂົ້າລະຫັດໄວ້ໂດຍໃຊ້ລະຫັດຜ່ານບັນຊີ Google ຂອງທ່ານ.<ph name="END_PARAGRAPH2" />
        <ph name="BEGIN_PARAGRAPH3" />ຂໍ້ມູນແອັບອາດເປັນຂໍ້ມູນໃດກໍຕາມທີ່ແອັບບັນທຶກໄວ້ (ໂດຍຂຶ້ນຢູ່ກັບການຕັ້ງຄ່າຂອງນັກພັດທະນາ), ເຊິ່ງຮວມທັງຂໍ້ມູນຕ່າງໆ ເຊັ່ນ: ລາຍຊື່ຜູ້ຕິດຕໍ່, ຂໍ້ຄວາມ ແລະ ຮູບພາບ.<ph name="END_PARAGRAPH3" />
        <ph name="BEGIN_PARAGRAPH4" />ຂໍ້ມູນສຳຮອງຈະບໍ່ນັບຮວມໃນໂຄຕ້າບ່ອນຈັດເກັບຂໍ້ມູນ Drive ຂອງທ່ານ.<ph name="END_PARAGRAPH4" />
        <ph name="BEGIN_PARAGRAPH5" />ທ່ານສາມາດປິດໃຊ້ບໍລິການນີ້ໄດ້ໃນການຕັ້ງຄ່າ.<ph name="END_PARAGRAPH5" /></translation>
<translation id="106814709658156573">ເພື່ອຕັ້ງຄ່າລາຍນິ້ວມື, ກະລຸນາໃຫ້ລູກຂອງທ່ານແຕະໃສ່ເຊັນເຊີລາຍນິ້ວມືຢູ່ມຸມຊ້າຍລຸ່ມສຸດຂອງແປ້ນພິມ. ຂໍ້ມູນລາຍນິ້ວມືຂອງລູກທ່ານແມ່ນຖືກເກັບໄວ້ຢ່າງປອດໄພ ແລະ ຢູ່ໃນ <ph name="DEVICE_TYPE" /> ນີ້ສະເໝີ.</translation>
<translation id="1073899992769346247">ປ່ຽນ ຫຼື ສາກໄຟແບັດເຕີຣີ</translation>
<translation id="1081015718268701546">ຕອນນີ້ບໍ່ຮອງຮັບແອັບ Linux ເທື່ອ. ແອັບອື່ນໆຈະຖືກບັນທຶກໄວ້.</translation>
<translation id="108486256082349153">ເຊວລູລາ: <ph name="ADDRESS" /></translation>
<translation id="1085697365578766383">ເກີດຄວາມຜິດພາດໃນການເລີ່ມເຄື່ອງຈຳລອງສະເໝືອນຈິງ. ກະລຸນາລອງອີກຄັ້ງ.</translation>
<translation id="1088231044944504242">ຊອກຫາ <ph name="CATEGORY" />, ໄຟລ໌, ແອັບ ແລະ ອື່ນໆຂອງທ່ານ. ໃຊ້ປຸ່ມລູກສອນເພື່ອນຳທາງແອັບຂອງທ່ານ.</translation>
<translation id="1093645050124056515">Ctrl + Alt + ລູກສອນລົງ</translation>
<translation id="1094756674036064790">ປິດ Bluetooth ບໍ?</translation>
<translation id="109647177154844434">ການຖອນການຕິດຕັ້ງ Parallels Desktop ຈະລຶບຮູບ Windows ຂອງທ່ານ. ນີ້ຮວມທັງແອັບພລິເຄຊັນ, ການຕັ້ງຄ່າ ແລະ ຂໍ້ມູນຂອງມັນນຳ. ທ່ານແນ່ໃຈບໍ່ວ່າທ່ານຕ້ອງການສືບຕໍ່?</translation>
<translation id="1104084341931202936">ສະແດງການຕັ້ງຄ່າການຊ່ວຍເຂົ້າເຖິງ</translation>
<translation id="1104621072296271835">ອຸປະກອນຂອງທ່ານໃຊ້ໄດ້ດີຍິ່ງຂຶ້ນຮ່ວມກັນ</translation>
<translation id="1107300737351978027">ຕ້ອງບໍ່ມີຕົວເລກຊ້ຳກັນ</translation>
<translation id="1111021433905331574">ທ່ານສາມາດປ່ຽນສີຂອງໄຟແປ້ນພິມຂອງທ່ານໄດ້ໃນການຕັ້ງຄ່າ &gt; <ph name="APP_TITLE" /></translation>
<translation id="1117719261843403176">ສະຫຼັບອິນເຕີເນັດມືຖື. <ph name="STATE" />.</translation>
<translation id="1118738876271697201">ລະບົບບໍ່ສາມາດກຳນົດຮຸ່ນອຸປະກອນ ຫຼື ໝາຍເລກຊີຣຽວໄດ້.</translation>
<translation id="1119447706177454957">ຜິດພາດພາຍໃນ</translation>
<translation id="1122849163460178706">ສອງສາມຢ່າງທີ່ຄວນລອງ</translation>
<translation id="112308213915226829">ເຊື່ອງຖ້ານອັດຕະໂນມັດ</translation>
<translation id="1129383337808748948">ໂຫຼດຂໍ້ມູນ <ph name="CONTENT_TITLE" /> ຄືນໃໝ່</translation>
<translation id="1142002900084379065">ຮູບພາບຫຼ້າສຸດ</translation>
<translation id="114221662579355151">ການດຳເນີນການນີ້ອະນຸຍາດໃຫ້ <ph name="APP1_NAME" />, <ph name="APP2_NAME" /> ຮວມທັງແອັບ ແລະ ເວັບໄຊທັງໝົດທີ່ມີສິດສາມາດເຂົ້າເຖິງກ້ອງຖ່າຍຮູບໄດ້. ທ່ານອາດຕ້ອງໂຫຼດຂໍ້ມູນໜ້າເວັບຄືນໃໝ່ ຫຼື ຣີສະຕາດແອັບ.</translation>
<translation id="1147991416141538220">ເພື່ອຂໍສິດເຂົ້າເຖິງ, ກະລຸນາຕິດຕໍ່ຫາຜູ້ເບິ່ງແຍງລະບົບຂອງອຸປະກອນນີ້.</translation>
<translation id="1148499908455722006">ເປີດກ່ອງໂຕ້​ຕອບຂໍ້ມູນສຳລັບ <ph name="USER_NAME" /></translation>
<translation id="1150989369772528668">ປະຕິທິນ</translation>
<translation id="1153918444040990015">ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບສຽງໂໝດໂຟກັສໄດ້</translation>
<translation id="1155734730463845512">ລະດັບແບັດເຕີຣີປັດຈຸບັນ <ph name="BATTERY_PERCENTAGE" />%</translation>
<translation id="1157514002898505378">AI ສ້າງເນື້ອຫາຢູ່ໃນຂັ້ນທົດລອງ ແລະ ອາດມີເນື້ອຫາທີ່ບໍ່ຖືກຕ້ອງ, ເຮັດໃຫ້ເຂົ້າໃຈຜິດ ຫຼື ບໍ່ເໝາະສົມ. ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານເພື່ອລາຍງານບັນຫາ. <ph name="LINK_TO_SERVICE_TERMS" /></translation>
<translation id="1160215328209699296">ເປີດ ແລະ ນຳໃຊ້ຢູ່</translation>
