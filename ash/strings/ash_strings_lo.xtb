<translation id="2360398059912971776">ແບັດເຕີຣີ</translation>
<translation id="2361210043495191221">ສະຫຼັບ Wi-Fi. <ph name="STATE" />.</translation>
<translation id="2364710166605611987">ເອັບເຟັກຮູບລັກ</translation>
<translation id="236574664504281623">ສົ່ງຈາກ <ph name="SESSION_NAME" /></translation>
<translation id="2367972762794486313">ສະແດງແອັບ</translation>
<translation id="2368828502825385061">ຊອກຫາ</translation>
<translation id="2370971919968699910">ສິ່ງນີ້ອາດມີຄ່າໃຊ້ຈ່າຍຂໍ້ມູນ.
ເຊື່ອມຕໍ່ <ph name="DEVICECOUNT" /> ອຸປະກອນແລ້ວ.</translation>
<translation id="2383521554963939360">ແອັບ ແລະ ກຸ່ມແຖບ</translation>
<translation id="2386292613071805067">ເລືອກທຸກຢ່າງໃນໜ້າ</translation>
<translation id="2389423187722941333">ເປີດ/ປິດ Gemini</translation>
<translation id="2390347491606624519">ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບພຣັອກຊີໄດ້, ກະລຸນາເຂົ້າສູ່ລະບົບອີກຄັ້ງ</translation>
<translation id="2393136602862631930">ຕັ້ງຄ່າ <ph name="APP_NAME" /> ໃນ Chromebook ຂອງທ່ານ</translation>
