<translation id="1632985212731562677">ປິດການນຳໃຊ້ການເຂົ້າເຖິງດ້ວຍປຸ່ມກົດໄດ້ໃນການຕັ້ງຄ່າ &gt; ການຊ່ວຍເຂົ້າເຖິງ.</translation>
<translation id="1637505162081889933"><ph name="NUM_DEVICES" /> ອຸປະກອນ</translation>
<translation id="1639239467298939599">ກໍາລັງໂຫຼດ</translation>
<translation id="1647986356840967552">ໜ້າກ່ອນໜ້າ</translation>
