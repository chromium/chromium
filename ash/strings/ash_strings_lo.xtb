<translation id="4177913004758410636">{0,plural, =1{ອັບເດດອຸປະກອນພາຍໃນໜຶ່ງມື້}other{ອັບເດດອຸປະກອນພາຍໃນ # ມື້}}</translation>
<translation id="4181841719683918333">ພາສາ</translation>
<translation id="4185671786623711291">ຍ້າຍໜ້າຈໍທີ່ເປີດນຳໃຊ້ຢູ່ໄປໃສ່ໂຕະທາງຂວາ</translation>
<translation id="4186749321808907788"><ph name="QUERY_NAME" /> - <ph name="DEFAULT_SEARCH_ENGINE_NAME" /> ຊອກຫາ</translation>
<translation id="4187424053537113647">ກຳລັງຕັ້ງຄ່າ <ph name="APP_NAME" />...</translation>
<translation id="4189826113259617332">ບັນທຶກທຸກໜ້າທີ່ເປີດໃນໜ້າຈໍປັດຈຸບັນເປັນບຸກມາກໃນໂຟນເດີໃໝ່</translation>
<translation id="4190143678693626113">ປະຢັດເວລາໂດຍການຕອບກັບຫາຂໍ້ຄວາມຂອງໂທລະສັບທ່ານຈາກ Chromebook ຂອງທ່ານ</translation>
<translation id="4190780880566297084">ປິດການຕັ້ງຄ່າການເບິ່ງຮູບພາບຫຼ້າສຸດ, ມີເດຍ ແລະ ແອັບຂອງໂທລະສັບທ່ານໄວ້</translation>
<translation id="4193857202545160520">ສະແດງການຄລິກ ແລະ ແປ້ນພິມ</translation>
<translation id="4193969623755915875">ເປີດ "ຊ່ວຍເຫຼືອ" ໃນແອັບສຳຫຼວດດ້ວຍ "<ph name="NEW_SHORTCUT" />".</translation>
<translation id="4195579532193195633">ເວີຊັນປັດຈຸບັນ <ph name="VERSION_NAME" /> (<ph name="OFFICIAL_STATUS" />) <ph name="CHANNEL_NAME" /> <ph name="PROCESSOR_VARIATION" /></translation>
<translation id="4195814663415092787">ສືບ​ຕໍ່​ບ່ອນທີ່ທ່ານອອກໄປ</translation>
<translation id="4197790712631116042">ປິດ</translation>
<translation id="4201033867194214117"><ph name="FEATURE_NAME" /> ບໍ່ສາມາດໃຊ້ໄດ້.</translation>
<translation id="4201051445878709314">ສະແດງເດືອນກ່ອນນີ້</translation>
<translation id="4209973997261364186">ເປີດໃຊ້ Wi-Fi ແລ້ວ</translation>
<translation id="4210048056321123003">ກຳລັງດາວໂຫຼດເຄື່ອງຈຳລອງສະເໝືອນຈິງ</translation>
<translation id="4212246570487010370">ສືບຕໍ່ທ່ອງເວັບ</translation>
<translation id="4212472694152630271">ປ່ຽນໄປໃຊ້ PIN</translation>
<translation id="4212932720786388874"><ph name="PREFERENCE_TITLE" />, <ph name="EFFECT_NAME" />, ປຸ່ມເປີດປິດ, <ph name="STATE" /></translation>
<translation id="4215497585250573029">ການຕັ້ງຄ່າ VPN</translation>
<translation id="4217571870635786043">ການພິມຕາມຄຳບອກ</translation>
<translation id="4221957499226645091"><ph name="APP_NAME" />, ແອັບທີ່ຕິດຕັ້ງແລ້ວ, ຢຸດໄວ້ຊົ່ວຄາວແລ້ວ</translation>
<translation id="4228078597006700451">ບໍ່ໄດ້ຕັ້ງຄ່າການຄວບຄຸມ</translation>
<translation id="4230560241506423345">ໃໝ່</translation>
<translation id="4236726631849783264">ການແຈ້ງເຕືອນກ່ຽວກັບຄຳສັ່ງທີ່ແນະນຳ</translation>
<translation id="4239069858505860023">GPRS</translation>
<translation id="4240486403425279990">ໂໝດພາບຮວມ</translation>
<translation id="4242533952199664413">ເປີດ​ການ​ຕັ້ງ​ຄ່າ</translation>
<translation id="4244765461494758482">ການຕັ້ງຄ່າເຫຼົ່ານີ້ກຳລັງຊິ້ງໃນທົ່ວອຸປະກອນ ChromeOS ອື່ນໆຂອງທ່ານ. ທ່ານສາມາດປ່ຽນແປງພວກມັນໄດ້ຢູ່ບ່ອນນີ້ ຫຼື ຈັດການລາຍຊື່ເຕັມໃນການຕັ້ງຄ່າ.</translation>
<translation id="4247123849143712100">ອັບເດດ ແລະ ປິດເຄື່ອງ</translation>
<translation id="4249248555939881673">ກໍາລັງລໍ​ຖ້າ​ການ​ເຊື່ອມ​ຕໍ່​ເຄືອ​ຂ່າຍ...</translation>
<translation id="4250229828105606438">ຮູບຖ່າຍໜ້າຈໍ</translation>
<translation id="425364040945105958">ບໍ່ມີ SIM</translation>
<translation id="425573743389990240">ອັດຕາປ່ອຍໃນແບັດເຕີຣີເປັນວັດຕ໌ (ຄ່າລົບໝາຍຄວາມວ່າ ແບັດເຕີຣີກໍາລັງສາກຢູ່)</translation>
<translation id="4259388776256904261">ຂັ້ນຕອນນີ້ຈະໃຊ້ເວລາເລັກນ້ອຍ</translation>
<translation id="4264977415328155183">, ຫຍໍ້ລົງແລ້ວ</translation>
<translation id="4265259722091164182">ຕົວພິມໃຫຍ່ນຳໜ້າ</translation>
<translation id="4269883910223712419">ຜູ້ເບິ່ງແແຍງລະບົບຂອງອຸປະກອນີ້ສາມາດ:</translation>
<translation id="4271841440229266861">ສະແດງເນື້ອຫາໄຟລ໌ທັງໝົດ</translation>
<translation id="4274537685965975248">ຄີລັດ Ctrl + Alt + ລູກສອນລົງຖືກປ່ຽນແປງແລ້ວ. ເພື່ອໃຊ້ປຸ່ມ End, ໃຫ້ກົດປຸ່ມ <ph name="LAUNCHER_KEY_NAME" /> + ລູກສອນຂວາ.</translation>
<translation id="4275283744500212192">ເປີດຕົວເລືອກໂຄງຮ່າງໜ້າຈໍ</translation>
<translation id="4275663329226226506">ມີເດຍ</translation>
<translation id="4276856098224910511">ຕິດຕັ້ງບໍ່ໄດ້, ການອັບເດດລະບົບປະຕິບັດການຍັງລໍຖ້າດຳເນີນການຢູ່. ກະລະນາໃຊ້ການອັບເດດລະບົບປະຕິບັດການທີ່ຍັງລໍຖ້າດຳເນີນການ, ຣີສະຕາດ ແລະ ລອງໃໝ່. ລະຫັດຂໍ້ຜິດພາດແມ່ນ <ph name="ERROR" />.</translation>
<translation id="4278779213160967034">ຂັ້ນຕອນນີ້ອາດໃຊ້ເວລາສອງສາມນາທີ. ກຳລັງດາວໂຫຼດໄຟລ໌.</translation>
<translation id="4279490309300973883">ການສ່ອງ</translation>
<translation id="4280601795273309128">ອັບເດດຄວາມປອດໄພສິ້ນສຸດແລ້ວ. ອັບເກຣດອຸປະກອນຂອງທ່ານ.</translation>
<translation id="4281844954008187215">ຂໍ້ກໍານົດການບໍລິການ</translation>
<translation id="4282196459431406533">Smart Lock ເປີດຢູ່</translation>
<translation id="4283888303416325161">ໃສ່ລະຫັດຜ່ານເພື່ອຄວາມປອດໄພເພີ່ມເຕີມ</translation>
<translation id="4285498937028063278">ຖອນໝຸດ</translation>
<translation id="428715201724021596">ກຳລັງເຊື່ອມຕໍ່ຫາໂປຣໄຟລ໌. ຂັ້ນຕອນນີ້ອາດໃຊ້ເວລາສອງສາມນາທີ.</translation>
<translation id="4287250812980588583">ໜ້າຈໍ Chrome</translation>
<translation id="4291322857434980285">{NUM_APPS,plural, =1{ລະດັບສຽງຂອງໄມຄວບຄຸມໂດຍ <ph name="APP_NAME" />}other{ລະດັບສຽງຂອງໄມຄວບຄຸມໂດຍ # ແອັບ}}</translation>
<translation id="4296136865091727875">ລຶບລ້າງການແຈ້ງເຕືອນທັງໝົດ <ph name="COUNT" /> ລາຍການ</translation>
<translation id="4300272766492248925">ເປີດແອັບ</translation>
<translation id="430191667033048642">ຍ້າຍ <ph name="MOVED_APP_NAME" /> ໄປຫາໂຟນເດີ <ph name="FOLDER_NAME" /> ແລ້ວ.</translation>
<translation id="4302592941791324970">ບໍ່ສາມາດໃຊ້ໄດ້</translation>
<translation id="4303223480529385476">ຂະຫຍາຍພື້ນທີ່ສະແດງສະຖານະ</translation>
<translation id="4305133312001648038">ຣີເຊັດລະດັບການຊູມໃນໜ້າ</translation>
<translation id="4305817255990598646">ປ່ຽນ</translation>
<translation id="4307713728991152670">ຕັ້ງຄ່າການເບິ່ງຮູບພາບຫຼ້າສຸດ, ມີເດຍ ແລະ ແອັບຂອງໂທລະສັບທ່ານ</translation>
<translation id="4312840429157639164">ແນບກ້ອງຖ່າຍຮູບໄປໃສ່ມຸມຂວາເທິງແລ້ວ. ຂັດແຍ້ງກັບພື້ນຜິວຂອງລະບົບ.</translation>
<translation id="4312935606722154789">ຈັດກຸ່ມ ຫຼື ຍົກເລີກການຈັດກຸ່ມສອງໜ້າຈໍທີ່ຢູ່ຮຽງຂ້າງກັນ</translation>
<translation id="4321179778687042513">Ctrl</translation>
<translation id="4322385711258710213">ເຊື່ອງການແນະນຳທັງໝົດຂອງໂປຣແກຣມທ່ອງເວັບ Chrome</translation>
<translation id="4322742403972824594">ຄີລັດ Ctrl + Alt + ລູກສອນຂຶ້ນຖືກປ່ຽນແປງແລ້ວ. ເພື່ອໃຊ້ປຸ່ມ Home, ໃຫ້ກົດປຸ່ມ <ph name="LAUNCHER_KEY_NAME" /> + ລູກສອນຊ້າຍ.</translation>
<translation id="4324840740119394760">ການດຳເນີນການນີ້ອະນຸຍາດສິດເຂົ້າເຖິງກ້ອງຖ່າຍຮູບໃຫ້ແກ່ <ph name="APP_NAME" /> ແລະ ແອັບ ແລະ ເວັບໄຊທັງໝົດທີ່ມີສິດການອະນຸຍາດກ້ອງຖ່າຍຮູບ</translation>
<translation id="4327147325944669226">ບັນທຶກເກມ</translation>
<translation id="4329076911374908740">ຮອດຂີດຈຳກັດຈຳນວນສູງສຸດຂອງກຸ່ມທີ່ບັນທຶກແລ້ວ.</translation>
<translation id="4338109981321384717">ແວ່ນຂະຫຍາຍ</translation>
<translation id="4348580496249286403"><ph name="VOLUME_LEVEL" />, ປິດສຽງຢູ່</translation>
<translation id="4351244548802238354">ປິດ​ໜ້າ​ຕ່າງ</translation>
<translation id="435527878592612277">ເລືອກຮູບພາບຂອງທ່ານ</translation>
<translation id="4356872429719185452">ສະແດງລາຍລະອຽດຮັອດສະປອດ. ກຳລັງເປີດຮັອດສະປອດ.</translation>
<translation id="4364101114148522660">ກຳລັງບັນທຶກ  <ph name="DURATION" /></translation>
<translation id="4368227575116094370">ສ້າງ Google Sheet</translation>
<translation id="4371348193907997655">ການຕັ້ງຄ່າການສົ່ງສັນຍານ</translation>
<translation id="4371834685492830207">ລະຫັດ PIN ຕ້ອງມີຕົວອັກສອນທີ່ຖືກຕ້ອງເທົ່ານັ້ນ</translation>
<translation id="4375482231364171368">ຊອກຫາໃນແຖບທີ່ຢູ່</translation>
<translation id="4378479437904450384"><ph name="WIRELESS_PROVIDER" />, ຄວາມແຮງສັນຍານ <ph name="SIGNAL_STRENGTH" /> ເປີເຊັນ</translation>
<translation id="4378551569595875038">ກໍາລັງ​ເຊື່ອມ​ຕໍ່ ...</translation>
<translation id="4379531060876907730">ສິ່ງເຫຼົ່ານີ້ແມ່ນເຄື່ອງມືປາກກາຂອງທ່ານ</translation>
<translation id="4381031910344220229">ການດຳເນີນການນີ້ອະນຸຍາດສິດເຂົ້າເຖິງໄມໂຄຣໂຟນໃຫ້ <ph name="APP_NAME" /> ແລະ ແອັບ ແລະ ເວັບໄຊທັງໝົດທີ່ມີສິດອະນຸຍາດໄມໂຄຣໂຟນ</translation>
<translation id="4382340674111381977">ກັບຄືນຫາໜ້າຜ່ານມາ</translation>
<translation id="4389184120735010762">ທ່ານໄດ້ກົດປຸ່ມລັດແປ້ນພິມສຳລັບແວ່ນຂະຫຍາຍທີ່ຕັ້ງໄວ້ແລ້ວ. ທ່ານຕ້ອງການເປີດມັນບໍ?</translation>
<translation id="439358628917130594"><ph name="MANAGER" /> ຕ້ອງການໃຫ້ທ່ານອ່ານ ແລະ ຍອມຮັບຂໍ້ກຳນົດບໍລິການຕໍ່ໄປນີ້ກ່ອນທີ່ຈະໃຊ້ອຸປະກອນນີ້. ຂໍ້ກຳນົດບໍລິການເຫຼົ່ານີ້ບໍ່ຂະຫຍາຍ, ປ່ຽນແປງ ຫຼື ຈຳກັດຂໍ້ກຳນົດຂອງ ChromiumOS.</translation>
<translation id="4394466652057229831">ຄລິກຂວາເພື່ອສະຫຼຸບ</translation>
<translation id="439598569299422042">ຢຸດຊົ່ວຄາວແລ້ວ, <ph name="SIZE_INFO" /></translation>
<translation id="439817266247065935">ອຸປະກອນຂອງທ່ານປິດເຄື່ອງຢ່າງບໍ່ຖືກຕ້ອງ. ຣີສະຕາດ Linux ເພື່ອໃຊ້ແອັບ Linux.</translation>
<translation id="440113666232554208">ບໍ່ສາມາດບັນທຶກ screencast ໄດ້</translation>
<translation id="4405151984121254935">ບໍ່ຮອງຮັບປະເພດອຸປະກອນຕໍ່ພ່ວງທີ່ເຊື່ອມຕໍ່</translation>
<translation id="4406883609789734330">ຄຳບັນຍາຍສົດ</translation>
<translation id="4412698727486357573">ສູນຊ່ວຍເຫຼືອ</translation>
<translation id="4412944820643904175"><ph name="FEATURE_NAME" /> ປິດຢູ່.</translation>
<translation id="44141919652824029">ອະນຸຍາດໃຫ້ "<ph name="APP_NAME" />" ໄດ້ຮັບລາຍການອຸປະກອນ USB ທີ່ຄັດຕິດຂອງທ່ານບໍ?</translation>
<translation id="4414242853388122273">ເກີດຄວາມຜິດພາດໃນການລຶບ <ph name="VM_NAME" /> ອອກ. ກະລຸນາລອງໃໝ່.</translation>
<translation id="4417647906073317561">ການຕັ້ງຄ່າໂໝດໂຟກັສ. ຕັ້ງໂມງນັບຖອຍຫຼັງ, ໜ້າວຽກ ແລະ ເພງເພື່ອໃຫ້ດຳເນີນໄປຢ່າງຕໍ່ເນື່ອງ.</translation>
<translation id="4418600384772451109">ປິດແຜງ</translation>
<translation id="4424159417645388645">ໂຕະ 5</translation>
<translation id="4426817706804363424">ສຸດຍອດເລີຍ!</translation>
<translation id="4426857487270413362">ບໍ່ສາມາດດາວໂຫຼດໄຟລ໌ຕົວຕິດຕັ້ງໄດ້. ກະລຸນາກວດສອບການເຊື່ອມຕໍ່ອິນເຕີເນັດຂອງທ່ານ ແລະ ທ່ານມີພື້ນທີ່ດິສກ໌ພຽງພໍຫຼືບໍ່ ແລ້ວລອງໃໝ່. ລະຫັດຂໍ້ຜິດພາດແມ່ນ <ph name="ERROR" />.</translation>
