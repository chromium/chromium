<translation id="1523032696246003">ແບັດເຕີຣີ <ph name="BATTERY_PERCENTAGE" />% | ອີກ <ph name="TIME" /> ຈະເຕັມ</translation>
<translation id="1525508553941733066">ປິດໄວ້</translation>
<translation id="152629053603783244">ຣີສະຕາດ Linux</translation>
<translation id="1526448108126799339">ເປີດແຖບໃໝ່ໃນໜ້າຈໍໃໝ່</translation>
<translation id="1528259147807435347">ແກ້ໄຂອາທິດແລ້ວ</translation>
<translation id="1536604384701784949">ເພື່ອໃຊ້ <ph name="USER_EMAIL_ADDRESS" /> ທ່ານຈະຕ້ອງອອກຈາກລະບົບທຸກບັນຊີກ່ອນ. ເພື່ອອອກຈາກລະບົບ, ໃຫ້ເລືອກຍົກເລີກເພື່ອກັບຄືນ. ຈາກນັ້ນເລືອກເວລາເພື່ອເປີດພື້ນທີ່ສະຖານະແລ້ວເລືອກອອກຈາກລະບົບ. ຈາກນັ້ນເຂົ້າສູ່ລະບົບຫາ <ph name="USER_EMAIL_ADDRESS_2" /> ຄືນໃໝ່.</translation>
<translation id="15373452373711364">ເຄີເຊີເມົາສ໌ໃຫຍ່</translation>
<translation id="1545331255323159851">ເບິ່ງຮູບພາບຫຼ້າສຸດ, ມີເດຍ ແລະ ການແຈ້ງເຕືອນຂອງໂທລະສັບທ່ານ</translation>
<translation id="1546492247443594934">ໂຕະ 2</translation>
<translation id="1546930421365146760">ຖາມຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານເພື່ອຕິດຕັ້ງອຸປະກອນນີ້ໃນຄອນໂຊ Google Admin</translation>
<translation id="1549721333775633305">ສະແດງການຕັ້ງຄ່າການແຊຣ໌ດ່ວນ. ປິດການນຳໃຊ້ການແຊຣ໌ດ່ວນແລ້ວ</translation>
<translation id="1550406609415860283">ອຸປະກອນທີ່ມີໃຫ້</translation>
<translation id="1550523713251050646">ຄລິກສຳລັບຕົວເລືອກເພີ່ມເຕີມ</translation>
<translation id="1555130319947370107">ສີ​ຟ້າ</translation>
<translation id="1557622599341396706">ສະແດງຊື່ໂຕະ</translation>
<translation id="1569384531973824928">ການດຳເນີນການນີ້ອະນຸຍາດໃຫ້ແອັບ ແລະ ເວັບໄຊທັງໝົດທີ່ມີສິດສາມາດເຂົ້າເຖິງກ້ອງຖ່າຍຮູບ ແລະ ໄມໂຄຣໂຟນໄດ້. ທ່ານອາດຕ້ອງໂຫຼດຂໍ້ມູນໜ້າເວັບຄືນໃໝ່ ຫຼື ຣີສະຕາດແອັບ.</translation>
<translation id="1570235441606255261">ຕົວຕິດຕັ້ງ Steam</translation>
<translation id="1571697193564730395">ປິດເປີດຫ້າມລົບກວນ. <ph name="STATE_TEXT" /></translation>
<translation id="1574691582236909946">ເລືອກດ້າມຈັບຂອບເບື້ອງຊ້າຍແລ້ວ, ໃຊ້ປຸ່ມລູກສອນເພື່ອຍ້າຍ</translation>
<translation id="1576623706766186887">ຂະຫຍາຍອອກເມື່ອແວ່ນຂະຫຍາຍເປີດຢູ່</translation>
<translation id="1578558981922970608">ບັງຄັບປິດ</translation>
<translation id="1580772913177567930">ຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານ</translation>
<translation id="1582946770779745370">ມີແຜງໜ້າປັດເກມໃຫ້ໃຊ້. ກົດ <ph name="LAUNCHER_KEY_NAME" /> + Shift + Escape, ຈາກນັ້ນ <ph name="LAUNCHER_KEY_NAME" /> + g ຕອນໃດກໍໄດ້ເພື່ອເປີດ</translation>
<translation id="1586324912145647027">ໄປຫາໂຕະທີ 1 ຫາ 8</translation>
<translation id="158838227375272121">ເວັບໄຊ Google ຫ້ອງຮຽນ</translation>
<translation id="1589090746204042747">ເຂົ້າເຖິງທຸກການເຄື່ອນໄຫວຂອງທ່ານໃນເຊດຊັນນີ້</translation>
<translation id="1592074621872221573"><ph name="MANAGER" /> ໄດ້ປິດການນຳໃຊ້ການດີບັກ ADB ແລ້ວ, ເຊິ່ງຈະຣີເຊັດ <ph name="DEVICE_TYPE" /> ຂອງທ່ານ. ສຳຮອງໄຟລ໌ຂອງທ່ານກ່ອນທີ່ຈະຣີສະຕາດ.</translation>
<translation id="1595492813686795610">Linux ກຳລັງອັບເກຣດ</translation>
<translation id="1597880963776148053">ເບິ່ງຂັ້ນຕອນທີ <ph name="STEP" /> ຈາກທັງໝົດ <ph name="TOTAL_STEPS" /> ຂັ້ນຕອນ. ແອັບທີ່ປັກໝຸດ ແລະ ເປີດໄວ້ຂອງທ່ານຈະຢູ່ໃນຖ້ານທີ່ຢູ່ລຸ່ມສຸດຂອງໜ້າຈໍຂອງທ່ານ. ກົດ Alt + Shift + L ແລ້ວກົດ Tab ເພື່ອໂຟກັສລາຍການໃນຖ້ານ.</translation>
<translation id="1602085790802918092">ກຳລັງເລີ່ມເຄື່ອງສະເໝືອນ</translation>
<translation id="1602874809115667351"><ph name="LAUNCHER_KEY_NAME" /> + ລູກສອນລົງ</translation>
<translation id="1604857178818051494">ຢຸດມີເດຍໄວ້ຊົ່ວຄາວ</translation>
<translation id="1607312127821884567">ປິດການຕັ້ງຄ່າການເບິ່ງແອັບຂອງໂທລະສັບທ່ານໄວ້</translation>
<translation id="1610778689852195798">"ຍົກເລີກ"</translation>
<translation id="1611432201750675208">ອຸປະກອນຂອງທ່ານລັອກຢູ່</translation>
<translation id="1611993646327628135">ເປີດ</translation>
<translation id="1612679292338846734">ເມື່ອທ່ານເປີດຄຸນສົມບັດເຫຼົ່ານີ້, ຂໍ້ຄວາມທີ່ປ້ອນເຂົ້າ, ເນື້ອຫາເອກະສານ ແລະ URL ໜ້າເວັບອາດຈະຖືກສົ່ງໄປຫາເຊີບເວີ Google AI. ຂໍ້ມູນນີ້ຖືກນໍາໃຊ້ເພື່ອສ້າງການແນະນຳການຂຽນ, ສ້າງບົດສະຫຼຸບ, ຕອບຄໍາຖາມ ແລະ ປັບປຸງຜະລິດຕະພັນ, ຂຶ້ນກັບ <ph name="LINK_TO_SERVICE_TERMS" />. ຢ່າລະບຸຂໍ້ມູນໃດກໍຕາມທີ່ສ່ວນຕົວ, ລະອຽດອ່ອນ ຫຼື ເປັນຄວາມລັບ.</translation>
<translation id="1619879934359211038">ບໍ່ສາມາດເຊື່ອມຕໍ່ຫາ Google Play ໄດ້. ກະລຸນາກວດສອບການເຊື່ອມຕໍ່ອິນເຕີເນັດຂອງທ່ານແລ້ວລອງໃໝ່. ລະຫັດຂໍ້ຜິດພາດ: <ph name="ERROR_CODE" />.</translation>
