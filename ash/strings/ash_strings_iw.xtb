<translation id="8473301994082929012"><ph name="ORGANIZATION_NAME" /> <ph name="FEATURE_STATE" /> ОљОф <ph name="FEATURE_NAME" />.</translation>
<translation id="8477270416194247200">РђЈОЎОЕ ОюОћОДОЎОЕ ОбОю Alt+Search ОљОЋ ОбОю Shift ОЏОЊОЎ ОюОЉОўОю.</translation>
<translation id="8492573885090281069">ОћОфОдОЋОњОћ ОЕОю <ph name="DISPLAY_NAME" /> ОюОљ ОфОЋОъОЏОф ОЉОеОќОЋОюОЋОдОЎОћ <ph name="SPECIFIED_RESOLUTION" />. ОћОеОќОЋОюОЋОдОЎОћ ОЕОЋОаОфОћ Ою-<ph name="FALLBACK_RESOLUTION" />. ОюОЕОъОЎОеОф ОћОЕОЎОаОЋОЎОЎОЮ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю 'ОљОЎОЕОЋОе'. ОћОћОњОЊОеОЋОф ОћОДОЋОЊОъОЋОф ОЎОЕОЋОЌОќОеОЋ ОЉОбОЋОЊ <ph name="TIMEOUT_SECONDS" />.</translation>
<translation id="8513108775083588393">ОАОЎОЉОЋОЉ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="851458219935658693">ОћОдОњОф ОЌОюОЋОаОЋОф ОъОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎ ОћОаОЋОЏОЌОЎ, ОюОЌОдОЪ ОћОЉОЌОЎОеОћ ОаОЉОЌОе</translation>
<translation id="8517041960877371778">ОЎОЎОфОЏОЪ ОЕОћ-<ph name="DEVICE_TYPE" /> ОюОљ ОЎОЎОўОбОЪ ОЏОЕОћОЋОљ ОцОЋОбОю.</translation>
<translation id="8553395910833293175">ОЏОЉОе ОъОЋОДОдОћ ОюОЏОю ОЕОЋОюОЌОаОЋОф ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОЎОЮ.</translation>
<translation id="8563862697512465947">ОћОњОЊОеОЋОф ОћОфОеОљОћ</translation>
<translation id="857201607579416096">ОћОфОцОеОЎОў ОћОЋОбОЉОе ОюОцОЎОаОћ ОћОЕОъОљОюОЎОф ОћОфОЌОфОЋОаОћ ОЕОю ОћОъОАОџ.</translation>
<translation id="8594115950068821369">-<ph name="FORMATTED_TIME" /></translation>
<translation id="8627191004499078455">ОЎОЕ ОЌОЎОЉОЋОе ОљОю <ph name="DEVICE_NAME" /></translation>
<translation id="8631727435199967028">ОћОњОЊОеОЋОф ОаОњОЎОЕОЋОф</translation>
<translation id="8637598503828012618"><ph name="CONNECTION_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" />, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="8639760480004882931">ОЕОЎОбОЋОе ОўОбОЎОаОћ ОаОЋОфОе - <ph name="PERCENTAGE" /></translation>
<translation id="8641805545866562088">ОеОбОаОЋОЪ ОеОЕОЎОъОф ОћОцОеОЋОцОЎОюОЎОЮ ОъОфОЉОдОб. ОЎОЕ ОюОћОъОфОЎОЪ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="8646417893960517480">ОўОЎОЎОъОе ОЕОю <ph name="TOTAL_TIME" /></translation>
<translation id="8647931990447795414">РђЈОЏОЊОЎ ОюОћОЋОАОЎОБ ОъОЕОфОъОЕ, ОЎОЕ ОюОћОќОЎОЪ ОДОЋОЊ ОњОЎОЕОћ ОюОћОЋОеОЎОЮ ОЉ-Family Link</translation>
<translation id="8649101189709089199">ОћОДОеОљОћ</translation>
<translation id="8652175077544655965">ОАОњОЎОеОф ОћОћОњОЊОеОЋОф</translation>
<translation id="8653151467777939995">ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОЕОю ОћОЋОЊОбОЋОф. ОћОћОЋОЊОбОЋОф ОъОЋОцОбОюОЋОф</translation>
<translation id="8660331759611631213">ОћОЕОЋОеОЕ ОћОеОЎОЉОЋОбОЎ ОЕОю 71</translation>
<translation id="8663756353922886599"><ph name="CONNECTION_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" /></translation>
<translation id="8664753092453405566">ОдОцОЎОЎОћ ОЉОеОЕОЎОъОф ОћОеОЕОфОЋОф. <ph name="STATE_TEXT" /></translation>
<translation id="8668052347555487755">ОъОдОЉ ОћОдОЉОбОЎОЮ</translation>
<translation id="8673028979667498656">270┬░</translation>
<translation id="8676770494376880701">ОЌОЋОЉОе ОъОўОбОЪ ОЉОбОю ОъОфОЌ ОаОъОЋОџ</translation>
<translation id="8683506306463609433">ОъОбОДОЉ ОћОЉОЎОдОЋОбОЎОЮ ОцОбОЎОю</translation>
<translation id="8703634754197148428">РђЈОЎОЕ ОюОћОфОЌОЎОю ОЉОћОДОюОўОћ. ОюОљОЌОе ОћОфОЌОюОф ОћОћОДОюОўОћ, ОЎОЕ ОюОћОДОЎОЕ ОбОю Alt РђЈ+ Shift РђЈ+ L ОЏОЊОЎ ОюОбОЉОЋОе ОюОъОЊОБ ОЋОюОъОдОЋОљ ОљОф ОћОюОЌОдОЪ ОюОћОцОАОДОф ОћОћОДОюОўОћ</translation>
<translation id="8709616837707653427"><ph name="DESC_TEXT" /> ОЏОЊОЎ ОюОаОћОю ОљОф ОћОфОЏОЋОаОћ ОћОќОЋ, ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОћОЎОъОаОЎ ОљОЋ ОћОЕОъОљОюОЎ.</translation>
<translation id="8712637175834984815">ОћОЉОаОфОЎ</translation>
<translation id="8721053961083920564">ОћОЕОъОбОћ ОљОЋ ОћОЕОфОДОћ ОЕОю ОдОюОЎОюОЎОЮ. <ph name="STATE_TEXT" /></translation>
<translation id="8724318433625452070">ОдОЎОюОЋОЮ ОъОАОџ ОъОюОљ</translation>
<translation id="8734991477317290293">ОЎОЎОфОЏОЪ ОЕОћОЎОљ ОъОаОАОћ ОюОфОбОЊ ОљОф ОћОћОДОЕОЋОф ОЕОюОџ.</translation>
<translation id="8735953464173050365">ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОћОъОДОюОЊОф. ОћОъОДОюОЊОф ОЕОаОЉОЌОеОћ ОћОЎОљ <ph name="KEYBOARD_NAME" /></translation>
<translation id="8755498163081687682">ОљОЎОъОЋОф ОћОќОћОЋОф ОЕОюОџ: ОбОю ОъОаОф ОюОћОфОЌОЉОе ОљОю <ph name="ORIGIN_NAME" /> ОЎОЕ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="875593634123171288">РђЈОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф VPN</translation>
<translation id="8759408218731716181">ОюОљ ОаОЎОфОЪ ОюОћОњОЊОЎОе ОЏОаОЎОАОћ ОбОЮ ОъОАОцОе ОЌОЕОЉОЋОаОЋОф</translation>
<translation id="878215960996152260"><ph name="APP_NAME" />, ОљОцОюОЎОДОдОЎОћ ОъОЋОфОДОаОф, ОЌОАОЋОъОћ</translation>
<translation id="8785070478575117577">ОћОфОЌОЉОеОЋОф ОљОю <ph name="NETWORK_NAME" /></translation>
<translation id="8788027118671217603"><ph name="STATE_TEXT" />. <ph name="ENTERPRISE_TEXT" /></translation>
<translation id="8814190375133053267">Wi-Fi</translation>
<translation id="881757059229893486">ОћОњОЊОеОЋОф ОЕОю ОЕОЎОўОф ОћОДОюОў</translation>
<translation id="8818320199597151042">ОћОАОеОф ОћОцОеОЋОцОЎОю ОъОфОЉОдОбОф. ОЎОЕ ОюОћОъОфОЎОЪ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="8825863694328519386">ОЎОЕ ОюОћОЌОюОЎОД ОъОдОЊ ОЎОъОЎОЪ ОЏОЊОЎ ОюОЌОќОЋОе ОљОЌОЋОеОћ</translation>
<translation id="8828714802988429505">90┬░</translation>
<translation id="8841375032071747811">ОюОЌОдОЪ 'ОћОДОЋОЊОЮ'</translation>
<translation id="8843682306134542540">ОћОцОбОюОћ ОљОЋ ОћОЕОЉОфОћ ОЕОю ОаОбОЎОюОф ОћОАОЎОЉОЋОЉ. <ph name="STATE_TEXT" /></translation>
<translation id="8850991929411075241">Search+Esc</translation>
<translation id="8853703225951107899">ОюОљ ОћОдОюОЌОаОЋ ОюОљОъОф ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОљОЋ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ. ОћОбОеОћ: ОљОЮ ОЕОЎОаОЎОф ОюОљОЌОеОЋОаОћ ОљОф ОћОАОЎОАОъОћ, ОбОюОЎОџ ОюОаОАОЋОф ОюОћОЎОЏОаОА ОбОЮ ОћОАОЎОАОъОћ ОћОЎОЕОаОћ. ОћОАОЎОАОъОћ ОћОЌОЊОЕОћ ОфОЎОЏОаОА ОюОфОЋОДОБ ОюОљОЌОе ОћОЎОдОЎОљОћ ОъОћОЌОЕОЉОЋОЪ.</translation>
<translation id="8870509716567206129">ОћОљОцОюОЎОДОдОЎОћ ОљОЎОаОћ ОфОЋОъОЏОф ОЉОъОАОџ ОъОцОЋОдОю.</translation>
<translation id="8871580645200179206">ОъОбОЉОе ОюОбОЎОдОЋОЉ ОЏОћОћ. <ph name="STATE_TEXT" /></translation>
<translation id="8874184842967597500">ОюОљ ОъОЌОЋОЉОе</translation>
<translation id="8876661425082386199">ОъОЋОъОюОЦ ОюОЉОЊОЋОД ОљОф ОћОЌОЎОЉОЋОе</translation>
<translation id="8877788021141246043">ОћОњОЊОеОф ОфОќОЏОЋОеОф</translation>
<translation id="8878886163241303700">ОъОАОџ ОъОфОеОЌОЉ</translation>
<translation id="8883473964424809116">РђЈОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОЎОЏОаОА ОюОћОњОЊОеОЋОф ОЕОю Google Assistant.</translation>
<translation id="8884537526797090108">ОљОЎ ОљОцОЕОе ОюОћОДОюОЎОў ОфОЋОЏОЪ ОАОЋОЊОЎ</translation>
<translation id="890616557918890486">ОЕОЎОаОЋОЎ ОћОъОДОЋОе</translation>
<translation id="8909138438987180327">ОЕОЎОбОЋОе ОћОўОбОЎОаОћ ОЕОю ОћОАОЋОюОюОћ ОћОЋОљ <ph name="PERCENTAGE" /> ОљОЌОЋОќОЎОЮ.</translation>
<translation id="8913384980486163186">ОъОбОЋОдОЉ (ОЉОеОЎОеОф ОъОЌОЊОю)</translation>
<translation id="8921554779039049422">+H</translation>
<translation id="8921624153894383499">РђЈGoogle Assistant ОюОљ ОъОЊОЉОеОф ОЉОЕОцОћ ОћОќОљОф.</translation>
<translation id="8936501819958976551">ОъОЋОЕОЉОфОф</translation>
<translation id="8938800817013097409">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЎОъОаОЎОф ОъОљОЌОЋОе)</translation>
<translation id="8940956008527784070">РђЈОАОЋОюОюОћ ОЌОюОЕОћ (Рђј<ph name="PERCENTAGE" />%Рђј)</translation>
<translation id="8951539504029375108">РђЈОеОД ОъОЏОЕОЎОеОЎ Thunderbolt ОъОљОЋОЕОеОЎОЮ ОфОЋОљОъОЎОЮ Ою-Chromebook</translation>
<translation id="8982906748181120328">ОњОЎОЕОћ ОЉОАОЉОЎОЉОћ</translation>
<translation id="8983038754672563810">HSPA</translation>
<translation id="8990809378771970590">ОъОДОюОЊОф ОЉОЕОЎОъОЋОЕ: <ph name="IME_NAME" /></translation>
<translation id="899350903320462459">ОЎОЕ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе ОЏ-<ph name="LOGIN_ID" /> ОбОю ОъОаОф ОюОЉОдОб ОљОф ОцОбОЋОюОф ОћОћОЋОЊОбОћ</translation>
<translation id="9017320285115481645">РђЈОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОњОЎОЕОћ ОюОћОЋОеОЎОЮ ОбОЉОЋОе Family Link.</translation>
<translation id="9024331582947483881">ОъОАОџ ОъОюОљ</translation>
<translation id="9047624247355796468">ОцОфОЎОЌОф ОћОћОњОЊОеОЋОф ОЕОю <ph name="NETWORK_NAME" /></translation>
<translation id="9056839673611986238">ОћОъОЏОЕОЎОе ОЎОЋОЌОќОе ОюОъОдОЉ ОДОЋОЊОЮ</translation>
<translation id="9063800855227801443">ОюОљ ОаОЎОфОЪ ОюОдОюОЮ ОфОЋОЏОЪ ОАОЋОЊОЎ</translation>
<translation id="9065203028668620118">ОбОеОЎОЏОћ</translation>
<translation id="9070640332319875144">РђЈОћОњОЊОеОЋОф Assistant</translation>
<translation id="9072519059834302790"><ph name="TIME_LEFT" /> ОбОЊ ОюОћОфОеОЋОДОаОЋОф ОћОАОЋОюОюОћ.</translation>
<translation id="9074739597929991885">Bluetooth</translation>
<translation id="9077515519330855811">ОцОДОЊОЎ ОъОЊОЎОћ, <ph name="MEDIA_TITLE" /> ОъОЋОцОбОю ОбОЏОЕОЎОЋ</translation>
<translation id="9079731690316798640">Wi-Fi: <ph name="ADDRESS" /></translation>
<translation id="9080132581049224423">ОЏОЊОЎ ОюОЌОќОЋОе ОюОЊОБ ОћОЉОЎОф, ОъОЌОюОЎОДОЎОЮ ОЏОюОцОЎ ОъОбОюОћ</translation>
<translation id="9080206825613744995">ОћОъОЎОДОеОЋОцОЋОЪ ОаОъОдОљ ОЉОЕОЎОъОЋОЕ.</translation>
<translation id="9084606467167974638">ОЕОЎОаОЋОЎ ОъОЎОДОЋОЮ ОћОфОцОеОЎОў</translation>
<translation id="9089416786594320554">ОЕОЎОўОЋОф ОДОюОў</translation>
<translation id="9091626656156419976">ОћОЋОАОеОћ ОћОфОдОЋОњОћ ОЕОю <ph name="DISPLAY_NAME" /></translation>
<translation id="9098969848082897657">ОћОЕОфОДОф ОћОўОюОцОЋОЪ</translation>
<translation id="9099154003160514616">РђЈОЎОЕ ОбОЊОЏОЋОЪ Ою-Lacros</translation>
<translation id="9100887602489003640">ОћОЋОАОцОф ОћОцОеОЋОцОЎОю ОъОфОЉОдОбОф. ОЎОЕ ОюОћОъОфОЎОЪ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="9105450214093926548">РђЈОљОЎ ОљОцОЕОе ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОЕОю ОъОЕОфОъОЕ ОаОЋОАОБ ОЉОќОъОЪ ОЕОЊОцОЊОцОЪ Lacros ОцОЋОбОю. ОЉОъОДОЋОЮ ОќОљОф, ОЎОЕ ОюОћОЕОфОъОЕ ОЉОцОеОЋОцОЎОю ОЊОцОЊОцОЪ ОЕОаОЎ ОЉ-Lacros ОљОЋ ОюОАОњОЋОе ОљОф Lacros ОЋОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="9133335900048457298">ОюОљ ОаОЎОфОЪ ОюОћОДОюОЎОў ОфОЋОЏОЪ ОъОЋОњОЪ</translation>
<translation id="9151726767154816831">РђЈОЏОЊОЎ ОюОбОЊОЏОЪ ОљОф ОћОъОбОеОЏОф, ОЎОЕ ОюОћОцОбОЎОю ОљОф ОћОъОЏОЕОЎОе ОъОЌОЊОЕ ОЋОюОЉОдОб Powerwash</translation>
<translation id="9166331175924255663">ОћОЌОюОцОф ОъОдОЉ ОћОЕОЎОфОЋОБ ОЉОДОеОЉОф ОъОДОЋОЮ ОЉОъОЎОЊОф ОЌОЕОЎОцОћ ОњОЉОЋОћОћ.</translation>
<translation id="9168436347345867845">ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="9179259655489829027">ОфОЏОЋОаОћ ОќОЋ ОъОљОцОЕОеОф ОюОџ ОюОњОЕОф ОЉОъОћОЎОеОЋОф ОюОЏОю ОъОЕОфОъОЕ ОћОъОЌОЋОЉОе ОюОЌОЕОЉОЋОЪ, ОЉОюОЎ ОюОћОќОЎОЪ ОАОЎОАОъОћ.

ОЎОЕ ОюОћОЕОфОъОЕ ОЉОфОЏОЋОаОћ ОћОќОЋ ОеОД ОбОЮ ОЌОЕОЉОЋОаОЋОф ОъОћОЎОъОаОЎОЮ.</translation>
<translation id="9183456764293710005">ОћОњОЊОюОф ОЏОю ОћОъОАОџ</translation>
<translation id="9193626018745640770">ОъОфОЉОдОбОф ОћОбОЉОеОћ ОЉОъОЏОЕОЎОе ОюОљ ОЎОЊОЋОб</translation>
<translation id="9194617393863864469">ОћОЋОАОцОф ОъОЕОфОъОЕ ОљОЌОе...</translation>
<translation id="9198992156681343238">ОћОеОќОЋОюОЋОдОЎОћ ОЕОю <ph name="DISPLAY_NAME" /> ОЕОЋОаОфОћ Ою-<ph name="RESOLUTION" />. ОюОЕОъОЎОеОф ОћОЕОЎОаОЋОЎОЎОЮ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю 'ОљОЎОЕОЋОе'. ОћОћОњОЊОеОЋОф ОћОДОЋОЊОъОЋОф ОЎОЕОЋОЌОќОеОЋ ОЉОбОЋОЊ <ph name="TIMEOUT_SECONDS" />.</translation>
<translation id="9201374708878217446"><ph name="CONNECTION_STATUS" />, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ</translation>
<translation id="9210037371811586452">РђЈОЎОдОЎОљОћ ОъОъОдОЉ Unified Desktop</translation>
<translation id="9211490828691860325">ОЏОю ОЕОЋОюОЌОаОЋОф ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОЎОЮ</translation>
<translation id="9211681782751733685"><ph name="TIME_REMAINING" /> ОбОЊ ОюОўОбОЎОаОћ ОъОюОљОћ ОЕОю ОћОАОЋОюОюОћ.</translation>
<translation id="9215934040295798075">ОћОњОЊОеОф ОўОцОў</translation>
