<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1012876632442809908">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОДОЊОъОЎОф)</translation>
<translation id="1013598600051641573"><ph name="DISPLAY_NAME" /> ОћОЕОфОаОћ Ою-<ph name="RESOLUTION" /> (<ph name="REFRESH_RATE" /> ОћОеОЦ). ОюОЕОъОЎОеОф ОћОЕОЎОаОЋОЎОЎОЮ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю 'ОљОЎОЕОЋОе'. ОћОћОњОЊОеОЋОф ОћОДОЋОЊОъОЋОф ОЎОЕОЋОЌОќОеОЋ ОЉОбОЋОЊ <ph name="TIMEOUT_SECONDS" />.</translation>
<translation id="1013923882670373915">РђЈОъОЏОЕОЎОе Оћ-Bluetooth РђЈ"<ph name="DEVICE_NAME" />" ОъОЉОДОЕ ОћОеОЕОљОћ ОюОЉОдОб ОћОфОљОъОћ. ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОћОЉОљ ОЉОъОЏОЕОЎОе: <ph name="PINCODE" /></translation>
<translation id="1024261588257374085">ОаОЉОЌОе ОдОЎОюОЋОЮ ОъОАОџ ОЌОюОДОЎ</translation>
<translation id="1032891413405719768">ОАОЋОюОюОф ОћОАОўОЎОЎОюОЋОА ОЌОюОЕОћ</translation>
<translation id="1036672894875463507">РђЈОљОаОЎ Google Assistant, ОЋОљОЋОЏОю ОюОбОќОЋОе ОюОџ ОюОЏОю ОљОЋОеОџ ОћОЎОЋОЮ!
ОћОаОћ ОЏОъОћ ОЊОЉОеОЎОЮ ОЕОљОцОЕОе ОюОаОАОЋОф ОЉОфОЋОе ОћОфОЌОюОћ.</translation>
<translation id="1037492556044956303"><ph name="DEVICE_NAME" /> ОаОЋОАОБ</translation>
<translation id="1047017786576569492">ОЌОюОДОЎ</translation>
<translation id="1047773237499189053">ОЎОЕ ОфОЏОЋОаОћ ОЌОЊОЕОћ. ОюОъОЎОЊОб ОаОЋОАОБ ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОбОюОћ.</translation>
<translation id="1052916631016577720">ОАОеОЎОДОф ОцОеОЎОўОЎОЮ</translation>
<translation id="1056775291175587022">ОљОЎОЪ ОеОЕОфОЋОф</translation>
<translation id="1059194134494239015"><ph name="DISPLAY_NAME" />: <ph name="RESOLUTION" /></translation>
<translation id="108486256082349153">ОАОюОЋОюОеОЎ: <ph name="ADDRESS" /></translation>
<translation id="1087110696012418426">ОљОЌОћ"Од ОўОЋОЉОЎОЮ <ph name="GIVEN_NAME" />,</translation>
<translation id="109942774857561566">ОъОЕОбОъОЮ ОюОЎ</translation>
<translation id="1104084341931202936">ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОћОаОњОЎОЕОЋОф</translation>
<translation id="1104621072296271835">ОЉОЎОЌОЊ, ОћОъОЏОЕОЎОеОЎОЮ ОЕОюОџ ОЎОЋОЏОюОЋ ОюОбОЉОЋОЊ ОбОЋОЊ ОЎОЋОфОе ОўОЋОЉ</translation>
<translation id="1119348796022671382">ОЉОъОдОЉ 'ОдОЉОбОЎОЮ ОъОбОЋОдОЉОЎОЮ' ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОдОЉОбОЎОЮ ОЕОаОЕОюОцОЎОЮ ОъОћОўОцОў ОЕОюОџ ОюОћОЋОАОцОф ОДОдОф ОдОЉОб ОюОъОъОЕОД.</translation>
<translation id="112308213915226829">ОћОАОфОеОћ ОљОЋОўОЋОъОўОЎОф ОЕОю ОћОъОЊОБ</translation>
<translation id="1148499908455722006">ОцОфОЎОЌОф ОфОЎОЉОф ОЊОЋ-ОЕОЎОЌ ОбОЮ ОъОЎОЊОб ОбОю <ph name="USER_NAME" /></translation>
<translation id="1153356358378277386">ОъОЏОЕОЎОеОЎОЮ ОъОЋОфОљОъОЎОЮ</translation>
<translation id="1165712434476988950">ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф ОћОъОЏОЕОЎОе ОЏОЊОЎ ОюОћОЌОЎОю ОљОф ОћОбОЊОЏОЋОЪ.</translation>
<translation id="1175572348579024023">ОњОюОЎОюОћ</translation>
<translation id="1178581264944972037">ОћОЕОћОЎОћ</translation>
<translation id="1181037720776840403">ОћОАОеОћ</translation>
<translation id="118532027333893379">ОЏОЊОЎ ОюОдОюОЮ ОљОф ОћОъОАОџ ОћОъОюОљ, ОЎОЕ ОюОћОДОЎОЕ ОЉОъОДОЋОЮ ОЏОюОЕОћОЋ</translation>
<translation id="1190609913194133056">ОъОеОЏОќ ОћОфОеОљОЋОф</translation>
<translation id="1195412055398077112">ОАОеОЎОДОф ОЎОфОе</translation>
<translation id="119944043368869598">ОаОЎОДОЋОЎ ОћОЏОЋОю</translation>
<translation id="1199716647557067911">ОюОЏОЉОЋОф ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ?</translation>
<translation id="1210557957257435379">ОћОДОюОўОф ОъОАОџ</translation>
<translation id="121097972571826261">ОъОЎОюОћ ОљОЌОф ОДОЊОЎОъОћ</translation>
<translation id="1225748608451425081">РђЈОћ-Chromebook ОЕОюОџ ОаОбОЋОю ОбОДОЉ ОЉОбОЎОћ ОЎОЊОЋОбОћ. ОаОЎОфОЪ ОЎОћОЎОћ ОюОћОЎОЏОаОА ОЉОбОЋОЊ: <ph name="TIME_LEFT" />.</translation>
<translation id="1229194443904279055">ОАОЎОЋОЮ ОћОЉОЌОЎОеОћ</translation>
<translation id="1239161794459865856">ОћОфОЏОЋОаОћ <ph name="FEATURE_NAME" /> ОъОЌОЋОЉОеОф.</translation>
<translation id="1247372569136754018">ОъОЎОДОеОЋОцОЋОЪ (ОцОаОЎОъОЎ)</translation>
<translation id="1252999807265626933">ОўОбОЎОаОћ Оъ-<ph name="POWER_SOURCE" /></translation>
<translation id="1255033239764210633">ОъОћ ОъОќОњ ОћОљОЋОЋОЎОе?</translation>
<translation id="1266097335951928626">ОцОфОЎОЌОф ОћОъОдОюОъОћ ОюОфОъОЋОаОф ОАОюОцОЎ</translation>
<translation id="1267032506238418139">ОЕОЎОаОЋОЎ ОъОДОЕ ОДОЎОдОЋОе</translation>
<translation id="1269405891096105529">ОљОЎОЪ ОфОъОЎОЏОћ ОЉОдОЎОЋОЊ ОћОЎОДОцОЎ ОЉОъОдОЉ ОљОЋОеОЌ</translation>
<translation id="1270290102613614947">ОћОъОДОюОЊОф ОЕОъОЋОцОЎОбОћ ОЉОъОАОџ ОъОЋОЕОЉОфОф</translation>
<translation id="1272079795634619415">ОћОцОАОДОћ</translation>
<translation id="1275285675049378717">ОъОАОцОД ОЌОЕОъОю Ою-<ph name="POWER_SOURCE" /></translation>
<translation id="1279938420744323401"><ph name="DISPLAY_NAME" />РђЈ (<ph name="ANNOTATION" />)</translation>
<translation id="1285992161347843613">ОљОЎОфОЋОе ОўОюОцОЋОЪ</translation>
<translation id="1289185460362160437">ОљОцОЕОе ОюОЌОќОЋОе ОЉОЎОЋОЮ <ph name="COME_BACK_DAY_OF_WEEK" /> ОЉОЕОбОћ <ph name="COME_BACK_TIME" />.</translation>
<translation id="1290331692326790741">ОљОЋОф ОЌОюОЕ</translation>
<translation id="1293264513303784526">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЕОъОљОюОЎОф)</translation>
<translation id="1294929383540927798">ОЕОЎОаОЋОЎ ОћОћОњОЊОеОЋОф ОЕОю ОћОћОфОеОљОЋОф ОЉОъОАОџ ОћОаОбОЎОюОћ</translation>
<translation id="1301069673413256657">GSM</translation>
<translation id="1302880136325416935">РђЈОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф BluetoothРђЈ. <ph name="STATE_TEXT" /></translation>
<translation id="1312604459020188865">ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" /></translation>
<translation id="1316069254387866896">ОћОъОЊОБ ОфОъОЎОЊ ОъОЋОдОњ</translation>
<translation id="1316811122439383437">ОъОЊОБ: ОдОЎОюОЋОъОЎ ОъОАОџ ОљОЌОеОЋОаОЎОЮ, ОћОЋОеОЊОЋОф ОЋОДОЉОдОЎОЮ ОъОЋОдОъОЊОЎОЮ</translation>
<translation id="1333308631814936910"><ph name="DISPLAY_NAME" /> ОъОЌОЋОЉОе</translation>
<translation id="1341651618736211726">ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="1346748346194534595">ОЎОъОЎОаОћ</translation>
<translation id="1351937230027495976">ОЏОЎОЋОЋОЦ ОћОфОцОеОЎОў</translation>
<translation id="1383876407941801731">ОЌОЎОцОЋОЕ</translation>
<translation id="1391102559483454063">ОъОЋОцОбОюОф</translation>
<translation id="1407069428457324124">ОбОЎОдОЋОЉ ОЏОћОћ</translation>
<translation id="1419738280318246476">ОЏОЊОЎ ОюОЉОдОб ОљОф ОцОбОЋОюОф ОћОћОЋОЊОбОћ ОЎОЕ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе</translation>
<translation id="1420408895951708260">ОћОцОбОюОћ ОљОЋ ОЏОЎОЉОЋОЎ ОЕОю ОфОљОЋОеОф ОћОюОЎОюОћ. <ph name="STATE_TEXT" /></translation>
<translation id="1426410128494586442">ОЏОЪ</translation>
<translation id="144853431011121127">ОДОЉОюОф ОћОфОеОљОЋОф ОъОћОўОюОцОЋОЪ ОЉОъОЏОЕОЎОе <ph name="DEVICE_TYPE" /> ОЕОюОџ</translation>
<translation id="1455242230282523554">ОћОдОњОф ОћОњОЊОеОЋОф ОћОЕОцОћ</translation>
<translation id="1460620680449458626">ОдОюОЎОюОЎОЮ ОъОЋОЕОфОДОЎОЮ.</translation>
<translation id="1467432559032391204">ОЕОъОљОюОћ</translation>
<translation id="147310119694673958">ОўОбОЎОаОф ОћОАОЋОюОюОћ ОЕОю ОћОўОюОцОЋОЪ: %<ph name="BATTERY_PERCENTAGE" /></translation>
<translation id="1479909375538722835">ОфОцОеОЎОў ОаОњОЎОЕОЋОф ОдОБ</translation>
<translation id="1484102317210609525"><ph name="DEVICE_NAME" /> (HDMI/DP)</translation>
<translation id="1503394326855300303">ОћОЌОЕОЉОЋОЪ ОЕОю ОЉОбОюОЎОЮ ОќОћ ОдОеОЎОџ ОюОћОЎОЋОф ОћОЌОЕОЉОЋОЪ ОћОеОљОЕОЋОЪ ОЕОљОюОЎОЋ ОаОЏОаОАОЎОЮ ОЉОбОф ОЏОаОЎОАОћ ОюОцОбОЎОюОЋОф ОЉОљОфОе ОъОЌОЕОЉОЋОаОЋОф ОъОеОЋОЉОЎОЮ.</translation>
<translation id="1510238584712386396">ОъОеОЏОќ ОћОљОцОюОЎОДОдОЎОЋОф</translation>
<translation id="1516740043221086139">ОъОдОЉ 'ОаОљ ОюОљ ОюОћОцОеОЎОб' ОъОЋОцОбОю.</translation>
<translation id="1520303207432623762">{NUM_APPS,plural, =1{ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОЕОю ОћОЋОЊОбОЋОф. ОћОћОЋОЊОбОЋОф ОъОЋОЕОЉОфОЋОф ОЉОљОцОюОЎОДОдОЎОћ ОљОЌОф}two{ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОЕОю ОћОЋОЊОбОЋОф. ОћОћОЋОЊОбОЋОф ОъОЋОЕОЉОфОЋОф ОЉ-# ОљОцОюОЎОДОдОЎОЋОф}many{ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОЕОю ОћОЋОЊОбОЋОф. ОћОћОЋОЊОбОЋОф ОъОЋОЕОЉОфОЋОф ОЉ-# ОљОцОюОЎОДОдОЎОЋОф}other{ОдОцОЎОЎОћ ОЉОћОњОЊОеОЋОф ОЕОю ОћОЋОЊОбОЋОф. ОћОћОЋОЊОбОЋОф ОъОЋОЕОЉОфОЋОф ОЉ-# ОљОцОюОЎОДОдОЎОЋОф}}</translation>
<translation id="1525508553941733066">ОАОњОЎОеОћ</translation>
<translation id="15373452373711364">ОАОъОЪ ОбОЏОЉОе ОњОЊОЋОю</translation>
<translation id="1546492247443594934">ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ 2</translation>
<translation id="1550523713251050646">ОЎОЕ ОюОюОЌОЋОЦ ОюОДОЉОюОф ОљОцОЕОеОЋОЎОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="1555130319947370107">ОЏОЌОЋОю</translation>
<translation id="1570871743947603115">РђЈОћОцОбОюОћ ОљОЋ ОћОЕОЉОфОћ ОЕОю Bluetooth. <ph name="STATE_TEXT" /></translation>
<translation id="1589090746204042747">ОњОЎОЕОћ ОюОЏОю ОћОцОбОЎОюОЋОф ОЕОюОџ ОЉОАОЕОЪ ОћОќОћ</translation>
<translation id="1611993646327628135">ОцОЋОбОю</translation>
<translation id="1615402009686901181">ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОъОаОћОю ОћОъОбОеОЏОф, ОдОЎОюОЋОЮ ОћОъОАОџ ОъОЋОЕОЉОф ОЏОЕОъОЋОдОњ ОфОЋОЏОЪ ОАОЋОЊОЎ</translation>
<translation id="1632985212731562677">ОаОЎОфОЪ ОюОћОЕОЉОЎОф ОљОф ОћОфОЏОЋОаОћ 'ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ' ОЊОеОџ 'ОћОњОЊОеОЋОф' &gt; 'ОаОњОЎОЕОЋОф'.</translation>
<translation id="1654477262762802994">ОћОцОбОюОћ ОЕОю ОЕОљОЎОюОфОћ ОДОЋОюОЎОф</translation>
<translation id="1667964833127753507">ОЉОъОдОЉ 'ОдОЉОбОЎОЮ ОаОЎОўОеОюОЎОЎОЮ' ОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОдОЉОбОЎОЮ ОЕОаОЕОюОцОЋ ОъОћОўОцОў, ОљОюОљ ОЉОбОеОЏОф ОњОЋОЋОаОЎОЮ ОаОЎОўОеОюОЎОЎОЮ, ОЉОћОЎОеОЎОЮ ОЋОЏОћОЎОЮ.</translation>
<translation id="1677472565718498478">ОќОъОЪ ОаОЋОфОе - <ph name="TIME" /></translation>
<translation id="1677507110654891115">ОћОфОЏОЋОаОћ <ph name="FEATURE_NAME" /> ОюОљ ОъОЌОЋОЉОеОф.</translation>
<translation id="1698080062160024910">ОўОЎОЎОъОе ОЕОю <ph name="TOTAL_TIME" /> ┬и <ph name="LABEL" /></translation>
<translation id="1698760176351776263">РђЈОЏОфОЋОЉОф IPv6: <ph name="ADDRESS" /></translation>
<translation id="1708345662127501511">ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ ОЋОЎОеОўОЋОљОюОЎ: <ph name="DESK_NAME" /></translation>
<translation id="1709762881904163296">ОћОњОЊОеОЋОф ОеОЕОф</translation>
<translation id="1719094688023114093">ОћОфОЏОЋОаОћ 'ОЏОфОЋОЉОЎОЋОф ОъОЎОЎОЊОЎОЋОф' ОъОЋОцОбОюОф.</translation>
<translation id="1720011244392820496">РђЈОћОцОбОюОћ ОЕОю ОАОаОЏОеОЋОЪ Wi-Fi</translation>
<translation id="1743570585616704562">ОюОљ ОъОќОЋОћОћ</translation>
<translation id="1746730358044914197">ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ ОъОњОЊОЎОе ОљОф ОЕОЎОўОЋОф ОћОДОюОў.</translation>
<translation id="1747827819627189109">ОћОъОДОюОЊОф ОЕОъОЋОцОЎОбОћ ОЉОъОАОџ ОъОЋОцОбОюОф</translation>
<translation id="1761222317188459878">ОћОцОбОюОћ ОљОЋ ОћОЕОЉОфОћ ОЕОю ОћОЌОЎОЉОЋОе ОюОеОЕОф. <ph name="STATE_TEXT" /></translation>
<translation id="1768366657309696705">РђЈОъОДОЕОЎ ОћОДОЎОдОЋОе <ph name="LAUNCHER_KEY_NAME" /> + ОаОДОЋОЊОћ ОћОЕОфОаОЋ. ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉОъОДОЕ Insert, ОЎОЕ ОюОћОДОЎОЕ ОбОю <ph name="LAUNCHER_KEY_NAME" /> + Shift + РђЈBackspace.</translation>
<translation id="1771761307086386028">ОњОюОЎОюОћ ОЎОъОЎОаОћ</translation>
<translation id="1782199038061388045">ОфОеОњОЋОЮ</translation>
<translation id="1787955149152357925">ОЏОЉОЋОЎ</translation>
<translation id="1804572139604454141">ОћОћОДОюОўОћ ОћОАОфОЎОЎОъОћ ОЏОЎ ОаОцОЌ ОћОљОЌОАОЋОЪ ОЉОЊОЎОАОД ОЏОъОбОў ОаОњОъОе</translation>
<translation id="181103072419391116">ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" />, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ</translation>
<translation id="1812997170047690955">ОъОћ ОъОЋОцОЎОб ОЉОъОАОџ ОЕОюОЎ?</translation>
<translation id="1823873187264960516">ОљОфОеОаОў: <ph name="ADDRESS" /></translation>
<translation id="1836215606488044471">РђЈAssistant (ОЉОўОбОЎОаОћ...)</translation>
<translation id="1838895407229022812">ОфОљОЋОеОф ОћОюОЎОюОћ ОЏОЉОЋОЎОћ.</translation>
<translation id="1864454756846565995">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОљОЌОЋОеОЎОф)</translation>
<translation id="1882814835921407042">ОљОЎОЪ ОеОЕОф ОАОюОЋОюОеОЎОф</translation>
<translation id="1882897271359938046">ОъОЕОДОБ ОљОю <ph name="DISPLAY_NAME" /></translation>
<translation id="1885785240814121742">ОЉОЎОўОЋОю ОаОбОЎОюОћ ОбОЮ ОўОЉОЎОбОф ОљОдОЉОб</translation>
<translation id="1888656773939766144">РђЈ<ph name="DISPLAY_NAME" /> ОюОљ ОфОЋОъОџ ОЉОеОќОЋОюОЋОдОЎОћ ОЕОю <ph name="SPECIFIED_RESOLUTION" /> РђЈ(<ph name="SPECIFIED_REFRESH_RATE" />Hz). ОћОеОќОЋОюОЋОдОЎОћ ОћОЋОЌОюОцОћ Ою-<ph name="FALLBACK_RESOLUTION" /> РђЈ(<ph name="FALLBACK_REFRESH_RATE" />). ОбОюОЎОџ ОюОюОЌОЋОЦ ОбОю 'ОљОЎОЕОЋОе' ОЏОЊОЎ ОюОЕОъОЋОе ОљОф ОћОЕОЎОаОЋОЎОЎОЮ. ОћОћОњОЊОеОЋОф ОћОДОЋОЊОъОЋОф ОЎОЕОЋОЌОќОеОЋ ОЉОбОЋОЊ <ph name="TIMEOUT_SECONDS" />.</translation>
<translation id="1919743966458266018">ОъОДОЕ ОћОДОЎОдОЋОе ОюОцОфОЎОЌОф ОъОаОћОю ОћОъОЕОЎОъОЋОф ОћОЕОфОаОћ. ОЎОЕ ОюОћОЕОфОъОЕ ОЉ-<ph name="NEW_SHORTCUT" /> ОЉОъОДОЋОЮ ОЉ-<ph name="OLD_SHORTCUT" />.</translation>
<translation id="1923539912171292317">ОюОЌОЎОдОЋОф ОљОЋОўОЋОъОўОЎОЋОф</translation>
<translation id="1928739107511554905">РђЈОЏОЊОЎ ОюОћОфОДОЎОЪ ОљОф ОћОбОЊОЏОЋОЪ, ОЎОЕ ОюОћОЕОфОъОЕ ОЉОъОАОџ ОћОъОњОб ОЋОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Оћ-Chromebook ОЏОЕОћОъОДОюОЊОф ОъОЌОЋОЉОеОф.</translation>
