<translation id="3039939407102840004">ОеОъОф ОћОўОбОЎОаОћ ОЕОю ОАОЋОюОюОф ОћОАОўОЎОЎОюОЋОА: <ph name="PERCENTAGE" />.</translation>
<translation id="3045488863354895414">ОљОЌОћ"Од ОўОЋОЉОЎОЮ,</translation>
<translation id="3051189971848907985">ОЕОЎОаОЋОЎ ОЕОЮ ОћОцОеОЋОцОЎОю ОъОфОЉОдОб. ОЎОЕ ОюОћОъОфОЎОЪ ОъОАОцОе ОЊОДОЋОф.</translation>
