<translation id="5397578532367286026">РђЈОћОъОаОћОю (<ph name="MANAGER_EMAIL" />) ОЎОЏОЋОю ОюОЉОЊОЋОД ОљОф ОћОЕОЎОъОЋОЕ ОЋОћОћОЎОАОўОЋОеОЎОћ ОЕОю ОъОЕОфОъОЕ ОќОћ ОЉ-chrome.com.</translation>
<translation id="5400461572260843123">ОћОњОЊОеОЋОф ОъОћОЎОеОЋОф, ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЎОцОЋОЕ ОЉОЎОЌОЊ ОбОЮ ОъОДОЕ ОЌОЦ ОЕОъОљОюОћ ОЏОЊОЎ ОюОњОЕОф ОљОю ОъОеОЏОќ ОћОћОфОеОљОЋОф.</translation>
<translation id="5426063383988017631">ОфОцОеОЎОў ОћОћОњОЊОеОЋОф ОаОАОњОе</translation>
<translation id="5428899915242071344">ОљОаОЎ ОеОЋОдОћ ОюОћОфОЌОЎОю ОюОЉОЌОЋОе</translation>
<translation id="5430931332414098647">ОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў ОъОЎОЎОЊОЎ ОЉОЎОЪ ОаОЎОЎОЊОЎОЮ</translation>
<translation id="5431825016875453137">OpenVPN / L2TP</translation>
<translation id="544691375626129091">ОЏОю ОћОъОЕОфОъОЕОЎОЮ ОћОќОъОЎОаОЎОЮ ОЏОЉОе ОаОЋОАОцОЋ ОюОцОбОЎОюОЋОф ОќОЋ ОЉОљОфОе.</translation>
<translation id="54609108002486618">ОъОаОЋОћОю</translation>
<translation id="5465662442746197494">ОЎОЕ ОдОЋОеОџ ОЉОбОќОеОћ?</translation>
<translation id="5496819745535887422">ОъОаОћОю ОћОъОбОеОЏОф ОъОЌОќОЎОе ОљОф ОћОъОЏОЕОЎОе ОюОъОдОЉ ОДОЋОЊОЮ. ОЏОю ОћОаОфОЋОаОЎОЮ ОЎОЎОъОЌОДОЋ ОљОЌОеОЎ ОЕОћОъОЏОЕОЎОе ОЎОЋОцОбОю ОъОЌОЊОЕ.</translation>
<translation id="5519195206574732858">LTE</translation>
<translation id="5523434445161341166">ОћОфОЏОЋОаОћ <ph name="FEATURE_NAME" /> ОъОфОЌОЉОеОф.</translation>
<translation id="5532994612895037630">ОЎОЕ ОюОћОДОЎОЕ ОЉОъОДОЋОЮ ОЏОюОЕОћОЋ ОЏОЊОЎ ОюОћОДОюОЎОў ОљОф ОћОъОАОџ ОћОъОюОљ</translation>
<translation id="553675580533261935">ОЎОдОЎОљОћ ОъОћОћОцОбОюОћ</translation>
<translation id="5537725057119320332">ОћОбОЉОеОћ</translation>
<translation id="554893713779400387">ОћОцОбОюОф ОћОЏОфОЉОћ ОљОЋ ОћОцОАОДОфОћ</translation>
<translation id="556042886152191864">ОюОЌОдОЪ</translation>
<translation id="5571066253365925590">РђЈBluetooth ОъОЋОцОбОю</translation>
<translation id="557563299383177668">ОћОцОАОДОћ ОћОЉОљОћ</translation>
<translation id="5577281275355252094">РђЈОЎОЕ ОюОЉОЊОЋОД ОЕОћ-Bluetooth ОцОЋОбОю ОЉОўОюОцОЋОЪ ОЏОЊОЎ ОюОћОЕОфОъОЕ ОЉ-Phone Hub</translation>
<translation id="558849140439112033">ОЎОЕ ОюОњОеОЋОе ОЏОЊОЎ ОюОЉОЌОЋОе ОљОќОЋОе ОюОдОЎОюОЋОЮ</translation>
<translation id="5597451508971090205"><ph name="SHORT_WEEKDAY" />, <ph name="DATE" /></translation>
<translation id="5600837773213129531">РђЈОЎОЕ ОюОћОДОЎОЕ ОбОю Ctrl РђЈ+ Alt РђЈ+ Z ОЏОЊОЎ ОюОћОЕОЉОЎОф ОљОф ОћОъОЕОЋОЉ ОћОДОЋОюОЎ.</translation>
<translation id="5601503069213153581">ОДОЋОЊ ОљОЎОъОЋОф</translation>
<translation id="5619862035903135339">ОюОцОЎ ОћОъОЊОЎОаОЎОЋОф ОЕОю ОъОаОћОю ОћОъОбОеОЏОф, ОдОЎОюОЋОЮ ОћОъОАОџ ОъОЋОЕОЉОф</translation>
<translation id="5625955975703555628">+LTE</translation>
<translation id="5648021990716966815">ОЕОДОб ОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="5662709761327382534">РђЈОћОДОюОўОф ОћОъОЎОДОеОЋОцОЋОЪ <ph name="CURRENT_STATE" />, ОЎОЕ ОюОћОДОЎОЕ ОбОю Enter ОЏОЊОЎ ОюОћОбОЉОЎОе ОљОф ОћОДОюОўОф ОћОъОЎОДОеОЋОцОЋОЪ ОюОъОдОЉ <ph name="NEW_STATE" /></translation>
<translation id="5669267381087807207">ОћОћОцОбОюОћ ОъОфОЉОдОбОф</translation>
<translation id="5673434351075758678">Оъ"<ph name="FROM_LOCALE" />" Ою"<ph name="TO_LOCALE" />" ОљОЌОеОЎ ОАОаОЏОеОЋОЪ ОћОћОњОЊОеОЋОф.</translation>
<translation id="5677928146339483299">ОЌОАОЋОЮ</translation>
<translation id="5679050765726761783">ОћОъОфОљОЮ ОЕОЌОЎОЉОеОф ОћОЋОљ ОЉОбОю ОћОАОцОД ОаОъОЋОџ</translation>
<translation id="5682642926269496722">РђЈGoogle Assistant ОюОљ ОќОъОЎОаОћ ОюОЌОЕОЉОЋОЪ ОћОъОЕОфОъОЕ ОћОаОЋОЏОЌОЎ.</translation>
<translation id="5689633613396158040">ОбОЮ ОфОљОЋОеОф ОюОЎОюОћ, ОДОю ОЎОЋОфОе ОюОћОАОфОЏОю ОбОю ОћОъОАОџ ОљОЋ ОюОДОеОЋОљ ОЏОЕОћОфОљОЋОеОћ ОъОАОЉОЎОЉ ОбОъОЋОъОћ. ОЎОЕ ОюОћОДОЎОЕ ОЏОЊОЎ ОюОЕОаОЋОф ОљОф ОћОЕОбОћ ОЕОЉОћ ОъОЋОцОбОюОф 'ОфОљОЋОеОф ОюОЎОюОћ' ОљОЋ ОЏОЊОЎ ОюОЏОЉОЋОф ОљОЋОфОћ ОюОњОъОеОЎ.</translation>
<translation id="5691772641933328258">ОўОЉОЎОбОф ОћОљОдОЉОб ОюОљ ОќОЋОћОфОћ</translation>
<translation id="5710450975648804523">ОъОдОЉ 'ОаОљ ОюОљ ОюОћОцОеОЎОб' ОъОЋОцОбОю</translation>
<translation id="571295407079589142">ОЌОЉОЎОюОф ОћОњОюОЎОЕОћ ОЏОЉОЋОЎОћ</translation>
<translation id="573413375004481890">ОћОъОЏОЕОЎОе ОћОќОћ ОюОљ ОћОдОюОЎОЌ ОюОфОъОЋОџ ОЉОЏОю ОћОъОАОЏОЎОЮ, ОЋОюОЏОЪ ОљОЌОЊ ОъОћОЮ ОаОЋОфОД</translation>
<translation id="574392208103952083">ОЉОЎОаОЋОаОЎ</translation>
<translation id="5744083938413354016">ОћОДОЕОћ ОЋОњОеОЎОеОћ</translation>
<translation id="5745612484876805746">ОфОљОЋОеОф ОюОЎОюОћ ОаОЊОюОДОф ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОЕОбОф ОћОЕОДОЎОбОћ</translation>
<translation id="5750765938512549687">РђЈBluetooth ОЏОЉОЋОЎ</translation>
<translation id="576453121877257266">ОфОљОЋОеОф ОћОюОЎОюОћ ОцОЋОбОюОф.</translation>
<translation id="5769373120130404283">ОъОАОџ ОцОеОўОЎОЋОф</translation>
<translation id="5777841717266010279">ОюОћОцОАОЎОД ОљОф ОЕОЎОфОЋОБ ОћОъОАОџ?</translation>
<translation id="5779721926447984944">ОДОЉОдОЎОЮ ОъОЋОдОъОЊОЎОЮ</translation>
<translation id="5790085346892983794">ОћОдОюОЌОћ</translation>
<translation id="5805809050170488595">ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОћОцОбОЎОю ОљОф <ph name="NETWORK_NAME" /></translation>
<translation id="5820394555380036790">РђЈОъОбОеОЏОф ОћОћОцОбОюОћ ОЕОю Chromium</translation>
<translation id="5825969630400862129">ОћОњОЊОеОЋОф ОЕОю ОъОЏОЕОЎОеОЎОЮ ОъОЌОЋОЉОеОЎОЮ</translation>
<translation id="583281660410589416">ОюОљ ОЎОЊОЋОб</translation>
<translation id="5837036133683224804">ОћОцОАОДОф <ph name="ROUTE_TITLE" /> ОЉОъОЏОЕОЎОе <ph name="RECEIVER_NAME" /></translation>
<translation id="5860033963881614850">ОЏОЉОЋОЎ</translation>
<translation id="5860491529813859533">ОћОцОбОюОћ</translation>
<translation id="5876666360658629066">ОЎОЕ ОюОћОќОЎОЪ ОДОЋОЊ ОњОЎОЕОћ ОюОћОЋОеОЎОЮ</translation>
<translation id="5881540930187678962">РђЈОюОћОњОЊОеОф Phone Hub ОЉОъОЋОбОЊ ОъОљОЋОЌОе ОЎОЋОфОе</translation>
<translation id="5895138241574237353">ОћОцОбОюОћ ОъОЌОЊОЕ</translation>
<translation id="589817443623831496">ОАОеОЎОДОф ОаОДОЋОЊОЋОф</translation>
<translation id="5901316534475909376">Shift+Esc</translation>
<translation id="5909862606227538307">ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ ОЋОЎОеОўОЋОљОюОЎ ОюОљ ОцОбОЎОю.</translation>
<translation id="5911909173233110115"><ph name="USERNAME" /> (<ph name="MAIL" />)</translation>
<translation id="5916664084637901428">ОцОЋОбОю</translation>
<translation id="5920710855273935292">ОћОъОЎОДОеОЋОцОЋОЪ ОъОЋОЕОфОД.</translation>
<translation id="5946788582095584774"><ph name="FEATURE_NAME" /> ОцОбОЎОюОЋОф.</translation>
<translation id="5947494881799873997">ОЌОќОеОћ ОюОњОеОАОћ ОћОДОЋОЊОъОф</translation>
<translation id="595202126637698455">ОъОбОДОЉ ОљОЌОе ОћОЉОЎОдОЋОбОЎОЮ ОъОЋОцОбОю</translation>
<translation id="5958529069007801266">ОъОЕОфОъОЕ ОЉОцОЎОДОЋОЌ</translation>
<translation id="5960825221082587934">РђЈAssistant ОфОЋОЏОю ОюОћОдОЎОњ ОъОЎОЊОб ОюОњОЉОЎ ОћОўОДОАОў ОЕОЉОЌОеОф, ОЏОъОЋ ОћОћОњОЊОеОћ, ОћОфОеОњОЋОЮ ОљОЋ ОћОъОеОф ОћОЎОЌОЎОЊОЋОф.</translation>
<translation id="5977415296283489383">ОљОЋОќОаОЎОЋОф</translation>
<translation id="5978382165065462689">ОЕОЎОфОЋОБ ОЕОюОЎОўОћ ОЉОъОАОџ ОЊОеОџ ОАОЎОЋОб ОъОеОЌОЋОД.</translation>
<translation id="5980301590375426705">ОЎОдОЎОљОћ ОъОћОцОбОюОф ОљОЋОеОЌ</translation>
<translation id="598882571027504733">РђЈОЏОЊОЎ ОюОћОфОДОЎОЪ ОљОф ОћОбОЊОЏОЋОЪ, ОЎОЕ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОљОф Оћ-Chromebook ОЏОЕОћОъОДОюОЊОф ОъОЌОЋОЉОеОф.</translation>
<translation id="5992218262414051481">РђЈОъОдОЉ ОаОЎОњОЋОЊОЎОЋОф ОњОЉОЋОћОћ ОцОЋОбОю. ОЎОЕ ОюОћОДОЎОЕ ОЕОЋОЉ ОбОю Ctrl+Search+H ОЏОЊОЎ ОюОЏОЉОЋОф ОљОЋОфОЋ.</translation>
<translation id="6018164090099858612">ОЎОдОЎОљОћ ОъОъОдОЉ ОЕОЎОДОЋОБ</translation>
<translation id="602001110135236999">ОњОюОЎОюОћ ОЕОъОљОюОћ</translation>
<translation id="602472752137106327">ОћОдОњОф ОЌОюОЋОаОЋОф ОъОЏОю ОЕОЋОюОЌОаОЋОф ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОЎОЮ, ОюОЌОдОЪ ОћОЉОЌОЎОеОћ ОаОЉОЌОе</translation>
<translation id="6025324406281560198"><ph name="SECURITY_STATUS" />,РђЈ <ph name="CONNECTION_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" />, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ</translation>
<translation id="6030495522958826102">ОћОфОцОеОЎОў ОћОЋОбОЉОе ОюОцОЎОаОћ ОћОЎОъОаОЎОф ОћОфОЌОфОЋОаОћ ОЕОю ОћОъОАОџ.</translation>
<translation id="6032620807120418574">ОЎОЕ ОюОюОЌОЋОЦ ОбОю ОъОДОЋОЮ ОЏОюОЕОћОЋ ОЉОъОАОџ ОЏОЊОЎ ОюОћОДОюОЎОў ОљОф ОћОъОАОџ ОћОъОюОљ.</translation>
<translation id="6040071906258664830">ОћОДОюОўОф ОћОъОЎОДОеОЋОцОЋОЪ <ph name="STATE" /></translation>
<translation id="6040143037577758943">ОАОњОЎОеОћ</translation>
<translation id="6043212731627905357">ОљОЎОЪ ОЏОЎОъОЎОћ ОЉОЎОЪ ОћОдОњ ОћОќОћ ОюОъОЏОЕОЎОе Оћ-<ph name="DEVICE_TYPE" /> ОЕОюОџ (ОћОъОЏОЕОЎОе ОюОљ ОфОЋОъОџ ОЉОдОњ).</translation>
<translation id="6043994281159824495">ОЎОдОЎОљОћ ОбОЏОЕОЎОЋ</translation>
<translation id="6047696787498798094">ОЕОЎОфОЋОБ ОћОъОАОџ ОЎОцОАОЎОД ОЉОеОњОб ОЕОфОбОЉОЋОе ОюОъОЕОфОъОЕ ОљОЌОе. ОћОљОЮ ОЉОеОдОЋОаОџ ОюОћОъОЕОЎОџ?</translation>
<translation id="6050368268239407309">ОЏОюОЎОЮ ОюОъОдОњОЋОф</translation>
<translation id="6054305421211936131">ОЏОаОЎОАОћ ОЉОљОъОдОбОЋОф ОЏОеОўОЎОА ОЌОЏОЮ</translation>
<translation id="6059276912018042191">РђЈОЏОеОўОЎОАОЎОЋОф Chrome ОљОЌОеОЋОаОЋОф</translation>
<translation id="6062360702481658777">ОфОЉОЋОдОб ОЎОдОЎОљОћ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ ОЉОбОЋОЊ <ph name="LOGOUT_TIME_LEFT" />.</translation>
<translation id="6073451960410192870">ОћОцОАОДОф ОдОЎОюОЋОЮ ОћОАОеОўОЋОЪ</translation>
<translation id="607652042414456612">РђЈОъОЏОЕОЎОеОЎ Bluetooth ОДОеОЋОЉОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОљОфОе ОљОф ОћОъОЌОЕОЉ ОЕОюОџ, ОЋОћОЋОљ ОЎОЋОцОЎОб ОЏ-"<ph name="NAME" />" ОбОЮ ОћОЏОфОЋОЉОф <ph name="ADDRESS" /></translation>
<translation id="6094290315941448991">ОЉОћОфОљОЮ ОюОъОЊОЎОаОЎОЋОф ОъОаОћОю ОћОъОбОеОЏОф, ОћОДОюОўОф ОћОъОАОџ ОъОЋОЕОЉОфОф ОЏОЕОъОЋОдОњ ОфОЋОЏОЪ ОАОЋОЊОЎ</translation>
<translation id="6119360623251949462"><ph name="CHARGING_STATE" />. <ph name="BATTERY_SAVER_STATE" /></translation>
<translation id="612734058257491180">РђЈGoogle Assistant ОюОљ ОќОъОЎОаОћ ОЉОњОюОЎОЕОћ ОЏОљОЋОеОЌ.</translation>
<translation id="6137566720514957455">ОцОфОЎОЌОф ОфОЎОЉОф ОЊОЋ-ОЊОЎОЌ ОюОћОАОеОћ ОЕОю <ph name="USER_EMAIL_ADDRESS" /></translation>
<translation id="6154006699632741460">ОљОЎОЪ ОфОъОЎОЏОћ ОЉОдОЎОЋОЊ ОћОћОЎОДОцОЎ</translation>
<translation id="615957422585914272">ОћОдОњОф ОъОДОюОЊОф ОЉОъОАОџ</translation>
<translation id="6165508094623778733">ОюОъОЎОЊОб ОаОЋОАОБ</translation>
<translation id="6179832488876878285">ОЏОљОЪ ОљОцОЕОе ОюОћОдОъОЎОЊ ОљОф ОћОДОЉОдОЎОЮ ОћОЌОЕОЋОЉОЎОЮ. ОЎОЕ ОюОцОфОЋОЌ ОљОф ОљОцОюОЎОДОдОЎОЎОф 'ОДОЉОдОЎОЮ' ОЏОЊОЎ ОюОћОфОЌОЎОю.</translation>
<translation id="622484624075952240">ОюОъОўОћ</translation>
<translation id="6231419273573514727">ОЎОЎОфОЏОЪ ОЕОћОЉОЎОдОЋОбОЎОЮ ОЕОю ОћОдОЎОЋОЊ ОћОћОЎОДОцОЎ ОЎОЋОњОЉОюОЋ</translation>
<translation id="6236290670123303279">ОаОЎОћОЋОю ОћОћОњОЊОеОЋОф</translation>
<translation id="6237231532760393653">Рђј1XРђј</translation>
<translation id="6254629735336163724">ОаОбОЋОю ОЉОъОдОЉ ОљОЋОцОДОЎ</translation>
<translation id="6259254695169772643">ОЏОЊОЎ ОюОЉОЌОЋОе ОЎОЕ ОюОћОЕОфОъОЕ ОЉОАОўОЎОЎОюОЋОА</translation>
<translation id="6267036997247669271"><ph name="NAME" />: ОЉОћОцОбОюОћ...</translation>
<translation id="6283712521836204486">ОъОдОЉ 'ОаОљ ОюОљ ОюОћОцОеОЎОб' ОъОЋОЕОЉОф.</translation>
<translation id="6284232397434400372">ОћОеОќОЋОюОЋОдОЎОћ ОћОЕОфОаОфОћ</translation>
<translation id="6288235558961782912">ОаОЎОфОЪ ОЎОћОЎОћ ОюОћОЋОАОЎОБ ОљОф <ph name="USER_EMAIL_ADDRESS" /> ОъОЌОЊОЕ ОъОљОЋОЌОе ОЎОЋОфОе ОюОљОЌОе ОЕОЎОфОДОЉОю ОљОЎОЕОЋОе ОЕОю ОћОЋОеОћ.</translation>
<translation id="6291221004442998378">ОюОљ ОЉОўОбОЎОаОћ</translation>
<translation id="6297287540776456956">ОЎОЕ ОюОЉОЌОЋОе ОљОќОЋОе ОЉОљОъОдОбОЋОф ОћОАОўОЎОЎОюОЋОА</translation>
<translation id="6310121235600822547"><ph name="DISPLAY_NAME" /> ОАОЋОЉОЉ ОљОю <ph name="ROTATION" /></translation>
<translation id="6315170314923504164">ОДОЋОю</translation>
<translation id="6330012934079202188">ОъОЋОдОњОЎОЮ ОћОЌОюОЋОаОЋОф ОъОЏОю ОЕОЋОюОЌОаОЋОф ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОЎОЮ. ОаОЎОфОЪ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОбОюОћ ОЏОЊОЎ ОюОћОдОЎОњ ОљОф ОћОЌОюОЋОаОЋОф ОъОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎ ОћОаОЋОЏОЌОЎ</translation>
<translation id="6338485349199627913"><ph name="DISPLAY_NAME" /> ОћОЋОљ ОАОЕОЪ ОъОаОЋОћОю ОЕОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="MANAGER" /></translation>
<translation id="6376931439017688372">РђЈBluetooth ОцОЋОбОю</translation>
<translation id="6381109794406942707">ОЏОЊОЎ ОюОЉОўОю ОљОф ОћОаОбОЎОюОћ ОЕОю ОћОъОЏОЕОЎОе, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф.</translation>
<translation id="639644700271529076">РђЈCAPS LOCK ОЏОЉОЋОЎ</translation>
<translation id="6406704438230478924">altgr</translation>
<translation id="6424520630891723617"><ph name="SECURITY_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" /></translation>
<translation id="642644398083277086">ОаОЎОДОЋОЎ ОЏОю ОћОћОЋОЊОбОЋОф</translation>
<translation id="643147933154517414">ОћОцОбОЋОюОћ ОћОЋОЕОюОъОћ</translation>
<translation id="6431865393913628856">ОћОДОюОўОф ОћОъОАОџ</translation>
<translation id="6445835306623867477"><ph name="ROUTE_TITLE" /> ОЉОъОЏОЕОЎОе <ph name="RECEIVER_NAME" /></translation>
<translation id="6452181791372256707">ОЊОЌОЎОЎОћ</translation>
<translation id="6453179446719226835">ОЕОЎОаОЋОЎ ОћОЕОцОћ ОћОАОфОЎОЎОЮ</translation>
<translation id="6459472438155181876">ОћОеОЌОЉОф ОћОъОАОџ ОљОю <ph name="DISPLAY_NAME" /> ОъОфОЉОдОбОф</translation>
<translation id="6482559668224714696">ОќОЏОЋОЏОЎОф ОъОњОЊОюОф ОЉОъОАОџ ОъОюОљ</translation>
<translation id="6490471652906364588">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЎОъОаОЎОф)</translation>
<translation id="649452524636452238">ОДОЋОЊ ОћОљОЎОъОЋОф ОЕОю ОћОЏОеОўОЎОА ОћОЌОЏОЮ</translation>
<translation id="6501401484702599040">ОћОбОЉОеОф ОћОъОАОџ ОљОю <ph name="RECEIVER_NAME" /> ОъОфОЉОдОбОф</translation>
<translation id="6520517963145875092">ОЎОЕ ОюОЉОЌОЋОе ОЌОюОЋОЪ ОюОдОЎОюОЋОЮ</translation>
<translation id="652139407789908527">ОЉОъОћОюОџ ОћОбОЊОЏОЋОЪ, ОЎОЎОфОЏОЪ ОЕОћОфОдОЋОњОћ ОЉОъОАОџ ОфОЋОцОАОД ОюОцОеОД ОќОъОЪ ОљОеОЋОџ ОъОћОеОњОЎОю (ОбОЊ ОЊОДОћ). ОљОЎОЪ ОюОюОЌОЋОЦ ОбОю ОюОЌОдОЪ ОћОћОцОбОюОћ ОбОЊ ОюОћОЕОюОъОф ОћОбОЊОЏОЋОЪ.</translation>
<translation id="6528179044667508675">ОаОљ ОюОљ ОюОћОцОеОЎОб</translation>
<translation id="65320610082834431">ОљОъОЋОњ'ОЎ</translation>
<translation id="6537270692134705506">ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="6537924328260219877">ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" />, ОАОЋОюОюОф ОћОўОюОцОЋОЪ: <ph name="BATTERY_STATUS" /></translation>
<translation id="6542521951477560771">ОћОћОбОЉОеОћ ОљОю <ph name="RECEIVER_NAME" /> ОъОфОЉОдОбОф</translation>
<translation id="6559976592393364813">ОЎОЕ ОюОЉОДОЕ ОъОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="6570902864550063460">РђЈОъОфОЉОдОбОф ОўОбОЎОаОћ ОЉОљОъОдОбОЋОф USB</translation>
<translation id="6585808820553845416">ОћОцОбОЎОюОЋОф ОЉОљОфОе ОфОАОфОЎОЎОЮ ОЉОбОЋОЊ <ph name="SESSION_TIME_REMAINING" />.</translation>
<translation id="661203523074512333"><ph name="SECURITY_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" />, ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="6612802754306526077">ОаОЉОЌОе ОъОдОЉ ОЕОю ОћОДОюОўОф ОъОАОџ</translation>
<translation id="6614169507485700968">ОъОАОџ ОћОцОеОўОЎОЋОф ОцОЋОбОю</translation>
<translation id="6627638273713273709">РђЈОЌОЎОцОЋОЕ+ShiftРђЈ+K</translation>
<translation id="6629480180092995136">ОћОљОцОюОЎОДОдОЎОћ <ph name="APP_NAME" /> ОъОЉОДОЕОф ОюОћОЕОфОъОЕ ОЉОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="6637729079642709226">ОЕОЎОаОЋОЎ ОћОќОъОЪ</translation>
<translation id="6641720045729354415">ОћОЌОюОцОћ ОюОъОдОЉ 'ОЏОфОЋОЉОЎОЋОф ОъОЎОЎОЊОЎОЋОф'. <ph name="STATE_TEXT" /></translation>
<translation id="6650072551060208490">ОЏОЊОЎ ОюОћОфОЌОЉОе ОљОю <ph name="ORIGIN_NAME" /> ОЎОЕ ОюОљОъОф ОљОф ОќОћОЋОфОџ</translation>
<translation id="6650933572246256093">РђЈОъОЏОЕОЎОе Оћ-Bluetooth РђЈ"<ph name="DEVICE_NAME" />" ОъОЉОДОЕ ОћОеОЕОљОћ ОюОЉОЎОдОЋОб ОћОфОљОъОћ. ОЎОЕ ОюОћОќОЎОЪ ОљОф ОъОцОфОЌ ОћОАОЎОАОъОћ ОћОЉОљ ОЉОъОЏОЕОЎОе ОћОќОћ: <ph name="PASSKEY" /></translation>
<translation id="6657585470893396449">ОАОЎОАОъОћ</translation>
<translation id="6665545700722362599">ОћОбОаОДОф ОћОеОЕОљОћ ОюОљОфОеОЎОЮ, ОюОљОцОюОЎОДОдОЎОЋОф ОЋОюОфОЋОАОцОЎОЮ ОюОћОЕОфОъОЕ ОЉОЕОЎОеОЋОфОЎ ОћОъОЎОДОЋОЮ, ОЉОъОЎОДОеОЋОцОЋОЪ ОЕОю ОћОъОЏОЕОЎОе, ОЉОъОдОюОъОћ ОљОЋ ОЉОфОЏОЋОаОЋОф ОљОЌОеОЋОф.</translation>
<translation id="6667908387435388584">РђЈОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОаОДОЋОЊОћ ОюОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў (Hotspot) ОЕОю ОћОўОюОцОЋОЪ, ОюОћОЕОфОЎОД ОљОф ОћОъОЏОЕОЎОе ОЋОюОљОфОе ОљОЋОфОЋ ОЋОЏОЪ ОюОћОдОЎОњ ОљОф ОћОЏОеОўОЎОАОЎОЋОф ОћОљОЌОеОЋОаОЋОф ОЕОцОфОЋОЌОЋОф ОЉОўОюОцОЋОЪ</translation>
<translation id="6670153871843998651">ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ 3</translation>
<translation id="6671495933530132209">ОћОбОфОДОф ОћОфОъОЋОаОћ</translation>
<translation id="6692996468359469499">ОДОЉОюОф ОъОЎОЊОб ОЉОДОЕОе ОюОЉОЌОЎОеОћ ОЕОюОџ</translation>
<translation id="6696025732084565524">ОюОъОДОюОЊОф ОћОаОЎОфОаОф ОюОаОЎОфОЋОД ОЊОеОЋОЕ ОбОЊОЏОЋОЪ ОДОеОЎОўОЎ</translation>
<translation id="6700713906295497288">РђЈОюОЌОдОЪ ОфОцОеОЎОў IME</translation>
<translation id="6713285437468012787">РђЈОъОЏОЕОЎОе Оћ-BluetoothРђЈ "<ph name="DEVICE_NAME" />" ОћОЋОфОљОЮ ОЋОћОЋОљ ОќОъОЎОЪ ОЏОбОф ОюОЏОю ОћОъОЕОфОъОЕОЎОЮ. ОаОЎОфОЪ ОюОћОАОЎОе ОљОф ОћОћОфОљОъОћ ОћОќОЋ ОЉ'ОћОњОЊОеОЋОф'.</translation>
<translation id="6715542151869432661">ОюОљ ОаОъОдОљОЋ ОъОЏОЕОЎОеОЎОЮ ОаОЎОЎОЊОЎОЮ.</translation>
<translation id="6723839937902243910">ОЌОЕОъОю</translation>
<translation id="6727969043791803658">РђЈОъОЌОЋОЉОе, Рђј<ph name="BATTERY_PERCENTAGE" />%Рђј ОАОЋОюОюОћ</translation>
<translation id="6732800389263199929">Рђј+<ph name="COUNT" /></translation>
<translation id="6751052314767925245">ОћОфОЏОЋОаОћ ОћОќОЋ ОаОљОЏОцОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф</translation>
<translation id="6751826523481687655">ОъОбОДОЉ ОћОЉОЎОдОЋОбОЎОЮ ОцОЋОбОю</translation>
<translation id="6752912906630585008">ОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ <ph name="REMOVED_DESK" /> ОћОЋОАОе ОЋОЕОЋОюОЉ ОбОЮ ОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ <ph name="RECEIVE_DESK" /></translation>
<translation id="6757237461819837179">ОъОЊОЎОћ ОюОљ ОъОЋОцОбОюОф</translation>
<translation id="6777216307882431711">РђЈОљОАОцОДОф ОЌОЕОъОю ОюОъОЏОЕОЎОеОЎОЮ ОћОъОЌОЋОЉОеОЎОЮ ОЉ-USB-C</translation>
<translation id="6790428901817661496">ОћОцОбОюОћ</translation>
<translation id="6803622936009808957">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОЕОДОБ ОъОАОЏОЎОЮ ОъОЏОЎОЋОЋОЪ ОЕОюОљ ОаОъОдОљОћ ОеОќОЋОюОЋОдОЎОћ ОаОфОъОЏОф. ОЉОъОДОЋОЮ ОќОљОф ОћОфОдОЋОњОћ ОбОЉОеОћ ОюОъОдОЉ ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ ОъОЋОеОЌОЉ.</translation>
<translation id="6816797338148849397">ОЎОЕ ОъОЎОЊОб ОЉОДОЕОе ОюОЉОЌОЎОеОћ ОЕОюОџ. ОЏОЊОЎ ОюОњОЕОф ОљОюОЎОЋ, ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОбОюОћ.</translation>
<translation id="6818242057446442178">ОъОЎОюОћ ОљОЌОф ОљОЌОЋОеОћ</translation>
<translation id="6820676911989879663">ОћОњОЎОб ОћОќОъОЪ ОюОћОцОАОДОћ</translation>
<translation id="6850010208275816200">ОћОљОцОюОЎОДОдОЎОћ ОћОаОЋОЏОЌОЎОф ОъОЋОдОњОф ОЉОъОАОџ ОъОюОљ. ОљОЮ ОћОфОЉОДОЕОф ОюОћОќОЎОЪ ОАОЎОАОъОћ, ОбОюОЎОџ ОДОЋОЊОЮ ОюОдОљОф ОъОъОАОџ ОъОюОљ.</translation>
<translation id="6852052252232534364">ОфОЋОцОбОю ОЉОюОЌОЎОдОћ</translation>
<translation id="6857725247182211756"><ph name="SECONDS" /> ОЕОаОЎОЋОф</translation>
<translation id="6857811139397017780">ОћОцОбОюОф <ph name="NETWORKSERVICE" /></translation>
<translation id="685782768769951078">{NUM_DIGITS,plural, =1{ОаОЕОљОеОћ ОАОцОеОћ ОљОЌОф}two{ОаОЕОљОеОЋ # ОАОцОеОЋОф}many{ОаОЕОљОеОЋ # ОАОцОеОЋОф}other{ОаОЕОљОеОЋ # ОАОцОеОЋОф}}</translation>
<translation id="6878400149835617132">ОДОЎОдОЋОе ОћОЊОеОџ ОъОЋОЕОЉОф</translation>
<translation id="6886172995547742638">РђЈОЎОЎОфОЏОЪ ОЕОћОЉОЎОдОЋОбОЎОЮ ОЕОю <ph name="DEVICE_TYPE" /> ОЎОћОЎОЋ ОаОъОЋОЏОЎОЮ ОЎОЋОфОе. ОЎОЕ ОюОћОЕОфОъОЕ ОЉОъОфОљОЮ ОъОфОЌ ОъОљОЋОЕОе ОЉОћОАОцОД ОЕОю <ph name="PREFERRED_MINIMUM_POWER" /> ОЋОљОў ОюОцОЌОЋОф, ОљОЋ ОъОАОЋОњ USB-C.</translation>
<translation id="688631446150864480">ОЎОЕ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОўОћ ОЏОЊОЎ ОюОбОЉОЋОе ОЉОЎОЪ ОЌОюОЋОаОЋОф</translation>
<translation id="6896758677409633944">ОћОбОфОДОћ</translation>
<translation id="6910714959251846841">РђЈОЏОЊОЎ ОюОћОфОДОЎОЪ ОљОф ОћОбОЊОЏОЋОЪ ОћОќОћ ОдОеОЎОџ ОюОЉОдОб Powerwash ОЕОю ОћОъОЏОЕОЎОе. ОљОцОЕОе ОюОДОеОЋОљ ОъОЎОЊОб ОаОЋОАОБ ОбОю ОћОбОЊОЏОЋОЪ ОћОљОЌОеОЋОЪ ОЕОю <ph name="SYSTEM_APP_NAME" />.</translation>
<translation id="6919251195245069855">ОюОљ ОаОЎОфОЪ ОћОЎОћ ОюОќОћОЋОф ОљОф ОћОЏОеОўОЎОА ОћОЌОЏОЮ ОЕОюОџ. ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="6921188888306725546">ОъОДОЕОЎ ОћОДОЎОдОЋОе ОћОЕОфОцОеОЋ</translation>
<translation id="6945221475159498467">ОЉОЌОЎОеОћ</translation>
<translation id="6961121602502368900">ОћОЕОфОДОф ОћОўОюОцОЋОЪ ОюОљ ОќОъОЎОаОћ ОЉОцОеОЋОцОЎОю ОћОбОЉОЋОЊОћ</translation>
<translation id="6961840794482373852">РђЈОъОДОЕОЎ ОћОДОЎОдОЋОе Alt + ОЌОЦ ОюОъОбОюОћ ОћОЋОЌОюОцОЋ. ОЏОЊОЎ ОюОЊОъОЋОф ОљОф ОћОцОбОЋОюОћ ОЕОю ОћОъОДОЕ Page Up, ОЎОЕ ОюОћОДОЎОЕ ОбОю <ph name="LAUNCHER_KEY_NAME" /> + ОћОЌОЦ ОюОъОбОюОћ.</translation>
<translation id="6965382102122355670">ОљОЎОЕОЋОе</translation>
<translation id="6972754398087986839">ОфОЌОЎОюОф ОћОбОЉОЋОЊОћ</translation>
<translation id="6981982820502123353">ОаОњОЎОЕОЋОф</translation>
<translation id="698231206551913481">ОЏОю ОћОДОЉОдОЎОЮ ОЋОћОаОфОЋОаОЎОЮ ОћОъОЕОЋОЎОЏОЎОЮ ОюОъОЕОфОъОЕ ОќОћ ОЎОЎОъОЌОДОЋ ОюОдОъОЎОфОЋОф ОЉОеОњОб ОЕОћОъОЕОфОъОЕ ОЎОЋОАОе.</translation>
<translation id="7007983414944123363">ОюОљ ОћОдОюОЌОаОЋ ОюОљОъОф ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф ОљОЋ ОљОф ОћОАОЎОАОъОћ ОЕОюОџ. ОљОцОЕОе ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="7015766095477679451">ОљОцОЕОе ОюОЌОќОЋОе ОЉОЕОбОћ <ph name="COME_BACK_TIME" />.</translation>
<translation id="70168403932084660">ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ ОЋОЎОеОўОЋОљОюОЎ 6</translation>
<translation id="7025533177575372252">ОЌОЎОЉОЋОе <ph name="DEVICE_NAME" /> ОюОўОюОцОЋОЪ</translation>
<translation id="7026338066939101231">ОћОцОЌОфОћ</translation>
<translation id="7029814467594812963">ОЎОдОЎОљОћ ОъОћОћОцОбОюОћ</translation>
<translation id="703425375924687388">РђЈ<ph name="QUERY_NAME" />,РђЈ Google Assistant</translation>
<translation id="7042322267639375032">ОЏОЎОЋОЋОЦ ОЕОю ОљОќОЋОе ОћОАОўОўОЋОА</translation>
<translation id="7045595904618419789">ОюОцОфОЎОЌОф ОћОќОЏОЋОЏОЎОф ОћОъОњОЊОюОф</translation>
<translation id="7055910611768509537">ОюОљ ОаОбОЕОћ ОЕОЎОъОЋОЕ ОЉОАОўОЎОЎОюОЋОА ОЎОЋОфОе ОъОЕОЉОЋОб</translation>
<translation id="7066646422045619941">ОъОаОћОю ОћОъОбОеОЏОф ОћОЕОЉОЎОф ОљОф ОћОеОЕОф ОћОќОЋ.</translation>
<translation id="7067196344162293536">ОАОЎОЉОЋОЉ ОљОЋОўОЋОъОўОЎ</translation>
<translation id="7068360136237591149">ОцОфОЎОЌОф ОДОЉОдОЎОЮ</translation>
<translation id="7076293881109082629">ОЏОаОЎОАОћ</translation>
<translation id="7088960765736518739">ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ</translation>
<translation id="7098389117866926363">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЕОъОљОюОЎОф ОъОљОЌОЋОе)</translation>
<translation id="7118268675952955085">ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="7131634465328662194">ОћОъОбОеОЏОф ОфОЋОдОЎОљ ОљОЋОфОџ ОъОћОЌОЕОЉОЋОЪ ОЉОљОЋОцОЪ ОљОЋОўОЋОъОўОЎ.</translation>
<translation id="7143207342074048698">ОъОфОЉОдОб ОЌОЎОЉОЋОе</translation>
<translation id="7144878232160441200">ОЎОЕ ОюОаОАОЋОф ОЕОЋОЉ</translation>
<translation id="7165278925115064263">Alt+Shift+K</translation>
<translation id="7168224885072002358">ОфОЉОЋОдОб ОЌОќОеОћ ОюОеОќОЋОюОЋОдОЎОћ ОћОДОЋОЊОъОф ОЉОбОЋОЊ <ph name="TIMEOUT_SECONDS" /></translation>
<translation id="7180611975245234373">ОеОбОаОЋОЪ</translation>
<translation id="7188494361780961876">ОћОфОцОеОЎОў ОћОЋОбОЉОе ОюОцОЎОаОћ ОћОЎОъОаОЎОф ОћОбОюОЎОЋОаОћ ОЕОю ОћОъОАОџ.</translation>
<translation id="7189412385142492784">ОъОћ ОћОъОеОЌОД ОЉОЎОЪ ОЏОЊОЋОе ОћОљОеОЦ ОюОаОЋОњОћ</translation>
<translation id="7246071203293827765">РђЈ<ph name="UPDATE_TEXT" />. ОЎОЕ ОюОћОцОбОЎОю ОљОф Оћ-Chromebook ОъОЌОЊОЕ ОЏОЊОЎ ОюОћОЌОЎОю ОбОЊОЏОЋОЪ. ОћОфОћОюОЎОџ ОбОЕОЋОЎ ОюОћОЎОъОЕОџ ОбОЊ ОЊОДОћ ОљОЌОф.</translation>
<translation id="7256634071279256947">ОъОЎОДОеОЋОцОЋОЪ ОљОЌОЋОеОЎ</translation>
<translation id="726276584504105859">ОюОЕОЎОъОЋОЕ ОЉОъОАОџ ОъОцОЋОдОю ОЎОЕ ОюОњОеОЋОе ОюОЏОљОЪ</translation>
<translation id="7262906531272962081">ОЎОдОЎОеОф ОфОќОЏОЋОеОф</translation>
<translation id="7279434993080105272">ОдОЉОб ОћОАОъОЪ: <ph name="COLOR_PARAMETER" /></translation>
<translation id="7302889331339392448">ОћОфОЏОЋОаОћ 'ОЏОфОЋОЉОЎОЋОф ОъОЎОЎОЊОЎОЋОф' ОъОЋОЕОЉОфОф.</translation>
<translation id="7303365578352795231">ОћОфОЕОЋОЉОћ ОъОфОДОЉОюОф ОЉОъОЏОЕОЎОе ОљОЌОе.</translation>
<translation id="7305884605064981971">EDGE</translation>
<translation id="7346909386216857016">ОЉОАОЊОе, ОћОЉОаОфОЎ</translation>
<translation id="7348093485538360975">ОъОДОюОЊОф ОбОю ОћОъОАОџ</translation>
<translation id="735745346212279324">РђЈVPN ОъОаОЋОфОД</translation>
<translation id="7360036564632145207">ОћОЉОЎОдОЋОбОЎОЮ ОбОЕОЋОЎОЎОЮ ОюОћОЕОфОцОе ОљОЮ ОћОћОњОЊОеОЋОф ОЕОю ОћОњОаОф ОћОњОЎОЕОћ ОюОаОфОЋОаОЎОЮ ОбОЉОЋОе ОдОЎОЋОЊ ОћОЎОДОцОЎ ОЎОЕОЋОаОЋ</translation>
<translation id="7371404428569700291">ОЌОюОЋОЪ ОћОћОДОюОўОћ</translation>
<translation id="7377169924702866686">РђЈCaps Lock ОъОЋОцОбОю.</translation>
<translation id="7378203170292176219">ОЎОЕ ОюОњОеОЋОе ОЏОЊОЎ ОюОЉОЌОЋОе ОљОќОЋОе ОюОћОДОюОўОћ</translation>
<translation id="7378594059915113390">ОцОДОЊОЎ ОъОЊОЎОћ</translation>
<translation id="7378889811480108604">ОъОдОЉ ОЌОАОЏОЋОЪ ОЉОАОЋОюОюОћ ОЏОЉОЋОЎ</translation>
<translation id="7392563512730092880">ОфОъОЎОЊ ОљОцОЕОе ОюОћОњОЊОЎОе ОъОљОЋОЌОе ОЎОЋОфОе ОЊОеОџ 'ОћОњОЊОеОЋОф'.</translation>
<translation id="7398254312354928459">ОЌОЎОЉОЋОе ОћОеОЕОф ОћОЋОЌОюОБ</translation>
<translation id="7405710164030118432">РђЈОЏОЊОЎ ОюОЉОўОю ОљОф ОаОбОЎОюОф ОћОъОЏОЕОЎОе, ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОњОЎОЕОф ОћОћОЋОеОћ ОЕОю Family Link</translation>
<translation id="7406608787870898861">ОАОЎОЋОЮ ОћОћОњОЊОеОћ ОЕОю ОћОеОЕОф ОћОАОюОЋОюОеОЎОф</translation>
<translation id="741244894080940828">ОћОъОеОћ</translation>
<translation id="7413851974711031813">РђЈОЎОЕ ОюОћОДОЎОЕ ОбОю "Esc" ОюОАОњОЎОеОћ</translation>
<translation id="742594950370306541">ОћОъОдОюОъОћ ОаОъОдОљОф ОЉОЕОЎОъОЋОЕ.</translation>
<translation id="742608627846767349">ОЉОЋОДОе ОўОЋОЉ,</translation>
<translation id="743058460480092004">ОћОъОдОюОъОћ ОЋОћОъОЎОДОеОЋОцОЋОЪ ОаОъОдОљОЎОЮ ОЉОЕОЎОъОЋОЕ.</translation>
<translation id="7434543979546293336">ОАОЋОъОЪ ОЏОеОбОЎОЋОЪ ОъОцОфОЌ</translation>
<translation id="7452560014878697800">ОљОцОюОЎОДОдОЎОћ ОЏОюОЕОћОЎ ОъОЕОфОъОЕОф ОЉОъОдОюОъОћ ОЕОюОџ</translation>
<translation id="7456049842111127849">ОъОдОЉ ОдОЎОюОЋОЮ ОъОАОџ, ОЉОеОЎОеОф ОћОъОЌОЊОю ОћОЎОљ <ph name="SOURCE" /> <ph name="TYPE" />.</translation>
<translation id="7461924472993315131">ОћОдОъОЊОћ</translation>
<translation id="746232733191930409">ОъОдОЉ ОћОДОюОўОф ОъОАОџ</translation>
<translation id="7466449121337984263">ОЎОЕ ОюОњОбОф ОЉОЌОЎОЎОЕОЪ</translation>
<translation id="7477793887173910789">ОЕОюОЎОўОћ ОЉОъОЋОќОЎОДОћ, ОЉОАОеОўОЋОаОЎОЮ ОЋОбОЋОЊ</translation>
<translation id="7483025031359818980">ОљОќОЋОе ОћОЉОЌОЎОеОћ ОћОЋОњОЊОе ОЏОъОАОџ ОъОюОљ</translation>
<translation id="7486227320194954040">ОЏОЎОЋОЋОЦ ОЏОюОЎ ОћОАОЎОъОЋОЪ</translation>
<translation id="7497767806359279797">ОЉОЌОЎОеОф ОЕОцОћ ОЋОъОДОюОЊОф</translation>
<translation id="7509246181739783082">ОљОЎОъОЋОф ОќОћОЋОф</translation>
<translation id="7513622367902644023">ОаОЉОЌОе ОъОдОЉ ОЕОю ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="7526573455193969409">ОЎОЎОфОЏОЪ ОЕОћОеОЕОф ОъОаОЋОўОеОф</translation>
<translation id="7536035074519304529">РђЈОЏОфОЋОЉОф IP: <ph name="ADDRESS" /></translation>
<translation id="7548434653388805669">ОюОЎОюОћ ОўОЋОЉ!</translation>
<translation id="7551643184018910560">ОћОдОъОЊОћ ОюОъОЊОБ</translation>
<translation id="7561982940498449837">ОАОњОЎОеОф ОћОфОцОеОЎОў</translation>
<translation id="7564874036684306347">ОћОбОЉОеОф ОЌОюОЋОаОЋОф ОюОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ ОљОЌОе ОбОюОЋОюОћ ОюОњОеОЋОЮ ОюОћОфОаОћОњОЋОф ОЉОюОфОЎ ОдОцОЋОЎОћ.

ОЎОЎОфОЏОЪ ОЕОћОЋОЊОбОЋОф, ОЌОюОЋОаОЋОф ОЋОфОЎОЉОЋОф ОЊОЋ-ОЕОЎОЌ ОЎОфОцОдОюОЋ ОЉОћОъОЕОџ ОЉОЎОЪ ОЕОЋОюОЌОаОЋОф ОбОЉОЋОЊОћ.</translation>
<translation id="7569509451529460200">РђЈОЏОфОЉ ОЉОеОЎОЎОю ОЋ-ChromeVox ОъОЋОцОбОюОЎОЮ</translation>
<translation id="7569983096843329377">ОЕОЌОЋОе</translation>
<translation id="7579778809502851308">ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="7590883480672980941">ОћОњОЊОеОЋОф ОДОюОў</translation>
