<translation id="5033299697334913360">ОЏОЊОЎ ОюОдОюОЮ ОљОф ОћОъОАОџ ОћОъОюОљ, ОЎОЕ ОюОюОЌОЋОЦ ОЉОъОДОЋОЮ ОЏОюОЕОћОЋ</translation>
<translation id="5035236842988137213">ОъОЏОЕОЎОе <ph name="DEVICE_NAME" /> ОћОфОЌОЉОе ОюОўОюОцОЋОЪ ОЌОЊОЕ</translation>
