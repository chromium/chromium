<translation id="2354174487190027830">ОћОъОбОеОЏОф ОъОцОбОЎОюОћ ОљОф <ph name="NAME" /></translation>
<translation id="2359808026110333948">ОћОъОЕОџ</translation>
<translation id="2365393535144473978">РђЈОЏОЕОъОцОбОЎОюОЎОЮ ОљОф ОЌОЉОЎОюОф ОћОњОюОЎОЕОћ, ОъОЋОцОбОюОф ОњОЮ ОфОДОЕОЋОеОф Bluetooth.</translation>
<translation id="2369165858548251131">"ОЕОюОЋОЮ" ОЉОАОЎОаОЎОф</translation>
<translation id="2390318262976603432">ОћОњОЊОеОЋОф ОЕОЎОюОЋОЉ ОЕОю ОЕОцОћ ОЋОљОќОЋОе</translation>
<translation id="2391579633712104609">180┬░</translation>
<translation id="240006516586367791">ОцОДОЊОЎ ОъОЊОЎОћ</translation>
<translation id="2405664212338326887">ОюОљ ОъОЌОЋОЉОе</translation>
<translation id="2408955596600435184">ОЎОЕ ОюОћОќОЎОЪ ОљОф ОДОЋОЊ ОћОљОЎОъОЋОф</translation>
<translation id="2412593942846481727">ОЎОЕ ОбОЊОЏОЋОЪ ОќОъОЎОЪ</translation>
<translation id="2427507373259914951">ОюОЌОЎОдОћ ОЕОъОљОюОЎОф</translation>
<translation id="2429753432712299108">РђЈОъОЏОЕОЎОе Оћ-Bluetooth РђЈ"<ph name="DEVICE_NAME" />" ОъОЉОДОЕ ОћОеОЕОљОћ ОюОЉОдОб ОћОфОљОъОћ. ОюОцОаОЎ ОъОфОЪ ОљОЎОЕОЋОе, ОЎОЕ ОюОЋОЋОЊОљ ОЕОъОцОфОЌ ОћОАОЎОАОъОћ ОћОЉОљ ОъОЋОдОњ ОЉОъОЏОЕОЎОе ОћОќОћ: <ph name="PASSKEY" /></translation>
<translation id="2435457462613246316">ОћОдОњОф ОАОЎОАОъОћ</translation>
<translation id="2450205753526923158">ОъОдОЉ ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="2473177541599297363">ОљОЎОЕОЋОе ОћОеОќОЋОюОЋОдОЎОћ</translation>
<translation id="2475982808118771221">ОљОЎОеОбОћ ОЕОњОЎОљОћ</translation>
<translation id="2482878487686419369">ОћОфОеОљОЋОф</translation>
<translation id="2484513351006226581">ОдОеОЎОџ ОюОћОДОЎОЕ ОбОю <ph name="KEYBOARD_SHORTCUT" /> ОЏОЊОЎ ОюОћОЌОюОЎОБ ОцОеОЎОАОф ОъОДОюОЊОф.</translation>
<translation id="2501920221385095727">ОъОДОЕОЎОЮ ОЊОЉОЎОДОЎОЮ</translation>
<translation id="2509468283778169019">РђЈCAPS LOCK ОъОЋОцОбОю</translation>
<translation id="2536159006530886390">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў.</translation>
<translation id="2542089167727451762">ОЎОЕ ОюОћОДОЎОЕ ОбОю ОфОъОЋОаОф ОћОцОеОЋОцОЎОю</translation>
<translation id="255671100581129685">РђЈGoogle Assistant ОљОЎОаОћ ОќОъОЎОаОћ ОЉОАОЕОЪ ОдОЎОЉОЋОеОЎ.</translation>
<translation id="256712445991462162">ОћОќОЏОЋОЏОЎОф ОћОъОњОЊОюОф ОЕОћОЋОдОъОЊОћ</translation>
<translation id="2575685495496069081">ОћОЏОаОЎОАОћ ОбОЮ ОъОАОцОе ОЌОЕОЉОЋОаОЋОф ОћОЋОЕОЉОфОћ</translation>
<translation id="2582112259361606227">ОдОеОЎОџ ОюОћОцОбОЎОю ОъОЌОЊОЕ ОЏОЊОЎ ОюОбОЊОЏОЪ</translation>
<translation id="2595239820337756193">ОЏОъОћ ОъОЎОЎОюОЎОЮ ОЎОЕ ОЉ-5 ОДОЎОюОЋОъОўОеОЎОЮ</translation>
<translation id="2596078834055697711">ОдОЎОюОЋОЮ ОъОАОџ ОЕОю ОЌОюОЋОЪ</translation>
<translation id="2617342710774726426">РђЈОЏОеОўОЎОА Оћ-SIM ОаОбОЋОю</translation>
<translation id="2621713457727696555">ОъОљОЋОЉОўОЌОф</translation>
<translation id="2653019840645008922">ОдОЎОюОЋОЮ ОЌОюОЋОЪ</translation>
<translation id="2653659639078652383">ОЕОюОЎОЌОћ</translation>
<translation id="2658778018866295321">ОюОЌОЎОдОћ ОЋОњОеОЎОеОћ</translation>
<translation id="2678852583403169292">ОфОцОеОЎОў ОћОДОеОљОћ</translation>
<translation id="2689613560355655046">ОЕОЋОюОЌОЪ ОбОЉОЋОЊОћ ОЋОЎОеОўОЋОљОюОЎ 8</translation>
<translation id="2700493154570097719">ОЉОЌОЎОеОф ОъОДОюОЊОф</translation>
<translation id="2704781753052663061">РђЈОћОдОўОеОцОЋОф ОюОеОЕОфОЋОф Wi-Fi ОљОЌОеОЋОф</translation>
<translation id="2705001408393684014">ОћОЌОюОцОф ОъОдОЉ ОћОъОЎОДОеОЋОцОЋОЪ. <ph name="STATE_TEXT" /></translation>
<translation id="2706462751667573066">ОюОъОбОюОћ</translation>
<translation id="2713444072780614174">ОюОЉОЪ</translation>
<translation id="2718395828230677721">ОфОљОЋОеОф ОюОЎОюОћ</translation>
<translation id="2726420622004325180">ОЏОЊОЎ ОюОАОцОД ОаОДОЋОЊОћ ОюОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў, ОаОЊОеОЕОф ОЌОЉОЎОюОф ОњОюОЎОЕОћ ОЉОўОюОцОЋОЪ</translation>
<translation id="2727175239389218057">ОъОбОаОћ</translation>
<translation id="2727977024730340865">ОъОЌОЋОЉОе ОюОъОўОбОЪ ОЉОбОю ОъОфОЌ ОаОъОЋОџ. ОЎОЎОфОЏОЪ ОЕОўОбОЎОаОф ОћОАОЋОюОюОћ ОюОљ ОфОћОЎОћ ОљОъОЎОаОћ.</translation>
<translation id="2778650143428714839"><ph name="DEVICE_TYPE" /> ОъОаОЋОћОю ОбОю ОЎОЊОЎ <ph name="MANAGER" /></translation>
<translation id="2782591952652094792">ОЎОдОЎОљОћ ОъОъОдОЉ ОЕОю ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="2792498699870441125">РђЈAlt + ОЌОЎОцОЋОЕ</translation>
<translation id="2814448776515246190">ОдОЎОюОЋОЮ ОЌОюОДОЎ</translation>
<translation id="2819276065543622893">ОћОъОбОеОЏОф ОфОЋОдОЎОљ ОљОЋОфОџ ОбОЏОЕОЎОЋ ОъОћОЌОЕОЉОЋОЪ.</translation>
<translation id="28232023175184696">ОюОљ ОаОЎОфОЪ ОюОћОфОЌОЉОе ОюОљОЎОаОўОеОаОў. ОЎОЕ ОюОюОЌОЋОЦ ОЏОЊОЎ ОюОаОАОЋОф ОЕОЋОЉ.</translation>
<translation id="2825224105325558319">ОћОфОдОЋОњОћ ОЕОю <ph name="DISPLAY_NAME" /> ОюОљ ОфОЋОъОЏОф ОЉОеОќОЋОюОЋОдОЎОћ <ph name="SPECIFIED_RESOLUTION" />. ОћОеОќОЋОюОЋОдОЎОћ ОЕОЋОаОфОћ Ою-<ph name="FALLBACK_RESOLUTION" />.</translation>
<translation id="2825619548187458965">ОъОЊОБ</translation>
<translation id="2841907151129139818">ОбОЉОеОф ОюОъОдОЉ ОўОљОЉОюОў</translation>
<translation id="2844169650293029770">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЕОъОљОюОЎОф-ОДОЊОъОЎОф)</translation>
<translation id="2865888419503095837">ОцОеОўОЎ ОеОЕОф</translation>
<translation id="2872961005593481000">ОЏОЎОЉОЋОЎ</translation>
