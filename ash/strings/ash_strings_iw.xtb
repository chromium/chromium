<translation id="315116470104423982">ОаОфОЋОаОЎ ОаОЎОЎОЊ</translation>
<translation id="3151786313568798007">ОЏОЎОЋОЋОЪ</translation>
<translation id="3153444934357957346">ОљОцОЕОе ОюОЏОюОЋОю ОбОЊ <ph name="MULTI_PROFILE_USER_LIMIT" /> ОЌОЕОЉОЋОаОЋОф ОЉОЏОаОЎОАОћ ОбОЮ ОъОАОцОе ОЌОЕОЉОЋОаОЋОф.</translation>
<translation id="3154351730702813399">ОЎОЎОфОЏОЪ ОЕОъОаОћОю ОћОъОЏОЕОЎОе ОбОЋОДОЉ ОљОЌОеОЎ ОцОбОЎОюОЋОф ОћОњОюОЎОЕОћ ОЕОюОџ.</translation>
<translation id="3181441307743005334">ОћОћОцОбОюОћ ОъОЌОЊОЕ ОбОЕОЋОЎОћ ОюОћОЎОъОЕОџ ОќОъОЪ ОъОћ</translation>
<translation id="3202010236269062730">{NUM_DEVICES,plural, =1{ОъОЌОЋОЉОе ОюОъОЏОЕОЎОе ОљОЌОЊ}two{ОъОЌОЋОЉОе Ою-# ОъОЏОЕОЎОеОЎОЮ}many{ОъОЌОЋОЉОе Ою-# ОъОЏОЕОЎОеОЎОЮ}other{ОъОЌОЋОЉОе Ою-# ОъОЏОЕОЎОеОЎОЮ}}</translation>
<translation id="320207200541803018">ОћОњОЊОеОф ОўОЎОЎОъОе</translation>
<translation id="3203405173652969239">'ОњОЎОЕОћ ОЉОљОъОдОбОЋОф ОъОфОњ' ОъОЋОцОбОюОф</translation>
<translation id="3207953481422525583">ОћОњОЊОеОЋОф ОъОЕОфОъОЕ</translation>
<translation id="3217205077783620295">ОюОЌОдОЪ ОбОЋОдОъОф ОћОДОЋОю ОъОЋОцОбОю. ОљОЮ ОћОъОдОЉ ОЎОЋОЌОюОБ, ОћОљОЋОЊОЎОЋ ОЎОЋОЕОфОД.</translation>
<translation id="3226991577105957773">+<ph name="COUNT" /> ОаОЋОАОцОЋОф</translation>
<translation id="324366796737464147">ОАОЎОаОЋОЪ ОеОбОЕОЎОЮ</translation>
<translation id="3249513730522716925">ОћОЌОюОЋОЪ <ph name="WINDOW_TITLE" /> ОћОЋОбОЉОе ОъОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ <ph name="ACTIVE_DESK" /> ОљОю ОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ <ph name="TARGET_DESK" /></translation>
<translation id="3255483164551725916">ОъОћ ОљОцОЕОе ОюОбОЕОЋОф?</translation>
<translation id="3269597722229482060">ОюОЌОЎОдОћ ОЎОъОаОЎОф</translation>
<translation id="3289674678944039601">ОъОфОЉОдОбОф ОўОбОЎОаОћ ОЉОљОъОдОбОЋОф ОъОфОљОЮ</translation>
<translation id="3290356915286466215">ОюОљ ОъОљОЋОЉОўОЌОф</translation>
<translation id="3294437725009624529">ОљОЋОеОЌ</translation>
<translation id="3307642347673023554">ОбОЉОеОф ОюОъОдОЉ ОъОЌОЕОЉ ОаОЎОЎОЊ</translation>
<translation id="3308453408813785101">Ою-<ph name="USER_EMAIL_ADDRESS" /> ОфОћОЎОћ ОбОЊОЎОЎОЪ ОљОцОЕОеОЋОф ОюОћОЎОЏОаОА ОюОЌОЕОЉОЋОЪ ОъОљОЋОЌОе ОЎОЋОфОе.</translation>
<translation id="3321628682574733415">ОДОЋОЊ ОћОЋОеОћ ОЕОњОЋОЎ</translation>
<translation id="332587331255250389">ОЎОЕ ОюОћОЌОюОЎОБ ОљОф ОћОАОЋОюОюОћ</translation>
<translation id="3341303451326249809">ОдОЎОюОЋОЮ ОћОъОАОџ ОЉОЋОдОб</translation>
<translation id="334252345105450327">ОЎОдОЎОеОф ОдОЎОюОЋОЮ ОъОАОџ</translation>
<translation id="3351879221545518001">ОъОфОЉОдОбОф ОбОЏОЕОЎОЋ ОћОбОЉОеОћ ОЕОю ОъОАОџ.</translation>
<translation id="3364721542077212959">ОЏОюОЎ ОАОўОЎОЎОюОЋОА</translation>
<translation id="3368922792935385530">ОъОЌОЋОЉОе</translation>
<translation id="3371140690572404006">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C (ОЎОдОЎОљОћ ОЎОъОаОЎОф-ОДОЊОъОЎОф)</translation>
<translation id="3375634426936648815">ОъОЌОЋОЉОе</translation>
<translation id="3378442621503952303">ОъОфОЉОдОб ОЌОЎОЉОЋОе ОюОцОеОЋОцОЎОю. ОЎОЕ ОюОћОъОфОЎОЪ ОъОАОцОе ОЊОДОЋОф.</translation>
<translation id="3386978599540877378">ОћОќОЏОЋОЏОЎОф ОћОъОњОЊОюОф ОЉОъОАОџ ОъОюОљ</translation>
<translation id="3400357268283240774">ОћОњОЊОеОЋОф ОаОЋОАОцОЋОф</translation>
<translation id="3410336247007142655">ОћОњОЊОеОЋОф ОЕОю ОћОдОњОф ОбОЎОдОЋОЉ ОЏОћОћ</translation>
<translation id="3413817803639110246">ОбОЊОЎОЎОЪ ОљОЎОЪ ОъОћ ОюОеОљОЋОф</translation>
<translation id="3428447136709161042">ОћОфОаОфОДОЋОф Оъ-<ph name="NETWORK_NAME" /></translation>
<translation id="3430396595145920809">ОЎОЕ ОюОћОЌОюОЎОД ОъОдОЊ ОЎОъОЎОЪ ОЏОЊОЎ ОюОЌОќОЋОе ОљОЌОЋОеОћ</translation>
<translation id="343571671045587506">ОбОеОЎОЏОф ОфОќОЏОЋОеОф</translation>
<translation id="3435967511775410570">ОўОЉОЎОбОф ОћОљОдОЉОб ОќОЋОћОфОћ</translation>
<translation id="3445288400492335833"><ph name="MINUTES" /> ОЊОД'</translation>
<translation id="3445925074670675829">РђЈОъОЏОЕОЎОе ОбОЮ ОЎОдОЎОљОф USB-C</translation>
<translation id="3454224730401036106">ОћОЌОЎОЉОЋОе ОЕОюОџ ОћОЋОбОЉОе ОюОеОЕОф ОъОљОЋОЉОўОЌОф ОЎОЋОфОе</translation>
<translation id="3465223694362104965">ОъОДОюОЊОф ОљОЌОеОф ОЌОЋОЉОеОћ ОюОъОЏОЕОЎОе ОюОљОЌОе ОћОЏОаОЎОАОћ ОћОљОЌОеОЋОаОћ ОЕОюОџ. ОЌОЕОЋОЉ ОюОЋОЋОЊОљ ОЕОќОЋ ОъОДОюОЊОф ОъОћОЎОъОаОћ ОюОцОаОЎ ОЕОъОЕОфОъОЕОЎОЮ ОЉОћ.</translation>
<translation id="3465356146291925647">ОћОеОЕОф ОъОаОЋОћОюОф ОбОю ОЎОЊОЎ ОъОаОћОю ОћОъОбОеОЏОф ОЕОюОџ</translation>
<translation id="3477079411857374384">РђЈControl+РђЈShift+ОъОДОЕ ОћОеОЋОЋОЌ</translation>
<translation id="3485319357743610354"><ph name="SECURITY_STATUS" />,РђЈ <ph name="CONNECTION_STATUS" />, ОбОЋОдОъОф ОћОљОЋОф: <ph name="SIGNAL_STRENGTH" /></translation>
<translation id="3486220673238053218">ОћОњОЊОеОћ</translation>
<translation id="3510164367642747937">ОћОЊОњОЕОћ ОЕОю ОАОъОЪ ОћОбОЏОЉОе</translation>
<translation id="3513798432020909783">ОћОЌОЕОЉОЋОЪ ОъОаОЋОћОю ОбОю-ОЎОЊОЎ <ph name="MANAGER_EMAIL" /></translation>
<translation id="3552189655002856821">РђЈWi-Fi ОЏОЉОЋОЎ</translation>
<translation id="3563775809269155755">ОћОцОбОюОф ОаОДОЋОЊОћ ОюОЕОЎОфОЋОБ ОљОЎОаОўОеОаОў</translation>
<translation id="3571734092741541777">ОћОњОЊОеОћ</translation>
<translation id="3573179567135747900">ОюОЕОЎОаОЋОЎ ОЉОЌОќОеОћ Ою"<ph name="FROM_LOCALE" />" (ОаОЊОеОЕОф ОћОцОбОюОћ ОъОЌОЊОЕ)</translation>
<translation id="3576141592585647168">ОЕОЎОаОЋОЎ ОљОќОЋОе ОћОќОъОЪ</translation>
<translation id="3593039967545720377">РђЈОЏОЊОЎ ОюОћОЎОЏОаОА ОюОћОЎОАОўОЋОеОЎОЎОф ОћОюОЋОЌ, ОЎОЕ ОюОюОЌОЋОЦ ОбОю <ph name="SHORTCUT_KEY_NAME" /> + V ОюОдОцОЎОЎОћ ОЉОюОЋОЌ. ОЏОЊОЎ ОюОћОфОЌОЎОю, ОдОеОЎОџ ОюОћОбОфОЎОД ОцОеОЎОў.</translation>
<translation id="3593646411856133110">ОЏОЊОЎ ОюОћОдОЎОњ ОљОф ОћОљОцОюОЎОДОдОЎОЋОф ОћОцОфОЋОЌОЋОф, ОъОЌОюОЎОДОЎОЮ ОЏОюОцОЎ ОъОбОюОћ ОЋОюОЋОЌОдОЎОЮ ОюОЌОЎОдОћ ОљОеОЋОЏОћ</translation>
<translation id="3595596368722241419">ОАОЋОюОюОћ ОъОюОљОћ</translation>
<translation id="3604801046548457007">ОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ <ph name="DESK_TITILE" /> ОаОЋОдОе</translation>
<translation id="3606978283550408104">ОдОњ ОЉОеОЎОЎОю ОъОЌОЋОЉОе</translation>
<translation id="3616883743181209306">ОћОфОцОеОЎОў ОћОЋОбОЉОе ОюОцОЎОаОћ ОћОЕОъОљОюОЎОф ОћОбОюОЎОЋОаОћ ОЕОю ОћОъОАОџ.</translation>
<translation id="3621202678540785336">ОДОюОў</translation>
<translation id="3621712662352432595">ОћОњОЊОеОЋОф ОљОЋОЊОЎОЋ</translation>
<translation id="3626281679859535460">ОЉОћОЎОеОЋОф</translation>
<translation id="3630697955794050612">ОЏОЉОЋОЎОћ</translation>
<translation id="3631369015426612114">ОћОъОДОЋОеОЋОф ОћОЉОљОЎОЮ ОЎОЏОЋОюОЎОЮ ОюОћОдОЎОњ ОћОфОеОљОЋОф</translation>
<translation id="3638400994746983214">ОћОцОбОюОћ ОЋОЏОЎОЉОЋОЎ ОЕОю ОъОАОџ ОћОцОеОўОЎОЋОф. <ph name="STATE_TEXT" />.</translation>
<translation id="366222428570480733"><ph name="USER_EMAIL_ADDRESS" /> ОъОЕОфОъОЕ ОъОаОЋОћОю</translation>
<translation id="3665889125180354336">ОћОДОюОўОф ОћОъОЎОДОеОЋОцОЋОЪ</translation>
<translation id="3680908746918359504">ОаОЎОДОЋОЎ ОЏОю ОћОАОЎОъОаОЎОЮ</translation>
<translation id="36813544980941320">РђЈОеОЕОфОЋОф Wi-Fi ОЎОЕОЋОфОцОЋ ОЉОЎОЪ ОћОўОюОцОЋОЪ ОЕОюОџ ОюОЉОЎОЪ <ph name="DEVICE_NAME" /></translation>
<translation id="3702809606464356667">ОъОЋОдОњОЎОЮ ОћОЌОюОЋОаОЋОф ОъОЕОЋОюОЌОЪ ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎ ОћОаОЋОЏОЌОЎ. ОаОЎОфОЪ ОюОћОДОЎОЕ ОбОю ОъОДОЕ ОћОЌОЦ ОюОъОбОюОћ ОЏОЊОЎ ОюОћОдОЎОњ ОЌОюОЋОаОЋОф ОъОЏОю ОЕОЋОюОЌОаОЋОф ОћОбОЉОЋОЊОћ ОћОЋОЋОЎОеОўОЋОљОюОЎОЎОЮ</translation>
<translation id="3702846122927433391">ОљОЋОЏОюОЋОАОЎОЎОф ОаОЎОњОеОЎОћ</translation>
<translation id="3705722231355495246">-</translation>
<translation id="370665806235115550">ОЉОўОбОЎОаОћ...</translation>
<translation id="3712407551474845318">ОдОЎОюОЋОЮ ОљОќОЋОе</translation>
<translation id="371370241367527062">ОъОЎОДОеОЋОцОЋОЪ ОДОЊОъОЎ</translation>
<translation id="3742055079367172538">ОдОЎОюОЋОЮ ОћОъОАОџ ОЉОЋОдОб</translation>
<translation id="3771549900096082774">ОъОдОЉ ОаОЎОњОЋОЊОЎОЋОф ОњОЉОЋОћОћ</translation>
<translation id="3773700760453577392">ОъОаОћОю ОъОбОеОЏОф ОЉОЎОўОю ОћОеОЕОљОћ ОЕОю ОЏОаОЎОАОћ ОбОЮ ОъОАОцОе ОЌОЕОЉОЋОаОЋОф ОбОЉОЋОе <ph name="USER_EMAIL" />. ОЏОЊОЎ ОюОћОъОЕОЎОџ, ОЏОю ОћОъОЕОфОъОЕОЎОЮ ОЌОЎОЎОЉОЎОЮ ОюОЉОдОб ОЎОдОЎОљОћ.</translation>
<translation id="3783640748446814672">alt</translation>
<translation id="3784455785234192852">ОаОбОЎОюОћ</translation>
<translation id="3796746699333205839">ОљОцОюОЎОДОдОЎОћ ОЏОюОЕОћОЎ ОъОЕОфОъОЕОф ОЉОъОдОюОъОћ ОЋОЉОъОЎОДОеОЋОцОЋОЪ ОЕОюОџ</translation>
<translation id="3798670284305777884">ОеОъОДОЋОю (ОцОаОЎОъОЎ)</translation>
<translation id="3799080171973636491">ОћОДОЕОф ОбОю ОъОДОЕ ОћОДОЎОдОЋОе ОЕОю ОќОЏОЋОЏОЎОф ОъОњОЊОюОф ОЉОъОАОџ ОъОюОљ. ОюОћОцОбОЎОю ОљОЋОфОћ?</translation>
<translation id="380165613292957338">ОћОЎОЎ, ОљОЎОџ ОљОцОЕОе ОюОбОќОЋОе?</translation>
<translation id="3826099427150913765">ОъОбОЉОе ОюОАОЎОАОъОћ</translation>
