import("//ui/webui/resources/tools/build_webui.gni")

assert(is_chromeos, "Projector is ChromeOS only")

build_webui("build") {
  grd_prefix = "ash_projector_app_untrusted"

  static_files = [
    "assets/icon_16.png",
    "assets/icon_32.png",
    "assets/icon_48.png",
    "assets/icon_64.png",
    "assets/icon_96.png",
    "assets/icon_128.png",
    "assets/icon_192.png",
    "assets/icon_256.png",
    "index.html",
  ]

  ts_files = [
    "app_api.ts",
    "launch.ts",
    "sandboxed_load_time_data.ts",
    "untrusted_app_comm_factory.ts",
    "untrusted_projector_browser_proxy.ts",
  ]

  mojo_files_deps = [
    "//ash/webui/projector_app/mojom:projector_mojo_bindings_ts__generator",
    "//ash/webui/projector_app/public/mojom:projector_mojo_bindings_ts__generator",
  ]

  mojo_base_path = "mojom"

  mojo_files = [
    "$root_gen_dir/ash/webui/projector_app/mojom/untrusted_projector.mojom-webui.ts",
    "$root_gen_dir/ash/webui/projector_app/public/mojom/projector_types.mojom-webui.ts",
  ]

  ts_composite = true
  ts_tsconfig_base = "tsconfig_base.json"

  ts_deps = [
    "//ui/webui/resources/cr_components/color_change_listener:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  webui_context_type = "untrusted"
  grit_output_dir = "$root_gen_dir/ash/webui"
}
