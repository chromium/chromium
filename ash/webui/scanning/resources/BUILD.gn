js_library("scanning_app_types") {
  deps = [ "//ash/webui/scanning/mojom:mojom_webui_js" ]
}

js_library("scanning_app_util") {
}

js_library("select_behavior") {
}

js_library("source_select") {
  deps = [
    ":scanning_app_util",
    ":select_behavior",
    "//ash/webui/common/resources:i18n_behavior",
    "//ash/webui/scanning/mojom:mojom_webui_js",
    "//third_party/polymer/v3_0/components-chromium/polymer:polymer_bundled",
  ]
}

js_library("scanning_browser_proxy") {
  deps = [
    "//ash/webui/common/resources:cr.m",
    "//ash/webui/common/resources:cr_deprecated",
  ]
  externs_list = [ "$externs_path/chrome_send.js" ]
}

js_library("mojo_interface_provider") {
  deps = [
    "//ash/webui/common/mojom:mojom_webui_js",
    "//ash/webui/common/resources:cr.m",
    "//ash/webui/scanning/mojom:mojom_webui_js",
  ]
}

preprocess_folder = "$target_gen_dir/preprocessed"

static_files = [
  "index.html",
  "scanning_app_icon_128.png",
  "scanning_app_icon_16.png",
  "scanning_app_icon_192.png",
  "scanning_app_icon_256.png",
  "scanning_app_icon_32.png",
  "scanning_app_icon_48.png",
  "scanning_app_icon_64.png",
  "svg/illo_loading_scanner.svg",
  "svg/illo_no_scanner.svg",
  "svg/illo_ready_to_scan.svg",
  "svg/no_scanners_dark.svg",
  "svg/no_scanners.svg",
  "svg/ready_to_scan_dark.svg",
  "svg/ready_to_scan.svg",
  "svg/remove_page.svg",
  "svg/rescan_page.svg",
  "svg/scanners_loading_dark.svg",
  "svg/scanners_loading.svg",
]

web_component_files = [
  "action_toolbar.js",
  "color_mode_select.js",
  "file_type_select.js",
  "loading_page.js",
  "multi_page_checkbox.js",
  "multi_page_scan.js",
  "page_size_select.js",
  "resolution_select.js",
  "scan_done_section.js",
  "scanner_select.js",
  "scanning_app.js",
  "scanning_fonts_css.js",
  "scanning_shared_css.js",
  "scan_preview.js",
  "scan_settings_section.js",
  "scan_to_select.js",
  "source_select.js",
]

non_web_component_files = [
  "mojo_interface_provider.js",
  "scanning_app_types.js",
  "scanning_app_util.js",
  "scanning_browser_proxy.js",
  "select_behavior.js",
]

html_files = []
html_wrapper_files = []
foreach(f, web_component_files) {
  file_name = string_replace(f, ".js", ".html")
  html_files += [ file_name ]
  html_wrapper_files += [ file_name + ".js" ]
}

html_to_wrapper("html_wrapper_files") {
  use_js = true
  in_files = html_files
}

copy("copy_webui_mojo") {
  deps = [
    "//ash/webui/common/mojom:mojom_webui_js",
    "//ash/webui/scanning/mojom:mojom_webui_js",
  ]
  sources = [
    "$root_gen_dir/mojom-webui/ash/webui/common/mojom/accessibility_features.mojom-webui.js",
    "$root_gen_dir/mojom-webui/ash/webui/scanning/mojom/scanning.mojom-webui.js",
  ]
  outputs = [ "$target_gen_dir/{{source_file_part}}" ]
}

preprocess_if_expr("preprocess") {
  in_folder = "."
  in_files = web_component_files + non_web_component_files
  out_folder = preprocess_folder
  out_manifest = "$target_gen_dir/manifest_preprocess.json"
}

preprocess_if_expr("preprocess_generated_files") {
  in_folder = target_gen_dir
  in_files = html_wrapper_files
  out_folder = preprocess_folder
  out_manifest = "$target_gen_dir/manifest_preprocess_generated.json"
  deps = [ ":html_wrapper_files" ]
}

preprocess_if_expr("preprocess_mojo") {
  in_folder = target_gen_dir
  in_files = [
    "accessibility_features.mojom-webui.js",
    "scanning.mojom-webui.js",
  ]
  out_folder = preprocess_folder
  out_manifest = "$target_gen_dir/manifest_preprocess_mojo.json"
  deps = [ ":copy_webui_mojo" ]
}

generate_grd("build_grd") {
  input_files = static_files
  input_files_base_dir = rebase_path(".", "//")
  deps = [
    ":preprocess",
    ":preprocess_generated_files",
    ":preprocess_mojo",
  ]
  manifest_files = [
    "$target_gen_dir/manifest_preprocess.json",
    "$target_gen_dir/manifest_preprocess_generated.json",
    "$target_gen_dir/manifest_preprocess_mojo.json",
  ]

  grd_prefix = "ash_scanning_app"
  out_grd = "$target_gen_dir/resources.grd"
}
