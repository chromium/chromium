import("//build/config/chromeos/ui_mode.gni")
import("//tools/grit/grit_rule.gni")
import("//tools/grit/preprocess_if_expr.gni")
import("//tools/polymer/css_to_wrapper.gni")
import("//tools/polymer/html_to_wrapper.gni")
import("//ui/webui/resources/tools/generate_grd.gni")

assert(is_chromeos_ash, "Non-ChromeOS builds cannot depend on //ash")

preprocessed_dir = "preprocessed"
preprocessed_gen_manifest = "preprocessed_gen_manifest.json"
preprocessed_mojo_manifest = "preprocessed_mojo_manifest.json"

css_files = [ "os_feedback_shared.css" ]
css_wrapper_files = []
foreach(f, css_files) {
  file_name = f + ".js"
  css_wrapper_files += [ file_name ]
}

web_component_files = [
  "confirmation_page.js",
  "feedback_flow.js",
  "file_attachment.js",
  "help_content.js",
  "search_page.js",
  "share_data_page.js",
]

html_files = [ "help_resources_icons.html" ]
html_wrapper_files = [ "help_resources_icons.html.js" ]
foreach(f, web_component_files) {
  file_name = string_replace(f, ".js", ".html")
  html_files += [ file_name ]
  html_wrapper_files += [ file_name + ".js" ]
}

generate_grd("build_grd") {
  input_files = [
    "app_icon_48.png",
    "app_icon_192.png",
    "app_icon_256.png",
    "fake_data.js",
    "fake_help_content_provider.js",
    "fake_feedback_service_provider.js",
    "feedback_constants.js",
    "feedback_types.js",
    "feedback_utils.js",
    "index.html",
    "mojo_interface_provider.js",
    "questionnaire.js",
  ]
  input_files_base_dir = rebase_path(".", "//")
  deps = [
    ":preprocess",
    ":preprocess_generated",
    ":preprocess_mojo",
  ]
  manifest_files = [
    "$target_gen_dir/manifest_preprocess.json",
    "$target_gen_dir/$preprocessed_gen_manifest",
    "$target_gen_dir/$preprocessed_mojo_manifest",
  ]
  grd_prefix = "ash_os_feedback"
  out_grd = "$target_gen_dir/${grd_prefix}_resources.grd"
}

preprocess_if_expr("preprocess") {
  in_folder = "."
  out_folder = "$target_gen_dir/$preprocessed_dir"
  out_manifest = "$target_gen_dir/manifest_preprocess.json"
  in_files = web_component_files
}

preprocess_if_expr("preprocess_generated") {
  deps = [
    ":css_wrapper_files",
    ":html_wrapper_files",
  ]
  in_folder = target_gen_dir
  out_folder = "$target_gen_dir/$preprocessed_dir"
  out_manifest = "$target_gen_dir/$preprocessed_gen_manifest"
  in_files = css_wrapper_files + html_wrapper_files
}

preprocess_if_expr("preprocess_mojo") {
  deps = [ ":copy_webui_mojo" ]
  in_folder = target_gen_dir
  out_folder = "$target_gen_dir/$preprocessed_dir/mojom"
  out_manifest = "$target_gen_dir/$preprocessed_mojo_manifest"
  in_files = [ "os_feedback_ui.mojom-webui.js" ]
}

css_to_wrapper("css_wrapper_files") {
  use_js = true
  in_files = css_files
}

html_to_wrapper("html_wrapper_files") {
  use_js = true
  in_files = html_files
}

copy("copy_webui_mojo") {
  deps = [ "../mojom:mojom_webui_js" ]
  sources = [ "$root_gen_dir/mojom-webui/ash/webui/os_feedback_ui/mojom/os_feedback_ui.mojom-webui.js" ]
  outputs = [ "$target_gen_dir/{{source_file_part}}" ]
}
