import("//build/config/chromeos/ui_mode.gni")

assert(is_chromeos_ash)

source_set("picker") {
  sources = [
    "views/picker_view.cc",
    "views/picker_view.h",
  ]

  public_deps = [
    "//base",
    "//ui/base",
    "//ui/views",
  ]

  deps = [ "//ui/gfx" ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "views/picker_view_unittest.cc" ]

  deps = [
    ":picker",
    "//ash:test_support",
    "//base/test:test_support",
    "//testing/gtest",
  ]
}
