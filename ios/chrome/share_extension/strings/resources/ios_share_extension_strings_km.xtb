<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1613742542373525524">APPLICATION_NAME бһҳбһ·бһ“вҖӢбһўбһ¶бһ…вҖӢбһ”бһҫбһҖвҖӢбһҸбҹҶбһҺвҖӢбһ“бҹҒбҹҮвҖӢбһ”бһ¶бһ“вҖӢбһ‘бҹҒбҹ”</translation>
<translation id="4655616150233109325">бһ”бһҫбһҖбһ“бҹ…бһҖбҹ’бһ“бһ»бһ„ Chrome</translation>
<translation id="5596627076506792578">бһҮбһҳбҹ’бһҡбһҫбһҹбһ…бҹ’бһҡбһҫбһ“бһ‘бҹҖбһҸ</translation>
<translation id="601731541915429022">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ‘бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢбһ”бһүбҹ’бһҮбһёвҖӢбһўбһ¶бһ“</translation>
<translation id="6930009216791986919">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ‘бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢбһ…бҹҶбһҺбһ¶бҹҶ</translation>
<translation id="6965382102122355670">бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳ</translation>
<translation id="7658239707568436148">бһ”бһҠбһ·бһҹбҹҒбһ’</translation>
<translation id="8258999165172757081">бһ”бһ¶бһ“бһ”бһ“бҹ’бһҗбҹӮбһҳ</translation>
<translation id="850600235656508448">бһ”бһҫбһҖбһ“бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„бһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҜбһҖвҖӢбһҮбһ“</translation>
</translationbundle>