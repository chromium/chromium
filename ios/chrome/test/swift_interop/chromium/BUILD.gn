import("//build/config/apple/swift_source_set.gni")

if (enable_swift_cxx_interop) {
  swift_modulemap("base_imports") {
    modules = [
      {
        name = "BaseImports"
        sources = [
          "//base/system/sys_info.h",
          "//base/time/time.h",
        ]
      },
    ]
  }

  swift_source_set("tests") {
    testonly = true
    sources = [
      "sys_info_xctest.swift",
      "time_xctest.swift",
    ]
    deps = [
      ":base_imports",
      "//base",
      "//build/config/ios:xctest",
    ]
  }
}
