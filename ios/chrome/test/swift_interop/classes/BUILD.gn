import("//build/config/apple/swift_source_set.gni")

if (enable_swift_cxx_interop) {
  source_set("outlined") {
    testonly = true
    sources = [
      "outlined.cc",
      "outlined.h",
    ]
  }

  swift_cxx_import("all_classes_import") {
    testonly = true
    sources = [
      "inlined_classes.h",
      "outlined.h",
      "polymorphism.h",
    ]
    apinotes = {
      Tags = [
        {
          Name = "RenamedClassOriginal"
          SwiftName = "RenamedClass"
        },
      ]
    }
    public_deps = [ ":outlined" ]
  }

  swift_source_set("tests") {
    testonly = true
    sources = [
      "inlined_xctest.swift",
      "outlined_xctest.swift",
      "polymorphism_xctest.swift",
    ]
    cxx_import_deps = [ ":all_classes_import" ]
    deps = [ "//build/config/ios:xctest" ]
  }
}
