import("//build/config/apple/swift_source_set.gni")

if (enable_swift_cxx_interop) {
  source_set("outlined") {
    sources = [
      "outlined.cc",
      "outlined.h",
    ]
  }

  swift_modulemap("classes") {
    module_name = "Classes"
    apinotes = [ "classes.apinotes" ]
    sources = [
      "inlined_classes.h",
      "outlined.h",
      "polymorphism.h",
    ]
    public_deps = [ ":outlined" ]
  }

  swift_source_set("tests") {
    sources = [
      "inlined_xctest.swift",
      "outlined_xctest.swift",
      "polymorphism_xctest.swift",
    ]
    deps = [
      ":classes",
      "//build/config/ios:xctest",
    ]
  }
}
