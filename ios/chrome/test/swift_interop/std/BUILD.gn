import("//build/config/apple/swift_source_set.gni")

if (enable_swift_cxx_interop) {
  source_set("_cxx_std_test_helpers") {
    testonly = true
    sources = [
      "string_helper.cc",
      "string_helper.h",
      "vector.cc",
      "vector.h",
    ]
    deps = [ "//base" ]
    visibility = [ ":*" ]
  }

  swift_modulemap("_swift_string_helpers") {
    testonly = true
    modules = [
      {
        name = "StringTestHelpers"
        sources = [ "string_helper.h" ]
      },
    ]

    # Test that visibility is handled correctly by swift_modulemap
    visibility = [ ":*" ]
  }

  swift_modulemap("_swift_vector_helpers") {
    testonly = true
    modules = [
      {
        name = "VectorTestHelpers"
        sources = [ "vector.h" ]
      },
    ]
    visibility = [ ":*" ]
  }

  swift_modulemap_group("_swift_std_test_helpers") {
    testonly = true
    module_name = "StdTestHelpers"
    deps = [
      ":_swift_string_helpers",
      ":_swift_vector_helpers",
    ]

    # Test that visibility is handled correctly by swift_modulemap_group
    visibility = [ ":tests" ]
  }

  swift_source_set("tests") {
    testonly = true
    sources = [
      "string_xctest.swift",
      "vector_xctest.swift",
    ]
    deps = [
      ":_cxx_std_test_helpers",
      ":_swift_std_test_helpers",
      "//base",
      "//build/config/ios:xctest",
    ]
  }
}
