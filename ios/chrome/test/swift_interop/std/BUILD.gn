import("//build/config/apple/swift_source_set.gni")

if (enable_swift_cxx_interop) {
  source_set("cxx_std_test_helpers") {
    sources = [
      "string_helper.cc",
      "string_helper.h",
      "vector.cc",
      "vector.h",
    ]
    deps = [ "//base" ]
  }

  swift_modulemap("swift_std_test_helpers") {
    modules = [
      {
        name = "StdTestHelpers"
        sources = [
          "string_helper.h",
          "vector.h",
        ]
      },
    ]
  }

  swift_source_set("tests") {
    sources = [
      "string_xctest.swift",
      "vector_xctest.swift",
    ]
    deps = [
      ":cxx_std_test_helpers",
      ":swift_std_test_helpers",
      "//base",
      "//build/config/ios:xctest",
    ]
  }
}
