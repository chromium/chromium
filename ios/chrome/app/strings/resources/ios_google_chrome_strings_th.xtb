<translation id="746684838091935575">3. เลือก Chrome</translation>
<translation id="7492574581995589075">องค์กรได้ปิดความสามารถในการใช้และบันทึกข้อมูล Chrome ในบัญชี Google ของคุณ บุ๊กมาร์ก รหัสผ่านใหม่ และข้อมูลอื่นๆ จะบันทึกไว้ในอุปกรณ์นี้เท่านั้น</translation>
<translation id="7501046334262221972">หากต้องการกำหนดให้ Chrome เป็นเบราว์เซอร์เริ่มต้น ให้เปิดการตั้งค่า แล้วแตะ "แอปเบราว์เซอร์เริ่มต้น" จากนั้นเลือก Chrome</translation>
<translation id="756809126120519699">ล้างข้อมูล Chrome แล้ว</translation>
<translation id="7581063337314642333">ไปที่ตารางกริดของแท็บใน Chrome</translation>
<translation id="7662994914830945754">ลงชื่อเข้าใช้และเปิดการซิงค์เพื่อดูแท็บที่เปิดไว้จากอุปกรณ์ที่คุณใช้ Chrome</translation>
<translation id="7669869107155339016">ไปที่การตั้งค่า Chrome</translation>
<translation id="769104993356536261">ใช้การดำเนินการใน Chrome บน iOS</translation>
<translation id="7693590760643069321">ตอนนี้คุณจะใช้ Chrome ทุกครั้งที่แตะลิงก์ในข้อความ เอกสาร และแอปอื่นๆ</translation>
<translation id="7698568245838009292">Chrome ต้องการเข้าถึงกล้องถ่ายรูป</translation>
<translation id="7754633291442704733">องค์กรของคุณ <ph name="DOMAIN" /> จะมีสิทธิ์เข้าถึงข้อมูล, บุ๊กมาร์ก, ประวัติการเข้าชม, รหัสผ่าน และการตั้งค่าอื่นๆ ของ Chrome ที่คุณจัดเก็บไว้ในบัญชีนี้ เมื่อออกจากระบบ ข้อมูลจะถูกล้างออกจากอุปกรณ์นี้  แต่ข้อมูลจะยังจัดเก็บอยู่ในบัญชี Google ที่มีการจัดการและพร้อมให้องค์กรใช้งาน องค์กรของคุณยังกำหนดนโยบายผู้ใช้สำหรับบัญชีดังกล่าวโดยเฉพาะได้ด้วย ซึ่งอาจทำให้ลักษณะการทำงานของ Chrome เปลี่ยนแปลงไป</translation>
<translation id="7780154209050837198">ลงชื่อเข้าใช้ Chrome ด้วยบัญชี Google เพื่อรับประโยชน์สูงสุดจาก Chrome</translation>
<translation id="778855399387580014">เริ่มการค้นหาในแท็บใหม่ของ Chrome</translation>
<translation id="7792140019572081272">Chrome ช่วยรักษาข้อมูลที่ละเอียดอ่อนของคุณให้ปลอดภัยด้วย Face ID</translation>
<translation id="7855730255114109580">Google Chrome อัปเดตแล้ว</translation>
<translation id="7897703007638178753">ดูแท็บล่าสุดใน Chrome</translation>
<translation id="7925119591961387184">เลือก "Chrome"</translation>
<translation id="7933491483529363150">เปิดแท็บล่าสุดของฉันใน Chrome</translation>
<translation id="7948283758957877064">มีอะไรใหม่ใน Chrome</translation>
<translation id="8006014511203279255">ใช้ Chrome ทุกครั้งที่คุณแตะลิงก์ในข้อความหรือแอปอื่นๆ</translation>
<translation id="8022947259858476807">ใช้ Chrome โดยค่าเริ่มต้นเพื่อเปิดลิงก์ ค้นหาจาก​​วิดเจ็ต และป้อนรหัสผ่านอัตโนมัติในแอปอื่นๆ</translation>
<translation id="804638182476029347">อนุญาตให้การแจ้งเตือนของ Chrome รับการแจ้งเตือนเมื่อราคาลดลง</translation>
<translation id="8065292699993359127">เปิด URL ใน Chrome ในโหมดไม่ระบุตัวตน</translation>
<translation id="8069507567842347179">ติดตามพัสดุนี้ใน Chrome แล้ว</translation>
<translation id="81358522153858150">ตอนนี้ Chrome รองรับนโยบายผู้ใช้สำหรับบัญชีที่จัดการแล้ว</translation>
<translation id="8136856065410661948">ระบบจะใช้เพื่อสร้างกิจกรรมจาก Chrome และ Google Lens ในปฏิทินของ Apple</translation>
<translation id="8160472928944011082">อัปเดต Chrome ไม่ได้</translation>
<translation id="8174679664544842874">เปิดแท็บใหม่ใน Chrome</translation>
<translation id="8213758103105806860">ดูบุ๊กมาร์ก Chrome</translation>
<translation id="8328903609881776074">เปิดแท็บที่ไม่ระบุตัวตนใหม่ใน Chrome</translation>
<translation id="8357607116237445042">เลือกว่าจะล้างข้อมูล Chrome จากอุปกรณ์นี้หรือเก็บไว้</translation>
