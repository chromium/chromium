<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1149198577555059081">ОљОцОЕОе ОюОћОќОЎОЪ ОЉОЎОўОЋОЎ ОюОЌОЎОцОЋОЕ ОљОЋ ОЏОфОЋОЉОф ОљОфОе</translation>
<translation id="1324575488877808473">РђЈОљОцОЕОе ОюОцОфОЋОЌ ОљОф Chrome ОЏОЊОЎ ОЕОЎОЋОцОЎОбОЋ ОЏОљОЪ ОћОљОфОеОЎОЮ ОЕОЉОЎОДОеОф ОЉОћОЮ ОћОЏОЎ ОћОеОЉОћ.</translation>
<translation id="1861587787412926934">ОЉОеОЎОеОф ОъОЌОЊОю</translation>
<translation id="2378341468609349249">ОЌОЎОцОЋОЕ ОЉОАОЎОАОъОљОЋОф</translation>
<translation id="2513892053093488070">ОЌОЎОцОЋОЕ ОДОЋОюОЎ</translation>
<translation id="2535710892645968259">РђЈОбОЉОеОЋ ОюОъОЕОЌОД Chrome Dino ОъОъОАОџ ОћОаОбОЎОюОћ.</translation>
<translation id="2542770169955243077">РђЈОъОЕОЌОД Chrome Dino</translation>
<translation id="2922313168575194078">РђЈОљОцОЕОе ОюОЌОцОЕ ОЉОЉОўОЌОћ ОАОЎОАОъОљОЋОф ОЕОъОЋОеОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="302608144225178783">РђЈОљОцОЕОе ОюОбОЉОЋОе ОћОЎОЎОЕОе ОюОъОЕОЌОД Chrome Dino ОъОъОАОџ ОћОЉОЎОф.</translation>
<translation id="3296938369177810197">ОЌОЎОцОЋОЕ ОДОЋОюОЎ</translation>
<translation id="3464120926993669599">ОЌОЎОцОЋОЕ ОЉОъОдОЉ ОљОаОЋОаОЎОъОЎ</translation>
<translation id="3501428580460217920">РђЈОЌОЎОцОЋОЕ ОљОЋ ОаОЎОЋОЋОў ОЉОЏОеОўОЎОАОЎОЎОћ ОцОеОўОЎОф ОЌОЊОЕОћ ОЉ-Chrome.</translation>
<translation id="3528874492835415837">ОўОДОАОў ОљОЋ ОЏОфОЋОЉОф ОљОфОе ОюОЌОЎОцОЋОЕ</translation>
<translation id="3798529146539130967">РђЈОЌОЎОцОЋОЕ ОЉ-Chrome ОЉОљОъОдОбОЋОф ОћОДОЋОю.</translation>
<translation id="405442954313519726">РђЈОљОцОЕОе ОюОЌОцОЕ ОљОЋ ОюОаОЋОЋОў ОЉОЏОеОўОЎОАОЎОЎОћ ОЌОЊОЕОћ, ОЉОъОдОЉ ОцОеОўОЎ, ОЉОљОъОдОбОЋОф ОћОДОЋОю ОљОЋ ОЉОљОъОдОбОЋОф ОДОЋОЊ QR.</translation>
<translation id="4557098988773644458">РђЈОъОбОЉОе ОъОћОЎОе ОюОъОЕОЌОД Chrome Dino</translation>
<translation id="4678859075583681103">ОДОЎОдОЋОе ОЊОеОџ ОюОЌОЎОцОЋОЕ ОЌОЊОЕ ОЋОюОљОфОеОЎОЮ ОћОДОЉОЋОбОЎОЮ ОЕОюОџ РђЊ ОЎОЕОе ОъОъОАОџ ОћОЉОЎОф ОЕОю ОћОљОЎОЎОцОЋОЪ.</translation>
<translation id="4962772945748414465">РђЈОцОфОЎОЌОф WEBSITE_PLACEHOLDER</translation>
<translation id="5234725349196694896">РђЈОЌОЎОцОЋОЕ ОЉ-Chrome ОЉОљОъОдОбОЋОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОћОъОЋОбОЊОБ ОбОюОЎОџ.</translation>
<translation id="5277852985315196237">РђЈОаОЎОфОЪ ОюОЌОцОЕ ОљОЋ ОюОћОќОЎОЪ ОЏОфОЋОЉОф URL</translation>
<translation id="529497070985873480">Chrome Dino</translation>
<translation id="5325847452011598583">ОљОЎОЪ ОЌОЕОЉОЋОЪ</translation>
<translation id="5683557219437283801">ОЌОЎОцОЋОЕ ОДОЋОюОЎ</translation>
<translation id="6179961764474023795">ОцОбОЋОюОЋОф ОъОћОЎОеОЋОф</translation>
<translation id="6330929932864892436">РђЈОаОЎОфОЪ ОюОЌОцОЕ ОљОЋ ОюОћОќОЎОЪ ОЏОфОЋОЉОф URL</translation>
<translation id="6336802729091778259">РђЈОъОЕОЌОД Chrome Dino</translation>
<translation id="6400175403219850910">ОъОаОћОю ОћОАОЎОАОъОљОЋОф</translation>
<translation id="6663288906398689853">ОЌОЎОцОЋОЕ</translation>
<translation id="6691821786147477657">РђЈОљОцОЕОе ОюОћОфОЌОЎОю ОЌОЎОцОЋОЕ ОЌОЊОЕ ОљОЋ ОюОцОфОЋОЌ ОљОф ОћОљОфОеОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф ОћОЏОЎ ОћОеОЉОћ ОъОЊОБ ОћОЉОЎОф ОЉ-iPad.</translation>
<translation id="6721566127904256183">ОЏОљОЪ ОЎОЋОдОњОЋ ОћОљОфОеОЎОЮ ОЕОЉОћОЮ ОЉОЎОДОеОф ОћОЏОЎ ОћОеОЉОћ.</translation>
<translation id="6804899947889706382">ОљОцОЕОе ОюОћОќОЎОЪ ОЉОЎОўОЋОЎ ОюОЌОЎОцОЋОЕ ОљОЋ ОЏОфОЋОЉОф ОљОфОе</translation>
<translation id="6855322554930231468">ОЌОЎОцОЋОЕ</translation>
<translation id="6973491011026415905">РђЈОЌОЎОцОЋОЕ ОАОЎОАОъОљОЋОф ОЉОъОаОћОю ОћОАОЎОАОъОљОЋОф ОЕОю Google</translation>
<translation id="7010831364920321713">ОЌОЎОцОЋОЕ ОЉОъОдОЉ ОцОеОўОЎ</translation>
<translation id="7048549665319929185">РђЈОаОЎОфОЪ ОюОЌОцОЕ ОљОЋ ОюОћОќОЎОЪ ОЏОфОЋОЉОф URL</translation>
<translation id="7317302007099170473">РђЈОАОеОЎОДОф ОДОЋОЊ QR</translation>
<translation id="744668050028871192">ОЌОЎОцОЋОЕ</translation>
<translation id="7730705312376865830">РђЈОДОЎОдОЋОеОЎ ОЊОеОџ ОЉ-Chrome</translation>
<translation id="8104498668011127805">РђЈОъОбОЉОе ОъОћОЎОе ОюОъОЕОЌОД Chrome Dino</translation>
<translation id="8150601371542319992">Lens</translation>
<translation id="8171952085734471362">ОЌОЎОцОЋОЕ ОЉОъОдОЉ ОцОеОўОЎ</translation>
<translation id="8310150944719146950">ОЌОЕОЉОЋОЪ</translation>
<translation id="8564942608461410346">РђЈОћОЌОЎОцОЋОЕ ОЉ-Chrome ОќОъОЎОЪ ОЉОљОъОдОбОЋОф ОъОаОЋОб ОћОЌОЎОцОЋОЕ ОћОъОЋОбОЊОБ ОбОюОЎОџ.</translation>
<translation id="8858765528951093286">ОћОЌОЕОЉОЋОЪ ОЕОЉОЋ ОћОЋОЋОЎОЊОњ'Оў ОъОЕОфОъОЕ ОћОЋОАОе. ОЏОЊОЎ ОюОЉОЌОЋОе ОЌОЕОЉОЋОЪ ОљОЌОе, ОдОеОЎОџ ОюОюОЌОЋОЦ ОбОю "ОбОеОЎОЏОф ОћОЋОЋОЎОЊОњ'Оў".</translation>
<translation id="9175676375569833962">ОЌОЎОцОЋОЕ
ОЉОАОЎОАОъОљОЋОф</translation>
</translationbundle>