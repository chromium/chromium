  ]
  deps = [
    "//base",
    "//ios/chrome/common/app_group",
    "//ios/chrome/credential_provider_extension:metrics_util",
    "//ios/components/credential_provider_extension:password_util",
  ]
  frameworks = [ "Foundation.framework" ]
