source_set("passkey_keychain_provider") {
  public_deps = [ ":passkey_keychain_provider_header" ]
  deps = [ ios_passkey_keychain_provider_target ]
  assert_no_deps = [ "//ios/chrome/browser/*" ]
  frameworks = [ "Foundation.framework" ]
}

