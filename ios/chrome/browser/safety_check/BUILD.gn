source_set("safety_check") {
  configs += [ "//build/config/compiler:enable_arc" ]
  sources = [
    "ios_chrome_safety_check_manager.h",
    "ios_chrome_safety_check_manager.mm",
    "ios_chrome_safety_check_manager_constants.h",
  ]
  public_deps = [
    "//base",
    "//components/keyed_service/core",
    "//components/prefs",
  ]
  deps = [ "//components/safe_browsing/core/common:safe_browsing_prefs" ]
}

source_set("factory") {
  configs += [ "//build/config/compiler:enable_arc" ]
  sources = [
    "ios_chrome_safety_check_manager_factory.h",
    "ios_chrome_safety_check_manager_factory.mm",
  ]
  public_deps = [
    "//base",
    "//components/keyed_service/ios",
  ]
  deps = [
    ":safety_check",
    "//components/keyed_service/core",
    "//components/prefs",
    "//ios/chrome/browser/shared/model/browser_state",
    "//ios/chrome/browser/shared/public/features",
  ]
}

source_set("unit_tests") {
  configs += [ "//build/config/compiler:enable_arc" ]
  testonly = true
  sources = [ "ios_chrome_safety_check_manager_unittest.mm" ]
  deps = [
    ":safety_check",
    "//base",
    "//base/test:test_support",
    "//components/prefs",
    "//components/prefs:test_support",
    "//components/safe_browsing/core/common:safe_browsing_prefs",
    "//ios/chrome/browser/shared/public/features",
    "//ios/web/public/test",
    "//testing/gtest",
  ]
}
