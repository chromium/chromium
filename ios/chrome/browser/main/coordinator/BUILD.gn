source_set("coordinator") {
  sources = [
    "browser_layout_coordinator.h",
    "browser_layout_coordinator.mm",
  ]
  deps = [
    "//base",
    "//ios/chrome/browser/browser_view/ui_bundled:safe_area_provider",
    "//ios/chrome/browser/fullscreen/ui_bundled",
    "//ios/chrome/browser/main/ui",
    "//ios/chrome/browser/overlays/ui_bundled",
    "//ios/chrome/browser/shared/coordinator/chrome_coordinator",
    "//ios/chrome/browser/shared/model/browser",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/chrome/browser/tab_switcher/tab_strip/coordinator",
    "//ios/chrome/browser/tab_switcher/tab_strip/ui:utils",
    "//ui/base",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "browser_layout_coordinator_unittest.mm" ]
  deps = [
    ":coordinator",
    "//base/test:test_support",
    "//ios/chrome/browser/browser_view/ui_bundled:test_support",
    "//ios/chrome/browser/main/ui",
    "//ios/chrome/browser/shared/model/browser/test:test_support",
    "//ios/chrome/browser/shared/model/profile/test",
    "//ios/web/public/test",
    "//testing/gtest",
  ]
}
