source_set("auto_deletion") {
  sources = [
    "auto_deletion_iph_view_controller.h",
    "auto_deletion_iph_view_controller.mm",
    "auto_deletion_mutator.h",
    "auto_deletion_settings_consumer.h",
    "auto_deletion_settings_mutator.h",
  ]

  deps = [
    "//base",
    "//ios/chrome/app/strings:ios_strings_grit",
    "//ios/chrome/browser/shared/model/browser",
    "//ios/chrome/browser/shared/public/commands",
    "//ios/chrome/browser/shared/ui/symbols",
    "//ios/chrome/browser/shared/ui/util",
    "//ios/chrome/common/ui/colors",
    "//ios/chrome/common/ui/confirmation_alert",
    "//ios/chrome/common/ui/util",
    "//ui/base",
  ]
  frameworks = [ "UIKit.framework" ]
}

source_set("eg2_tests") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [ "auto_deletion_egtest.mm" ]
  deps = [
    "//ios/chrome/app/strings:ios_strings_grit",
    "//ios/chrome/browser/download/ui:test_util",
    "//ios/chrome/browser/history/ui_bundled:constants",
    "//ios/chrome/browser/shared/public/features",
    "//ios/chrome/common/ui/confirmation_alert:constants",
    "//ios/chrome/test/earl_grey:eg_test_support+eg2",
    "//ios/chrome/test/earl_grey:switches",
    "//ios/testing/earl_grey:eg_test_support+eg2",
    "//net:test_support",
    "//ui/base",
  ]
  frameworks = [ "UIKit.framework" ]
}
