source_set("zero_state_suggestions") {
  sources = [
    "zero_state_suggestions_service.h",
    "zero_state_suggestions_service.mm",
  ]

  deps = [
    "//base",
    "//components/optimization_guide/proto:optimization_guide_proto",
    "//ios/chrome/browser/intelligence/zero_state_suggestions/model",
