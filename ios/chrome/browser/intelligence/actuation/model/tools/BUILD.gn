    "//ios/chrome/browser/shared/model/browser",
    "//ios/chrome/browser/shared/model/web_state_list",
    "//ios/chrome/browser/shared/model/web_state_list:utils",
    "//ios/web/public",
  ]
}

source_set("web_actuation_interface") {
  sources = [
    "web_actuation_tool.h",
    "web_actuation_tool.mm",
  ]
  deps = [
    ":actuation_interface",
    ":java_script_features",
    "//base",
    "//ios/chrome/browser/intelligence/actuation/model:actuation_error",
    "//ios/web/public",
  ]
}

source_set("navigate_tool") {
