}

source_set("history_tool") {
  sources = [
    "history_tool.h",
    "history_tool.mm",
  ]

  deps = [
    ":actuation_interface",
    "//base",
    "//components/optimization_guide/proto:optimization_guide_proto",
    "//ios/chrome/browser/intelligence/actuation/model:actuation_error",
    "//ios/web/public",
  ]
}

compile_ts("actuation_utils_ts") {
  sources = [ "resources/actuation_utils.ts" ]
}

optimize_ts("actuation_target_ts") {
  sources = [ "resources/actuation_target.ts" ]
  output_name = "actuation_target"

  deps = [
    ":actuation_utils_ts",
    "//components/autofill/ios/form_util:child_frame_registration_ts",
    "//ios/web/public/js_messaging:gcrweb",
  ]
}

optimize_ts("click_tool_ts") {
  sources = [ "resources/click_tool.ts" ]
  output_name = "click_tool"

  deps = [
    ":actuation_utils_ts",
    "//ios/chrome/browser/intelligence/proto_wrappers:dom_node_ids_ts",
    "//ios/web/public/js_messaging:gcrweb",
  ]
}

optimize_ts("type_tool_ts") {
  sources = [ "resources/type_tool.ts" ]
  output_name = "type_tool"

  deps = [
    ":actuation_utils_ts",
    "//components/autofill/ios/form_util:fill_js_dependencies",
    "//ios/chrome/browser/intelligence/proto_wrappers:dom_node_ids_ts",
    "//ios/web/public/js_messaging:gcrweb",
  ]
}

