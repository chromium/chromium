source_set("eg_app_support+eg2") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [
    "actor_app_interface.h",
    "actor_app_interface.mm",
  ]
  deps = [
    "//base",
    "//base/test:test_support",
    "//components/optimization_guide/proto:optimization_guide_proto",
    "//ios/chrome/browser/intelligence/actor/model",
    "//ios/chrome/browser/intelligence/actor/tools/model:actor_tool_interface",
    "//ios/chrome/browser/intelligence/actor/tools/model:click_tool",
    "//ios/chrome/browser/intelligence/actor/tools/model:java_script_features",
    "//ios/chrome/browser/intelligence/actor/tools/public",
    "//ios/chrome/browser/intelligence/proto_wrappers",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/chrome/test/app:test_support",
    "//ios/web/public",
    "//ios/web/public/js_messaging",
    "//ios/web/public/test",
  ]
}

source_set("eg_test_support+eg2") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [
    "actor_app_interface.h",
    "actor_app_interface_stub.mm",
  ]
  deps = [
    "//ios/chrome/test:eg_test_support+eg2",
    "//ios/chrome/test/earl_grey:eg_test_support+eg2",
    "//ios/testing/earl_grey:eg_test_support+eg2",
  ]
}

source_set("eg2_tests") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [ "actor_tools_egtest.mm" ]
  deps = [
    ":eg_test_support+eg2",
    "//base",
    "//components/optimization_guide/proto:optimization_guide_proto",
    "//ios/chrome/browser/intelligence/features",
    "//ios/chrome/test:eg_test_support+eg2",
    "//ios/chrome/test/earl_grey:eg_test_support+eg2",
    "//ios/testing/earl_grey:eg_test_support+eg2",
    "//ios/web/public/test:element_selector",
    "//net:test_support",
    "//url",
  ]
}
