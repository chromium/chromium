source_set("model") {
  sources = [
    "destination_usage_history.h",
    "destination_usage_history.mm",
  ]
  frameworks = [ "Foundation.framework" ]
  deps = [
    "//base",
    "//components/prefs",
    "//ios/chrome/browser/popup_menu/overflow_menu/public",
    "//ios/chrome/browser/popup_menu/overflow_menu/public:overflow_menu_constants",
    "//ios/chrome/browser/shared/model/prefs:pref_names",
