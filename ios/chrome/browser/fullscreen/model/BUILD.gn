source_set("model") {
  sources = [
    "fullscreen_browser_agent.h",
    "fullscreen_browser_agent.mm",
    "fullscreen_browser_agent_observer.h",
    "fullscreen_browser_agent_observer_bridge.h",
    "fullscreen_browser_agent_observer_bridge.mm",
  ]
  deps = [
    "//base",
    "//ios/chrome/browser/fullscreen/public:metrics",
    "//ios/chrome/browser/shared/model/browser",
    "//ios/chrome/common:timing",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "fullscreen_browser_agent_unittest.mm" ]
  deps = [
    ":model",
    "//base",
    "//base/test:test_support",
    "//ios/chrome/browser/fullscreen/public:metrics",
    "//ios/chrome/browser/shared/model/browser/test:test_support",
    "//ios/chrome/browser/shared/model/profile/test",
    "//ios/chrome/common:timing",
    "//testing/gtest",
  ]
}
