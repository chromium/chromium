<!DOCTYPE translationbundle>
<translationbundle lang="am">
<translation id="1293556467332435079">ፋይሎች</translation>
<translation id="1383876407941801731">ፍለጋ </translation>
<translation id="142328118701750893">ሌሎች የመግቢያ አማራጮች</translation>
<translation id="1703743472724191604">ዋጋ $100 - $150</translation>
<translation id="1741219894094057085">ዘመናዊ ሰዓት</translation>
<translation id="1841425245869881163">ወደታች ይሸብልሉ እና ሌሎች የግዢ አማራጮች ላይ መታ ያድርጉ</translation>
<translation id="1988591645162894496">መግዛት የሚፈልጓቸውን ምርቶች የሚያቀርቡ ተጨማሪ መደብሮችን በቀላሉ ያግኙ</translation>
<translation id="2043455190894016404">በአድራሻ አሞሌው ውስጥ በጊዜ ሂደት የመጡ የዋጋ ለውጦችን ለማየት የዋጋ ታሪክ አዶው ላይ መታ ያድርጉ</translation>
<translation id="2058876133802084300">$150</translation>
<translation id="2216366330550244277">ወደ የምርት ገፅ ይሂዱ</translation>
<translation id="2327645920613292309">ፋይልዎን ለመስቀል አረጋግጥ ላይ መታ ያድርጉ</translation>
<translation id="2359808026110333948">ቀጥል</translation>
<translation id="2657494017069155956">Chrome ወደ የእርስዎ iPhone መነሻ ማያ ገፅ መትከያ በማንቀሳቀስ በፍጥነት ይድረሱ</translation>
<translation id="268174276332005428">ፋይሎችን ከDrive ይምረጡ</translation>
<translation id="3021342271734507256">ለመፈለግ በማያ ገፅዎ ላይ ያለውን ማንኛውንም ነገር ይሳሉ፣ ያድምቁ ወይም መታ ያድርጉ</translation>
<translation id="3266153067803506235">የChrome አዶን ተጭነው ይያዙ እና «የመነሻ ማያ ገፅን አርትዕ» ላይ ጠቅ ያድርጉ</translation>
<translation id="3764562164106905124">ኖቬምበር</translation>
<translation id="3872216204881482120">ኮከብ የተደረገባቸው</translation>
<translation id="3950820424414687140">በመለያ ይግቡ</translation>
<translation id="3958312024468322930">በመነሻ ማያዎ ግርጌ ላይ ወደሚገኘው መትከያ ይውሰዱት</translation>
<translation id="407228967569097346">Drive ላይ ያስቀምጡ</translation>
<translation id="4227258125987011664">$200</translation>
<translation id="4425149324548788773">የእኔ Drive</translation>
<translation id="4607887340472970274">የዋጋ ክትትል</translation>
<translation id="4760786790170329383">የሚመለከቱትን ነገር ይፈልጉ</translation>
<translation id="4803728135431112209">ለመፈለግ የሚፈልጉትን ማንኛውንም ነገር ለመምረጥ እና ትርዎን ሳይለቁ ውጤቶችን ለማግኘት ይሳሉ፣ ያድምቁ ወይም መታ ያድርጉ</translation>
<translation id="4830983309873331014">መስቀል ሲያስፈልግዎት በፍጥነት ወደ Drive ፋይሎችዎ ይሂዱ</translation>
<translation id="5010406651457630570">ኮምፒውተሮች</translation>
<translation id="5119329531859909472">ምርቱን ለመከታተል፣ ተከታተል ላይ መታ ያድርጉ</translation>
<translation id="5317780077021120954">አስቀምጥ</translation>
<translation id="5423269318075950257">ዋጋ ይከታተሉ</translation>
<translation id="5551447203719429864">Google ሌንስ ሲያስሱ የበለጠ መማርን ቀላል ያደርገዋል። ምርቶችን፣ ቦታዎችን እና ጽሑፎችን ለማሰስ አሁን በማንኛውም ገፅ ላይ የሚያዩትን መፈለግ ይችላሉ።</translation>
<translation id="5658444654562271132">Google Drive ላይ መታ ያድርጉ እና የሚያስፈልግዎትን ፋይል ይምረጡ ወይም እንዲፈልጉት ለማገዝ ፍለጋን ይጠቀሙ</translation>
<translation id="5675979375011880274">ከChrome ፋይል ሲሰቅሉ የChrome ተገቢ ሁኔታ ምናሌን ይመለከታሉ</translation>
<translation id="5839396067375352669">የይለፍ ቁልፎችን ለመጠቀም ለራስ-ሙላ Chrome ይምረጡ እና ጣቢያዎች ውስጥ ይበልጥ በፍጥነት ይግቡ</translation>
<translation id="5910891913281809039">ዲሴምበር</translation>
<translation id="5980825544755559844">$100</translation>
<translation id="5997931385777991124">ሌሎች የግዢ አማራጮች</translation>
<translation id="6250648963363746140">በጊዜ ሂደት የምርቶች ዋጋዎች እንዴት እንደተለወጠ ይመልከቱ</translation>
<translation id="6372558618707314581">ወደሚወዱት ማንኛውም ገፅ ይሂዱ</translation>
<translation id="6434483369543264725">ኦክቶበር</translation>
<translation id="6536209789880969634">«ወደ ቅንብሮች ይሂዱ» ላይ መታ ያድርጉ</translation>
<translation id="6539312626351642103">«የይለፍ ቃላት እና የይለፍ ቁልፎችን በራስ ሙላ» የሚለውን ያብሩ</translation>
<translation id="6624396414246486321">ሲያስሱ ወደ እርስዎ Google Drive ፋይሎችን በቀላሉ ያስቀምጡ</translation>
<translation id="6639712022575740908">በይለፍ ቁልፍዎ ይገባሉ?</translation>
<translation id="6926200709057244215">ዋጋዎችን ለመከታተል፣ የዋጋ ታሪክን ለመመልከት እና በምርጡ ጊዜ ለመግዛት የሚያግዙዎ የሸመታ ግንዛቤዎችን ያግኙ</translation>
<translation id="6944020103996173879">ተጨማሪ የግዢ አማራጮችን ይመልከቱ</translation>
<translation id="6998251471716094661">የምርቶችን ዋጋዎች ይከታተሉ እና በማንኛውም ጣቢያ ላይ ዋጋ ሲቀንስ ማንቂያዎች ያግኙ</translation>
<translation id="7065813315247345131">Chromeን ወደ መትከያ ያንቀሳቅሱ</translation>
<translation id="7097046145876891318">በአድራሻ አሞሌው ውስጥ በጊዜ ሂደት የመጡ የዋጋ ለውጦችን ለማየት የዋጋ ታሪክ ላይ መታ ያድርጉ</translation>
<translation id="7227293336683593977">የዋጋ ታሪክ</translation>
<translation id="7418640008860669073">አስቀምጥ በ...</translation>
<translation id="7520967554541807842">በመለያ ገብተው ሳለ ማውረድ የሚፈልጉት ፋይል ላይ መታ ያድርጉ</translation>
<translation id="7525567841374979660">የይለፍ ቁልፎችዎን በሁሉም መሣሪያዎችዎ ላይ ያግኙ</translation>
<translation id="7658239707568436148">ይቅር</translation>
<translation id="794945939108159738">$120</translation>
<translation id="8131740175452115882">አረጋግጥ</translation>
<translation id="8430394465953433179">የተጋሩ Drives</translation>
<translation id="8625706492572042370">መነሻ ማያ ገጽን ያርትዑ</translation>
<translation id="8871142946513037507">በድር ላይ ያሉ ሌሎች መደብሮች</translation>
<translation id="8881717477499381087">በአድራሻ አሞሌው ውስጥ የGoogle ሌንስ ካሜራ አዶ ላይ መታ ያድርጉ</translation>
<translation id="9130497518691394452">ለማስቀመጥ ከመገለጫዎችዎ አንዱን ይምረጡ</translation>
<translation id="935509901616026553">«አስቀምጥ» ላይ መታ ያድርጉ እና «Google Drive» ይምረጡ</translation>
<translation id="939956147720459009">Chromeን ይምረጡ</translation>
<translation id="991428047095920989">በአድራሻ አሞሌው ውስጥ በጊዜ ሂደት የመጡ የዋጋ ለውጦችን ለማየት የዋጋ ታሪክ አዶ ላይ መታ ያድርጉ</translation>
