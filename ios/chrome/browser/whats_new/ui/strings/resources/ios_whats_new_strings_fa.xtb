<translation id="4803728135431112209">با کشیدن، برجسته کردن، یا تک‌ضرب زدن می‌توانید هر چیزی را برای جستجو کردن انتخاب کنید و نتایج را بدون ترک کردن زبانه دریافت کنید</translation>
<translation id="4830983309873331014">‏وقتی نیاز دارید فایل‌های Drive را بارگذاری کنید، به‌سرعت به آن‌ها دسترسی پیدا کنید</translation>
<translation id="5010406651457630570">رایانه‌ها</translation>
