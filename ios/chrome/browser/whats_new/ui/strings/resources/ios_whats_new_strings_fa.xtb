<translation id="1988591645162894496">به‌آسانی فروشگاه‌های بیشتری پیدا کنید که محصولات مدنظرتان را ارائه می‌دهند</translation>
<translation id="2043455190894016404">در نوار نشانی، روی نماد سابقه قیمت تک‌ضرب بزنید تا تغییرات قیمت درطول زمان را ببینید</translation>
<translation id="2058876133802084300">‫۱۵۰ دلار</translation>
<translation id="2216366330550244277">رفتن به صفحه محصول</translation>
<translation id="2327645920613292309">برای بارگذاری فایل، روی «تأیید کردن» تک‌ضرب بزنید</translation>
<translation id="2359808026110333948">ادامه</translation>
<translation id="2657494017069155956">‏با انتقال Chrome به سکوی برنامه‌ها در «صفحه اصلی» iPhone، سریع‌تر به آن دسترسی داشته باشید</translation>
<translation id="268174276332005428">‏انتخاب فایل‌ها از Drive</translation>
<translation id="3021342271734507256">برای جستجو کردن می‌توانید هر چیزی را روی صفحه‌نمایش خود بکشید، برجسته کنید، یا روی آن تک‌ضرب بزنید</translation>
<translation id="3266153067803506235">‏نماد Chrome را فشار دهید و نگه دارید، سپس روی Edit Home Screen (ویرایش صفحه اصلی) کلیک کنید</translation>
