<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="hy">
<translation id="1293556467332435079">Ֆայլեր</translation>
<translation id="1383876407941801731">Որոնում</translation>
<translation id="142328118701750893">Մուտք գործելու այլ տարբերակներ</translation>
<translation id="1703743472724191604">Գինը՝ 100 $ – 150 $</translation>
<translation id="1741219894094057085">Խելացի ժամացույց</translation>
<translation id="1841425245869881163">Իջեք ներքև և հպեք «Գնման այլ տարբերակներ»</translation>
<translation id="1988591645162894496">Հեշտությամբ գտեք այլ խանութներ, որոնք առաջարկում են ձեր ուզած ապրանքները</translation>
<translation id="2043455190894016404">Հասցեագոտում հպեք գների պատմության պատկերակին՝ տեսնելու գների փոփոխությունները ժամանակի ընթացքում</translation>
<translation id="2058876133802084300">150 $</translation>
<translation id="2216366330550244277">Անցեք ապրանքի էջ</translation>
<translation id="2327645920613292309">Հպեք «Հաստատել»՝ ֆայլը վերբեռնելու համար</translation>
<translation id="2359808026110333948">Շարունակել</translation>
<translation id="2657494017069155956">Ավելի արագ բացեք Chrome-ը՝ այն տեղափոխելով ձեր iPhone-ի հիմնական էկրանի Dock վահանակ</translation>
<translation id="268174276332005428">Ավելացրեք ֆայլեր Drive-ից</translation>
<translation id="3021342271734507256">Շրջագծեք, ընդգծեք կամ հպեք՝ էկրանին ընտրելով այն տարրը, որի մասին ուզում եք տեղեկություններ որոնել</translation>
<translation id="3266153067803506235">Սեղմեք Chrome-ի պատկերակը և պահեք, ապա ընտրեք «Փոփոխել հիմնական էկրանը»</translation>
<translation id="3764562164106905124">Նոյ</translation>
<translation id="3872216204881482120">Աստղանշված</translation>
<translation id="3950820424414687140">Մուտք գործել</translation>
<translation id="3958312024468322930">Քաշեք պատկերակը Dock վահանակի վրա՝ հիմնական էկրանի ներքևում</translation>
<translation id="407228967569097346">Պահեք ֆայլեր Drive-ում</translation>
<translation id="4227258125987011664">200 $</translation>
<translation id="4425149324548788773">Իմ դրայվը</translation>
<translation id="4607887340472970274">Գների հետագծում</translation>
<translation id="4760786790170329383">Որոնեք այն, ինչ տեսնում եք</translation>
<translation id="4803728135431112209">Նկարեք, ընդգծեք կամ հպեք՝ ընտրելու այն, ինչ ցանկանում եք որոնել և արդյունքներ ստանալ՝ առանց ձեր ներդիրից դուրս գալու</translation>
<translation id="4830983309873331014">Արագ գտեք Drive-ի ձեր ֆայլերը, երբ ուզում եք վերբեռնել դրանք</translation>
<translation id="5010406651457630570">Համակարգիչներ</translation>
<translation id="5119329531859909472">Ապրանքին հետևելու համար հպեք «Հետևել»</translation>
<translation id="5317780077021120954">Պահել</translation>
<translation id="5423269318075950257">Հետևեք գներին</translation>
<translation id="5551447203719429864">Google Տեսապակու հետ նոր բաներ իմանալն ավելի հեշտ է դարձել։ Այժմ դուք կարող եք որոնել տեղեկություններ այն ամենի մասին, ինչ տեսնում եք էջում, օրինակ՝ ապրանքների, վայրերի կամ տեքստի։</translation>
<translation id="5658444654562271132">Հպեք Google Drive-ի պատկերակին և ընտրեք անհրաժեշտ ֆայլը կամ օգտվեք որոնումից</translation>
<translation id="5675979375011880274">Chrome-ից ֆայլ վերբեռնելիս դուք կտեսնեք Chrome-ի տեղային ընտրացանկը</translation>
<translation id="5839396067375352669">Ինքնալրացման կարգավորումներում ընտրեք Chrome-ը՝ մուտքի բանալիների միջոցով կայքերում ավելի արագ մուտք գործելու համար</translation>
<translation id="5910891913281809039">Դեկ</translation>
<translation id="5980825544755559844">100 $</translation>
<translation id="5997931385777991124">Գնման այլ տարբերակներ</translation>
<translation id="6250648963363746140">Տեսեք, թե ինչպես են փոխվել ապրանքների գները ժամանակի ընթացքում</translation>
<translation id="6372558618707314581">Անցեք ձեզ անհրաժեշտ էջ</translation>
<translation id="6434483369543264725">Հոկ</translation>
<translation id="6536209789880969634">Հպեք «Անցնել Կարգավորումներ»</translation>
<translation id="6539312626351642103">Միացրեք «Գաղտնաբառերի և մուտքի բանալիների ինքնալրացում» գործառույթը</translation>
<translation id="6624396414246486321">Հեշտությամբ ֆայլեր պահեք Google Drive-ում, երբ կայքեր եք այցելում</translation>
<translation id="6639712022575740908">Մուտք գործե՞լ մուտքի բանալու միջոցով</translation>
<translation id="6926200709057244215">Ստացեք գնումների վիճակագրություն, որը կօգնի ձեզ հետևել գներին, տեսնել գների պատմությունը և կատարել գնում ճիշտ պահին</translation>
<translation id="6944020103996173879">Տեսնել գնման այլ տարբերակներ</translation>
<translation id="6998251471716094661">Հետևեք ապրանքների գներին և ստանցեք ծանուցումներ, եթե գինն իջնի որևէ կայքում</translation>
<translation id="7065813315247345131">Տեղափոխեք Chrome-ը Dock վահանակ</translation>
<translation id="7097046145876891318">Հասցեագոտում հպեք գների պատմությանը՝ տեսնելու գների փոփոխությունները ժամանակի ընթացքում</translation>
<translation id="7227293336683593977">Գների փոփոխությունների պատմություն</translation>
<translation id="7418640008860669073">Պահել...</translation>
<translation id="7520967554541807842">Եթե դուք մուտք եք գործել հաշիվ, հպեք ֆայլին, որն ուզում եք ներբեռնել</translation>
<translation id="7525567841374979660">Օգտագործեք ձեր մուտքի բանալիները բոլոր սարքերում</translation>
<translation id="7658239707568436148">Չեղարկել</translation>
<translation id="794945939108159738">120 $</translation>
<translation id="8131740175452115882">Հաստատել</translation>
<translation id="8430394465953433179">Ընդհանուր դրայվներ</translation>
<translation id="8625706492572042370">Փոփոխել հիմնական էկրանը</translation>
<translation id="8871142946513037507">Այլ խանութներ համացանցում</translation>
<translation id="8881717477499381087">Հասցեագոտում հպեք Google Տեսապակու տեսախցիկի պատկերակին</translation>
<translation id="9130497518691394452">Ընտրեք պրոֆիլներից մեկը՝ պահելու համար</translation>
<translation id="935509901616026553">Հպեք «Պահել» և ընտրեք «Google Drive»-ը</translation>
<translation id="939956147720459009">Ընտրեք Chrome-ը</translation>
<translation id="991428047095920989">Հասցեագոտում հպեք գների պատմության պատկերակին՝ տեսնելու գների փոփոխությունները ժամանակի ընթացքում</translation>
</translationbundle>