<translation id="1383876407941801731">शोधा</translation>
<translation id="142328118701750893">इतर साइन-इन पर्याय</translation>
<translation id="1703743472724191604">किंमत $१०० ते $१५०</translation>
<translation id="1741219894094057085">स्‍मार्ट वॉच</translation>
<translation id="1841425245869881163">तळाशी स्क्रोल करा आणि इतर खरेदी पर्यायांवर टॅप करा</translation>
<translation id="1988591645162894496">तुम्हाला खरेदी करायची असलेली उत्पादने देऊ करणारी आणखी स्टोअर सहजपणे शोधा</translation>
<translation id="2043455190894016404">अ‍ॅड्रेस बारमध्ये, काळानुसार किमतीमधील बदल पाहण्यासाठी किंमत इतिहास आयकनवर टॅप करा</translation>
<translation id="2058876133802084300">$१५०</translation>
<translation id="2216366330550244277">उत्पादनाच्या पेजवर जा</translation>
<translation id="2327645920613292309">तुमची फाइल अपलोड करण्यासाठी कन्फर्म करा वर टॅप करा</translation>
<translation id="2359808026110333948">सुरू ठेवा</translation>
<translation id="2657494017069155956">Chrome ला तुमच्या iPhone च्या होम स्क्रीन डॉकमध्ये हलवून ते जलद अ‍ॅक्सेस करा</translation>
<translation id="268174276332005428">Drive मधून फाइल निवडा</translation>
<translation id="3021342271734507256">शोधण्यासाठी तुमच्या स्क्रीनवर कोणतीही गोष्ट ड्रॉ, हायलाइट किंवा टॅप करा</translation>
<translation id="3266153067803506235">Chrome आयकन प्रेस करून धरून ठेवा आणि "होम स्क्रीन संपादित करा" यावर क्लिक करा</translation>
<translation id="3764562164106905124">नोव्हें</translation>
<translation id="3872216204881482120">तारांकित</translation>
<translation id="3950820424414687140">साइन इन करा</translation>
<translation id="3958312024468322930">ते तुमच्या होम स्क्रीन च्या तळाशी डॉक करा वर ड्रॅग करा</translation>
<translation id="407228967569097346">Drive वर सेव्ह करा</translation>
<translation id="4227258125987011664">$२००</translation>
<translation id="4425149324548788773">माझा ड्राइव्ह</translation>
<translation id="4607887340472970274">किमतीचा माग ठेवणे</translation>
<translation id="4760786790170329383">तुम्ही जे पाहता ते शोधा</translation>
<translation id="4803728135431112209">तुम्हाला शोधायची असलेली कोणतीही गोष्ट निवडण्यासाठी ड्रॉ, हायलाइट किंवा टॅप करा आणि तुमच्या टॅबमधून बाहेर न पडता परिणाम मिळवा</translation>
<translation id="4830983309873331014">तुम्हाला फाइल अपलोड करण्याची आवश्यकता असते, तेव्हा झटपट तुमच्या Drive फाइल मिळवा</translation>
<translation id="5010406651457630570">काँप्युटर</translation>
<translation id="5119329531859909472">उत्पादन ट्रॅक करण्यासाठी, ट्रॅक करा वर टॅप करा</translation>
<translation id="5317780077021120954">सेव्ह करा</translation>
<translation id="5423269318075950257">किमतीचा माग ठेवा</translation>
<translation id="5551447203719429864">तुम्ही ब्राउझ करत असताना Google Lens मुळे अधिक जाणून घेणे सोपे होते. उत्पादने, ठिकाणे आणि मजकूर एक्सप्लोर करण्यासाठी तुम्ही आता कोणत्याही पेजवर जे पाहता ते शोधू शकता.</translation>
<translation id="5658444654562271132">Google Drive वर टॅप करा आणि तुम्हाला हवी असलेली फाइल निवडा किंवा तुम्हाला फाइल शोधण्यात मदत करण्यासाठी शोध वापरा</translation>
<translation id="5839396067375352669">पासकी वापरण्यासाठी आणि साइटवर अधिक जलद साइन इन करण्यासाठी ऑटोफिल करण्याकरिता Chrome निवडा</translation>
<translation id="5910891913281809039">डिसें</translation>
<translation id="5980825544755559844">$१००</translation>
<translation id="5997931385777991124">खरेदीचे इतर पर्याय</translation>
<translation id="6250648963363746140">उत्पादनांच्या किमती काळानुसार कशा बदलल्या आहेत हे पहा</translation>
<translation id="6372558618707314581">तुम्हाला आवडत असलेल्या कोणत्याही पेजवर जा</translation>
<translation id="6434483369543264725">ऑक्टो</translation>
<translation id="6536209789880969634">“सेटिंग्ज वर जा” वर टॅप करा</translation>
<translation id="6539312626351642103">“पासवर्ड आणि पासकी ऑटोफिल करा” सुरू करा</translation>
<translation id="6624396414246486321">तुम्ही ब्राउझ करत असताना तुमच्या Google Drive मध्ये फाइल सहजपणे सेव्ह करा</translation>
<translation id="6639712022575740908">तुमची पासकी वापरून साइन इन करायचे आहे का?</translation>
<translation id="6926200709057244215">तुम्हाला किमतींचा माग ठेवण्यात मदत करणाऱ्या खरेदीसंबंधित इनसाइट मिळवा, किमतीचा इतिहास पहा आणि सर्वोत्तम वेळी खरेदी करा.</translation>
<translation id="6944020103996173879">खरेदीचे आणखी पर्याय पहा</translation>
<translation id="6998251471716094661">उत्पादनांच्या किमती ट्रॅक करा आणि कोणत्याही साइटवर किंमत कमी झाल्यावर सूचना मिळवा</translation>
<translation id="7065813315247345131">Chrome ला डॉक वर हलवा</translation>
<translation id="7097046145876891318">अ‍ॅड्रेस बारमध्ये, काळानुसार किमतीमधील बदल पाहण्यासाठी किंमत इतिहासावर टॅप करा</translation>
<translation id="7227293336683593977">किमतीचा इतिहास</translation>
<translation id="7418640008860669073">यामध्ये सेव्ह करा...</translation>
<translation id="7520967554541807842">तुम्ही साइन केलेले असल्यावर, तुम्हाला डाउनलोड करायच्या असलेल्या फाइलवर टॅप करा</translation>
<translation id="7525567841374979660">तुमच्या सर्व डिव्हाइसवर तुमच्या पासकी मिळवा</translation>
<translation id="7658239707568436148">रद्द करा</translation>
<translation id="794945939108159738">$१२०</translation>
<translation id="8131740175452115882">पुष्टी करा</translation>
<translation id="8430394465953433179">शेअर केलेल्या ड्राइव्ह</translation>
<translation id="8625706492572042370">होम स्क्रीन संपादित करा</translation>
<translation id="8871142946513037507">संपूर्ण वेबवरील इतर स्टोअर</translation>
<translation id="8881717477499381087">अ‍ॅड्रेस बारमध्ये, Google Lens कॅमेरा आयकनवर टॅप करा</translation>
<translation id="9130497518691394452">यामध्ये सेव्ह करण्यासाठी तुमच्या प्रोफाइलपैकी एक प्रोफाइल निवडा</translation>
