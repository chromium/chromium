<translation id="2327645920613292309">כדי להעלות את הקובץ, צריך ללחוץ על "אישור"</translation>
<translation id="2359808026110333948">המשך</translation>
<translation id="2657494017069155956">‏אפשר להעביר את Chrome ל-Dock במסך הבית של האייפון כדי לגשת לאפליקציה מהר יותר</translation>
<translation id="268174276332005428">‏בחירת קבצים מ-Drive</translation>
<translation id="3021342271734507256">משרטטים, מדגישים או לוחצים על כל דבר במסך כדי לחפש</translation>
<translation id="3266153067803506235">‏לוחצים לחיצה ארוכה על סמל Chrome ואז לוחצים על 'עריכה של מסך הבית'</translation>
<translation id="3764562164106905124">נוב'</translation>
