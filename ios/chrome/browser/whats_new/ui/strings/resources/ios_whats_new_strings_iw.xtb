<translation id="5119329531859909472">כדי לעקוב אחרי המוצר, לוחצים על "מעקב"</translation>
<translation id="5317780077021120954">שמירה</translation>
<translation id="5423269318075950257">מעקב אחר המחיר</translation>
<translation id="5551447203719429864">‏עם Google Lens קל יותר ללמוד עוד דברים בזמן הגלישה. עכשיו אפשר לחפש את מה שרואים בדף כדי לחקור מוצרים, מקומות וטקסט.</translation>
<translation id="5658444654562271132">‏לוחצים על Google Drive ובוחרים את הקובץ הרצוי, או משתמשים בחיפוש כדי למצוא אותו</translation>
<translation id="5675979375011880274">‏כשמעלים קובץ מ-Chrome, מוצג תפריט ההקשר של Chrome</translation>
<translation id="5839396067375352669">‏אפשר לבחור ב-Chrome למילוי אוטומטי כדי להשתמש במפתחות גישה ולהיכנס לאתרים מהר יותר</translation>
<translation id="5910891913281809039">דצמ'</translation>
<translation id="5980825544755559844">$100</translation>
<translation id="5997931385777991124">אפשרויות רכישה אחרות</translation>
