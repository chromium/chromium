<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="mn">
<translation id="1293556467332435079">Файлууд</translation>
<translation id="1383876407941801731">Хайлт</translation>
<translation id="142328118701750893">Нэвтрэх бусад сонголт</translation>
<translation id="1703743472724191604">Үнэ $100 - $150</translation>
<translation id="1741219894094057085">Ухаалаг цаг</translation>
<translation id="1841425245869881163">Доод тал руу гүйлгэж, Худалдан авах бусад сонголт дээр товшино уу</translation>
<translation id="1988591645162894496">Таны худалдан авахыг хүсэж буй бүтээгдэхүүнүүдийг санал болгодог бусад дэлгүүрийг хялбархан олоорой</translation>
<translation id="2043455190894016404">Цаг хугацааны явц дахь үнийн өөрчлөлтийг харахын тулд хаяг оруулах хэсэгт үнийн түүхийн дүрс тэмдэг дээр товшино уу</translation>
<translation id="2058876133802084300">$150</translation>
<translation id="2216366330550244277">Бүтээгдэхүүний хуудас руу очно уу</translation>
<translation id="2327645920613292309">Файлаа байршуулахын тулд Баталгаажуулах дээр товшино уу</translation>
<translation id="2359808026110333948">Цааш</translation>
<translation id="2657494017069155956">Chrome-г өөрийн iPhone-н үндсэн нүүрний суурилуулагч руу зөөж хурдан хандана уу</translation>
<translation id="268174276332005428">Драйваас файл сонгоно уу</translation>
<translation id="3021342271734507256">Хайхын тулд дэлгэц дээрээ байгаа дурын зүйлийг зурж, тодруулж, товшино уу</translation>
<translation id="3266153067803506235">Chrome-н дүрс тэмдгийг удаан дараад, “Үндсэн нүүрийг засах”-ыг товшино уу</translation>
<translation id="3764562164106905124">11-р сар</translation>
<translation id="3872216204881482120">Одтой</translation>
<translation id="3950820424414687140">Нэвтрэх</translation>
<translation id="3958312024468322930">Үүнийг үндсэн нүүрнийхээ доод талын суурилуулагч руу чирнэ үү</translation>
<translation id="407228967569097346">Драйвт хадгалах</translation>
<translation id="4227258125987011664">$200</translation>
<translation id="4425149324548788773">Миний Драйв</translation>
<translation id="4607887340472970274">Үнэ мөшгөх</translation>
<translation id="4760786790170329383">Харж буй зүйлээсээ хайгаарай</translation>
<translation id="4803728135431112209">Хайхыг хүссэн зүйлээ сонгохын тулд зурж, тодруулж, товшиж, табаасаа гарахгүйгээр илэрц аваарай</translation>
<translation id="4830983309873331014">Та Драйвын файлаа байршуулах шаардлагатай үедээ тухайн файлдаа хурдан очоорой</translation>
<translation id="5010406651457630570">Компьютерууд</translation>
<translation id="5119329531859909472">Бүтээгдэхүүнийг хянахын тулд Хянах дээр товшино уу</translation>
<translation id="5317780077021120954">Хадгалах</translation>
<translation id="5423269318075950257">Үнэ хянах</translation>
<translation id="5551447203719429864">Google Lens танд үзэх явцдаа нэмэлт мэдээлэл авахыг хялбар болгодог. Та одоо бүтээгдэхүүн, газар, текст судлахын тулд аливаа хуудсан дээр харж буй зүйлээсээ хайх боломжтой.</translation>
<translation id="5658444654562271132">Google Драйв дээр товшиж, хэрэгтэй файлаа сонгох эсвэл олоход тусламж болгон хайлтыг ашиглана уу</translation>
<translation id="5839396067375352669">Нэвтрэх түлхүүрийг ашиглах, сайтад илүү хурдан нэвтрэхийн тулд Автоматаар бөглөх хэсэгт зориулж Chrome-г сонгоно уу</translation>
<translation id="5910891913281809039">12-р сар</translation>
<translation id="5980825544755559844">$100</translation>
<translation id="5997931385777991124">Худалдан авах бусад сонголт</translation>
<translation id="6250648963363746140">Цаг хугацааны явцад үнэ хэрхэн өөрчлөгдсөн болохыг хараарай</translation>
<translation id="6372558618707314581">Дурын хуудас руу очно уу</translation>
<translation id="6434483369543264725">10-р сар</translation>
<translation id="6536209789880969634">“Тохиргоо руу очих” дээр товшино уу</translation>
<translation id="6539312626351642103">“Нууц үг, нэвтрэх түлхүүрийг автоматаар бөглөх”-ийг асаана уу</translation>
<translation id="6624396414246486321">Та үзэх явцдаа Google Драйвтаа файл хялбархан хадгалаарай</translation>
<translation id="6639712022575740908">Нэвтрэх түлхүүрээрээ нэвтрэх үү?</translation>
<translation id="6926200709057244215">Танд үнэ хянах, үнийн түүх харах, хамгийн зөв цагт худалдан авахад туслах худалдан авалтын статистикийг аваарай</translation>
<translation id="6944020103996173879">Худалдан авах бусад сонголтыг харах</translation>
<translation id="6998251471716094661">Бүтээгдэхүүнүүдийн үнийг хянаж, аливаа сайт дээр үнэ буурахад дохио аваарай</translation>
<translation id="7065813315247345131">Chrome-г суурилуулагч руу зөөх</translation>
<translation id="7097046145876891318">Цаг хугацааны явц дахь үнийн өөрчлөлтийг харахын тулд хаяг оруулах хэсэгт үнийн түүх дээр товшино уу</translation>
<translation id="7227293336683593977">Үнийн түүх</translation>
<translation id="7418640008860669073">Дараахад хадгалах...</translation>
<translation id="7520967554541807842">Та нэвтэрсэн үедээ татахыг хүссэн файл дээрээ товшино уу</translation>
<translation id="7525567841374979660">Бүх төхөөрөмж дээрээ нэвтрэх түлхүүрээ авах</translation>
<translation id="7658239707568436148">Болих</translation>
<translation id="794945939108159738">$120</translation>
<translation id="8131740175452115882">Батлах</translation>
<translation id="8430394465953433179">Дундын драйв</translation>
<translation id="8625706492572042370">Үндсэн нүүрийг засах</translation>
<translation id="8871142946513037507">Веб дээрх бусад дэлгүүр</translation>
<translation id="8881717477499381087">Хаяг оруулах хэсэгт Google Lens-н камерын дүрс тэмдэг дээр товшино уу</translation>
<translation id="9130497518691394452">Профайлуудаасаа зүйл хадгалах нэг профайл сонгоно уу</translation>
<translation id="935509901616026553">“Хадгалах” дээр товшиж, “Google Драйв”-ыг сонгоно уу</translation>
<translation id="939956147720459009">Chrome-г сонгох</translation>
<translation id="991428047095920989">Цаг хугацааны явц дахь үнийн өөрчлөлтийг харахын тулд хаяг оруулах хэсэгт үнийн түүхийн дүрс тэмдэг дээр товшино уу</translation>
</translationbundle>