<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="vi">
<translation id="1293556467332435079">Tệp</translation>
<translation id="1383876407941801731">Tìm kiếm</translation>
<translation id="142328118701750893">Các phương thức đăng nhập khác</translation>
<translation id="1703743472724191604">Giá $100 – $150</translation>
<translation id="1741219894094057085">Đồng hồ thông minh</translation>
<translation id="1841425245869881163">Cuộn xuống dưới cùng rồi nhấn vào Các lựa chọn mua hàng khác</translation>
<translation id="1988591645162894496">Dễ dàng tìm thấy nhiều cửa hàng khác bán sản phẩm bạn muốn mua</translation>
<translation id="2043455190894016404">Trong thanh địa chỉ, hãy nhấn vào biểu tượng giá theo thời gian để xem các mức giá thay đổi theo thời gian</translation>
<translation id="2058876133802084300">$150</translation>
<translation id="2216366330550244277">Truy cập trang của một sản phẩm</translation>
<translation id="2327645920613292309">Nhấn vào Xác nhận để tải tệp lên</translation>
<translation id="2359808026110333948">Tiếp tục</translation>
<translation id="2657494017069155956">Đưa Chrome vào thanh Dock trên Màn hình chính của iPhone để truy cập nhanh hơn</translation>
<translation id="268174276332005428">Chọn tệp trên Drive</translation>
<translation id="3021342271734507256">Vẽ, đánh dấu hoặc nhấn vào nội dung bất kỳ trên màn hình để tìm kiếm</translation>
<translation id="3266153067803506235">Nhấn và giữ biểu tượng Chrome rồi nhấp vào "Chỉnh sửa Màn hình chính"</translation>
<translation id="3764562164106905124">Th11</translation>
<translation id="3872216204881482120">Có gắn dấu sao</translation>
<translation id="3950820424414687140">Đăng nhập</translation>
<translation id="3958312024468322930">Kéo biểu tượng ứng dụng vào thanh dock ở cuối Màn hình chính</translation>
<translation id="407228967569097346">Lưu vào Drive</translation>
<translation id="4227258125987011664">$200</translation>
<translation id="4425149324548788773">Drive của tôi</translation>
<translation id="4607887340472970274">Theo dõi giá</translation>
<translation id="4760786790170329383">Tìm thông tin về điều bạn thấy</translation>
<translation id="4803728135431112209">Vẽ, đánh dấu hoặc nhấn để chọn bất kỳ nội dung nào bạn muốn tìm kiếm và nhận kết quả mà không cần rời khỏi thẻ</translation>
<translation id="4830983309873331014">Nhanh chóng truy cập vào các tệp trên Drive khi bạn cần tải tệp lên</translation>
<translation id="5010406651457630570">Máy tính</translation>
<translation id="5119329531859909472">Để theo dõi sản phẩm, hãy nhấn vào Theo dõi</translation>
<translation id="5317780077021120954">Lưu</translation>
<translation id="5423269318075950257">Theo dõi giá</translation>
<translation id="5551447203719429864">Google Ống kính giúp bạn dễ dàng tìm hiểu thêm thông tin trong khi duyệt web. Giờ đây, bạn có thể tìm thông tin về nội dung mình nhìn thấy trên bất kỳ trang nào để khám phá các sản phẩm, địa điểm và văn bản.</translation>
<translation id="5658444654562271132">Nhấn vào Google Drive rồi chọn tệp bạn cần hoặc sử dụng tính năng tìm kiếm để tìm tệp đó</translation>
<translation id="5675979375011880274">Khi tải tệp lên từ Chrome, bạn sẽ thấy trình đơn theo bối cảnh của Chrome</translation>
<translation id="5839396067375352669">Chọn Chrome làm dịch vụ tự động điền để sử dụng khoá truy cập và đăng nhập vào các trang web nhanh chóng hơn</translation>
<translation id="5910891913281809039">Th12</translation>
<translation id="5980825544755559844">$100</translation>
<translation id="5997931385777991124">Các lựa chọn mua hàng khác</translation>
<translation id="6250648963363746140">Xem giá của sản phẩm đã thay đổi như thế nào theo thời gian</translation>
<translation id="6372558618707314581">Chuyển đến trang bất kỳ mà bạn muốn.</translation>
<translation id="6434483369543264725">Th10</translation>
<translation id="6536209789880969634">Nhấn vào "Chuyển đến phần Cài đặt"</translation>
<translation id="6539312626351642103">Bật chế độ "Tự động điền mật khẩu và khoá truy cập"</translation>
<translation id="6624396414246486321">Dễ dàng lưu tệp vào Google Drive trong lúc duyệt web</translation>
<translation id="6639712022575740908">Đăng nhập bằng khoá truy cập?</translation>
<translation id="6926200709057244215">Nhận thông tin mua sắm chi tiết để theo dõi giá, xem giá theo thời gian và mua hàng vào thời điểm tốt nhất</translation>
<translation id="6944020103996173879">Xem các lựa chọn mua hàng khác</translation>
<translation id="6998251471716094661">Theo dõi giá của sản phẩm và nhận thông báo khi có chương trình giảm giá trên bất cứ trang web nào</translation>
<translation id="7065813315247345131">Đưa Chrome vào thanh Dock</translation>
<translation id="7097046145876891318">Trong thanh địa chỉ, hãy nhấn vào giá theo thời gian để xem các mức giá thay đổi theo thời gian</translation>
<translation id="7227293336683593977">Giá theo thời gian</translation>
<translation id="7418640008860669073">Lưu vào...</translation>
<translation id="7520967554541807842">Sau khi bạn đăng nhập, hãy nhấn vào tệp bạn muốn tải xuống</translation>
<translation id="7525567841374979660">Sử dụng khoá truy cập trên tất cả thiết bị của bạn</translation>
<translation id="7658239707568436148">Huỷ</translation>
<translation id="794945939108159738">$120</translation>
<translation id="8131740175452115882">Xác nhận</translation>
<translation id="8430394465953433179">Bộ nhớ dùng chung</translation>
<translation id="8625706492572042370">Chỉnh sửa Màn hình chính</translation>
<translation id="8871142946513037507">Các cửa hàng khác trên web</translation>
<translation id="8881717477499381087">Trong thanh địa chỉ, hãy nhấn vào biểu tượng camera của Google Ống kính</translation>
<translation id="9130497518691394452">Chọn hồ sơ mà bạn muốn lưu tệp vào trong số các hồ sơ của bạn</translation>
<translation id="935509901616026553">Nhấn vào "Lưu" rồi chọn "Google Drive"</translation>
<translation id="939956147720459009">Chọn Chrome</translation>
<translation id="991428047095920989">Trong thanh địa chỉ, hãy nhấn vào biểu tượng giá theo thời gian để xem các mức giá thay đổi theo thời gian</translation>
</translationbundle>