<!DOCTYPE translationbundle>
<translationbundle lang="th">
<translation id="1293556467332435079">ไฟล์</translation>
<translation id="1383876407941801731">ค้นหา</translation>
<translation id="142328118701750893">ตัวเลือกการลงชื่อเข้าใช้อื่นๆ</translation>
<translation id="1703743472724191604">ราคา $100 - $150</translation>
<translation id="1741219894094057085">สมาร์ทวอทช์</translation>
<translation id="1841425245869881163">เลื่อนไปที่ด้านล่างแล้วแตะ "ตัวเลือกการซื้ออื่นๆ"</translation>
<translation id="1988591645162894496">ค้นหาร้านค้าอื่นๆ ที่มีผลิตภัณฑ์ที่คุณต้องการซื้อได้อย่างง่ายดาย</translation>
<translation id="2043455190894016404">ในแถบที่อยู่ ให้แตะไอคอนประวัติราคาเพื่อดูการเปลี่ยนแปลงของราคาเมื่อเวลาผ่านไป</translation>
<translation id="2058876133802084300">$150</translation>
<translation id="2216366330550244277">ไปที่หน้าผลิตภัณฑ์</translation>
<translation id="2327645920613292309">แตะยืนยันเพื่ออัปโหลดไฟล์</translation>
<translation id="2359808026110333948">ต่อไป</translation>
<translation id="2657494017069155956">เข้าถึง Chrome ได้เร็วขึ้นโดยย้ายไปยังแถบแอปในหน้าจอหลักของ iPhone</translation>
<translation id="268174276332005428">เลือกไฟล์จากไดรฟ์</translation>
<translation id="3021342271734507256">วง ไฮไลต์ หรือแตะสิ่งใดก็ได้บนหน้าจอเพื่อค้นหา</translation>
<translation id="3266153067803506235">กดไอคอน Chrome ค้างไว้แล้วคลิก "แก้ไขหน้าจอหลัก"</translation>
<translation id="3764562164106905124">พ.ย.</translation>
<translation id="3872216204881482120">ที่ติดดาว</translation>
<translation id="3950820424414687140">ลงชื่อเข้าใช้</translation>
<translation id="3958312024468322930">ลากแอปไปยังแถบแอปที่ด้านล่างของหน้าจอหลัก</translation>
<translation id="407228967569097346">บันทึกไปที่ไดรฟ์</translation>
<translation id="4227258125987011664">$200</translation>
<translation id="4425149324548788773">ไดรฟ์ของฉัน</translation>
<translation id="4607887340472970274">การติดตามราคา</translation>
<translation id="4760786790170329383">ค้นหาสิ่งที่คุณเห็น</translation>
<translation id="4803728135431112209">วง ไฮไลต์ หรือแตะเพื่อเลือกสิ่งที่ต้องการค้นหาและรับผลการค้นหาโดยไม่ต้องออกจากแท็บ</translation>
<translation id="4830983309873331014">เข้าถึงไฟล์ในไดรฟ์ได้อย่างรวดเร็วเมื่อต้องการอัปโหลดไฟล์</translation>
<translation id="5010406651457630570">คอมพิวเตอร์</translation>
<translation id="5119329531859909472">หากต้องการติดตามผลิตภัณฑ์ ให้แตะ "ติดตาม"</translation>
<translation id="5317780077021120954">บันทึก</translation>
<translation id="5423269318075950257">ติดตามราคา</translation>
<translation id="5551447203719429864">Google Lens ช่วยให้คุณดูข้อมูลเพิ่มเติมได้ง่ายๆ ขณะท่องเว็บ ตอนนี้คุณจะค้นหาสิ่งที่เห็นในหน้าเว็บใดก็ได้เพื่อสำรวจเกี่ยวกับผลิตภัณฑ์ สถานที่ และข้อความต่างๆ</translation>
<translation id="5658444654562271132">แตะ Google ไดรฟ์แล้วเลือกไฟล์ที่ต้องการ หรือใช้การค้นหาเพื่อช่วยคุณค้นหาไฟล์</translation>
<translation id="5839396067375352669">เลือก Chrome สำหรับการป้อนข้อความอัตโนมัติเพื่อใช้พาสคีย์และลงชื่อเข้าใช้เว็บไซต์ได้เร็วขึ้น</translation>
<translation id="5910891913281809039">ธ.ค.</translation>
<translation id="5980825544755559844">$100</translation>
<translation id="5997931385777991124">ตัวเลือกการซื้ออื่นๆ</translation>
<translation id="6250648963363746140">ดูว่าราคาผลิตภัณฑ์มีการเปลี่ยนแปลงอย่างไรเมื่อเวลาผ่านไป</translation>
<translation id="6372558618707314581">ไปที่หน้าใดก็ได้ที่คุณต้องการ</translation>
<translation id="6434483369543264725">ต.ค.</translation>
<translation id="6536209789880969634">แตะ "ไปที่การตั้งค่า"</translation>
<translation id="6539312626351642103">เปิด "ป้อนรหัสผ่านและพาสคีย์อัตโนมัติ"</translation>
<translation id="6624396414246486321">บันทึกไฟล์ลงใน Google ไดรฟ์ได้อย่างง่ายดายขณะท่องเว็บ</translation>
<translation id="6639712022575740908">ลงชื่อเข้าใช้ด้วยพาสคีย์ใช่ไหม</translation>
<translation id="6926200709057244215">รับข้อมูลเชิงลึกเกี่ยวกับการช็อปปิ้งที่ช่วยให้คุณติดตามราคา ดูประวัติราคา และซื้อในเวลาที่ดีที่สุด</translation>
<translation id="6944020103996173879">ดูตัวเลือกการซื้อเพิ่มเติม</translation>
<translation id="6998251471716094661">ติดตามราคาของผลิตภัณฑ์และรับการแจ้งเตือนเมื่อราคาต่ำลงในเว็บไซต์ใดก็ตาม</translation>
<translation id="7065813315247345131">ย้าย Chrome ไปที่แถบแอป</translation>
<translation id="7097046145876891318">ในแถบที่อยู่ ให้แตะประวัติราคาเพื่อดูการเปลี่ยนแปลงของราคาเมื่อเวลาผ่านไป</translation>
<translation id="7227293336683593977">ประวัติราคา</translation>
<translation id="7367247969270271216">เมื่อต้องการไฟล์จากไดรฟ์ ให้แตะเมนู Chrome</translation>
<translation id="7418640008860669073">บันทึกใน...</translation>
<translation id="7520967554541807842">เมื่อลงชื่อเข้าใช้แล้ว ให้แตะไฟล์ที่ต้องการดาวน์โหลด</translation>
<translation id="7525567841374979660">รับพาสคีย์ในอุปกรณ์ทุกเครื่อง</translation>
<translation id="7658239707568436148">ยกเลิก</translation>
<translation id="794945939108159738">$120</translation>
<translation id="8131740175452115882">ยืนยัน</translation>
<translation id="8430394465953433179">ไดรฟ์ที่แชร์</translation>
<translation id="8625706492572042370">แก้ไขหน้าจอหลัก</translation>
<translation id="8871142946513037507">ร้านค้าอื่นๆ ในอินเทอร์เน็ต</translation>
<translation id="8881717477499381087">ในแถบที่อยู่ ให้แตะไอคอนกล้อง Google Lens</translation>
<translation id="9130497518691394452">เลือกโปรไฟล์ที่จะบันทึก</translation>
<translation id="935509901616026553">แตะ "บันทึก" แล้วเลือก "Google ไดรฟ์"</translation>
<translation id="939956147720459009">เลือก Chrome</translation>
<translation id="991428047095920989">ในแถบที่อยู่ ให้แตะไอคอนประวัติราคาเพื่อดูการเปลี่ยนแปลงของราคาเมื่อเวลาผ่านไป</translation>
</translationbundle>