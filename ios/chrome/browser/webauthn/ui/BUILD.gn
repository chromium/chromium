import("//ios/build/chrome_build.gni")

source_set("ui") {
  sources = [
    "passkey_incognito_interstitial_view_controller.h",
    "passkey_incognito_interstitial_view_controller.mm",
  ]
  deps = [
    "//ios/chrome/app/strings",
    "//ios/chrome/common/ui/button_stack",
    "//ios/chrome/common/ui/colors",
    "//ios/chrome/common/ui/confirmation_alert",
    "//ui/base",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "passkey_incognito_interstitial_view_controller_unittest.mm" ]
  deps = [
    ":ui",
    "//ios/chrome/app/strings",
    "//ios/chrome/common/ui/button_stack",
    "//testing/gtest",
    "//ui/base",
  ]
}
