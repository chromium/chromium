compile_ts("compile_send_tab_to_self_fragments_js") {
  allow_js = true
  sources = [
    "//third_party/text-fragments-polyfill/src/src/fragment-generation-utils.js",
    "//third_party/text-fragments-polyfill/src/src/text-fragment-utils.js",
    "resources/send_tab_to_self_fragments.ts",
  ]
  deps = [ "//ios/web/public/js_messaging:gcrweb" ]
}

optimize_js("send_tab_to_self_fragments_js") {
  _outputs = get_target_outputs(":compile_send_tab_to_self_fragments_js")
  _primary_script =
      filter_include(_outputs, [ "*send_tab_to_self_fragments.js" ])
  primary_script = _primary_script[0]
  sources = _primary_script
  deps = [
    ":compile_send_tab_to_self_fragments_js",
    "//ios/web/public/js_messaging:gcrweb",
  ]
}

