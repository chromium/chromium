source_set("eg2_tests") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [ "bookmarks_editor_egtest.mm" ]
  deps = [
    "//ios/chrome/app/strings",
    "//ios/chrome/browser/bookmarks/model:bookmark_storage_type",
    "//ios/chrome/browser/bookmarks/public:constants",
    "//ios/chrome/browser/bookmarks/test:eg_test_support+eg2",
    "//ios/chrome/browser/shared/public/snackbar:constants",
    "//ios/chrome/test/earl_grey:eg_test_support+eg2",
    "//ios/testing/earl_grey:eg_test_support+eg2",
    "//net:test_support",
    "//ui/base",
  ]
  frameworks = [ "UIKit.framework" ]
}
