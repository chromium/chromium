source_set("util") {
  sources = [
    "parcel_tracking_util.h",
    "parcel_tracking_util.mm",
  ]
  deps = [
    "//base",
    "//components/prefs",
    "//components/signin/public/base",
    "//ios/chrome/browser/shared/model/browser_state",
    "//ios/chrome/browser/shared/model/prefs:pref_names",
