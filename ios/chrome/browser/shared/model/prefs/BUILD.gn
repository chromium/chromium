source_set("pref_names") {
  configs += [ "//build/config/compiler:enable_arc" ]
  sources = [ "pref_names.h" ]
  public_deps = [ "//ios/chrome/browser/prefs:pref_names" ]
}

source_set("browser_prefs") {
  configs += [ "//build/config/compiler:enable_arc" ]
  sources = [ "browser_prefs.h" ]
  public_deps = [ "//ios/chrome/browser/prefs:browser_prefs" ]
}
