source_set("ui") {
  sources = [
    "assistant_container_accessibility_manager.h",
    "assistant_container_accessibility_manager.mm",
    "assistant_container_animatable.h",
    "assistant_container_animator.h",
    "assistant_container_animator.mm",
    "assistant_container_delegate.h",
    "assistant_container_layout_utils.h",
    "assistant_container_layout_utils.mm",
    "assistant_container_presentation_context.h",
    "assistant_container_presenter.h",
    "assistant_container_view.h",
    "assistant_container_view.mm",
    "assistant_container_view_controller.h",
    "assistant_container_view_controller.mm",
    "assistant_grabber_button.h",
    "assistant_grabber_button.mm",
  ]
  deps = [
    ":constants",
    ":detent",
    "//base",
    "//ios/chrome/app/strings",
    "//ios/chrome/browser/shared/coordinator/scene/state",
    "//ios/chrome/browser/shared/public/features",
    "//ios/chrome/browser/shared/ui/chrome_overlay_window",
    "//ios/chrome/browser/shared/ui/elements",
    "//ios/chrome/browser/shared/ui/symbols",
    "//ios/chrome/common/ui/colors",
    "//ios/chrome/common/ui/util",
    "//ui/base",
  ]
}

source_set("constants") {
  sources = [
    "assistant_container_constants.h",
    "assistant_container_constants.mm",
  ]
  deps = [ "//base" ]
}

source_set("detent") {
  sources = [
    "assistant_container_detent.h",
    "assistant_container_detent.mm",
  ]
  deps = [ "//base" ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "assistant_container_accessibility_manager_unittest.mm",
    "assistant_container_layout_utils_unittest.mm",
    "assistant_container_view_controller_unittest.mm",
  ]
  deps = [
    ":detent",
    ":ui",
    "//base",
    "//base/test:test_support",
    "//ios/chrome/app/strings",
    "//ios/chrome/browser/shared/coordinator/scene/state",
    "//ios/chrome/common/ui/util",
    "//ios/chrome/test/app:test_support",
    "//testing/gtest",
    "//third_party/ocmock",
    "//ui/base",
  ]
}
