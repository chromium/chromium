  sources = [ "x509_certificate_model_ios_unittest.mm" ]
  deps = [
    ":model",
    "//base/test:test_support",
    "//components/strings",
    "//ios/chrome/app/strings",
    "//net",
    "//net:test_support",
    "//testing/gtest",
    "//ui/base",
  ]
}
