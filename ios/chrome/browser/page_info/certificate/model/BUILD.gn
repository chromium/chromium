source_set("model") {
  sources = [
    "x509_certificate_model_ios.h",
    "x509_certificate_model_ios.mm",
  ]
  deps = [
    "//base",
    "//components/certificate_model",
    "//components/strings",
    "//crypto",
    "//ios/chrome/app/strings",
    "//net",
    "//third_party/boringssl",
    "//ui/base",
