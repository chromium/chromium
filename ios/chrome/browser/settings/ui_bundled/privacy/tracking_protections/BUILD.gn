    "tracking_protections_view_controller.mm",
  ]

  deps = [
    "//components/strings",
    "//ios/chrome/browser/net/model:crurl",
    "//ios/chrome/browser/settings/ui_bundled:settings_root",
    "//ios/chrome/browser/settings/ui_bundled/cells",
    "//ios/chrome/browser/settings/ui_bundled/privacy/tracking_protections/script_blocking",
    "//ios/chrome/browser/shared/coordinator/chrome_coordinator",
