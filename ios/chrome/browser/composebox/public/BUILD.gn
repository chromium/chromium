group("public") {
  public_deps = [
    ":animation",
    ":attachment_options",
    ":attachment_selection",
    ":composebox_mode",
    ":constants",
    ":entrypoint",
    ":features",
    ":focus_params",
    ":input_plate_controls",
    ":input_plate_position",
    ":model_options",
    ":theme",
  ]
}

source_set("features") {
  sources = [
    "features.h",
    "features.mm",
  ]
  deps = [ "//base" ]
}

source_set("theme") {
  sources = [
    "composebox_theme.h",
    "composebox_theme.mm",
  ]
  deps = [
    "//base",
    "//ios/chrome/common/ui/colors",
    "//ios/web/public",
    "//ui/base",
  ]
  public_deps = [ ":input_plate_position" ]
}

source_set("constants") {
  sources = [ "composebox_constants.h" ]
  deps = [ "//base" ]
}

source_set("animation") {
  sources = [ "composebox_animation_base.h" ]
  deps = [ "//base" ]
}

source_set("input_plate_position") {
  sources = [ "composebox_input_plate_position.h" ]
  deps = [ "//base" ]
}

source_set("input_plate_controls") {
  sources = [ "composebox_input_plate_controls.h" ]
  deps = [ "//base" ]
}

source_set("model_options") {
  sources = [ "composebox_model_option.h" ]
  deps = [ "//base" ]
}

source_set("attachment_options") {
  sources = [ "composebox_attachment_option.h" ]
  deps = [ "//base" ]
}

source_set("entrypoint") {
  sources = [ "composebox_entrypoint.h" ]
  deps = [ "//base" ]
}

source_set("attachment_selection") {
  sources = [
    "composebox_attachment_selection.h",
    "composebox_attachment_selection.mm",
  ]
  public_deps = [
    "//ios/chrome/browser/composebox/shared/coordinator",
    "//ios/web/public",
  ]
  deps = [ "//base" ]
}

source_set("composebox_mode") {
  sources = [ "composebox_mode.h" ]
  deps = [ "//base" ]
}

source_set("focus_params") {
  sources = [
    "composebox_focus_params.h",
    "composebox_focus_params.mm",
  ]
  public_deps = [
    ":attachment_selection",
    ":composebox_mode",
    ":entrypoint",
    ":model_options",
    "//ios/chrome/browser/composebox/shared/coordinator",
    "//ios/chrome/browser/composebox/shared/metrics",
    "//ios/web/public",
  ]
  deps = [ "//base" ]
}
