source_set("eg2_tests") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [ "composebox_egtest.mm" ]
  deps = [
    ":eg_test_support+eg2",
    "//base",
    "//base:i18n",
    "//base/test:test_support",
    "//components/omnibox/browser:aim_eligibility_service_features",
    "//ios/chrome/app/strings",
    "//ios/chrome/browser/composebox/coordinator:constants",
    "//ios/chrome/browser/composebox/shared/ui:ui_constants",
    "//ios/chrome/browser/omnibox/public:constants",
    "//ios/chrome/browser/shared/public/features",
    "//ios/chrome/browser/tab_picker/ui:ui_constants",
    "//ios/chrome/browser/tab_switcher/ui_bundled/tab_grid/grid:grid_ui_constants",
    "//ios/chrome/browser/tab_switcher/ui_bundled/test:utils",
    "//ios/chrome/test/earl_grey:eg_test_support+eg2",
    "//ios/testing/earl_grey:eg_test_support+eg2",
    "//net:test_support",
    "//ui/base",
  ]
  frameworks = [ "UIKit.framework" ]
}

source_set("eg_app_support+eg2") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [
    "composebox_app_interface.h",
    "composebox_app_interface.mm",
  ]
  deps = [
    "//base",
    "//ios/chrome/browser/aim/model:aim_availability",
    "//ios/chrome/browser/aim/model:test_support",
    "//ios/chrome/browser/composebox/model",
    "//ios/chrome/browser/composebox/model:test_support",
    "//ios/chrome/browser/composebox/public:features",
    "//ios/chrome/browser/composebox/ui",
    "//ios/chrome/browser/composebox/ui:state",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/chrome/test/app:test_support",
    "//testing/gmock",
  ]
}

source_set("eg_test_support+eg2") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [
    "composebox_app_interface.h",
    "composebox_app_interface_stub.mm",
  ]
  deps = [ "//ios/testing/earl_grey:eg_test_support+eg2" ]
}
