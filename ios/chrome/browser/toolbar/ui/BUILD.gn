source_set("ui") {
  sources = [
    "toolbar_consumer.h",
    "toolbar_mutator.h",
    "toolbar_view_controller.h",
    "toolbar_view_controller.mm",
  ]
  deps = [
    ":constants",
    ":height_delegate",
    "//base",
    "//ios/chrome/browser/composebox/coordinator",
    "//ios/chrome/browser/fullscreen/ui_bundled:ui",
    "//ios/chrome/browser/intents/model:model_donation_helper",
    "//ios/chrome/browser/shared/public/commands",
    "//ios/chrome/browser/shared/ui/elements",
    "//ios/chrome/browser/shared/ui/util",
    "//ios/chrome/browser/shared/ui/util:util_swift",
