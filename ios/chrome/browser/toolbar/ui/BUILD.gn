    "//ios/chrome/browser/toolbar/ui/buttons",
    "//ios/chrome/common/ui/util",
    "//ui/base",
  ]
  frameworks = [ "UIKit.framework" ]
}

source_set("height_delegate") {
  sources = [ "toolbar_height_delegate.h" ]
}

source_set("constants") {
  sources = [
    "toolbar_constants.h",
    "toolbar_constants.mm",
  ]
  frameworks = [ "UIKit.framework" ]
