<translation id="1363028406613469049">ติดตาม</translation>
<translation id="1554523534964039554">แชร์รหัสผ่านกับกลุ่มครอบครัว</translation>
<translation id="2319645462410562206">Chrome สามารถตรวจหาหมายเลขติดตามพัสดุที่คุณป้อนในเว็บไซต์ และแสดงข้อมูลอัปเดตเกี่ยวกับพัสดุในหน้า "แท็บใหม่"</translation>
<translation id="2551790923936684824">ติดตามพัสดุนี้ไหม</translation>
<translation id="2734585994146185878">การจัดส่งของคุณ</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">วันพุธที่ 1 พฤษภาคม ภายในเวลา 19:00 น.</translation>
<translation id="3770157741494890119">อนุญาตให้ Chrome ติดตามพัสดุ</translation>
<translation id="5475069061743940393">การติดตามพัสดุภัณฑ์</translation>
<translation id="5777468213129569553">เปิด Chrome</translation>
<translation id="6147071803535394951">ดูข้อมูลอัปเดตเกี่ยวกับพัสดุในการ์ดบนหน้าแท็บใหม่</translation>
<translation id="6494974875566443634">การกำหนดค่าเอง</translation>
<translation id="7108338896283013870">ซ่อน</translation>
<translation id="7343651556898151354">Chrome จะช่วยคุณติดตามพัสดุนี้ในหน้าแท็บใหม่ได้</translation>
<translation id="8094734579697217987">แชร์สำเนารหัสผ่านกับกลุ่มครอบครัวได้อย่างง่ายดายและปลอดภัยในเครื่องมือจัดการรหัสผ่านบน Google</translation>
<translation id="9085041112720733880">ป้อนหมายเลขติดตามพัสดุในเว็บไซต์ไปรษณีย์หรือเว็บไซต์ช็อปปิ้ง</translation>
<translation id="9093047661118118915">วันที่จัดส่งโดยประมาณ</translation>
