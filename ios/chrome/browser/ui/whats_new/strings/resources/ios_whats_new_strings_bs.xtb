<translation id="1239866612142087073">3. Otvorite Postavke &gt; Upravitelj zaporki.</translation>
<translation id="1363028406613469049">Numera</translation>
<translation id="1554523534964039554">Dijelite zaporke sa svojom obiteljskom grupom</translation>
<translation id="1556556838855011466">1. Otvorite Chrome.</translation>
<translation id="2319645462410562206">Chrome može otkriti evidencijske brojeve koje unosite na web-lokacijama i prikazati ažuriranja paketa na stranici Nova kartica.</translation>
<translation id="2551790923936684824">Pratiti taj paket?</translation>
<translation id="2734585994146185878">Vaša otprema</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Srijeda, 1. svibnja do 19:00</translation>
<translation id="3770157741494890119">Dopustite Chromeu da prati vaše pakete.</translation>
<translation id="401853092657437412">2. Dodirnite izbornik s tri točke.</translation>
<translation id="5475069061743940393">Praćenje paketa</translation>
<translation id="6147071803535394951">Pogledajte ažuriranja paketa na karticama na stranici Nova kartica.</translation>
<translation id="6292962033060948789">Dijeljenje kopije zaporke u Google upravitelju zaporki</translation>
<translation id="6297866979658584786">4. Odaberite zaporku i dodirnite ikonu za dijeljenje.</translation>
<translation id="7343651556898151354">Chrome vam može pomoći da pratite taj paket na stranici Nova kartica.</translation>
<translation id="7425802352219229154">5. Odaberite članove obitelji s kojima želite dijeliti.</translation>
<translation id="8094734579697217987">Jednostavno i sigurno dijelite kopiju zaporke sa svojom obiteljskom grupom u Google upravitelju zaporki.</translation>
<translation id="9085041112720733880">Unesite evidencijski broj na poštansku web-lokaciju ili web-lokaciju za kupnju.</translation>
<translation id="9093047661118118915">Procijenjeni datum isporuke</translation>
</translationbundle>