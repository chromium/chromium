<!DOCTYPE translationbundle>
<translationbundle lang="de">
<translation id="1363028406613469049">Verfolgen</translation>
<translation id="1554523534964039554">Passwörter mit deiner Familiengruppe teilen</translation>
<translation id="2319645462410562206">Chrome kann Sendungsnummern erkennen, die du auf Websites eingibst, und dir auf der Seite „Neuer Tab“ aktuelle Informationen zu deinen Paketen anzeigen.</translation>
<translation id="2551790923936684824">Dieses Paket verfolgen?</translation>
<translation id="2734585994146185878">Deine Sendung</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Mittwoch, 1. Mai, bis 19:00 Uhr</translation>
<translation id="3770157741494890119">Erlaube Chrome, deine Pakete zu verfolgen.</translation>
<translation id="5475069061743940393">Paketverfolgung</translation>
<translation id="5777468213129569553">Chrome öffnen</translation>
<translation id="6147071803535394951">Rufe auf der Seite „Neuer Tab“ die Karten auf, um dir aktuelle Informationen zu deinen Paketen anzusehen.</translation>
<translation id="6494974875566443634">Anpassung</translation>
<translation id="7108338896283013870">Ausblenden</translation>
<translation id="7343651556898151354">Chrome kann dir dabei helfen, dieses Paket auf der Seite „Neuer Tab“ zu verfolgen.</translation>
<translation id="8094734579697217987">Im Google Passwortmanager kannst du Kopien deiner Passwörter einfach und sicher mit deiner Familiengruppe teilen.</translation>
<translation id="9085041112720733880">Gib deine Sendungsnummer auf der Website eines Versandunternehmens oder Händlers ein.</translation>
<translation id="9093047661118118915">Voraussichtliche Zustellung</translation>
</translationbundle>