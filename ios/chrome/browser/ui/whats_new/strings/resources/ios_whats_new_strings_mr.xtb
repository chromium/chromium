<!DOCTYPE translationbundle>
<translationbundle lang="mr">
<translation id="1703743472724191604">किंमत $१०० ते $१५०</translation>
<translation id="1741219894094057085">स्‍मार्ट वॉच</translation>
<translation id="1988591645162894496">तुम्हाला खरेदी करायची असलेली उत्पादने देऊ करणारी आणखी स्टोअर सहजपणे शोधा</translation>
<translation id="2043455190894016404">अ‍ॅड्रेस बारमध्ये, काळानुसार किमतीमधील बदल पाहण्यासाठी किंमत इतिहास आयकनवर टॅप करा</translation>
<translation id="2058876133802084300">$१५०</translation>
<translation id="2216366330550244277">उत्पादनाच्या पेजवर जा</translation>
<translation id="3266153067803506235">Chrome आयकन प्रेस करून धरून ठेवा आणि "होम स्क्रीन संपादित करा" यावर क्लिक करा</translation>
<translation id="3764562164106905124">नोव्हें</translation>
<translation id="3958312024468322930">ते तुमच्या होम स्क्रीन च्या तळाशी डॉक करा वर ड्रॅग करा</translation>
<translation id="4227258125987011664">$२००</translation>
<translation id="4607887340472970274">किमतीचा माग ठेवणे</translation>
<translation id="5119329531859909472">उत्पादन ट्रॅक करण्यासाठी, ट्रॅक करा वर टॅप करा</translation>
<translation id="5423269318075950257">किमतीचा माग ठेवा</translation>
<translation id="5910891913281809039">डिसें</translation>
<translation id="5980825544755559844">$१००</translation>
<translation id="6250648963363746140">उत्पादनांच्या किमती काळानुसार कशा बदलल्या आहेत हे पहा</translation>
<translation id="6434483369543264725">ऑक्टो</translation>
<translation id="6944020103996173879">खरेदीचे आणखी पर्याय पहा</translation>
<translation id="6998251471716094661">उत्पादनांच्या किमती ट्रॅक करा आणि कोणत्याही साइटवर किंमत कमी झाल्यावर सूचना मिळवा</translation>
<translation id="7065813315247345131">Chrome ला डॉक वर हलवा</translation>
<translation id="7097046145876891318">अ‍ॅड्रेस बारमध्ये, काळानुसार किमतीमधील बदल पाहण्यासाठी किंमत इतिहासावर टॅप करा</translation>
<translation id="7227293336683593977">किमतीचा इतिहास</translation>
<translation id="794945939108159738">$१२०</translation>
<translation id="8625706492572042370">होम स्क्रीन संपादित करा</translation>
<translation id="8871142946513037507">संपूर्ण वेबवरील इतर स्टोअर</translation>
<translation id="991428047095920989">अ‍ॅड्रेस बारमध्ये, काळानुसार किमतीमधील बदल पाहण्यासाठी किंमत इतिहास आयकनवर टॅप करा</translation>
