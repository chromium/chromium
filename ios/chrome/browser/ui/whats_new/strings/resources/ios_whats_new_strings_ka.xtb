<translation id="1239866612142087073">3. გადადით „პარამეტრებში“ &gt; „პაროლების მმართველი“</translation>
<translation id="1363028406613469049">ჩანაწერი</translation>
<translation id="1554523534964039554">გაუზიარეთ პაროლები თქვენს ოჯახის ჯგუფს</translation>
<translation id="1556556838855011466">1. გახსენით Chrome</translation>
<translation id="2319645462410562206">Chrome-ს შეუძლია თქვენ მიერ საიტზე შეყვანილი თვალის დევნების ნომრების ამოცნობა და ამანათთან დაკავშირებული განახლებების ახალი ჩანართის გვერდზე ჩვენება.</translation>
<translation id="2551790923936684824">გსურთ ამ ამანათისთვის თვალის მიდევნება?</translation>
<translation id="2734585994146185878">თქვენი გზავნილი</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">ოთხშაბათი, 1 მაისი, 19:00-მდე</translation>
<translation id="3770157741494890119">ნება დართეთ Chrome-ს, თვალი ადევნოს თქვენს ამანათებს.</translation>
<translation id="401853092657437412">2. შეეხეთ სამწერტილიან მენიუს</translation>
<translation id="5475069061743940393">ამანათებისთვის თვალის დევნება</translation>
<translation id="6147071803535394951">იხილეთ ამანათთან დაკავშირებული განახლებები ბარათებში, თქვენი ახალი ჩანართის გვერდზე.</translation>
<translation id="6292962033060948789">გააზიარეთ თქვენი პაროლის ასლი Google პაროლების მმართველში</translation>
<translation id="6297866979658584786">4. აირჩიეთ პაროლი და შეეხეთ „გაზიარების“ ხატულას</translation>
<translation id="7343651556898151354">Chrome-ს შეუძლია დაგეხმაროთ, თვალი ადევნოთ ამ ამანათს ახალი ჩანართის გვერდზე.</translation>
<translation id="7425802352219229154">5. აირჩიეთ ოჯახის წევრები, რომლებთანაც გსურთ გაზიარება</translation>
<translation id="8094734579697217987">მარტივად და დაცულად გაუზიარეთ თქვენი პაროლის ასლი ოჯახის წევრებს Google პაროლების მმართველში.</translation>
<translation id="9085041112720733880">შეიყვანეთ თვალის დევნების ნომერი ფოსტის ან სავაჭრო ვებსაიტზე.</translation>
<translation id="9093047661118118915">მიწოდების სავარაუდო დრო</translation>
