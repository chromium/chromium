<!DOCTYPE translationbundle>
<translationbundle lang="kn">
<translation id="1363028406613469049">ಟ್ರ್ಯಾಕ್</translation>
<translation id="1554523534964039554">ನಿಮ್ಮ ಕುಟುಂಬದ ಗುಂಪಿನೊಂದಿಗೆ ಪಾಸ್‌ವರ್ಡ್‌ಗಳನ್ನು ಹಂಚಿಕೊಳ್ಳಿ</translation>
<translation id="2319645462410562206">ನೀವು ಸೈಟ್‌ಗಳಲ್ಲಿ ನಮೂದಿಸುವ ಟ್ರ್ಯಾಕಿಂಗ್ ಸಂಖ್ಯೆಗಳನ್ನು Chrome ಪತ್ತೆ ಮಾಡುತ್ತದೆ ಮತ್ತು ಹೊಸ ಟ್ಯಾಬ್ ಪುಟದಲ್ಲಿ ಪ್ಯಾಕೇಜ್ ಅಪ್‌ಡೇಟ್‌ಗಳನ್ನು ತೋರಿಸುತ್ತದೆ.</translation>
<translation id="2551790923936684824">ಈ ಪ್ಯಾಕೇಜ್ ಅನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಬೇಕೆ?</translation>
<translation id="2734585994146185878">ನಿಮ್ಮ ಶಿಪ್‌ಮೆಂಟ್</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">ಬುಧವಾರ, ಮೇ 01 ರಂದು ಸಂಜೆ 7:00 ಗಂಟೆಗೆ</translation>
<translation id="3770157741494890119">ನಿಮ್ಮ ಪ್ಯಾಕೇಜ್‌ಗಳನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಲು Chrome ಗೆ ಅನುಮತಿಸಿ.</translation>
<translation id="5475069061743940393">ಪ್ಯಾಕೇಜ್ ಟ್ರಾಕಿಂಗ್</translation>
<translation id="5777468213129569553">Chrome ತೆರೆಯಿರಿ</translation>
<translation id="6147071803535394951">ನಿಮ್ಮ ಹೊಸ ಟ್ಯಾಬ್ ಪುಟದಲ್ಲಿರುವ ಕಾರ್ಡ್‌ಗಳಲ್ಲಿ ಪ್ಯಾಕೇಜ್ ಅಪ್‌ಡೇಟ್‌ಗಳನ್ನು ನೋಡಿ.</translation>
<translation id="6494974875566443634">ಕಸ್ಟಮೈಸ್ ಮಾಡುವಿಕೆ</translation>
<translation id="7108338896283013870">ಮರೆಮಾಡಿ</translation>
<translation id="7343651556898151354">ಹೊಸ ಟ್ಯಾಬ್ ಪುಟದಲ್ಲಿ ಈ ಪ್ಯಾಕೇಜ್ ಅನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಲು Chrome ನಿಮಗೆ ಸಹಾಯ ಮಾಡುತ್ತದೆ.</translation>
<translation id="8094734579697217987">Google Password Manager ನಲ್ಲಿ ನಿಮ್ಮ ಕುಟುಂಬದ ಗುಂಪಿನೊಂದಿಗೆ ಪಾಸ್‌ವರ್ಡ್‌ನ ಕಾಪಿಯನ್ನು ಸುಲಭವಾಗಿ ಮತ್ತು ಸುರಕ್ಷಿತವಾಗಿ ಹಂಚಿಕೊಳ್ಳಿ.</translation>
<translation id="9085041112720733880">ಪೋಸ್ಟಲ್ ಅಥವಾ ಶಾಪಿಂಗ್ ವೆಬ್‌ಸೈಟ್‌ನಲ್ಲಿ ನಿಮ್ಮ ಟ್ರ್ಯಾಕಿಂಗ್ ಸಂಖ್ಯೆಯನ್ನು ನಮೂದಿಸಿ.</translation>
<translation id="9093047661118118915">ಅಂದಾಜು ಡೆಲಿವರಿ ದಿನಾಂಕ</translation>
</translationbundle>