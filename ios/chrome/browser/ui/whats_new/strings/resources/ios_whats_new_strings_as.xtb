<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="as">
<translation id="1239866612142087073">৩) “ছেটিং” &gt; “Password Manager”লৈ যাওক</translation>
<translation id="1363028406613469049">ট্ৰেক</translation>
<translation id="1554523534964039554">আপোনাৰ পৰিয়ালৰ গোটৰ সৈতে পাছৱৰ্ড শ্বেয়াৰ কৰক</translation>
<translation id="1556556838855011466">১) Chrome খোলক</translation>
<translation id="2319645462410562206">Chromeএ আপুনি ছাইটত দিয়া ট্ৰেকিং নম্বৰসমূহ চিনাক্ত কৰিব পাৰে আৰু নতুন টেবৰ পৃষ্ঠাত পেকেজৰ আপডে’ট দেখুৱাব পাৰে।</translation>
<translation id="2551790923936684824">এই পেকেজটো ট্ৰেক কৰিবনে?</translation>
<translation id="2734585994146185878">আপোনাৰ শ্বিপমেণ্ট</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">বুধবাৰ, ১ মে’ৰ সন্ধিয়া ৭:০০ বজাৰ ভিতৰত</translation>
<translation id="3770157741494890119">Chromeক আপোনাৰ পেকেজ ট্ৰেক কৰিবলৈ দিয়ক।</translation>
<translation id="401853092657437412">২) তিনিটা বিন্দুৰ মেনুখনত টিপক</translation>
<translation id="5475069061743940393">পেকেজ ট্ৰেকিং</translation>
<translation id="6147071803535394951">আপোনাৰ নতুন টেবৰ পৃষ্ঠাত থকা কাৰ্ডত পেকেজ সম্পৰ্কীয় আপডে’টসমূহ চাওক।</translation>
<translation id="6292962033060948789">Google Password Managerত এটা পাছৱৰ্ডৰ এটা প্ৰতিলিপি শ্বেয়াৰ কৰক</translation>
<translation id="6297866979658584786">৪) এটা পাছৱৰ্ড বাছনি কৰক আৰু “শ্বেয়াৰ কৰক” চিহ্নটোত টিপক</translation>
<translation id="7343651556898151354">Chromeএ আপোনাক এই পেকেজটো নতুন টেবৰ পৃষ্ঠাখনত ট্ৰেক কৰাত সহায় কৰিব পাৰে।</translation>
<translation id="7425802352219229154">৫) শ্বেয়াৰ কৰিবলৈ পৰিয়ালৰ সদস্য বাছনি কৰক</translation>
<translation id="8094734579697217987">Google Password Managerত আপোনাৰ পৰিয়ালৰ গোটৰ সৈতে সহজে আৰু সুৰক্ষিতভাৱে এটা পাছৱৰ্ডৰ এটা প্ৰতিলিপি শ্বেয়াৰ কৰক।</translation>
<translation id="9085041112720733880">কোনো প’ষ্টেল বা শ্বপিং ৱেবছাইটত আপোনাৰ ট্ৰেকিং নম্বৰটো দিয়ক।</translation>
<translation id="9093047661118118915">ডেলিভাৰীৰ আনুমানিক সময়</translation>
</translationbundle>