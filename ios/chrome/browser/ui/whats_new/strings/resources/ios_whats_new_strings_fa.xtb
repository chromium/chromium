<translation id="1239866612142087073">۳. به «تنظیمات» &gt; «مدیر گذرواژه» بروید</translation>
<translation id="1363028406613469049">تراک</translation>
<translation id="1554523534964039554">هم‌رسانی گذرواژه‌ها با گروه خانواده</translation>
<translation id="1556556838855011466">‏۱. ‫Chrome را باز کنید</translation>
<translation id="2319645462410562206">‏Chrome می‌تواند شماره‌های پیگیری را که در سایت‌ها وارد می‌کنید شناسایی کند و به‌روزرسانی‌های بسته را در «صفحه برگه جدید» نشان دهد.</translation>
<translation id="2551790923936684824">این بسته پیگیری شود؟</translation>
<translation id="2734585994146185878">مرسوله شما</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">چهارشنبه، ۰۱ مه تا ساعت ۷:۰۰ ب.ظ.</translation>
<translation id="3770157741494890119">‏به Chrome اجازه دهید بسته‌ها را ردیابی کند.</translation>
<translation id="401853092657437412">۲. روی منوِ سه‌نقطه‌ای تک‌ضرب بزنید</translation>
<translation id="5475069061743940393">پیگیری بسته پستی</translation>
<translation id="6147071803535394951">به‌روزرسانی‌های بسته را در «کارت‌ها» در «صفحه برگه جدید» ببینید.</translation>
<translation id="6292962033060948789">‏هم‌رسانی نسخه‌ای از گذرواژه در «مدیر گذرواژه Google»</translation>
<translation id="6297866979658584786">۴. گذرواژه‌ای را انتخاب کنید و روی نماد «هم‌رسانی» تک‌ضرب بزنید</translation>
<translation id="7343651556898151354">‏‫Chrome می‌تواند به شما کمک کند این بسته را در صفحه «برگه جدید» ردیابی کنید.</translation>
<translation id="7425802352219229154">۵. برای هم‌رسانی، اعضای خانواده را انتخاب کنید</translation>
<translation id="8094734579697217987">‏به‌راحتی و با ایمنی نسخه‌ای از گذرواژه را در «مدیر گذرواژه Google» با گروه خانواده‌تان هم‌رسانی کنید.</translation>
<translation id="9085041112720733880">شماره پیگیری را در وب‌سایت پست یا فروشنده وارد کنید.</translation>
<translation id="9093047661118118915">زمان تخمینی تحویل</translation>
