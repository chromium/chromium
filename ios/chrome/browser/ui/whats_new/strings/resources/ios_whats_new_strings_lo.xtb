<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="lo">
<translation id="1239866612142087073">3. ເຂົ້າໄປ “ການຕັ້ງຄ່າ” &gt; “ຕົວຈັດການລະຫັດຜ່ານ”</translation>
<translation id="1363028406613469049">ແທຣັກ</translation>
<translation id="1554523534964039554">ແບ່ງປັນລະຫັດຜ່ານກັບກຸ່ມຄອບຄົວຂອງທ່ານ</translation>
<translation id="1556556838855011466">1. ເປີດ Chrome</translation>
<translation id="2319645462410562206">Chrome ສາມາດກວດຫາໝາຍເລກຕິດຕາມທີ່ທ່ານລະບຸໃນເວັບໄຊ ແລະ ສະແດງຂໍ້ມູນອັບເດດກ່ຽວກັບພັດສະດຸໃນໜ້າແຖບໃໝ່ໄດ້.</translation>
<translation id="2551790923936684824">ຕິດຕາມພັດສະດຸນີ້ບໍ?</translation>
<translation id="2734585994146185878">ການຈັດສົ່ງຂອງທ່ານ</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">ວັນພຸດທີ 1 ພຶດສະພາ, ພາຍໃນເວລາ 19:00 ໂມງ.</translation>
<translation id="3770157741494890119">ອະນຸຍາດໃຫ້ Chrome ຕິດຕາມພັດສະດຸຂອງທ່ານ.</translation>
<translation id="401853092657437412">2. ແຕະເມນູສາມຈ້ຳ</translation>
<translation id="5475069061743940393">ການຕິດຕາມພັດສະດຸ</translation>
<translation id="6147071803535394951">ເບິ່ງຂໍ້ມູນອັບເດດກ່ຽວກັບພັດສະດຸໃນບັດຢູ່ໜ້າແຖບໃໝ່ຂອງທ່ານ.</translation>
<translation id="6292962033060948789">ແບ່ງປັນສຳເນົາລະຫັດຜ່ານໃນຕົວຈັດການລະຫັດຜ່ານ Google</translation>
<translation id="6297866979658584786">4. ເລືອກລະຫັດຜ່ານແລ້ວແຕະໄອຄອນ “ແບ່ງປັນ”</translation>
<translation id="7343651556898151354">Chrome ສາມາດຊ່ວຍທ່ານຕິດຕາມພັດສະດຸນີ້ໃນໜ້າແຖບໃໝ່ໄດ້.</translation>
<translation id="7425802352219229154">5. ເລືອກສະມາຊິກຄອບຄົວທີ່ຈະແບ່ງປັນນຳ</translation>
<translation id="8094734579697217987">ແບ່ງປັນສຳເນົາລະຫັດຜ່ານກັບກຸ່ມຄອບຄົວຂອງທ່ານໄດ້ຢ່າງງ່າຍດາຍ ແລະ ປອດໄພໃນຕົວຈັດການລະຫັດຜ່ານ Google.</translation>
<translation id="9085041112720733880">ໃສ່ໝາຍເລກຕິດຕາມຂອງທ່ານໃນເວັບໄຊໄປສະນີ ຫຼື ເວັບໄຊຊື້ເຄື່ອງ.</translation>
<translation id="9093047661118118915">ວັນທີຈັດສົ່ງໂດຍປະມານ</translation>
</translationbundle>