<!DOCTYPE translationbundle>
<translationbundle lang="sl">
<translation id="1363028406613469049">Posnetek</translation>
<translation id="1554523534964039554">Deljenje gesel s skupino družinskih članov</translation>
<translation id="2319645462410562206">Chrome lahko zazna številke za sledenje, ki jih vnesete na spletnih mestih, in prikaže obvestila o paketu na novem zavihku s povezavami.</translation>
<translation id="2551790923936684824">Želite slediti temu paketu?</translation>
<translation id="2734585994146185878">Vaša pošiljka</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Sreda, 1. maj do 19.00.</translation>
<translation id="3770157741494890119">Dovolite Chromu, da sledi paketom.</translation>
<translation id="5475069061743940393">Sledenje paketu</translation>
<translation id="5777468213129569553">Odpri Chrome</translation>
<translation id="6147071803535394951">Oglejte si obvestila o paketu na karticah na novem zavihku s povezavami.</translation>
<translation id="6494974875566443634">Prilagajanje</translation>
<translation id="7108338896283013870">Skrij</translation>
<translation id="7343651556898151354">Chrome vam lahko pomaga slediti temu paketu na novem zavihku s povezavami.</translation>
<translation id="8094734579697217987">Preprosto in varno delite kopijo gesla s skupino družinskih članov v Googlovem upravitelju gesel.</translation>
<translation id="9085041112720733880">Vnesite številko za sledenje na spletnem mestu pošte ali spletnem mestu za nakupovanje.</translation>
<translation id="9093047661118118915">Predvidena dostava</translation>
</translationbundle>