<translation id="1239866612142087073">3. Opnaðu „Stillingar &gt; Aðgangsorðastjórnun“</translation>
<translation id="1363028406613469049">Rekja</translation>
<translation id="1554523534964039554">Deildu aðgangsorðum með fjölskylduhópnum þínum</translation>
<translation id="1556556838855011466">1. Opnaðu Chrome</translation>
<translation id="2319645462410562206">Chrome getur greint rakningarnúmer sem þú slærð inn á vefsvæðum og birt tilkynningar sem tengjast pakkanum á síðu nýrra flipa.</translation>
<translation id="2551790923936684824">Rekja þennan pakka?</translation>
<translation id="2734585994146185878">Sendingin þín</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Miðvikudagur 1. maí fyrir kl. 19:00</translation>
<translation id="3770157741494890119">Leyfðu Chrome að rekja pakkana þína.</translation>
<translation id="401853092657437412">2. Ýttu á þriggja punkta valmyndina</translation>
<translation id="5475069061743940393">Pakkarakning</translation>
<translation id="6147071803535394951">Tilkynningar sem tengjast pakkanum birtast á spjöldunum á síðu nýrra flipa.</translation>
<translation id="6292962033060948789">Deildu afriti af aðgangsorðinu þínu í Google-aðgangsorðastjórnun</translation>
<translation id="6297866979658584786">4. Veldu aðgangsorð og ýttu á táknið „Deila“</translation>
<translation id="7343651556898151354">Chrome getur hjálpað þér að rekja þennan pakka á síðu nýrra flipa.</translation>
<translation id="7425802352219229154">5. Veldu fjölskyldumeðlimi sem þú vilt deila með</translation>
<translation id="8094734579697217987">Þú getur deilt afriti af aðgangsorðinu þínu með fjölskylduhópnum þínum á einfaldan og öruggan hátt í Google-aðgangsorðastjórnun.</translation>
<translation id="9085041112720733880">Sláðu rakningarnúmerið inn á vefsvæði póstþjónustu eða verslunar.</translation>
<translation id="9093047661118118915">Áætlaður afhendingartími</translation>
</translationbundle>