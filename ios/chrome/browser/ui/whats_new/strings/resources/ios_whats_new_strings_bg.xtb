<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="bg">
<translation id="1239866612142087073">3. Отворете „Настройки &gt; Мениджър на пароли“.</translation>
<translation id="1363028406613469049">Запис</translation>
<translation id="1554523534964039554">Споделяйте пароли със семейната си група</translation>
<translation id="1556556838855011466">1. Отворете Chrome.</translation>
<translation id="2319645462410562206">Chrome може да открива проследяващите номера, които въвеждате на сайтовете, и да показва актуализации за съответните пратки в новия раздел в браузъра.</translation>
<translation id="2551790923936684824">Искате ли да проследявате тази пратка?</translation>
<translation id="2734585994146185878">Вашата доставка</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Сряда, 1 май, до 19:00 ч.</translation>
<translation id="3770157741494890119">Разрешете на Chrome да проследява пратките ви.</translation>
<translation id="401853092657437412">2. Докоснете менюто с три точки.</translation>
<translation id="5475069061743940393">Проследяване на пратки</translation>
<translation id="6147071803535394951">Преглеждайте актуализации за пратки в картите в новия раздел в браузъра.</translation>
<translation id="6292962033060948789">Споделяне на копие на парола в Google Мениджър на пароли</translation>
<translation id="6297866979658584786">4. Изберете парола и докоснете иконата за споделяне.</translation>
<translation id="7343651556898151354">Chrome може да ви помогне да проследявате тази пратка в нов раздел.</translation>
<translation id="7425802352219229154">5. Изберете членовете на семейството, с които да се сподели.</translation>
<translation id="8094734579697217987">Лесно и сигурно споделяйте копие на дадена парола със семейната си група в Google Мениджър на пароли.</translation>
<translation id="9085041112720733880">Въведете проследяващия си номер на пощенски уебсайт или уебсайт за пазаруване.</translation>
<translation id="9093047661118118915">Очаквано време на доставка</translation>
</translationbundle>