<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="am">
<translation id="1363028406613469049">ትራክ</translation>
<translation id="1546129703935983118">የChrome ምናሌዎን በማበጀት Chrome እርስዎ ከሚያሰሱበት መንገድ ጋር እንዲስማማ ያድርጉ።</translation>
<translation id="1554523534964039554">የይለፍ ቃላትን ለቤተሰብ ቡድንዎ ያጋሩ</translation>
<translation id="2319645462410562206">Chrome በጣቢያዎች ላይ እርስዎ የሚያስገቧቸውን የመከታተያ ቁጥሮች ማወቅ እና የጥቅል ዝማኔዎችን በአዲሱ የትር ገፅ ላይ ማሳየት ይችላል።</translation>
<translation id="2551790923936684824">ይህ ጥቅል ክትትል ይደረግበት?</translation>
<translation id="3067067035910355531">የይለፍ ቃል ይምረጡ እና «አጋራ» የሚለውን አዶ መታ ያድርጉ</translation>
<translation id="3770157741494890119">Chrome የእርስዎን ጥቅሎች እንዲከታተል ይፍቀዱ።</translation>
<translation id="4047337302138771011">የእርስዎን የይለፍ ቃላት ያጋሩ</translation>
<translation id="4093156958486416052">የእርስዎ ጭነት</translation>
<translation id="4874629658972056851">የእርስዎ የChrome ምናሌ ይምረጡ</translation>
<translation id="4989753829760610266">ማየት የማይፈልጓቸውን ማናቸውም ንጥሎች ይደብቁ።</translation>
<translation id="5475069061743940393">የጥቅል መከታተያ</translation>
<translation id="5777468213129569553">Chromeን ክፈት</translation>
<translation id="5985054498852397330">ምናሌዎን ያብጁ</translation>
<translation id="6147071803535394951">በአዲሱ የትር ገፅዎ ላይ በካርዶቹ ውስጥ የጥቅል ዝማኔዎችን ይመልከቱ።</translation>
<translation id="6527303717912515753">አጋራ</translation>
<translation id="6780178366025947966">ወደ «የሚስጥር ቁልፍ አስተዳዳሪ» ይሂዱ</translation>
<translation id="7108338896283013870">ደብቅ</translation>
<translation id="7180865173735832675">አብጅ</translation>
<translation id="8094734579697217987">በGoogle የይለፍ ቃል አስተዳዳሪ ውስጥ በቀላሉ እና ደህንነቱ በተጠበቀ መልኩ የይለፍ ቃል ቅጂ ለቤተሰብ ቡድንዎ ያጋሩ።</translation>
<translation id="8105002292464261990">«ምናሌ አብጅ» ላይ መታ ያድርጉ</translation>
<translation id="8348530355586151720">ባለ ሦስት ነጥብ ምናሌውን መታ ያድርጉ</translation>
<translation id="8856329583773053724">የሚያጋሯቸውን የቤተሰብ አባላት ይምረጡ</translation>
<translation id="9085041112720733880">የመከታተያ ቁጥርዎን በፖስታ ወይም በግዢ ድር ጣቢያ ላይ ያስገቡ።</translation>
<translation id="9093047661118118915">የሚገመተው ማድረሻ ጊዜ</translation>
<translation id="9181396888106868838">ማንኛውንም የምናሌ ንጥል በረዥሙ ይጫኑ</translation>
</translationbundle>