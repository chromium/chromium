<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="pa">
<translation id="1239866612142087073">3. “ਸੈਟਿੰਗਾਂ” &gt; “Password Manager” 'ਤੇ ਜਾਓ</translation>
<translation id="1363028406613469049">ਟਰੈਕ</translation>
<translation id="1554523534964039554">ਆਪਣੇ ਪਰਿਵਾਰ ਗਰੁੱਪ ਨਾਲ ਪਾਸਵਰਡ ਸਾਂਝੇ ਕਰੋ</translation>
<translation id="1556556838855011466">1. Chrome ਖੋਲ੍ਹੋ</translation>
<translation id="2319645462410562206">Chrome ਤੁਹਾਡੇ ਵੱਲੋਂ ਦਾਖਲ ਕੀਤੇ ਟਰੈਕਿੰਗ ਨੰਬਰਾਂ ਦਾ ਪਤਾ ਲਗਾ ਸਕਦਾ ਹੈ ਅਤੇ ਨਵੇਂ ਟੈਬ ਪੰਨੇ 'ਤੇ ਪੈਕੇਜ ਸੰਬੰਧੀ ਅੱਪਡੇਟਾਂ ਨੂੰ ਦਿਖਾ ਸਕਦਾ ਹੈ।</translation>
<translation id="2551790923936684824">ਕੀ ਇਸ ਪੈਕੇਜ ਨੂੰ ਟਰੈਕ ਕਰਨਾ ਹੈ?</translation>
<translation id="2734585994146185878">ਤੁਹਾਡੀ ਸ਼ਿਪਮੈਂਟ</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">ਬੁੱਧਵਾਰ, 01 ਮਈ ਨੂੰ ਸ਼ਾਮ 7:00 ਵਜੇ ਤੱਕ</translation>
<translation id="3770157741494890119">Chrome ਨੂੰ ਤੁਹਾਡੇ ਪੈਕੇਜ ਟਰੈਕ ਕਰਨ ਦਿਓ।</translation>
<translation id="401853092657437412">2. ਤਿੰਨ-ਬਿੰਦੂਆਂ ਵਾਲੇ ਮੀਨੂ 'ਤੇ ਟੈਪ ਕਰੋ</translation>
<translation id="5475069061743940393">ਪੈਕੇਜ ਟਰੈਕਿੰਗ</translation>
<translation id="6147071803535394951">ਆਪਣੇ ਨਵੇਂ ਟੈਬ ਪੰਨੇ 'ਤੇ ਕਾਰਡਾਂ ਵਿੱਚ ਦਿੱਤੇ ਪੈਕੇਜ ਸੰਬੰਧੀ ਅੱਪਡੇਟਾਂ ਨੂੰ ਦੇਖੋ।</translation>
<translation id="6292962033060948789">Google Password Manager ਵਿੱਚ ਪਾਸਵਰਡ ਦੀ ਕਾਪੀ ਨੂੰ ਸਾਂਝਾ ਕਰੋ</translation>
<translation id="6297866979658584786">4. ਕੋਈ ਪਾਸਵਰਡ ਚੁਣੋ ਅਤੇ “ਸਾਂਝਾ ਕਰੋ” ਪ੍ਰਤੀਕ 'ਤੇ ਟੈਪ ਕਰੋ</translation>
<translation id="7343651556898151354">Chrome ਨਵੇਂ ਟੈਬ ਪੰਨੇ 'ਤੇ ਇਸ ਪੈਕੇਜ ਨੂੰ ਟਰੈਕ ਕਰਨ ਵਿੱਚ ਤੁਹਾਡੀ ਮਦਦ ਕਰ ਸਕਦਾ ਹੈ।</translation>
<translation id="7425802352219229154">5. ਉਨ੍ਹਾਂ ਪਰਿਵਾਰਕ ਮੈਂਬਰਾਂ ਨੂੰ ਚੁਣੋ ਜਿਨ੍ਹਾਂ ਨਾਲ ਸਾਂਝਾ ਕਰਨਾ ਹੈ</translation>
<translation id="8094734579697217987">Google Password Manager ਵਿੱਚ ਆਪਣੇ ਪਰਿਵਾਰ ਗਰੁੱਪ ਨਾਲ ਪਾਸਵਰਡ ਦੀ ਕਾਪੀ ਨੂੰ ਆਸਾਨੀ ਅਤੇ ਸੁਰੱਖਿਅਤ ਢੰਗ ਨਾਲ ਸਾਂਝਾ ਕਰੋ।</translation>
<translation id="9085041112720733880">ਡਾਕ ਜਾਂ ਖਰੀਦਦਾਰੀ ਵੈੱਬਸਾਈਟ 'ਤੇ ਆਪਣਾ ਟਰੈਕਿੰਗ ਨੰਬਰ ਦਾਖਲ ਕਰੋ।</translation>
<translation id="9093047661118118915">ਅੰਦਾਜ਼ਨ ਡਿਲੀਵਰੀ</translation>
</translationbundle>