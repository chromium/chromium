<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="te">
<translation id="3266153067803506235">Chrome చిహ్నాన్ని నొక్కి, పట్టుకొని, “మొదటి స్క్రీన్‌ను ఎడిట్ చేయండి” అనే ఆప్షన్‌ను క్లిక్ చేయండి</translation>
<translation id="3958312024468322930">దీన్ని మీ మొదటి స్క్రీన్ దిగువున ఉన్న డాక్‌కు లాగండి</translation>
<translation id="4607887340472970274">ధర ట్రాకింగ్</translation>
<translation id="5423269318075950257">ధరను ట్రాక్ చేయండి</translation>
<translation id="5858597710560817319">Chromeను మీ iPhone మొదటి స్క్రీన్ డాక్‌కు తరలించి, దాన్ని వేగంగా యాక్సెస్ చేయండి.</translation>
<translation id="7065813315247345131">Chromeను డాక్‌కు తరలించండి</translation>
<translation id="7227293336683593977">ధర హిస్టరీ</translation>
<translation id="8625706492572042370">మొదటి స్క్రీన్‌ను ఎడిట్ చేయండి</translation>
</translationbundle>