<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="te">
<translation id="1363028406613469049">ట్రాక్ చేయండి</translation>
<translation id="1554523534964039554">మీ ఫ్యామిలీ గ్రూప్‌తో పాస్‌వర్డ్‌లను షేర్ చేయండి</translation>
<translation id="2319645462410562206">మీరు సైట్‌లలో ఎంటర్ చేసే ట్రాకింగ్ నంబర్‌లను Chrome గుర్తించగలదు, కొత్త ట్యాబ్ పేజీలో ప్యాకేజీ నఅప్‌డేట్‌లను చూపగలదు.</translation>
<translation id="2551790923936684824">ఈ ప్యాకేజీని ట్రాక్ చేయాలా?</translation>
<translation id="2734585994146185878">మీ షిప్‌మెంట్</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">బుధవారం, మే 01 సాయంత్రం 7:00 గంటల లోపు.</translation>
<translation id="3770157741494890119">మీ ప్యాకేజీలను ట్రాక్ చేయడానికి Chromeను అనుమతించండి.</translation>
<translation id="5475069061743940393">ప్యాకేజీ ట్రాకింగ్</translation>
<translation id="5777468213129569553">Chromeని తెరవండి</translation>
<translation id="6147071803535394951">మీ కొత్త ట్యాబ్ పేజీలోని కార్డ్‌లలో ప్యాకేజీ అప్‌డేట్‌లను చూడండి.</translation>
<translation id="6494974875566443634">అనుకూలీకరణ</translation>
<translation id="7108338896283013870">దాచిపెట్టు</translation>
<translation id="7343651556898151354">కొత్త ట్యాబ్ పేజీలో ఈ ప్యాకేజీని ట్రాక్ చేయడంలో Chrome మీకు సహాయం చేయవచ్చు.</translation>
<translation id="8094734579697217987">Google Password Managerలో మీ ఫ్యామిలీ గ్రూప్‌తో పాస్‌వర్డ్ కాపీని సులభంగా, సురక్షితంగా షేర్ చేయండి.</translation>
<translation id="9085041112720733880">పోస్టల్ లేదా షాపింగ్ వెబ్‌సైట్‌లో మీ ట్రాకింగ్ నంబర్‌ను ఎంటర్ చేయండి.</translation>
<translation id="9093047661118118915">అంచనా వేసిన డెలివరీ సమయం</translation>
</translationbundle>