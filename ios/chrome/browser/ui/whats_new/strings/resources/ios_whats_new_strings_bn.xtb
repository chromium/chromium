<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="bn">
<translation id="1363028406613469049">ট্র্যাক</translation>
<translation id="1554523534964039554">আপনার ফ্যামিলি গ্রুপের সাথে পাসওয়ার্ড শেয়ার করুন</translation>
<translation id="2319645462410562206">Chrome, সাইটে আপনার লেখা ট্র্যাকিং নম্বর শনাক্ত করতে এবং 'নতুন ট্যাব' পৃষ্ঠায় প্যাকেজ সম্পর্কিত আপডেট দেখাতে পারে।</translation>
<translation id="2551790923936684824">এই প্যাকেজ ট্র্যাক করবেন?</translation>
<translation id="2734585994146185878">আপনার শিপমেন্ট</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">বুধবার, ১ মে সন্ধে ৭টার মধ্যে।</translation>
<translation id="3770157741494890119">আপনার প্যাকেজ ট্র্যাক করার জন্য Chrome-কে অনুমতি দিন।</translation>
<translation id="5475069061743940393">প্যাকেজ ট্র্যাকিং</translation>
<translation id="5777468213129569553">Chrome খুলুন</translation>
<translation id="6147071803535394951">আপনার 'নতুন ট্যাব' পৃষ্ঠায় থাকা কার্ডে প্যাকেজ সম্পর্কিত আপডেট দেখুন।</translation>
<translation id="6494974875566443634">কাস্টোমাইজ করা</translation>
<translation id="7108338896283013870">লুকান</translation>
<translation id="7343651556898151354">'নতুন ট্যাব' পৃষ্ঠায় এই প্যাকেজটি ট্র্যাক করার ক্ষেত্রে Chrome আপনাকে সাহায্য করতে পারে।</translation>
<translation id="8094734579697217987">Google Password Manager-এ আপনার ফ্যামিলি গ্রুপের সাথে সুরক্ষিত ভাবে ও সহজে পাসওয়ার্ডের কপি শেয়ার করুন।</translation>
<translation id="9085041112720733880">কোনও পোস্টাল বা শপিং ওয়েবসাইটে আপনার ট্র্যাকিং নম্বর লিখুন।</translation>
<translation id="9093047661118118915">ডেলিভারির আনুমানিক সময়</translation>
</translationbundle>