<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="sq">
<translation id="1363028406613469049">Pjesa muzikore</translation>
<translation id="1554523534964039554">Ndaj fjalëkalimet me grupin tënd të familjes</translation>
<translation id="2319645462410562206">Chrome mund të zbulojë numrat e gjurmimit që ti fut në sajte dhe mund të shfaqë përditësime për pakot në faqen e skedës së re.</translation>
<translation id="2551790923936684824">Të gjurmohet kjo pako?</translation>
<translation id="2734585994146185878">Dërgesa jote</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">E mërkurë, 1 maj, në orën 19:00</translation>
<translation id="3770157741494890119">Lejo Chrome që të gjurmojë pakot e tua.</translation>
<translation id="5475069061743940393">Gjurmimi i pakos</translation>
<translation id="5777468213129569553">Hap Chrome</translation>
<translation id="6147071803535394951">Shiko përditësimet e pakove te "Kartat" në faqen e skedës së re.</translation>
<translation id="6494974875566443634">Personalizimi</translation>
<translation id="7108338896283013870">Fshih</translation>
<translation id="7343651556898151354">Chrome mund të të ndihmojë ta gjurmosh këtë pako në faqen e skedës së re.</translation>
<translation id="8094734579697217987">Ndaj me lehtësi dhe siguri një kopje të një fjalëkalimi me grupin tënd të familjes te "Menaxheri i fjalëkalimeve i Google".</translation>
<translation id="9085041112720733880">Fut numrin tënd të gjurmimit në një uebsajt blerjesh ose postar.</translation>
<translation id="9093047661118118915">Dërgesa e parashikuar</translation>
</translationbundle>