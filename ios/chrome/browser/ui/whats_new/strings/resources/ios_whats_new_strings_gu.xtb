<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="gu">
<translation id="3266153067803506235">Chrome આઇકન દબાવી રાખો અને "હોમ સ્ક્રીનમાં ફેરફાર કરો" પર ક્લિક કરો</translation>
<translation id="3958312024468322930">તમારી હોમ સ્ક્રીનની એકદમ નીચે તેને ડૉક પર ખેંચો</translation>
<translation id="4607887340472970274">કિંમત ટ્રૅક કરવી</translation>
<translation id="5423269318075950257">કિંમત ટ્રૅક કરો</translation>
<translation id="5858597710560817319">Chromeને તમારા iPhoneના હોમ સ્ક્રીન પર આવેલા ડૉકમાં ખસેડો અને તેને ઝટપટ ઍક્સેસ કરો.</translation>
<translation id="7065813315247345131">Chromeને ડૉકમાં ખસેડો</translation>
<translation id="7227293336683593977">કિંમતનો ઇતિહાસ</translation>
<translation id="8625706492572042370">હોમ સ્ક્રીનમાં ફેરફાર કરો</translation>
</translationbundle>