<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1363028406613469049">бһҹбҹҶбһЎбҹҒбһ„</translation>
<translation id="1546129703935983118">бһҸбһҳбҹ’бһҡбһјбһң Chrome бһҸбһ¶бһҳбһҡбһ”бҹҖбһ”вҖӢбһҠбҹӮбһӣбһўбҹ’бһ“бһҖвҖӢбһҡбһ»бһҖбһҡбһҖвҖӢбһҠбҹ„бһҷбһ”бҹ’бһҠбһјбһҡвҖӢбһҳбҹүбһәбһ“бһ»бһҷ Chrome бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһҸбһ¶бһҳбһ”бҹҶбһҺбһ„бҹ”</translation>
<translation id="1554523534964039554">бһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖвҖӢбһ–бһ¶бһҖбҹ’бһҷвҖӢбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҮбһ¶бһҳбһҪбһҷвҖӢбһҖбҹ’бһҡбһ»бһҳвҖӢбһӮбҹ’бһҡбһҪбһҹбһ¶бһҡвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ</translation>
<translation id="2319645462410562206">Chrome бһўбһ¶бһ…вҖӢбһҡбһҖбһғбһҫбһүвҖӢбһӣбҹҒбһҒвҖӢбһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҠбҹӮбһӣбһўбҹ’бһ“бһҖвҖӢбһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ“бҹ…бһӣбһҫвҖӢбһӮбҹҒбһ бһ‘бҹҶбһ–бҹҗбһҡ бһ“бһ·бһ„вҖӢбһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҗбҹ’бһҳбһёбҹ—вҖӢбһўбҹҶбһ–бһёвҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһ“бҹ…бһӣбһҫвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҗбҹ’бһҳбһёбһ”бһ¶бһ“бҹ”</translation>
<translation id="2551790923936684824">бһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҖбһүбҹ’бһ…бһ”бҹӢбһ“бҹҒбҹҮвҖӢбһ¬?</translation>
<translation id="3067067035910355531">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹвҖӢбһ–бһ¶бһҖбҹ’бһҷвҖӢбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢ бһҡбһҪбһ…бһ…бһ»бһ…вҖӢбһҡбһјбһ”бһҸбҹҶбһҺбһ¶бһ„ вҖңбһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖвҖқ</translation>
<translation id="3770157741494890119">бһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸбһұбҹ’бһҷ Chrome бһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</translation>
<translation id="4047337302138771011">бһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖбһ–бһ¶бһҖбҹ’бһҷвҖӢбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ</translation>
<translation id="4874629658972056851">бһ”бһҫбһҖвҖӢбһҳбҹүбһәбһ“бһ»бһҷ Chrome бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ</translation>
<translation id="4989753829760610266">бһӣбһ¶бһҖбҹӢвҖӢбһ’бһ¶бһҸбһ»вҖӢбһҠбҹӮбһӣбһўбҹ’бһ“бһҖвҖӢбһҳбһ·бһ“бһ…бһ„бҹӢвҖӢбһғбһҫбһүбҹ”</translation>
<translation id="5475069061743940393">бһҖбһ¶бһҡбһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҖбһүбҹ’бһ…бһ”бҹӢ</translation>
<translation id="5777468213129569553">бһ”бһҫбһҖ Chrome</translation>
<translation id="5985054498852397330">бһ”бҹ’бһҠбһјбһҡвҖӢбһҳбҹүбһәбһ“бһ»бһҷвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһҸбһ¶бһҳбһ”бҹҶбһҺбһ„</translation>
<translation id="6147071803535394951">бһҳбһҫбһӣбһғбһҫбһүвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҗбҹ’бһҳбһёбҹ—вҖӢбһўбҹҶбһ–бһёвҖӢбһҖбһүбҹ’бһ…бһ”бҹӢвҖӢбһ“бҹ…бһҖбҹ’бһ“бһ»бһ„вҖӢбһҖбһ¶бһҸвҖӢбһ“бҹ…бһӣбһҫвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҗбҹ’бһҳбһёвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</translation>
<translation id="6527303717912515753">бһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖ</translation>
<translation id="6780178366025947966">бһ…бһјбһӣвҖӢбһ‘бҹ…бһҖбһ¶бһ“бҹӢ вҖңбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„вҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖқ</translation>
<translation id="7108338896283013870">бһӣбһ¶бһҖбҹӢ</translation>
<translation id="7180865173735832675">бһҖбҹӮбһҹбһҳбҹ’бһҡбһҪбһӣ</translation>
<translation id="8094734579697217987">бһ„бһ¶бһҷбһҹбҹ’бһҡбһҪбһӣвҖӢбһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖвҖӢбһ…бҹ’бһ”бһ¶бһ”бҹӢбһ…бһҳбҹ’бһӣбһ„вҖӢбһ–бһ¶бһҖбҹ’бһҷвҖӢбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢвҖӢбһҠбҹ„бһҷвҖӢбһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ–вҖӢбһҮбһ¶бһҳбһҪбһҷвҖӢбһҖбҹ’бһҡбһ»бһҳвҖӢбһӮбҹ’бһҡбһҪбһҹбһ¶бһҡвҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһ“бҹ…бһҖбҹ’бһ“бһ»бһ„вҖӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„вҖӢбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢбҹ”</translation>
<translation id="8105002292464261990">бһ…бһ»бһ… вҖҳбһ”бҹ’бһҠбһјбһҡвҖӢбһҳбҹүбһәбһ“бһ»бһҷвҖӢбһҸбһ¶бһҳвҖӢбһ”бҹҶбһҺбһ„вҖҷ</translation>
<translation id="8348530355586151720">бһ…бһ»бһ…вҖӢбһҳбҹүбһәбһ“бһ»бһҷбһ…бһ»бһ…бһ”бһё</translation>
<translation id="8856329583773053724">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹвҖӢбһҹбһҳбһ¶бһҮбһ·бһҖвҖӢбһӮбҹ’бһҡбһҪбһҹбһ¶бһҡвҖӢбһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңвҖӢбһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖвҖӢбһҮбһ¶бһҳбһҪбһҷ</translation>
<translation id="9085041112720733880">бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһӣбҹҒбһҒвҖӢбһҸбһ¶бһҳбһҠбһ¶бһ“вҖӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖвҖӢбһ“бҹ…бһӣбһҫвҖӢбһӮбҹҒбһ бһ‘бҹҶбһ–бҹҗбһҡвҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ‘бһ·бһүбһ‘бҹҶбһ“бһ·бһү бһ¬вҖӢбһ”бҹ’бһҡбҹғбһҹбһҺбһёбһҷбҹҚбҹ”</translation>
<translation id="9093047661118118915">бһ–бҹҒбһӣбһҠбһ№бһҖбһҮбһүбҹ’бһҮбһјбһ“бһҠбһӣбҹӢвҖӢбһ”бҹүбһ¶бһ“бҹӢбһҹбҹ’бһҳбһ¶бһ“</translation>
<translation id="9181396888106868838">бһ…бһ»бһ…вҖӢбһ’бһ¶бһҸбһ»вҖӢбһҳбҹүбһәбһ“бһ»бһҷвҖӢбһұбҹ’бһҷбһҷбһјбһҡ</translation>
</translationbundle>