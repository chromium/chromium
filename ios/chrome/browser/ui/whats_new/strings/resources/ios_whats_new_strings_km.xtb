<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="3575234738189584619">бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҠбҹ„бһҷбһ”бҹ’бһҡбһҫ Lens</translation>
<translation id="4133265950310064865">бһҖбһ¶бһҡбһҖбһ¶бһҡбһ–бһ¶бһҡвҖӢбһҠбҹӮбһӣбһ”бҹ’бһҡбһҹбһҫбһҡбһҮбһ¶бһ„бһҳбһ»бһ“</translation>
<translation id="6277426346321820595">бһӮбҹ’бһҳбһ¶бһ“вҖӢбһҖбһ¶бһҡбһҖбһ¶бһҡбһ–бһ¶бһҡвҖӢбһ‘бҹҒ</translation>
<translation id="6366190659675876144">бһҖбһ¶бһҡбһҖбһ¶бһҡбһ–бһ¶бһҡбһҹбҹ’бһҸбһ„бҹӢбһҠбһ¶бһҡ</translation>
<translation id="8717864919010420084">бһ…бһҳбҹ’бһӣбһ„бһҸбҹҶбһҺ</translation>
<translation id="880967149107462122">бһ…бһјбһӣбһ‘бҹ…бһҖбһ¶бһ“бҹӢвҖӢбһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢ Chrome</translation>
<translation id="9203951165704618409">бһ”бҹ’бһҠбһјбһҡбһҡбһ”бһ¶бһҡбһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ–бһёбһҒбһ¶бһ„бһӣбһҫбһ‘бҹ…бһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ”бһ‘бһ–бһ·бһҹбҹ„бһ’бһҡбһ»бһҖбһҡбһҖбһҠбҹӮбһӣбһ”бҹ’бһҠбһјбһҡбһҸбһ¶бһҳбһ”бҹҶбһҺбһ„бҹ”</translation>
</translationbundle>