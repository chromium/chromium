<!DOCTYPE translationbundle>
<translationbundle lang="lv">
<translation id="1239866612142087073">3. Pārejiet uz sadaļu Iestatījumi &gt; Paroļu pārvaldnieks.</translation>
<translation id="1363028406613469049">Izsekošana</translation>
<translation id="1554523534964039554">Paroļu kopīgošana ar ģimenes grupu</translation>
<translation id="1556556838855011466">1. Atveriet pārlūku Chrome.</translation>
<translation id="2319645462410562206">Chrome var noteikt vietnēs ievadītos izsekošanas numurus un parādīt jaunumus par sūtījumiem jaunas cilnes lapā.</translation>
<translation id="2551790923936684824">Vai izsekot šo sūtījumu?</translation>
<translation id="2734585994146185878">Jūsu sūtījums</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Trešdien, 1. maijā, līdz plkst. 19:00</translation>
<translation id="3770157741494890119">Atļaujiet pārlūkam Chrome izsekot jūsu sūtījumus.</translation>
<translation id="401853092657437412">2. Pieskarieties trīs punktu izvēlnei.</translation>
<translation id="5475069061743940393">Sūtījuma izsekošana</translation>
<translation id="6147071803535394951">Skatiet jaunumus par sūtījumiem jaunas cilnes lapas kartītēs.</translation>
<translation id="6292962033060948789">Paroles kopijas kopīgošana Google paroļu pārvaldniekā</translation>
<translation id="6297866979658584786">4. Atlasiet paroli un pieskarieties ikonai “Kopīgot”.</translation>
<translation id="7343651556898151354">Chrome var palīdzēt jums izsekot šo sūtījumu jaunas cilnes lapā.</translation>
<translation id="7425802352219229154">5. Atlasiet ģimenes locekļus, ar kuriem kopīgot paroli.</translation>
<translation id="8094734579697217987">Ērti un droši kopīgojiet paroles kopiju ar savu ģimenes grupu Google paroļu pārvaldniekā.</translation>
<translation id="9085041112720733880">Ievadiet savu izsekošanas numuru pasta vai iepirkšanās vietnē.</translation>
<translation id="9093047661118118915">Paredzamais piegādes laiks</translation>
</translationbundle>