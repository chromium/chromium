<!DOCTYPE translationbundle>
<translationbundle lang="ne">
<translation id="1363028406613469049">ट्रयाक</translation>
<translation id="1554523534964039554">आफ्नो पारिवारिक समूहसँग पासवर्डहरू सेयर गर्नुहोस्</translation>
<translation id="2319645462410562206">Chrome ले तपाईंले साइटहरूमा हाल्ने ट्र्याकिङ नम्बरहरू पत्ता लगाउन र "नयाँ ट्याब" पेजमा प्याकेजसम्बन्धी अपडेटहरू देखाउन सक्छ।</translation>
<translation id="2551790923936684824">यो प्याकेज ट्र्याक गर्ने हो?</translation>
<translation id="2734585994146185878">तपाईंको ढुवानी</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">बुधबार, मे ०१ का दिन साँझको ७ बजेसम्ममा</translation>
<translation id="3770157741494890119">Chrome लाई तपाईंका प्याकेजहरू ट्र्याक गर्ने अनुमति दिनुहोस्।</translation>
<translation id="5475069061743940393">प्याकेज ट्रयाकिङ</translation>
<translation id="5777468213129569553">Chrome खोल्नुहोस्</translation>
<translation id="6147071803535394951">आफ्नो "नयाँ ट्याब" पेजमा भएको "कार्डहरू" मा प्याकेजसम्बन्धी अपडेटहरू हेर्नुहोस्।</translation>
<translation id="6494974875566443634">व्यक्तिगत सेटिङ</translation>
<translation id="7108338896283013870">लुकाउनुहोस्</translation>
<translation id="7343651556898151354">तपाईं Chrome प्रयोग गरेर "नयाँ ट्याब" पेजमा गई यो प्याकेज ट्र्याक गर्न सक्नुहुन्छ।</translation>
<translation id="8094734579697217987">Google पासवर्ड म्यानेजरमा आफ्ना पारिवारिक समूहसँग सुरक्षित तरिकाले सजिलैसँग पासवर्डको कपी सेयर गर्नुहोस्।</translation>
<translation id="9085041112720733880">आफ्नो ट्र्याकिङ नम्बर हुलाक वा किनमेलसम्बन्धी वेबसाइटमा हाल्नुहोस्।</translation>
<translation id="9093047661118118915">डेलिभरी गरिने अनुमानित समय</translation>
</translationbundle>