<!DOCTYPE translationbundle>
<translationbundle lang="ne">
<translation id="3266153067803506235">Chrome आइकन थिचिराख्नुहोस् र “होम स्क्रिनमा परिवर्तन गर्नुहोस्” मा क्लिक गर्नुहोस्</translation>
<translation id="3958312024468322930">यसलाई ड्रयाग गरी आफ्नो होम स्क्रिनको पुछारमा रहेको डकसम्म पुर्‍याउनुहोस्</translation>
<translation id="4607887340472970274">मूल्य ट्र्याकिङ</translation>
<translation id="5423269318075950257">मूल्य ट्रयाक गर्नुहोस्</translation>
<translation id="5858597710560817319">Chrome लाई आफ्नो iPhone को होम स्क्रिनको डकमा सारेर अझ छिटो एक्सेस गर्नुहोस्।</translation>
<translation id="7065813315247345131">Move Chrome लाई सारेर डकमा लैजानुहोस्</translation>
<translation id="7227293336683593977">विगतको मूल्य</translation>
<translation id="8625706492572042370">होम स्क्रिन बदल्नुहोस्</translation>
</translationbundle>