<translation id="1239866612142087073">‫3- انتقِل إلى "الإعدادات" &gt; "مدير كلمات المرور"</translation>
<translation id="1363028406613469049">تتبّع</translation>
<translation id="1554523534964039554">مشاركة كلمات المرور مع مجموعة عائلتك</translation>
<translation id="1556556838855011466">‏‫1- افتح Chrome</translation>
<translation id="2319645462410562206">‏يمكن أن يرصد Chrome أرقام التتبُّع التي تدخلها على المواقع الإلكترونية ويعرِض لك إشعارات الطرود في صفحة "علامة تبويب جديدة".</translation>
<translation id="2551790923936684824">هل تريد تتبُّع هذا الطرد؟</translation>
<translation id="2734585994146185878">شحنتك</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">الأربعاء، 1 مايو بحلول الساعة 7:00 مساءً</translation>
<translation id="3770157741494890119">‏اسمح لمتصفّح Chrome بتتبُّع الطرود الخاصة بك.</translation>
<translation id="401853092657437412">‫2- انقر على قائمة الخيارات الإضافية</translation>
<translation id="5475069061743940393">تتبُّع الطرود</translation>
<translation id="6147071803535394951">اطّلِع على إشعارات الطرود في "البطاقات" المتوفّرة على صفحة "علامة تبويب جديدة".</translation>
<translation id="6292962033060948789">‏يمكنك مشاركة نسخة من إحدى كلمات المرور في "مدير كلمات المرور في Google"</translation>
<translation id="6297866979658584786">‫4- اختَر كلمة مرور وانقر على رمز المشاركة</translation>
<translation id="7343651556898151354">‏يمكن أن يساعدك Chrome في تتبُّع هذه الحزمة من خلال صفحة "علامة تبويب جديدة".</translation>
<translation id="7425802352219229154">‫5- اختَر أفراد العائلة الذين تريد مشاركة كلمة المرور معهم</translation>
<translation id="8094734579697217987">‏يمكنك مشاركة نسخة من إحدى كلمات المرور بسهولة وأمان مع مجموعة عائلتك في "مدير كلمات المرور في Google".</translation>
<translation id="9085041112720733880">أدخِل رقم التتبّع على موقع إلكتروني للبريد أو للتسوّق.</translation>
