<translation id="1363028406613469049">Pista</translation>
<translation id="1554523534964039554">Comparteix les contrasenyes amb el grup familiar</translation>
<translation id="2319645462410562206">Chrome pot detectar els números de seguiment que introdueixes als llocs web i mostrar novetats sobre els paquets a la pàgina Pestanya nova.</translation>
<translation id="2551790923936684824">Vols fer el seguiment d'aquest paquet?</translation>
<translation id="2734585994146185878">El teu enviament</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Dimecres, 1 de maig, a les 19:00</translation>
<translation id="3770157741494890119">Permet que Chrome faci un seguiment dels teus paquets.</translation>
<translation id="5475069061743940393">Seguiment d'enviaments</translation>
<translation id="5777468213129569553">Obre Chrome</translation>
<translation id="6147071803535394951">Consulta les novetats sobre els paquets a les targetes de la pàgina Pestanya nova.</translation>
<translation id="6494974875566443634">Personalització</translation>
<translation id="7108338896283013870">Amaga</translation>
<translation id="7343651556898151354">Chrome et pot ajudar a fer un seguiment d'aquest paquet a la pàgina Pestanya nova.</translation>
<translation id="8094734579697217987">Comparteix una còpia d'una contrasenya amb el teu grup familiar d'una manera fàcil i segura al gestor de contrasenyes de Google.</translation>
<translation id="9085041112720733880">Introdueix el número de seguiment en un lloc web de correus o de compres.</translation>
<translation id="9093047661118118915">Entrega prevista</translation>
