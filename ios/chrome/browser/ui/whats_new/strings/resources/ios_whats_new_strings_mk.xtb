<translation id="5423269318075950257">Следи ја цената</translation>
<translation id="7065813315247345131">Преместете го Chrome на докот</translation>
<translation id="7227293336683593977">Историја на цените</translation>
<translation id="8625706492572042370">Изменете го почетниот екран</translation>
