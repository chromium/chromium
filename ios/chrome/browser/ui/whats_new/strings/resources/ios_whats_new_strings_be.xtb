<!DOCTYPE translationbundle>
<translationbundle lang="be">
<translation id="1363028406613469049">Трэк</translation>
<translation id="1554523534964039554">Абагульвайце паролі з удзельнікамі сямейнай групы</translation>
<translation id="2319645462410562206">Chrome можа выяўляць нумары для адсочвання, якія вы ўводзіце на сайтах, і паказваць актуальную інфармацыю пра пасылкі на старонцы новай укладкі.</translation>
<translation id="2551790923936684824">Адсочваць гэту пасылку?</translation>
<translation id="2734585994146185878">Дастаўка</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Серада, 1 мая, да 19:00</translation>
<translation id="3770157741494890119">Дайце Chrome дазвол на адсочванне вашых пасылак.</translation>
<translation id="5475069061743940393">Адсочванне</translation>
<translation id="5777468213129569553">Адкрыць Chrome</translation>
<translation id="6147071803535394951">Актуальную інфармацыю пра пасылкі можна глядзець у раздзеле "Карткі" на старонцы новай укладкі.</translation>
<translation id="6494974875566443634">Наладжванне</translation>
<translation id="7108338896283013870">Схаваць</translation>
<translation id="7343651556898151354">Вы можаце сачыць за гэтай пасылкай на старонцы новай укладкі ў Chrome.</translation>
<translation id="8094734579697217987">Вы можаце зручна і бяспечна абагуліць копію пароля з удзельнікамі сямейнай групы ў Менеджары пароляў Google.</translation>
<translation id="9085041112720733880">Увядзіце нумар для адсочвання на вэб-сайце пошты або крамы.</translation>
<translation id="9093047661118118915">Прыблізны час дастаўкі</translation>
</translationbundle>