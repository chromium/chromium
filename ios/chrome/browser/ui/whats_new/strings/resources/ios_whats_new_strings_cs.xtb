<translation id="1239866612142087073">3. Přejděte na Nastavení &gt; Správce hesel.</translation>
<translation id="1363028406613469049">Stopa</translation>
<translation id="1554523534964039554">Sdílení hesel s rodinnou skupinou</translation>
<translation id="1556556838855011466">1. Otevřete Chrome.</translation>
<translation id="2319645462410562206">Chrome dokáže rozpoznat čísla zásilek, která zadáte na webech, a zobrazovat na stránce Nová karta aktuální informace o zásilkách.</translation>
<translation id="2551790923936684824">Sledovat tuhle zásilku?</translation>
<translation id="2734585994146185878">Vaše zásilka</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Středa 1. května do 19:00</translation>
<translation id="3770157741494890119">Povolte Chromu sledovat vaše zásilky.</translation>
<translation id="401853092657437412">2. Klepněte na nabídku se třemi tečkami.</translation>
<translation id="5475069061743940393">Sledování zásilek</translation>
<translation id="6147071803535394951">Na kartách na stránce Nová karta sledujte aktuální informace o zásilce.</translation>
<translation id="6292962033060948789">Ve Správci hesel Google můžete sdílet kopii hesla</translation>
<translation id="6297866979658584786">4. Vyberte heslo a klepněte na ikonu Sdílet.</translation>
<translation id="7343651556898151354">Chrome vám může pomoct sledovat tuhle zásilku na stránce Nová karta.</translation>
<translation id="7425802352219229154">5. Vyberte členy rodiny, se kterými chcete heslo sdílet.</translation>
<translation id="8094734579697217987">Ve Správci hesel Google můžete snadno a bezpečně sdílet kopii hesla se svou rodinnou skupinou.</translation>
<translation id="9085041112720733880">Na poštovním nebo nákupním webu zadejte číslo zásilky.</translation>
<translation id="9093047661118118915">Předpokládané doručení</translation>
</translationbundle>