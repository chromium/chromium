<!DOCTYPE translationbundle>
<translationbundle lang="si">
<translation id="1363028406613469049">ඛණ්ඩය</translation>
<translation id="1554523534964039554">ඔබේ පවුලේ කණ්ඩායම සමග මුරපද බෙදා ගන්න</translation>
<translation id="2319645462410562206">Chromeහට ඔබ අඩවිවල ඇතුළු කරන ලුහුබැඳීමේ අංක හඳුනා ගැනීමටත් නව පටිති පිටුවෙහි පැකේජ යාවත්කාලීන පෙන්වීමටත් හැක.</translation>
<translation id="2551790923936684824">මෙම පැකේජය නිරීක්ෂණය කරන්න ද?</translation>
<translation id="2734585994146185878">ඔබේ නැව්ගත කිරීම</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">මැයි 01 වැනි බදාදා ප.ව. 7:00 ට.</translation>
<translation id="3770157741494890119">ඔබේ පැකේජ නිරීක්ෂණය කිරීමට Chrome හට ඉඩ දෙන්න.</translation>
<translation id="5475069061743940393">පැකේජය හඹා යෑම</translation>
<translation id="5777468213129569553">Chrome විවෘත කරන්න</translation>
<translation id="6147071803535394951">ඔබේ නව පටිති පිටුවෙහි කාඩ්පත්වල පැකේජ යාවත්කාලීන බලන්න.</translation>
<translation id="6494974875566443634">අභිරුචිකරණය</translation>
<translation id="7108338896283013870">සඟවන්න</translation>
<translation id="7343651556898151354">Chrome හට නව පටිති පිටුවෙහි මෙම පැකේජය නිරීක්ෂණය කිරීමට ඔබට උදවු කළ හැක.</translation>
<translation id="8094734579697217987">Google මුරපද කළමනාකරු තුළ ඔබේ පවුලේ කණ්ඩායම සමග මුරපදයක පිටපතක් පහසුවෙන් සහ සුරක්ෂිතව බෙදා ගන්න.</translation>
<translation id="9085041112720733880">තැපැල් හෝ සාප්පු සවාරි වෙබ් අඩවියක ඔබේ ලුහුබැඳීමේ අංකය ඇතුළු කරන්න.</translation>
<translation id="9093047661118118915">ඇස්තෙම්න්තුගත බෙදා හැරීම</translation>
</translationbundle>