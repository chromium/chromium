<!DOCTYPE translationbundle>
<translationbundle lang="hi">
<translation id="1703743472724191604">कीमत: 100 से 150 डॉलर के बीच</translation>
<translation id="1741219894094057085">स्मार्टवॉच</translation>
<translation id="1841425245869881163">स्क्रोल करके नीचे जाएं और 'खरीदारी के अन्य विकल्प' पर टैप करें</translation>
<translation id="1988591645162894496">अपने पसंदीदा प्रॉडक्ट बेचने वाले ज़्यादा स्टोर आसानी से खोजें</translation>
<translation id="2043455190894016404">कीमतों में समय के साथ हुए बदलावों को देखने के लिए, पता बार पर मौजूद 'कीमत का इतिहास' आइकॉन पर टैप करें</translation>
<translation id="2058876133802084300">$150</translation>
<translation id="2216366330550244277">किसी प्रॉडक्ट के पेज पर जाएं</translation>
<translation id="2657494017069155956">Chrome को तुरंत ऐक्सेस करने के लिए, इसे अपने iPhone की होम स्क्रीन पर मौजूद डॉक पर मूव करें</translation>
<translation id="3266153067803506235">Chrome के आइकॉन को दबाकर रखें और “होम स्क्रीन में बदलाव करें” पर क्लिक करें</translation>
<translation id="3764562164106905124">नवंबर</translation>
<translation id="3958312024468322930">इसे खींचकर होम स्क्रीन पर सबसे नीचे मौजूद डॉक में छोड़ें</translation>
<translation id="4227258125987011664">$200</translation>
<translation id="4607887340472970274">कीमत को ट्रैक करने की सुविधा</translation>
<translation id="4760786790170329383">स्क्रीन पर दिख रहे कॉन्टेंट के बारे में जानकारी खोजें</translation>
<translation id="5119329531859909472">प्रॉडक्ट को ट्रैक करने के लिए, 'ट्रैक करें' पर टैप करें</translation>
<translation id="5423269318075950257">कीमत ट्रैक करें</translation>
<translation id="5551447203719429864">Google Lens की मदद से, ब्राउज़ करते समय ज़्यादा जानकारी मिलती है. अब किसी भी पेज पर दिखने वाले प्रॉडक्ट, जगहों, और टेक्स्ट के बारे में ज़्यादा जानकारी खोजी जा सकती है.</translation>
<translation id="5910891913281809039">दिसंबर</translation>
<translation id="5980825544755559844">$100</translation>
<translation id="5997931385777991124">खरीदारी के अन्य विकल्प</translation>
<translation id="6250648963363746140">देखें कि समय के साथ, प्रॉडक्ट की कीमतों में क्या बदलाव हुए हैं</translation>
<translation id="6434483369543264725">अक्टूबर</translation>
<translation id="6709005160890717159">इमेज में दिख रहे टेक्स्ट का अनुवाद पाएं</translation>
<translation id="6926200709057244215">खरीदारी से जुड़ी अहम जानकारी पाएं. इससे आपको कीमतों को ट्रैक करने, कीमत का इतिहास देखने, और सही समय पर खरीदारी करने में मदद मिलती है</translation>
<translation id="6944020103996173879">खरीदारी के अन्य विकल्प देखें</translation>
<translation id="6998251471716094661">प्रॉडक्ट की कीमतें ट्रैक करें. साथ ही, किसी भी साइट पर मौजूद प्रॉडक्ट की कीमत में गिरावट आने पर सूचनाएं पाएं</translation>
<translation id="7065813315247345131">Chrome को डॉक पर मूव करें</translation>
<translation id="7097046145876891318">कीमतों में समय के साथ हुए बदलावों को देखने के लिए, पता बार पर मौजूद 'कीमत का इतिहास' पर टैप करें</translation>
<translation id="7227293336683593977">कीमत का इतिहास</translation>
<translation id="794945939108159738">$120</translation>
<translation id="8625706492572042370">होम स्क्रीन में बदलाव करें</translation>
<translation id="8871142946513037507">वेब पर मौजूद अन्य स्टोर</translation>
<translation id="991428047095920989">कीमतों में समय के साथ हुए बदलावों को देखने के लिए, पता बार पर मौजूद 'कीमत का इतिहास' आइकॉन पर टैप करें</translation>
