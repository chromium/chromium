<translation id="1363028406613469049">ट्रैक</translation>
<translation id="1554523534964039554">अपने फ़ैमिली ग्रुप के साथ पासवर्ड शेयर करें</translation>
<translation id="2319645462410562206">Chrome, साइटों पर आपके डाले गए ट्रैकिंग नंबर का पता लगा सकता है और 'नया टैब' पेज पर पैकेज के अपडेट दिखा सकता है.</translation>
<translation id="2551790923936684824">क्या इस पैकेज को ट्रैक करना है?</translation>
<translation id="2734585994146185878">आपका शिपमेंट</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">बुधवार, 1 मई शाम 7:00 बजे तक</translation>
<translation id="3770157741494890119">Chrome को आपके पैकेज ट्रैक करने की अनुमति दें.</translation>
<translation id="5475069061743940393">पैकेज ट्रैकिंग</translation>
<translation id="5777468213129569553">Chrome खोलें</translation>
<translation id="6147071803535394951">'नया टैब' पेज पर 'कार्ड' में पैकेज से जुड़े अपडेट देखें.</translation>
<translation id="6494974875566443634">पसंद के मुताबिक सेटिंग</translation>
<translation id="7108338896283013870">छुपाएं</translation>
<translation id="7343651556898151354">Chrome, 'नया टैब' पेज पर इस पैकेज को ट्रैक करने में आपकी मदद कर सकता है.</translation>
<translation id="8094734579697217987">Google Password Manager में, पासवर्ड की किसी कॉपी को अपने फ़ैमिली ग्रुप के साथ आसानी से और सुरक्षित तरीके से शेयर करें.</translation>
<translation id="9085041112720733880">किसी पोस्टल या शॉपिंग वेबसाइट पर अपना ट्रैकिंग नंबर डालें.</translation>
<translation id="9093047661118118915">डिलीवर होने का अनुमानित समय</translation>
