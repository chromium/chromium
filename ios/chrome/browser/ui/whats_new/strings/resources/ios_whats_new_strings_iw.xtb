<translation id="1239866612142087073">3. עוברים אל 'הגדרות' &gt; 'מנהל הסיסמאות'</translation>
<translation id="1363028406613469049">רצועה</translation>
<translation id="1554523534964039554">שיתוף סיסמאות עם הקבוצה המשפחתית</translation>
<translation id="1556556838855011466">‏1. פותחים את Chrome.</translation>
<translation id="2319645462410562206">‏‫Chrome יכול לזהות מספרי מעקב שהזנת באתרים ולהציג עדכונים על חבילות בדף 'כרטיסייה חדשה'.</translation>
<translation id="2551790923936684824">לעקוב אחרי החבילה הזו?</translation>
<translation id="2734585994146185878">המשלוח שלך</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">יום רביעי, 1 במאי, עד 19:00</translation>
<translation id="3770157741494890119">‏מאשרים ל-Chrome לעקוב אחר החבילות.</translation>
<translation id="401853092657437412">2. מקישים על סמל האפשרויות הנוספות (3 נקודות)</translation>
<translation id="5475069061743940393">מעקב אחר חבילה</translation>
<translation id="6147071803535394951">בודקים את העדכונים על חבילות ב'כרטיסים' בדף 'כרטיסייה חדשה'.</translation>
<translation id="6292962033060948789">‏אפשר לשתף עותק של סיסמה במנהל הסיסמאות של Google</translation>
<translation id="6297866979658584786">4. בוחרים סיסמה ומקישים על סמל השיתוף</translation>
<translation id="7343651556898151354">‏‫Chrome יכול לעזור לך לעקוב אחרי החבילה הזו בדף 'כרטיסייה חדשה'.</translation>
<translation id="7425802352219229154">5. בוחרים חברים בקבוצה המשפחתית שאיתם רוצים לשתף את הסיסמה</translation>
<translation id="8094734579697217987">‏אפשר לשתף עותק של סיסמה עם הקבוצה המשפחתית באופן קל ומאובטח ב'מנהל הסיסמאות של Google'.</translation>
<translation id="9085041112720733880">מזינים את מספר המעקב שמופיע באתר המשלוחים או באתר הקניות.</translation>
<translation id="9093047661118118915">מועד המסירה המשוער</translation>
