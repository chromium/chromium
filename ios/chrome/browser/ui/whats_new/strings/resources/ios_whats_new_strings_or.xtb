<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="or">
<translation id="3266153067803506235">Chrome ଆଇକନକୁ ଦବାଇ ଧରି “ହୋମ ସ୍କ୍ରିନକୁ ଏଡିଟ କରନ୍ତୁ”ରେ କ୍ଲିକ କରନ୍ତୁ</translation>
<translation id="3958312024468322930">ଏହାକୁ ଆପଣଙ୍କ ହୋମ ସ୍କ୍ରିନର ନିମ୍ନରେ ଥିବା ଡକକୁ ଡ୍ରାଗ କରନ୍ତୁ</translation>
<translation id="4607887340472970274">ମୂଲ୍ୟ ଟ୍ରାକିଂ</translation>
<translation id="5423269318075950257">ମୂଲ୍ୟ ଟ୍ରାକ କରନ୍ତୁ</translation>
<translation id="5858597710560817319">Chromeକୁ ଆପଣଙ୍କ iPhoneର ହୋମ ସ୍କ୍ରିନର ଡକକୁ ମୁଭ କରି ଏହାକୁ ଶୀଘ୍ର ଆକ୍ସେସ କରନ୍ତୁ।</translation>
<translation id="7065813315247345131">Chromeକୁ ଡକକୁ ମୁଭ କରାଯାଇଛି</translation>
<translation id="7227293336683593977">ମୂଲ୍ୟ ଇତିହାସ</translation>
<translation id="8625706492572042370">ହୋମ ସ୍କ୍ରିନକୁ ଏଡିଟ କରନ୍ତୁ</translation>
</translationbundle>