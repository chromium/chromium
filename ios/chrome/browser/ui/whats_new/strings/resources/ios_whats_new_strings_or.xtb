<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="or">
<translation id="1239866612142087073">3. “ସେଟିଂସ” &gt; “Password Manager”କୁ ଯାଆନ୍ତୁ</translation>
<translation id="1363028406613469049">ଟ୍ରାକ୍‌ କରନ୍ତୁ</translation>
<translation id="1554523534964039554">ଆପଣଙ୍କ ପରିବାର ଗୋଷ୍ଠୀ ସହ ପାସୱାର୍ଡଗୁଡ଼ିକ ସେୟାର କରନ୍ତୁ</translation>
<translation id="1556556838855011466">1. Chrome ଖୋଲନ୍ତୁ</translation>
<translation id="2319645462410562206">Chrome ଆପଣ ସାଇଟଗୁଡ଼ିକରେ ଲେଖୁଥିବା ଟ୍ରାକିଂ ନମ୍ବରଗୁଡ଼ିକୁ ଚିହ୍ନଟ କରିପାରିବ ଏବଂ ନୂଆ ଟାବ ପୃଷ୍ଠାରେ ପେକେଜ ଅପଡେଟଗୁଡ଼ିକ ଦେଖାଇପାରିବ।</translation>
<translation id="2551790923936684824">ଏହି ପେକେଜକୁ ଟ୍ରାକ କରିବେ?</translation>
<translation id="2734585994146185878">ଆପଣଙ୍କ ସିପମେଣ୍ଟ</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">ବୁଧବାର, ମଇ 01 7:00 P.M. ସୁଦ୍ଧା</translation>
<translation id="3770157741494890119">ଆପଣଙ୍କ ପେକେଜଗୁଡ଼ିକୁ ଟ୍ରାକ କରିବା ପାଇଁ Chromeକୁ ଅନୁମତି ଦିଅନ୍ତୁ।</translation>
<translation id="401853092657437412">2. ତିନି-ଡଟ ମେନୁରେ ଟାପ କରନ୍ତୁ</translation>
<translation id="5475069061743940393">ପେକେଜ ଟ୍ରାକିଂ</translation>
<translation id="6147071803535394951">ଆପଣଙ୍କ ନୂଆ ଟାବ ପୃଷ୍ଠାରେ ଥିବା କାର୍ଡଗୁଡ଼ିକରେ ପେକେଜ ଅପଡେଟଗୁଡ଼ିକୁ ଦେଖନ୍ତୁ।</translation>
<translation id="6292962033060948789">Google Password Managerରେ ଏକ ପାସୱାର୍ଡର ଗୋଟିଏ କପି ସେୟାର କରନ୍ତୁ</translation>
<translation id="6297866979658584786">4. ଏକ ପାସୱାର୍ଡ ଚୟନ କରି “ସେୟାର କରନ୍ତୁ” ଆଇକନରେ ଟାପ କରନ୍ତୁ</translation>
<translation id="7343651556898151354">Chrome ଆପଣଙ୍କୁ ନୂଆ ଟାବ ପୃଷ୍ଠାରେ ଏହି ପେକେଜକୁ ଟ୍ରାକ କରିବାରେ ସାହାଯ୍ୟ କରିପାରିବ।</translation>
<translation id="7425802352219229154">5. ଆପଣ ପରିବାରର ଯେଉଁ ସଦସ୍ୟମାନଙ୍କ ସହ ସେୟାର କରିବାକୁ ଚାହାଁନ୍ତି, ସେମାନଙ୍କୁ ଚୟନ କରନ୍ତୁ</translation>
<translation id="8094734579697217987">Google Password Managerରେ ଆପଣଙ୍କ ପରିବାର ଗୋଷ୍ଠୀ ସହିତ ସହଜରେ ଏବଂ ସୁରକ୍ଷିତ ଭାବରେ ଏକ ପାସୱାର୍ଡର ଗୋଟିଏ କପି ସେୟାର କରନ୍ତୁ।</translation>
<translation id="9085041112720733880">ଏକ ପୋଷ୍ଟାଲ କିମ୍ବା ସପିଂ ୱେବସାଇଟରେ ଆପଣଙ୍କ ଟ୍ରାକିଂ ନମ୍ବର ଲେଖନ୍ତୁ।</translation>
<translation id="9093047661118118915">ଆନୁମାନିକ ଡେଲିଭରୀ</translation>
</translationbundle>