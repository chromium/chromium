<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="ml">
<translation id="1363028406613469049">ട്രാക്കുചെയ്യുക</translation>
<translation id="1554523534964039554">നിങ്ങളുടെ കുടുംബ ഗ്രൂപ്പുമായി പാസ്‌വേഡുകൾ പങ്കിടുക</translation>
<translation id="2319645462410562206">സൈറ്റുകളിൽ നിങ്ങൾ നൽകുന്ന ട്രാക്കിംഗ് നമ്പറുകൾ കണ്ടെത്താനും പുതിയ ടാബ് പേജിൽ പാക്കേജ് അപ്‌ഡേറ്റുകൾ കാണിക്കാനും Chrome-ന് കഴിയും.</translation>
<translation id="2551790923936684824">ഈ പാക്കേജ് ട്രാക്ക് ചെയ്യണോ?</translation>
<translation id="2734585994146185878">നിങ്ങളുടെ ഷിപ്പ്മെന്റ്</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">മേയ് 1, ബുധൻ, 7:00 P.M-ന്.</translation>
<translation id="3770157741494890119">നിങ്ങളുടെ പാക്കേജുകൾ ട്രാക്ക് ചെയ്യാൻ Chrome-നെ അനുവദിക്കുക.</translation>
<translation id="5475069061743940393">പാക്കേജ് ട്രാക്ക് ചെയ്യൽ</translation>
<translation id="5777468213129569553">Chrome തുറക്കുക</translation>
<translation id="6147071803535394951">നിങ്ങളുടെ പുതിയ ടാബ് പേജിലെ കാർഡുകളിൽ പാക്കേജ് അപ്‌ഡേറ്റുകൾ കാണുക.</translation>
<translation id="6494974875566443634">ഇഷ്ടാനുസൃതമാക്കൽ</translation>
<translation id="7108338896283013870">മറയ്ക്കുക</translation>
<translation id="7343651556898151354">പുതിയ ടാബ് പേജിൽ ഈ പാക്കേജ് ട്രാക്ക് ചെയ്യാൻ Chrome-ന് നിങ്ങളെ സഹായിക്കാനാകും.</translation>
<translation id="8094734579697217987">Google Password Manager-ലെ നിങ്ങളുടെ കുടുംബ ഗ്രൂപ്പുമായി ഒരു പാസ്‌വേഡിന്റെ പകർപ്പ് എളുപ്പത്തിലും സുരക്ഷിതമായും പങ്കിടുക.</translation>
<translation id="9085041112720733880">ഒരു തപാൽ അല്ലെങ്കിൽ ഷോപ്പിംഗ് വെബ്സൈറ്റിൽ നിങ്ങളുടെ ട്രാക്കിംഗ് നമ്പർ നൽകുക.</translation>
<translation id="9093047661118118915">പ്രതീക്ഷിക്കുന്ന ഡെലിവറി തീയതി</translation>
</translationbundle>