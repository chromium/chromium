<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="ml">
<translation id="3266153067803506235">Chrome ഐക്കണിൽ അമർത്തിപ്പിടിച്ച് “ഹോം സ്ക്രീൻ എഡിറ്റ് ചെയ്യുക” ക്ലിക്ക് ചെയ്യുക</translation>
<translation id="3958312024468322930">ഇത് നിങ്ങളുടെ ഹോം സ്ക്രീനിന് ചുവടെയുള്ള ഡോക്കിലേക്ക് വലിച്ചിടുക</translation>
<translation id="4607887340472970274">നിരക്ക് ട്രാക്ക് ചെയ്യൽ</translation>
<translation id="5423269318075950257">നിരക്ക് ട്രാക്ക് ചെയ്യുക</translation>
<translation id="5858597710560817319">നിങ്ങളുടെ iPhone-ന്റെ ഹോം സ്‌ക്രീൻ ഡോക്കിലേക്ക് നീക്കി Chrome വേഗത്തിൽ ആക്‌സസ് ചെയ്യുക.</translation>
<translation id="7065813315247345131">ഡോക്കിലേക്ക് Chrome നീക്കുക</translation>
<translation id="7227293336683593977">നിരക്ക് ചരിത്രം</translation>
<translation id="8625706492572042370">ഹോം സ്‌ക്രീൻ എഡിറ്റ് ചെയ്യുക</translation>
</translationbundle>