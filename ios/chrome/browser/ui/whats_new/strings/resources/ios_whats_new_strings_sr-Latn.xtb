<!DOCTYPE translationbundle>
<translationbundle lang="sr-Latn">
<translation id="1239866612142087073">3. Idite u Podešavanja &gt; Menadžer lozinki</translation>
<translation id="1363028406613469049">Pesma</translation>
<translation id="1554523534964039554">Delite lozinke sa grupom za porodicu</translation>
<translation id="1556556838855011466">1. Otvorite Chrome</translation>
<translation id="2319645462410562206">Chrome može da otkrije brojeve za praćenje koje unosite na sajtovima i da prikazuje novosti o paketima na stranici nove kartice.</translation>
<translation id="2551790923936684824">Želite da pratite ovaj paket?</translation>
<translation id="2734585994146185878">Vaša pošiljka</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">sreda, 1.maj do 19:00.</translation>
<translation id="3770157741494890119">Dozvolite Chrome-u da prati pakete.</translation>
<translation id="401853092657437412">2. Dodirnite meni sa tri tačke</translation>
<translation id="5475069061743940393">Praćenje paketa</translation>
<translation id="6147071803535394951">Pregledajte novosti o paketima na karticama na stranici nove kartice.</translation>
<translation id="6292962033060948789">Delite kopiju lozinke u Google menadžeru lozinki</translation>
<translation id="6297866979658584786">4. Izaberite lozinku i dodirnite ikonu Deli</translation>
<translation id="7343651556898151354">Chrome može da vam pomogne da pratite ovaj paket na stranici nove kartice.</translation>
<translation id="7425802352219229154">5. Izaberite članove porodice sa kojima ćete je deliti</translation>
<translation id="8094734579697217987">Lako i bezbedno delite kopiju lozinke sa grupom za porodicu u Google menadžeru lozinki.</translation>
<translation id="9085041112720733880">Unesite broj za praćenje na veb-sajtu kurirske službe ili veb-sajtu za kupovinu.</translation>
<translation id="9093047661118118915">Procenjena isporuka</translation>
</translationbundle>