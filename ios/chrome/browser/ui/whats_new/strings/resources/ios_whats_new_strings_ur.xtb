<!DOCTYPE translationbundle>
<translationbundle lang="ur">
<translation id="3266153067803506235">‏‫Chrome آئیکن کو چھوئیں اور دبائے رکھیں اور "ہوم اسکرین میں ترمیم کریں" پر کلک کریں</translation>
<translation id="3958312024468322930">اسے اپنی ہوم اسکرین کے نیچے ڈاک پر گھسیٹیں۔</translation>
<translation id="4607887340472970274">قیمت کی ٹریکنگ</translation>
<translation id="5423269318075950257">قیمت ٹریک کریں</translation>
<translation id="5858597710560817319">‏Chrome کو اپنے iPhone کی ہوم اسکرین ڈاک میں منتقل کر کے اس تک تیزی سے رسائی حاصل کریں۔</translation>
<translation id="7065813315247345131">‏‫Chrome کو ڈاک میں منتقل کریں</translation>
<translation id="7227293336683593977">قیمت کی سرگزشت</translation>
<translation id="8625706492572042370">ہوم اسکرین میں ترمیم کریں</translation>
</translationbundle>