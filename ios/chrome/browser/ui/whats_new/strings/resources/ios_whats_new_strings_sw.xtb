<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="sw">
<translation id="1363028406613469049">Wimbo</translation>
<translation id="1546129703935983118">Ifanye Chrome ilingane na jinsi unavyovinjari kwa kubadilisha menyu yako upendavyo.</translation>
<translation id="1554523534964039554">Kutuma Manenosiri kwenye Kikundi cha Familia yako</translation>
<translation id="2319645462410562206">Chrome inaweza kutambua namba za ufuatiliaji unazoweka kwenye tovuti na kukuonyesha taarifa za kifurushi kwenye Ukurasa wa Kichupo Kipya.</translation>
<translation id="2551790923936684824">Ungependa kufuatilia Kifurushi hiki?</translation>
<translation id="3067067035910355531">Chagua nenosiri kisha uguse aikoni ya “tuma”</translation>
<translation id="3770157741494890119">Ruhusu Chrome ifuatilie vifurushi vyako.</translation>
<translation id="4047337302138771011">Ruhusu Manenosiri Yako Yafikiwe</translation>
<translation id="4093156958486416052">Bidhaa unayosafirishiwa</translation>
<translation id="4874629658972056851">Fungua menyu yako ya Chrome</translation>
<translation id="4989753829760610266">Ficha vipengee vyovyote ambavyo hungependa kuviona.</translation>
<translation id="5475069061743940393">Ufuatiliaji wa Kifurushi</translation>
<translation id="5777468213129569553">Fungua Chrome</translation>
<translation id="5985054498852397330">Badilisha Menyu Upendavyo</translation>
<translation id="6147071803535394951">Angalia taarifa za kifurushi katika Kadi kwenye Ukurasa wako wa Kichupo Kipya.</translation>
<translation id="6527303717912515753">Shiriki</translation>
<translation id="6780178366025947966">Nenda kwenye “Kidhibiti cha Manenosiri”</translation>
<translation id="7108338896283013870">Ficha</translation>
<translation id="7180865173735832675">Binafsisha</translation>
<translation id="8094734579697217987">Tuma nakala ya nenosiri kwenye kikundi cha familia yako kwa njia salama na rahisi katika Kidhibiti cha Manenosiri cha Google.</translation>
<translation id="8105002292464261990">Gusa ‘Weka Mapendeleo kwenye Menyu’</translation>
<translation id="8348530355586151720">Gusa menyu ya nukta tatu</translation>
<translation id="8856329583773053724">Chagua wanafamilia ambao ungependa kuwaruhusu wafikie</translation>
<translation id="9085041112720733880">Weka namba yako ya ufuatiliaji kwenye tovuti ya ununuzi au ya posta.</translation>
<translation id="9093047661118118915">Inatarajiwa kukufikia</translation>
<translation id="9181396888106868838">Bonyeza kwa muda mrefu kipengee chochote cha menyu</translation>
</translationbundle>