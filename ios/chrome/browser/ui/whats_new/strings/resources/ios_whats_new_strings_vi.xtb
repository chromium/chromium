<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="vi">
<translation id="1239866612142087073">3. Chuyển đến phần "Cài đặt" &gt; "Trình quản lý mật khẩu"</translation>
<translation id="1363028406613469049">Theo dõi</translation>
<translation id="1554523534964039554">Chia sẻ mật khẩu với nhóm gia đình</translation>
<translation id="1556556838855011466">1. Mở Chrome</translation>
<translation id="2319645462410562206">Chrome có thể phát hiện số vận đơn bạn nhập trên các trang web và cung cấp thông tin cập nhật về gói hàng trên trang Thẻ mới.</translation>
<translation id="2551790923936684824">Bạn muốn theo dõi gói hàng này?</translation>
<translation id="2734585994146185878">Lô hàng của bạn</translation>
<translation id="282865025718505166">1ZX32F000348211000</translation>
<translation id="3092996224604267355">Muộn nhất là 7 giờ tối thứ Tư, ngày 1 tháng 5</translation>
<translation id="3770157741494890119">Cho phép Chrome theo dõi các gói hàng của bạn.</translation>
<translation id="401853092657437412">2. Nhấn vào trình đơn có biểu tượng ba dấu chấm</translation>
<translation id="5475069061743940393">Theo dõi gói hàng</translation>
<translation id="6147071803535394951">Xem thông tin cập nhật về gói hàng trong phần Thẻ trên trang Thẻ mới.</translation>
<translation id="6292962033060948789">Chia sẻ bản sao mật khẩu trong Trình quản lý mật khẩu của Google</translation>
<translation id="6297866979658584786">4. Chọn một mật khẩu rồi nhấn vào biểu tượng "chia sẻ"</translation>
<translation id="7343651556898151354">Chrome có thể giúp bạn theo dõi gói hàng này trên trang Thẻ mới.</translation>
<translation id="7425802352219229154">5. Chọn thành viên gia đình mà bạn muốn chia sẻ</translation>
<translation id="8094734579697217987">Dễ dàng chia sẻ bản sao mật khẩu với nhóm gia đình một cách an toàn trong Trình quản lý mật khẩu của Google.</translation>
<translation id="9085041112720733880">Nhập số vận đơn của bạn trên một trang web bưu chính hoặc mua sắm.</translation>
<translation id="9093047661118118915">Thời gian giao hàng dự kiến</translation>
</translationbundle>