source_set("utils") {
  sources = [
    "clipboard_utils.h",
    "clipboard_utils.mm",
    "data_controls_utils.h",
    "data_controls_utils.mm",
  ]
  deps = [
    "//base",
    "//components/enterprise/data_controls/core/browser",
    "//components/strings",
    "//ios/chrome/browser/enterprise/data_controls",
    "//ios/chrome/browser/shared/model/profile",
