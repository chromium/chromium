source_set("client_certificates") {
  public = [
    "certificate_provisioning_service_factory_ios.h",
    "certificate_store_factory.h",
    "client_certificates_service_ios.h",
    "client_certificates_service_ios_factory.h",
    "profile_context_delegate_ios.h",
  ]

  sources = [
    "certificate_provisioning_service_factory_ios.mm",
    "certificate_store_factory.mm",
    "client_certificates_service_ios.mm",
    "client_certificates_service_ios_factory.mm",
    "profile_context_delegate_ios.mm",
  ]

  public_deps = [
    ":util",
    "//base",
    "//components/enterprise/client_certificates/ios",
    "//components/keyed_service/core",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/chrome/browser/shared/model/profile:profile_keyed_service_factory",
