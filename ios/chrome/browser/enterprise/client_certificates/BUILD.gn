    "//components/enterprise",
    "//components/enterprise/client_certificates/core:management_delegate",
    "//crypto",
    "//ios/chrome/browser/content_settings/model",
    "//ios/chrome/browser/enterprise/core",
    "//ios/chrome/browser/enterprise/identifiers:profile_id_service_factory",
    "//ios/chrome/browser/policy/model",
    "//ios/chrome/browser/shared/model/application_context",
    "//services/network/public/cpp",
  ]
}

source_set("util") {
  public = [ "cert_utils.h" ]

  sources = [
    "browser_context_delegate_ios.h",
    "browser_context_delegate_ios.mm",
    "cert_utils.mm",
  ]

  public_deps = [ "//components/enterprise/client_certificates/ios" ]

  deps = [
    "//base",
    "//components/enterprise",
    "//components/enterprise/client_certificates/core:management_delegate",
    "//ios/chrome/common:ios_app_bundle_id_prefix_buildflags",
  ]

  friend = [ ":unit_tests" ]
}

