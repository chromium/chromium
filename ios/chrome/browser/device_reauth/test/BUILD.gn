source_set("eg_app_support+eg2") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [
    "reauthentication_app_interface.h",
    "reauthentication_app_interface.mm",
  ]
  deps = [
    "//base",
    "//ios/chrome/browser/device_reauth/model",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/chrome/common/ui/reauthentication",
    "//ios/chrome/common/ui/reauthentication:mock_reauthentication_module",
    "//ios/chrome/test/app:test_support",
  ]
}

source_set("eg_test_support+eg2") {
  configs += [ "//build/config/ios:xctest_config" ]
  testonly = true
  sources = [
    "reauthentication_app_interface.h",
    "reauthentication_app_interface_stub.mm",
  ]
  deps = [
    "//ios/chrome/common/ui/reauthentication",
    "//ios/chrome/test:eg_test_support+eg2",
    "//ios/testing/earl_grey:eg_test_support+eg2",
  ]
}
