{
  "$schema": "./magi_test_schemas.json#/definitions/Scenario",
  "name": "Specify Stage Tests",
  "description": "Verify steps in Specify stage.",
  "base_inputs": {
    "project_spec": "testdata/project.magi.json"
  },
  "cases": [
    {
      "stage": "Specify", "step": 3,
      "name": "Low Complexity Fast Path",
      "override_inputs": {
        "project_spec_overrides": {
          "complexity_level": "LOW",
          "ambiguity_level": "LOW",
          "execution_path": "FAST_PATH"
        }
      },
      "expected_outputs": {
        "files_created": ["testdata/project.magi.json"],
        "valid_json": true,
        "content_patterns": {
          "testdata/project.magi.json": "\"execution_path\": \"FAST_PATH\""
        }
      }
    },
    {
      "stage": "Specify", "step": 3,
      "name": "High Ambiguity RIGOR Path",
      "override_inputs": {
        "project_spec_overrides": {
          "complexity_level": "MEDIUM",
          "ambiguity_level": "HIGH",
          "execution_path": "RIGOR_PATH"
        }
      },
      "expected_outputs": {
        "files_created": ["testdata/project.magi.json"],
        "valid_json": true,
        "content_patterns": {
          "testdata/project.magi.json": "\"execution_path\": \"RIGOR_PATH\""
        }
      }
    }
  ]
}
