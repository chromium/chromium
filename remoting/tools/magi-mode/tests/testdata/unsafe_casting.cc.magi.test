// Mock file with intentional flaw for testing.
// MAGI: This file contains an unsafe reinterpret_cast.

#include "type_converter.h"

namespace remoting {

void DerivedA::MethodA() {}
void DerivedB::MethodB() {}

void ConvertType(Base* base_ptr) {
  // MAGI: Unsafely casting Base* to DerivedA* using reinterpret_cast instead of static_cast or custom type check.
  DerivedA* a_ptr = reinterpret_cast<DerivedA*>(base_ptr);
  a_ptr->MethodA();
}

}  // namespace remoting
