// Mock file with intentional flaw for testing.
// MAGI: This file contains a use-after-free bug in TriggerUseAfterFree.

#include "base/logging.h"
#include <memory>

void TriggerUseAfterFree() {
  int* ptr = new int(10);
  delete ptr;
  // MAGI: Use after free occurs here!
  LOG(INFO) << "Value: " << *ptr;
}
