{
    "$schema": "./magi_test_schemas.json#/definitions/Scenario",
    "name": "Review & Consensus",
    "description": "Verify review consolidation and consensus logic.",
    "base_inputs": {
        "project_spec": "testdata/project.magi.json",
        "state_block": "testdata/state_block.magi.json"
    },
    "cases": [
        {
            "phase": 5,
            "name": "Consensus Logical AND",
            "override_inputs": {
                "mock_reviews": [
                    {
                        "persona": "core/security.json",
                        "verdict": "ACCEPT",
                        "checklist": {
                            "no_pii_leaks": true
                        }
                    },
                    {
                        "persona": "domain/signaling.json",
                        "verdict": "REJECT",
                        "checklist": {
                            "no_pii_leaks": false
                        },
                        "comments": [
                            {
                                "file": "testdata/file1.cc",
                                "comment": "Found PII!"
                            }
                        ]
                    }
                ]
            },
            "expected_outputs": {
                "files_created": [
                    "testdata/state_block.magi.json"
                ],
                "valid_json": true,
                "content_patterns": {
                    "testdata/state_block.magi.json": "\"no_pii_leaks\": false"
                }
            }
        },
        {
            "phase": 5,
            "name": "Detect Use-After-Free",
            "override_inputs": {
                "project_spec_overrides": {
                    "target_files": [
                        "testdata/sample_ipc.cc"
                    ]
                },
                "mock_reviews": [
                    {
                        "persona": "core/security.json",
                        "verdict": "REJECT",
                        "checklist": {
                            "no_use_after_free": false
                        },
                        "comments": [
                            {
                                "file": "testdata/sample_ipc.cc",
                                "comment": "Use after free detected!"
                            }
                        ]
                    }
                ]
            },
            "expected_outputs": {
                "files_created": [
                    "testdata/state_block.magi.json"
                ],
                "valid_json": true,
                "content_patterns": {
                    "testdata/state_block.magi.json": "\"no_use_after_free\": false"
                }
            }
        },
