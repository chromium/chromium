import("//build/config/features.gni")
import("//build/config/ui.gni")

# 'use_blink' is default to '!is_ios'. Consequently, remoting is only enabled on
# iOS if use_blink or enable_remoting are explicitly set to true.
declare_args() {
  enable_remoting = use_blink && !is_castos && !is_cast_android && !is_fuchsia
}
