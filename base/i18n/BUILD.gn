source_set("base_i18n_export") {
  public = [ "base_i18n_export.h" ]
}

source_set("language_tag") {
  sources = [
    "bcp47_extensions.cc",
    "bcp47_extensions.h",
    "language_tag.cc",
    "language_tag.h",
    "language_tag_matcher.cc",
    "language_tag_matcher.h",
    "tag_converters.cc",
    "tag_converters.h",
    "tags.cc",
    "tags.h",
  ]

  defines = [ "BASE_I18N_IMPLEMENTATION" ]

  public_deps = [ ":base_i18n_export" ]
  deps = [
    "//base",
    "//base/i18n/internal",
    "//base/i18n/internal:canonical_language_tags",
    "//base/i18n/internal:i18n_icu_bridge_ffi",
  ]
  visibility = [
    ":*",
    "//base:*",
  ]
}

source_set("unicodestring") {
  sources = [ "unicodestring.h" ]
  public_deps = [ "//third_party/icu" ]
}

source_set("time_formatting_types") {
  sources = [ "time_formatting_types.h" ]
}

source_set("unittests") {
  testonly = true
  sources = [
    "language_tag_matcher_unittest.cc",
    "language_tag_unittest.cc",
  ]
  deps = [
    "//base",
    "//base:i18n",
    "//base/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
