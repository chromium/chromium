source_set("icubridge") {
  sources = [
    "date_time_formatter.cc",
    "date_time_formatter.h",
    "icu_bridge.cc",
    "icu_bridge.h",
    "icu_bridge_helpers.h",
  ]

  defines = [ "BASE_I18N_IMPLEMENTATION" ]

  configs += [ "//build/config/compiler:wexit_time_destructors" ]

  public_deps = [
    "//base",
    "//base/i18n:base_i18n_export",
    "//base/i18n:time_formatting_types",
  ]

  deps = [ "//third_party/icu" ]

  visibility = [
    ":*",
    ":unittests",
    "//base:i18n",
    "//base/i18n:*",
  ]
}

source_set("unittests") {
  testonly = true
  sources = [ "date_time_formatter_unittest.cc" ]
  deps = [
    "//base",
    "//base:i18n",
    "//base/test:test_support",
    "//testing/gtest",
  ]
}
