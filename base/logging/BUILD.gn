import("//build/rust/rust_bindgen.gni")

source_set("log_severity") {
  public = [ "log_severity.h" ]
  deps = [ "//base:dcheck_is_on" ]
  visibility = [ "*" ]
}

rust_bindgen("log_severity_bindgen") {
  header = "log_severity.h"
  cpp = true
  visibility = [ "rust_logger:*" ]
  deps = [ ":log_severity" ]
}
