import("//build/rust/rust_static_library.gni")

rust_static_library("rust_logger") {
  allow_unsafe = true  # Unsafe needed for FFI.
  deps = [
    "//base/logging:log_severity_bindgen",
    "//third_party/rust/log/v0_4:lib",
  ]

  # These somewhat random `deps` are needed, because `print_rust_log.rs`
  # contains: `include!("base/logging/rust_logger/print_rust_log_ffi.h")` and
  # it ends up transitively including `log_severity.h` as well as
  # PartitionAlloc headers (which require specific `include_dirs` to be set up
  # via `deps`).
  #
  # TODO(https://crbug.com/495537792): Depend directly on a target that
  # provides `print_rust_log_ffi.h`.  Today this target is `//base` and
  # depending on `//base` would create a circular dependency.  In the future we
  # should move `print_rust_log_ffi.h` into a separate target (which may also
  # necessitary moving `logging::LogMessage` into a small target, as well as
  # moving _its_ dependencies into smaller/low-layer targets).
  deps += [
    "//base:tracing_buildflags",
    "//base/allocator/partition_allocator:raw_ptr",
    "//base/logging:log_severity",
    "//build:chromeos_buildflags",
  ]

  visibility = [ "//base" ]
  crate_root = "lib.rs"
  sources = [
    "custom_panic_hook.rs",
    "log_crate_integration.rs",
    "print_rust_log.rs",
    crate_root,
  ]
  cxx_bindings = [
    crate_root,
    "print_rust_log.rs",
  ]
}

rust_static_library("test_support") {
  allow_unsafe = true  # Unsafe needed for FFI
  testonly = true
  deps = [ "//third_party/rust/log/v0_4:lib" ]
  crate_root = "test_support.rs"
  sources = [ crate_root ]
  cxx_bindings = [ crate_root ]
  visibility = [ ":*" ]
}

source_set("unittests") {
  visibility = [ "//base:*" ]
  testonly = true
  sources = [ "unittests.cc" ]
  deps = [
    ":test_support",
    "//base/logging:log_severity",
    "//base/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
