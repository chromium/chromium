import argparse
import pathlib
import sys


def main():
    readme_path = pathlib.Path('./README.chromium')

    if not readme_path.exists():
        print(f'File not found: {readme_path}!', file=sys.stderr)
        print(
            f'The program needs to be invoked from the BiDiMapper directory!',
            file=sys.stderr)
        return 1

    with pathlib.Path(readme_path).open('r') as f:
        for line in f.readlines():
            prefix = 'Version:'
            if not line.startswith(prefix):
                continue
            print(line[len(prefix):].strip())
            return 0

    print(
        f'Unable to find the current BiDiMapper version in file: {readme_path}!',
        file=sys.stderr)
    return 1


if __name__ == '__main__':
    parser = argparse.ArgumentParser(
        description='Get the BiDiMapper version used by ChromeDriver')
    parser.parse_args()
    sys.exit(main())
