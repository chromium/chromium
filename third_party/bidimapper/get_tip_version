import argparse
import json
import sys
import urllib
import urllib.parse
import urllib.request


def main():
    package_json = json.load(
        urllib.request.urlopen(
            f'https://registry.npmjs.org/chromium-bidi/latest'))
    version = package_json['version']
    print(version)
    return 0


if __name__ == '__main__':
    parser = argparse.ArgumentParser(
        description='Get the latest available BiDiMapper version')
    parser.parse_args()
    sys.exit(main())
