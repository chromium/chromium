// TODO(https://crbug.com/481412281): Add spec link when available.

[
    Exposed=Window, SecureContext, RuntimeEnabled=RTCDiagnosticLogging
] interface RTC : EventTarget {
    [CallWith=ScriptState] Promise<DOMString> startDiagnosticLogging(optional RTCDiagnosticLoggingOptions options = {});
    [CallWith=ScriptState] Promise<undefined> finishDiagnosticLogging();
    [CallWith=ScriptState] Promise<undefined> cancelDiagnosticLogging();

};
