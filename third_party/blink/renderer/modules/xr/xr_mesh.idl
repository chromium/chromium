// More details about the mesh detection API can be found here:
// https://immersive-web.github.io/real-world-meshing/#native-mesh-detection

[
    SecureContext,
    Exposed=Window,
    RuntimeEnabled=WebXRMeshDetection
]
interface XRMesh {
    [SameObject] readonly attribute XRSpace meshSpace;

    readonly attribute Float32Array vertices;
    readonly attribute Uint32Array indices;
    readonly attribute DOMHighResTimeStamp lastChangedTime;
    readonly attribute DOMString? semanticLabel;
};