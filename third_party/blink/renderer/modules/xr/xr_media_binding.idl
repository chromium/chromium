[
    Exposed=Window,
    SecureContext,
    RuntimeEnabled=WebXRMediaBinding
] interface XRMediaBinding {
    [CallWith=ScriptState, RaisesException] constructor(XRSession session);

    [RaisesException] XRQuadLayer createQuadLayer(HTMLVideoElement video, XRMediaQuadLayerInit init);
    [RaisesException] XRCylinderLayer createCylinderLayer(HTMLVideoElement video, XRMediaCylinderLayerInit init);
    [RaisesException] XREquirectLayer createEquirectLayer(HTMLVideoElement video, XRMediaEquirectLayerInit init);
};
