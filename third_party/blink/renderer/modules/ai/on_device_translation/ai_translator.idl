[
    RuntimeEnabled=TranslationAPI,
    Exposed=(Window,Worker),
    SecureContext
]
interface AITranslator {
[
  MeasureAs=Translator_Translate,
  CallWith=ScriptState,
  RaisesException
]
  Promise<DOMString> translate(DOMString input, optional AITranslatorTranslateOptions options = {});

[
  MeasureAs=Translator_TranslateStreaming,
  CallWith=ScriptState,
  RaisesException
]
  ReadableStream translateStreaming(DOMString input, optional AITranslatorTranslateOptions options = {});

  [MeasureAs=Translator_SourceLanguage]
  readonly attribute DOMString sourceLanguage;
  [MeasureAs=Translator_TargetLanguage]
  readonly attribute DOMString targetLanguage;

[
  MeasureAs=Translator_Destroy,
  CallWith=ScriptState
]
  undefined destroy();

[
  MeasureAs=Translator_MeasureInputUsage,
  CallWith=ScriptState,
  RaisesException
]
  Promise<double> measureInputUsage(
    DOMString input,
    optional AITranslatorTranslateOptions options = {}
  );
  [MeasureAs=Translator_InputQuota]
  readonly attribute unrestricted double inputQuota;
};

dictionary AITranslatorTranslateOptions {
  AbortSignal signal;
};
