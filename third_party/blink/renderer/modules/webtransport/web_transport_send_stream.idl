// https://w3c.github.io/webtransport/#webtransportsendstream
[
    Exposed=(Window,Worker),
    SecureContext,
    RuntimeEnabled=WebTransportSendGroup
] interface WebTransportSendStream : WritableStream {
  [RaisesException=Setter] attribute WebTransportSendGroup? sendGroup;
  attribute long long sendOrder;
  [CallWith=ScriptState]
  Promise<WebTransportSendStreamStats> getStats();
  // TODO(crbug.com/487117768): Add WebTransportWriter getWriter() once
  // WebTransportWriter interface is implemented.
};
