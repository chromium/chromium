// https://w3c.github.io/webtransport/#dictdef-webtransportsendoptions
dictionary WebTransportSendOptions {
  [RuntimeEnabled=WebTransportSendGroup] WebTransportSendGroup? sendGroup = null;
  [RuntimeEnabled=WebTransportSendGroup] long long sendOrder = 0;
};
