dictionary HTMLMediaStreamConstraints {
  MediaTrackConstraintSet video;
  MediaTrackConstraintSet audio;
};

[RuntimeEnabled=UserMediaElement, ImplementedAs=UserMediaElementConstraints]
partial interface HTMLUserMediaElement {
    void setConstraints(optional HTMLMediaStreamConstraints constraints = {});
};
