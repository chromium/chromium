// Experimental API to draw child elements to WebGL.

dictionary WebGLCopyElementImageConfig {
    GLfloat sx;
    GLfloat sy;
    GLfloat swidth;
    GLfloat sheight;
    GLsizei width;
    GLsizei height;
};
