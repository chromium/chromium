[
    Exposed=(Window, Worker),
    RuntimeEnabled=DocumentPatching
]
interface TrustedParserOptions {
  readonly attribute (Sanitizer or SanitizerConfig or SanitizerPresets) sanitizer;
  readonly attribute boolean runScripts;
};
