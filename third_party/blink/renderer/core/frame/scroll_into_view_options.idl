enum ScrollLogicalPosition { "start", "center", "end", "nearest", "auto" };
enum ScrollContainer { "all", "nearest" };

dictionary ScrollIntoViewOptions : ScrollOptions {
    ScrollLogicalPosition block = "auto";
    [ImplementedAs=inlinePosition] ScrollLogicalPosition inline = "auto";
    [RuntimeEnabled=ScrollIntoViewNearest] ScrollContainer container = "all";
};
