[
    Exposed=Window,
    RuntimeEnabled=FormControlRange
] interface FormControlRange : AbstractRange {
    DOMRectList getClientRects();
    DOMRect getBoundingClientRect();
};

[RuntimeEnabled=FormControlRange]
interface mixin FormControlRangeCreation {
    [RaisesException] FormControlRange getValueRange(unsigned long start, unsigned long end);
};
