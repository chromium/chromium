// https://dom.spec.whatwg.org/#dictdef-addeventlisteneroptions

dictionary AddEventListenerOptions : EventListenerOptions {
    boolean passive;
    boolean once = false;
    [RuntimeEnabled=AddEventListenerAbortSignal] AbortSignal signal;
};
