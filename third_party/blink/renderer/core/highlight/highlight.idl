enum HighlightType {
  "highlight",
  "spelling-error",
  "grammar-error"
};

[
  Exposed=Window
] interface Highlight {
  constructor(AbstractRange... initRanges);
  setlike<AbstractRange>;
  attribute long priority;
  attribute HighlightType type;
};
