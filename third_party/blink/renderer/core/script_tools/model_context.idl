// https://webmachinelearning.github.io/webmcp/#model-context-container

[
    Exposed=Window,
    SecureContext,
    RuntimeEnabled=WebMCP
] interface ModelContext {
  [CallWith=ScriptState, RaisesException, MeasureAs=ModelContextRegisterTool] undefined registerTool(ModelContextTool tool);
  [RaisesException] undefined unregisterTool(DOMString name);
};
