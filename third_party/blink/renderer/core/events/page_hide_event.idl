[RuntimeEnabled=PageHideSpeculations, Exposed=Window]
interface PageHideEvent : PageTransitionEvent {
    constructor(DOMString type, optional PageHideEventInit eventInitDict = {});

    // Speculation data - always present on pagehide
    readonly attribute SpeculationData speculations;
};
