enum FenceReportingDestination {
  "buyer",
  "seller",
  "component-seller",
  "direct-seller",
  "shared-storage-select-url"
};

dictionary FenceEvent {
  required DOMString eventType;
  required DOMString eventData;
  required sequence<FenceReportingDestination> destination;
};
