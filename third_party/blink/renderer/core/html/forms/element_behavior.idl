// Platform-provided behavior base interface.
// Behaviors can be attached to custom elements via
// attachInternals({ behaviors: [...] }).
[
  Exposed=Window,
  RuntimeEnabled=ElementInternalsBehaviors
]
interface ElementBehavior {
};
