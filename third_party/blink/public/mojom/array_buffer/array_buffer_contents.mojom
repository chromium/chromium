module blink.mojom;

import "mojo/public/mojom/base/big_buffer.mojom";

// Struct which represents the contents of an ArrayBuffer, e.g.
// ArrayBufferContents.
struct SerializedArrayBufferContents {
  mojo_base.mojom.BigBuffer contents;

  // If the buffer is resizable via JavaScript, the limit to which it can be
  // resized. If it is not resizable via JavaScript, this is not set.
  uint64? javascript_resize_limit;
};
