module blink.mojom;

import "mojo/public/mojom/base/big_buffer.mojom";
import "mojo/public/mojom/base/token.mojom";
import "third_party/blink/public/mojom/tokens/tokens.mojom";
import "ui/gfx/geometry/mojom/geometry.mojom";

// Browser -> Renderer interface to manage a single image replacement (where an
// image in a HTML document is replaced in-place with remote content (hosted and
// rendered by a page in an iframe).
// Note: Features using image replacement will need to send the browser a
// pending_remote<ImageReplacement> through a separate interface.
interface ImageReplacement {
  // Starts the replacement of the image in the renderer (i.e. creates the
  // shadow tree, and appends a blank iframe).
  //
  // Params:
  //   `host_remote`: Will be used to communicate with the browser process about
  //     this image's replacement.
  //   `tracked_element_feature_id`: A viz::TrackedElementFeature to associate
  //     with the element, if tracking is required.
  StartReplacement(pending_remote<ImageReplacementHost> host_remote,
                   int32? tracked_element_feature_id);

  // Instructs the renderer to stop painting the original image content and
  // start painting the replacement frame instead.
  RenderReplacement();
};

struct ImageData {
  // Encoded image bytes (always WebP).
  mojo_base.mojom.BigBuffer webp_bytes;
};

// Renderer -> Browser interface to communicate status for a single image
// replacement.
interface ImageReplacementHost {
  // Called by the renderer after an iframe (represented by
  // `replacement_frame_token`) has been attached. This subframe will be
  // used by the browser to render the replacement.
  //
  // Params:
  //   `replacement_frame_token`: Identifier for the subframe in the replacement
  //     image shadow tree. The host is responsible for navigating this subframe
  //     to the remote content.
  //   `original_image`: Bytes for the original image.
  //   `tracked_element_id`: The viz::TrackedElementId which identifies this
  //     element, if tracking was requested.
  ReplacementFrameAttached(LocalFrameToken replacement_frame_token,
                           ImageData original_image,
                           mojo_base.mojom.Token? tracked_element_id);
};
