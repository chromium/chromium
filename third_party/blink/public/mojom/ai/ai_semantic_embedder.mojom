module blink.mojom;

import "third_party/blink/public/mojom/ai/ai_common.mojom";

// The task type for the AISemanticEmbedder.
// These task types allow the underlying model to optimize the generated
// embeddings for specific downstream use cases.
enum AISemanticEmbedderTaskType {
  // Evaluates how semantically similar two strings are.
  kSemanticSimilarity,
  // Groups strings into clusters.
  kClustering,
  // Classifies strings based on their semantic meaning.
  kClassification,
  // Finds relevant documents for a given short query.
  kRetrievalQuery,
  // Encoding document content for future retrieval.
  kRetrievalDocument,
};

// Options for the Embed method.
struct AISemanticEmbedderEmbedOptions {
  AISemanticEmbedderTaskType? task_type;
};

struct ContentEmbedding {
  array<float> values;
};

struct SemanticEmbedderResult {
  array<ContentEmbedding> embeddings;
};

// A semantic embedder.
interface AISemanticEmbedder {
  // Embeds strings and returns an array of 1:1 mapped float arrays.
  Embed(array<string> inputs, AISemanticEmbedderEmbedOptions? options)
      => (SemanticEmbedderResult result);
};

