# This file lists WPTs that should run against headless shell via chromedriver.
# It is only used for migrating from RWT to Wptrunner, and will be deleted
# after the migration is done. WPTs should by default run with headless shell,
# except those listed in chrome.filter eventually.
#
# Further documentation:
# https://chromium.googlesource.com/chromium/src/+/HEAD/docs/testing/run_web_platform_tests.md

# Don't run tests in `headless_shell_wpt_tests` by default. When this term is
# negated for `blink_wpt_tests`, `+*` will run all tests by default.
-*

external/wpt/accessibility/*
external/wpt/acid/*
-external/wpt/acid/acid2/reftest.html
external/wpt/ai/*
external/wpt/apng/*
external/wpt/audio-output/*
external/wpt/autoplay-policy-detection/*
external/wpt/avif/*
external/wpt/background-sync/*
external/wpt/badging/*
external/wpt/beacon/*
external/wpt/captured-mouse-events/*
external/wpt/clear-site-data/*
external/wpt/client-hints/accept-ch-stickiness/*
external/wpt/client-hints/service-workers/*
external/wpt/clipboard-apis/*
-external/wpt/clipboard-apis/async-navigator-clipboard-write-multiple.tentative.https.sub.html

external/wpt/css/*
