bench_write_to_prefix_dynamic_size:
	push r14
	push rbx
	push rax
	mov rbx, rcx
	lea r14, [2*rsi + 5]
	and r14, -2
	cmp r14, rcx
	ja .LBB5_2
	mov rax, rdi
	mov rdi, rdx
	mov rsi, rax
	mov rdx, r14
	call qword ptr [rip + memcpy@GOTPCREL]
.LBB5_2:
	cmp r14, rbx
	setbe al
	add rsp, 8
	pop rbx
	pop r14
	ret
