bench_try_read_from_bytes_static_size:
	mov ax, -16191
	cmp rsi, 6
	jne .LBB5_1
	mov ecx, dword ptr [rdi]
	movzx edx, cx
	cmp edx, 49344
	jne .LBB5_4
	movzx eax, word ptr [rdi + 4]
	shl rax, 32
	or rcx, rax
	shr rcx, 16
	mov ax, -16192
.LBB5_4:
	shl rcx, 16
	movzx eax, ax
	or rax, rcx
	ret
.LBB5_1:
	shl rcx, 16
	movzx eax, ax
	or rax, rcx
	ret
