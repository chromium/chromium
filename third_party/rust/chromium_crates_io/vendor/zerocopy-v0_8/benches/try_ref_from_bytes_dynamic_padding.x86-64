bench_try_ref_from_bytes_dynamic_padding:
	test dil, 3
	jne .LBB5_4
	movabs rax, 9223372036854775804
	and rax, rsi
	cmp rax, 9
	jb .LBB5_4
	add rax, -9
	movabs rcx, -6148914691236517205
	mul rcx
	shr rdx
	lea rax, [rdx + 2*rdx]
	or rax, 3
	add rax, 9
	cmp rsi, rax
	jne .LBB5_4
	cmp word ptr [rdi], -16192
	je .LBB5_5
.LBB5_4:
	xor edi, edi
	mov rdx, rsi
.LBB5_5:
	mov rax, rdi
	ret
