bench_ref_from_prefix_with_elems_dynamic_size:
	movabs rax, 9223372036854775805
	cmp rdx, rax
	ja .LBB5_1
	mov rcx, rdx
	xor edx, edx
	mov eax, 0
	test dil, 1
	jne .LBB5_4
	lea rax, [2*rcx + 4]
	xor r8d, r8d
	cmp rax, rsi
	mov edx, 1
	cmovbe rdx, rcx
	cmova rdi, r8
	mov rax, rdi
