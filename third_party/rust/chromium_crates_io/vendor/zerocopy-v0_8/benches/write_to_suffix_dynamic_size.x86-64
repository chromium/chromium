bench_write_to_suffix_dynamic_size:
	push r14
	push rbx
	push rax
	mov rbx, rcx
	lea r14, [2*rsi + 5]
	and r14, -2
	sub rcx, r14
	jb .LBB5_2
	mov rax, rdi
	add rdx, rcx
	mov rdi, rdx
	mov rsi, rax
	mov rdx, r14
	call qword ptr [rip + memcpy@GOTPCREL]
.LBB5_2:
	cmp rbx, r14
	setae al
	add rsp, 8
	pop rbx
	pop r14
	ret
