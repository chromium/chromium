bench_ref_from_bytes_dynamic_padding:
	test dil, 3
	je .LBB5_2
	xor eax, eax
	mov rdx, rsi
	ret
.LBB5_2:
	movabs rax, 9223372036854775804
	and rax, rsi
	cmp rax, 9
	jae .LBB5_4
	xor eax, eax
	mov rdx, rsi
	ret
.LBB5_4:
	add rax, -9
	movabs rcx, -6148914691236517205
	mul rcx
	shr rdx
	lea rcx, [rdx + 2*rdx]
	or rcx, 3
	add rcx, 9
	xor eax, eax
	cmp rsi, rcx
	cmove rsi, rdx
	cmove rax, rdi
	mov rdx, rsi
	ret
