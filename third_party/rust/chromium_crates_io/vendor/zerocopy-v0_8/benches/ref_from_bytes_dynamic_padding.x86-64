bench_ref_from_bytes_dynamic_padding:
	test dil, 3
	jne .LBB5_3
	movabs rax, 9223372036854775804
	and rax, rsi
	cmp rax, 9
	jb .LBB5_3
	add rax, -9
	movabs rcx, -6148914691236517205
	mul rcx
	shr rdx
	lea rax, [rdx + 2*rdx]
	or rax, 3
	add rax, 9
	cmp rsi, rax
	je .LBB5_4
.LBB5_3:
	xor edi, edi
	mov rdx, rsi
.LBB5_4:
	mov rax, rdi
	ret
