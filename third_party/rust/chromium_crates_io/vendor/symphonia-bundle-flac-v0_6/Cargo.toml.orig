[package]
name = "symphonia-bundle-flac"
description = "Pure Rust FLAC demuxer and decoder (a part of project Symphonia)."
authors = ["Philip Deljanov <philip.deljanov@gmail.com>"]
readme = "README.md"
categories = ["multimedia", "multimedia::audio", "multimedia::encoding"]
keywords = ["audio", "codec", "decoder", "flac"]
# Common package metadata located in workspace Cargo.toml.
edition.workspace = true
homepage.workspace = true
license.workspace = true
repository.workspace = true
rust-version.workspace = true
version.workspace = true

[dependencies]
log = { workspace = true }
symphonia-core = { version = "0.6.0-alpha.2", path = "../symphonia-core" }
symphonia-common = { version = "0.6.0-alpha.2", path = "../symphonia-common" }

[dependencies.symphonia-metadata]
version = "0.6.0-alpha.2"
path = "../symphonia-metadata"
default-features = false
features = ["flac"]

[lints.rust]
unexpected_cfgs = { level = "warn", check-cfg = ['cfg(fuzzing)'] }
