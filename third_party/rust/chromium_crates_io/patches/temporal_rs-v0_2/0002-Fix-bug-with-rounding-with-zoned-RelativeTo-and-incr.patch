         //
         // 14. Let progress be (destEpochNs - startEpochNs) / (endEpochNs - startEpochNs).
         // 15. Let total be r1 + progress × increment × sign.
@@ -910,10 +910,8 @@ impl InternalDurationRecord {
         let divisor = end_epoch_ns.0 - start_epoch_ns.0;
 
