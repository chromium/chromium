diff --git a/third_party/rust/chromium_crates_io/vendor/temporal_rs-v0_2/src/builtins/compiled/duration/tests.rs b/third_party/rust/chromium_crates_io/vendor/temporal_rs-v0_2/src/builtins/compiled/duration/tests.rs
