From cae696aaf11e7a40fd62383b12e8747f6250b53e Mon Sep 17 00:00:00 2001
From: Dominik Röttsches <drott@chromium.org>
Date: Thu, 2 Apr 2026 14:47:38 +0300
Subject: [PATCH] Allow resumable EOF in lexer state

Introduces ability encounter a temporary EOF in chunked reading for
comment, CDATA, PI and DOCTYPE.

https://github.com/kornelski/xml-rs/pull/74
---
 .../vendor/xml-v1/src/reader/parser.rs        | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/third_party/rust/chromium_crates_io/vendor/xml-v1/src/reader/parser.rs b/third_party/rust/chromium_crates_io/vendor/xml-v1/src/reader/parser.rs
index 6baa84b9c9f8e..8d7f1395e0829 100644
--- a/third_party/rust/chromium_crates_io/vendor/xml-v1/src/reader/parser.rs
+++ b/third_party/rust/chromium_crates_io/vendor/xml-v1/src/reader/parser.rs
@@ -411,6 +411,10 @@ impl PullParser {
                 },
                 Err(lexer_error) => {
                     self.next_pos();
+                    if self.config.ignore_end_of_stream {
+                        self.lexer.reset_eof_handled();
+                        return Err(lexer_error);
+                    }
                     return self.set_final_result(Err(lexer_error));
                 },
             }
@@ -423,6 +427,14 @@ impl PullParser {
         let ev = if self.depth() == 0 {
             if self.encountered == Encountered::Element && self.st == State::OutsideTag {  // all is ok
                 Ok(XmlEvent::EndDocument)
+            } else if self.config.ignore_end_of_stream {
+                self.final_result = None;
+                self.lexer.reset_eof_handled();
+                return if self.encountered < Encountered::Element {
+                    self.error(SyntaxError::NoRootElement)
+                } else {
+                    self.error(SyntaxError::UnexpectedEof)
+                };
             } else if self.encountered < Encountered::Element {
                 self.error(SyntaxError::NoRootElement)
             } else {  // self.st != State::OutsideTag
