group("screen_ai") {
  # Note that this group depends on data that must be used only for test. If we
  # need to remove/update the testonly variable below, we must go through a
  # security review.
  testonly = true
  if (is_linux) {
    data_deps = [ "//third_party/screen-ai/linux:screen_ai_resources" ]
  } else if (is_mac && target_cpu == "amd4") {
    data_deps = [ "//third_party/screen-ai/macos_amd64:screen_ai_resources" ]
  } else if (is_mac && target_cpu == "arm64") {
    data_deps = [ "//third_party/screen-ai/macos_arm64:screen_ai_resources" ]
  }
}
