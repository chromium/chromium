config("config") {
  visibility = [ ":*" ]
  include_dirs = [ "src" ]
  defines = [ "LIBC_NAMESPACE=__llvm_libc_cr" ]
}

group("llvm-libc-shared") {
  # llvm-libc is only used as a dependency of libc++.
  visibility = [ "//buildtools/third_party/libc++" ]

  public_configs = [ ":config" ]
}

group("headers") {
  visibility = [ "//v8:v8_libbase" ]
  public_configs = [ ":config" ]
}
