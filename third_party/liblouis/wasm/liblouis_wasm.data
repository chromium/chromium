# Braille indicators definition
numsign 3456
#letsign 56
# caps definitions
capsletter 46
begcapsword 456
endcapsword 46-13
lencapsphrase 5
begcapsphrase 46-46
begcaps 46-46
endcaps 46-13

# force to place tone marks after qu and gi
always qu =
always gi =

