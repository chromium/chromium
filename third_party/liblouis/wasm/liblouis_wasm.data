#This file containing only backtranslation correction related rules, for example inside a word have cscs letters, szsz letters, etc.
#Because in hungarian Braille usual the dot combinations equals with single consonants letters and double consonants letters (for example 146 with cs, 146-146 with ccs, and 146-146 with cscs), need doing last correction when happening a back translation
#cscs, ccs word part related backtranslate corrections
nofor correct "aganccsap" "agancscsap"	For example agancscsapr├│l word
nofor correct "apoccsont" "apocscsont"	For example ├ílkapocscsont, sz├írkapocscsont, sz├írkapocscsonttal word part corrections
nofor correct "kapocscsal" "kapoccsal"
nofor correct "cs├║ccsap" "cs├║cscsap"	For example cs├║cscsapat word
nofor correct "erk├Âlccs┼æ" "erk├Âlcscs┼æ"	For example erk├Âlcscs┼æsz, erk├Âlcscs┼æsszel words backtranslation correction
nofor correct "furdanccsi" "furdancscsi"	With furdancscsiga backtranslation correction
nofor correct "habarccs├Â" "habarcscs├Â"	For example habarcscs├Âvekkel, habarcscs├Âvet words backtranslation word correction
nofor correct "habarccs┼æ" "habarcscs┼æ"	Similar correction, for example habarcscs┼ævel, habarcscs┼æ word
nofor correct "orb├íccsap" "orb├ícscsap"	For example korb├ícscsap├ís word backtranslation correction
nofor correct "ulccse" "ulcscse"	With kulcscsere word part backtranslation correction
nofor correct "ulccso" "ulcscso"	For example kulcscsom├│, kulcscsomag, kulcscsont backtranslation words corrections
nofor correct "ulccs├Â" "ulcscs├Â"	For example ├ífakulcscs├Âkkent├®s, kulcscs├Ârg├®s words backtranslation correction
nofor correct "ullanccsi" "ullancscsi"	With kullancscsipesz word part correction
nofor correct "ullanccs├¡" "ullancscs├¡"	With kullancscs├¡p├®s word correction
nofor correct "anccsap" "ancscsap"	For example mancsap├íssal word backtranslation
nofor correct "kinccsemp" "kincscsemp"	With m┼▒kincscsemp├®sz word part backtranslation
nofor correct "felejccsok" "felejcscsok"	For example nefelejcscsokorral word part
nofor correct "ak├íccsapat" "ak├ícscsapat"	For example szak├ícscsapat word
nofor correct "endviccsi" "endvicscsi"	For example szendvicscsin├íl├ís word
nofor correct "an├íccsap" "an├ícscsap"
nofor correct "tan├íccsop" "tan├ícscsop"	For example tan├ícscsoport word correction
nofor correct "kart├ícscsal" "kart├íccsal"	For example f├®mkart├íccsal, kart├íccsal words backtranslation
nofor correct "narancscsal" "naranccsal"


#ggy, gygy backtranslation rule corrections
nofor correct "jeggy┼▒r" "jegygy┼▒r"	For example jegygy┼▒r┼▒, jegygy┼▒r┼▒vel words backtranslation correction
nofor correct "├írggy┼▒" "├írgygy┼▒"	For example t├írgygy┼▒jtem├®ny, kegyt├írgygy┼▒jtem├®ny words backtranslation corrections
nofor correct "csap├íggy├í" "csap├ígygy├í"	For example csap├ígygy├ír, csap├ígygy├írt├ís, csap├ígygy├ír├íban word
nofor correct "naggy┼▒" "nagygy┼▒"	For example nagygy┼▒l├®s, nagygy┼▒l├®sen words backtranslation correction
nofor correct "t┼æggyull" "t┼ægygyull"	For example t┼ægygyullad├ís word backtranslation correction

#nyny, nyny letters related backtranslate corrections
nofor correct "arannyel" "aranynyel"	For example aranynyel┼▒ word
nofor correct "asszonnyer" "asszonynyer"	For example asszonynyereg word back translation
nofor correct "b├ír├ínnyelv" "b├ír├ínynyelv"	For example b├ír├ínynyelv, b├ír├ínynyelvb┼æl, b├ír├ínynyelvvel words
nofor correct "b├ír├ínny├¡" "b├ír├ínyny├¡"	For example b├ír├ínyny├¡r├│k├®nt word back translation
nofor correct "boszork├ínnyom" "boszork├ínynyom"
nofor correct "├ík├ínny├®l" "├ík├ínyny├®l"	For example cs├ík├ínny├®l, cs├ík├ínyny├®lb┼æl, cs├ík├ínyny├®l words
nofor correct "├®nnyal" "├®nynyal"	For example ed├®nynyal├íbokban, ed├®nynyal├íbokb├│l, ed├®nynyal├íbr├│l, f├®nynyal├íbbal, f├®nynyal├íbb├│l, f├®nynyal├íbokban, f├®nynyal├íbokkal word
