display \x00e8 23568    # 232 Ãš    LATIN SMALL LETTER E WITH GRAVE
display \x00ec 2368     # 236 Ã¬    LATIN SMALL LETTER I WITH GRAVE
display \x00f2 358      # 242 Ã²    LATIN SMALL LETTER O WITH GRAVE
display \x00f9 3568     # 249 Ã¹    LATIN SMALL LETTER U WITH GRAVE

