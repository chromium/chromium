#####   Start of Unicode


#   Unicode:  Basic Latin

display ! 2346
punctuation ! 235
nofor postpunc ! 235
match %a ! %a 56-235

display " 5
punctuation " 6-2356
# The "?" symbol is mostly handled below,
# but the pattern needs to be defined before prepunc and postpunc can be used.
display ? 1456
nofor punctuation ? 236
nofor punctuation " 356
nofor prepunc " 236
nofor postpunc " 356
match %[^_~]%<* " %[_.$]*%[a#] 236
match %[a#]%[_.$]* " %>*%[^_~] 356

display # 3456
sign # 456-1456
display $ 1246
sign $ 4-234
display % 146
sign % 46-356
display & 12346
sign & 4-12346
display ' 3
punctuation ' 3
display ( 12356
punctuation ( 5-126
display ) 23456
punctuation ) 5-345
display * 16
sign * 5-35
display + 346
math + 5-235
display , 6
punctuation , 2
match %a , %a 56-2
display - 36
punctuation - 36
hyphen - 36
display . 46
punctuation . 256
display / 34
math / 456-34
# 0-9   see Numeric Symbols
display : 156
punctuation : 25
postpunc : 25
match %a : %a 56-25
