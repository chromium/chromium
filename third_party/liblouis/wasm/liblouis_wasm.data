#largesign \x00D0 4-15     [D0] upper eth
#largesign \x00F0   4-15     [F0] lower eth

#largesign \x00D1 4-1345   [D1] upper n tilde
#largesign \x00F1   4-1345   [F1] lower n tilde

largesign \x00D2 23-135    [D2] upper o grave
