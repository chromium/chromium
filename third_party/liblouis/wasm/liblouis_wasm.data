#######################
# General Punctuation #
#######################

# Hyphen
sign	-	36
hyphen	-	36

punctuation	'	3	# ÔÇÖ Apostrophe
always '\x03C2 3-234
always \x03C3' 234-3

punctuation , 2 # , Comma
midnum , 2 # Decimal Point

punctuation	:	25	# : Colon

punctuation	\x0387	23	# ╬ç Ano Teleia (Semicolon)
punctuation	\x1FBD	3	# ß¥¢ Koronis (Apostrophe)
punctuation	\x2015	6-36	# ÔÇò Dialog (Horizontal) Bar
punctuation	\x2018	3	# ÔÇÿ Left Single Quote
punctuation	\x2019	3	# ÔÇÖ Right Single Quote
punctuation	\x2026	3-3-3	# ÔÇª Horizontal Ellipsis

#########
# Signs #
#########

sign	*	35-35	# Asterisk
sign	/	34	# Slash
sign	_	456	# Underline
sign	@	4-1	# At Sign
sign	%	4-356	# Percent Sign
sign	Ôé¼	4-15	# Euro Sign
sign	$	4-234	# Dollar Sign

################
# Math Symbols #
################

math	+	346	# Addition

math	\x2212	36	# Subtraction
endnum	-	36	# Subtraction

math	\x00D7	46-16	# Multiplication
endnum	*	46-16	# Multiplication

math	\x00F7	46-34	# Division
endnum	/	46-34	# Division

math	=	46-13	# Equals
math	<	5-13	# Less Than
math	>	46-2	# Greater Than

#################
# Braille Cells #
#################

include braille-patterns.cti

##########################
# Positional Punctuation #
##########################

# . Period
punctuation . 256
midnum . 46 # Digit Grouping
postpunc . 256

# ┬½ Greek Opening Quotation Mark (Left-Pointing Double Angle Quotation Mark)
punctuation \x00AB 23678
prepunc     \x00AB 236

# ┬╗ Greek Closing Quotation Mark (Right-Pointing Double Angle Quotation Mark)
punctuation \x00BB 35678
postpunc    \x00BB 356

# "" English Quotation Marks
punctuation " 235678
prepunc     " 6-236
postpunc    " 356-3

# ( Opening Parenthesis
punctuation ( 23678
prepunc     ( 2356

# ) Closing Parenthesis
punctuation ) 35678
postpunc    ) 2356

# [ Opening Bracket
punctuation [ 1235678
prepunc     [ 12356

# ] Closing Bracket
punctuation ] 2345678
postpunc    ] 23456

# { Opening Brace
punctuation { 1234678
prepunc     { 12346

# } Closing Brace
punctuation } 1345678
postpunc    } 13456

# ? English Question Mark
punctuation ? 236
postpunc ? 236

# ! Exclamation Mark
punctuation	!	235
postpunc	!	235

# ═¥ Greek Question Mark
punctuation	\x037E	26
postpunc	\x037E	26

###########
# Numbers #
###########

include digits6Dots.uti

numsign 3456
include litdigits6Dots.uti

####################
# Greek Diphthongs #
####################

# For the diphthong contractions to be mroe easily coded,
# we first remove accents that don't generate any braille.

# The Dialytika isn't rendered in braille.
noback correct "\x03AA" "\x0399" # ╬¬╬Ö Capital Iota with Dialytika
noback correct "\x03CA" "\x03B9" # ¤è╬╣ Small Iota with Dialytika
noback correct "\x0390" "\x03AF" # ╬É╬» Small Iota with Dialytika and Tonos
noback correct "\x1FD3" "\x1F77" # ß┐ôß¢À Small Iota with Dialytika and Oxia
noback correct "\x1FD2" "\x1F76" # ß┐Æß¢Â Small Iota with Dialytika and Varia
noback correct "\x1FD7" "\x1FD6" # ß┐ùß┐û Small Iota with Dialytika and Perispomeni
noback correct "\x03AB" "\x03A5" # ╬½╬Ñ Capital Upsilon with Dialytika
noback correct "\x03CB" "\x03C5" # ¤ï¤à Small Upsilon with Dialytika
noback correct "\x03B0" "\x03CD" # ╬░¤ì Small Upsilon with Dialytika and Tonos
noback correct "\x1FE3" "\x1F7B" # ß┐úß¢╗ Small Upsilon with Dialytika and Oxia
noback correct "\x1FE2" "\x1F7A" # ß┐óß¢║ Small Upsilon with Dialytika and Varia
noback correct "\x1FE7" "\x1FE6" # ß┐ºß┐ª Small Upsilon with Dialytika and Perispomeni

# The Psili when not used with any other accent isn't rendered in braille.
noback correct "\x1F08" "\x0391" # ß╝ê╬æ Capital Alpha with Psili
noback correct "\x1F18" "\x0395" # ß╝ÿ╬ò Capital Epsilon with Psili
noback correct "\x1F28" "\x0397" # ß╝¿╬ù Capital Eta with Psili
noback correct "\x1F38" "\x0399" # ß╝©╬Ö Capital Iota with Psili
noback correct "\x1F48" "\x039F" # ß¢ê╬ƒ Capital Omicron with Psili
noback correct "\x1F68" "\x03A9" # ß¢¿╬® Capital Omega with Psili
noback correct "\x1F00" "\x03B1" # ß╝Ç╬▒ Small Alpha with Psili
noback correct "\x1F10" "\x03B5" # ß╝É╬Á Small Epsilon with Psili
noback correct "\x1F20" "\x03B7" # ß╝á╬À Small Eta with Psili
noback correct "\x1F30" "\x03B9" # ß╝░╬╣ Small Iota with Psili
noback correct "\x1F40" "\x03BF" # ß¢Ç╬┐ Small Omicron with Psili
noback correct "\x1FE4" "\x03C1" # ß┐ñ¤ü Small Rho with Psili
noback correct "\x1F50" "\x03C5" # ß¢É¤à Small Upsilon with Psili
noback correct "\x1F60" "\x03C9" # ß¢á¤ë Small Omega with Psili

# These are the diphthong contractions.
always \x03B1\x03B9	126	# ╬▒╬╣ Alpha Iota
always \x03B1\x03C5	16	# ╬▒¤à Alpha Upsilon
always \x03B5\x03B9	146	# ╬Á╬╣ Epsilon Iota
always \x03B5\x03C5	156	# ╬Á¤à Epsilon Upsilon
always \x03B7\x03C5	1256	# ╬À¤à Eta Upsilon
always \x03BF\x03B9	246	# ╬┐╬╣ Omicron Iota
always \x03BF\x03C5	136	# ╬┐¤à Omicron Upsilon
always \x03C5\x03B9	12456	# ¤à╬╣ Upsilon Iota

# Accents are always applied to the second vowel of a diphthong.

# For forward translation, move the accents to before the contraction.
noback pass2 @1[%accent]@24	*@126	# ╬▒╬╣ Alpha Iota
noback pass2 @1[%accent]@13456	*@16	# ╬▒¤à Alpha Upsilon
noback pass2 @15[%accent]@24	*@146	# ╬Á╬╣ Epsilon Iota
noback pass2 @15[%accent]@13456	*@156	# ╬Á¤à Epsilon Upsilon
noback pass2 @345[%accent]@13456	*@1256	# ╬À¤à Eta Upsilon
noback pass2 @135[%accent]@24	*@246	# ╬┐╬╣ Omicron Iota
noback pass2 @135[%accent]@13456	*@136	# ╬┐¤à Omicron Upsilon
noback pass2 @13456[%accent]@24	*@12456	# ¤à╬╣ Upsilon Iota

# For back translation, move the accents to before the second vowel.
nofor pass2 [%accent]@126	@1*@24	# ╬▒╬╣ Alpha Iota
nofor pass2 [%accent]@16	@1*@13456	# ╬▒¤à Alpha Upsilon
nofor pass2 [%accent]@146	@15*@24	# ╬Á╬╣ Epsilon Iota
nofor pass2 [%accent]@156	@15*@13456	# ╬Á¤à Epsilon Upsilon
nofor pass2 [%accent]@1256	@345*@13456	# ╬À¤à Eta Upsilon
nofor pass2 [%accent]@246	@135*@24	# ╬┐╬╣ Omicron Iota
nofor pass2 [%accent]@136	@135*@13456	# ╬┐¤à Omicron Upsilon
nofor pass2 [%accent]@12456	@13456*@24	# ¤à╬╣ Upsilon Iota

##############
# Indicators #
##############

capsletter	46
begcapsword 46-46

####################
# English Alphabet #
####################

# Define all of them as just letters in order to avoid Greek capital signs.
# Add virtual dot E to the uppercase letters, and virtual dot F to the
# lowercase letters, so that they have unique braille representations that
# don't overlap with those used for Greek characters.

# The uppercase English letters.
letter A 1e
letter B 12e
letter C 14e
letter D 145e
letter E 15e
letter F 124e
letter G 1245e
letter H 125e
letter I 24e
letter J 245e
letter K 13e
letter L 123e
letter M 134e
letter N 1345e
letter O 135e
letter P 1234e
letter Q 12345e
letter R 1235e
letter S 234e
letter T 2345e
letter U 136e
letter V 1236e
letter W 2456e
letter X 1346e
letter Y 13456e
letter Z 1356e

# The lowercase English letters.
letter a 1f
letter b 12f
letter c 14f
letter d 145f
letter e 15f
letter f 124f
letter g 1245f
letter h 125f
letter i 24f
letter j 245f
letter k 13f
letter l 123f
letter m 134f
letter n 1345f
letter o 135f
letter p 1234f
letter q 12345f
letter r 1235f
letter s 234f
letter t 2345f
letter u 136f
letter v 1236f
letter w 2456f
letter x 1346f
letter y 13456f
letter z 1356f

##########################################
# Forward Translation of English Letters #
##########################################

# Prepend the English letter sign to each block of English letters.
attribute englishLetter abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ
noback pass2 %englishLetter. @56*

# Prepend the English capital sign to each uppercase English letter.
attribute englishUpper ABCDEFGHIJKLMNOPQRSTUVWXYZ
noback pass3 %englishUpper @6*

# Remove virtual dot F from the lowercase English letters.
noback pass4 [@1F] @1 # a
noback pass4 [@12F] @12 # b
noback pass4 [@14F] @14 # c
noback pass4 [@145F] @145 # d
noback pass4 [@15F] @15 # e
noback pass4 [@124F] @124 # f
noback pass4 [@1245F] @1245 # g
noback pass4 [@125F] @125 # h
noback pass4 [@24F] @24 # i
noback pass4 [@245F] @245 # j
noback pass4 [@13F] @13 # k
noback pass4 [@123F] @123 # l
noback pass4 [@134F] @134 # m
noback pass4 [@1345F] @1345 # n
noback pass4 [@135F] @135 # o
noback pass4 [@1234F] @1234 # p
noback pass4 [@12345F] @12345 # q
noback pass4 [@1235F] @1235 # r
noback pass4 [@234F] @234 # s
noback pass4 [@2345F] @2345 # t
noback pass4 [@136F] @136 # u
noback pass4 [@1236F] @1236 # v
noback pass4 [@2456F] @2456 # w
noback pass4 [@1346F] @1346 # x
noback pass4 [@13456F] @13456 # y
noback pass4 [@1356F] @1356 # z

# Remove virtual dot E from the uppercase English letters.
noback pass4 [@1E] @1 # A
noback pass4 [@12E] @12 # B
noback pass4 [@14E] @14 # C
noback pass4 [@145E] @145 # D
noback pass4 [@15E] @15 # E
noback pass4 [@124E] @124 # F
noback pass4 [@1245E] @1245 # G
noback pass4 [@125E] @125 # H
noback pass4 [@24E] @24 # I
noback pass4 [@245E] @245 # J
noback pass4 [@13E] @13 # K
noback pass4 [@123E] @123 # L
noback pass4 [@134E] @134 # M
noback pass4 [@1345E] @1345 # N
noback pass4 [@135E] @135 # O
noback pass4 [@1234E] @1234 # P
noback pass4 [@12345E] @12345 # Q
noback pass4 [@1235E] @1235 # R
noback pass4 [@234E] @234 # S
noback pass4 [@2345E] @2345 # T
noback pass4 [@136E] @136 # U
noback pass4 [@1236E] @1236 # V
noback pass4 [@2456E] @2456 # W
noback pass4 [@1346E] @1346 # X
noback pass4 [@13456E] @13456 # Y
noback pass4 [@1356E] @1356 # Z

###########################################
# Backward Translation of English Letters #
###########################################

nofor pass2 @56 ?#1=1
nofor pass2 #1=1@6 ?#1=2
nofor pass2 [$a] *#1=0

# Add virtual dot F to indicate a lowercase English letter.
nofor pass2 #1=1@1 @1F # a
nofor pass2 #1=1@12 @12F # b
nofor pass2 #1=1@14 @14F # c
nofor pass2 #1=1@145 @145F # d
nofor pass2 #1=1@15 @15F # e
nofor pass2 #1=1@124 @124F # f
nofor pass2 #1=1@1245 @1245F # g
nofor pass2 #1=1@125 @125F # h
nofor pass2 #1=1@24 @24F # i
nofor pass2 #1=1@245 @245F # j
nofor pass2 #1=1@13 @13F # k
nofor pass2 #1=1@123 @123F # l
nofor pass2 #1=1@134 @134F # m
nofor pass2 #1=1@1345 @1345F # n
nofor pass2 #1=1@135 @135F # o
nofor pass2 #1=1@1234 @1234F # p
nofor pass2 #1=1@12345 @12345F # q
nofor pass2 #1=1@1235 @1235F # r
nofor pass2 #1=1@234 @234F # s
nofor pass2 #1=1@2345 @2345F # t
nofor pass2 #1=1@136 @136F # u
nofor pass2 #1=1@1236 @1236F # v
nofor pass2 #1=1@2456 @2456F # w
nofor pass2 #1=1@1346 @1346F # x
nofor pass2 #1=1@13456 @13456F # y
nofor pass2 #1=1@1356 @1356F # z

# Add virtual dot E to indicate an uppercase English letter.
nofor pass2 #1=2@1 @1E#1=1 # A
nofor pass2 #1=2@12 @12E#1=1 # B
nofor pass2 #1=2@14 @14E#1=1 # C
nofor pass2 #1=2@145 @145E#1=1 # D
nofor pass2 #1=2@15 @15E#1=1 # E
nofor pass2 #1=2@124 @124E#1=1 # F
nofor pass2 #1=2@1245 @1245E#1=1 # G
nofor pass2 #1=2@125 @125E#1=1 # H
nofor pass2 #1=2@24 @24E#1=1 # I
nofor pass2 #1=2@245 @245E#1=1 # J
nofor pass2 #1=2@13 @13E#1=1 # K
nofor pass2 #1=2@123 @123E#1=1 # L
nofor pass2 #1=2@134 @134E#1=1 # M
nofor pass2 #1=2@1345 @1345E#1=1 # N
