display \x00c1 1678     # 193 Ã    LATIN CAPITAL LETTER A WITH ACUTE
display \x00c9 12678    # 201 Ã    LATIN CAPITAL LETTER E WITH ACUTE
display \x00cd 14678    # 205 Ã    LATIN CAPITAL LETTER I WITH ACUTE
