display \x00f3 14568    # 243 Ã³    LATIN SMALL LETTER O WITH ACUTE
display \x00fa 1568     # 250 Ãº    LATIN SMALL LETTER U WITH ACUTE
display \x00fd 12468    # 253 Ãœ    LATIN SMALL LETTER Y WITH ACUTE

# The 6 letters with a dieresis accent (Âš) use the [f-j] dot combinations with
