#  Maintained by Christo de Klerk <cjdk@mweb.co.za>

# Begin entries

# Some sign definitions which might otherwise conflict with Afrikaans contractions:
sign \x00b0 56-45-245 В°
sign \x00a7 56-45-234 В§ section
sign \x2122 56-45-2345 в„ў
sign \x25cb 56-1246-123456 в—Ӣ   circle

include afr-za-g1.ctb
include IPA-unicode-range.uti

multind 56-6 nocontractsign capsletter

seqdelimiter -вҖ”
seqdelimiter вҖҗ   \x2010
seqdelimiter вҖ‘   \x2011
seqdelimiter вҖ“   \x2013
seqdelimiter вҖ”   \x2014
seqbeforechars ([{"вҖң'вҖҳ
seqafterchars  )]}"вҖқ'вҖҷ.,;:.!?вҖҰ

noback correct "вҖҷ" "'"
noback correct "Еү" "'n"

attribute 1 AEIOUYГҠГӢaeiouyГӘГ« vowels
attribute 2 BCDFGHJKLMNPQRSTVWXZbcdfghjklmnpqrstvwxz consonants
attribute 3 +=*,.;:?!"'вҖңвҖқвҖҳвҖҷ  punctuation with only lower dots (except hyphens)

# Shape symbols require a grade 1 indicator (Section 3.22.1)
contraction \x25a0 в–  filled (solid) square
contraction \x25a1 в–Ў square
contraction \x25a7 в–§ shaded square (upper left to lower right)
contraction \x25b2 в–І filled (solid) (equilateral) triangle
contraction \x25b3 в–і regular (equilateral) triangle
contraction \x25cb в—Ӣ circle
contraction \x25cd в—Қ shaded circle

