nofor context #5=1@345 "\x00e4"
nofor context #5=1@246 "\x00f6"
nofor context #5=1@1256 "\x00fc"

nofor context [@46] #5=2			# Input an uppercase Latin letter

nofor context #5=2@1 "A"#5=1
nofor context #5=2@12 "B"#5=1
