#######################
# General Punctuation #
#######################

# Hyphen
sign	-	36
hyphen	-	36

punctuation	'	3	# â Apostrophe
always '\x03C2 3-234
always \x03C3' 234-3

punctuation , 2 # , Comma
midnum , 2 # Decimal Point

punctuation	:	25	# : Colon

punctuation	\x0387	23	# Î Ano Teleia (Semicolon)
punctuation	\x1FBD	3	# áŸœ Koronis (Apostrophe)
punctuation	\x2015	6-36	# â Dialog (Horizontal) Bar
punctuation	\x2018	3	# â Left Single Quote
punctuation	\x2019	3	# â Right Single Quote
punctuation	\x2026	3-3-3	# âŠ Horizontal Ellipsis

#########
# Signs #
#########

sign	*	35-35	# Asterisk
sign	/	34	# Slash
sign	_	456	# Underline
sign	@	4-1	# At Sign
sign	%	4-356	# Percent Sign
sign	â¬	4-15	# Euro Sign
sign	$	4-234	# Dollar Sign

################
# Math Symbols #
################

math	+	346	# Addition

math	\x2212	36	# Subtraction
endnum	-	36	# Subtraction

math	\x00D7	46-16	# Multiplication
endnum	*	46-16	# Multiplication

math	\x00F7	46-34	# Division
endnum	/	46-34	# Division

math	=	46-13	# Equals
math	<	5-13	# Less Than
math	>	46-2	# Greater Than

#################
# Braille Cells #
#################

include braille-patterns.cti

##########################
# Positional Punctuation #
##########################

# . Period
punctuation . 256
midnum . 46 # Digit Grouping
postpunc . 256

# Â« Greek Opening Quotation Mark (Left-Pointing Double Angle Quotation Mark)
punctuation \x00AB 23678
prepunc     \x00AB 236

# Â» Greek Closing Quotation Mark (Right-Pointing Double Angle Quotation Mark)
punctuation \x00BB 35678
postpunc    \x00BB 356

# "" English Quotation Marks
punctuation " 235678
prepunc     " 6-236
postpunc    " 356-3

# ( Opening Parenthesis
punctuation ( 23678
prepunc     ( 2356

# ) Closing Parenthesis
punctuation ) 35678
postpunc    ) 2356

# [ Opening Bracket
punctuation [ 1235678
prepunc     [ 12356

# ] Closing Bracket
punctuation ] 2345678
postpunc    ] 23456

# { Opening Brace
punctuation { 1234678
prepunc     { 12346

# } Closing Brace
punctuation } 1345678
postpunc    } 13456

# ? English Question Mark
punctuation ? 236
postpunc ? 236

# ! Exclamation Mark
punctuation	!	235
postpunc	!	235

# ÍŸ Greek Question Mark
punctuation	\x037E	26
postpunc	\x037E	26

###########
# Numbers #
###########

include digits6Dots.uti

numsign 3456
include litdigits6Dots.uti

####################
# Greek Diphthongs #
####################

# For the diphthong contractions to be mroe easily coded,
# we first remove accents that don't generate any braille.

# The Dialytika isn't rendered in braille.
noback correct "\x03AA" "\x0399" # ÎªÎ Capital Iota with Dialytika
noback correct "\x03CA" "\x03B9" # ÏÎ¹ Small Iota with Dialytika
noback correct "\x0390" "\x03AF" # ÎÎ¯ Small Iota with Dialytika and Tonos
noback correct "\x1FD3" "\x1F77" # á¿áœ· Small Iota with Dialytika and Oxia
noback correct "\x1FD2" "\x1F76" # á¿áœ¶ Small Iota with Dialytika and Varia
noback correct "\x1FD7" "\x1FD6" # á¿á¿ Small Iota with Dialytika and Perispomeni
noback correct "\x03AB" "\x03A5" # Î«Î¥ Capital Upsilon with Dialytika
noback correct "\x03CB" "\x03C5" # ÏÏ Small Upsilon with Dialytika
noback correct "\x03B0" "\x03CD" # Î°Ï Small Upsilon with Dialytika and Tonos
noback correct "\x1FE3" "\x1F7B" # á¿£áœ» Small Upsilon with Dialytika and Oxia
noback correct "\x1FE2" "\x1F7A" # á¿¢áœº Small Upsilon with Dialytika and Varia
noback correct "\x1FE7" "\x1FE6" # á¿§á¿Š Small Upsilon with Dialytika and Perispomeni

# The Psili when not used with any other accent isn't rendered in braille.
noback correct "\x1F08" "\x0391" # áŒÎ Capital Alpha with Psili
noback correct "\x1F18" "\x0395" # áŒÎ Capital Epsilon with Psili
noback correct "\x1F28" "\x0397" # áŒšÎ Capital Eta with Psili
noback correct "\x1F38" "\x0399" # áŒžÎ Capital Iota with Psili
noback correct "\x1F48" "\x039F" # áœÎ Capital Omicron with Psili
noback correct "\x1F68" "\x03A9" # áœšÎ© Capital Omega with Psili
noback correct "\x1F00" "\x03B1" # áŒÎ± Small Alpha with Psili
noback correct "\x1F10" "\x03B5" # áŒÎµ Small Epsilon with Psili
noback correct "\x1F20" "\x03B7" # áŒ Î· Small Eta with Psili
noback correct "\x1F30" "\x03B9" # áŒ°Î¹ Small Iota with Psili
noback correct "\x1F40" "\x03BF" # áœÎ¿ Small Omicron with Psili
noback correct "\x1FE4" "\x03C1" # á¿€Ï Small Rho with Psili
noback correct "\x1F50" "\x03C5" # áœÏ Small Upsilon with Psili
noback correct "\x1F60" "\x03C9" # áœ Ï Small Omega with Psili

# These are the diphthong contractions.
always \x03B1\x03B9	126	# Î±Î¹ Alpha Iota
always \x03B1\x03C5	16	# Î±Ï Alpha Upsilon
always \x03B5\x03B9	146	# ÎµÎ¹ Epsilon Iota
always \x03B5\x03C5	156	# ÎµÏ Epsilon Upsilon
always \x03B7\x03C5	1256	# Î·Ï Eta Upsilon
always \x03BF\x03B9	246	# Î¿Î¹ Omicron Iota
always \x03BF\x03C5	136	# Î¿Ï Omicron Upsilon
always \x03C5\x03B9	12456	# ÏÎ¹ Upsilon Iota

# Accents are always applied to the second vowel of a diphthong.

# For forward translation, move the accents to before the contraction.
noback pass2 @1[%accent]@24	*@126	# Î±Î¹ Alpha Iota
noback pass2 @1[%accent]@13456	*@16	# Î±Ï Alpha Upsilon
noback pass2 @15[%accent]@24	*@146	# ÎµÎ¹ Epsilon Iota
noback pass2 @15[%accent]@13456	*@156	# ÎµÏ Epsilon Upsilon
noback pass2 @345[%accent]@13456	*@1256	# Î·Ï Eta Upsilon
noback pass2 @135[%accent]@24	*@246	# Î¿Î¹ Omicron Iota
noback pass2 @135[%accent]@13456	*@136	# Î¿Ï Omicron Upsilon
noback pass2 @13456[%accent]@24	*@12456	# ÏÎ¹ Upsilon Iota

# For back translation, move the accents to before the second vowel.
nofor pass2 [%accent]@126	@1*@24	# Î±Î¹ Alpha Iota
nofor pass2 [%accent]@16	@1*@13456	# Î±Ï Alpha Upsilon
nofor pass2 [%accent]@146	@15*@24	# ÎµÎ¹ Epsilon Iota
nofor pass2 [%accent]@156	@15*@13456	# ÎµÏ Epsilon Upsilon
nofor pass2 [%accent]@1256	@345*@13456	# Î·Ï Eta Upsilon
nofor pass2 [%accent]@246	@135*@24	# Î¿Î¹ Omicron Iota
nofor pass2 [%accent]@136	@135*@13456	# Î¿Ï Omicron Upsilon
nofor pass2 [%accent]@12456	@13456*@24	# ÏÎ¹ Upsilon Iota

##############
# Indicators #
##############

capsletter	46
begcapsword 46-46

####################
# English Alphabet #
####################

# Define all of them as just letters in order to avoid Greek capital signs.
# Add virtual dot E to the uppercase letters, and virtual dot F to the
# lowercase letters, so that they have unique braille representations that
# don't overlap with those used for Greek characters.

# The uppercase English letters.
letter A 1e
letter B 12e
letter C 14e
letter D 145e
letter E 15e
letter F 124e
letter G 1245e
letter H 125e
letter I 24e
letter J 245e
letter K 13e
letter L 123e
letter M 134e
letter N 1345e
letter O 135e
letter P 1234e
letter Q 12345e
letter R 1235e
letter S 234e
letter T 2345e
letter U 136e
letter V 1236e
letter W 2456e
letter X 1346e
letter Y 13456e
letter Z 1356e

# The lowercase English letters.
letter a 1f
letter b 12f
letter c 14f
letter d 145f
letter e 15f
letter f 124f
letter g 1245f
letter h 125f
