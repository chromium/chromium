#-index-name: Vietnamese, Saigon, contracted
#-display-name: Southern Vietnamese braille
#
#+language: vi
#+type: literary
#+contraction: full
#+grade: 1
#+dots: 6
#+direction: forward
#+system: saigon
#
#-copyright: Sao Mai Center for the Blind <www.saomaicenter.org/en>
