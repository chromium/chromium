numsign 3456
letsign 56
capsletter 6
begcapsword 6-6
endcapsword 6-3
lencapsphrase 3
begcapsphrase 6-6-6
begcaps 6-6-6
endcaps 6-3

# time processing with : as saperator sign
noback match %# :0 %# 45-245
noback match %# :1 %# 45-1
noback match %# :2 %# 45-12
noback match %# :3 %# 45-14
noback match %# :4 %# 45-145
noback match %# :5 %# 45-15
noback match %# '0 %# 3-245
