#
# Based on <https://www.saomaicenter.org/en/blog/accessible-formats/vietnamese-saigon-braille-grade-1>
#
# This braille system still used by many visually impaired adults in the Southern area of Vietnam.

include vi-charsdef.uti

# Braille indicators definition
numsign 3456
#letsign 6
# caps indicator
capsletter 46
begcapsword 456
endcapsword 46-13
lencapsphrase 5
begcapsphrase 46-46
begcaps 46-46
endcaps 46-13
# no letter sign before Vietnamese single-letter words
#noletsign ГЎГ бәЈГЈбәЎбәҜбәұбәібәөбә·бәҘбә§бә©бә«бәӯГ©ГЁбә»бәҪбә№бәҝб»Ғб»ғб»…б»ҮГӯГ¬б»үД©б»ӢГіГІб»ҸГөб»Қб»‘б»“б»•б»—б»ҷб»ӣб»қб»ҹб»Ўб»ЈГәГ№б»§Е©б»Ҙб»©б»«б»ӯб»Ҝб»ұГҪб»іб»·б»№б»ө
#word a =
#word e =
#word ГӘ =
#word i =
#word o =
#word Гҙ =
#word ЖЎ =
#word u =
#word Ж° =
#word y =

# special contracted words
always quyбәҝn 12345-35-2356
always quyб»Ғn 12345-56-2356
always quyб»ғn 12345-26-2356
always quyб»…n 12345-36-2356
always quyб»Үn 12345-6-2356
always quyбәҝt 12345-356
always quyб»Үt 12345-6-356
always giГӘng 245-12
always giбәҝng 245-35-12
always giб»Ғng 245-56-12
always yГӘn 13456-1345
always yбәҝn 35-13456-1345

# words contraction
match %[^_]|[\x0022\x0028\x0027\x007B\x005B] cГі %[_^.] 1
match %[^_]|[\x0022\x0028\x0027\x007B\x005B] cб»§a %[_^.] 145
match %[^_]|[\x0022\x0028\x0027\x007B\x005B] lГ  %[_^.] 156
