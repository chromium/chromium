# liblouis: Malay Braille Code (Grade 2)
#
#-display-name: Malay braille
#-index-name: Malay
#
#+language:ms
#+type:literary
#+contraction:full
#+grade:2
#+dots:6
# Marked as "direction:forward" by Bue Vester-Andersen
# as tests only run forward.
