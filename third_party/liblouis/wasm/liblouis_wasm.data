match - \x17BB\x17C6 - 1246
match - \x17B6\x17C6 - 1356
match - \x17BB\x17C7 - 1346
match - \x17C1\x17C7 - 136
match - \x17C4\x17C7 - 2346	
# add v subscript for consonants
letter \x17D2 1236
