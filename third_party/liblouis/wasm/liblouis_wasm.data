#   10.5   Lower Wordsigns
#   - 10.5.1   be were his was
#   - 10.5.2   enough
#   - 10.5.3   in
#   - 10.5.4   enough in

attribute 1 +=*,.;:?!"'ÔÇ£ÔÇØÔÇÿÔÇÖ  punctuation with only lower dots (except hyphens)
#attribute lowerdotspunc +=*,.?!"'ÔÇ£ÔÇØÔÇÿÔÇÖ

# be
