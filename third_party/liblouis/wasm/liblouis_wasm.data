noback pass3 %super%super. *@356

# fix order of super sign and number sign
noback pass3 @3456-46-236 @46-236-3456
noback pass3 @3456-46 @46-3456

noback pass4 @245b  @245  # â°
noback pass4 @1b    @1    # Â¹
noback pass4 @12b   @12   # Â²
noback pass4 @14b   @14   # Â³
noback pass4 @145b  @145  # âŽ
noback pass4 @15b   @15   # âµ
