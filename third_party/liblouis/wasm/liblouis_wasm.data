# The6 letters with an acute accent ') use the [a-f] dot combinations with
# dots 3 and 6 added:

#Hex Dots Dec Char Description
letter \x00C1 28 # 193├ü Latin capital letter a with acute
letter \x00C9 1234567 # 201├ë Latin capital letter e with acute
letter \x00CD 258 # 205├ì Latin capital letter i with acute
letter \x00D3 267 # 211├ô Latin capital letter o with acute
letter \x00DA 268 # 218├Ü Latin capital letter u with acute
letter \x00DD 3568 # 221├Ø Latin capital letter y with acute
letter \x00E1 168 # 225├í Latin small letter a with acute
letter \x00E9 123456 # 233├® Latin small letter e with acute
letter \x00ED 2478 # 237├¡ Latin small letter i with acute
letter \x00F3 13578 # 243├│ Latin small letter o with acute
letter \x00FA 13678 # 250├║ Latin small letter u with acute
letter \x00FD 24568 # 253├¢ Latin small letter y with acute

# The 6 letters with a dieresis accent ") use the [f-j] dot combinations with
# dots 3 and 6 added, and the number sign because it fits the sequence
# reasonably well):

#Hex Dots Dec Char Description
letter \x00C4 3457 # 196├ä Latin capital letter a with diaeresis
letter \x00CB 2358 # 203├ï Latin capital letter e with diaeresis
letter \x00CF 23568 # 207├Å Latin capital letter i with diaeresis
letter \x00D6  2467 # 214├û Latin capital letter o with diaeresis
letter \x00DC  12567 # 220├£ Latin capital letter u with diaeresis
letter \x00E4 345 # 228├ñ Latin small letter a with diaeresis
letter \x00EB 12468 # 235├½ Latin small letter e with diaeresis
letter \x00EF 124568 # 239├» Latin small letter i with diaeresis
letter \x00F6  246 # 246├Â Latin small letter o with diaeresis
letter \x00FC  1256 # 252├╝ Latin small letter u with diaeresis
letter \x00FF 134568 # 255├┐ Latin small letter y with diaeresis

# There is no uppercase y-dieresis in the  Latin 1 character set. The German
# lowercase double-s, which also doesn't have an uppercase counterpart in the
#  Latin 1 character set, uses its representation:

#Hex Dots Dec Char Description
letter \x00DF 34568 # 223├ƒ Latin small letter sharp s

# The remaining accented letters are:

#Hex Dots Dec Char Description
letter \x00C3 3467 # 195├â Latin capital letter a with tilde
letter \x00D1 2567 # 209├æ Latin capital letter n with tilde
letter \x00D5  267 # 213├ò Latin capital letter o with tilde
letter \x00C5 167 # 197├à Latin capital letter a with ring above
letter \x00C7 1578 # 199├ç Latin capital letter c with cedilla
letter \x00D8 1567 # 216├ÿ Latin capital letter o with stroke
letter \x00C6 47 # 198├å Latin capital letter ae
letter \x00D0 3567 # 208├É Latin capital letter eth
letter \x00DE 2357 # 222├× Latin capital letter thorn
letter \x00E3 13678 # 227├ú Latin small letter a with tilde
letter \x00F1 13458 # 241├▒ Latin small letter n with tilde
letter \x00F5  1358 # 245├Á Latin small letter o with tilde
letter \x00E5 16 # 229├Ñ Latin small letter a with ring above
letter \x00E7 1234678 # 231├º Latin small letter c with cedilla
letter \x00F8 24678 # 248├© Latin small letter o with stroke
letter \x00E6 34578 # 230├ª Latin small letter ae
letter \x00F0 23458 # 240├░ Latin small letter eth
letter \x00FE 12348 # 254├¥ Latin small letter thorn
