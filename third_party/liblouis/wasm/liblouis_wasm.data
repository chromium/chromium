emphclass italic
emphclass underline
emphclass bold

begemphphrase italic 46-46
endemphphrase italic before 46
lenemphphrase italic 4
begemphword italic 46
endemphword italic 6-3

begemphphrase bold 456-46-46
endemphphrase bold before 456-46
lenemphphrase bold 4
begemphword bold 456-46
endemphword bold 6-3

begemphphrase underline 0-456-36-0
endemphphrase underline after 0-6-3-0
lenemphphrase underline 1
# liblouis: Russian literary (grade 1) text translation table
#
#-index-name: Russian, contracted
#-display-name: Russian contracted braille
#
#+locale: ru
#+type: literary
#+dots: 6
#+contraction: partial
#+grade:1
#+direction: forward
#
#  Copyright (C) 2021 Ekaterina Anisimova <musicate@yandex.ru>
#  Copyright (C) 2021 Andrey Yakuboy <andrewia2002@yandex.ru>
#
#  This file is part of liblouis.
