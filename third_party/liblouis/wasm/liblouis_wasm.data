display \x00db 2678     # 219 Гӣ    LATIN CAPITAL LETTER U WITH CIRCUMFLEX
display \x00e2 28       # 226 Гў    LATIN SMALL LETTER A WITH CIRCUMFLEX
display \x00ea 238      # 234 ГӘ    LATIN SMALL LETTER E WITH CIRCUMFLEX
display \x00ee 258      # 238 Г®    LATIN SMALL LETTER I WITH CIRCUMFLEX
display \x00f4 2568     # 244 Гҙ    LATIN SMALL LETTER O WITH CIRCUMFLEX
display \x00fb 268      # 251 Г»    LATIN SMALL LETTER U WITH CIRCUMFLEX

# The 5 letters with a grave accent (`) use the [6-0] dot combinations:

        #Hex   Dots       Dec Char Description
display \x00c0 23578    # 192 ГҖ    LATIN CAPITAL LETTER A WITH GRAVE
display \x00c8 235678   # 200 ГҲ    LATIN CAPITAL LETTER E WITH GRAVE
display \x00cc 23678    # 204 ГҢ    LATIN CAPITAL LETTER I WITH GRAVE
display \x00d2 3578     # 210 Г’    LATIN CAPITAL LETTER O WITH GRAVE
display \x00d9 35678    # 217 Гҷ    LATIN CAPITAL LETTER U WITH GRAVE
display \x00e0 2358     # 224 Г     LATIN SMALL LETTER A WITH GRAVE
display \x00e8 23568    # 232 ГЁ    LATIN SMALL LETTER E WITH GRAVE
display \x00ec 2368     # 236 Г¬    LATIN SMALL LETTER I WITH GRAVE
display \x00f2 358      # 242 ГІ    LATIN SMALL LETTER O WITH GRAVE
display \x00f9 3568     # 249 Г№    LATIN SMALL LETTER U WITH GRAVE

# The 6 letters with an acute accent (Вҙ) use the [a-f] dot combinations with
# dots 6 and 8 added:

        #Hex   Dots       Dec Char Description
display \x00c1 1678     # 193 ГҒ    LATIN CAPITAL LETTER A WITH ACUTE
display \x00c9 12678    # 201 Гү    LATIN CAPITAL LETTER E WITH ACUTE
display \x00cd 14678    # 205 ГҚ    LATIN CAPITAL LETTER I WITH ACUTE
display \x00d3 145678   # 211 Г“    LATIN CAPITAL LETTER O WITH ACUTE
display \x00da 15678    # 218 Гҡ    LATIN CAPITAL LETTER U WITH ACUTE
display \x00dd 124678   # 221 Гқ    LATIN CAPITAL LETTER Y WITH ACUTE
display \x00e1 168      # 225 ГЎ    LATIN SMALL LETTER A WITH ACUTE
display \x00e9 1268     # 233 Г©    LATIN SMALL LETTER E WITH ACUTE
display \x00ed 1468     # 237 Гӯ    LATIN SMALL LETTER I WITH ACUTE
display \x00f3 14568    # 243 Гі    LATIN SMALL LETTER O WITH ACUTE
display \x00fa 1568     # 250 Гә    LATIN SMALL LETTER U WITH ACUTE
display \x00fd 12468    # 253 ГҪ    LATIN SMALL LETTER Y WITH ACUTE

# The 6 letters with a dieresis accent (ВЁ) use the [f-j] dot combinations with
# dots 3 and 6 added, and the number sign (because it fits the sequence
# reasonably well):

        #Hex   Dots       Dec Char Description
display \x00c4 1234678  # 196 Г„    LATIN CAPITAL LETTER A WITH DIAERESIS
display \x00cb 12345678 # 203 ГӢ    LATIN CAPITAL LETTER E WITH DIAERESIS
display \x00cf 1235678  # 207 ГҸ    LATIN CAPITAL LETTER I WITH DIAERESIS
display \x00d6 234678   # 214 Г–    LATIN CAPITAL LETTER O WITH DIAERESIS
display \x00dc 2345678  # 220 Гң    LATIN CAPITAL LETTER U WITH DIAERESIS
display \x00e4 123468   # 228 ГӨ    LATIN SMALL LETTER A WITH DIAERESIS
display \x00eb 1234568  # 235 Г«    LATIN SMALL LETTER E WITH DIAERESIS
display \x00ef 123568   # 239 ГҜ    LATIN SMALL LETTER I WITH DIAERESIS
display \x00f6 23468    # 246 Г¶    LATIN SMALL LETTER O WITH DIAERESIS
display \x00fc 234568   # 252 Гј    LATIN SMALL LETTER U WITH DIAERESIS
display \x00ff 34568    # 255 Гҝ    LATIN SMALL LETTER Y WITH DIAERESIS

# There is no uppercase y-dieresis in the Latin1 character set. The German
# lowercase double-s, which also doesn't have an uppercase counterpart in the
# Latin1 character set, uses its representation:

        #Hex   Dots       Dec Char Description
display \x00df 345678   # 223 Гҹ    LATIN SMALL LETTER SHARP S

# The remaining accented letters are:

        #Hex   Dots       Dec Char Description
display \x00c3 578      # 195 Гғ    LATIN CAPITAL LETTER A WITH TILDE
display \x00d1 4678     # 209 Г‘    LATIN CAPITAL LETTER N WITH TILDE
display \x00d5 5678     # 213 Г•    LATIN CAPITAL LETTER O WITH TILDE
display \x00c5 34578    # 197 Г…    LATIN CAPITAL LETTER A WITH RING ABOVE
display \x00c7 34678    # 199 ГҮ    LATIN CAPITAL LETTER C WITH CEDILLA
display \x00d8 3478     # 216 Гҳ    LATIN CAPITAL LETTER O WITH STROKE
display \x00c6 378      # 198 ГҶ    LATIN CAPITAL LETTER AE
display \x00d0 678      # 208 Гҗ    LATIN CAPITAL LETTER ETH
display \x00de 3678     # 222 Гһ    LATIN CAPITAL LETTER THORN
display \x00e3 58       # 227 ГЈ    LATIN SMALL LETTER A WITH TILDE
display \x00f1 468      # 241 Гұ    LATIN SMALL LETTER N WITH TILDE
display \x00f5 568      # 245 Гө    LATIN SMALL LETTER O WITH TILDE
display \x00e5 3458     # 229 ГҘ    LATIN SMALL LETTER A WITH RING ABOVE
display \x00e7 3468     # 231 Г§    LATIN SMALL LETTER C WITH CEDILLA
display \x00f8 348      # 248 Гё    LATIN SMALL LETTER O WITH STROKE
display \x00e6 38       # 230 ГҰ    LATIN SMALL LETTER AE
display \x00f0 68       # 240 Г°    LATIN SMALL LETTER ETH
display \x00fe 368      # 254 Гҫ    LATIN SMALL LETTER THORN

# Some characters are the same as other characters which they resemble but with
# dot 7 added:

        #Hex   Dots       Dec Char Description
display \x00ad 367      # 173 Вӯ    SOFT HYPHEN
display \x00ab 1267     # 171 В«    LEFT-POINTING DOUBLE ANGLE QUOTATION MARK
display \x00bb 3457     # 187 В»    RIGHT-POINTING DOUBLE ANGLE QUOTATION MARK
display \x00a6 1567     # 166 ВҰ    BROKEN BAR
display \x00b9 27       # 185 В№    SUPERSCRIPT ONE
display \x00b2 237      # 178 ВІ    SUPERSCRIPT TWO
display \x00b3 257      # 179 Ві    SUPERSCRIPT THREE
display \x00b1 3467     # 177 Вұ    PLUS-MINUS SIGN
display \x00d7 167      # 215 Г—    MULTIPLICATION SIGN
display \x00f7 347      # 247 Г·    DIVISION SIGN
display \x00b7 467      # 183 В·    MIDDLE DOT
display \x00a1 23467    # 161 ВЎ    INVERTED EXCLAMATION MARK
display \x00bf 14567    # 191 Вҝ    INVERTED QUESTION MARK
display \x00a2 12467    # 162 Вў    CENT SIGN
display \x00a3 34567    # 163 ВЈ    POUND SIGN

# A few more characters follow this same convention but their relationships
# to their base characters is a bit obscure:

        #Hex   Dots       Dec Char Description
display \x00a4 1467     # 164 ВӨ    CURRENCY SIGN
display \x00a5 123467   # 165 ВҘ    YEN SIGN

# Some characters are represented by the first letters of their names lowered
# by one row of dots:

        #Hex   Dots       Dec Char Description
display \x00ac 2567     # 172 В¬    NOT SIGN
display \x00b6 2357     # 182 В¶    PILCROW SIGN
display \x00a9 23567    # 169 В©    COPYRIGHT SIGN
display \x00ae 2367     # 174 В®    REGISTERED SIGN
display \x00a7 357      # 167 В§    SECTION SIGN
display \x00b0 3567     # 176 В°    DEGREE SIGN

# The three fraction characters use combinations of dots 1 and 4 (which
# progress from left to right as the value of the fraction increases) together
# with dots 2,3,5,6,7:

        #Hex   Dots       Dec Char Description
display \x00bc 123567   # 188 Вј    VULGAR FRACTION ONE QUARTER
display \x00bd 1234567  # 189 ВҪ    VULGAR FRACTION ONE HALF
display \x00be 234567   # 190 Вҫ    VULGAR FRACTION THREE QUARTERS

# Each of the three extended accent characters is the same as its conventional
# compose character but with dot7 added:

        #Hex   Dots       Dec Char Description
display \x00b4 37       # 180 Вҙ    ACUTE ACCENT
display \x00b8 67       # 184 Вё    CEDILLA
display \x00a8 57       # 168 ВЁ    DIAERESIS

# The two gender symbols are:

        #Hex   Dots       Dec Char Description
display \x00ba 7        # 186 Вә    MASCULINE ORDINAL INDICATOR
display \x00aa 8        # 170 ВӘ    FEMININE ORDINAL INDICATOR

# The three remaining characters are:

        #Hex   Dots       Dec Char Description
display \x00af 267      # 175 ВҜ    MACRON
display \x00b5 567      # 181 Вө    MICRO SIGN
display \x00a0 78       # 160 В     NO-BREAK SPACE

# The nonbreaking space is dots 7 and 8 because this presents a sequence of
# nonbreaking spaces as a smooth low line segment.
