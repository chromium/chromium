#+system: ubc-ve
# "UBC" stands for "Unified Braille Code" and is a generalization of UEB.
# See https://sabrailleauthority.org.za/unified-braille-code-ubc.

# Tshivenda is one of the 11 official languages of South Africa. It is
# spoken primarily in the Limpopo province.
#
# The language uses the roman alphabet and has five diacritic letters.
#
# The code was substantially modified between 2010 and 2012. The code
# was also unified according to the principles of the UEB. We do not
# use additional codes such as Nemeth or computer braille codes; we
# use our unified Tshivenda code also for technical material.

# This table does bidirectional translation.
#+direction: both

# This table is Maintained by Christo de Klerk <cjdk@mweb.co.za>
#-author-name: Christo de Klerk
#-maintainer-name: Christo de Klerk
#-maintainer-email: cjdk@mweb.co.za

# Apart from the addition of the diacritic  letters the grade 1 system is
# identical to UEB.

# Diacritic characters used in Tshivenda:
lowercase \x1e13 46-145 ß©ô # letter d with a circumflex below
lowercase \x1e3d 46-123 ß©¢ # letter l with a circumflex below
lowercase \x1e4b 46-1345 ß╣ï # letter n with a circumflex below
lowercase \x1e45 4-1345 ß╣à # letter n with a dot above
lowercase \x1e71 46-2345 ß╣▒ # letter t with a circumflex below

base uppercase \x1e12 \x1e13 ß©Æß©ô # letter d with a circumflex below
base uppercase \x1e3c \x1e3d ß©╝ß©¢ # letter l with a circumflex below
base uppercase \x1e4a \x1e4b ß╣èß╣ï # letter n with a circumflex below
base uppercase \x1e44 \x1e45 ß╣äß╣à # letter n with a dot above
base uppercase \x1e70 \x1e71 ß╣░ß╣▒ # letter t with a circumflex below

