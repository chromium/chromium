#largesign \x00C5 4-1      [C5] upper a ring
#largesign \x00E5   4-1      [E5] lower a ring

largesign \x00C6 1-15     [C6] upper ae
largesign \x00E6   1-15			[E6] lower ae

#largesign \x00C7 4-14     [C7] upper c cedilla
