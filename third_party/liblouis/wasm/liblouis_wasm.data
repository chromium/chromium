# -----------------------

capsletter 6
begcapsword 6-6			# uncomment if you don't want capitalization

sign \x00B7 3456			# so the line below compile
numsign 3456
midnum , 2
midnum . 3
midnum + 256
midnum - 36
midnum / 34
