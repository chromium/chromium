punctuation ! 235
display " 5
punctuation " 236
#prepunc " 236
#postpunc " 356
display ? 1456
punctuation ? 236
match %[^_~]%<* " %[_.$]*%[a#] 236
match %[a#]%[_.$]* " %>*%[^_~] 356

display # 3456
sign # 3456
display $ 1246
sign $ 4-234
display % 146
sign % 4-356
math % 3456-245-356
display & 12346
