# This is the Belarusian computer braille table.
# It is based on the Russian computer braille.

#-maintainer-name: Andrey Yakuboy

# As the definition of the grave accent sign in the Russian computer Braille conflicts with the Belarusian letter РҺ, this definition should be changed.

punctuation ` 378		GRAVE ACCENT

# There are two additional letters in the Belarusian alphabet: РҶ and РҺ.
# These letters are in the Russian computer braille table, but the letter РҺ cannot be translated back.

nofor uppercase \x040e 3467		CYRILLIC CAPITAL LETTER SHORT U
nofor lowercase \x045e 346		CYRILLIC SMALL LETTER SHORT U

include ru.ctb
UTF-8

