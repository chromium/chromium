noback pass4 @124a  @124  # â
noback pass4 @1245a @1245 # â
noback pass4 @125a  @125  # â
noback pass4 @24a   @24   # â

# superscript
# -----------

emphclass super
emphletter super 46
begemph super 46-236
endemph super 346

digit â° 245b
digit Â¹ 1b
digit Â² 12b
digit Â³ 14b
digit âŽ 145b
digit âµ 15b
digit â¶ 124b
digit â· 1245b
digit âž 125b
digit â¹ 24b

# â± âº â» âŒ âœ âŸ â¿ Âª Âº â±œ áŽ® áŽ¯ áŽ° áŽ± áŽ² áŽ³ áŽŽ áŽµ áŽ¶ áŽ· áŽž áŽ¹ áŽº áŽ» áŽŒ áŽœ áŽŸ áŽ¿ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ áµ  áµ¡

attribute super â°Â¹Â²Â³âŽâµâ¶â·âžâ¹

