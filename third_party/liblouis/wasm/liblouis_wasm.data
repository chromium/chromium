#   Unicode:  Miscellaneous Mathematical Symbols-B

sign \x29b5 46-245 вҰө   'normal' (superscript circle crossed by horizontal line)


#   Unicode:  Supplemental Mathematical Operators

sign \x2a23 45-146-5-235 вЁЈ
sign \x2a24 45-12456-5-235 вЁӨ
sign \x2ae4 46-456-25 в«Ө   reverse 'is valid' sign


#   Unicode:  Latin Extended-C

uplow \x2c63\x1d7d 4-25-1234 вұЈбөҪ


#   Unicode:  CJK Symbols and Punctuation

sign \x3003 5-2 гҖғ   ditto mark
math \x3008 4-126 гҖҲ
math \x3009 4-345 гҖү


#   Unicode:  Latin Extended-D

uplow \xa740\xa741 4-25-13 кқҖкқҒ
uplow \xa742\xa743 4-16-13 кқӮкқғ
uplow \xa750\xa751 4-25-1234 кқҗкқ‘
