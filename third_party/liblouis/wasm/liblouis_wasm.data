always ВҘ 4-13456 yen
always Вө 2-134 mu

# special character sequences
literal :// URLs
literal www.

literal .com
literal .edu
literal .gov
literal .mil
literal .net
literal .org
literal .doc
compbrl .xml
compbrl .xsl
literal .htm
literal .html
literal .tex
literal .txt
literal .gif
