include en-ueb-g1.ctb

multind 56-6 nocontractsign capsletter

seqdelimiter -вҖ”
seqdelimiter вҖҗ   \x2010
seqdelimiter вҖ‘   \x2011
seqdelimiter вҖ“   \x2013
seqdelimiter вҖ”   \x2014
seqdelimiter вҖ•   \x2015

seqbeforechars ([{"вҖң'вҖҳ
seqafterchars  )]}"вҖқ'вҖҷ.,;:.!?вҖҰ
seqafterpattern 'd
seqafterpattern 'll
seqafterpattern 're
seqafterpattern 's
seqafterpattern 't
seqafterpattern 've
seqafterpattern вҖҷd
seqafterpattern вҖҷll
seqafterpattern вҖҷre
seqafterpattern вҖҷs
seqafterpattern вҖҷt
seqafterpattern вҖҷve
#TODO:  all caps words (see lou_translateString.c:inSequence()
seqafterpattern 'D
seqafterpattern 'LL
seqafterpattern 'RE
seqafterpattern 'S
seqafterpattern 'T
seqafterpattern 'VE
seqafterexpression '([DSTdst]|ll|[rv]e|LL|[RV]E)
seqafterpattern вҖҷD
seqafterpattern вҖҷLL
seqafterpattern вҖҷRE
seqafterpattern вҖҷS
seqafterpattern вҖҷT
seqafterpattern вҖҷVE
seqafterexpression вҖҷ([DSTdst]|ll|[rv]e|LL|[RV]E)

#   10.1   Alphabetic Wordsigns
#   - 10.1.1   standing alone
#   - 10.1.2   followed by 'd, 'll, 're, 's, 't, 've and standing alone
#   - 2.6.4

#   must be before contractions?
