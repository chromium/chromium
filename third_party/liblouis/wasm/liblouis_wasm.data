# Version: Bue Vester-Andersen, 200302

### Table Metadata

#-name: Dansk forkortet 8-punkt
#-index-name: Danish, contracted, 8-dot
#-display-name: Danish 8-dot contracted braille

#+locale: da
#+type: literary
#+contraction: full
#+grade: 2
#+dots: 8
#+direction: both

#-has-nocross: yes

# Display upcodes
include da-dk-octobraille.dis

