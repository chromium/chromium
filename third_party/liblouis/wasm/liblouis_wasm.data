include text_nabcc.dis All display opcodes
include spaces.uti
include braille-patterns.cti # unicode braille.

# Arabic characters
letter ШЎ 3 # arabic individual hamza (\x0621)
letter Шў 345 # arabic alef madd (\x0622)
letter ШЈ 34 # arabic hamza above alef (\x0623)
letter ШӨ 1256 # arabic hamza on waw (\x0624)
letter ШҘ 46 # arabic hamza below alef (\x0625)
letter ШҰ 13456 # arabic hamza on iaa (\x0626)
letter Ш§ 1 # arabic Alef (\x0626)
letter ШЁ 12 # arabic baa (\x0628)
letter Ш© 16 # arabic taa marbuta (\x0629)
letter Ш« 1456 # arabic thaa (\x062B)
letter ШӘ 2345 # arabic Taa (\x062A)
letter Ш¬ 245 # arabic jeem (\x062C)
letter Шӯ 156 # arabic strong haa (\x062D)
letter Ш® 1346 # arabic Khaa (\x062E)
letter ШҜ 145 # arabic dal (\x062F)
letter Ш° 2346 # arabic thal (\x0630)
letter Шұ 1235 # arabic raa (\x0631)
letter ШІ 1356 # arabic zaai (\x0632)
letter Ші 234 # arabic seen (\x0633)
letter Шҙ 146 # arabic sheen (\x0634)
letter Шө 12346 # arabic saad (\x0635)
letter Ш¶ 1246 # arabic dhaad (\x0636)
letter Ш· 23456 # arabic strong taa (\x0637)
letter Шё 123456 # arabic strong thaa (\x0638)
letter Ш№ 12356 # arabic ayn (\x0639)
letter Шә 126 # arabic ghayn (\x063A)
letter ЩҒ 124 # arabic faa (\x0641)
letter ЩӮ 12345 # arabic strong qaaf (\x0642)
letter Щғ 13 # arabic kaaf (\x0643)
letter Щ„ 123 # arabic laam (\x0644)
letter Щ… 134 # arabic meem (\x0645)
letter ЩҶ 1345 # arabic noon (\x0646)
letter ЩҮ 125 # arabic soft haa (\x0647)
letter ЩҲ 2456 # arabic waaw (\x0648)
letter Щү 135 # arabic alef maqsoora (\x0649)
letter ЩҠ 24 # arabic iaa (\x064A)
letter ЩҺ 2 # arabic diacritic symbol fathah (\x064E)
letter Щҗ 15 # arabic diacritic symbol kasrah (\x0650)
letter ЩӢ 23 # arabic diacritic symbol tanween fath (\x064B)
letter ЩҢ 26 # arabic diacritic symbol tanween dham (\x064C)
letter ЩҚ 35 # arabic diacritic symbol tanween kasr (\x064D)
letter ЩҸ 136 # arabic diacritic symbol dhamma (\x064F)
letter Щ‘ 6 # arabic diacritic symbol shadda (\x0651)
letter Щ’ 25 # arabic diacritic symbol sukoon (\x0652)
#additional forms
letter \x067E 12 #Arabic letter Peh
letter \x0686 245 # arabic letter gtcheh ЪҶ
letter \x06a4 124 # arabic letter Veh ЪӨ
letter \x06af 13 # arabic letter gaf ЪҜ

noback sign ЩҖ 25-25 # arabic tatweel (\x0640)

always \x0644\x0627 1236 # to join lam and alef together in one cell if they come in one word
midendword \x0651 6 # to indicate that Shadda can never come at the beginning of a word
midendword \x0652 25 # arabic diacritic symbol sukoon (\x0652)
midendword ЩҺ 2

#the following to correct Shadda symbol, which should be written before the character in Arabic braille code. this will consists of every arabic character followed by the Shadda diacritic symbol, and a dot pattern of the braille shadda followed by the character.
noback always ШЎЩ‘ 6-3
noback always ШўЩ‘ 6-345
noback always ШЈЩ‘ 6-34
noback always ШӨЩ‘ 6-1256
noback always ШҘЩ‘ 6-46
noback always ШҰЩ‘ 6-13456
noback always Ш§Щ‘ 6-1
noback always ШЁЩ‘ 6-12
noback always Ш©Щ‘ 6-16
noback always Ш«Щ‘ 6-1456
noback always ШӘЩ‘ 6-2345
noback always Ш¬Щ‘ 6-245
noback always ШӯЩ‘ 6-156
noback always Ш®Щ‘ 6-1346
noback always ШҜЩ‘ 6-145
noback always Ш°Щ‘ 6-2346
noback always ШұЩ‘ 6-1235
noback always ШІЩ‘ 6-1356
noback always ШіЩ‘ 6-234
noback always ШҙЩ‘ 6-146
noback always ШөЩ‘ 6-12346
noback always Ш¶Щ‘ 6-1246
noback always Ш·Щ‘ 6-23456
noback always ШёЩ‘ 6-123456
noback always Ш№Щ‘ 6-12356
noback always ШәЩ‘ 6-126
noback always ЩҒЩ‘ 6-124
noback always ЩӮЩ‘ 6-12345
noback always ЩғЩ‘ 6-13
noback always Щ„Щ‘ 6-123
noback always Щ…Щ‘ 6-134
noback always ЩҶЩ‘ 6-1345
noback always ЩҮЩ‘ 6-125
noback always ЩҲЩ‘ 6-2456
noback always ЩҠЩ‘ 6-24
noback always Щ„Ш§Щ‘ 6-1236

punctuation ШҢ 5 # Arabic comma (\x060C)
# Arabic semi-colon: in the old standard it was dots 56; had to be changed to make way for the implementation of the
# grade 1 indicator.
punctuation \x061B 5-23
noback punctuation ; 5-23
punctuation : 5-2
punctuation \x061F 236 # Arabic question mark Шҹ
noback punctuation ? 236
punctuation \x06D4 256 # Arabic Full stop
punctuation . 256
noback punctuation , 2
punctuation ! 235
punctuation " 2356
# number sign: the old standard mapped it to 3456, but had to be changed in order to distinguish other uses beside
# preceding numbers.
sign # 456-35
# dollar sign: in the old standard it is mapped to dots 12456 but this would conflict with the contraction ЩҮЩ… in grade 2.
sign $ 4-256
punctuation % 25-1234
sign & 4-12346
noback punctuation ' 3 # apostrophe
punctuation ) 356
punctuation ( 236
sign * 56-35
math + 56-235
punctuation - 36-36
nofor punctuation - 36-0
# forward slash: originally mapped to dots 34; had to be changed so that it does not conflict with the letter \x0623
# (arabic hamza above alef)
math / 456-36

# Arabic numbers
digit \x0660 245 # 0 (Щ )
digit \x0661 1 # 1 (ЩЎ)
digit \x0662 12 # 2 (Щў)
digit \x0663 14 # 3 (ЩЈ)
digit \x0664 145 # 4 (ЩӨ)
digit \x0665 15 # 5 (ЩҘ)
digit \x0666 124 # 6 (ЩҰ)
digit \x0667 1245 # 7 (Щ§)
digit \x0668 125 # 8 (ЩЁ)
digit \x0669 24 # 9 (Щ©)
litdigit \x0660 245 # 0 (Щ )
litdigit \x0661 1 # 1 (ЩЎ)
litdigit \x0662 12 # 2 (Щў)
litdigit \x0663 14 # 3 (ЩЈ)
litdigit \x0664 145 # 4 (ЩӨ)
litdigit \x0665 15 # 5 (ЩҘ)
litdigit \x0666 124 # 6 (ЩҰ)
litdigit \x0667 1245 # 7 (Щ§)
litdigit \x0668 125 # 8 (ЩЁ)
litdigit \x0669 24 # 9 (Щ©)

# Latin numbers
include loweredDigits6Dots.uti
include litdigits6Dots.uti

# less than sign: the old standard mapped it to dots 246, which conflicted with a contraction in grade 2
math < 45-26
math = 56-2356 
# greater than sign: the old standard mapped it to dots 135, which conflicted with a character and a contraction
math > 45-35
# at sign: the old standard used dot 4; it was changed to match the UEB representation, in order to make it readable
# also in grade 2
sign @ 4-1

include latinLetterDef6Dots.uti
punctuation [ 6-236
sign \\ 45-36 # not mentioned in the Unified arabic braille code.
punctuation ] 356-3 
# caret sign: changed to match the UEB representation because dots 346 is used as a prefix for many math symbols
sign ^ 4-26
sign _ 6-36 # underscore
noback sign ` 4 # grave accent
punctuation { 5-236
# vertical bar: changed so that it can not be confused with latin letter g or the contraction of the word ЩғШ§ЩҶ
sign | 456-25
punctuation } 356-2
# tilde: the old standard mapped it to dots 45; had to be changed so that it can be read in grade 2 context
math ~ 45-25

punctuation \x00Ad 36-36 # soft hyphen

sign \x00AB 6-2356 # LEFT-POINTING DOUBLE ANGLE QUOTATION
sign \x00BB 2356-3 # RIGHT-POINTING DOUBLE ANGLE QUOTATION
noback punctuation \x2018 3 # smart single left quotation mark
noback punctuation \x2019 3 # smart single right quotation mark
punctuation \x201C 2356 # smart opening double quote
punctuation \x201D 2356 # smart closing double quote
punctuation \x201E 2356 # smart double low quotation mark
punctuation \x201F 2356 # smart double high reverse quotation mark
sign \x2329 2356 вҢ©
sign \x232A 2356 вҢӘ
math \x3008 2356 гҖҲ
math \x3009 2356 гҖү

punctuation \x00bf 45-56-236 Вҝ
sign \x00a1 45-56-235 ВЎ
math \x2212 56-36 # вҲ’ minus Ш§Щ„Ш·ШұШӯ
math \x00D7 56-236 # Г— multiplication sign
math \x2715 56-236 MULTIPLICATION SIGN
math \x00F7 56-256 # Г· division sign

sign \x200C 9 # ZERO WIDTH NON-JOINER
punctuation \x2010 36-36 # hyphen
punctuation \x2011 36-36 #  non-breaking hyphen
punctuation \x2013 5-36-36 вҖ“
punctuation \x2014 45-36-36 вҖ”
punctuation \x2015 456-36-36 вҖ•

# smart ellipsis: was changed from dots 3-3-3, so as to keep consistency with the period
punctuation \x2026 256-256-256
sign \x2022 456-256 вҖў   bullet
noback sign \x25CF 35 # BLACK CIRCLE not representing filled circle shape as it is mostly used in password fields to represent hidden characters

#additional rules
postpunc ) 356
prepunc ( 236
begnum # 456-35
midnum . 256
# the old standard assigned the math comma to dot 3, which is awkward; changed to match other braille codes and to be in
# the upper part of the cell like the numbers
midnum , 2
noback postpunc , 2
decpoint . 256
midnum - 36-36
hyphen - 36-36
postpunc ШҢ 5 # Arabic comma (\x060C)
postpunc . 256
postpunc \x06D4 256 # Arabic Full stop
postpunc ; 5-23
postpunc \x061B 5-23 # Arabic semiColon
midnum : 5-2
postpunc : 5-2
midnum / 456-36
postpunc \x061F 236 # Arabic question mark Шҹ
postpunc ? 236
endnum % 25-1234
midnum ^ 4-26

# Braille indicators
numsign 3456  number sign, just a dots operand
numericmodechars .,
nocontractsign 56
numericnocontchars Ш§ШЁШҜЩҗШЁЩҮЩҠШ¬abcdefghij

noback multind 56-6 letsign capsletter
noback capsletter 6
noback begcapsword 6-6
noback endcapsword 6-3
emphclass italic
emphclass underline
emphclass bold
noback begemph italic 46
noback endemph italic 46-46
noback begemph bold 456
noback endemph bold 456-456
# LibLouis table for both modern and ancient Greek braille
# ОөО»О»О·ОҪО№ОәПҢ ПғПҚПғП„О·ОјОұ ОјПҖПҒО¬О№Оі [Greek Braille System]
# ОәОӯОҪП„ПҒОҝ ОөОәПҖОұОҜОҙОөП…ПғО·ПӮ ОәОұО№ ОұПҖОҝОәОұП„О¬ПғП„ОұПғО·ПӮ П„П…ПҶО»ПҺОҪ [Center for Education and Rehabilitation for the Blind]
