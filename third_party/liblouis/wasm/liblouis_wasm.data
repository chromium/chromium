compbrl .tar
compbrl .gz
compbrl .bz2
compbrl .zip

# Fix input where less than / greater than already are surrounding the
# URL / email address.
noback pass2 @126-246-3 @126
noback pass2 @135-2-345 @345
noback pass2 @3456-3456 @3456-6-3456
noback pass2 @5-356-0-6-14 @5-356-6-14
noback pass2 @5-356-0-6-124 @5-356-6-124
noback pass2 @5-356-0-6-13 @5-356-6-13

# subscript
# ---------

emphclass sub
emphletter sub 16
begemph sub 16-236
endemph sub 356

digit ÔéÇ 245a
digit Ôéü 1a
digit Ôéé 12a
digit Ôéâ 14a
digit Ôéä 145a
digit Ôéà 15a
digit Ôéå 124a
digit Ôéç 1245a
digit Ôéê 125a
digit Ôéë 24a

# Ôéè Ôéï Ôéî Ôéì ÔéÄ ÔéÉ Ôéæ ÔéÆ Ôéô Ôéö Ô▒╝ ßÁó ßÁú ßÁñ ßÁÑ ßÁª ßÁº ßÁ¿ ßÁ® ßÁ¬

attribute sub ÔéÇÔéüÔééÔéâÔéäÔéàÔéåÔéçÔéêÔéë

noback pass2 %sub%sub. @16-236*
noback pass2 %sub @16*
noback pass3 %sub%sub. *@356

# fix order of sub sign and number sign
noback pass3 @3456-16-236 @16-236-3456
noback pass3 @3456-16 @16-3456

noback pass4 @245a  @245  # ÔéÇ
noback pass4 @1a    @1    # Ôéü
noback pass4 @12a   @12   # Ôéé
noback pass4 @14a   @14   # Ôéâ
noback pass4 @145a  @145  # Ôéä
noback pass4 @15a   @15   # Ôéà
noback pass4 @124a  @124  # Ôéå
noback pass4 @1245a @1245 # Ôéç
noback pass4 @125a  @125  # Ôéê
noback pass4 @24a   @24   # Ôéë

# superscript
# -----------

emphclass super
emphletter super 46
begemph super 46-236
endemph super 346

digit Ôü░ 245b
digit ┬╣ 1b
digit ┬▓ 12b
digit ┬│ 14b
digit Ôü┤ 145b
digit ÔüÁ 15b
digit ÔüÂ 124b
digit ÔüÀ 1245b
digit Ôü© 125b
digit Ôü╣ 24b

# Ôü▒ Ôü║ Ôü╗ Ôü╝ Ôü¢ Ôü¥ Ôü┐ ┬¬ ┬║ Ô▒¢ ß┤« ß┤» ß┤░ ß┤▒ ß┤▓ ß┤│ ß┤┤ ß┤Á ß┤Â ß┤À ß┤© ß┤╣ ß┤║ ß┤╗ ß┤╝ ß┤¢ ß┤¥ ß┤┐ ßÁÇ ßÁü ßÁé ßÁâ ßÁä ßÁà ßÁå ßÁç ßÁê ßÁë ßÁè ßÁï ßÁî ßÁì ßÁÅ ßÁÉ ßÁæ ßÁÆ ßÁô ßÁû ßÁù ßÁÿ ßÁÜ ßÁø ßÁØ ßÁ× ßÁƒ ßÁá ßÁí

attribute super Ôü░┬╣┬▓┬│Ôü┤ÔüÁÔüÂÔüÀÔü©Ôü╣

noback pass2 %super%super. @46-236*
noback pass2 %super @46*
noback pass3 %super%super. *@356

# fix order of super sign and number sign
noback pass3 @3456-46-236 @46-236-3456
noback pass3 @3456-46 @46-3456

noback pass4 @245b  @245  # Ôü░
noback pass4 @1b    @1    # ┬╣
noback pass4 @12b   @12   # ┬▓
noback pass4 @14b   @14   # ┬│
noback pass4 @145b  @145  # Ôü┤
noback pass4 @15b   @15   # ÔüÁ
noback pass4 @124b  @124  # ÔüÂ
noback pass4 @1245b @1245 # ÔüÀ
noback pass4 @125b  @125  # Ôü©
noback pass4 @24b   @24   # Ôü╣

# 9.6 Percent/promille
noback context [$s]"%" ?
noback context [$s]"ÔÇ░" ?
noback context "%"[")"] @6-356
noback context "ÔÇ░"[")"] @6-356

# 11.3 Pound sign
noback joinnum \x00A3 123
