#-maintainer-name: Andrey Yakuboy

# As some Russian punctuation definitions conflict with Ukrainian letters, these definitions should be changed.

punctuation @ 3578		COMMERCIAL AT
punctuation ? 2567		QUESTION MARK
punctuation ( 358		LEFT PARENTHESIS
punctuation ) 267		RIGHT PARENTHESIS
punctuation ~ 23568		TILDE

# There are the Ukrainian letters in the Russian table, but they cannot be translated back
#    except "Ð"

nofor uppercase \x0404 3457		CYRILLIC CAPITAL LETTER UKRAINIAN IE
nofor uppercase \x0407 14567		CYRILLIC CAPITAL LETTER YI
nofor lowercase \x0454 345		CYRILLIC SMALL LETTER UKRAINIAN IE
nofor lowercase \x0457 1456		CYRILLIC SMALL LETTER YI
nofor uppercase \x0490 124567		CYRILLIC CAPITAL LETTER GHE WITH UPTURN
nofor lowercase \x0491 12456		CYRILLIC SMALL LETTER GHE WITH UPTURN

punctuation \x20b4 2578		HRYVNIA SIGN

