punctuation ) 345		RIGHT PARENTHESIS
punctuation , 2		COMMA
punctuation - 36		HYPHEN-MINUS
punctuation . 256		FULL STOP
punctuation : 25		COLON
punctuation ; 23		SEMICOLON
