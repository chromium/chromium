#--------------------- ALL CHARS DEFINITIONS -------------------------------------------

punctuation ! 235					# EXCLAMATION MARK
punctuation â¢ 3					# BULET
sign + 235							# PLUS SIGN
midnum + 235						# PLUS SIGN
punctuation ? 26					# QUESTION MARK
