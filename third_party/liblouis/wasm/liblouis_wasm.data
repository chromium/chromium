sign вҖһ 56

include fr-bfu-comp6.utb

attribute con bcГ§dfghjklmnpqrstvwxzBCГҮDFGHJKLMNPQRSTVWXZ
attribute voy aeiouyГ©Г ГЁГ№ГўГӘГ®ГҙГ»Г«ГҜГјЕ“AEIOUYГүГҖГҲГҷГӮГҠГ„ГӢГҸГңЕ’
attribute bmp bmpBMP
attribute apost '\x2018\x2019

#Pour dГ©sabrГ©ger, il nous faut une classe contenant les consonnes et les abrГ©viations commenГ§ant par une consonne
attribute conabr bcГ§dfghjklmnpqrstvwxzBCГҮDFGHJKLMNPQRSTVWXZв ҳв Ҷв ·в ©в ’в №в ¶в »в ёв «в –в ҙ
#Pour dГ©sabrГ©ger, extension de la classe bmp aux abrГ©viations commenГ§ant par b, m ou p
attribute bmpabr bmpBMPв ҳв Ҷв «в –

#Pour dГ©sabrГ©ger, il nous faut une classe contenant les voyelles et les abrГ©viations commenГ§ant par une voyelle exceptГ© celles dont la reprГ©sentation peut ГӘtre confondue avec un chiffre
attribute bvoy aeiouyГ©Г ГЁГ№AEIOUYГүГҖГҲГҷЕ“Е’в Ҳв …в ңв ўв Ұв җв Ёв өв  в ҫв әв ¬в ё

#Pour dГ©sabrГ©ger, une classe contenant les abrГ©viations identiques aux chiffres ou Г  certains opГ©rateurs
attribute bvoyy в јв Ўв Јв ©в №в ұв «в »в ів Әв Ів Ңв Ӯв ”
#Enfin, une classe regroupant les deux prГ©cГ©dentes pour simplifier certaines rГЁgles
attribute bvoyyy aeiouyГ©Г ГЁГ№AEIOUYГүГҖГҲГҷЕ“Е’в Ҳв …в ңв ўв Ұв җв Ёв өв  в ҫв әв ¬в °в ёв јв Ўв Јв ©в №в ұв «в »в ів Әв Ів Ңв Ӯв ”

#En dГ©sabrГЁgement, cette classe permet de savoir si nous sommes dans une opГ©ration mathГ©matique ou non
attribute frmath в ¬в јв Ўв Јв ©в №в ұв «в »в ів Әв Ӯв Ҷв ’в Ів –в ¶в Ұв ”в ҙв Өв „в җв  в Ңв ҳв ·в ҫв ңв ғв Ёв Ҳ
attribute puncEnd в Ӯ,;:.?!")]}
attribute urlPuncs :./

