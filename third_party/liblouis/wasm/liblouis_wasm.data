sign \x00Ea 12456
sign \x00EB 46-346
sign \x00EC 346

# for quotes and other signs
punctuation \x00C9 236
punctuation \x2026 256-256-256
punctuation \x2018 3
punctuation \x2019 3

include digits6Dots.uti

punctuation : 25
punctuation ; 23
sign < 246
sign = 2356
sign > 135
punctuation ? 26
sign @ 2346

