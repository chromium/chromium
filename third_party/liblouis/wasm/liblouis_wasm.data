always \x0637\x0651 6-23456                      ),               ,)
always \x0688\x0650\x0651 6-346-15               +E,              ,+E
always \x062A\x062A\x064E\x0651 6-2345-2345-2    TTE,             ,TTE
always \x062A\x0650\x0651 15-6-2345              TE,              E,T

