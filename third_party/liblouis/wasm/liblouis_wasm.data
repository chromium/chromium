# the hyphen
always \sвҖ“\s 36-36
#always - 36
repeated ВӯВӯВӯ 36-36-36
always \sВӯ\s 36-36
midword - 36
joinword - 36
begword - 36
hyphen - 36



# mathematical symbols
#decpoint . 2 # removed to sort out translations such as p.11
noback always < 246
joinword = 56-2356
joinnum = 56-2356
noback always > 135
midnum + 0-56-235-3456
