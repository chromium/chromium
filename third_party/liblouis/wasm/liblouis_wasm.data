uplow \xa758\xa759 4-16-12345 кқҳкқҷ
uplow \xa75e\xa75f 4-16-1236 кқһкқҹ
uplow \xa798\xa799 4-25-124 кһҳкһҷ


#   Unicode:  Latin Extended-D

lowercase \xfb00 124-45-235-124 п¬Җ
lowercase \xfb01 124-45-235-24 п¬Ғ
#\xfb02 п¬ғ
#\xfb03 п¬„
lowercase \xfb05 124-45-235-2345 п¬…
lowercase \xfb06 234-45-235-2345 п¬Ҷ


#   Unicode:  Cyrillic
