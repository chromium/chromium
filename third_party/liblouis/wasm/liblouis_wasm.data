include nl-g0.uti

# Rules where nl-NL-g0.utb and nl-BE-g0.utb differ from each other,
# because either not or ambiguously defined in the Dutch braille
# standard of 2005.

# Foreign letters Гғ, Г• (Portuguese), Г…, ГҶ, Гҳ (Norwegian/Danish/Finnish), ГҢ (Italian)
# Clear definition missing from standard
# Belgium uses the definitions from the various languages, see [2]
# CBB uses the letters without accent, see В§2.7 Beklemtoonde klinkers [1]
# CBB suggests dots "246" for letter o with stroke, see Norway, p. 101 [2]

uplow       \x00C3\x00E3  345,345             ГғГЈ                  LATIN CAPITAL LETTER A WITH TILDE - LATIN SMALL LETTER A WITH TILDE
uplow       \x00C5\x00E5  345,345             Г…ГҘ                  LATIN CAPITAL LETTER A WITH RING ABOVE - LATIN SMALL LETTER A WITH RING ABOVE
uplow       \x00C6\x00E6  345,345             ГҶГҰ                  LATIN CAPITAL LETTER AE - LATIN SMALL LETTER AE
uplow       \x00CC\x00EC  34,34               ГҢГ¬                  LATIN CAPITAL LETTER I WITH GRAVE - LATIN SMALL LETTER I WITH GRAVE
uplow       \x00D5\x00F5  246,246             Г•Гө                  LATIN CAPITAL LETTER O WITH TILDE - LATIN SMALL LETTER O WITH TILDE

# Left and right curly brackets
# Definition missing from standard
# Belgium and Dedicon use dots "12356" and "23456"
# CBB uses "46" and "3456" but suggests dots "6-12356" and "6-23456", see Norway, p. 101 [2]

punctuation \x007B        12356               {                   LEFT CURLY BRACKET
punctuation \x007D        23456               }                   RIGHT CURLY BRACKET

# Greek letters
# Clear definition missing from standard
# The Netherlands use the definitions from Greek (International), p. 185 [2] and rule В§2.2 Alfabetwisselingsteken [1]
# Belgium uses prefix "456" for capital letters
# Belgium uses dots "345" for letter eta
# Belgium uses dots "13456" for letter upsilon
# Belgium uses dots "125" for letter chi
# Belgium uses dots "12346" for letter psi
# Belgium uses dots "245" for letter omega

letter      \x0391        456-1               О‘                   GREEK CAPITAL LETTER ALPHA
letter      \x0392        456-12              О’                   GREEK CAPITAL LETTER BETA
letter      \x0393        456-1245            О“                   GREEK CAPITAL LETTER GAMMA
letter      \x0394        456-145             О”                   GREEK CAPITAL LETTER DELTA
letter      \x0395        456-15              О•                   GREEK CAPITAL LETTER EPSILON
letter      \x0396        456-1356            О–                   GREEK CAPITAL LETTER ZETA
letter      \x0397        456-345             О—                   GREEK CAPITAL LETTER ETA
letter      \x0398        456-1456            Оҳ                   GREEK CAPITAL LETTER THETA
letter      \x0399        456-24              Оҷ                   GREEK CAPITAL LETTER IOTA
letter      \x039A        456-13              Оҡ                   GREEK CAPITAL LETTER KAPPA
letter      \x039B        456-123             Оӣ                   GREEK CAPITAL LETTER LAMDA
letter      \x039C        456-134             Оң                   GREEK CAPITAL LETTER MU
letter      \x039D        456-1345            Оқ                   GREEK CAPITAL LETTER NU
letter      \x039E        456-1346            Оһ                   GREEK CAPITAL LETTER XI
letter      \x039F        456-135             Оҹ                   GREEK CAPITAL LETTER OMICRON
letter      \x03A0        456-1234            О                    GREEK CAPITAL LETTER PI
letter      \x03A1        456-1235            ОЎ                   GREEK CAPITAL LETTER RHO
letter      \x03A3        456-234             ОЈ                   GREEK CAPITAL LETTER SIGMA
letter      \x03A4        456-2345            ОӨ                   GREEK CAPITAL LETTER TAU
letter      \x03A5        456-13456           ОҘ                   GREEK CAPITAL LETTER UPSILON
letter      \x03A6        456-124             ОҰ                   GREEK CAPITAL LETTER PHI
letter      \x03A7        456-125             О§                   GREEK CAPITAL LETTER CHI
letter      \x03A8        456-12346           ОЁ                   GREEK CAPITAL LETTER PSI
