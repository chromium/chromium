display } 12456
punctuation } 456-345
display | 1256
sign | 456-1256
display { 246
punctuation { 456-126
display ~ 45
math ~ 4-35
punctuation \x17D4 123456
punctuation \x201C 236
punctuation \x201D 356

include braille-patterns.cti



# two special cases, not put v infront of subscript consonants
#match - \x17D2\x178B - 36-23456
