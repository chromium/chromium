include no-no-g0.utb
capsnocont
#------------------------------------------------------
# -------------- level 1 contractions -----------------
#------------------------------------------------------
endword ar 3456
word at 1
word ble 12
word de 1456
endword de 1456
word du 145
word eg 1245
word eller 15
word ellers 15-234
word en 126
endword en 126
word ende 126-1456
endword ende 126-1456
word er 156
endword er 156
word et 346
endword et 346
word etter 1356
begword etter 1356
word etterat 1356-1
word ettersom 1356-234
word etterpГҘ 1356-1234

word for 1246											# level 1 contractions
endword for 1246
begword for 1246
word forat 1246-1
word forfra 1246-124
word forover 1246-1346
word forlike 1246-123

word forhold 12346
endword forhold 12346
begword forhold 12346

word forholdsvis 12346-1236

word fra 124											# level 1 contractions
word fГёr 246
word gjennom 12456
begword gjennom 12456
endword gjennom 12456
word gjennomfГёr 12456-246

word han 125
word hans 125-234
word har 1235
word hun 136
word hvor 2456
begword hvor 2456

word ikke 24-13										# level 1 contractions
word ikkje 24-13-245
word jeg 245
word kan 13
word like 123
word mange 134
word med 146
word mye 13456
word nГҘr 1345

word og 14												# level 1 contractions
word ogsГҘ 14-234
word oss 135										
word over 1346
begword over 1346
word overfor 1346-1246
word overpГҘ 1346-1234
word overunder 1346-12345
word overfГёr 1346-246
word overvГҰre 1346-345
word overvar 1346-3456

word pГҘ 1234
word som 234
word til 2345
word under 12345
begword under 12345
word underer 12345-345
word underet 12345-346
word underfra 12345-124
word undersom 12345-234
word undertil 12345-2345

word var 3456
word ved 1236
word vГҰre 345											# level 1 contractions

letsign 56
noletsign i
noletsign I
noletsign ГҘ
noletsign Г…
noletsign Г 
noletsign ГЎ
#noletsignbefore '.
noletsignafter :.

# Remove dot 56 before e-post (email)
noback pass2 @56-15-36-1234-135-234-2345 @15-36-1234-135-234-2345
noback pass2 @56-6-15-36-1234-135-234-2345 @6-15-36-1234-135-234-2345

