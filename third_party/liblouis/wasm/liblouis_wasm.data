always \x0644\x0627 123-1					#[Peter EngstrÃ¶m 2011-02-08]
always \x0640\x0640\x0640\x064F 136
always \x0640\x0640\x0640\x064B 23
always \x0640\x0640\x0640\x064C 26


include countries.cti
#undefined 123456

# Braille indicators
numsign 3456  number sign, just a dots operand
multind 56-6 letsign capsletter
capsletter 6
begcapsword 6-6
endcapsword 6-3
emphclass italic
emphclass underline
emphclass bold
begemph italic 46
endemph italic 46-46
begemph bold 456
endemph bold 456-456
begcomp 456-346
endcomp 456-156

# the decimal digits
include litdigits6Dots.uti

# Letters are defined in en-chardefs
# punctuation

prepunc ) 356
postpunc ( 236

prepunc " 236	#[Peter EngstrÃ¶m 2011-03-15]
postpunc " 236	#[Peter EngstrÃ¶m 2011-03-15]

prepunc ' 3		#[Peter EngstrÃ¶m 2011-03-15]
postpunc ' 3	#[Peter EngstrÃ¶m 2011-03-15]
word 'em = 
word 'tis =
word 'twas =
begnum # 3456 print number sign before number #[Peter EngstrÃ¶m 2011-03-15]
midnum , 46
postpunc , 46
decpoint . 46
midnum - 36
hyphen - 36
#capsnocont
postpunc . 256
postpunc ; 5		#[Peter EngstrÃ¶m 2011-03-15]
midnum : 5-2		#[Peter EngstrÃ¶m 2011-03-15]
postpunc : 5-2		#[Peter EngstrÃ¶m 2011-03-15]
postpunc ! 235
midnum / 34
noback always / 34
#always < 0-135-0	#[Peter EngstrÃ¶m 2011-03-15]
# always > 0-246-0
postpunc ? 1456		#[Peter EngstrÃ¶m 2011-03-15]
endnum % 1234		#[Peter EngstrÃ¶m 2011-03-15]
midnum ^ 346		#[Peter EngstrÃ¶m 2011-03-15]
noback always ^ 45			#[Peter EngstrÃ¶m 2011-03-15]
noback always ~ 45
noback always & 12346		#[Peter EngstrÃ¶m 2011-03-15]
midnum * 16			#[Peter EngstrÃ¶m 2011-03-15]
noback always * 16			#[Peter EngstrÃ¶m 2011-03-15]
noback always [ 13456		#[Peter EngstrÃ¶m 2011-03-15]
noback always ] 12346		#[Peter EngstrÃ¶m 2011-03-15]
noback always { 135		#[Peter EngstrÃ¶m 2011-03-15]
noback always } 246		#[Peter EngstrÃ¶m 2011-03-15]
prepunc ` 6-236
noback always @ 4
always \\ 1256		#[Peter EngstrÃ¶m 2011-03-15]
noback always | 1245
always ... 3-3-3
always .\s.\s. 3-3-3 . . .
noback always $ 1246		#[Peter EngstrÃ¶m 2011-03-15]

