word ÔÇÖuns 3-136-1345-234
endword 've 3-1236-15
endword ÔÇÖve 3-1236-15
midnum , 3
noback always , 2
midnum . 2
#decpoint . 2 # removed to sort out translations such as p.11
noback always . 256
noback always ; 23
