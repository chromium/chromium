#-index-name: Hebrew, Israel
#-display-name: Israeli braille

#+locale: mul-IL
#+type: literary
#+dots: 6
#+contraction: no
#+grade: 1
# Marked as "direction:forward" by Bue Vester-Andersen
# as tests only run forward.
#+direction:forward

# This table was created by Erez Kugler from TSR Gaash, Inc. with the
# assistance of BAUM Engineering.

#-license: LGPLv2.1
#-author-name: BAUM Engineering
#-author-email: liblouis@baum.ro
#-author-name: Erez Kugler
#-author-email: erez@tsr-gaash.com

# The 4 most used languages in Israel are Hebrew, Arabic, Russian and
# English. This table supports 3 of them: Hebrew, Arabic and
# English. The native braille codes of these languages differ in how
# they treat certain punctuation marks etc. The library for the blind
# and the ministry of education sat together in 2016 and decided how
# to combine the 3 languages in a single braille code. This table is
# the result of their decision.

# Refer to World Braille Usage (3rd edition), page 74
# <http://liblouis.org/braille-specs/world-braille-usage-third-edition.pdf>
# and <http://liblouis.org/braille-specs/hebrew>.

# Braille indicators
numsign 3456  number sign, just a dots operand

capsletter 6
begcapsword 6-6
endcapsword 6-3

# literary forms of the decimal digits
include litdigits6Dots.uti

# display/passthrough for unicode braille
include braille-patterns.cti

# punctuation
prepunc ( 2356
postpunc ) 2356
prepunc [ 6-2356
postpunc ] 2356-3
prepunc { 12346
postpunc } 13456
prepunc " 236
postpunc " 356
prepunc ` 6-236
prepunc ' 6-236
postpunc ' 356-3
begnum # 456-1456
punctuation , 2
decpoint . 46
postpunc . 256
punctuation ; 23
punctuation : 25
punctuation ! 235
math < 25-246
math > 135-25
punctuation ? 26
endnum st 34
endnum nd 1345-145
endnum rd 1235-145
endnum th 1456
endnum 's 3-234
always % 25-1234
sign ^ 45
midnum * 4-16
sign * 35-35
sign @ 4
sign \\ 1256

include en-chardefs.cti All character definition opcodes

# Single quote is defined in chardefs.
word ' 4-3
word 'em =
word 'tis =
word 'twas =

# Additional fixes for hebrew letters with dagesh
# if the dagesh dot is typed as a separate element.
word ЧӣЦј 13 # Hebrew letter PE with dagesh as a separate dot.
word ЧӨЦј 1234 # Hebrew letter KAF with dagesh as a separate dot.
word Ч‘Цј 12 # Hebrew letter BET with dagesh as a separate dot.
word Ч©ЧӮ 156 # Hebrew letter SHIN with SIN as a separate dot.

