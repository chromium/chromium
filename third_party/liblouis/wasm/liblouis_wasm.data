# ----------------------------------------------------------------------------------------------
# Braille indicator opcodes
# ----------------------------------------------------------------------------------------------

numsign  3456
capsletter  6
begcapsword  56
endcapsword  5

# ----------------------------------------------------------------------------------------------
# Literary digits
# ----------------------------------------------------------------------------------------------

include litdigits6Dots.uti

# ----------------------------------------------------------------------------------------------
# Decimal points, hyphens
# ----------------------------------------------------------------------------------------------

decpoint  \x002C  2
decpoint  \x002E  3
hyphen    \x002D  36

# ----------------------------------------------------------------------------------------------
# Letter prefix in numbers
# ----------------------------------------------------------------------------------------------

attribute    digitletter                 abcdefghij
noback context  $d[]%digitletter            @5
noback context  $d"."[]%digitletter         @5
noback context  $d","[]%digitletter         @5

# ----------------------------------------------------------------------------------------------
#  liblouis: English, U.S. (EBAE) emphasis definitions
#
#  Based on the Linux screenreader BRLTTY, copyright (C) 1999-2006 by
#  The BRLTTY Team
