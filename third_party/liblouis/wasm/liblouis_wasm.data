include mn-MN-common.cti
include en-ueb-g2.ctb
#-index-name: Khmer
#-display-name: Khmer braille
#
#+locale: km
#+type: literary
#+contraction: no
#+grade: 1
#+dots: 6
#+direction: both
#+system: cambodia
#
#-copyright: Sao Mai Center for the Blind <www.saomaicenter.org/en>
#-license: LGPLv2.1
#
