match %[^_]|[\x0022\x0028\x0027\x007B\x005B] vГ  %[_^.] 23456
#match %[^_]|[\x0022\x0028\x0027\x007B\x005B] б»ҹ %[_^.] 26
match %[^_]|[\x0022\x0028\x0027\x007B\x005B] vГ o %[_^.] 23456-135
match %[^_]|[\x0022\x0028\x0027\x007B\x005B] mГ  %[_^.] 12345
