# The Bashkir braille code was created by Makarim Tukhvatshin in the
# early 60's. There is no official documentation on the braille code
# that we know of.

# Bashkir braille is largely the same as Russian braille
include ru-litbrl.ctb


# The Bashkir alphabet has 9 letters that are not in the Russian
# alphabet, namely Ëÿ, Ë¿, Êá, ÊÆ, Ê¬, Êÿ, Ê║, Ê« and Êó. Like in ru-chardefs.cti, the
# following definitions have dot 9 set to make them distinguishable
# from the Latin letters.
uppercase \x04D8 34579   CYRILLIC LETTER ├ª Ëÿ
uppercase \x04E8 12679   CYRILLIC LETTER ├© Ë¿
uppercase \x04A0 14679   CYRILLIC LETTER q Êá
uppercase \x0492 1245679 CYRILLIC LETTER ╔ú ÊÆ
uppercase \x04AA 3479    CYRILLIC LETTER ╬© Ê¬
uppercase \x0498 34679   CYRILLIC LETTER ├░ Êÿ
uppercase \x04BA 123679  CYRILLIC LETTER h Ê║
uppercase \x04AE 1345679 CYRILLIC LETTER y Ê«
uppercase \x04A2 145679  CYRILLIC LETTER ┼ï Êó
lowercase \x04D9 3459    CYRILLIC LETTER ├ª ËÖ
lowercase \x04E9 1269    CYRILLIC LETTER ├© Ë®
lowercase \x04A1 1469    CYRILLIC LETTER q Êí
lowercase \x0493 124569  CYRILLIC LETTER ╔ú Êô
lowercase \x04AB 349     CYRILLIC LETTER ╬© Ê½
lowercase \x0499 3469    CYRILLIC LETTER ├░ ÊÖ
lowercase \x04BB 12369   CYRILLIC LETTER h Ê╗
lowercase \x04AF 134569  CYRILLIC LETTER y Ê»
lowercase \x04A3 14569   CYRILLIC LETTER ┼ï Êú

# Extend classes defined in ru-litbrl.ctb
attribute uppercyrillic \x04D8\x04E8\x04A0\x0492\x04AA\x0498\x04BA\x04AE\x04A2
attribute lowercyrillic \x04D9\x04E9\x04A1\x0493\x04AB\x0499\x04BB\x04AF\x04A3

# Unicode braille patterns
include braille-patterns.cti
