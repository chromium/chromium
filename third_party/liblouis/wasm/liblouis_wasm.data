nofor context #4=2@1356 "Р—"
nofor context #4=2@24 "Рҳ"
nofor context #4=2@12346 "Рҷ"
nofor context #4=2@13 "Рҡ"
nofor context #4=2@123 "Рӣ"
nofor context #4=2@134 "Рң"
nofor context #4=2@1345 "Рқ"
nofor context #4=2@135 "Рһ"
nofor context #4=2@1234 "Рҹ"
nofor context #4=2@1235 "Р "
nofor context #4=2@234 "РЎ"
nofor context #4=2@2345 "Рў"
nofor context #4=2@136 "РЈ"
nofor context #4=2@124 "РӨ"
nofor context #4=2@125 "РҘ"
nofor context #4=2@14 "РҰ"
nofor context #4=2@12345 "Р§"
nofor context #4=2@156 "РЁ"
nofor context #4=2@1346 "Р©"
nofor context #4=2@12356 "РӘ"
nofor context #4=2@2346 "Р«"
nofor context #4=2@23456 "Р¬"
nofor context #4=2@246 "Рӯ"
nofor context #4=2@1256 "Р®"
nofor context #4=2@1246 "РҜ"

nofor context !#4=0[!%uppercyrillic] *#4=0

# Latin letters
nofor context [@6] #5=1			# Input a Latin lowercase letter

nofor context #5=1@1 "a"
nofor context #5=1@12 "b"
nofor context #5=1@14 "c"
nofor context #5=1@145 "d"
nofor context #5=1@15 "e"
nofor context #5=1@124 "f"
