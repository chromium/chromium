From ddc7bc724c358b0afc4bd7244f7b48865d0435d1 Mon Sep 17 00:00:00 2001
From: Alexander Cooper <alcooper@chromium.org>
Date: Thu, 27 Feb 2025 13:00:14 -0800
Subject: [PATCH 2/3] Remove dependency on deprecated method in cardboard
 sensors

---
 .../sensors/android/device_accelerometer_sensor.cc   |  8 ++++----
 .../sdk/sensors/android/device_gyroscope_sensor.cc   | 12 ++++++------
 2 files changed, 10 insertions(+), 10 deletions(-)

diff --git a/third_party/cardboard/src_overrides/sdk/sensors/android/device_accelerometer_sensor.cc b/third_party/cardboard/src_overrides/sdk/sensors/android/device_accelerometer_sensor.cc
index def2735d8213e..2462400f57542 100644
--- a/third_party/cardboard/src_overrides/sdk/sensors/android/device_accelerometer_sensor.cc
+++ b/third_party/cardboard/src_overrides/sdk/sensors/android/device_accelerometer_sensor.cc
@@ -13,7 +13,7 @@
  * See the License for the specific language governing permissions and
  * limitations under the License.
  */
-#include "sensors/device_accelerometer_sensor.h"
+#include "third_party/cardboard/src/sdk/sensors/device_accelerometer_sensor.h"
 
 #include <android/looper.h>
 #include <android/sensor.h>
@@ -22,8 +22,8 @@
 #include <memory>
 #include <mutex>  // NOLINT
 
-#include "util/constants.h"
-#include "util/logging.h"
+#include "third_party/cardboard/src/sdk/util/constants.h"
+#include "third_party/cardboard/src/sdk/util/logging.h"
 
 // Workaround to avoid the inclusion of "android_native_app_glue.h.
 #ifndef LOOPER_ID_USER
@@ -56,7 +56,7 @@ const ASensor* InitSensor(ASensorManager* sensor_manager) {
 
 bool PollLooper(int timeout_ms, int* num_events) {
   void* source = nullptr;
-  const int looper_id = ALooper_pollAll(timeout_ms, NULL, num_events,
+  const int looper_id = ALooper_pollOnce(timeout_ms, NULL, num_events,
                                         reinterpret_cast<void**>(&source));
   if (looper_id != LOOPER_ID_USER) {
     return false;
diff --git a/third_party/cardboard/src_overrides/sdk/sensors/android/device_gyroscope_sensor.cc b/third_party/cardboard/src_overrides/sdk/sensors/android/device_gyroscope_sensor.cc
index eaa279be53bd1..3e9f70bffbe1a 100644
--- a/third_party/cardboard/src_overrides/sdk/sensors/android/device_gyroscope_sensor.cc
+++ b/third_party/cardboard/src_overrides/sdk/sensors/android/device_gyroscope_sensor.cc
@@ -13,7 +13,7 @@
  * See the License for the specific language governing permissions and
  * limitations under the License.
  */
-#include "sensors/device_gyroscope_sensor.h"
+#include "third_party/cardboard/src/sdk/sensors/device_gyroscope_sensor.h"
 
 #include <android/looper.h>
 #include <android/sensor.h>
@@ -21,10 +21,10 @@
 
 #include <memory>
 
-#include "sensors/accelerometer_data.h"
-#include "sensors/gyroscope_data.h"
-#include "util/constants.h"
-#include "util/logging.h"
+#include "third_party/cardboard/src/sdk/sensors/accelerometer_data.h"
+#include "third_party/cardboard/src/sdk/sensors/gyroscope_data.h"
+#include "third_party/cardboard/src/sdk/util/constants.h"
+#include "third_party/cardboard/src/sdk/util/logging.h"
 
 // Workaround to avoid the inclusion of "android_native_app_glue.h.
 #ifndef LOOPER_ID_USER
@@ -87,7 +87,7 @@ const ASensor* InitSensor(ASensorManager* sensor_manager) {
 
 bool PollLooper(int timeout_ms, int* num_events) {
   void* source = nullptr;
-  const int looper_id = ALooper_pollAll(timeout_ms, NULL, num_events,
+  const int looper_id = ALooper_pollOnce(timeout_ms, NULL, num_events,
                                         reinterpret_cast<void**>(&source));
   if (looper_id != LOOPER_ID_USER) {
     return false;
