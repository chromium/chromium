import("//third_party/protobuf/proto_library.gni")

config("confidential_compute_include") {
  include_dirs = [ "src" ]
}

proto_library("signed_endorsements_proto") {
  sources = [ "src/fcp/protos/confidentialcompute/signed_endorsements.proto" ]

  proto_deps = [ "//third_party/oak:endorsement_proto" ]

  import_dirs = [ "//third_party/oak/src" ]

  cc_generator_options = "lite"
}

proto_library("confidential_encryption_config_proto") {
  sources =
      [ "src/fcp/protos/federatedcompute/confidential_encryption_config.proto" ]

  proto_deps = [
    "//third_party/oak:endorsement_proto",
    "//third_party/oak:evidence_proto",
  ]

  import_dirs = [
    "//third_party/oak/src",
    "//third_party/protobuf/src",
  ]

  cc_generator_options = "lite"
}

proto_library("data_upload_config_proto") {
  sources = [ "src/fcp/protos/confidentialcompute/data_upload_config.proto" ]

  proto_deps = [
    ":confidential_encryption_config_proto",
    ":signed_endorsements_proto",
    "//third_party/oak:endorsement_proto",
    "//third_party/oak:eventlog_proto",
    "//third_party/oak:evidence_proto",
    "//third_party/protobuf:any_proto",
  ]

  link_deps = [
    ":confidential_encryption_config_proto",
    ":signed_endorsements_proto",
    "//third_party/oak:endorsement_proto",
    "//third_party/oak:eventlog_proto",
    "//third_party/oak:evidence_proto",
    "//third_party/protobuf:any_proto",
  ]

  import_dirs = [
    "src",
    "//third_party/oak/src",
    "//third_party/protobuf/src",
  ]

  cc_generator_options = "lite"
}

group("confidential_compute_proto") {
  public_deps = [
    ":confidential_encryption_config_proto",
    ":data_upload_config_proto",
    ":signed_endorsements_proto",
  ]
}

source_set("confidential_compute") {
  public = [
    "src/fcp/base/base_name.h",
    "src/fcp/base/digest.h",
    "src/fcp/base/monitoring.h",
    "src/fcp/confidentialcompute/cose.h",
    "src/fcp/confidentialcompute/crypto.h",
  ]

  sources = [
    "src/fcp/base/base_name.cc",
    "src/fcp/base/digest.cc",
    "src/fcp/base/monitoring.cc",
    "src/fcp/confidentialcompute/cose.cc",
    "src/fcp/confidentialcompute/crypto.cc",
  ]

  configs -= [ "//build/config/compiler:chromium_code" ]
  configs += [ "//build/config/compiler:no_chromium_code" ]

  public_configs = [ ":confidential_compute_include" ]

  public_deps = [ ":confidential_compute_proto" ]

  deps = [
    "//third_party/abseil-cpp:absl",
    "//third_party/boringssl",
  ]
}
