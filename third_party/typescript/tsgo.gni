  _platform_dir = "linux-amd64"
  _binary_name = "tsgo"
} else if (host_os == "mac") {
  if (host_cpu == "arm64") {
    _platform_dir = "mac-arm64"
  } else {
    _platform_dir = "mac-amd64"
  }
  _binary_name = "tsgo"
} else if (host_os == "win") {
  _platform_dir = "windows-amd64"
  _binary_name = "tsgo.exe"
}

assert(defined(_platform_dir), "Did not find binary for host_os='${host_os}'")

tsgo_inputs = [
